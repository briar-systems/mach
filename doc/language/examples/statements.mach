// assume `std.io.print` is a function that exists in the `io` module of the `std` module (standard library)

// use statement module level
use std;

// use statement submodule level
use std.io;

// use statement object level
use std.io.print;

// use statement object level with alias
use std.io.print as print_alias;

// type definition basic
def t_number: u32;

// type definition fixed array
def t_fixed_array: [2]u32;

// type definition boundless array
def t_boundless_array: []u32;

// type definition function
def t_function: fun(u32): u32;

// variable declaration basic
var a: u32;

// value declaration basic
val b: u32 = 0;

// function definition
fun f_basic(x: u32): u32 {
    ret x;
};

// struct definition
str s_basic {
    x: u32,
    y: u32,
};

// union definition
uni u_basic {
    a: u32,
    b: f32,
};
