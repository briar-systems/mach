// dummy type definitions for clarity
def t_fixed_array: [2]u32;
def t_function:    fun(u32): u32;

str t_struct {
    x: u32,
    y: u32
};

uni t_union {
    a: u32,
    b: f32
};

fun t_function_impl(x: u32): u32 {
    ret x;
};

// NOTE: value (using `val` has identical syntax to variable declaration)

// basic variable declaration without initialization
var a: u32;

// basic variable declaration with initialization
var b: u32 = 0;

// variable declaration unnamed array type fixed size with full initialization
var c: [2]u32 = [0, 0];

// variable declaration unnamed array type dynamic size with initialization
var d: []u32 = [0, 0];

// variable declaration named array type fixed size with full initialization
var e: t_fixed_array = [0, 0];

// variable declaration named array type fixed size with partial initialization
var f: t_fixed_array = [0];

// variable declaration named struct type without initialization
var g: t_struct;

// variable declaration named struct type with initialization
var h: t_struct = t_struct {
    x = 0,
    y = 0
};

// variable declaration unnamed struct type with initialization
var i: str {
    x: u32,
    y: u32
} = str {
    x = 0,
    y = 0
};

// variable declaration named union type with initialization
var j: t_union = t_union {
    a = 0
};

// variable declaration unnamed union type with initialization
var k: uni {
    a: u32,
    b: f32
} = uni {
    a = 0
};

// variable declaration named function type with initialization
var l: t_function = t_function_impl;

// variable declaration unnamed function type with initialization
var m: fun(u32): u32 = t_function_impl;

// NOTE: Mach does not currently support anonymous functions

// struct member access
var n: u32 = h.x;

// struct member assignment
h.x = 1;

// union member access
var o: u32 = j.a;

// union member assignment
j.a = 1;

// array element access
var p: u32 = e[0];

// array element assignment
e[0] = 1;

// function call
var q: u32 = l(0);
