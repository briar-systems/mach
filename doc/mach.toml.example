# Example mach.toml for standalone projects
# This file demonstrates how to configure a Mach project
# outside of the main mach repository.

[project]
name = "my_project"
version = "0.1.0"
entrypoint = "main.mach"

[directories]
src = "src"
out = "out"

[deps]
# Standard library path using environment variable (recommended)
# Set MACH_STD=/path/to/mach/std in your environment
# Or use --std /path/to/mach/std flag when building
std = "$MACH_STD"

# Alternative: Use absolute path
# std = "/usr/local/lib/mach/std"

# Alternative: Use relative path
# std = "../mach/std"
