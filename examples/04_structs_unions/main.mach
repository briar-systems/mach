# structs and unions: aggregate data with `rec` and overlapping `uni`.
#
# a `rec` lays its fields out sequentially; a `uni` overlaps its fields in
# the same storage, so only one is valid at a time. here a tagged record
# pairs a discriminant with a union payload to model a small variant value.

use std.runtime;
use std.print.println;
use std.print.printlnf;

$main.symbol = "main";

# a record: distinct fields, each at its own offset.
rec Point {
    x: i64;
    y: i64;
}

# a union: every field shares the same storage.
uni Number {
    i: i64;
    f: f64;
}

# tag values for the variant below.
val TAG_INT:   u8 = 0;
val TAG_FLOAT: u8 = 1;

# a tagged variant: the tag says which union arm is live.
rec Value {
    tag:     u8;
    payload: Number;
}

fun manhattan(p: Point) i64 {
    var ax: i64 = p.x;
    var ay: i64 = p.y;
    if (ax < 0) { ax = -ax; }
    if (ay < 0) { ay = -ay; }
    ret ax + ay;
}

fun main(argc: i64, argv: **u8) i64 {
    var p: Point = Point{ x: 3, y: -4 };
    p.x = p.x + 1;
    printlnf("manhattan distance: %d", manhattan(p));

    # build an int-tagged value, then read its payload back through the
    # matching union arm.
    var v: Value;
    v.tag        = TAG_INT;
    v.payload.i  = 99;

    if (v.tag == TAG_INT) {
        printlnf("tagged value is int: yes -> %d", v.payload.i);
    }
    or {
        println("tagged value is int: no");
    }

    ret 0;
}
