# comptime: code and values resolved at compile time.
#
# `$if` / `$or` select a branch during compilation — discarded branches are
# never emitted, so each only needs to be valid for the chosen target. the
# value intrinsics $size_of / $align_of fold to compile-time constants. a
# `$mode` parameter is a compile-time-known argument fixed per call site.

use std.runtime;
use std.print.println;
use std.print.printlnf;

$main.symbol = "main";

rec Point {
    x: i32;
    y: i64;
}

rec Pair {
    a: i64;
    b: i64;
}

# value intrinsics fold to compile-time constants; their natural type is an
# unsigned integer, so they are stored as u64 here.
val POINT_SIZE:  u64 = $size_of(Point);
val POINT_ALIGN: u64 = $align_of(Point);
val PAIR_SIZE:   u64 = $size_of(Pair);

# a comptime value parameter: `$mode` must be known at compile time, so the
# compiler fixes it per call site and monomorphizes the body once per distinct
# value. because `mode` is comptime-known inside the body, `$if`/`$or` can
# select on it — each instance compiles only its taken arm.
val MODE_DOUBLE: u8 = 0;
val MODE_SQUARE: u8 = 1;

fun apply($mode: u8, n: i64) i64 {
    $if (mode == MODE_DOUBLE) {
        ret n + n;
    }
    $or (mode == MODE_SQUARE) {
        ret n * n;
    }
    ret 0;
}

# comptime params also drive a mix of compile-time and runtime parameters: the
# `$op` selector is folded per call site, the value operands stay runtime.
fun combine($op: u8, a: i64, b: i64) i64 {
    $if (op == 0) { ret a + b; }
    $or (op == 1) { ret a - b; }
    ret a * b;
}

fun main(argc: i64, argv: **u8) i64 {
    printlnf("sizeof(Point): %u", POINT_SIZE);
    printlnf("alignof(Point): %u", POINT_ALIGN);
    printlnf("sizeof(Pair): %u", PAIR_SIZE);

    printlnf("apply(DOUBLE, 21): %d", apply(MODE_DOUBLE, 21));
    printlnf("apply(SQUARE, 9): %d", apply(MODE_SQUARE, 9));

    printlnf("combine(ADD, 8, 5): %d", combine(0, 8, 5));
    printlnf("combine(SUB, 8, 5): %d", combine(1, 8, 5));
    printlnf("combine(MUL, 8, 5): %d", combine(2, 8, 5));

    # target-conditional code: only the taken branch is compiled and emitted.
    $if ($mach.target.os == $mach.os.linux) {
        println("target os: linux");
    }
    $or ($mach.target.os == $mach.os.darwin) {
        println("target os: darwin");
    }
    $or {
        println("target os: other");
    }

    $if ($mach.target.arch == $mach.arch.x86_64) {
        println("target arch: x86_64");
    }
    $or {
        println("target arch: other");
    }

    ret 0;
}

# comptime value-param monomorphization: each distinct comptime argument value
# emits a separate body that compiles only the `$if` arm selected for that value.

test "comptime param: $if selects the DOUBLE arm" {
    if (apply(MODE_DOUBLE, 21) != 42) { ret 1; }
    ret 0;
}

test "comptime param: $or selects the SQUARE arm" {
    if (apply(MODE_SQUARE, 9) != 81) { ret 1; }
    ret 0;
}

test "comptime param: distinct values pick distinct arms" {
    if (apply(MODE_DOUBLE, 5) != 10) { ret 1; }
    if (apply(MODE_SQUARE, 5) != 25) { ret 1; }
    ret 0;
}

test "comptime param: mixed comptime + runtime params" {
    if (combine(0, 8, 5) != 13) { ret 1; }
    if (combine(1, 8, 5) != 3) { ret 1; }
    if (combine(2, 8, 5) != 40) { ret 1; }
    ret 0;
}
