# low-level: inline assembly and a raw syscall.
#
# `asm x86_64 { ... }` drops to native instructions with `{name}` operand
# substitution; the compiler infers operand direction and clobbers. here one
# asm block adds two integers, and another issues the Linux `write` syscall
# directly (rax=1, rdi=fd, rsi=buf, rdx=len) with no stdlib write wrapper.

use std.runtime;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;
use std.print.printlnf;

$main.symbol = "main";

# add two integers using inline assembly instead of the `+` operator.
fun add_asm(a: i64, b: i64) i64 {
    var out: i64 = 0;
    asm x86_64 {
        mov rax, {a}
        add rax, {b}
        mov {out}, rax
    }
    ret out;
}

# the Linux write syscall, issued by hand: syscall number 1 in rax, the
# file descriptor in rdi, buffer pointer in rsi, byte count in rdx.
fun raw_write(fd: i64, buf: *u8, len: usize) i64 {
    var ret_val: i64 = 0;
    asm x86_64 {
        mov rax, 1
        mov rdi, {fd}
        mov rsi, {buf}
        mov rdx, {len}
        syscall
        mov {ret_val}, rax
    }
    ret ret_val;
}

fun main(argc: i64, argv: **u8) i64 {
    # the raw syscall is the point of this example: write straight to fd 1
    # with no stdlib wrapper.
    val msg: str = "written via raw syscall, no stdlib write\n";
    raw_write(1, msg::*u8, str_len(msg));

    # the inline-asm result is ordinary data, so print it with std.print.
    printlnf("add_asm(40, 2) = %d", add_asm(40, 2));

    ret 0;
}
