# inline asm demonstrations: ISA tag mandatory, {name} substitution,
# multi-arch via outer $if on $mach.target.arch.

# read a hardware counter — different instruction per arch
pub fun cycles() i64 {
    var result: i64 = 0;

    $if ($mach.target.arch == $mach.arch.x86_64) {
        asm x86_64 {
            rdtsc
            shl rdx, 32
            or rax, rdx
            mov {result}, rax
        }
    }
    $or ($mach.target.arch == $mach.arch.aarch64) {
        asm aarch64 {
            mrs {result}, cntvct_el0
        }
    }

    ret result;
}

# arithmetic done via raw asm — demonstrates operand substitution
# for both input and output locals
pub fun add_via_asm(a: i64, b: i64) i64 {
    var result: i64 = 0;

    $if ($mach.target.arch == $mach.arch.x86_64) {
        asm x86_64 {
            mov rax, {a}
            add rax, {b}
            mov {result}, rax
        }
    }
    $or ($mach.target.arch == $mach.arch.aarch64) {
        asm aarch64 {
            add {result}, {a}, {b}
        }
    }

    ret result;
}

# trap — no operands, just an instruction
pub fun trap() {
    $if ($mach.target.arch == $mach.arch.x86_64) {
        asm x86_64 { ud2 }
    }
    $or ($mach.target.arch == $mach.arch.aarch64) {
        asm aarch64 { brk 0 }
    }
}
