# data shapes for full.core: type aliases, records, unions, and
# module-level constants. picked up by `full.core` via `pub fwd`.

# type alias
pub def Age: i64;

# function-pointer type, named via a def
pub def BinOp: fun(i64, i64) i64;

# module-level constant
pub val MAX: i64 = 100;

# record
pub rec Point {
    x: i64;
    y: i64;
}

# generic record, two type parameters
pub rec Pair[T, U] {
    left:  T;
    right: U;
}

# union
pub uni Number {
    i: i64;
    f: f64;
}

# generic union
pub uni Maybe[T] {
    some: T;
    none: u8;
}
