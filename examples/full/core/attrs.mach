# attribute demonstrations: every locked attribute applied to a real decl.
# attribute writes appear before the decl as a "header."

# .symbol — linker name override on an ext function
$libc_write.symbol = "write";
pub ext fun libc_write(fd: i64, buf: *u8, n: i64) i64;

# .noreturn — function never returns; compiler omits dead-code after calls
# (flags are u8; stdlib `true`/`false` = 1/0 are the idiomatic spelling)
$panic.noreturn = 1;
pub fun panic(msg: *u8) {
    asm x86_64 { ud2 }
}

# .inline — strong hint to inline at call sites
$bump_inline.inline = 1;
pub fun bump_inline(p: *i64) {
    @p = @p + 1;
}

# .align on a module-level var — 64-byte cache-line alignment
$aligned_buf.align = 64;
pub var aligned_buf: [256]u8;

# .align on a record type — minimum type alignment
$Aligned.align = 16;
pub rec Aligned {
    x: i64;
    y: i64;
}

# .packed on a record type — disable field padding
$Header.packed = 1;
pub rec Header {
    magic:   u32;
    version: u8;
    flags:   u8;
    length:  u32;
}

# .section — place data in a custom linker section
$boot_data.section = ".boot";
pub val boot_data: [4]u8 = [4]u8{0xDE, 0xAD, 0xBE, 0xEF};
