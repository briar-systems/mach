# Library half of the Mach syntax fixture: every public declaration
# form. Imported by main.mach. Nothing here is meant to be useful — the
# fixture exists to exercise and develop the parser.

# type alias
pub def Age: i64;

# function-pointer type, named via a def
pub def BinOp: fun(i64, i64) i64;

# module-level constant, and a module-private variable
pub val MAX: i64 = 100;
var calls: i64 = 0;

# record
pub rec Point {
    x: i64;
    y: i64;
}

# generic record, two type parameters
pub rec Pair[T, U] {
    left:  T;
    right: U;
}

# union
pub uni Number {
    i: i64;
    f: f64;
}

# generic union
pub uni Maybe[T] {
    some: T;
    none: u8;
}

# function
pub fun add(a: i64, b: i64) i64 {
    ret a + b;
}

# function with no return type
pub fun bump() {
    calls = calls + 1;
}

# generic function
pub fun identity[T](value: T) T {
    ret value;
}

# generic function returning a generic record
pub fun make_pair[T, U](a: T, b: U) Pair[T, U] {
    var p: Pair[T, U];
    p.left  = a;
    p.right = b;
    ret p;
}

# variadic function
pub fun sum(count: i64, ...) i64 {
    var ap: va_list;
    va_start(?ap);

    var total: i64 = 0;
    var i: i64 = 0;
    for (i < count) {
        total = total + va_arg[i64](?ap);
        i = i + 1;
    }

    va_end(?ap);
    ret total;
}
