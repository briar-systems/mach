# generics: type-parameterized functions and records.
#
# `fun f[T](...)` and `rec Type[A, B]` are monomorphized per unique type
# instantiation. call sites supply the type arguments explicitly in
# brackets, e.g. `identity[i64](x)` or `Pair[i64, u8]{ ... }`.

use std.runtime;
use std.print.printlnf;

$main.symbol = "main";

# a generic record over two independent type parameters.
rec Pair[A, B] {
    first:  A;
    second: B;
}

# a generic function: returns its argument unchanged, whatever the type.
fun identity[T](value: T) T {
    ret value;
}

# a generic constructor for Pair.
fun make_pair[A, B](a: A, b: B) Pair[A, B] {
    var p: Pair[A, B];
    p.first  = a;
    p.second = b;
    ret p;
}

fun main(argc: i64, argv: **u8) i64 {
    # identity instantiated at two different types.
    val n: i64 = identity[i64](7);
    val c: u8  = identity[u8]('Z');

    printlnf("identity[i64](7) = %d", n);

    # a Pair[i64, u8]; read both fields back.
    val pr: Pair[i64, u8] = make_pair[i64, u8](100, c);
    printlnf("pair.first = %d", pr.first);
    printlnf("pair.second (as int) = %d", pr.second::i64);

    ret 0;
}
