# collections: the standard hash Map and Set.
#
# both are generic over their key type and take an allocator plus a key
# hash/equality pair at construction. the stdlib ships ready-made hashers
# (hash_i64 / eq_i64, hash_str / eq_str, ...). this example backs storage
# with the page allocator and stores i64 keys.

use std.runtime;
use std.types.size.usize;
use std.types.bool.bool;
use std.types.string.str;
use std.types.string.str_len;

use allocator: std.allocator;
use page:      std.allocator.page;

use map: std.collections.map;
use set: std.collections.set;

use std.types.result.Result;
use std.types.result.is_ok;
use std.types.result.unwrap_ok;

use os: std.system.os;

$main.symbol = "main";

fun out(s: str) {
    os.write(os.STDOUT_FD, s::*u8, str_len(s));
}

fun out_num(n: i64) {
    var buf: [24]u8;
    var idx: i64 = 23;
    var x:   i64 = n;
    buf[idx] = '\n';
    if (x == 0) {
        idx = idx - 1;
        buf[idx] = '0';
    }
    or {
        for (x > 0) {
            idx = idx - 1;
            buf[idx] = (x % 10)::u8 + '0';
            x = x / 10;
        }
    }
    os.write(os.STDOUT_FD, ?buf[idx], (24 - idx)::usize);
}

fun out_bool(b: bool) {
    if (b) { out("true\n"); }
    or { out("false\n"); }
}

fun main(argc: i64, argv: **u8) i64 {
    # a page-backed allocator drives all dynamic storage below.
    var alloc: allocator.Allocator;
    page.make(?alloc);

    # Map[i64, i64]: square each of a few keys.
    var squares: map.Map[i64, i64] = map.init[i64, i64](?alloc, map.hash_i64, map.eq_i64);

    var k: i64 = 1;
    for (k <= 4) {
        map.insert[i64, i64](?squares, k, k * k);
        k = k + 1;
    }

    out("map length: ");
    out_num(map.length[i64, i64](squares)::i64);

    var key: i64 = 3;
    val lookup: Result[*i64, str] = map.get[i64, i64](?squares, ?key);
    if (is_ok[*i64, str](lookup)) {
        out("squares[3] = ");
        out_num(@unwrap_ok[*i64, str](lookup));
    }

    out("map contains 4: ");
    key = 4;
    out_bool(map.contains[i64, i64](?squares, ?key));

    out("map contains 9: ");
    key = 9;
    out_bool(map.contains[i64, i64](?squares, ?key));

    # Set[i64]: dedupe a sequence with repeats.
    var seen: set.Set[i64] = set.init[i64](?alloc, map.hash_i64, map.eq_i64);

    var vals: [6]i64 = [6]i64{ 5, 5, 7, 7, 7, 9 };
    var i: i64 = 0;
    for (i < 6) {
        set.insert[i64](?seen, vals[i]);
        i = i + 1;
    }

    out("set length (unique values): ");
    out_num(set.length[i64](seen)::i64);

    key = 7;
    out("set contains 7: ");
    out_bool(set.contains[i64](?seen, ?key));

    map.dnit[i64, i64](?squares);
    set.dnit[i64](?seen);

    ret 0;
}
