# functions and recursion: defining, calling, and self-referencing functions.
#
# shows plain functions, a recursive factorial, a mutually-recursive
# even/odd pair, and a module-level constant. results print to stdout.

use std.runtime;
use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.print.println;
use std.print.printlnf;

$main.symbol = "main";

# module-level constant, visible to every function in this file.
val MAX_N: i64 = 10;

# direct recursion.
fun factorial(n: i64) i64 {
    if (n <= 1) { ret 1; }
    ret n * factorial(n - 1);
}

# mutual recursion: each function calls the other.
fun is_even(n: i64) bool {
    if (n == 0) { ret true; }
    ret is_odd(n - 1);
}

fun is_odd(n: i64) bool {
    if (n == 0) { ret false; }
    ret is_even(n - 1);
}

fun main(argc: i64, argv: **u8) i64 {
    printlnf("factorial(5) = %d", factorial(5));

    if (is_even(MAX_N)) {
        println("MAX_N is even: yes");
    }
    or {
        println("MAX_N is even: no");
    }

    ret 0;
}
