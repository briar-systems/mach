# casts: the two cast operators.
#
# `::` is a VALUE conversion — it resizes integers, converts between integer and
# float, and is the identity on same-type operands; it preserves the numeric
# value where representable. `:~` is a BIT reinterpret — it reads the operand's
# exact bits as the target type, with no conversion, and requires the two types
# to have the same byte size. `f` reads as "bit cast".
#
# the two differ sharply on int<->float: `1.5 :: u64` is the number `1` (a
# float-to-int conversion), while `1.5 :~ u64` is the raw IEEE-754 bit pattern
# `0x3FF8000000000000`.

use std.runtime;
use std.types.size.usize;
use std.print.printlnf;

$main.symbol = "main";

fun main() i32 {
    val f: f64 = 1.5;
    printlnf("1.5 :: u64 = %u  (value conversion)", f :: u64);
    printlnf("1.5 :~ u64 = %x  (raw IEEE-754 bits)", f :~ u64);
    ret 0;
}

# `::` converts a float to its truncated integer value.
test "cast `::` float-to-int yields the numeric value" {
    val f: f64 = 1.5;
    if ((f :: u64) != 1) { ret 1; }
    val g: f64 = 42.9;
    if ((g :: i64) != 42) { ret 1; }
    ret 0;
}

# `:~` on a float reads its exact IEEE-754 bit pattern.
test "reinterpret `:~` f64 yields raw IEEE-754 bits" {
    val f: f64 = 1.5;
    if ((f :~ u64) != 0x3FF8000000000000) { ret 1; }
    val z: f64 = 0.0;
    if ((z :~ u64) != 0x0000000000000000) { ret 1; }
    ret 0;
}

# `:~` reads a 32-bit float's bits (the MOVD path).
test "reinterpret `:~` f32 yields raw 32-bit bits" {
    val f: f32 = 1.5;
    if ((f :~ u32) != 0x3FC00000) { ret 1; }
    ret 0;
}

# a bit reinterpret round-trips: bits -> f64 -> bits is the identity.
test "reinterpret `:~` round-trips bits through f64" {
    val bits: u64 = 0x4009000000000000;
    val f: f64 = bits :~ f64;
    if ((f :~ u64) != bits) { ret 1; }
    ret 0;
}

# `:~` between equal-size integers reinterprets the bit pattern: -1 as i64 is
# all-ones as u64.
test "reinterpret `:~` i64 to u64 preserves the bit pattern" {
    val si: i64 = 0 - 1;
    if ((si :~ u64) != 0xFFFFFFFFFFFFFFFF) { ret 1; }
    val ui: u64 = 7;
    if ((ui :~ i64) != 7) { ret 1; }
    ret 0;
}

# a pointer and a `usize` share a width, so `:~` reinterprets between them; the
# address survives a round trip.
test "reinterpret `:~` round-trips a pointer through usize" {
    var n: i64 = 99;
    val p: *i64 = ?n;
    val a: usize = p :~ usize;
    val p2: *i64 = a :~ *i64;
    if (@p2 != 99) { ret 1; }
    ret 0;
}
