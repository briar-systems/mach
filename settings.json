{
    "git_panel": {
        "tree_view": true,
        "dock": "left"
    },
    "tabs": {
        "file_icons": false,
        "git_status": true
    },
    "title_bar": {
        "show_menus": false
    },
    "ui_font_weight": 100.0,
    "ui_font_family": ".ZedMono",
    "buffer_font_weight": 100.0,
    "buffer_font_family": ".ZedMono",
    "buffer_line_height": "standard",
    "project_panel": {
        "hide_root": true,
        "indent_size": 20.0,
        "entry_spacing": "standard"
    },
    "git": {
        "inline_blame": {
            "enabled": false
        }
    },
    "wsl_connections": [
        {
            "distro_name": "Ubuntu-24.04",
            "user": null,
            "projects": [
                {
                    "paths": ["/home/octalide"]
                },
                {
                    "paths": ["/home/octalide/dev/src/github.com/octalide"]
                },
                {
                    "paths": [
                        "/home/octalide/dev/src/github.com/octalide/budgie"
                    ]
                },
                {
                    "paths": ["/home/octalide/dev/src/github.com/octalide/mach"]
                },
                {
                    "paths": [
                        "/home/octalide/dev/src/github.com/octalide/mach-lsp"
                    ]
                },
                {
                    "paths": [
                        "/home/octalide/dev/src/github.com/octalide/mach-seive"
                    ]
                }
            ]
        }
    ],
    "features": {
        "edit_prediction_provider": "copilot"
    },
    "telemetry": {
        "diagnostics": false,
        "metrics": false
    },
    "agent": {
        "favorite_models": [
            {
                "provider": "copilot_chat",
                "model": "claude-opus-4.5"
            },
            {
                "provider": "google",
                "model": "gemini-3-pro-preview"
            },
            {
                "provider": "copilot_chat",
                "model": "gpt-5.2-codex"
            },
            {
                "provider": "copilot_chat",
                "model": "gemini-3-pro-preview"
