use "std/math"

type foo {
    var a: u32
    var b: u32
    var c: ?foo
}

fun main(args: []str) {
    # literal decleration
    var a = 0
    var b = 0.00
    var c = "foo"
    var d = 'f'
    var _ = '\0'
    var e = true
    var f = false

    # array decleration
    var g = [1, 2, 3, 4, 5]

    # value decleration
    val h = 0

    # pointers
    var i = ?a
    var j = @i

    # variable reassignment
    a = 1
    
    # arithmetic
    a = a + 1
    a = a - 1
    a = a * 1
    a = a / 1
    a = a % 1
    a = a ** 1

    # comparison
    e = a == 1
    e = a != 1
    e = a > 1
    e = a < 1
    e = a >= 1
    e = a <= 1

    # logical
    e = a && b
    e = a || b
    e = !a

    # binary
    a = a & 1
    a = a | 1
    a = a ^ 1
    a = a << 1
    a = a >> 1

    # flow control
    if a == 1 {
        a = 2
    } elif a == 2 {
        a = 3
    } else {
        a = 4
    }

    # loops
    for var i = 0, i < 10, i = i + 1 {
        a = i
    }

    for {
        a = 0
        break
    }

    # function call
    foo(a)
    bar(a, b)
    do foo(a)

    # match case
    match a {
        1: a = 2
        2: a = 3
        3: a = 4
        _: a = 1
    }

    ret 0
}
