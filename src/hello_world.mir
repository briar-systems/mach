val HELLO_MSG: ptr = "Hello, World!\n";

pub _start:
    xor.i64 rbp, rbp, rbp;
    
    mov.i64 %temp, rsp;
    and.i64 %temp, %temp, -16;
    mov.i64 rsp, %temp;
    
    jmp mach_runtime_entry;

pub mach_runtime_entry:
    jmp main;

pub main:
    mov.i64 rdi, 1;
    lea.ptr rsi, HELLO_MSG;
    mov.i64 rdx, 14;
    
    mov.i64 rax, 1;
    x86.syscall;
    
    mov.i64 rdi, 42;
    mov.i64 rax, 60;
    x86.syscall;
    
    unreachable;
