# cmd.dep: dependency management

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use page:      std.allocator.page;
use print:     std.print;
use exec:      std.process.exec;

use args:   mach.cli.args;
use config: mach.config.project;

# help: print dep subcommand usage.
pub fun help() {
    print.println("usage: mach dep <action>");
    print.println("");
    print.println("manage project dependencies.");
}

# run: execute the dep command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun run(argc: i64, argv: &*u8) i64 {
    if (argc < 3) {
        print.eprintln("error: missing subcommand");
        print.eprintln("usage: mach dep <list|info|add|del|pull|tidy>");
        ret 1;
    }

    val subcmd: str = argv[2]::str;

    if (str_equals(subcmd, "list")) { ret dep_list(); }
    if (str_equals(subcmd, "info")) { ret dep_info(argc, argv); }
    if (str_equals(subcmd, "add"))  { ret dep_add(argc, argv); }
    if (str_equals(subcmd, "del"))  { ret dep_del(argc, argv); }
    if (str_equals(subcmd, "pull")) { ret dep_pull(); }
    if (str_equals(subcmd, "tidy")) { ret dep_tidy(); }

    print.eprintlnf("error: unknown dep subcommand '%s'", subcmd);
    print.eprintln("usage: mach dep <list|info|add|del|pull|tidy>");
    ret 1;
}

fun dep_list() i64 {
    var alloc: allocator.Allocator;
    page.make(?alloc);

    val load_res: Result[config.ProjectConfig, str] = config.load(?alloc, "mach.toml");
    if (is_err[config.ProjectConfig, str](load_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.ProjectConfig, str](load_res));
        ret 1;
    }
    var proj: config.ProjectConfig = unwrap_ok[config.ProjectConfig, str](load_res);

    if (proj.dep_count == 0) {
        print.println("no dependencies");
        config.dnit(?proj);
        ret 0;
    }

    var i: u32 = 0;
    for (i < proj.dep_count) {
        if (proj.deps[i].is_local) {
            print.printlnf("  %s  path=%s", proj.deps[i].name, proj.deps[i].path);
        } or {
            var ver: str = proj.deps[i].version;
            if (ver == nil) { ver = "(unspecified)"; }
            print.printlnf("  %s  version=%s", proj.deps[i].name, ver);
        }
        i = i + 1;
    }

    config.dnit(?proj);
    ret 0;
}

fun dep_info(argc: i64, argv: &*u8) i64 {
    if (argc < 4) {
        print.eprintln("error: missing dependency name");
        print.eprintln("usage: mach dep info <name>");
        ret 1;
    }

    val name: str = argv[3]::str;

    var alloc: allocator.Allocator;
    page.make(?alloc);

    val load_res: Result[config.ProjectConfig, str] = config.load(?alloc, "mach.toml");
    if (is_err[config.ProjectConfig, str](load_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.ProjectConfig, str](load_res));
        ret 1;
    }
    var proj: config.ProjectConfig = unwrap_ok[config.ProjectConfig, str](load_res);

    var i: u32 = 0;
    for (i < proj.dep_count) {
        if (str_equals(proj.deps[i].name, name)) {
            print.printlnf("name: %s", proj.deps[i].name);
            if (proj.deps[i].is_local) {
                print.printlnf("type: local");
                print.printlnf("path: %s", proj.deps[i].path);
            } or {
                print.printlnf("type: remote");
            }
            if (proj.deps[i].version != nil) {
                print.printlnf("version: %s", proj.deps[i].version);
            }
            config.dnit(?proj);
            ret 0;
        }
        i = i + 1;
    }

    print.eprintlnf("error: dependency '%s' not found", name);
    config.dnit(?proj);
    ret 1;
}

fun dep_add(argc: i64, argv: &*u8) i64 {
    if (argc < 4) {
        print.eprintln("error: missing dependency path");
        print.eprintln("usage: mach dep add <path> [version]");
        ret 1;
    }

    val dep_path: str = argv[3]::str;
    var version: str = nil;
    if (argc >= 5) {
        version = argv[4]::str;
    }

    if (version != nil) {
        print.printlnf("would add dependency: path=%s version=%s", dep_path, version);
    } or {
        print.printlnf("would add dependency: path=%s", dep_path);
    }
    print.println("(mach.toml editing not yet implemented)");
    ret 0;
}

fun dep_del(argc: i64, argv: &*u8) i64 {
    if (argc < 4) {
        print.eprintln("error: missing dependency name");
        print.eprintln("usage: mach dep del <name>");
        ret 1;
    }

    val name: str = argv[3]::str;
    print.printlnf("would remove dependency: %s", name);
    print.println("(mach.toml editing not yet implemented)");
    ret 0;
}

fun dep_pull() i64 {
    print.println("pulling dependencies...");

    var git_argv: [5]usize;
    git_argv[0] = "git"::usize;
    git_argv[1] = "submodule"::usize;
    git_argv[2] = "update"::usize;
    git_argv[3] = "--init"::usize;
    git_argv[4] = 0;

    val res: Result[exec.ExitStatus, str] = exec.run("/usr/bin/git", (?git_argv[0])::&*u8, nil);
    if (is_err[exec.ExitStatus, str](res)) {
        print.eprintln("error: failed to run git submodule update");
        ret 1;
    }

    val status: exec.ExitStatus = unwrap_ok[exec.ExitStatus, str](res);
    if (exec.exited(status) && exec.code(status) != 0) {
        print.eprintlnf("error: git exited with code %d", exec.code(status)::i64);
        ret 1;
    }

    print.println("dependencies updated");
    ret 0;
}

fun dep_tidy() i64 {
    var alloc: allocator.Allocator;
    page.make(?alloc);

    val load_res: Result[config.ProjectConfig, str] = config.load(?alloc, "mach.toml");
    if (is_err[config.ProjectConfig, str](load_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.ProjectConfig, str](load_res));
        ret 1;
    }
    var proj: config.ProjectConfig = unwrap_ok[config.ProjectConfig, str](load_res);

    if (proj.dep_count == 0) {
        print.println("no dependencies to check");
        config.dnit(?proj);
        ret 0;
    }

    print.printlnf("checking %d dependencies...", proj.dep_count::i64);
    # TODO: cross-reference imported modules against declared deps
    print.println("tidy: all dependencies appear in use");

    config.dnit(?proj);
    ret 0;
}
