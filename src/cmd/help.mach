# cmd.help: help text display

use print: std.print;

pub fun run(argc: i64, argv: &&u8) i64 {
    if (argc >= 3) {
        val subcmd: str = argv[2]::str;

        if (str_equals(subcmd, "build")) {
            print.println("usage: mach build [options]");
            print.println("");
            print.println("compile a mach project.");
            print.println("");
            print.println("options:");
            print.println("  --target <name>    target configuration name");
            print.println("  -o <file>          output binary path");
            print.println("  --release          enable optimizations, strip debug info");
            print.println("  --emit-masm        write .masm IR text files");
            print.println("  --emit-asm         write .s assembly files");
            print.println("  --verbose          verbose output");
            print.println("  -j <N>             parallel codegen workers");
            ret 0;
        }

        if (str_equals(subcmd, "run")) {
            print.println("usage: mach run [options] [-- <program args>]");
            print.println("");
            print.println("build and execute a mach project.");
            print.println("");
            print.println("options:");
            print.println("  --target <name>    target configuration name");
            print.println("  -o <file>          output binary path");
            print.println("  --release          enable optimizations, strip debug info");
            print.println("  --emit-masm        write .masm IR text files");
            print.println("  --emit-asm         write .s assembly files");
            print.println("  --verbose          verbose output");
            print.println("  -j <N>             parallel codegen workers");
            print.println("");
            print.println("arguments after '--' are passed to the executed program.");
            ret 0;
        }

        if (str_equals(subcmd, "test")) {
            print.println("usage: mach test [options]");
            print.println("");
            print.println("compile and run tests for a mach project.");
            print.println("");
            print.println("options:");
            print.println("  --test <pattern>   filter test names by pattern");
            print.println("  --module <pattern> filter modules by pattern");
            print.println("  -v, --verbose      verbose output");
            ret 0;
        }

        if (str_equals(subcmd, "dep")) {
            print.println("usage: mach dep <subcommand> [args]");
            print.println("");
            print.println("manage project dependencies.");
            print.println("");
            print.println("subcommands:");
            print.println("  list               list all dependencies");
            print.println("  info <name>        show details for a dependency");
            print.println("  add <path> [ver]   add a dependency");
            print.println("  del <name>         remove a dependency");
            print.println("  pull               update git submodules");
            print.println("  tidy               check for unused dependencies");
            ret 0;
        }

        if (str_equals(subcmd, "init")) {
            print.println("usage: mach init [name]");
            print.println("");
            print.println("create a new mach project.");
            print.println("");
            print.println("creates a project directory with mach.toml, src/, and dep/.");
            print.println("if no name is given, defaults to 'my-project'.");
            ret 0;
        }

        print.eprintlnf("error: unknown command '%s'", subcmd);
        print.println("");
    }

    print.println("usage: mach <command> [options]");
    print.println("");
    print.println("commands:");
    print.println("  build    compile a mach project");
    print.println("  run      build and execute");
    print.println("  test     run tests");
    print.println("  dep      manage dependencies");
    print.println("  init     create a new project");
    print.println("  help     show this message");
    print.println("");
    print.println("use 'mach help <command>' for detailed usage.");
    ret 0;
}
