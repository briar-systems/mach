# cmd.help: top-level help text and subcommand dispatch

use std.types.string;

use print: std.print;

use cmd_build: mach.cmd.build;
use cmd_run:   mach.cmd.run;
use cmd_test:  mach.cmd.testing;
use cmd_dep:   mach.cmd.dep;
use cmd_init:  mach.cmd.init;

# run: display help text, dispatching to subcommand help if specified.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun run(argc: i64, argv: **u8) i64 {
    if (argc >= 3) {
        val subcmd: str = argv[2]::str;
        if (str_equals(subcmd, "build")) { cmd_build.help(); ret 0; }
        if (str_equals(subcmd, "run"))   { cmd_run.help();   ret 0; }
        if (str_equals(subcmd, "test"))  { cmd_test.help();  ret 0; }
        if (str_equals(subcmd, "dep"))   { cmd_dep.help();   ret 0; }
        if (str_equals(subcmd, "init"))  { cmd_init.help();  ret 0; }

        print.eprintlnf("error: unknown command '%s'", subcmd);
        print.println("");
    }

    print.println("usage: mach <command> [options]");
    print.println("");
    print.println("commands:");
    print.println("  build    compile a mach project");
    print.println("  run      build and execute");
    print.println("  test     run tests");
    print.println("  dep      manage dependencies");
    print.println("  init     create a new project");
    print.println("  help     show this message");
    print.println("");
    print.println("use 'mach help <command>' for detailed usage.");
    ret 0;
}
