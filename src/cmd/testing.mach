# cmd.testing: test runner

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use page:      std.allocator.page;
use print:     std.print;

use args:     mach.cli.args;
use config:   mach.config.project;
use session:  mach.compiler.session;
use compiler: mach.compiler.compiler;

# help: print test subcommand usage.
pub fun help() {
    print.println("usage: mach test [options]");
    print.println("");
    print.println("run tests for a mach project.");
}

# run: execute the test command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun run(argc: i64, argv: &&u8) i64 {
    val test_filter:  str  = args.get_option(argc, argv, "--test");
    val mod_filter:   str  = args.get_option(argc, argv, "--module");
    val verbose:      bool = args.has_flag(argc, argv, "-v");
    val verbose_long: bool = args.has_flag(argc, argv, "--verbose");
    val is_verbose:   bool = verbose || verbose_long;

    var alloc: allocator.Allocator;
    page.make(?alloc);

    val load_res: Result[config.ProjectConfig, str] = config.load(?alloc, "mach.toml");
    if (is_err[config.ProjectConfig, str](load_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.ProjectConfig, str](load_res));
        ret 1;
    }
    var proj: config.ProjectConfig = unwrap_ok[config.ProjectConfig, str](load_res);

    var effective_target: str = proj.default_target;
    if (effective_target == nil && proj.target_count > 0) {
        effective_target = proj.targets[0].name;
    }

    if (effective_target == nil) {
        print.eprintln("error: no target configured in mach.toml");
        config.dnit(?proj);
        ret 1;
    }

    if (is_verbose) {
        print.printlnf("running tests for '%s'...", proj.name);
        if (test_filter != nil) {
            print.printlnf("  test filter: %s", test_filter);
        }
        if (mod_filter != nil) {
            print.printlnf("  module filter: %s", mod_filter);
        }
    }

    var opts: session.CompileOpts = session.default_opts();
    opts.verbose = is_verbose;

    val compile_result: session.CompileResult = compiler.compile_project(?alloc, ".", effective_target, nil, nil, opts);

    if (!compile_result.ok) {
        print.eprintln("error: compilation failed");
        config.dnit(?proj);
        ret 1;
    }

    # TODO: invoke test binary with test harness once NK_DECL_TEST support is wired
    print.println("test: compilation succeeded (test harness not yet wired)");
    print.println("");
    print.println("0 passed, 0 failed");

    config.dnit(?proj);
    ret 0;
}
