# cmd.build: build command

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use arena:     std.allocator.arena;
use page:      std.allocator.page;
use print:     std.print;
use parse:     std.text.parse;

use args:     mach.cli.args;
use config:   mach.config.project;
use session:  mach.compiler.session;
use compiler: mach.compiler.compiler;

# help: print build subcommand usage.
pub fun help() {
    print.println("usage: mach build [options]");
    print.println("");
    print.println("options:");
    print.println("  --target <name>    target configuration name");
    print.println("  -o <file>          output binary path");
    print.println("  --release          enable optimizations, strip debug info");
    print.println("  --emit-masm        write .masm IR text files");
    print.println("  --emit-asm         write .s assembly files");
    print.println("  --verbose          verbose output");
    print.println("  -j <N>             parallel codegen workers");
}

# run: execute the build command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun run(argc: i64, argv: **u8) i64 {
    val target_name: str = args.get_option(argc, argv, "--target");
    val output_path: str = args.get_option(argc, argv, "-o");
    val artifacts:   str = args.get_option(argc, argv, "--artifacts");
    val jobs_str:    str = args.get_option(argc, argv, "-j");
    val is_release:  bool = args.has_flag(argc, argv, "--release");
    val emit_masm:   bool = args.has_flag(argc, argv, "--emit-masm");
    val emit_asm:    bool = args.has_flag(argc, argv, "--emit-asm");
    val verbose:     bool = args.has_flag(argc, argv, "--verbose");

    var opts: session.CompileOpts = session.default_opts();
    opts.release   = is_release;
    opts.emit_masm = emit_masm;
    opts.emit_asm  = emit_asm;
    opts.verbose   = verbose;

    if (is_release) {
        opts.opt_level = 2;
        opts.verify_ir = false;
    }

    if (jobs_str != nil) {
        val res_parse_u64: Result[u64, str] = parse.parse_u64(jobs_str, 10);
        if (is_ok[u64, str](res_parse_u64)) {
            opts.jobs = unwrap_ok[u64, str](res_parse_u64)::u32;
        } or {
            print.eprintln("error: invalid value for -j");
            ret 1;
        }
    }

    var backing: allocator.Allocator;
    page.make(?backing);
    var ar: arena.Arena;
    arena.init(?ar, ?backing, 16 * 1024 * 1024);
    var alloc: allocator.Allocator;
    arena.make(?alloc, ?ar);

    val res_load: Result[config.ProjectConfig, str] = config.load(?alloc, "mach.toml");
    if (is_err[config.ProjectConfig, str](res_load)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.ProjectConfig, str](res_load));
        ret 1;
    }
    var proj: config.ProjectConfig = unwrap_ok[config.ProjectConfig, str](res_load);

    if (verbose) {
        print.printlnf("project: %s %s", proj.name, proj.version);
        print.printlnf("  src: %s", proj.dir_src);
        print.printlnf("  out: %s", proj.dir_out);
        print.printlnf("  dep: %s", proj.dir_dep);

        if (proj.target_count > 0) {
            var i: u32 = 0;
            for (i < proj.target_count) {
                print.printlnf("  target '%s': os=%s isa=%s abi=%s",
                    proj.targets[i].name,
                    proj.targets[i].os,
                    proj.targets[i].isa,
                    proj.targets[i].abi);
                i = i + 1;
            }
        }

        if (proj.dep_count > 0) {
            var di: u32 = 0;
            for (di < proj.dep_count) {
                if (proj.deps[di].is_local) {
                    print.printlnf("  dep '%s': path=%s", proj.deps[di].name, proj.deps[di].path);
                } or {
                    print.printlnf("  dep '%s': version=%s", proj.deps[di].name, proj.deps[di].version);
                }
                di = di + 1;
            }
        }
    }

    var effective_target: str = target_name;
    if (effective_target == nil) {
        effective_target = proj.default_target;
    }
    if (effective_target == nil && proj.target_count > 0) {
        effective_target = proj.targets[0].name;
    }

    if (effective_target == nil) {
        print.eprintln("error: no target specified and no default target in mach.toml");
        config.dnit(?proj);
        ret 1;
    }

    val tc: *config.TargetConfig = config.find_target(?proj, effective_target);
    if (tc == nil) {
        print.eprintlnf("error: target '%s' not found in mach.toml", effective_target);
        config.dnit(?proj);
        ret 1;
    }

    if (verbose) {
        print.printlnf("building target '%s'...", effective_target);
    }

    val compile_result: session.CompileResult = compiler.compile_project(?alloc, ".", effective_target, output_path, artifacts, opts);

    if (!compile_result.ok) {
        print.eprintln("error: compilation failed");
        config.dnit(?proj);
        ret 1;
    }

    config.dnit(?proj);
    ret 0;
}
