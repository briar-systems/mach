# cmd.init: project scaffolding

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use page:      std.allocator.page;
use print:     std.print;
use fs:        std.filesystem;
use mem:       std.memory;

use args: mach.cli.args;

# help: print init subcommand usage.
pub fun help() {
    print.println("usage: mach init [name]");
    print.println("");
    print.println("create a new mach project.");
}

# run: execute the init command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun run(argc: i64, argv: **u8) i64 {
    var name: str = nil;
    if (argc >= 3) {
        name = argv[2]::str;
    }
    if (name == nil) {
        name = "my-project";
    }

    var alloc: allocator.Allocator;
    page.make(?alloc);

    # create project root directory
    if (!fs.is_dir(name)) {
        val dir_res: Result[bool, str] = fs.create_dir(name, 493);
        if (is_err[bool, str](dir_res)) {
            print.eprintlnf("error: failed to create directory '%s': %s", name, unwrap_err[bool, str](dir_res));
            ret 1;
        }
    }

    val name_len: usize = str_len(name);

    # create src/
    var src_path: [256]u8;
    var off: usize = 0;
    mem.raw_copy(?src_path[0], name, name_len);
    off = name_len;
    src_path[off] = 47; # '/'
    off = off + 1;
    mem.raw_copy(?src_path[off], "src", 3);
    off = off + 3;
    src_path[off] = 0;

    if (!fs.is_dir(?src_path[0])) {
        val src_res: Result[bool, str] = fs.create_dir(?src_path[0], 493);
        if (is_err[bool, str](src_res)) {
            print.eprintlnf("error: failed to create src directory: %s", unwrap_err[bool, str](src_res));
            ret 1;
        }
    }

    # create dep/
    var dep_path: [256]u8;
    off = 0;
    mem.raw_copy(?dep_path[0], name, name_len);
    off = name_len;
    dep_path[off] = 47;
    off = off + 1;
    mem.raw_copy(?dep_path[off], "dep", 3);
    off = off + 3;
    dep_path[off] = 0;

    if (!fs.is_dir(?dep_path[0])) {
        val dep_res: Result[bool, str] = fs.create_dir(?dep_path[0], 493);
        if (is_err[bool, str](dep_res)) {
            print.eprintlnf("error: failed to create dep directory: %s", unwrap_err[bool, str](dep_res));
            ret 1;
        }
    }

    # write mach.toml
    var toml_path: [256]u8;
    off = 0;
    mem.raw_copy(?toml_path[0], name, name_len);
    off = name_len;
    toml_path[off] = 47;
    off = off + 1;
    mem.raw_copy(?toml_path[off], "mach.toml", 9);
    off = off + 9;
    toml_path[off] = 0;

    val toml_content: str = build_toml(name);
    val toml_len: usize = str_len(toml_content);

    val toml_res: Result[bool, str] = fs.write_file(?toml_path[0], toml_content, toml_len, 420);
    if (is_err[bool, str](toml_res)) {
        print.eprintlnf("error: failed to write mach.toml: %s", unwrap_err[bool, str](toml_res));
        ret 1;
    }

    # write src/main.mach
    var main_path: [256]u8;
    off = 0;
    mem.raw_copy(?main_path[0], name, name_len);
    off = name_len;
    main_path[off] = 47;
    off = off + 1;
    mem.raw_copy(?main_path[off], "src/main.mach", 13);
    off = off + 13;
    main_path[off] = 0;

    val main_content: str = build_main();
    val main_len: usize = str_len(main_content);

    val main_res: Result[bool, str] = fs.write_file(?main_path[0], main_content, main_len, 420);
    if (is_err[bool, str](main_res)) {
        print.eprintlnf("error: failed to write src/main.mach: %s", unwrap_err[bool, str](main_res));
        ret 1;
    }

    print.printlnf("created project: %s", name);
    ret 0;
}

fun build_toml(name: str) str {
    var buf: [512]u8;
    var off: usize = 0;

    off = append(off, ?buf[0], 512, "[project]\n");
    off = append(off, ?buf[0], 512, "id = \"");
    off = append(off, ?buf[0], 512, name);
    off = append(off, ?buf[0], 512, "\"\n");
    off = append(off, ?buf[0], 512, "name = \"");
    off = append(off, ?buf[0], 512, name);
    off = append(off, ?buf[0], 512, "\"\n");
    off = append(off, ?buf[0], 512, "version = \"0.1.0\"\n");
    off = append(off, ?buf[0], 512, "\n");
    off = append(off, ?buf[0], 512, "[dirs]\n");
    off = append(off, ?buf[0], 512, "src = \"src\"\n");
    off = append(off, ?buf[0], 512, "out = \"out\"\n");
    off = append(off, ?buf[0], 512, "dep = \"dep\"\n");
    off = append(off, ?buf[0], 512, "\n");
    off = append(off, ?buf[0], 512, "[targets.linux]\n");
    off = append(off, ?buf[0], 512, "os = \"linux\"\n");
    off = append(off, ?buf[0], 512, "isa = \"x86_64\"\n");
    off = append(off, ?buf[0], 512, "abi = \"sysv64\"\n");
    off = append(off, ?buf[0], 512, "mode = \"executable\"\n");
    off = append(off, ?buf[0], 512, "entrypoint = \"main.mach\"\n");
    off = append(off, ?buf[0], 512, "binary = \"");
    off = append(off, ?buf[0], 512, name);
    off = append(off, ?buf[0], 512, "\"\n");

    buf[off] = 0;
    ret (?buf[0])::str;
}

fun build_main() str {
    var buf: [256]u8;
    var off: usize = 0;

    off = append(off, ?buf[0], 256, "use std.runtime;\n");
    off = append(off, ?buf[0], 256, "use print: std.print;\n");
    off = append(off, ?buf[0], 256, "\n");
    off = append(off, ?buf[0], 256, "$main.symbol = \"main\";\n");
    off = append(off, ?buf[0], 256, "fun main(argc: i64, argv: **u8) i64 {\n");
    off = append(off, ?buf[0], 256, "    print.println(\"hello, mach!\");\n");
    off = append(off, ?buf[0], 256, "    ret 0;\n");
    off = append(off, ?buf[0], 256, "}\n");

    buf[off] = 0;
    ret (?buf[0])::str;
}

fun append(off: usize, buf: *u8, cap: usize, s: str) usize {
    val len: usize = str_len(s);
    if (off + len >= cap) { ret off; }
    mem.raw_copy((buf::usize + off)::ptr, s, len);
    ret off + len;
}
