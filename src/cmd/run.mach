# cmd.run: build and execute a mach project

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use arena:     std.allocator.arena;
use page:      std.allocator.page;
use print:     std.print;
use parse:     std.text.parse;
use exec:      std.process.exec;

use args:     mach.cli.args;
use config:   mach.config.project;
use session:  mach.compiler.session;
use compiler: mach.compiler.compiler;

# help: print run subcommand usage.
pub fun help() {
    print.println("usage: mach run [options]");
    print.println("");
    print.println("build and execute a mach project.");
}

# run: execute the run command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun run(argc: i64, argv: **u8) i64 {
    val target_name: str = args.get_option(argc, argv, "--target");
    val output_path: str = args.get_option(argc, argv, "-o");
    val jobs_str:    str = args.get_option(argc, argv, "-j");
    val is_release:  bool = args.has_flag(argc, argv, "--release");
    val emit_asm:    bool = args.has_flag(argc, argv, "--emit-asm");
    val verbose:     bool = args.has_flag(argc, argv, "--verbose");

    var opts: session.CompileOpts = session.default_opts();
    opts.release   = is_release;
    opts.emit_asm  = emit_asm;
    opts.verbose   = verbose;

    if (is_release) {
        opts.opt_level = 2;
        opts.verify_ir = false;
    }

    if (jobs_str != nil) {
        val jr: Result[u64, str] = parse.parse_u64(jobs_str, 10);
        if (is_ok[u64, str](jr)) {
            opts.jobs = unwrap_ok[u64, str](jr)::u32;
        } or {
            print.eprintln("error: invalid value for -j");
            ret 1;
        }
    }

    var backing: allocator.Allocator;
    page.make(?backing);
    var ar: arena.Arena;
    arena.init(?ar, ?backing, 16 * 1024 * 1024);
    var alloc: allocator.Allocator;
    arena.make(?alloc, ?ar);

    val load_res: Result[config.ProjectConfig, str] = config.load(?alloc, "mach.toml");
    if (is_err[config.ProjectConfig, str](load_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.ProjectConfig, str](load_res));
        ret 1;
    }
    var proj: config.ProjectConfig = unwrap_ok[config.ProjectConfig, str](load_res);

    var effective_target: str = target_name;
    if (effective_target == nil) {
        effective_target = proj.default_target;
    }
    if (effective_target == nil && proj.target_count > 0) {
        effective_target = proj.targets[0].name;
    }

    if (effective_target == nil) {
        print.eprintln("error: no target specified and no default target in mach.toml");
        config.dnit(?proj);
        ret 1;
    }

    val tc: *config.TargetConfig = config.find_target(?proj, effective_target);
    if (tc == nil) {
        print.eprintlnf("error: target '%s' not found in mach.toml", effective_target);
        config.dnit(?proj);
        ret 1;
    }

    if (verbose) {
        print.printlnf("building target '%s'...", effective_target);
    }

    val compile_result: session.CompileResult = compiler.compile_project(?alloc, ".", effective_target, nil, nil, opts);

    if (!compile_result.ok) {
        print.eprintln("error: compilation failed");
        config.dnit(?proj);
        ret 1;
    }

    var binary_path: str = compile_result.binary;
    if (binary_path == nil) {
        binary_path = tc.binary;
    }
    if (binary_path == nil) {
        binary_path = "a.out";
    }

    # find the "--" separator to split program args
    var separator_idx: i64 = 0;
    var si: i64 = 1;
    for (si < argc) {
        if (str_equals(argv[si]::str, "--")) {
            separator_idx = si;
            brk;
        }
        si = si + 1;
    }

    var prog_argc: i64 = 0;
    if (separator_idx > 0) {
        prog_argc = argc - separator_idx - 1;
    }

    # build argv array: [binary_path, <forwarded args...>, nil]
    val total_args: i64 = 1 + prog_argc + 1;
    val argv_res: Result[*usize, str] = allocator.allocate[usize](?alloc, total_args::usize);
    if (is_err[*usize, str](argv_res)) {
        print.eprintln("error: failed to allocate argv");
        config.dnit(?proj);
        ret 1;
    }
    val prog_argv: *usize = unwrap_ok[*usize, str](argv_res);

    prog_argv[0] = binary_path::usize;
    if (prog_argc > 0) {
        var pi: i64 = 0;
        for (pi < prog_argc) {
            prog_argv[1 + pi] = argv[separator_idx + 1 + pi]::usize;
            pi = pi + 1;
        }
    }
    prog_argv[1 + prog_argc] = 0;

    if (verbose) {
        print.printlnf("executing: %s", binary_path);
    }

    val exec_res: Result[exec.ExitStatus, str] = exec.run(binary_path, prog_argv::**u8, nil);
    if (is_err[exec.ExitStatus, str](exec_res)) {
        print.eprintlnf("error: failed to execute '%s'", binary_path);
        config.dnit(?proj);
        ret 1;
    }

    val status: exec.ExitStatus = unwrap_ok[exec.ExitStatus, str](exec_res);
    config.dnit(?proj);

    if (exec.exited(status)) {
        ret exec.code(status)::i64;
    }

    if (exec.signaled(status)) {
        print.eprintlnf("error: program killed by signal %d", exec.signal(status)::i64);
        ret 128 + exec.signal(status)::i64;
    }

    ret 1;
}
