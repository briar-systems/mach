use std.types.bool;
use std.types.string;
use std.types.list;
use std.types.size;
use std.types.result;
use std.types.option;

use toml:    std.data.toml;
use fs:      std.io.filesystem;
use console: std.io.console;

pub rec Dependency {
    id:   string; # unique dependency identifier
    path: string; # path to dependency source
}

pub fun (this: *Dependency) init() {
    this.id   = "";
    this.path = "";
}

pub fun (this: *Dependency) dnit() {
    this.id   = "";
    this.path = "";
}

pub rec Target {
    name:          string; # target name
    triple:        string; # target triple
    # TODO: validate that an entrypoint is necessary with manual runtime
    entrypoint:    string; # entrypoint file
    artifacts:     string; # output artifacts directory
    out:           string; # output binary path
    opt_level:     u8;     # optimization level
    emit_ast:      bool;   # emit AST files
    emit_ir:       bool;   # emit intermediate representation files
    emit_asm:      bool;   # emit assembly files
    emit_obj:      bool;   # emit object files
    build_library: bool;   # build as a library
    no_pie:        bool;   # disable position-independent executable generation
}

pub fun (this: *Target) init() {
    this.name          = "";
    this.triple        = "";
    this.entrypoint    = "";
    this.artifacts     = "";
    this.out           = "";
    this.opt_level     = 0;
    this.emit_ast      = false;
    this.emit_ir       = false;
    this.emit_asm      = false;
    this.emit_obj      = false;
    this.build_library = false;
    this.no_pie        = false;
}

pub fun (this: *Target) dnit() {
    this.name          = "";
    this.triple        = "";
    this.entrypoint    = "";
    this.artifacts     = "";
    this.out           = "";
    this.opt_level     = 0;
    this.emit_ast      = false;
    this.emit_ir       = false;
    this.emit_asm      = false;
    this.emit_obj      = false;
    this.build_library = false;
    this.no_pie        = false;
}

pub rec Config {
    project_id:   string; # unique project identifier
    project_name: string; # cannonical project name
    version:      string; # project version
    dir_source:   string; # source directory
    target:       string; # selected build target

    dependencies: List[Dependency]; # project dependencies
    targets:      List[Target];     # build targets
}

pub fun (this: *Config) init() {
    this.project_id   = "";
    this.project_name = "";
    this.version      = "";
    this.dir_source   = "";
    this.target       = "";

    val deps_result: Result[List[Dependency], string] = list_new[Dependency](8);
    if (deps_result.is_err()) {
        console.print("error: failed to allocate dependencies list\n");
        ret;
    }
    this.dependencies = deps_result.unwrap_ok();

    val targets_result: Result[List[Target], string] = list_new[Target](4);
    if (targets_result.is_err()) {
        console.print("error: failed to allocate targets list\n");
        ret;
    }
    this.targets = targets_result.unwrap_ok();
}

pub fun (this: *Config) dnit() {
    this.project_id   = "";
    this.project_name = "";
    this.version      = "";
    this.dir_source   = "";
    this.target       = "";

    var i: usize = 0;
    val dep_count: usize = this.dependencies.len;
    for (i < dep_count) {
        val dep_opt: Option[Dependency] = this.dependencies.get(i);
        if (dep_opt.is_some()) {
            var dep: Dependency = dep_opt.unwrap();
            dep.dnit();
        }
        i = i + 1;
    }
    this.dependencies.free();

    i = 0;
    val target_count: usize = this.targets.len;
    for (i < target_count) {
        val target_opt: Option[Target] = this.targets.get(i);
        if (target_opt.is_some()) {
            var target: Target = target_opt.unwrap();
            target.dnit();
        }
        i = i + 1;
    }
    this.targets.free();
}

pub fun (this: *Config) target_add(target: Target) Option[string] {
    ret this.targets.push(target);
}

pub fun (this: *Config) dependency_add(dep: Dependency) Option[string] {
    ret this.dependencies.push(dep);
}

fun get_string_from_table(table: *List[toml.TomlProperty], key: string) Option[string] {
    var i: usize = 0;
    for (i < table.len) {
        val prop_opt: Option[toml.TomlProperty] = table.get(i);
        if (prop_opt.is_some()) {
            val prop: toml.TomlProperty = prop_opt.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_string();
            }
        }
        i = i + 1;
    }
    ret none[string]();
}

fun get_integer_from_table(table: *List[toml.TomlProperty], key: string) Option[i64] {
    var i: usize = 0;
    for (i < table.len) {
        val prop_opt: Option[toml.TomlProperty] = table.get(i);
        if (prop_opt.is_some()) {
            val prop: toml.TomlProperty = prop_opt.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_integer();
            }
        }
        i = i + 1;
    }
    ret none[i64]();
}

fun get_bool_from_table(table: *List[toml.TomlProperty], key: string) Option[bool] {
    var i: usize = 0;
    for (i < table.len) {
        val prop_opt: Option[toml.TomlProperty] = table.get(i);
        if (prop_opt.is_some()) {
            val prop: toml.TomlProperty = prop_opt.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_bool();
            }
        }
        i = i + 1;
    }
    ret none[bool]();
}

fun get_table_from_table(table: *List[toml.TomlProperty], key: string) Option[*List[toml.TomlProperty]] {
    var i: usize = 0;
    for (i < table.len) {
        val prop_opt: Option[toml.TomlProperty] = table.get(i);
        if (prop_opt.is_some()) {
            val prop: toml.TomlProperty = prop_opt.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_table();
            }
        }
        i = i + 1;
    }
    ret none[*List[toml.TomlProperty]]();
}

fun get_array_from_table(table: *List[toml.TomlProperty], key: string) Option[*List[toml.TomlValue]] {
    var i: usize = 0;
    for (i < table.len) {
        val prop_opt: Option[toml.TomlProperty] = table.get(i);
        if (prop_opt.is_some()) {
            val prop: toml.TomlProperty = prop_opt.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_array();
            }
        }
        i = i + 1;
    }
    ret none[*List[toml.TomlValue]]();
}

fun parse_dependency(dep_table: *List[toml.TomlProperty]) Result[Dependency, string] {
    var dep: Dependency;
    dep.init();
    
    val id_opt: Option[string] = get_string_from_table(dep_table, "id");
    if (id_opt.is_some()) {
        dep.id = id_opt.unwrap();
    } or {
        ret err[Dependency, string]("dependency missing 'id' field");
    }
    
    val path_opt: Option[string] = get_string_from_table(dep_table, "path");
    if (path_opt.is_some()) {
        dep.path = path_opt.unwrap();
    } or {
        ret err[Dependency, string]("dependency missing 'path' field");
    }
    
    ret ok[Dependency, string](dep);
}

fun parse_target(target_table: *List[toml.TomlProperty]) Result[Target, string] {
    var target: Target;
    target.init();
    
    # required fields
    val name_opt: Option[string] = get_string_from_table(target_table, "name");
    if (name_opt.is_some()) {
        target.name = name_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'name' field");
    }
    
    # optional fields with defaults
    val triple_opt: Option[string] = get_string_from_table(target_table, "triple");
    if (triple_opt.is_some()) {
        target.triple = triple_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'triple' field");
    }
    
    val entrypoint_opt: Option[string] = get_string_from_table(target_table, "entrypoint");
    if (entrypoint_opt.is_some()) {
        target.entrypoint = entrypoint_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'entrypoint' field");
    }
    
    val artifacts_opt: Option[string] = get_string_from_table(target_table, "artifacts");
    if (artifacts_opt.is_some()) {
        target.artifacts = artifacts_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'artifacts' field");
    }
    
    val out_opt: Option[string] = get_string_from_table(target_table, "out");
    if (out_opt.is_some()) {
        target.out = out_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'out' field");
    }
    
    val opt_level_opt: Option[i64] = get_integer_from_table(target_table, "opt_level");
    if (opt_level_opt.is_some()) {
        target.opt_level = opt_level_opt.unwrap() :: u8;
    }
    or {
        ret err[Target, string]("target missing 'opt_level' field");
    }
    
    val emit_ast_opt: Option[bool] = get_bool_from_table(target_table, "emit_ast");
    if (emit_ast_opt.is_some()) {
        target.emit_ast = emit_ast_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'emit_ast' field");
    }
    
    val emit_ir_opt: Option[bool] = get_bool_from_table(target_table, "emit_ir");
    if (emit_ir_opt.is_some()) {
        target.emit_ir = emit_ir_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'emit_ir' field");
    }
    
    val emit_asm_opt: Option[bool] = get_bool_from_table(target_table, "emit_asm");
    if (emit_asm_opt.is_some()) {
        target.emit_asm = emit_asm_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'emit_asm' field");
    }
    
    val emit_obj_opt: Option[bool] = get_bool_from_table(target_table, "emit_obj");
    if (emit_obj_opt.is_some()) {
        target.emit_obj = emit_obj_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'emit_obj' field");
    }
    
    val build_library_opt: Option[bool] = get_bool_from_table(target_table, "build_library");
    if (build_library_opt.is_some()) {
        target.build_library = build_library_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'build_library' field");
    }
    
    val no_pie_opt: Option[bool] = get_bool_from_table(target_table, "no_pie");
    if (no_pie_opt.is_some()) {
        target.no_pie = no_pie_opt.unwrap();
    }
    or {
        ret err[Target, string]("target missing 'no_pie' field");
    }
    
    ret ok[Target, string](target);
}

pub fun config_read(path: string) Result[Config, string] {
    # read file contents
    val file_result: Result[[]u8, i32] = fs.read_all(path);
    if (file_result.is_err()) {
        val err_code: i32 = file_result.unwrap_err();
        val err_msg: []u8 = fs.error_string(err_code);
        ret err[Config, string](string{ err_msg.data, err_msg.len });
    }
    
    val contents: []u8 = file_result.unwrap_ok();
    val content_str: string = string{ contents.data, contents.len };
    
    # parse toml
    val toml_result: Result[toml.TomlValue, string] = toml.parse_toml(content_str);
    if (toml_result.is_err()) {
        ret err[Config, string](toml_result.unwrap_err());
    }
    
    val root: toml.TomlValue = toml_result.unwrap_ok();
    val root_table_opt: Option[*List[toml.TomlProperty]] = root.as_table();
    if (root_table_opt.is_none()) {
        ret err[Config, string]("invalid config: expected table at root");
    }
    
    val root_table: *List[toml.TomlProperty] = root_table_opt.unwrap();
    
    # initialize config
    var config: Config;
    config.init();
    
    # parse required fields
    val project_id_opt: Option[string] = get_string_from_table(root_table, "id");
    if (project_id_opt.is_some()) {
        config.project_id = project_id_opt.unwrap();
    } or {
        ret err[Config, string]("missing required field 'id'");
    }
    
    val project_name_opt: Option[string] = get_string_from_table(root_table, "name");
    if (project_name_opt.is_some()) {
        config.project_name = project_name_opt.unwrap();
    } or {
        ret err[Config, string]("missing required field 'name'");
    }
    
    # parse optional fields
    val version_opt: Option[string] = get_string_from_table(root_table, "version");
    if (version_opt.is_some()) {
        config.version = version_opt.unwrap();
    }
    or {
        ret err[Config, string]("missing required field 'version'");
    }
    
    val dir_source_opt: Option[string] = get_string_from_table(root_table, "src");
    if (dir_source_opt.is_some()) {
        config.dir_source = dir_source_opt.unwrap();
    }
    or {
        ret err[Config, string]("missing required field 'src'");
    }
    
    val target_opt: Option[string] = get_string_from_table(root_table, "target");
    if (target_opt.is_some()) {
        config.target = target_opt.unwrap();
    }
    or {
        ret err[Config, string]("missing required field 'target'");
    }
    
    # parse dependencies array
    val deps_array_opt: Option[*List[toml.TomlValue]] = get_array_from_table(root_table, "dependencies");
    if (deps_array_opt.is_some()) {
        val deps_array: *List[toml.TomlValue] = deps_array_opt.unwrap();
        var i: usize = 0;
        for (i < deps_array.len) {
            val dep_val_opt: Option[toml.TomlValue] = deps_array.get(i);
            if (dep_val_opt.is_some()) {
                val dep_val: toml.TomlValue = dep_val_opt.unwrap();
                val dep_table_opt: Option[*List[toml.TomlProperty]] = dep_val.as_table();
                if (dep_table_opt.is_some()) {
                    val dep_result: Result[Dependency, string] = parse_dependency(dep_table_opt.unwrap());
                    if (dep_result.is_err()) {
                        ret err[Config, string](dep_result.unwrap_err());
                    }
                    config.dependency_add(dep_result.unwrap_ok());
                }
            }
            i = i + 1;
        }
    }
    
    # parse targets array
    val targets_array_opt: Option[*List[toml.TomlValue]] = get_array_from_table(root_table, "targets");
    if (targets_array_opt.is_some()) {
        val targets_array: *List[toml.TomlValue] = targets_array_opt.unwrap();
        var i: usize = 0;
        for (i < targets_array.len) {
            val target_val_opt: Option[toml.TomlValue] = targets_array.get(i);
            if (target_val_opt.is_some()) {
                val target_val: toml.TomlValue = target_val_opt.unwrap();
                val target_table_opt: Option[*List[toml.TomlProperty]] = target_val.as_table();
                if (target_table_opt.is_some()) {
                    val target_result: Result[Target, string] = parse_target(target_table_opt.unwrap());
                    if (target_result.is_err()) {
                        ret err[Config, string](target_result.unwrap_err());
                    }
                    config.target_add(target_result.unwrap_ok());
                }
            }
            i = i + 1;
        }
    }
    or {
        ret err[Config, string]("project configuration missing at least one target entry");
    }
    
    ret ok[Config, string](config);
}
