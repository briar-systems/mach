use std.types.bool;
use std.types.string;
use std.types.result;

# mach.util.git: git operations for dependency management.
# ---
# provides helpers for git operations like submodule management and version
# checkout. these are used by the dep command for dependency management.

# exec: execute a git command and return the exit code.
# ---
# command: git command string to execute (e.g. "git init")
# ret:     Ok(exit_code) on success, Err(str) on failure
pub fun exec(command: str) Result[i32, str] {
    if (command == nil) {
        ret err[i32, str]("command is nil");
    }

    # TODO: implement command execution via fork/exec or posix_spawn
    # this requires platform-specific syscall bindings

    ret err[i32, str]("git exec not yet implemented");
}

# init: initialize a new git repository in the current directory.
# ---
# ret: Ok(true) on success, Err(str) on failure
pub fun init() Result[bool, str] {
    val res: Result[i32, str] = exec("git init");
    if (res.is_err()) {
        ret err[bool, str](res.unwrap_err());
    }

    if (res.unwrap_ok() != 0) {
        ret err[bool, str]("git init failed");
    }

    ret ok[bool, str](true);
}

