use std.types.size;
use std.types.string;
use pmem: std.system.platform.memory;

use pfs: std.system.platform.filesystem;
use int: std.types.int;
use std.types.bool;
use c: std.system.platform.linux.constants;

# read a file into a nul-terminated string using the provided allocator
# out_src/out_err are out-params: on success the function returns true and sets
# `out_src` to the file contents; on failure it returns false and sets
# `out_err` to a human-readable error message. This avoids returning
# `Result[str,str]` by-value across module boundaries.
pub fun read_file(path: str, out_src: *ptr, out_err: *ptr) bool {
    if (path == nil) {
        @out_err = "path is nil"::ptr;
        ret false;
    }

    # open directly using platform syscall to avoid cross-module Result ABI issues.
    # note: std.system.platform.linux.constants.AT_FDCWD is currently miscompiled
    # by the bootstrap toolchain (ends up as 0), so compute -100 at runtime.
    var dirfd: i32 = 0;
    dirfd = dirfd - 100;
    val raw_fd: i64 = pfs.openat(dirfd, path, c.O_RDONLY, 0);
    if (raw_fd < 0) { @out_err = "open failed"::ptr; ret false; }
    val fd: i32 = int.trunc_i64_to_i32(raw_fd);

    # determine file size using lseek to avoid depending on stat struct layout.
    val end: i64 = pfs.lseek(fd, 0, c.SEEK_END);
    if (end < 0) { pfs.close(fd); @out_err = "seek failed"::ptr; ret false; }

    val rewind: i64 = pfs.lseek(fd, 0, c.SEEK_SET);
    if (rewind < 0) { pfs.close(fd); @out_err = "seek failed"::ptr; ret false; }

    if (end < 0) { pfs.close(fd); @out_err = "invalid file size"::ptr; ret false; }
    val size: usize = end::usize;

    # allocate a buffer size + 1 (for nul)
    val p: ptr = pmem.allocate(size + 1);
    if (p == nil) { pfs.close(fd); @out_err = "out of memory"::ptr; ret false; }
    val buf: ptr = p;
    var total: usize = 0;

    for (total < size) {
        val p: *u8 = (buf::usize + total)::*u8;
        val raw_r: i64 = pfs.read(fd, p, size - total);
        if (raw_r < 0) { pfs.close(fd); @out_err = "read failed"::ptr; ret false; }
        val got: usize = raw_r::usize;
        if (got == 0) { brk; }
        total = total + got;
    }

    # nul terminate
    val bytes: *u8 = buf::*u8;
    bytes[total] = 0;

    pfs.close(fd);
    @out_src = buf;
    ret true;
}
