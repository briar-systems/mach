use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use allocator: std.allocator;
use fs:        std.filesystem;
use mem:       std.memory;
use path:      std.types.path;
use c:         std.system.platform.linux.constants;
use pfs:       std.system.platform.filesystem;

# mach.util.filesystem: filesystem utilities extending the standard library.
# ---
# provides higher-level helpers for common filesystem operations needed by the
# compiler, such as reading entire files, checking file types, and finding
# project roots.

# read_file: read an entire file into a null-terminated string.
# ---
# file_path: path to the file to read
# alloc:     allocator to use for the buffer
# ret:       Ok(str) with file contents on success, Err(str) on failure
pub fun read_file(file_path: str, alloc: *allocator.Allocator) Result[str, str] {
    if (file_path == nil) {
        ret err[str, str]("file path is nil");
    }

    if (alloc == nil) {
        ret err[str, str]("allocator is nil");
    }

    val open_res: Result[fs.File, str] = fs.open(file_path);
    if (result_is_err[fs.File, str](open_res)) {
        ret err[str, str](result_unwrap_err[fs.File, str](open_res));
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](open_res);

    val stat_res: Result[fs.Stat, str] = fs.file_stat(?file);
    if (result_is_err[fs.Stat, str](stat_res)) {
        fs.file_close(?file);
        ret err[str, str](result_unwrap_err[fs.Stat, str](stat_res));
    }

    val st: fs.Stat = result_unwrap_ok[fs.Stat, str](stat_res);
    val file_size: usize = st.st_size::usize;

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, file_size + 1);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        fs.file_close(?file);
        ret err[str, str](result_unwrap_err[*u8, allocator.AllocError](buf_res));
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    val read_res: Result[usize, str] = fs.file_read(?file, buf, file_size);
    if (result_is_err[usize, str](read_res)) {
        allocator.allocator_free[u8](alloc, buf, file_size + 1);
        fs.file_close(?file);
        ret err[str, str](result_unwrap_err[usize, str](read_res));
    }

    buf[file_size] = '\0';
    fs.file_close(?file);

    ret ok[str, str](buf::&u8);
}

# file_exists: check if a file exists and is accessible.
# ---
# file_path: path to check
# ret:       true if file exists and can be opened, false otherwise
pub fun file_exists(file_path: str) bool {
    if (file_path == nil) {
        ret false;
    }

    val open_res: Result[fs.File, str] = fs.open(file_path);
    if (result_is_err[fs.File, str](open_res)) {
        ret false;
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](open_res);
    fs.file_close(?file);
    ret true;
}

# is_mach_file: check if a path ends with .mach extension.
# ---
# file_path: path to check
# ret:       true if path ends with ".mach", false otherwise
pub fun is_mach_file(file_path: str) bool {
    if (file_path == nil) {
        ret false;
    }

    ret str_ends_with(file_path, ".mach");
}

# find_project_root: find the project root by searching for mach.toml.
# ---
# start_path: path to start searching from
# alloc:      allocator for path operations
# ret:        Ok(path) to project root, Err(str) if not found
pub fun find_project_root(start_path: str, alloc: *allocator.Allocator) Result[str, str] {
    if (start_path == nil) {
        ret err[str, str]("start path is nil");
    }

    if (alloc == nil) {
        ret err[str, str]("allocator is nil");
    }

    # start with the given path
    var current_path: str = start_path;
    var depth: i32 = 0;
    val max_depth: i32 = 32;  # prevent infinite loops

    for (depth < max_depth) {
        # check if mach.toml exists in current path
        val join_res: Result[path.Path, allocator.AllocError] = path.join(alloc, current_path, "mach.toml");
        if (result_is_ok[path.Path, allocator.AllocError](join_res)) {
            val config_path: str = result_unwrap_ok[path.Path, allocator.AllocError](join_res);
            if (file_exists(config_path)) {
                ret ok[str, str](current_path);
            }
        }

        # check if we've reached the root
        if (path.is_root(current_path)) {
            brk;
        }

        # get parent directory using path.parent()
        val parent_res: Result[path.Path, allocator.AllocError] = path.parent(alloc, current_path);
        if (result_is_err[path.Path, allocator.AllocError](parent_res)) {
            brk;
        }

        val parent_path: str = result_unwrap_ok[path.Path, allocator.AllocError](parent_res);

        # check if parent is same as current (no progress)
        if (str_equals(parent_path, current_path)) {
            brk;
        }

        # check if we got "." (relative path exhausted)
        if (str_equals(parent_path, ".")) {
            brk;
        }

        current_path = parent_path;
        depth = depth + 1;
    }

    ret err[str, str]("project root not found");
}

# get_extension: get the file extension from a path.
# ---
# file_path: path to extract extension from
# ret:       extension including the dot (e.g. ".mach"), or empty string if none
pub fun get_extension(file_path: str) str {
    if (file_path == nil) {
        ret "";
    }

    val len: usize = str_len(file_path);
    if (len == 0) {
        ret "";
    }

    # search backwards for '.'
    var i: usize = len;
    for (i > 0) {
        i = i - 1;
        val c: u8 = file_path[i];

        # stop at path separator
        if (c == path.separator()) {
            ret "";
        }

        if (c == '.') {
            ret (file_path::usize + i)::str;
        }
    }

    ret "";
}

# get_basename: get the filename from a path (everything after the last separator).
# ---
# file_path: path to extract basename from
# ret:       basename portion of the path
pub fun get_basename(file_path: str) str {
    if (file_path == nil) {
        ret "";
    }

    val len: usize = str_len(file_path);
    if (len == 0) {
        ret "";
    }

    val sep: u8 = path.separator();

    # search backwards for separator
    var i: usize = len;
    for (i > 0) {
        i = i - 1;
        if (file_path[i] == sep) {
            ret (file_path::usize + i + 1)::str;
        }
    }

    # no separator found, entire path is the basename
    ret file_path;
}

# get_dirname: get the directory portion of a path (everything before the last separator).
# ---
# file_path: path to extract dirname from
# alloc:     allocator for result string
# ret:       Ok(dirname) on success, Err(str) on failure
pub fun get_dirname(file_path: str, alloc: *allocator.Allocator) Result[str, str] {
    if (file_path == nil) {
        ret err[str, str]("file path is nil");
    }

    if (alloc == nil) {
        ret err[str, str]("allocator is nil");
    }

    # delegate to path.parent() for OS-agnostic behavior
    val parent_res: Result[path.Path, allocator.AllocError] = path.parent(alloc, file_path);
    if (result_is_err[path.Path, allocator.AllocError](parent_res)) {
        ret err[str, str](result_unwrap_err[path.Path, allocator.AllocError](parent_res));
    }

    ret ok[str, str](result_unwrap_ok[path.Path, allocator.AllocError](parent_res));
}

# path_join: join two path components with a separator.
# ---
# base:  base path
# rel:   relative path to append
# alloc: allocator for result
# ret:   joined path or nil on failure
pub fun path_join(base: str, rel: str, alloc: *allocator.Allocator) str {
    if (base == nil || rel == nil || alloc == nil) {
        ret nil;
    }

    val base_len: usize = str_len(base);
    val rel_len: usize = str_len(rel);
    val total: usize = base_len + 1 + rel_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret nil;
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);
    var pos: usize = 0;

    var i: usize = 0;
    for (i < base_len) {
        buf[pos] = base[i];
        pos = pos + 1;
        i = i + 1;
    }

    if (base_len > 0 && base[base_len - 1] != '/') {
        buf[pos] = '/';
        pos = pos + 1;
    }

    i = 0;
    for (i < rel_len) {
        buf[pos] = rel[i];
        pos = pos + 1;
        i = i + 1;
    }

    buf[pos] = '\0';
    ret buf::&u8;
}

# get_output_dir: return the parent directory of a file path.
# ---
# file_path: path to extract directory from
# alloc:     allocator for result
# ret:       parent directory or nil on failure
pub fun get_output_dir(file_path: str, alloc: *allocator.Allocator) str {
    if (file_path == nil || alloc == nil) { ret nil; }
    val len: usize = str_len(file_path);
    if (len == 0) { ret nil; }

    var i: usize = len;
    for (i > 0 && file_path[i - 1] != '/') {
        i = i - 1;
    }

    if (i == 0) { ret nil; }
    if (i == 1 && file_path[0] == '/') { ret "/"; }

    val dir_len: usize = i - 1;
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, dir_len + 1);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var j: usize = 0;
    for (j < dir_len) {
        buf[j] = file_path[j];
        j = j + 1;
    }
    buf[dir_len] = '\0';
    ret buf::&u8;
}

# ensure_dir: recursively create directories (mkdir -p).
# ---
# path_str: directory path to create
# alloc:    allocator for temporary buffer
# ret:      true on success, false on failure
pub fun ensure_dir(path_str: str, alloc: *allocator.Allocator) bool {
    if (path_str == nil) { ret false; }
    if (alloc == nil) { ret false; }
    val len: usize = str_len(path_str);
    if (len == 0) { ret false; }

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) { ret false; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var i: usize = 0;
    for (i < len) {
        buf[i] = path_str[i];
        i = i + 1;
    }
    buf[len] = '\0';

    i = 0;
    for (i < len) {
        if (buf[i] == '/' && i > 0) {
            val saved: u8 = buf[i];
            buf[i] = '\0';
            val result: i64 = pfs.mkdirat(c.AT_FDCWD, buf::&u8, 0o755);
            if (result < 0 && result != c.EEXIST) {
                ret false;
            }
            buf[i] = saved;
        }
        i = i + 1;
    }

    val final_res: i64 = pfs.mkdirat(c.AT_FDCWD, buf::&u8, 0o755);
    if (final_res < 0 && final_res != c.EEXIST) {
        ret false;
    }

    ret true;
}
