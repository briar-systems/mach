use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use platform:  std.system.platform;

use c:   std.system.platform.linux.constants;
use pfs: std.system.platform.filesystem;
use sc:  std.system.platform.linux.syscall;

use utilfs: mach.util.filesystem;

# mach.util.process: process execution utilities.
# ---
# provides centralized process management: environment inheritance, PATH-based
# binary resolution, and command execution. all command files should use this
# module instead of directly calling fork/execve with hardcoded paths.

# symlinkat syscall number (x86_64 linux)
val SYS_SYMLINKAT: usize = 266;

# maximum number of PATH entries to search
val MAX_PATH_ENTRIES: i32 = 64;

# maximum path length for resolved binary paths
val MAX_PATH_LEN: usize = 4096;

# stored environment pointer, set once from main via init_env.
var g_envp: &&u8 = nil;

# init_env: initialize the process environment from main's argc/argv.
# ---
# on linux, envp sits on the stack immediately after the null-terminated argv
# array: envp = argv + argc + 1.
#
# must be called once at startup before any command execution.
#
# argc: argument count from main
# argv: argument vector from main
pub fun init_env(argc: i64, argv: &&u8) {
    if (argv == nil) {
        ret;
    }

    # envp is at argv[argc + 1] (after the null terminator of argv)
    g_envp = (argv::usize + ((argc + 1)::usize * 8))::&&u8;
}

# get_envp: return the stored environment pointer.
# ---
# ret: pointer to the null-terminated environment array, or nil
pub fun get_envp() &&u8 {
    ret g_envp;
}

# getenv: look up an environment variable by name.
# ---
# name: variable name to look up (e.g., "PATH")
# ret: value string or nil if not found
pub fun getenv(name: str) str {
    if (name == nil || g_envp == nil) {
        ret nil;
    }

    val name_len: usize = str_len(name);
    if (name_len == 0) {
        ret nil;
    }

    var i: usize = 0;
    for (g_envp[i] != nil) {
        val entry: str = g_envp[i];
        if (entry != nil) {
            # check if entry starts with "name="
            var match: bool = true;
            var j: usize = 0;
            for (j < name_len) {
                if (entry[j] != name[j]) {
                    match = false;
                    brk;
                }
                j = j + 1;
            }

            if (match && entry[name_len] == '=') {
                # return pointer past the '='
                ret (entry::usize + name_len + 1)::str;
            }
        }

        i = i + 1;
    }

    ret nil;
}

# resolve_binary: find a binary by searching PATH.
# ---
# name:  binary name (e.g., "git", "rm")
# alloc: allocator for the result path
# ret:   absolute path to the binary, or nil if not found
#
# if name already contains '/', it is checked directly and returned as-is.
# otherwise, each directory in PATH is searched in order.
pub fun resolve_binary(name: str, alloc: *allocator.Allocator) str {
    if (name == nil || alloc == nil) {
        ret nil;
    }

    # if name contains '/', treat it as a path and check directly
    val name_len: usize = str_len(name);
    var has_slash: bool = false;
    var k: usize = 0;
    for (k < name_len) {
        if (name[k] == '/') {
            has_slash = true;
            brk;
        }
        k = k + 1;
    }

    if (has_slash) {
        if (is_executable(name)) {
            ret name;
        }
        ret nil;
    }

    # look up PATH from environment
    val path_env: str = getenv("PATH");
    if (path_env == nil) {
        ret nil;
    }

    val path_len: usize = str_len(path_env);

    # iterate over PATH entries separated by ':'
    var start: usize = 0;
    var i: usize = 0;
    for (i <= path_len) {
        if (i == path_len || path_env[i] == ':') {
            val dir_len: usize = i - start;
            if (dir_len > 0) {
                # build candidate: dir + "/" + name + '\0'
                val total: usize = dir_len + 1 + name_len + 1;
                if (total <= MAX_PATH_LEN) {
                    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
                    if (result_is_ok[*u8, allocator.AllocError](buf_res)) {
                        val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);
                        var p: usize = 0;

                        # copy dir
                        var j: usize = 0;
                        for (j < dir_len) {
                            buf[p] = path_env[start + j];
                            p = p + 1;
                            j = j + 1;
                        }

                        buf[p] = '/';
                        p = p + 1;

                        # copy name
                        j = 0;
                        for (j < name_len) {
                            buf[p] = name[j];
                            p = p + 1;
                            j = j + 1;
                        }

                        buf[p] = '\0';
                        val candidate: str = buf::&u8;

                        if (is_executable(candidate)) {
                            ret candidate;
                        }
                    }
                }
            }

            start = i + 1;
        }

        i = i + 1;
    }

    ret nil;
}

# is_executable: check if a path is an executable file.
# ---
# path: file path to check
# ret: true if file exists and is executable
fun is_executable(path: str) bool {
    if (path == nil) {
        ret false;
    }

    # F_OK=0 checks existence, X_OK=1 checks execute permission
    val result: i64 = pfs.faccessat(c.AT_FDCWD, path, 1, 0);
    ret result == 0;
}

# run_command: execute a command using fork/exec with inherited environment.
# ---
# argv: null-terminated argument array (argv[0] = program path)
# ret: exit code of the command (0 = success), or -1 on fork/exec failure
pub fun run_command(argv: &&u8) i64 {
    val pid: i64 = platform.fork();

    if (pid < 0) {
        ret -1;
    }

    if (pid == 0) {
        # child process - execute the command with inherited environment
        var envp: &&u8 = g_envp;

        if (envp == nil) {
            # fallback: empty environment if init_env was never called
            var empty_envp: [1]&u8;
            empty_envp[0] = nil;
            envp = ?empty_envp[0];
        }

        val result: i64 = platform.execve(argv[0], argv, envp);

        # if execve returns, it failed
        platform.terminate(127);
    }

    # parent process - wait for child
    var status: i32 = 0;
    val wait_result: i64 = platform.waitpid(pid, ?status, 0);

    if (wait_result < 0) {
        ret -1;
    }

    if (platform.wifexited(status)) {
        ret platform.wexitstatus(status)::i64;
    }

    if (platform.wifsignaled(status)) {
        ret (128 + platform.wtermsig(status))::i64;
    }

    ret -1;
}

# run_binary: execute a binary with arguments and inherited environment.
# ---
# binary_path: path to the executable
# argc: number of arguments to pass
# argv: argument array
# ret: exit code of the executed program
pub fun run_binary(binary_path: str, argc: i64, argv: &&u8) i64 {
    val pid: i64 = platform.fork();

    if (pid < 0) {
        ret -1;
    }

    if (pid == 0) {
        # child process - build argv and execute
        var exec_argv: [64]&u8;
        exec_argv[0] = binary_path;

        var i: i64 = 0;
        for (i < argc && i < 62) {
            exec_argv[i + 1] = argv[i];
            i = i + 1;
        }
        exec_argv[i + 1] = nil;

        var envp: &&u8 = g_envp;
        if (envp == nil) {
            var empty_envp: [1]&u8;
            empty_envp[0] = nil;
            envp = ?empty_envp[0];
        }

        val result: i64 = platform.execve(binary_path, ?exec_argv[0], envp);

        # if execve returns, it failed
        platform.terminate(1);
    }

    # parent process - wait for child
    var status: i32 = 0;
    val wait_result: i64 = platform.waitpid(pid, ?status, 0);

    if (wait_result < 0) {
        ret -1;
    }

    if (platform.wifexited(status)) {
        ret platform.wexitstatus(status)::i64;
    }

    if (platform.wifsignaled(status)) {
        ret (128 + platform.wtermsig(status))::i64;
    }

    ret -1;
}

# symlinkat: create a symbolic link using the platform syscall interface.
# ---
# target: path that the symlink points to
# dirfd: directory fd for relative linkpath (AT_FDCWD for cwd)
# linkpath: path of the symlink to create
# ret: 0 on success, negative errno on failure
pub fun symlinkat(target: str, dirfd: i32, linkpath: str) i64 {
    ret sc.syscall3(SYS_SYMLINKAT, target::usize, dirfd::isize::usize, linkpath::usize);
}
