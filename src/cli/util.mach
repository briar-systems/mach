# mach.cli.util: shared CLI primitives — string, io, argv, and path helpers.
#
# every subcommand needs the same handful of null-terminated-string,
# argv-scanning, and project-path operations; this module owns the single
# copy of each so a fix lands once. it allocates nothing and frames no parse
# state: the argv helpers are exact-match scans over the raw vector, mirroring
# `mach.cli.args` (which this supersedes), and the path helpers operate on
# caller-provided buffers. `--flag=value` and bundled short flags are
# intentionally not recognized.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.result.Result;
use std.types.result.is_ok;

use os: std.system.os;
use fs: std.filesystem;

# eq: byte-wise equality of two null-terminated `*u8` strings.
# ---
# a:   first null-terminated byte string
# b:   second null-terminated byte string
# ret: true if both reach the terminator at the same position with matching bytes
pub fun eq(a: *u8, b: *u8) bool {
    if (a == b)               { ret true; }
    if (a == nil || b == nil) { ret false; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}

# slen: length in bytes of a null-terminated `*u8` string, excluding the terminator.
# ---
# s:   null-terminated byte string
# ret: number of bytes before the terminator (0 for nil)
pub fun slen(s: *u8) usize {
    if (s == nil) { ret 0; }
    var n: usize = 0;
    for (s[n] != 0) { n = n + 1; }
    ret n;
}

# cstr_str: view a null-terminated `*u8` as a length-counted `str`. the result
# borrows the same bytes — it must not outlive `s`.
# ---
# s:   null-terminated byte string
# ret: a `str` over the same bytes
pub fun cstr_str(s: *u8) str {
    ret s::str;
}

# out: write a null-terminated `*u8` string to stdout.
# ---
# s: null-terminated byte string to write
pub fun out(s: *u8) {
    os.write(os.STDOUT_FD, s, slen(s));
}

# emit: write a null-terminated `*u8` string to stderr.
# ---
# s: null-terminated byte string to write
pub fun emit(s: *u8) {
    os.write(os.STDERR_FD, s, slen(s));
}

# emit_num: write the base-10 rendering of `n` to stderr.
# ---
# n: the value to render
pub fun emit_num(n: usize) {
    var buf: [24]u8;
    var blen: usize = 0;
    var v: usize = n;
    if (v == 0) { buf[0] = '0'; blen = 1; }
    or {
        var tmp: [24]u8;
        var t: usize = 0;
        for (v > 0) { tmp[t] = (v % 10)::u8 + '0'; v = v / 10; t = t + 1; }
        var ri: usize = 0;
        for (ri < t) { buf[ri] = tmp[t - 1 - ri]; ri = ri + 1; }
        blen = t;
    }
    os.write(os.STDERR_FD, ?buf[0], blen);
}

# has_flag: returns true if argv contains an exact match for `flag`.
# ---
# argc: the number of arguments to scan
# argv: the argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  true if the flag appears in argv[0..argc)
pub fun has_flag(argc: usize, argv: **u8, flag: *u8) bool {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# get_value: returns the argument following the given flag, if present.
# ---
# argc: the number of arguments to scan
# argv: the argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  some(next arg) when the flag is found and followed by a value, else none
pub fun get_value(argc: usize, argv: **u8, flag: *u8) Option[*u8] {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) {
            if (i + 1 < argc) { ret some[*u8](argv[i + 1]); }
            ret none[*u8]();
        }
        i = i + 1;
    }
    ret none[*u8]();
}

# is_flag: returns true when `s` looks like a flag (begins with '-').
# ---
# s:   the token to test
# ret: true when `s` is non-nil and starts with '-'
pub fun is_flag(s: *u8) bool {
    ret s != nil && s[0] == '-';
}

# is_value_flag: whether a token is a known flag that consumes the following
# argv entry as its value. one table for every value flag the CLI recognizes,
# so the positional and link-input scanners step over a flag's value rather
# than mistaking it for a positional or an object path.
# ---
# a:   the token to test
# ret: true when `a` is a value-taking flag
pub fun is_value_flag(a: *u8) bool {
    ret eq(a, "-L") || eq(a, "-l") || eq(a, "-o") ||
        eq(a, "--target") || eq(a, "--cwd") || eq(a, "--color") ||
        eq(a, "--artifacts") || eq(a, "--emit") || eq(a, "--filter") ||
        eq(a, "--out") || eq(a, "--name") || eq(a, "--ref");
}

# separator_index: index of the `--` separator in argv, or argc when absent.
# the value doubles as the effective argument count for the build: everything
# at or after `--` is a program argument the build must not scan, so callers
# pass this index as the argc handed to the build's flag and link scanners.
# ---
# argc: the number of arguments
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  the index of the first `--`, or argc when there is none
pub fun separator_index(argc: usize, argv: **u8) usize {
    var i: usize = 1;
    for (i < argc) {
        if (eq(argv[i], "--")) { ret i; }
        i = i + 1;
    }
    ret argc;
}

# positional_index: index of the first bare (non-flag) argument at or after
# `start`, skipping each known value flag together with its value. returns
# argc when no positional is present.
# ---
# argc:  the number of arguments to scan
# argv:  the argument vector (argc null-terminated byte pointers)
# start: the index to begin scanning from (typically 2, past the subcommand)
# ret:   the index of the first positional, or argc when there is none
pub fun positional_index(argc: usize, argv: **u8, start: usize) usize {
    var i: usize = start;
    for (i < argc) {
        val a: *u8 = argv[i];
        if (is_value_flag(a) && i + 1 < argc) { i = i + 2; cnt; }
        if (a != nil && a[0] != '-') { ret i; }
        i = i + 1;
    }
    ret argc;
}

# join_into: join `dir` and `leaf` with a single '/' into the caller-provided
# buffer and null-terminate. `dir` may alias `buf`. returns the byte length
# written (excluding the terminator), or 0 if it would not fit.
# ---
# buf:  destination buffer
# cap:  capacity of `buf` in bytes
# dir:  leading directory component
# leaf: trailing component to append under `dir`
# ret:  bytes written excluding the terminator, or 0 when it would overflow
pub fun join_into(buf: *u8, cap: usize, dir: *u8, leaf: *u8) usize {
    val dl: usize = slen(dir);
    val ll: usize = slen(leaf);
    val need: usize = dl + 1 + ll + 1;
    if (need > cap) { ret 0; }
    var k: usize = 0;
    var i: usize = 0;
    for (i < dl) { buf[k] = dir[i]; k = k + 1; i = i + 1; }
    if (k > 0 && buf[k - 1] != '/') { buf[k] = '/'; k = k + 1; }
    i = 0;
    for (i < ll) { buf[k] = leaf[i]; k = k + 1; i = i + 1; }
    buf[k] = 0;
    ret k;
}

# parent_dir: strip the final path component of `path` in place, turning the
# last '/' into a terminator. returns true if a parent component remained,
# false when `path` had no separator (already at a root or bare name).
# ---
# path: the null-terminated path to truncate in place
# ret:  true when a parent remained, false at a root or bare name
pub fun parent_dir(path: *u8) bool {
    var last: usize = 0;
    var found: bool = false;
    var i: usize = 0;
    for (path[i] != 0) {
        if (path[i] == '/') { last = i; found = true; }
        i = i + 1;
    }
    if (!found) { ret false; }
    if (last == 0) {
        # path is "/<leaf>" — keep the root slash
        path[1] = 0;
        ret false;
    }
    path[last] = 0;
    ret true;
}

# find_project_root: walk up from `start` (or the process cwd when nil) until a
# directory containing mach.toml is found, writing the resolved root into
# `out_buf` (caller-provided, must hold at least 4096 bytes). returns true on
# success; false when no ancestor directory holds a mach.toml.
# ---
# start:   starting directory, or nil to begin at the process cwd
# out_buf: destination buffer for the resolved root
# cap:     capacity of `out_buf` in bytes
# ret:     true when a mach.toml-bearing ancestor was found
pub fun find_project_root(start: *u8, out_buf: *u8, cap: usize) bool {
    var i: usize = 0;
    if (start != nil && start[0] != 0) {
        val n: usize = slen(start);
        if (n + 1 > cap) { ret false; }
        for (i < n) { out_buf[i] = start[i]; i = i + 1; }
        out_buf[n] = 0;
    }
    or {
        val g: i64 = os.getcwd(out_buf, cap);
        if (g < 0) { ret false; }
    }

    var probe: [4096]u8;
    for (true) {
        val plen: usize = join_into(?probe[0], 4096, out_buf, "mach.toml");
        if (plen > 0 && fs.is_file(cstr_str(?probe[0]))) { ret true; }
        if (!parent_dir(out_buf)) { ret false; }
    }
    ret false;
}

# ensure_dir: create the directory at `path` if it does not already exist.
# returns true on success or when it already exists.
# ---
# path: the null-terminated directory path to create
# ret:  true when the directory exists after the call
pub fun ensure_dir(path: *u8) bool {
    val p: str = cstr_str(path);
    if (fs.is_dir(p)) { ret true; }
    val mk: Result[bool, str] = fs.create_dir(p, 493);
    if (is_ok[bool, str](mk)) { ret true; }
    ret fs.is_dir(p);
}

# ensure_parents: create every parent directory of the file path `path`
# (mkdir-p over the leading components, excluding the final leaf). each
# intermediate prefix is created in turn so deeply nested paths materialise
# their directories. the path buffer is restored after each temporary
# truncation. returns true once every parent exists.
# ---
# path: the null-terminated file path whose parents are created
# ret:  true once every parent directory exists
pub fun ensure_parents(path: *u8) bool {
    val n: usize = slen(path);
    var i: usize = 1;
    for (i < n) {
        if (path[i] == '/') {
            val saved: u8 = path[i];
            path[i] = 0;
            val ok_dir: bool = ensure_dir(path);
            path[i] = saved;
            if (!ok_dir) { ret false; }
        }
        i = i + 1;
    }
    ret true;
}

test "util: separator_index reports the -- boundary as the effective argc" {
    var argv: [4]*u8;
    argv[0] = "mach"; argv[1] = "run"; argv[2] = "--"; argv[3] = "x";
    if (separator_index(4, ?argv[0]) != 2) { ret 1; }

    var bare: [2]*u8;
    bare[0] = "mach"; bare[1] = "build";
    if (separator_index(2, ?bare[0]) != 2) { ret 1; }
    ret 0;
}

test "util: positional_index skips a value flag's value (mach init --name)" {
    # [mach, init, --name, myproj] has no positional: --name eats myproj.
    var a: [4]*u8;
    a[0] = "mach"; a[1] = "init"; a[2] = "--name"; a[3] = "myproj";
    if (positional_index(4, ?a[0], 2) != 4) { ret 1; }

    # an explicit directory is found, and --name's value is still skipped.
    var b: [5]*u8;
    b[0] = "mach"; b[1] = "init"; b[2] = "mydir"; b[3] = "--name"; b[4] = "x";
    if (positional_index(5, ?b[0], 2) != 2) { ret 1; }

    # mach build . resolves the '.' positional.
    var c: [3]*u8;
    c[0] = "mach"; c[1] = "build"; c[2] = ".";
    if (positional_index(3, ?c[0], 2) != 2) { ret 1; }
    ret 0;
}
