# shared CLI argv and path helpers, plus thin `*u8` bridges.
#
# Every subcommand needs the same handful of argv-scanning and project-path
# operations over the raw `**u8` / `*u8` argument vector, so this module owns
# the single copy of each. It frames no parse state: the argv helpers are
# exact-match, allocation-free scans over the raw vector, and the path helpers
# operate on caller-provided buffers. `resolve_cmd` alone allocates, through
# the caller's allocator. `--flag=value` and bundled short flags are
# intentionally not recognized.
#
# `cstr_len` and `cstr_str` are the remaining thin `*u8` bridges: `cstr_len` is
# the nil-safe length adapter (std `str_len` derefs nil, mach-std#204) and
# `cstr_str` views a `*u8` as a `str`.

use std.filesystem;
use std.system.os;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

# permission bits for a directory the CLI creates (octal 0755, rwxr-xr-x)
val DIR_MODE: i32 = 493;

# length in bytes of a null-terminated `*u8`, excluding the terminator
#
# The nil-safe adapter over `std.types.string.str_len` (which derefs nil);
# returns 0 for nil. The CLI `*u8` call sites can see nil (mach-std#204 tracks
# the std-side gap).
# ---
# s:   null-terminated byte string
# ret: number of bytes before the terminator (0 for nil)
pub fun cstr_len(s: *u8) usize {
    if (s == nil) { ret 0; }
    ret str_len(s::str);
}

# view a null-terminated `*u8` as a length-counted `str`
#
# The result borrows the same bytes; it must not outlive `s`.
# ---
# s:   null-terminated byte string
# ret: a `str` over the same bytes
pub fun cstr_str(s: *u8) str {
    ret s::str;
}

# whether argv contains an exact match for `flag`
# ---
# argc: number of arguments to scan
# argv: argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  true when the flag appears in argv[0, argc)
pub fun has_flag(argc: usize, argv: **u8, flag: *u8) bool {
    val want: str   = flag::str;
    var i:    usize = 0;
    for (i < argc) {
        if (str_equals(argv[i]::str, want)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# the argument following `flag`, when `flag` is present and is not the last token
# ---
# argc: number of arguments to scan
# argv: argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  some(next arg) when the flag is found and followed by a value, else none
pub fun get_value(argc: usize, argv: **u8, flag: *u8) O.Option[*u8] {
    val want: str   = flag::str;
    var i:    usize = 0;
    for (i < argc) {
        if (str_equals(argv[i]::str, want)) {
            if (i + 1 < argc) { ret O.some[*u8](argv[i + 1]); }
            ret O.none[*u8]();
        }
        i = i + 1;
    }
    ret O.none[*u8]();
}

# whether `s` looks like a flag (a non-nil token beginning with '-')
# ---
# s:   the token to test
# ret: true when `s` is non-nil and starts with '-'
pub fun is_flag(s: *u8) bool {
    ret s != nil && s[0] == '-';
}

# whether `a` is a known flag that consumes the following argv entry as its value
#
# One table for every value-taking flag the CLI recognizes, so the positional
# and link-input scanners step over a flag's value rather than mistaking it for
# a positional or an object path.
# ---
# a:   the token to test
# ret: true when `a` is a value-taking flag
pub fun is_value_flag(a: *u8) bool {
    val s: str = a::str;
    ret str_equals(s, "-L")
        || str_equals(s, "-l")
        || str_equals(s, "-o")
        || str_equals(s, "--target")
        || str_equals(s, "--color")
        || str_equals(s, "--artifacts")
        || str_equals(s, "--emit")
        || str_equals(s, "--filter")
        || str_equals(s, "--out")
        || str_equals(s, "--name")
        || str_equals(s, "--ref")
        || str_equals(s, "--profile")
        || str_equals(s, "--bin")
        || str_equals(s, "--lib")
        || str_equals(s, "--runner");
}

# index of the `--` separator in argv, or argc when absent
#
# The value doubles as the effective argument count for the build: everything
# at or after `--` is a program argument the build must not scan, so callers
# pass this index as the argc handed to the build's flag and link scanners.
# ---
# argc: number of arguments
# argv: argument vector (argc null-terminated byte pointers)
# ret:  index of the first `--`, or argc when there is none
pub fun separator_index(argc: usize, argv: **u8) usize {
    var i: usize = 1;
    for (i < argc) {
        if (str_equals(argv[i]::str, "--")) { ret i; }
        i = i + 1;
    }
    ret argc;
}

# index of the first bare (non-flag) argument at or after `start`, skipping each
# known value flag together with its value, or argc when none is present
# ---
# argc:  number of arguments to scan
# argv:  argument vector (argc null-terminated byte pointers)
# start: index to begin scanning from (typically 2, past the subcommand)
# ret:   index of the first positional, or argc when there is none
pub fun positional_index(argc: usize, argv: **u8, start: usize) usize {
    var i: usize = start;
    for (i < argc) {
        val a: *u8 = argv[i];
        if (is_value_flag(a) && i + 1 < argc) {
            i = i + 2;
            cnt;
        }
        if (a != nil && !is_flag(a)) { ret i; }
        i = i + 1;
    }
    ret argc;
}

# join `dir` and `leaf` with a single '/' into `buf` and null-terminate
#
# `dir` may alias `buf`. A trailing '/' already on `dir` is not doubled.
# ---
# buf:  destination buffer
# cap:  capacity of `buf` in bytes
# dir:  leading directory component
# leaf: trailing component to append under `dir`
# ret:  bytes written excluding the terminator, or 0 when it would overflow
pub fun join_into(buf: *u8, cap: usize, dir: *u8, leaf: *u8) usize {
    val dir_len:  usize = cstr_len(dir);
    val leaf_len: usize = cstr_len(leaf);
    val need:     usize = dir_len + 1 + leaf_len + 1;
    if (need > cap) { ret 0; }

    var w: usize = 0;
    var i: usize = 0;
    for (i < dir_len) {
        buf[w] = dir[i];
        w = w + 1;
        i = i + 1;
    }
    if (w > 0 && buf[w - 1] != '/') {
        buf[w] = '/';
        w = w + 1;
    }
    i = 0;
    for (i < leaf_len) {
        buf[w] = leaf[i];
        w = w + 1;
        i = i + 1;
    }
    buf[w] = 0;
    ret w;
}

# write `path` into `buf`, resolving it against `base` when relative or copying
# it verbatim when absolute (begins with '/')
#
# An absolute `path` ignores `base` entirely.
# ---
# buf:  destination buffer
# cap:  capacity of `buf` in bytes
# base: directory to join against when `path` is relative
# path: the path to resolve (absolute or relative)
# ret:  bytes written excluding the terminator, or 0 when it would overflow
pub fun path_into(buf: *u8, cap: usize, base: *u8, path: *u8) usize {
    val path_len: usize = cstr_len(path);
    if (path_len > 0 && path[0] == '/') {
        if (path_len + 1 > cap) { ret 0; }
        var i: usize = 0;
        for (i < path_len) {
            buf[i] = path[i];
            i = i + 1;
        }
        buf[path_len] = 0;
        ret path_len;
    }
    ret join_into(buf, cap, base, path);
}

# walk up from `start` until a directory containing mach.toml is found, writing
# the resolved root into `out_buf`
#
# `out_buf` must hold at least 4096 bytes. The search probes each ancestor for a
# mach.toml until one is found or the filesystem root is reached.
# ---
# start:   starting directory (required, non-nil)
# out_buf: destination buffer for the resolved root
# cap:     capacity of `out_buf` in bytes
# ret:     true when a mach.toml-bearing ancestor was found
pub fun find_project_root(start: *u8, out_buf: *u8, cap: usize) bool {
    val start_len: usize = cstr_len(start);
    if (start_len + 1 > cap) { ret false; }
    var i: usize = 0;
    for (i < start_len) {
        out_buf[i] = start[i];
        i = i + 1;
    }
    out_buf[start_len] = 0;

    var probe: [4096]u8;
    for (true) {
        val probe_len: usize = join_into(?probe[0], 4096, out_buf, "mach.toml");
        if (probe_len > 0 && filesystem.is_file(cstr_str(?probe[0]))) { ret true; }
        if (!parent_dir(out_buf))                                     { ret false; }
    }
    ret false;
}

# create the directory at `path` if it does not already exist
# ---
# path: the null-terminated directory path to create
# ret:  true when the directory exists after the call
pub fun ensure_dir(path: *u8) bool {
    val p: str = cstr_str(path);
    if (filesystem.is_dir(p)) { ret true; }
    val res_create: R.Result[bool, str] = filesystem.create_dir(p, DIR_MODE);
    if (R.is_ok[bool, str](res_create)) { ret true; }
    # tolerate a concurrent creation: re-check existence after a failed create
    ret filesystem.is_dir(p);
}

# create every parent directory of the file path `path` (mkdir -p over the
# leading components, excluding the final leaf)
#
# Each intermediate prefix is created in turn so a deeply nested path
# materialises its directories. `path` is restored after each temporary
# truncation.
# ---
# path: the null-terminated file path whose parents are created
# ret:  true once every parent directory exists
pub fun ensure_parents(path: *u8) bool {
    val path_len: usize = cstr_len(path);
    var i: usize = 1;
    for (i < path_len) {
        if (path[i] == '/') {
            path[i] = 0;
            val parent_ok: bool = ensure_dir(path);
            path[i] = '/';
            if (!parent_ok) { ret false; }
        }
        i = i + 1;
    }
    ret true;
}

# resolve a command name to a concrete executable path for `os.spawn`
#
# execve performs no PATH search, so a bare name is resolved by scanning the
# `PATH` environment variable; a name already containing a path separator is
# returned verbatim. The resolved path is allocated from `a`.
#
# The PATH list separator and the path component separator are platform
# specific: posix uses ':' and '/', windows uses ';' and '\'. The windows list
# separator must not be ':', since drive-letter prefixes (`C:\...`) embed a ':'
# that would otherwise shatter every entry.
# ---
# a:    allocator for the resolved path
# name: command name or path to resolve
# ret:  the executable path, or an error ("PATH unset" / "not found on PATH" / allocator error)
pub fun resolve_cmd(a: *A.Allocator, name: *u8) R.Result[*u8, str] {
    var list_sep: u8 = ':';
    var path_sep: u8 = '/';
    $if ($mach.build.os == $mach.os.windows) {
        list_sep = ';';
        path_sep = '\\';
    }

    # a name that already spells a path is returned verbatim; only bare names
    # are searched on PATH.
    val nlen: usize = cstr_len(name);
    var i: usize = 0;
    for (i < nlen) {
        if (name[i] == '/' || name[i] == path_sep) { ret R.ok[*u8, str](name); }
        i = i + 1;
    }

    var path_buf: [4096]u8;
    val getenv_len: i64 = os.getenv("PATH", ?path_buf[0], 4096);
    if (getenv_len <= 0) { ret R.err[*u8, str]("PATH unset"); }
    val plen: usize = getenv_len::usize;

    i = 0;
    for (i < plen) {
        val start: usize = i;
        for (i < plen && path_buf[i] != list_sep) { i = i + 1; }
        val end: usize = i;
        if (i < plen)     { i = i + 1; }
        if (end == start) { cnt; }

        val seg_len:  usize = end - start;
        val cand_len: usize = seg_len + 1 + nlen;
        val res_alloc: R.Result[*u8, str] = A.allocate[u8](a, cand_len + 1);
        if (R.is_err[*u8, str](res_alloc)) {
            ret R.err[*u8, str](R.unwrap_err[*u8, str](res_alloc));
        }
        val cand: *u8 = R.unwrap_ok[*u8, str](res_alloc);

        var w:  usize = 0;
        var ii: usize = start;
        for (ii < end) {
            cand[w] = path_buf[ii];
            w  = w + 1;
            ii = ii + 1;
        }
        cand[w] = path_sep;
        w = w + 1;
        ii = 0;
        for (ii < nlen) {
            cand[w] = name[ii];
            w  = w + 1;
            ii = ii + 1;
        }
        cand[w] = 0;

        if (filesystem.is_file(cand::str)) { ret R.ok[*u8, str](cand); }
        A.deallocate[u8](a, cand, cand_len + 1);
    }
    ret R.err[*u8, str]("not found on PATH");
}

# strip the final path component of `path` in place, turning the last '/' into a
# terminator
#
# Returns false when `path` has no separator (already a root or bare name); a
# "/leaf" path keeps its root slash.
# ---
# path: the null-terminated path to truncate in place
# ret:  true when a parent component remained
fun parent_dir(path: *u8) bool {
    var last_sep: usize = 0;
    var found:    bool  = false;
    var i:        usize = 0;
    for (path[i] != 0) {
        if (path[i] == '/') {
            last_sep = i;
            found    = true;
        }
        i = i + 1;
    }
    if (!found) { ret false; }
    if (last_sep == 0) {
        # path is "/<leaf>" - keep the root slash
        path[1] = 0;
        ret false;
    }
    path[last_sep] = 0;
    ret true;
}

# path_into copies an absolute path verbatim (ignoring base) and joins a
# relative path against base.
test "mach.cli.util.path_into:absolute_and_relative" {
    var buf: [256]u8;
    val al: usize = path_into(?buf[0], 256, "/base", "/tmp/out/mach");
    if (al == 0) { ret 1; }
    var i: usize = 0;
    val want: *u8 = "/tmp/out/mach";
    for (buf[i] != 0) {
        if (want[i] == 0 || buf[i] != want[i]) { ret 1; }
        i = i + 1;
    }
    if (want[i] != 0) { ret 1; }

    val rl: usize = path_into(?buf[0], 256, "/base", "rel/out");
    if (rl == 0) { ret 1; }
    val rwant: *u8 = "/base/rel/out";
    i = 0;
    for (buf[i] != 0) {
        if (rwant[i] == 0 || buf[i] != rwant[i]) { ret 1; }
        i = i + 1;
    }
    if (rwant[i] != 0) { ret 1; }
    ret 0;
}

# separator_index reports the `--` boundary as the effective argc, and argc
# itself when there is no separator.
test "mach.cli.util.separator_index:boundary_as_argc" {
    var argv: [4]*u8;
    argv[0] = "mach"; argv[1] = "run"; argv[2] = "--"; argv[3] = "x";
    if (separator_index(4, ?argv[0]) != 2) { ret 1; }

    var bare: [2]*u8;
    bare[0] = "mach"; bare[1] = "build";
    if (separator_index(2, ?bare[0]) != 2) { ret 1; }
    ret 0;
}

# positional_index skips a value flag together with its value, finds an explicit
# positional, and resolves `mach build .`.
test "mach.cli.util.positional_index:skips_value_flag" {
    # [mach, init, --name, myproj] has no positional: --name eats myproj.
    var a: [4]*u8;
    a[0] = "mach"; a[1] = "init"; a[2] = "--name"; a[3] = "myproj";
    if (positional_index(4, ?a[0], 2) != 4) { ret 1; }

    # an explicit directory is found, and --name's value is still skipped.
    var b: [5]*u8;
    b[0] = "mach"; b[1] = "init"; b[2] = "mydir"; b[3] = "--name"; b[4] = "x";
    if (positional_index(5, ?b[0], 2) != 2) { ret 1; }

    # mach build . resolves the '.' positional.
    var c: [3]*u8;
    c[0] = "mach"; c[1] = "build"; c[2] = ".";
    if (positional_index(3, ?c[0], 2) != 2) { ret 1; }
    ret 0;
}
