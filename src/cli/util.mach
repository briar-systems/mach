# shared CLI argv scanners and project-path operations
#
# Every subcommand needs the same handful of argv-scanning and project-path
# operations over the raw `**u8` / `*u8` argument vector, so this module owns
# the single copy of each. It frames no parse state: the argv helpers are
# exact-match, allocation-free scans over the raw vector; the path and
# directory helpers allocate through the caller's allocator and compose
# std.types.path with std.filesystem. `--flag=value` and bundled short flags
# are intentionally not recognized.

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use std.allocator.arena;
use std.allocator.page;
use fs: std.filesystem;
use std.print;
use std.process.env;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;
use std.types.string.str_len;
use std.types.path;
use std.types.path.Path;

use mach.lang.manifest;

# permission bits for a directory the CLI creates (octal 0755, rwxr-xr-x)
val DIR_MODE: i32 = 0o0755;

# the project manifest filename; the CLI's alias for `manifest.MANIFEST_FILE`,
# the single source of truth
pub val PROJECT_CONFIG_NAME: str = manifest.MANIFEST_FILE;

# whether argv contains an exact match for `flag`
# ---
# argc: number of arguments to scan
# argv: argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  true when the flag appears in argv[0, argc)
pub fun flag_exists(argc: usize, argv: *str, flag: str) bool {
    var i: usize = 0;
    for (i < argc) {
        if (str_equals(argv[i], flag)) {
            ret true;
        }
        i = i + 1;
    }

    ret false;
}

# the argument following `flag`, when `flag` is present and is not the last token
# ---
# argc: number of arguments to scan
# argv: argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  some(next arg) when the flag is found and followed by a value, else none
pub fun flag_value(argc: usize, argv: *str, flag: str) O.Option[str] {
    var i: usize = 0;
    for (i < argc) {
        if (str_equals(argv[i], flag)) {
            if (i + 1 < argc) {
                ret O.some[str](argv[i + 1]);
            }

            ret O.none[str]();
        }

        i = i + 1;
    }

    ret O.none[str]();
}

# has_flag that also records every matching index into `marks`, so a later
# reject_unknown pass treats the flag as consumed
#
# `marks` is parallel to argv (length argc); nil skips recording, leaving a plain
# presence test. Every occurrence is marked, so a repeated boolean flag is fully
# consumed. Consumption itself is the registration - a command marks a flag by
# reading it, with no separate accepted-flag table to drift.
# ---
# marks: consumption record parallel to argv, or nil to only test presence
# argc:  number of arguments to scan
# argv:  argument vector (argc null-terminated byte pointers)
# flag:  the flag to search for
# ret:   true when the flag appears in argv[0, argc)
pub fun flag_mark(marks: *bool, argc: usize, argv: *str, flag: str) bool {
    var found: bool  = false;
    var i:     usize = 0;
    for (i < argc) {
        if (str_equals(argv[i], flag)) {
            found = true;
            if (marks != nil) { marks[i] = true; }
        }

        i = i + 1;
    }

    ret found;
}

# get_value that records the flag index and its value index into `marks`, so a
# later reject_unknown pass treats both as consumed
#
# Every occurrence is marked - a repeatable value flag (`-L`, `-l`) consumes each
# of its pairs - while the first value is returned, matching get_value. `marks`
# may be nil to only read. A trailing flag with no following value still marks the
# flag token itself, so it is never misreported as unknown.
# ---
# marks: consumption record parallel to argv, or nil to only read
# argc:  number of arguments to scan
# argv:  argument vector (argc null-terminated byte pointers)
# flag:  the flag to search for
# ret:   some(first value) when the flag is found with a following value, else none
pub fun flag_mark_value(marks: *bool, argc: usize, argv: *str, flag: str) O.Option[str] {
    var value: O.Option[str] = O.none[str]();
    var i:     usize         = 0;
    for (i < argc) {
        if (str_equals(argv[i], flag)) {
            # mark the flag itself
            if (marks != nil) { marks[i] = true; }

            if (i + 1 < argc) {
                # mark the value token, and return the first value found
                if (marks != nil) {
                    marks[i + 1] = true;
                }

                # only return the first value, but mark every occurrence
                if (O.is_none[str](value)) {
                    value = O.some[str](argv[i + 1]);
                }
            }
        }

        i = i + 1;
    }

    ret value;
}

# whether `s` looks like a flag (a non-nil token beginning with '-')
# ---
# s:   the token to test
# ret: true when `s` is non-nil and starts with '-'
pub fun arg_is_flag(s: str) bool {
    ret s != nil && s[0] == '-';
}

# index of the `--` separator in argv, or argc when absent
#
# Meaningful only to `mach run`, whose contract forwards every post-`--` token to
# the executed program as its argv. `run` passes this index as the effective argc
# to its flag and positional scanners so those tokens are never read as flags; on
# every other command `--` has no special meaning and is rejected as an unknown
# flag (see reject_unknown).
# ---
# argc: number of arguments
# argv: argument vector (argc null-terminated byte pointers)
# ret:  index of the first `--`, or argc when there is none
pub fun arg_separator_index(argc: usize, argv: *str) usize {
    var i: usize = 1;
    for (i < argc) {
        if (str_equals(argv[i], "--")) { ret i; }
        i = i + 1;
    }
    ret argc;
}

# index of the first positional argument at or after `start`, or argc when none
#
# The consumption record `marks` is the single source of truth: every flag and
# its value were marked when read (config.parse plus each command's own flag
# reads), so this steps over any marked index and returns the first bare token
# nobody claimed - no separate value-flag table to drift from the reads (#1810).
# A `--` gets no special treatment: it is not a positional, and reject_unknown
# has already rejected any unmarked flag (including a stray `--`) before this
# runs, so a leading `-` token can only be a marked flag, stepped over here. No
# CLI positional legitimately begins with `-`; `mach run` forwards its post-`--`
# program arguments by passing the separator index as `argc`, so they are never
# scanned as positionals.
# ---
# argc:  number of arguments to scan (the `--` boundary for `mach run`)
# argv:  argument vector (argc null-terminated byte pointers)
# marks: consumption record parallel to argv
# start: index to begin scanning from (typically 2, past the subcommand)
# ret:   index of the first positional, or argc when there is none
pub fun arg_index_positional(argc: usize, argv: *str, marks: *bool, start: usize) usize {
    var i: usize = start;
    for (i < argc) {
        val a: str = argv[i];

        # skip any token that was marked consumed by a flag or value read
        if (marks[i]) {
            i = i + 1;
            cnt;
        }

        if (!arg_is_flag(a)) {
            ret i;
        }

        i = i + 1;
    }

    ret argc;
}

# report the first flag token in argv[start, argc) that no reader marked consumed
#
# Consumption marking (mark_flag / mark_value, and config.parse) records every
# recognized flag and its value; this walks the same range and errors on the
# first `-`-prefixed token nobody claimed, so a typo'd or removed flag is a hard
# error rather than a silently misparsed positional (#1810). Bare (non-flag)
# tokens are positionals or link inputs and are left alone. A `--` separator gets
# no special treatment - it is an unmarked `-`-prefixed token and so is reported
# as an unknown flag; only `mach run` gives it meaning, and it does so by passing
# the separator index as `argc`, clipping the scan before `--` so its post-`--`
# program arguments are never reached. The diagnostic names the flag and the
# command; the caller returns its usage-error exit code.
# ---
# argc:  number of arguments to scan (the `--` boundary for `mach run`)
# argv:  argument vector (argc null-terminated byte pointers)
# marks: consumption record parallel to argv
# start: index to begin scanning from (past the subcommand / action)
# cmd:   command label for the diagnostic (e.g. "mach build")
# ret:   true when an unknown flag was found and reported
pub fun flag_reject_unknown(argc: usize, argv: *str, marks: *bool, start: usize, cmd: str) bool {
    var i: usize = start;
    for (i < argc) {
        if (!marks[i] && arg_is_flag(argv[i])) {
            print.eprintf("error: unknown flag '{}' for '{}'\n", argv[i], cmd);
            ret true;
        }

        i = i + 1;
    }

    ret false;
}

# resolve a command's required path argument to its project root
#
# the argument names a project directory: an existing directory containing a
# mach.toml. it is never walked upward (#1992), and a manifest file is not
# accepted in place of its directory. the returned root is a fresh allocation
# from `a`; the manifest is always `<root>/mach.toml`, derived by the driver.
# ---
# a:   allocator for the returned root and error messages
# arg: the positional path token, or nil when none was given
# ret: the project root, or an error message
pub fun resolve_project_root(a: *A.Allocator, arg: str) R.Result[Path, str] {
    if (arg == nil) {
        ret R.err[Path, str]("missing project path; pass a project directory, e.g. '.'");
    }
    if (!fs.is_dir(arg)) {
        ret R.err[Path, str]("project path is not a directory");
    }

    val mp_r: R.Result[Path, str] = path.join(a, arg, PROJECT_CONFIG_NAME);
    if (R.is_err[Path, str](mp_r)) { ret mp_r; }
    val mp: Path = R.unwrap_ok[Path, str](mp_r);

    val found: bool = fs.is_file(mp);
    A.deallocate[u8](a, mp, str_len(mp) + 1);
    if (!found) {
        ret R.err[Path, str]("no mach.toml in the project directory");
    }

    ret path.clone(a, arg);
}


# create a single directory, succeeding when it already exists
# ---
# p:   directory path
# ret: true when the directory exists on return
pub fun ensure_dir(p: str) bool {
    if (fs.is_dir(p)) { ret true; }
    ret O.is_none[str](fs.create_dir(p, DIR_MODE));
}

# create every missing parent directory of the file at `p`
# ---
# a:   allocator for the transient parent path
# p:   file path whose parent chain is materialized
# ret: none on success, or an error message
pub fun ensure_parents(a: *A.Allocator, p: str) O.Option[str] {
    val pr: R.Result[Path, str] = path.parent(a, p);
    if (R.is_err[Path, str](pr)) { ret O.some[str](R.unwrap_err[Path, str](pr)); }
    ret fs.create_dir_all(a, R.unwrap_ok[Path, str](pr), DIR_MODE);
}

# resolve a bare command name against PATH, or return a pathed name verbatim
#
# a name containing a separator is returned as-is; a bare name is joined onto
# each PATH segment and the first existing file wins. only the returned
# candidate stays allocated; misses are freed.
# ---
# a:    allocator for the returned candidate path
# name: command name or path
# ret:  an executable path, or an error message
pub fun resolve_cmd(a: *A.Allocator, name: str) R.Result[str, str] {
    # a name that already spells a path is returned verbatim; only bare names
    # are searched on PATH.
    if (path.has_separator(name)) { ret R.ok[str, str](name); }

    var list_sep: u8 = ':';
    $if ($mach.build.os == $mach.os.windows) {
        list_sep = ';';
    }

    val paths_r: R.Result[str, str] = env.value(a, "PATH");
    if (R.is_err[str, str](paths_r)) { ret R.err[str, str]("PATH unset"); }
    val paths: str = R.unwrap_ok[str, str](paths_r);
    val plen: usize = str_len(paths);

    # the PATH value is owned, so each segment is terminated in place and
    # handed to path.join as an ordinary string
    var i: usize = 0;
    for (i < plen) {
        val start: usize = i;
        for (i < plen && paths[i] != list_sep) { i = i + 1; }
        paths[i] = 0;
        i = i + 1;
        if (i - 1 == start) { cnt; }

        val cand_r: R.Result[Path, str] = path.join(a, ?paths[start], name::str);
        if (R.is_err[Path, str](cand_r)) { ret R.err[str, str](R.unwrap_err[Path, str](cand_r)); }
        val cand: Path = R.unwrap_ok[Path, str](cand_r);

        if (fs.is_file(cand)) { ret R.ok[str, str](cand); }
        A.deallocate[u8](a, cand, str_len(cand) + 1);
    }

    ret R.err[str, str]("not found on PATH");
}

# separator_index reports the `--` boundary as the effective argc, and argc
# itself when there is no separator
test "mach.cli.util.arg_separator_index:boundary_as_argc" {
    var argv: [4]*u8;
    argv[0] = "mach"; argv[1] = "run"; argv[2] = "--"; argv[3] = "x";
    if (arg_separator_index(4, ?argv[0]) != 2) { ret 1; }

    var bare: [2]*u8;
    bare[0] = "mach"; bare[1] = "build";
    if (arg_separator_index(2, ?bare[0]) != 2) { ret 1; }
    ret 0;
}

# positional_index steps over marked flag/value indices and finds the first
# bare token nobody claimed
test "mach.cli.util.arg_index_positional:skips_marked" {
    var a: [4]*u8;
    a[0] = "mach"; a[1] = "init"; a[2] = "--name"; a[3] = "myproj";
    var ma: [4]bool;
    ma[0] = false; ma[1] = false; ma[2] = true; ma[3] = true;
    if (arg_index_positional(4, ?a[0], ?ma[0], 2) != 4) { ret 1; }

    var b: [5]*u8;
    b[0] = "mach"; b[1] = "init"; b[2] = "mydir"; b[3] = "--name"; b[4] = "x";
    var mb: [5]bool;
    mb[0] = false; mb[1] = false; mb[2] = false; mb[3] = true; mb[4] = true;
    if (arg_index_positional(5, ?b[0], ?mb[0], 2) != 2) { ret 1; }
    ret 0;
}

# mark_flag records every matching index and reports presence; a nil marks
# vector leaves it a plain presence test
test "mach.cli.util.flag_mark:records_every_occurrence" {
    var argv: [4]*u8;
    argv[0] = "mach"; argv[1] = "build"; argv[2] = "-v"; argv[3] = "-v";
    var marks: [4]bool;
    var i: usize = 0;
    for (i < 4) { marks[i] = false; i = i + 1; }

    if (!flag_mark(?marks[0], 4, ?argv[0], "-v")) { ret 1; }
    if (!marks[2] || !marks[3])                   { ret 1; }
    if (marks[0] || marks[1])                     { ret 1; }
    if (flag_mark(?marks[0], 4, ?argv[0], "-q"))  { ret 1; }
    if (!flag_mark(nil, 4, ?argv[0], "-v"))       { ret 1; }
    ret 0;
}

# mark_value records each flag/value pair (repeatable) and returns the first value
test "mach.cli.util.flag_mark_value:marks_pairs_returns_first" {
    var argv: [6]*u8;
    argv[0] = "mach"; argv[1] = "build"; argv[2] = "-l"; argv[3] = "a";
    argv[4] = "-l";   argv[5] = "b";
    var marks: [6]bool;
    var i: usize = 0;
    for (i < 6) { marks[i] = false; i = i + 1; }

    val v: O.Option[*u8] = flag_mark_value(?marks[0], 6, ?argv[0], "-l");
    if (O.is_none[*u8](v))                                { ret 1; }
    if (!str_equals(O.unwrap[*u8](v)::str, "a"))          { ret 1; }
    if (!marks[2] || !marks[3] || !marks[4] || !marks[5]) { ret 1; }
    if (marks[0] || marks[1])                             { ret 1; }
    ret 0;
}

# reject_unknown flags the first unmarked flag token and leaves marked flags
# and bare positionals alone
test "mach.cli.util.flag_reject_unknown:first_unmarked_flag" {
    var a: [4]*u8;
    a[0] = "mach"; a[1] = "build"; a[2] = "--bogus"; a[3] = ".";
    var ma: [4]bool;
    var i: usize = 0;
    for (i < 4) { ma[i] = false; i = i + 1; }
    if (!flag_reject_unknown(4, ?a[0], ?ma[0], 2, "mach build")) { ret 1; }

    ma[2] = true;
    if (flag_reject_unknown(4, ?a[0], ?ma[0], 2, "mach build")) { ret 1; }
    ret 0;
}

# the positional argument must name an existing directory containing a
# mach.toml; a manifest file, a missing path, and a nil argument are all
# rejected, and the returned root is a fresh allocation
test "mach.cli.util.resolve_project_root:directory_only" {
    var backing: A.Allocator;
    if (O.is_some[str](page.make(?backing))) { ret 1; }

    val tf_r: R.Result[fs.TempFile, str] = fs.temp_create(?backing, "mach_rpr_test");
    if (R.is_err[fs.TempFile, str](tf_r)) { ret 1; }
    var tf: fs.TempFile = R.unwrap_ok[fs.TempFile, str](tf_r);
    val dir: str = fs.temp_path(?tf);
    fs.temp_close_and_remove(?tf);

    if (O.is_some[str](fs.create_dir_all(?backing, dir, 493))) { ret 1; }

    var bad: i32 = 0;

    # a directory without a manifest is rejected
    if (R.is_ok[Path, str](resolve_project_root(?backing, dir))) { bad = 1; }

    val mf_r: R.Result[Path, str] = path.join(?backing, dir, PROJECT_CONFIG_NAME);
    if (R.is_err[Path, str](mf_r)) { bad = 1; }
    val mf: Path = R.unwrap_ok[Path, str](mf_r);
    if (O.is_some[str](fs.write_bytes(mf, "[project]\n", 10, 420))) { bad = 1; }

    # a directory with a manifest resolves to a fresh clone of itself
    val rr: R.Result[Path, str] = resolve_project_root(?backing, dir);
    if (R.is_err[Path, str](rr)) { bad = 1; }
    or {
        val root: Path = R.unwrap_ok[Path, str](rr);
        if (!str_equals(root, dir))     { bad = 1; }
        if (root::usize == dir::usize)  { bad = 1; }
    }

    # the manifest file itself is not accepted in place of its directory
    if (R.is_ok[Path, str](resolve_project_root(?backing, mf))) { bad = 1; }

    # a missing path and a nil argument are user errors
    if (R.is_ok[Path, str](resolve_project_root(?backing, "/nonexistent_mach_rpr"))) { bad = 1; }
    if (R.is_ok[Path, str](resolve_project_root(?backing, nil)))                     { bad = 1; }

    fs.remove_all(?backing, dir);
    ret bad;
}

# ensure_parents materializes every missing directory above a file path and
# is idempotent
test "mach.cli.util.ensure_parents:creates_missing_levels" {
    var backing: A.Allocator;
    if (O.is_some[str](page.make(?backing))) { ret 1; }

    val tf_r: R.Result[fs.TempFile, str] = fs.temp_create(?backing, "mach_ep_test");
    if (R.is_err[fs.TempFile, str](tf_r)) { ret 1; }
    var tf: fs.TempFile = R.unwrap_ok[fs.TempFile, str](tf_r);
    val base: str = fs.temp_path(?tf);
    fs.temp_close_and_remove(?tf);
    if (O.is_some[str](fs.create_dir_all(?backing, base, 493))) { ret 1; }

    var bad: i32 = 0;

    val deep_r: R.Result[Path, str] = path.join(?backing, base, "a/b/c/file.txt");
    if (R.is_err[Path, str](deep_r)) { bad = 1; }
    val deep: Path = R.unwrap_ok[Path, str](deep_r);

    if (O.is_some[str](ensure_parents(?backing, deep))) { bad = 1; }
    val parent_r: R.Result[Path, str] = path.parent(?backing, deep);
    if (R.is_err[Path, str](parent_r))                          { bad = 1; }
    or (!fs.is_dir(R.unwrap_ok[Path, str](parent_r)))           { bad = 1; }
    if (O.is_some[str](ensure_parents(?backing, deep)))         { bad = 1; }

    fs.remove_all(?backing, base);
    ret bad;
}

# a name that already spells a path is returned verbatim without any
# filesystem probe
test "mach.cli.util.resolve_cmd:pathed_name_verbatim" {
    var backing: A.Allocator;
    if (O.is_some[str](page.make(?backing))) { ret 1; }

    val name: *u8 = "./definitely/not/a/real-cmd";
    val r: R.Result[*u8, str] = resolve_cmd(?backing, name);
    if (R.is_err[*u8, str](r))                     { ret 1; }
    if (R.unwrap_ok[*u8, str](r)::usize != name::usize) { ret 1; }
    ret 0;
}
