# mach.cli.cmd.init: `mach init` — scaffolds a new project.
#
# writes a complete mach.toml with a `[project]` block and default
# target entries for linux/windows/darwin (all on the host isa), a
# `[deps.mach-std]` dependency, and starter source (`src/main.mach` or
# `src/lib.mach`). for binary projects, the generated main is a standard-library
# hello world. the command also syncs `mach-std` into `dep/mach-std` so a fresh
# scaffold builds immediately. refuses to overwrite an existing mach.toml,
# src/main.mach, or src/lib.mach unless `--force` is given. the project id
# defaults to the directory name and is overridable with `--name <name>`.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.is_err;

use os: std.system.os;
use fs: std.filesystem;

use util: mach.cli.util;
use dep:  mach.cli.cmd.dep;

val MACH_STD_URL: *u8 = "https://github.com/octalide/mach-std";
val MACH_STD_REF: *u8 = "branch/dev";

# host_os: the running compiler's host os name, resolved at comptime.
fun host_os() *u8 {
    $if ($mach.target.os == $mach.os.linux)   { ret "linux"; }
    $or ($mach.target.os == $mach.os.darwin)  { ret "darwin"; }
    $or ($mach.target.os == $mach.os.windows) { ret "windows"; }
    $or                                        { ret "linux"; }
}

# host_isa: the running compiler's host isa name, resolved at comptime.
fun host_isa() *u8 {
    $if ($mach.target.arch == $mach.arch.x86_64)  { ret "x86_64"; }
    $or ($mach.target.arch == $mach.arch.aarch64) { ret "aarch64"; }
    $or                                            { ret "x86_64"; }
}

# put: append a null-terminated `s` to `buf` at `off`, returning the new
# offset. silently truncates if it would overflow `cap`.
fun put(buf: *u8, cap: usize, off: usize, s: *u8) usize {
    val n: usize = util.slen(s);
    if (off + n >= cap) { ret off; }
    var i: usize = 0;
    for (i < n) { buf[off + i] = s[i]; i = i + 1; }
    ret off + n;
}

# base_name: the trailing path component of `path` (after the final '/'),
# or the whole string when there is no separator.
fun base_name(path: *u8) *u8 {
    val n: usize = util.slen(path);
    var last: usize = 0;
    var found: bool = false;
    var i: usize = 0;
    for (i < n) {
        if (path[i] == '/') { last = i; found = true; }
        i = i + 1;
    }
    if (!found) { ret path; }
    ret ?path[last + 1];
}

# run: `mach init` subcommand entry point. scaffolds a new project in the
# positional directory (or the current directory). called by cmd.dispatch.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  0 on success, 1 on a user error, 2 on an internal error
pub fun run(argc: usize, argv: **u8) i64 {
    val force: bool = util.has_flag(argc, argv, "--force");
    val is_lib: bool = util.has_flag(argc, argv, "--lib");

    var cwd_buf: [4096]u8;
    val gw: i64 = os.getcwd(?cwd_buf[0], 4096);
    if (gw < 0) {
        util.emit("error: failed to read the working directory\n");
        ret 2;
    }

    # positional directory: the first bare argv after `init`, skipping each
    # value flag together with its value so `mach init --name myproj` takes the
    # current directory (id `myproj`) rather than eating `myproj` as the dir.
    var dir: *u8 = ?cwd_buf[0];
    val pix: usize = util.positional_index(argc, argv, 2);
    if (pix < argc) { dir = argv[pix]; }

    # project id: --name, else the directory base name.
    var id: *u8 = base_name(dir);
    val name_opt: Option[*u8] = util.get_value(argc, argv, "--name");
    if (is_some[*u8](name_opt)) { id = unwrap[*u8](name_opt); }

    # preflight every collision check before any filesystem write, so a refused
    # init (a populated path without --force) leaves nothing behind.
    var manifest: [4096]u8;
    util.join_into(?manifest[0], 4096, dir, "mach.toml");
    if (fs.exists(?manifest[0]) && !force) {
        util.emit("error: mach.toml already exists (use --force to overwrite)\n");
        ret 1;
    }

    var src_dir: [4096]u8;
    util.join_into(?src_dir[0], 4096, dir, "src");

    var entry: [4096]u8;
    if (is_lib) {
        util.join_into(?entry[0], 4096, ?src_dir[0], "lib.mach");
        if (fs.exists(?entry[0]) && !force) {
            util.emit("error: src/lib.mach already exists (use --force to overwrite)\n");
            ret 1;
        }
    }
    or {
        util.join_into(?entry[0], 4096, ?src_dir[0], "main.mach");
        if (fs.exists(?entry[0]) && !force) {
            util.emit("error: src/main.mach already exists (use --force to overwrite)\n");
            ret 1;
        }
    }

    # all collision checks passed — create directories and write the scaffold.
    if (!fs.is_dir(dir)) {
        val mk: Result[bool, str] = fs.create_dir(dir, 493);
        if (is_err[bool, str](mk)) {
            util.emit("error: failed to create the project directory\n");
            ret 2;
        }
    }

    if (!fs.is_dir(?src_dir[0])) {
        val mk: Result[bool, str] = fs.create_dir(?src_dir[0], 493);
        if (is_err[bool, str](mk)) {
            util.emit("error: failed to create the src directory\n");
            ret 2;
        }
    }

    if (!write_manifest(?manifest[0], id, is_lib)) {
        util.emit("error: failed to write mach.toml\n");
        ret 2;
    }

    if (is_lib) {
        if (!write_source(?entry[0], lib_template())) {
            util.emit("error: failed to write src/lib.mach\n");
            ret 2;
        }
    }
    or {
        if (!write_source(?entry[0], main_template())) {
            util.emit("error: failed to write src/main.mach\n");
            ret 2;
        }
    }

    # delegate dependency sync to the same machinery as `mach dep sync`: the
    # freshly written manifest drives a single clone path with the allowlisted
    # child environment and lockfile handling — propagating its accurate
    # diagnostics on failure.
    val rc: i64 = dep.sync_project(dir::str);
    if (rc != 0) { ret rc; }

    util.emit("created project '");
    util.emit(id);
    util.emit("'\n");
    ret 0;
}

# write_manifest: write the mach.toml manifest at `path` with project id
# `id`, embedding default targets for linux/windows/darwin on the host isa.
# each target carries every key the driver requires (os, isa, entrypoint,
# binary); a library project additionally sets `mode = "library"` and roots
# each entrypoint at `lib.mach`. returns false on a write error.
fun write_manifest(path: *u8, id: *u8, is_lib: bool) bool {
    var buf: [4096]u8;
    var off: usize = 0;
    off = put(?buf[0], 4096, off, "[project]\n");
    off = put(?buf[0], 4096, off, "id = \"");
    off = put(?buf[0], 4096, off, id);
    off = put(?buf[0], 4096, off, "\"\n");
    off = put(?buf[0], 4096, off, "target = \"native\"\n");
    off = put(?buf[0], 4096, off, "dir_src = \"src\"\n");
    off = put(?buf[0], 4096, off, "dir_dep = \"dep\"\n");
    off = put(?buf[0], 4096, off, "\n");

    off = put(?buf[0], 4096, off, "[targets.linux]\n");
    off = put(?buf[0], 4096, off, "os = \"linux\"\n");
    off = put(?buf[0], 4096, off, "isa = \"");
    off = put(?buf[0], 4096, off, host_isa());
    off = put(?buf[0], 4096, off, "\"\n");
    if (is_lib) {
        off = put(?buf[0], 4096, off, "mode = \"library\"\n");
        off = put(?buf[0], 4096, off, "entrypoint = \"lib.mach\"\n");
        off = put(?buf[0], 4096, off, "binary = \"linux/lib/");
        off = put(?buf[0], 4096, off, id);
        off = put(?buf[0], 4096, off, ".o\"\n");
    }
    or {
        off = put(?buf[0], 4096, off, "entrypoint = \"main.mach\"\n");
        off = put(?buf[0], 4096, off, "binary = \"linux/bin/");
        off = put(?buf[0], 4096, off, id);
        off = put(?buf[0], 4096, off, "\"\n");
    }
    off = put(?buf[0], 4096, off, "\n");

    off = put(?buf[0], 4096, off, "[targets.windows]\n");
    off = put(?buf[0], 4096, off, "os = \"windows\"\n");
    off = put(?buf[0], 4096, off, "isa = \"");
    off = put(?buf[0], 4096, off, host_isa());
    off = put(?buf[0], 4096, off, "\"\n");
    if (is_lib) {
        off = put(?buf[0], 4096, off, "mode = \"library\"\n");
        off = put(?buf[0], 4096, off, "entrypoint = \"lib.mach\"\n");
        off = put(?buf[0], 4096, off, "binary = \"windows/lib/");
        off = put(?buf[0], 4096, off, id);
        off = put(?buf[0], 4096, off, ".o\"\n");
    }
    or {
        off = put(?buf[0], 4096, off, "entrypoint = \"main.mach\"\n");
        off = put(?buf[0], 4096, off, "binary = \"windows/bin/");
        off = put(?buf[0], 4096, off, id);
        off = put(?buf[0], 4096, off, ".exe\"\n");
    }
    off = put(?buf[0], 4096, off, "\n");

    off = put(?buf[0], 4096, off, "[targets.darwin]\n");
    off = put(?buf[0], 4096, off, "os = \"darwin\"\n");
    off = put(?buf[0], 4096, off, "isa = \"");
    off = put(?buf[0], 4096, off, host_isa());
    off = put(?buf[0], 4096, off, "\"\n");
    if (is_lib) {
        off = put(?buf[0], 4096, off, "mode = \"library\"\n");
        off = put(?buf[0], 4096, off, "entrypoint = \"lib.mach\"\n");
        off = put(?buf[0], 4096, off, "binary = \"darwin/lib/");
        off = put(?buf[0], 4096, off, id);
        off = put(?buf[0], 4096, off, ".o\"\n");
    }
    or {
        off = put(?buf[0], 4096, off, "entrypoint = \"main.mach\"\n");
        off = put(?buf[0], 4096, off, "binary = \"darwin/bin/");
        off = put(?buf[0], 4096, off, id);
        off = put(?buf[0], 4096, off, "\"\n");
    }
    off = put(?buf[0], 4096, off, "\n");

    off = put(?buf[0], 4096, off, "[deps.mach-std]\n");
    off = put(?buf[0], 4096, off, "url = \"");
    off = put(?buf[0], 4096, off, MACH_STD_URL);
    off = put(?buf[0], 4096, off, "\"\n");
    off = put(?buf[0], 4096, off, "ref = \"");
    off = put(?buf[0], 4096, off, MACH_STD_REF);
    off = put(?buf[0], 4096, off, "\"\n");

    val r: Result[bool, str] = fs.write_file(path, ?buf[0], off, 420);
    ret !is_err[bool, str](r);
}

# write_source: write `content` (a null-terminated template) to `path`.
# returns false on a write error.
fun write_source(path: *u8, content: *u8) bool {
    val r: Result[bool, str] = fs.write_file(path, content, util.slen(content), 420);
    ret !is_err[bool, str](r);
}

# main_template: the starter binary entry module written by a default
# `mach init`. this is a standard-library hello world wired through
# `std.runtime` and `std.print`.
fun main_template() *u8 {
    ret "use std.runtime;\nuse print: std.print;\n\n$main.symbol = \"main\";\nfun main(argc: i64, argv: **u8) i64 {\n    print.println(\"Hello, World!\");\n    ret 0;\n}\n";
}

# lib_template: the starter library root module written by `mach init --lib`.
# library builds stop at per-module objects, so the root needs no entry point.
fun lib_template() *u8 {
    ret "# library root module.\n";
}
