# `mach init` - scaffolds a new project.
#
# Writes a complete `mach.toml` (a `[project]` block with explicit src/dep dirs
# and output templates, `[target.*]` platforms for linux/windows/darwin on the
# host isa, one `[bin.*]`/`[lib.*]` artifact, debug/release profiles, and a
# `[deps.mach-std]` dependency) plus a starter source module. For a binary the
# generated `src/main.mach` is a standard-library hello world; a library gets a
# bare `src/lib.mach` root. The command then syncs `mach-std` into `dep/mach-std`
# through the same machinery as `mach dep pull`, so a fresh scaffold builds
# immediately.
#
# It refuses to overwrite an existing `mach.toml` or source entry unless
# `--force` is given. The project id is `--name`, else the positional name, else
# the current directory's base name for a bare `mach init`. The positional is
# taken verbatim, so a value the manifest grammar would reject (`.`, a path, ...)
# is refused before any filesystem write - invalid input is rejected, not
# repaired.

use std.filesystem;
use std.print;
use std.system.os;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use O: std.types.option;
use R: std.types.result;

use mach.cli.cmd.dep;
use mach.cli.util;
use mach.lang.manifest;

# git source url for the bundled standard-library dependency
val MACH_STD_URL: *u8 = "https://github.com/briar-systems/mach-std";
# default git ref for the standard-library dependency
val MACH_STD_REF: *u8 = "branch/main";

# permission bits for a created directory (octal 0755, rwxr-xr-x)
val DIR_MODE:  i32 = 493;
# permission bits for a written file (octal 0644, rw-r--r--)
val FILE_MODE: i32 = 420;

# fixed-capacity append buffer over caller-provided storage
# ---
# ptr: backing storage
# cap: capacity in bytes
# len: bytes appended so far
# ok:  whether every append fit so far (false once one overflowed)
rec Buf {
    ptr: *u8;
    cap: usize;
    len: usize;
    ok:  bool;
}

# `mach init` subcommand entry point. scaffolds a new project in the positional
# directory (or the current directory). called by cmd.dispatch.
# ---
# argc:  argument count including argv[0]
# argv:  the argument vector (argc null-terminated byte pointers)
# marks: consumption record parallel to argv, for the unknown-flag rejector
# ret:   0 on success, 1 on a user error, 2 on an internal error
pub fun run(argc: usize, argv: **u8, marks: *bool) i64 {
    # `mach init` reads only its own flags (no shared config parser). marking each
    # both registers it for the rejector and reads it, so there is no second
    # unmarked read to drift. reject any unrecognized flag before the directory
    # positional is resolved.
    val force:    bool          = util.mark_flag(marks, argc, argv, "--force");
    val is_lib:   bool          = util.mark_flag(marks, argc, argv, "--lib");
    val quiet_l:  bool          = util.mark_flag(marks, argc, argv, "--quiet");
    val quiet_s:  bool          = util.mark_flag(marks, argc, argv, "-q");
    val quiet:    bool          = quiet_l || quiet_s;
    val opt_name: O.Option[*u8] = util.mark_value(marks, argc, argv, "--name");
    if (util.reject_unknown(argc, argv, marks, 2, "mach init")) { ret 1; }

    var cwd_buf: [4096]u8;
    val cwd_len: i64 = os.getcwd(?cwd_buf[0], 4096);
    if (cwd_len < 0) {
        print.eprint("error: failed to read the working directory\n");
        ret 2;
    }

    # the target directory and project id both default to the cwd; a positional
    # argument (the first bare argv after `init`) overrides both. it is taken
    # verbatim, so a path or `.` is refused by is_valid_id below, never repaired.
    var dir: *u8 = ?cwd_buf[0];
    var id:  *u8 = base_name(?cwd_buf[0]);
    val pos_idx: usize = util.positional_index(argc, argv, marks, 2);
    if (pos_idx < argc) {
        dir = argv[pos_idx];
        id  = argv[pos_idx];
    }

    # --name (read above) takes precedence over the positional for the id (never
    # the directory)
    if (O.is_some[*u8](opt_name)) { id = O.unwrap[*u8](opt_name); }

    # validate the id before any filesystem write so a rejected init leaves
    # nothing behind
    if (!manifest.is_valid_id(id::str)) {
        print.eprint("error: '");
        print.eprint(id::str);
        print.eprint("' is not a valid project id\n");
        print.eprint("       a project id may contain only letters, digits, '_', or '-' (no '.', '/', or spaces)\n");
        print.eprint("       pass a valid name as the argument or with --name <name>\n");
        ret 1;
    }

    var manifest_path: [4096]u8;
    util.join_into(?manifest_path[0], 4096, dir, "mach.toml");

    var src_dir: [4096]u8;
    util.join_into(?src_dir[0], 4096, dir, "src");

    var entry_leaf:  *u8 = "main.mach";
    var entry_label: *u8 = "src/main.mach";
    if (is_lib) {
        entry_leaf  = "lib.mach";
        entry_label = "src/lib.mach";
    }
    var entry: [4096]u8;
    util.join_into(?entry[0], 4096, ?src_dir[0], entry_leaf);

    # preflight every collision check before any filesystem write, so a refused
    # init (a populated path without --force) leaves nothing behind
    if (exists_refused(?manifest_path[0], "mach.toml", force)) { ret 1; }
    if (exists_refused(?entry[0], entry_label, force))         { ret 1; }

    # all collision checks passed - create directories and write the scaffold
    if (!dir_ensure(dir, "project"))     { ret 2; }
    if (!dir_ensure(?src_dir[0], "src")) { ret 2; }

    if (!write_manifest(?manifest_path[0], id, is_lib)) {
        print.eprint("error: failed to write mach.toml\n");
        ret 2;
    }

    var template: *u8 = main_template();
    if (is_lib) { template = lib_template(); }
    if (!write_source(?entry[0], template)) {
        print.eprint("error: failed to write ");
        print.eprint(entry_label);
        print.eprint("\n");
        ret 2;
    }

    # delegate dependency acquisition to the same machinery as `mach dep pull`:
    # the freshly written manifest drives a single clone path with the
    # allowlisted child environment and lockfile handling, propagating its
    # accurate diagnostics on failure
    val pull_rc: i64 = dep.pull_project(dir::str, quiet);
    if (pull_rc != 0) { ret pull_rc; }

    if (!quiet) {
        print.eprint("created project '");
        print.eprint(id::str);
        print.eprint("'\n");
    }
    ret 0;
}

# write the `mach.toml` manifest for a freshly scaffolded project
#
# Emits a `[project]` block (id, version, src/dep dirs, output-path templates,
# and `module` for a library), `[target.<os>-<isa>]` blocks for linux/windows/darwin
# on the host isa, one `[bin.<id>]` or `[lib.<id>]` artifact, debug/release profiles,
# and the `[deps.mach-std]` dependency.
# ---
# path:   destination path for the manifest
# id:     project id (already validated)
# is_lib: emit a library project rather than a binary
# ret:    true on success, false on a write error or if the content overflowed
fun write_manifest(path: *u8, id: *u8, is_lib: bool) bool {
    var storage: [4096]u8;
    var buf: Buf;
    buf.ptr = ?storage[0];
    buf.cap = 4096;
    buf.len = 0;
    buf.ok  = true;

    buf_put(?buf, "[project]\n");
    buf_put(?buf, "id = \"");
    buf_put(?buf, id);
    buf_put(?buf, "\"\n");
    buf_put(?buf, "version = \"0.1.0\"\n");
    buf_put(?buf, "src = \"src\"\n");
    buf_put(?buf, "dep = \"dep\"\n");
    # a library is importable by its project id; the module key names the file a
    # bare `use <id>;` resolves to (the lib root). bins are not importable.
    if (is_lib) { buf_put(?buf, "module = \"lib.mach\"\n"); }
    buf_put(?buf, "target = \"native\"\n");
    buf_put(?buf, "out   = \"out/{target}/{profile}/bin/{name}{ext}\"\n");
    buf_put(?buf, "obj   = \"out/{target}/{profile}/obj\"\n");
    buf_put(?buf, "ir    = \"out/{target}/{profile}/ir\"\n");
    buf_put(?buf, "asm   = \"out/{target}/{profile}/asm\"\n");
    buf_put(?buf, "tests = \"out/{target}/{profile}/test/{name}\"\n");
    buf_put(?buf, "\n");

    # target names follow the `<os>-<isa>` convention the root manifest uses; the
    # isa suffix is the host isa verbatim, so the name always matches the isa field
    buf_put(?buf, "[target.linux-");
    buf_put(?buf, host_isa());
    buf_put(?buf, "]\n");
    buf_put(?buf, "isa = \"");
    buf_put(?buf, host_isa());
    buf_put(?buf, "\"\n");
    buf_put(?buf, "os  = \"linux\"\n");
    buf_put(?buf, "abi = \"sysv64\"\n");
    buf_put(?buf, "\n");

    buf_put(?buf, "[target.windows-");
    buf_put(?buf, host_isa());
    buf_put(?buf, "]\n");
    buf_put(?buf, "isa = \"");
    buf_put(?buf, host_isa());
    buf_put(?buf, "\"\n");
    buf_put(?buf, "os  = \"windows\"\n");
    buf_put(?buf, "abi = \"win64\"\n");
    buf_put(?buf, "ext = \".exe\"\n");
    buf_put(?buf, "\n");

    buf_put(?buf, "[target.darwin-");
    buf_put(?buf, host_isa());
    buf_put(?buf, "]\n");
    buf_put(?buf, "isa = \"");
    buf_put(?buf, host_isa());
    buf_put(?buf, "\"\n");
    buf_put(?buf, "os  = \"darwin\"\n");
    buf_put(?buf, "abi = \"sysv64\"\n");
    buf_put(?buf, "\n");

    if (is_lib) {
        buf_put(?buf, "[lib.");
        buf_put(?buf, id);
        buf_put(?buf, "]\n");
        buf_put(?buf, "entry = \"lib.mach\"\n");
        buf_put(?buf, "kind  = \"static\"\n");
    }
    or {
        buf_put(?buf, "[bin.");
        buf_put(?buf, id);
        buf_put(?buf, "]\n");
        buf_put(?buf, "entry = \"main.mach\"\n");
    }
    buf_put(?buf, "\n");

    buf_put(?buf, "[profile.debug]\n");
    buf_put(?buf, "opt = 0\n");
    buf_put(?buf, "\n");
    buf_put(?buf, "[profile.release]\n");
    buf_put(?buf, "opt = 2\n");
    buf_put(?buf, "\n");

    buf_put(?buf, "[deps.mach-std]\n");
    buf_put(?buf, "git = \"");
    buf_put(?buf, MACH_STD_URL);
    buf_put(?buf, "\"\n");
    buf_put(?buf, "ref = \"");
    buf_put(?buf, MACH_STD_REF);
    buf_put(?buf, "\"\n");

    if (!buf.ok) { ret false; }
    val res_write: R.Result[bool, str] = filesystem.write_file(path, ?storage[0], buf.len, FILE_MODE);
    ret !R.is_err[bool, str](res_write);
}

# write a null-terminated source template to `path`
# ---
# path:     destination path
# template: null-terminated template bytes
# ret:      true on success, false on a write error
fun write_source(path: *u8, template: *u8) bool {
    val res_write: R.Result[bool, str] = filesystem.write_file(path, template, util.cstr_len(template), FILE_MODE);
    ret !R.is_err[bool, str](res_write);
}

# the starter binary entry module for a default `mach init`
#
# A standard-library hello world wired through `std.runtime` and `std.print`.
# ---
# ret: the null-terminated module source
fun main_template() *u8 {
    ret "use std.runtime;\nuse print: std.print;\n\n#[symbol(\"main\")]\nfun main(argc: i64, argv: **u8) i64 {\n    print.println(\"Hello, World!\");\n    ret 0;\n}\n";
}

# the starter library root module for `mach init --lib`
#
# Library builds stop at per-module objects, so the root needs no entry point.
# ---
# ret: the null-terminated module source
fun lib_template() *u8 {
    ret "# library root module.\n";
}

# create `path` as a directory if absent, reporting a labeled error on failure
# ---
# path:  directory to create
# label: human name of the directory, used in the error message
# ret:   true on success
fun dir_ensure(path: *u8, label: *u8) bool {
    if (util.ensure_dir(path)) { ret true; }
    print.eprint("error: failed to create the ");
    print.eprint(label);
    print.eprint(" directory\n");
    ret false;
}

# report and refuse when `path` already exists without `--force`
# ---
# path:  path to test
# label: human name of the file, used in the error message
# force: whether `--force` was given
# ret:   true if the init must abort (the path exists and force is unset)
fun exists_refused(path: *u8, label: *u8, force: bool) bool {
    if (!filesystem.exists(path) || force) { ret false; }
    print.eprint("error: ");
    print.eprint(label);
    print.eprint(" already exists (use --force to overwrite)\n");
    ret true;
}

# append a null-terminated `s` to the buffer, marking overflow
#
# Once an append would exceed capacity the buffer is marked failed (`ok` set
# false) and every later append is a no-op, so a truncated manifest is never
# written.
# ---
# b: the buffer to append to
# s: null-terminated bytes to append
fun buf_put(b: *Buf, s: *u8) {
    if (!b.ok) { ret; }
    val n: usize = util.cstr_len(s);
    if (b.len + n > b.cap) {
        b.ok = false;
        ret;
    }
    var i: usize = 0;
    for (i < n) {
        b.ptr[b.len + i] = s[i];
        i = i + 1;
    }
    b.len = b.len + n;
}

# the trailing path component of `path`, after the final `/`
#
# Returns the whole string when there is no separator. The result is a view into
# `path`, not a copy.
# ---
# path: null-terminated path
# ret:  pointer to the base-name component within `path`
fun base_name(path: *u8) *u8 {
    val n: usize = util.cstr_len(path);
    var start: usize = 0;
    var i: usize = 0;
    for (i < n) {
        if (path[i] == '/') { start = i + 1; }
        i = i + 1;
    }
    ret ?path[start];
}

# the host isa name, folded at comptime from the compiler's build target
# ---
# ret: the manifest isa string for the host architecture
fun host_isa() *u8 {
    $if ($mach.build.arch == $mach.arch.x86_64)  { ret "x86_64"; }
    $or ($mach.build.arch == $mach.arch.aarch64) { ret "aarch64"; }
    $or                                          { ret "x86_64"; }
}
