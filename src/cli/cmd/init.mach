# mach.cli.cmd.init: `mach init` — scaffolds a new project.
#
# writes a minimal mach.toml with a `[project]` block and a
# `[targets.host]` entry matching the running compiler, a starter
# `src/main.mach` (or `src/lib.mach` with `--lib`), and an empty `dep/`
# directory. refuses to scaffold into a non-empty directory unless
# `--force` is given. the project id defaults to the directory name and is
# overridable with `--name <name>`.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.is_err;

use os: std.system.os;
use fs: std.filesystem;

# eq: byte-wise equality of two null-terminated `*u8` strings.
# ---
# a:   first null-terminated byte string
# b:   second null-terminated byte string
# ret: true if both reach the terminator at the same position with matching bytes
fun eq(a: *u8, b: *u8) bool {
    if (a == b)               { ret true; }
    if (a == nil || b == nil) { ret false; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}

# slen: length in bytes of a null-terminated `*u8` string.
# ---
# s:   null-terminated byte string
# ret: number of bytes before the terminator (0 for nil)
fun slen(s: *u8) usize {
    if (s == nil) { ret 0; }
    var n: usize = 0;
    for (s[n] != 0) { n = n + 1; }
    ret n;
}

# emit: write a null-terminated `*u8` string to stderr.
# ---
# s: null-terminated byte string to write
fun emit(s: *u8) {
    os.write(os.STDERR_FD, s, slen(s));
}

# get_value: returns the argument following `flag` in argv, or none.
fun get_value(argc: usize, argv: **u8, flag: *u8) Option[*u8] {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) {
            if (i + 1 < argc) { ret some[*u8](argv[i + 1]); }
            ret none[*u8]();
        }
        i = i + 1;
    }
    ret none[*u8]();
}

# has_flag: returns true if argv contains an exact match for `flag`.
fun has_flag(argc: usize, argv: **u8, flag: *u8) bool {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# is_flag: returns true when `s` looks like a flag (begins with '-').
fun is_flag(s: *u8) bool {
    ret s != nil && s[0] == '-';
}

# host_os: the running compiler's host os name, resolved at comptime.
fun host_os() *u8 {
    $if ($mach.target.os == $mach.os.linux)   { ret "linux"; }
    $or ($mach.target.os == $mach.os.darwin)  { ret "darwin"; }
    $or ($mach.target.os == $mach.os.windows) { ret "windows"; }
    $or                                        { ret "linux"; }
}

# host_isa: the running compiler's host isa name, resolved at comptime.
fun host_isa() *u8 {
    $if ($mach.target.arch == $mach.arch.x86_64)  { ret "x86_64"; }
    $or ($mach.target.arch == $mach.arch.aarch64) { ret "aarch64"; }
    $or                                            { ret "x86_64"; }
}

# put: append a null-terminated `s` to `buf` at `off`, returning the new
# offset. silently truncates if it would overflow `cap`.
fun put(buf: *u8, cap: usize, off: usize, s: *u8) usize {
    val n: usize = slen(s);
    if (off + n >= cap) { ret off; }
    var i: usize = 0;
    for (i < n) { buf[off + i] = s[i]; i = i + 1; }
    ret off + n;
}

# join_into: join `dir` and `leaf` with a single '/' into `buf`, null-terminating.
fun join_into(buf: *u8, cap: usize, dir: *u8, leaf: *u8) usize {
    var off: usize = put(buf, cap, 0, dir);
    if (off > 0 && buf[off - 1] != '/') {
        if (off + 1 < cap) { buf[off] = '/'; off = off + 1; }
    }
    off = put(buf, cap, off, leaf);
    if (off < cap) { buf[off] = 0; }
    ret off;
}

# base_name: the trailing path component of `path` (after the final '/'),
# or the whole string when there is no separator.
fun base_name(path: *u8) *u8 {
    val n: usize = slen(path);
    var last: usize = 0;
    var found: bool = false;
    var i: usize = 0;
    for (i < n) {
        if (path[i] == '/') { last = i; found = true; }
        i = i + 1;
    }
    if (!found) { ret path; }
    ret ?path[last + 1];
}

# run: `mach init` subcommand entry point. scaffolds a new project in the
# positional directory (or the current directory). called by cmd.dispatch.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  0 on success, 1 on a user error, 2 on an internal error
pub fun run(argc: usize, argv: **u8) i64 {
    val force: bool = has_flag(argc, argv, "--force");
    val is_lib: bool = has_flag(argc, argv, "--lib");

    var cwd_buf: [4096]u8;
    val gw: i64 = os.getcwd(?cwd_buf[0], 4096);
    if (gw < 0) {
        emit("error: failed to read the working directory\n");
        ret 2;
    }

    # positional directory: the first non-flag argv after `init`.
    var dir: *u8 = ?cwd_buf[0];
    var i: usize = 2;
    for (i < argc) {
        if (!is_flag(argv[i])) { dir = argv[i]; brk; }
        i = i + 1;
    }

    # project id: --name, else the directory base name.
    var id: *u8 = base_name(dir);
    val name_opt: Option[*u8] = get_value(argc, argv, "--name");
    if (is_some[*u8](name_opt)) { id = unwrap[*u8](name_opt); }

    # refuse to clobber a populated project unless --force.
    var manifest: [4096]u8;
    join_into(?manifest[0], 4096, dir, "mach.toml");
    if (fs.exists(?manifest[0]) && !force) {
        emit("error: mach.toml already exists (use --force to overwrite)\n");
        ret 1;
    }

    if (!fs.is_dir(dir)) {
        val mk: Result[bool, str] = fs.create_dir(dir, 493);
        if (is_err[bool, str](mk)) {
            emit("error: failed to create the project directory\n");
            ret 2;
        }
    }

    var src_dir: [4096]u8;
    join_into(?src_dir[0], 4096, dir, "src");
    if (!fs.is_dir(?src_dir[0])) {
        val mk: Result[bool, str] = fs.create_dir(?src_dir[0], 493);
        if (is_err[bool, str](mk)) {
            emit("error: failed to create the src directory\n");
            ret 2;
        }
    }

    var dep_dir: [4096]u8;
    join_into(?dep_dir[0], 4096, dir, "dep");
    if (!fs.is_dir(?dep_dir[0])) {
        val mk: Result[bool, str] = fs.create_dir(?dep_dir[0], 493);
        if (is_err[bool, str](mk)) {
            emit("error: failed to create the dep directory\n");
            ret 2;
        }
    }

    if (!write_manifest(?manifest[0], id, is_lib)) {
        emit("error: failed to write mach.toml\n");
        ret 2;
    }

    var entry: [4096]u8;
    if (is_lib) {
        join_into(?entry[0], 4096, ?src_dir[0], "lib.mach");
        if (!write_source(?entry[0], lib_template())) {
            emit("error: failed to write src/lib.mach\n");
            ret 2;
        }
    }
    or {
        join_into(?entry[0], 4096, ?src_dir[0], "main.mach");
        if (!write_source(?entry[0], main_template())) {
            emit("error: failed to write src/main.mach\n");
            ret 2;
        }
    }

    emit("created project '");
    emit(id);
    emit("'\n");
    ret 0;
}

# write_manifest: write the mach.toml manifest at `path` with project id
# `id`, embedding a `[targets.host]` entry matching the running compiler.
# a library project omits the `entrypoint` key. returns false on a write
# error.
fun write_manifest(path: *u8, id: *u8, is_lib: bool) bool {
    var buf: [1024]u8;
    var off: usize = 0;
    off = put(?buf[0], 1024, off, "[project]\n");
    off = put(?buf[0], 1024, off, "id = \"");
    off = put(?buf[0], 1024, off, id);
    off = put(?buf[0], 1024, off, "\"\n");
    off = put(?buf[0], 1024, off, "dir_src = \"src\"\n");
    off = put(?buf[0], 1024, off, "dir_dep = \"dep\"\n");
    off = put(?buf[0], 1024, off, "\n");
    off = put(?buf[0], 1024, off, "[targets.host]\n");
    off = put(?buf[0], 1024, off, "os = \"");
    off = put(?buf[0], 1024, off, host_os());
    off = put(?buf[0], 1024, off, "\"\n");
    off = put(?buf[0], 1024, off, "isa = \"");
    off = put(?buf[0], 1024, off, host_isa());
    off = put(?buf[0], 1024, off, "\"\n");
    if (!is_lib) {
        off = put(?buf[0], 1024, off, "entrypoint = \"main.mach\"\n");
    }

    val r: Result[bool, str] = fs.write_file(path, ?buf[0], off, 420);
    ret !is_err[bool, str](r);
}

# write_source: write `content` (a null-terminated template) to `path`.
# returns false on a write error.
fun write_source(path: *u8, content: *u8) bool {
    val r: Result[bool, str] = fs.write_file(path, content, slen(content), 420);
    ret !is_err[bool, str](r);
}

# main_template: the starter binary entry module written by a default `mach init`.
fun main_template() *u8 {
    ret "fun main(argc: usize, argv: **u8) i64 {\n    ret 0;\n}\n";
}

# lib_template: the starter library root module written by `mach init --lib`.
fun lib_template() *u8 {
    ret "# library root module.\n";
}
