# `mach build <path>` - compile the project per the composed request
#
# The command is the pipeline's thin front: parse the flags, compose the
# settled request against the once-loaded manifest, resolve it into a plan,
# hand the plan to the engine, and render the outcome. Resolution lives in the
# planner (`mach.lang.build.plan`), execution in the engine
# (`mach.lang.build.engine`); nothing here compiles, emits, or links. With
# `--explain` the resolved plan is printed and nothing is built. Exit codes:
# 0 ok, 1 user error (missing mach.toml, unknown target, compile errors),
# 2 internal error.

use std.allocator.arena;
use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use args: mach.cli.args;
use cli_diag: mach.cli.diagnostic;
use engine: mach.lang.build.engine;
use outcome: mach.lang.build.outcome;
use plan: mach.lang.build.plan;
use request: mach.lang.build.request;
use mach.cli.util;
use mach.lang.driver;
use mach.lang.manifest;
use mach.lang.readout;
use mach.lang.session;

# compose and plan one invocation: init the planning session (returned through
# `ps`, which the caller tears down after consuming the plan), load the root
# manifest once, compose the settled request against it, and resolve the plan
#
# On error the session is torn down here and the failure is returned for the
# caller's render. The plan's units borrow the session's interner and
# allocator, so `ps` must outlive every consumer of the returned plan.
# ---
# a:    allocator backing the planning session and the plan's units
# root: the resolved project root directory (from the command entry)
# cli:  the parsed command line, captures included (collect_build ran)
# goal: what this invocation produces
# ps:   receives the live planning session on success
# ret:  the resolved plan, or the failure to render
pub fun plan_invocation(a: *A.Allocator, root: str, cli: *args.CliArgs, goal: request.BuildGoal,
                        ps: *session.Session) R.Result[plan.BuildPlan, outcome.Fail] {
    val res_session: R.Result[session.Session, str] = session.init(a);
    if (R.is_err[session.Session, str](res_session)) {
        ret R.err[plan.BuildPlan, outcome.Fail](outcome.internal("failed to initialise compiler session"));
    }
    @ps = R.unwrap_ok[session.Session, str](res_session);

    val res_register: R.Result[bool, str] = driver.setup_registry(?ps.registry);
    if (R.is_err[bool, str](res_register)) {
        session.dnit(ps);
        ret R.err[plan.BuildPlan, outcome.Fail](outcome.internal(R.unwrap_err[bool, str](res_register)));
    }

    val res_manifest: R.Result[manifest.Manifest, str] = driver.load_manifest(ps, root);
    if (R.is_err[manifest.Manifest, str](res_manifest)) {
        val f: outcome.Fail = outcome.user(R.unwrap_err[manifest.Manifest, str](res_manifest));
        session.dnit(ps);
        ret R.err[plan.BuildPlan, outcome.Fail](f);
    }
    var m: manifest.Manifest = R.unwrap_ok[manifest.Manifest, str](res_manifest);

    var sel: manifest.Selection;
    val sr: R.Result[bool, str] = args.selection_from_config(cli, ?sel);
    if (R.is_err[bool, str](sr)) {
        val f: outcome.Fail = outcome.user(R.unwrap_err[bool, str](sr));
        session.dnit(ps);
        ret R.err[plan.BuildPlan, outcome.Fail](f);
    }

    val res_req: R.Result[request.BuildRequest, outcome.Fail] = request.compose(a, ?ps.interner, ?m, cli, root, goal, ?sel);
    if (R.is_err[request.BuildRequest, outcome.Fail](res_req)) {
        val f: outcome.Fail = R.unwrap_err[request.BuildRequest, outcome.Fail](res_req);
        session.dnit(ps);
        ret R.err[plan.BuildPlan, outcome.Fail](f);
    }

    # the composed request must outlive the plan (its units point back at it);
    # it lands on the planning allocator next to the units it drives.
    val res_rq: R.Result[*request.BuildRequest, str] = A.allocate[request.BuildRequest](a, 1::usize);
    if (R.is_err[*request.BuildRequest, str](res_rq)) {
        session.dnit(ps);
        ret R.err[plan.BuildPlan, outcome.Fail](outcome.internal("out of memory"));
    }
    val req: *request.BuildRequest = R.unwrap_ok[*request.BuildRequest, str](res_rq);
    @req = R.unwrap_ok[request.BuildRequest, outcome.Fail](res_req);

    val plan_r: R.Result[plan.BuildPlan, outcome.Fail] = plan.plan(ps.alloc, ?ps.interner, ?ps.registry, ?m, req);
    if (R.is_err[plan.BuildPlan, outcome.Fail](plan_r)) {
        session.dnit(ps);
    }
    ret plan_r;
}

# reject a `mach build` flag combination that cannot produce correct output
#
# `-o` names a single artifact path; `--all-targets` builds every declared
# target. Combined, each target would link to that one path and overwrite the
# previous, leaving only the last target's binary with no warning. A per-target
# `-o` template could be considered later; an explicit error is the floor.
# ---
# config: the parsed CLI config
# ret:    ok(true) when the combination is valid, err naming the conflict
fun reject_output_all_targets(config: *args.CliArgs) R.Result[bool, str] {
    if (config.output != nil && config.all_targets) {
        ret R.err[bool, str]("-o cannot be combined with --all-targets (it names a single output)");
    }
    ret R.ok[bool, str](true);
}

# `-o` and `--all-targets` are rejected together; either alone is accepted
test "mach.cli.cmd.build.reject_output_all_targets:rejects_the_pair" {
    var config: args.CliArgs;

    config.output      = "bin/app";
    config.all_targets = true;
    if (R.is_ok[bool, str](reject_output_all_targets(?config)))  { ret 1; }

    config.all_targets = false;
    if (R.is_err[bool, str](reject_output_all_targets(?config))) { ret 1; }

    config.output      = nil;
    config.all_targets = true;
    if (R.is_err[bool, str](reject_output_all_targets(?config))) { ret 1; }

    ret 0;
}

# `mach build` subcommand entry point
#
# parse -> compose -> plan -> execute -> render: the flags settle into a
# request, the planner resolves the (target, artifact) matrix, the engine
# executes each unit, and the outcome derives the exit code. Called by
# cmd.dispatch.
# ---
# argc:  argument count including argv[0]
# argv:  the argument vector (argc null-terminated byte pointers)
# marks: consumption record parallel to argv, for the unknown-flag rejector
# ret:   0 on success, 1 on a user error, 2 on an internal error
pub fun run(argc: usize, argv: **u8, marks: *bool) i64 {
    var goal: request.BuildGoal = request.GOAL_EXECUTE;
    val opt_emit: O.Option[str] = util.flag_value(argc, argv, "--emit");
    if (O.is_some[str](opt_emit)) {
        val kind: str = O.unwrap[str](opt_emit);
        if (str_equals(kind, "obj")) { goal = request.GOAL_OBJECTS; }
        or (str_equals(kind, "exe")) { goal = request.GOAL_EXECUTE; }
        or {
            val f: outcome.Fail = outcome.user("--emit expects 'obj' or 'exe'");
            ret cli_diag.render_fail(?f);
        }
    }

    # back the build with a page allocator; the planning pass and each engine
    # unit get their own arena over it, so a unit's compile memory is reclaimed
    # before the next while the plan (the request arena) outlives the loop.
    var backing: A.Allocator;
    if (O.is_some[str](page.make(?backing))) {
        val f: outcome.Fail = outcome.internal("failed to initialise allocator");
        ret cli_diag.render_fail(?f);
    }

    val res_config: R.Result[args.CliArgs, str] = args.parse(argc, argv);
    if (R.is_err[args.CliArgs, str](res_config)) {
        val f: outcome.Fail = outcome.user(R.unwrap_err[args.CliArgs, str](res_config));
        ret cli_diag.render_fail(?f);
    }
    var config: args.CliArgs = R.unwrap_ok[args.CliArgs, str](res_config);
    if (config.bin != nil && config.lib != nil) {
        val f: outcome.Fail = outcome.user("--bin and --lib cannot be combined");
        ret cli_diag.render_fail(?f);
    }
    val oc: R.Result[bool, str] = reject_output_all_targets(?config);
    if (R.is_err[bool, str](oc)) {
        val f: outcome.Fail = outcome.user(R.unwrap_err[bool, str](oc));
        ret cli_diag.render_fail(?f);
    }

    # mark the flags `mach build` accepts from their tables - the cross-cutting
    # set (`parse` read their values), the `-O` override, the build-flow inputs,
    # and `--explain` (prints the resolved plan and builds nothing) - then reject
    # any unrecognized flag before the project-path positional is resolved (so an
    # unknown flag can never displace the path). `mach build` gives `--` no
    # special meaning, so a stray `--` is rejected here like any other flag.
    args.mark_cross(marks, argc, argv);
    args.mark_flags(marks, argc, argv, ?args.OPT[0], args.OPT_N);
    args.mark_flags(marks, argc, argv, ?args.EMIT[0], args.EMIT_N);
    args.mark_flags(marks, argc, argv, ?args.JOBS[0], args.JOBS_N);
    args.mark_flags(marks, argc, argv, ?args.LINKIN[0], args.LINKIN_N);
    args.mark_flags(marks, argc, argv, ?args.BUILD_OWN[0], args.BUILD_OWN_N);
    val explain_only: bool = util.flag_exists(argc, argv, "--explain");
    if (util.flag_reject_unknown(argc, argv, marks, 2, "mach build")) { ret 1; }

    # resolve the project root from the required positional path
    # (`mach build <path>`); see util.resolve_project_root for the rules.
    val pix: usize = util.arg_index_positional(argc, argv, marks, 2);
    var arg: *u8 = nil;
    if (pix < argc) { arg = argv[pix]; }

    val root_r: R.Result[str, str] = util.resolve_project_root(?backing, arg);
    if (R.is_err[str, str](root_r)) {
        val f: outcome.Fail = outcome.user(R.unwrap_err[str, str](root_r));
        ret cli_diag.render_fail(?f);
    }
    val root: str = R.unwrap_ok[str, str](root_r);

    # capture the build-flow values (`-O`, `--jobs`, `-L` dirs, link tokens) now
    # that the full flag set is marked; past this point argv is dead to the
    # build flow - every unit reads its composed request.
    val col_r: R.Result[bool, str] = args.collect_build(?backing, ?config, argc, argv, marks);
    if (R.is_err[bool, str](col_r)) {
        val f: outcome.Fail = outcome.internal(R.unwrap_err[bool, str](col_r));
        ret cli_diag.render_fail(?f);
    }

    # the request arena: the plan, the composed request, and the outcome live
    # here for the whole invocation; the planning session's interner backs the
    # unit selectors and target entries.
    var menu_ar: arena.Arena;
    if (O.is_some[str](arena.init(?menu_ar, ?backing, 0))) {
        val f: outcome.Fail = outcome.internal("failed to initialise allocator");
        ret cli_diag.render_fail(?f);
    }
    var menu_alloc: A.Allocator;
    if (O.is_some[str](arena.make(?menu_alloc, ?menu_ar))) {
        arena.dnit(?menu_ar);
        val f: outcome.Fail = outcome.internal("failed to initialise allocator");
        ret cli_diag.render_fail(?f);
    }

    var ps: session.Session;
    val plan_r: R.Result[plan.BuildPlan, outcome.Fail] = plan_invocation(?menu_alloc, root, ?config, goal, ?ps);
    if (R.is_err[plan.BuildPlan, outcome.Fail](plan_r)) {
        var f: outcome.Fail = R.unwrap_err[plan.BuildPlan, outcome.Fail](plan_r);
        val c: i64 = cli_diag.render_fail(?f);
        arena.dnit(?menu_ar);
        ret c;
    }
    val bp: plan.BuildPlan = R.unwrap_ok[plan.BuildPlan, outcome.Fail](plan_r);
    if (bp.units.len == 0) {
        val f: outcome.Fail = outcome.user("nothing to build");
        val c: i64 = cli_diag.render_fail(?f);
        session.dnit(?ps);
        arena.dnit(?menu_ar);
        ret c;
    }

    # `--explain`: render the resolved plan and exit without building.
    if (explain_only) {
        plan.explain(?bp, ?ps.interner);
        session.dnit(?ps);
        arena.dnit(?menu_ar);
        ret 0;
    }

    # the `-v`/`-vv` narration: a readout-backed progress sink; a plain build
    # passes none and stays silent.
    var ro: readout.Readout;
    var pr: readout.Progress;
    var ev: *readout.Progress = nil;
    if (config.verbosity > 0) {
        readout.init(?ro, ?menu_alloc, config.verbosity);
        pr = readout.progress(?ro);
        ev = ?pr;
    }

    var rctx: cli_diag.RenderCtx;
    var rd: outcome.Render = cli_diag.render_sink(?rctx, bp.units.len);

    val ex_r: R.Result[outcome.BuildOutcome, outcome.Fail] = engine.execute(?bp, ?backing, ?menu_alloc, ev, ?rd);
    readout.dnit(?ro);

    var code: i64 = 0;
    if (R.is_err[outcome.BuildOutcome, outcome.Fail](ex_r)) {
        var f: outcome.Fail = R.unwrap_err[outcome.BuildOutcome, outcome.Fail](ex_r);
        code = cli_diag.render_fail(?f);
    }
    or {
        var bo: outcome.BuildOutcome = R.unwrap_ok[outcome.BuildOutcome, outcome.Fail](ex_r);
        code = cli_diag.outcome_code(?bo);
    }

    session.dnit(?ps);
    arena.dnit(?menu_ar);
    ret code;
}
