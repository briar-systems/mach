# mach.cli.cmd.help: `mach help` — prints usage.
#
# the fallback target for cmd.dispatch when no subcommand or an unknown
# subcommand is given. with no further args it prints the top-level usage
# summary; with a known `argv[2]` it prints that subcommand's detail page;
# with an unknown `argv[2]` it prints the top-level usage and returns
# non-zero.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;

use os: std.system.os;

# eq: byte-wise equality of two null-terminated `*u8` strings.
# ---
# a:   first null-terminated byte string
# b:   second null-terminated byte string
# ret: true if both reach the terminator at the same position with matching bytes
fun eq(a: *u8, b: *u8) bool {
    if (a == b)               { ret true; }
    if (a == nil || b == nil) { ret false; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}

# slen: length in bytes of a null-terminated `*u8` string.
# ---
# s:   null-terminated byte string
# ret: number of bytes before the terminator (0 for nil)
fun slen(s: *u8) usize {
    if (s == nil) { ret 0; }
    var n: usize = 0;
    for (s[n] != 0) { n = n + 1; }
    ret n;
}

# out: write a null-terminated `*u8` string to stdout.
# ---
# s: null-terminated byte string to write
fun out(s: *u8) {
    os.write(os.STDOUT_FD, s, slen(s));
}

fun top_level_usage() {
    out("mach — the Mach compiler\n");
    out("\n");
    out("usage: mach <command> [options]\n");
    out("\n");
    out("commands:\n");
    out("  build    compile the current project\n");
    out("  run      build and execute the current project\n");
    out("  test     build and run the project's tests\n");
    out("  dep      manage project dependencies\n");
    out("  init     scaffold a new project\n");
    out("  doc      generate reference documentation\n");
    out("  help     show this message\n");
    out("\n");
    out("global flags:\n");
    out("  --verbose, -v   surface extra detail\n");
    out("  --quiet, -q     suppress non-error output\n");
    out("  --color <mode>  auto | always | never\n");
    out("  --cwd <path>    run as if started in <path>\n");
    out("  --target <name> select a [targets.<name>] entry\n");
    out("\n");
    out("use 'mach help <command>' for detailed usage.\n");
}

fun help_build() {
    out("usage: mach build [options]\n");
    out("\n");
    out("compile the current project to an executable or object.\n");
    out("\n");
    out("options:\n");
    out("  --target <name>  select a [targets.<name>] entry\n");
    out("  --release        enable the release optimisation pipeline\n");
    out("  --emit <kind>    obj | exe\n");
    out("  --verbose, -v    write per-stage compilation progress to stderr\n");
    out("\n");
    out("exit: 0 ok, 1 user error, 2 internal error\n");
}

fun help_run() {
    out("usage: mach run [options] [-- args...]\n");
    out("\n");
    out("build the project and execute the resulting binary.\n");
    out("arguments after '--' are forwarded to the program.\n");
    out("\n");
    out("exit: the program's exit code, 1 on build error, 2 internal\n");
}

fun help_test() {
    out("usage: mach test [options]\n");
    out("\n");
    out("build the project's tests and run them.\n");
    out("\n");
    out("options:\n");
    out("  --filter <pattern>  run only tests whose name contains <pattern>\n");
    out("  --list              list the collected tests and exit\n");
    out("\n");
    out("exit: 0 all passed, 1 any failed, 2 build/internal error\n");
}

fun help_dep() {
    out("usage: mach dep <action> [args]\n");
    out("\n");
    out("manage vendored dependencies under dir_dep.\n");
    out("\n");
    out("actions:\n");
    out("  list                    list declared dependencies\n");
    out("  add <alias> <source>    vendor a dependency and record it\n");
    out("  remove <alias>          drop a vendored dependency\n");
    out("  sync                    re-fetch declared dependencies\n");
    out("  vendor <path>           copy a local directory in as a dep\n");
}

fun help_init() {
    out("usage: mach init [dir] [options]\n");
    out("\n");
    out("scaffold a new project in <dir> (default: current directory).\n");
    out("\n");
    out("options:\n");
    out("  --name <name>  project id (default: directory name)\n");
    out("  --force        scaffold into a non-empty directory\n");
    out("  --lib          library project layout (default: binary)\n");
}

fun help_doc() {
    out("usage: mach doc [options]\n");
    out("\n");
    out("generate Markdown reference documentation from source doc-comments.\n");
    out("writes one page per module plus an index under doc/api.\n");
    out("\n");
    out("options:\n");
    out("  --out <dir>      output directory, rooted at the project (default: doc/api)\n");
    out("  --target <name>  select a [targets.<name>] entry for module discovery\n");
    out("\n");
    out("exit: 0 ok, 1 user error, 2 internal error\n");
}

# run: `mach help` subcommand entry point. prints the top-level usage or a
# subcommand detail page. called by cmd.dispatch, including its error path.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  0 for usage and known detail pages, 1 for an unknown subcommand
pub fun run(argc: usize, argv: **u8) i64 {
    if (argc < 3) {
        top_level_usage();
        ret 0;
    }

    val sub: *u8 = argv[2];
    if (eq(sub, "build")) { help_build(); ret 0; }
    if (eq(sub, "run"))   { help_run();   ret 0; }
    if (eq(sub, "test"))  { help_test();  ret 0; }
    if (eq(sub, "dep"))   { help_dep();   ret 0; }
    if (eq(sub, "init"))  { help_init();  ret 0; }
    if (eq(sub, "doc"))   { help_doc();   ret 0; }
    if (eq(sub, "help"))  { top_level_usage(); ret 0; }

    out("error: unknown command '");
    out(sub);
    out("'\n");
    top_level_usage();
    ret 1;
}
