# mach.cli.cmd.dep: `mach dep` — manages a project's dependency tree under its
# dep directory (see issue #1223).
#
# reads `argv[2]` as the sub-subcommand and dispatches: `pull` realizes the
# manifest's intent (clone missing git deps, re-resolve a changed ref, repair
# checkout-vs-lock drift, write the lock); `update` is the only lock-advancer
# (branch refs → current remote tips); `add`/`remove` mutate the manifest;
# `list` reports each dep's source form, ref, locked commit, and state.
#
# a dependency stanza `[deps.<name>]` has exactly one source key: a `git` url plus
# an optional `ref`, which mach acquires into `dep/<name>/` with plain git
# operations (submodule-compatible, never `git submodule`), or a `path` pointing at
# a local project tree, never fetched but materialized at `dep/<name>/` as a
# relative symlink so the build resolves it by the same vendor layout. git is the
# only fetch transport: `mach build` never needs it, but the network-shaped
# commands here do.
# transitive deps resolve into the flat dep tree; the same name required from two
# different sources/refs is a hard error.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;
use std.types.string.str_empty;
use std.types.string.str_equals;
use std.types.string.str_starts_with;
use std.types.string.str_region_equals;
use std.types.option.Option;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.is_ok;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use std.text.string.str_dup;

use page: std.allocator.page;

use os:    std.system.os;
use fs:    std.filesystem;
use toml:  std.data.toml;
use exec:  std.process.exec;
use print: std.print;

use util: mach.cli.util;

# the manifest and lockfile names, relative to the project root.
val MANIFEST: *u8 = "mach.toml";
val LOCKFILE: *u8 = "mach.lock";

# the fixed text framing a serialized `[deps.<name>]` lock table, between the
# entry's dynamic name/url/ref/commit values. both the manifest appender and the
# lockfile writer size their buffers and emit from this single set, so the byte
# estimate can never drift from the bytes written — the class of under-allocation
# that overflowed the lock writer by 2 bytes per dep (#1258).
val SEG_OPEN:   *u8 = "\n[deps.";
val SEG_URL:    *u8 = "]\nurl = \"";
val SEG_REF:    *u8 = "\"\nref = \"";
val SEG_COMMIT: *u8 = "\"\ncommit = \"";
val SEG_CLOSE:  *u8 = "\"\n";
val SEG_GIT:    *u8 = "git = \"";
val SEG_PATH:   *u8 = "path = \"";
val SEG_MREF:   *u8 = "ref = \"";

# the lockfile preamble. regenerated verbatim on every write; the idempotent
# writer compares against it byte-for-byte to leave an up-to-date lock untouched.
val LOCK_HEAD: *u8 = "# this file is automatically generated; do not edit by hand.\n";

# DepNode: one dependency in the resolved flat tree. a git node is acquired into
# `dir`; a path node points at committed in-tree files. `req` names the manifest
# that required this node, for the conflict diagnostic. `commit` is the resolved
# sha (git nodes only), filled while the node is processed.
# ---
# name:    owned dependency name as written in `[deps.<name>]`
# git_url: owned git url, "" for a path node
# path:    owned source path as declared, "" for a git node
# ref:     owned git ref, "" when omitted
# dir:     owned on-disk directory holding the dep's own mach.toml
# req:     owned name of the requiring manifest
# commit:  owned resolved commit sha, "" until a git node is processed
# is_git:  true for a git source, false for a path source
rec DepNode {
    name:    str;
    git_url: str;
    path:    str;
    ref:     str;
    dir:     str;
    req:     str;
    commit:  str;
    is_git:  bool;
}

# NodeVec: the growable flat dep tree built during resolution. nodes are appended
# as manifests are read; the processing loop walks it by index so transitive deps
# appended mid-walk are processed in turn.
rec NodeVec {
    alloc: *Allocator;
    data:  *DepNode;
    count: usize;
    cap:   usize;
}

# GitTool: the lazily-resolved git transport — the absolute git path and the
# allowlisted child environment, found on the first git operation so a pull with
# no git deps never touches PATH.
rec GitTool {
    ready: bool;
    git:   str;
    env:   **u8;
}

# run: `mach dep` subcommand entry point. dispatches on `argv[2]`. called by
# cmd.dispatch.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  0 on success, 1 on a user error, 2 on an internal error
pub fun run(argc: usize, argv: **u8) i64 {
    if (argc < 3) {
        print.eprint("error: missing dep action\n");
        print.eprint("usage: mach dep <pull|update|add|remove|list>\n");
        ret 1;
    }

    val action: str = argv[2]::str;
    val quiet:  bool = arg_quiet(argc, argv);

    if (str_equals(action, "list"))   { ret dep_list(); }
    if (str_equals(action, "add"))    { ret dep_add(argc, argv); }
    if (str_equals(action, "remove")) { ret dep_remove(argc, argv); }
    if (str_equals(action, "update")) { ret dep_update(argc, argv); }
    if (str_equals(action, "pull"))   { ret pull_project(".", quiet); }
    if (str_equals(action, "sync")) {
        # `sync` is the pre-#1223 name; kept one cycle as a hidden alias.
        print.eprint("note: `mach dep sync` is deprecated; use `mach dep pull`\n");
        ret pull_project(".", quiet);
    }

    print.eprint("error: unknown dep action '");
    print.eprint(action);
    print.eprint("'\n");
    print.eprint("usage: mach dep <pull|update|add|remove|list>\n");
    ret 1;
}

# read_dep_spec: read one `[deps.<name>]` sub-table into a DepNode skeleton
# (name/source/ref/is_git set; dir/req/commit left empty for the caller). a
# stanza declares exactly one source key — `git` (a url, with an optional `ref`)
# or `path`.
fun read_dep_spec(alloc: *Allocator, sub: *toml.Table, name: str) Result[DepNode, str] {
    var n: DepNode;
    n.name    = own(alloc, name);
    n.git_url = "";
    n.path    = "";
    n.ref     = "";
    n.dir     = "";
    n.req     = "";
    n.commit  = "";
    n.is_git  = false;

    val git_s:  str = toml.get_str(sub, "git");
    val path_s: str = toml.get_str(sub, "path");
    val has_git:  bool = !str_empty(git_s);
    val has_path: bool = !str_empty(path_s);
    if (has_git == has_path) {
        ret err[DepNode, str](cc3(alloc, "[deps.", name, "] needs exactly one source key: 'git' or 'path'"));
    }
    if (has_git) {
        n.is_git  = true;
        n.git_url = own(alloc, git_s);
        n.ref     = own(alloc, toml.get_str(sub, "ref"));
    }
    or {
        n.path = own(alloc, path_s);
    }
    ret ok[DepNode, str](n);
}

# pull_project: realize the manifest's dependency intent for the project rooted
# at `root`. resolves the flat dep tree (cloning missing git deps transitively),
# re-resolves any dep whose manifest ref differs from the lock, repairs
# checkout-vs-lock drift, and rewrites `<root>/mach.lock`. idempotent: a tree
# already in sync touches neither the network nor the lock's mtime.
# ---
# root:  project directory holding mach.toml ("." for the current directory)
# quiet: suppress routine per-dep lines; re-resolve/drift notices print regardless
# ret:   0 on success, 1 on a user error, 2 on an internal error
pub fun pull_project(root: str, quiet: bool) i64 {
    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) {
        print.eprint("error: failed to initialise allocator\n");
        ret 2;
    }

    val mp_r: Result[str, str] = join2(?alloc, root, MANIFEST);
    if (is_err[str, str](mp_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val mp: str = unwrap_ok[str, str](mp_r);

    val tr: Result[toml.Table, str] = parse_file(?alloc, mp);
    if (is_err[toml.Table, str](tr)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[toml.Table, str](tr));
        print.eprint("\n");
        ret 1;
    }
    var mt: toml.Table = unwrap_ok[toml.Table, str](tr);

    val dep_name: str = dep_dir_name(?mt);
    val dep_root_r: Result[str, str] = join2(?alloc, root, dep_name::*u8);
    if (is_err[str, str](dep_root_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val dep_root: str = unwrap_ok[str, str](dep_root_r);

    var project_id: str = toml.get_str(?mt, "project.id");
    if (str_empty(project_id)) { project_id = "(project)"; }

    var nv: NodeVec;
    val nvr: Result[bool, str] = nv_init(?alloc, ?nv, 8);
    if (is_err[bool, str](nvr)) { print.eprint("error: out of memory\n"); ret 2; }

    # seed the flat tree from the top-level manifest's `[deps.*]`.
    val seed: Result[bool, str] = enqueue_manifest(?nv, root, dep_root, ?mt, project_id);
    if (is_err[bool, str](seed)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[bool, str](seed));
        print.eprint("\n");
        ret 1;
    }
    if (nv.count == 0) {
        if (!quiet) { print.print("no dependencies\n"); }
        ret 0;
    }

    val lock_r: Result[str, str] = join2(?alloc, root, LOCKFILE);
    if (is_err[str, str](lock_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val lock_path: str = unwrap_ok[str, str](lock_r);
    val lock_deps: *toml.Table = read_lock_deps(?alloc, lock_path);

    var gt: GitTool;
    gt.ready = false;

    var i: usize = 0;
    for (i < nv.count) {
        if (nv.data[i].is_git) {
            val rc: i64 = process_git_node(?alloc, ?gt, ?nv.data[i], dep_root, lock_deps, quiet);
            if (rc != 0) { ret rc; }
        }
        or {
            val rc: i64 = materialize_path_node(?alloc, ?nv.data[i], dep_root, dep_name, quiet);
            if (rc != 0) { ret rc; }
        }

        # descend into the dep's own manifest to grow the flat tree transitively.
        val tt_r: Result[toml.Table, str] = read_dep_manifest(?alloc, nv.data[i].dir);
        if (is_ok[toml.Table, str](tt_r)) {
            var tt: toml.Table = unwrap_ok[toml.Table, str](tt_r);
            val er: Result[bool, str] = enqueue_manifest(?nv, nv.data[i].dir, dep_root, ?tt, nv.data[i].name);
            if (is_err[bool, str](er)) {
                print.eprint("error: ");
                print.eprint(unwrap_err[bool, str](er));
                print.eprint("\n");
                ret 1;
            }
        }
        i = i + 1;
    }

    val lw: Result[bool, str] = write_lock(?alloc, ?nv.data[0], nv.count, lock_path);
    if (is_err[bool, str](lw)) {
        print.eprint("error: failed to write mach.lock: ");
        print.eprint(unwrap_err[bool, str](lw));
        print.eprint("\n");
        ret 2;
    }
    if (!quiet) {
        if (unwrap_ok[bool, str](lw)) { print.print("wrote mach.lock\n"); }
        or                           { print.print("mach.lock up to date\n"); }
    }
    ret 0;
}

# process_git_node: acquire one git dep into its flat-tree directory and record
# the resolved commit on the node. clones a missing checkout; hard-errors on a
# present-but-not-a-checkout directory (the dead directory-shape heuristic);
# honours the lock except where the manifest ref changed (re-resolve, loud) or
# the checkout drifted from the lock (repair, loud). an empty directory (a plain
# clone's submodule placeholder) is treated as absent and cloned into (#1329).
fun process_git_node(alloc: *Allocator, gt: *GitTool, node: *DepNode, dep_root: str, lock_deps: *toml.Table, quiet: bool) i64 {
    val exists:  bool = fs.exists(node.dir) && !dir_is_empty(node.dir);
    if (exists && !is_git_checkout(alloc, node.dir)) {
        print.eprint("error: ");
        print.eprint(node.dir);
        print.eprint(" exists but is not a git checkout; if these are vendored files, declare it a path dependency (path = \"");
        print.eprint(node.dir);
        print.eprint("\")\n");
        ret 1;
    }

    val gr: Result[bool, str] = ensure_git(alloc, gt);
    if (is_err[bool, str](gr)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[bool, str](gr));
        print.eprint("\n");
        ret 2;
    }

    val lk_ref:    str  = lock_field(lock_deps, node.name, "ref");
    val lk_commit: str  = lock_field(lock_deps, node.name, "commit");
    val has_lock:  bool = !str_empty(lk_commit);
    val honor:     bool = has_lock && str_equals(lk_ref, node.ref);

    if (!exists) {
        if (is_err[bool, str](git_clone(alloc, gt, dep_root, node.dir, node.git_url))) {
            ret git_fail(node.name);
        }
    }

    # fast idempotent path: lock honoured and the checkout already sits on it.
    var cur: str = "";
    if (exists) { cur = head_sha(alloc, node.dir); }
    if (honor && str_equals(cur, lk_commit)) {
        node.commit = lk_commit;
        ret 0;
    }

    var target: str = node.ref;
    if (honor) { target = lk_commit; }

    # a present checkout needs fresh remotes to resolve a moved ref or a commit
    # not yet fetched; a just-cloned one already has them.
    if (exists) { git_fetch(alloc, gt, node.dir); }

    if (is_err[bool, str](git_checkout(alloc, gt, node.dir, target))) {
        ret git_fail(node.name);
    }
    val sha: str = head_sha(alloc, node.dir);
    node.commit = sha;

    if (honor && exists) {
        # an existing checkout differed from the lock: report the repair (loud).
        print.print("repaired ");
        print.print(node.name);
        print.print(" (checkout drift: ");
        print.print(sha_or(cur));
        print.print(" → ");
        print.print(sha);
        print.print(")\n");
        ret 0;
    }
    if (has_lock && !honor) {
        # manifest ref changed since the lock: re-resolve (loud).
        print.print("re-resolved ");
        print.print(node.name);
        print.print(" (manifest ref changed: ");
        print.print(ref_or(lk_ref));
        print.print(" → ");
        print.print(ref_or(node.ref));
        print.print(")\n");
        ret 0;
    }
    if (!quiet) {
        print.print("pulled ");
        print.print(node.name);
        print.print(" @ ");
        print.print(sha);
        print.print("\n");
    }
    ret 0;
}

# materialize_path_node: realize one path dependency at its flat-tree vendor
# location `<dep_root>/<name>` as a symlink to the resolved source `node.dir`, so
# the build (which resolves every dep purely by vendor layout) reaches the dep's
# modules through it. the source must exist and carry a mach.toml — a missing
# directory or manifest is a hard error, never silent success (#1370). a path that
# already resolves to the vendor location (in-tree vendoring, `path = "<dep>/<name>"`)
# is left as is. a real directory squatting the vendor location (a stale git
# checkout, foreign vendored files) is a hard error rather than a clobber; a prior
# symlink is replaced, so re-pull is idempotent. path deps carry no lock entry: the
# manifest's `path` is the record.
fun materialize_path_node(alloc: *Allocator, node: *DepNode, dep_root: str, dep_name: str, quiet: bool) i64 {
    if (!fs.exists(node.dir)) {
        print.eprint("error: path dependency '");
        print.eprint(node.name);
        print.eprint("' points at a missing directory: ");
        print.eprint(node.path);
        print.eprint("\n");
        ret 1;
    }
    val mp_r: Result[str, str] = join2(alloc, node.dir, MANIFEST);
    if (is_err[str, str](mp_r)) { print.eprint("error: out of memory\n"); ret 2; }
    if (!fs.exists(unwrap_ok[str, str](mp_r))) {
        print.eprint("error: path dependency '");
        print.eprint(node.name);
        print.eprint("' has no mach.toml: ");
        print.eprint(node.path);
        print.eprint("\n");
        ret 1;
    }

    val v_r: Result[str, str] = join2(alloc, dep_root, node.name::*u8);
    if (is_err[str, str](v_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val vendor: str = unwrap_ok[str, str](v_r);

    # in-tree vendoring: the source already lives at the vendor location.
    if (str_equals(node.dir, vendor)) { ret 0; }

    fs.create_dir_all(alloc, dep_root, 0o755);
    val pre_exists: bool = fs.exists(vendor);

    # drop a stale symlink (its target may have moved); a real directory here is a
    # hard error — unlink leaves a directory intact (EISDIR), so it remains a dir.
    fs.unlink(vendor);
    if (fs.is_dir(vendor)) {
        print.eprint("error: ");
        print.eprint(vendor);
        print.eprint(" is a real directory, not a path-dependency link; remove it (e.g. `mach dep remove ");
        print.eprint(node.name);
        print.eprint(" --purge`) and re-pull\n");
        ret 1;
    }

    val target_r: Result[str, str] = link_target(alloc, dep_name, node.dir);
    if (is_err[str, str](target_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val target: str = unwrap_ok[str, str](target_r);
    if (is_err[bool, str](make_symlink(target, vendor))) {
        print.eprint("error: failed to link ");
        print.eprint(vendor);
        print.eprint(" -> ");
        print.eprint(target);
        print.eprint("\n");
        ret 2;
    }
    if (!quiet && !pre_exists) {
        print.print("linked ");
        print.print(node.name);
        print.print(" -> ");
        print.print(node.path);
        print.print("\n");
    }
    ret 0;
}

# link_target: the symlink target for a path dependency — a relative path from the
# vendor location `<dep_root>/<name>` back to the resolved source `src` (expressed
# relative to the project root). the symlink sits one directory below the project
# root per path segment of the dep dir, so the target climbs that many `..` before
# applying the source path. a relative target keeps a tree that moves as a whole (a
# monorepo, a committed examples dir) linked without a re-pull. errors only on a
# failed allocation.
fun link_target(alloc: *Allocator, dep_name: str, src: str) Result[str, str] {
    val depth: usize = path_segments(dep_name);
    val sl: usize = str_len(src);
    val r: Result[*u8, str] = allocate[u8](alloc, depth * 3 + sl + 1);
    if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = 0;
    var d: usize = 0;
    for (d < depth) {
        buf[k] = '.'::u8; buf[k + 1] = '.'::u8; buf[k + 2] = '/'::u8;
        k = k + 3; d = d + 1;
    }
    k = put_n(buf, k, src::*u8, sl);
    buf[k] = 0;
    ret ok[str, str](buf::str);
}

# path_segments: the number of real path components in a `/`-separated path,
# ignoring empty (`//`, leading/trailing `/`) and `.` components — the climb depth
# from a `<dep>/<name>` link back to the project root.
fun path_segments(s: str) usize {
    val n: usize = str_len(s);
    var count: usize = 0;
    var i: usize = 0;
    for (i < n) {
        if (s[i] == '/'::u8) { i = i + 1; cnt; }
        val start: usize = i;
        for (i < n && s[i] != '/'::u8) { i = i + 1; }
        if (!(i - start == 1 && s[start] == '.'::u8)) { count = count + 1; }
    }
    ret count;
}

# make_symlink: create a symbolic link at `linkpath` pointing at `target`. the
# target is recorded verbatim — a relative path the build resolves against the
# link's own directory by the vendor layout — and the caller has already cleared
# any prior link. delegates to the std filesystem primitive (no host `ln`, so
# path dependencies materialize on hosts without it, e.g. native windows).
fun make_symlink(target: str, linkpath: str) Result[bool, str] {
    ret fs.symlink(target, linkpath);
}

# git_fail: the generic per-dep git failure exit, naming the dependency.
fun git_fail(name: str) i64 {
    print.eprint("error: git operation failed for '");
    print.eprint(name);
    print.eprint("'\n");
    ret 2;
}

# dep_update: `mach dep update <name> | --all` — the only lock-advancer. for each
# selected git dep whose ref is a branch (or the default branch), fetch and
# resolve the current remote tip; tag/commit refs are an immutable no-op. never
# edits the manifest; always prints `name: <old> → <new>`.
fun dep_update(argc: usize, argv: **u8) i64 {
    val all: bool = util.has_flag(argc, argv, "--all");
    var name: *u8 = nil;
    var ai: usize = 3;
    for (ai < argc) {
        if (argv[ai][0] != '-'::u8) { name = argv[ai]; ai = argc; }
        or { ai = ai + 1; }
    }
    if (!all && name == nil) {
        print.eprint("error: usage: mach dep update <name> | --all\n");
        ret 1;
    }
    if (all && name != nil) {
        print.eprint("error: give a name or --all, not both\n");
        ret 1;
    }
    val quiet: bool = arg_quiet(argc, argv);

    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { print.eprint("error: failed to initialise allocator\n"); ret 2; }

    val tr: Result[toml.Table, str] = parse_file(?alloc, MANIFEST::str);
    if (is_err[toml.Table, str](tr)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[toml.Table, str](tr));
        print.eprint("\n");
        ret 1;
    }
    var mt: toml.Table = unwrap_ok[toml.Table, str](tr);
    val dep_root_r: Result[str, str] = join2(?alloc, ".", dep_dir_name(?mt)::*u8);
    if (is_err[str, str](dep_root_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val dep_root: str = unwrap_ok[str, str](dep_root_r);

    var specs: *DepNode = nil;
    var count: usize = 0;
    val rd: Result[bool, str] = read_lock_nodes(?alloc, LOCKFILE::str, dep_root, ?specs, ?count);
    if (is_err[bool, str](rd)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[bool, str](rd));
        print.eprint("\n");
        ret 1;
    }
    if (count == 0) {
        print.eprint("error: no mach.lock to update (run `mach dep pull` first)\n");
        ret 1;
    }

    var gt: GitTool;
    gt.ready = false;
    var changed: bool = false;
    var matched: bool = false;

    var i: usize = 0;
    for (i < count) {
        val want: bool = all || (name != nil && str_equals(specs[i].name, name::str));
        if (!want) { i = i + 1; cnt; }
        matched = true;

        if (!is_git_checkout(?alloc, specs[i].dir)) {
            print.eprint("error: '");
            print.eprint(specs[i].name);
            print.eprint("' is not checked out (run `mach dep pull` first)\n");
            ret 1;
        }
        val gr: Result[bool, str] = ensure_git(?alloc, ?gt);
        if (is_err[bool, str](gr)) {
            print.eprint("error: ");
            print.eprint(unwrap_err[bool, str](gr));
            print.eprint("\n");
            ret 2;
        }

        val old: str = specs[i].commit;
        var new: str = old;
        if (ref_advanceable(specs[i].ref)) {
            git_fetch(?alloc, ?gt, specs[i].dir);
            if (is_err[bool, str](git_checkout(?alloc, ?gt, specs[i].dir, specs[i].ref))) {
                ret git_fail(specs[i].name);
            }
            new = head_sha(?alloc, specs[i].dir);
        }

        print.print(specs[i].name);
        print.print(": ");
        print.print(sha_or(old));
        print.print(" → ");
        print.print(sha_or(new));
        print.print("\n");
        if (!str_equals(old, new)) { specs[i].commit = new; changed = true; }
        i = i + 1;
    }

    if (!all && !matched) {
        print.eprint("error: no dependency '");
        print.eprint(name::str);
        print.eprint("' in mach.lock\n");
        ret 1;
    }

    if (changed) {
        val lw: Result[bool, str] = write_lock(?alloc, specs, count, LOCKFILE::str);
        if (is_err[bool, str](lw)) {
            print.eprint("error: failed to write mach.lock\n");
            ret 2;
        }
    }
    or {
        if (!quiet) { print.print("already up to date\n"); }
    }
    ret 0;
}

# ref_advanceable: whether `update` may advance a ref to a fresh remote tip. an
# explicit `branch/<n>` or the default branch (empty ref) advances; `tag/<n>`,
# `commit/<n>`, and a bare commit sha are immutable. a bare name is treated as a
# branch (best effort, matching the checkout's remote-tracking preference).
fun ref_advanceable(ref: str) bool {
    if (str_empty(ref)) { ret true; }
    if (str_starts_with(ref, "branch/")) { ret true; }
    if (str_starts_with(ref, "tag/"))    { ret false; }
    if (str_starts_with(ref, "commit/")) { ret false; }
    if (is_hex_sha(ref)) { ret false; }
    ret true;
}

# dep_add: `mach dep add <name> --git <url> [--ref <r>] | --path <dir>`. appends
# the `git`/`path` source stanza to the manifest, then pulls.
fun dep_add(argc: usize, argv: **u8) i64 {
    if (argc < 4 || argv[3][0] == '-'::u8) {
        print.eprint("error: usage: mach dep add <name> --git <url> [--ref <r>] | --path <dir>\n");
        ret 1;
    }
    val name: *u8 = argv[3];
    val git_opt:  Option[*u8] = util.get_value(argc, argv, "--git");
    val path_opt: Option[*u8] = util.get_value(argc, argv, "--path");
    val ref_opt:  Option[*u8] = util.get_value(argc, argv, "--ref");
    val has_git:  bool = is_some[*u8](git_opt);
    val has_path: bool = is_some[*u8](path_opt);
    if (has_git == has_path) {
        print.eprint("error: give exactly one source: --git <url> or --path <dir>\n");
        ret 1;
    }
    val quiet: bool = arg_quiet(argc, argv);

    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { print.eprint("error: failed to initialise allocator\n"); ret 2; }

    val tr: Result[toml.Table, str] = parse_file(?alloc, MANIFEST::str);
    if (is_err[toml.Table, str](tr)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[toml.Table, str](tr));
        print.eprint("\n");
        ret 1;
    }
    var mt: toml.Table = unwrap_ok[toml.Table, str](tr);

    if (table_has_key(toml.get_table(?mt, "deps"), name)) {
        print.eprint("error: dependency '");
        print.eprint(name::str);
        print.eprint("' is already declared in mach.toml\n");
        ret 1;
    }

    var wr: Result[bool, str];
    if (has_git) {
        var ref: *u8 = "";
        if (is_some[*u8](ref_opt)) { ref = opt_value(ref_opt); }
        wr = append_git_dep(?alloc, name, opt_value(git_opt), ref);
    }
    or {
        wr = append_path_dep(?alloc, name, opt_value(path_opt));
    }
    if (is_err[bool, str](wr)) {
        print.eprint("error: failed to update mach.toml: ");
        print.eprint(unwrap_err[bool, str](wr));
        print.eprint("\n");
        ret 2;
    }

    if (!quiet) {
        print.print("added [deps.");
        print.print(name::str);
        print.print("]\n");
    }
    ret pull_project(".", quiet);
}

# dep_remove: `mach dep remove <name> [--purge]`. drops the `[deps.<name>]` entry
# from mach.toml and its lock entry; with `--purge`, also deletes the dep dir.
fun dep_remove(argc: usize, argv: **u8) i64 {
    if (argc < 4) {
        print.eprint("error: usage: mach dep remove <name> [--purge]\n");
        ret 1;
    }
    val name:  *u8 = argv[3];
    val purge: bool = util.has_flag(argc, argv, "--purge");
    val quiet: bool = arg_quiet(argc, argv);

    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { print.eprint("error: failed to initialise allocator\n"); ret 2; }

    if (!dep_declared(?alloc, name)) {
        print.eprint("error: dependency '");
        print.eprint(name::str);
        print.eprint("' is not declared in mach.toml\n");
        ret 1;
    }

    val rr: Result[bool, str] = strip_dep_entry(?alloc, MANIFEST, name);
    if (is_err[bool, str](rr)) {
        print.eprint("error: failed to update mach.toml: ");
        print.eprint(unwrap_err[bool, str](rr));
        print.eprint("\n");
        ret 2;
    }
    if (fs.exists(LOCKFILE::str)) { strip_dep_entry(?alloc, LOCKFILE, name); }

    if (purge) {
        val dir_r: Result[str, str] = dep_dir_path(?alloc, name);
        if (is_ok[str, str](dir_r)) {
            val dir: str = unwrap_ok[str, str](dir_r);
            if (fs.exists(dir)) { remove_tree(?alloc, dir); }
        }
    }

    if (!quiet) {
        print.print("removed [deps.");
        print.print(name::str);
        print.print("]\n");
    }
    ret 0;
}

# dep_list: print every `[deps.<name>]` entry with its source form, ref, locked
# commit, and state (synced | missing | drifted | path).
fun dep_list() i64 {
    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { print.eprint("error: failed to initialise allocator\n"); ret 2; }

    val tr: Result[toml.Table, str] = parse_file(?alloc, MANIFEST::str);
    if (is_err[toml.Table, str](tr)) {
        print.eprint("error: ");
        print.eprint(unwrap_err[toml.Table, str](tr));
        print.eprint("\n");
        ret 1;
    }
    var mt: toml.Table = unwrap_ok[toml.Table, str](tr);

    val deps: *toml.Table = toml.get_table(?mt, "deps");
    if (deps == nil || toml.table_len(deps) == 0) {
        print.print("no dependencies\n");
        ret 0;
    }

    val dep_root_r: Result[str, str] = join2(?alloc, ".", dep_dir_name(?mt)::*u8);
    if (is_err[str, str](dep_root_r)) { print.eprint("error: out of memory\n"); ret 2; }
    val dep_root: str = unwrap_ok[str, str](dep_root_r);
    val lock_deps: *toml.Table = read_lock_deps(?alloc, LOCKFILE::str);

    val count: usize = toml.table_len(deps);
    var i: usize = 0;
    for (i < count) {
        val name: str = toml.table_key(deps, i);
        val v: *toml.Value = toml.table_value(deps, i);
        print.print("  ");
        print.print(name);
        if (v == nil || v.tag != toml.TYPE_TABLE) { print.print("  (invalid)\n"); i = i + 1; cnt; }

        val nr: Result[DepNode, str] = read_dep_spec(?alloc, ?v.data.table, name);
        if (is_err[DepNode, str](nr)) { print.print("  (invalid: "); print.print(unwrap_err[DepNode, str](nr)); print.print(")\n"); i = i + 1; cnt; }
        var n: DepNode = unwrap_ok[DepNode, str](nr);

        if (n.is_git) {
            print.print("  git=");
            print.print(n.git_url);
            if (!str_empty(n.ref)) { print.print("  ref="); print.print(n.ref); }
            val lk: str = lock_field(lock_deps, name, "commit");
            if (!str_empty(lk)) { print.print("  locked="); print.print(lk); }
            val dir_r: Result[str, str] = join2(?alloc, dep_root, name::*u8);
            print.print("  ");
            print.print(git_state(?alloc, dir_r, lk));
        }
        or {
            print.print("  path=");
            print.print(n.path);
            print.print("  path");
        }
        print.print("\n");
        i = i + 1;
    }
    ret 0;
}

# git_state: the listed state of a git dep — `missing` (no checkout), `drifted`
# (present but not a checkout, or checked-out commit ≠ lock), else `synced`.
fun git_state(alloc: *Allocator, dir_r: Result[str, str], lk_commit: str) str {
    if (is_err[str, str](dir_r)) { ret "missing"; }
    val dir: str = unwrap_ok[str, str](dir_r);
    if (!fs.exists(dir)) { ret "missing"; }
    if (!is_git_checkout(alloc, dir)) { ret "drifted"; }
    if (str_empty(lk_commit)) { ret "synced"; }
    if (str_equals(head_sha(alloc, dir), lk_commit)) { ret "synced"; }
    ret "drifted";
}

# nv_init: initialise a NodeVec with a starting capacity.
fun nv_init(alloc: *Allocator, nv: *NodeVec, cap0: usize) Result[bool, str] {
    val r: Result[*DepNode, str] = allocate[DepNode](alloc, cap0);
    if (is_err[*DepNode, str](r)) { ret err[bool, str](unwrap_err[*DepNode, str](r)); }
    nv.alloc = alloc;
    nv.data  = unwrap_ok[*DepNode, str](r);
    nv.count = 0;
    nv.cap   = cap0;
    ret ok[bool, str](true);
}

# nv_find: index of the node named `name`, or -1 when absent.
fun nv_find(nv: *NodeVec, name: str) i64 {
    var i: usize = 0;
    for (i < nv.count) {
        if (str_equals(nv.data[i].name, name)) { ret i::i64; }
        i = i + 1;
    }
    ret -1;
}

# nv_push: append a node, growing the backing array by doubling when full.
fun nv_push(nv: *NodeVec, n: DepNode) Result[bool, str] {
    if (nv.count == nv.cap) {
        val ncap: usize = nv.cap * 2;
        val r: Result[*DepNode, str] = reallocate[DepNode](nv.alloc, nv.data, nv.cap, ncap);
        if (is_err[*DepNode, str](r)) { ret err[bool, str](unwrap_err[*DepNode, str](r)); }
        nv.data = unwrap_ok[*DepNode, str](r);
        nv.cap  = ncap;
    }
    nv.data[nv.count] = n;
    nv.count = nv.count + 1;
    ret ok[bool, str](true);
}

# enqueue_manifest: read every `[deps.*]` of the parsed manifest `mt` (declared by
# `req`, whose own files live in `manifest_dir`) and merge each into the flat tree.
# a git dep's flat-tree directory is `<dep_root>/<name>`; a path dep is resolved
# relative to the requiring manifest. a name already present must match its source
# and ref exactly, else it is a conflict naming both requirers.
fun enqueue_manifest(nv: *NodeVec, manifest_dir: str, dep_root: str, mt: *toml.Table, req: str) Result[bool, str] {
    val deps: *toml.Table = toml.get_table(mt, "deps");
    if (deps == nil) { ret ok[bool, str](true); }
    val n: usize = toml.table_len(deps);
    if (n == 0) { ret ok[bool, str](true); }

    var k: usize = 0;
    for (k < n) {
        val name: str = toml.table_key(deps, k);
        val v: *toml.Value = toml.table_value(deps, k);
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            ret err[bool, str](cc3(nv.alloc, "[deps.", name, "] is not a table"));
        }
        val sr: Result[DepNode, str] = read_dep_spec(nv.alloc, ?v.data.table, name);
        if (is_err[DepNode, str](sr)) { ret err[bool, str](unwrap_err[DepNode, str](sr)); }
        var node: DepNode = unwrap_ok[DepNode, str](sr);
        node.req = own(nv.alloc, req);

        var dir_r: Result[str, str];
        if (node.is_git) { dir_r = join2(nv.alloc, dep_root, node.name::*u8); }
        or              { dir_r = join2(nv.alloc, manifest_dir, node.path::*u8); }
        if (is_err[str, str](dir_r)) { ret err[bool, str]("out of memory"); }
        node.dir = unwrap_ok[str, str](dir_r);

        val existing: i64 = nv_find(nv, node.name);
        if (existing >= 0) {
            if (!node_source_eq(?nv.data[existing::usize], ?node)) {
                ret err[bool, str](conflict_msg(nv.alloc, node.name, nv.data[existing::usize].req, req));
            }
            k = k + 1;
            cnt;
        }
        val pr: Result[bool, str] = nv_push(nv, node);
        if (is_err[bool, str](pr)) { ret pr; }
        k = k + 1;
    }
    ret ok[bool, str](true);
}

# node_source_eq: whether two nodes name the same source — both path with the same
# path, or both git with the same url and ref. a git-vs-path mismatch is unequal.
fun node_source_eq(a: *DepNode, b: *DepNode) bool {
    if (a.is_git != b.is_git) { ret false; }
    if (a.is_git) { ret str_equals(a.git_url, b.git_url) && str_equals(a.ref, b.ref); }
    ret str_equals(a.path, b.path);
}

# conflict_msg: the hard-error diagnostic for one name required from two sources.
fun conflict_msg(alloc: *Allocator, name: str, req_a: str, req_b: str) str {
    ret cc5(alloc, cc3(alloc, "dependency '", name, "' is required by '"), req_a, "' and '", req_b, "' with conflicting sources or refs");
}

# read_dep_manifest: parse `<dir>/mach.toml`, returning an error only on a present
# but malformed file. a missing manifest yields an error too (so the caller skips
# it); the caller treats any error as "no transitive deps here".
fun read_dep_manifest(alloc: *Allocator, dir: str) Result[toml.Table, str] {
    val mp_r: Result[str, str] = join2(alloc, dir, MANIFEST);
    if (is_err[str, str](mp_r)) { ret err[toml.Table, str]("out of memory"); }
    val mp: str = unwrap_ok[str, str](mp_r);
    if (!fs.exists(mp)) { ret err[toml.Table, str]("no manifest"); }
    ret parse_file(alloc, mp);
}

# ensure_git: resolve the git transport once — the absolute git path plus the
# allowlisted child environment — caching it on the GitTool. absence is a clean
# error naming the operation that needed git.
fun ensure_git(alloc: *Allocator, gt: *GitTool) Result[bool, str] {
    if (gt.ready) { ret ok[bool, str](true); }
    # windows executables carry a `.exe` extension; the bare `git` name does not
    # resolve on PATH there (it's `git.exe`), so look for the right name (#1506).
    var gname: *u8 = "git";
    $if ($mach.build.os == $mach.os.windows) { gname = "git.exe"; }
    val git_r: Result[str, str] = find_on_path(alloc, gname);
    if (is_err[str, str](git_r)) { ret err[bool, str]("git not found on PATH (needed to fetch git dependencies)"); }
    gt.git = unwrap_ok[str, str](git_r);
    # windows CreateProcess inherits the full parent environment when the child
    # env is nil — required here, since git's winsock initialization needs
    # SystemRoot (and friends) that the posix allowlist drops; without them the
    # clone fails with "getaddrinfo() thread failed to start" (#1538). posix
    # execve does not inherit and the runtime exposes no handle to environ, so
    # there the child env is reconstructed from the allowlist.
    $if ($mach.build.os == $mach.os.windows) {
        gt.env = nil;
    } $or {
        val env_r: Result[**u8, str] = build_env(alloc);
        if (is_err[**u8, str](env_r)) { ret err[bool, str]("failed to build child environment for git"); }
        gt.env = unwrap_ok[**u8, str](env_r);
    }
    gt.ready = true;
    ret ok[bool, str](true);
}

# git_clone: `git clone <url> <dir>`, creating the dep root first.
fun git_clone(alloc: *Allocator, gt: *GitTool, dep_root: str, dir: str, url: str) Result[bool, str] {
    fs.create_dir_all(alloc, dep_root, 0o755);
    var ca: [4]usize;
    ca[0] = "clone"::usize;
    ca[1] = url::usize;
    ca[2] = dir::usize;
    ca[3] = 0;
    ret run_git(gt.git, gt.env, (?ca[0])::**u8);
}

# git_fetch: `git -C <dir> fetch --all --tags`, refreshing remotes so a moved
# branch or new tag resolves. a fetch failure is tolerated (an offline pull can
# still honour an already-present commit).
fun git_fetch(alloc: *Allocator, gt: *GitTool, dir: str) {
    var fa: [6]usize;
    fa[0] = "-C"::usize;
    fa[1] = dir::usize;
    fa[2] = "fetch"::usize;
    fa[3] = "--all"::usize;
    fa[4] = "--tags"::usize;
    fa[5] = 0;
    run_git(gt.git, gt.env, (?fa[0])::**u8);
}

# git_checkout: detach HEAD onto the commit named by `ref`. an empty ref takes the
# remote default branch; `branch/<n>` the remote-tracking branch tip; `tag/<n>`
# the tag; `commit/<n>` or a bare sha the literal commit; a bare name prefers the
# remote-tracking branch (a moved branch resolves to its tip), else the literal.
fun git_checkout(alloc: *Allocator, gt: *GitTool, dir: str, ref: str) Result[bool, str] {
    if (str_empty(ref)) { ret git_checkout_one(gt, dir, "origin/HEAD"); }
    if (str_starts_with(ref, "branch/")) {
        ret git_checkout_one(gt, dir, with_prefix(alloc, "origin/", drop_prefix(ref, 7)));
    }
    if (str_starts_with(ref, "tag/")) {
        ret git_checkout_one(gt, dir, drop_prefix(ref, 4));
    }
    if (str_starts_with(ref, "commit/")) {
        ret git_checkout_one(gt, dir, drop_prefix(ref, 7));
    }
    if (is_hex_sha(ref)) { ret git_checkout_one(gt, dir, ref); }

    val remote_ref: str = with_prefix(alloc, "refs/remotes/origin/", ref);
    if (git_ref_exists(gt, dir, remote_ref)) {
        ret git_checkout_one(gt, dir, with_prefix(alloc, "origin/", ref));
    }
    ret git_checkout_one(gt, dir, ref);
}

# git_ref_exists: true if the fully-qualified `ref` resolves, probed silently via
# `git -C <dir> show-ref --verify --quiet <ref>`.
fun git_ref_exists(gt: *GitTool, dir: str, ref: str) bool {
    var sr: [7]usize;
    sr[0] = "-C"::usize;
    sr[1] = dir::usize;
    sr[2] = "show-ref"::usize;
    sr[3] = "--verify"::usize;
    sr[4] = "--quiet"::usize;
    sr[5] = ref::usize;
    sr[6] = 0;
    ret is_ok[bool, str](run_git(gt.git, gt.env, (?sr[0])::**u8));
}

# git_checkout_one: `git -C <dir> checkout --detach <committish>`.
fun git_checkout_one(gt: *GitTool, dir: str, committish: str) Result[bool, str] {
    var co: [6]usize;
    co[0] = "-C"::usize;
    co[1] = dir::usize;
    co[2] = "checkout"::usize;
    co[3] = "--detach"::usize;
    co[4] = committish::usize;
    co[5] = 0;
    ret run_git(gt.git, gt.env, (?co[0])::**u8);
}

# run_git: spawn git (program path `git`) with a null-terminated argument vector
# `rest` (the trailing args after the program name), wait, and map a non-zero exit
# or spawn failure to an error.
fun run_git(git: str, env: **u8, rest: **u8) Result[bool, str] {
    var n: usize = 0;
    for (rest[n]::usize != 0) { n = n + 1; }

    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { ret err[bool, str]("allocator init failed"); }
    val r: Result[*usize, str] = allocate[usize](?alloc, n + 2);
    if (is_err[*usize, str](r)) { ret err[bool, str](unwrap_err[*usize, str](r)); }
    val argv: *usize = unwrap_ok[*usize, str](r);
    argv[0] = git::usize;
    var i: usize = 0;
    for (i < n) { argv[i + 1] = rest[i]::usize; i = i + 1; }
    argv[n + 1] = 0;

    val rr: Result[exec.ExitStatus, str] = exec.run(git, (?argv[0])::**u8, env);
    if (is_err[exec.ExitStatus, str](rr)) { ret err[bool, str]("spawn failed"); }
    val s: exec.ExitStatus = unwrap_ok[exec.ExitStatus, str](rr);
    if (!exec.exited(s) || exec.code(s) != 0) { ret err[bool, str]("git exited non-zero"); }
    ret ok[bool, str](true);
}

# is_git_checkout: true if `<dir>/.git` exists as a file or a directory — i.e. a
# plain clone (`.git` dir) or a committed submodule (`.git` gitlink file). a
# directory without `.git` is a vendored raw tree, not a checkout.
fun is_git_checkout(alloc: *Allocator, dir: str) bool {
    val gp_r: Result[str, str] = join2(alloc, dir, ".git");
    if (is_err[str, str](gp_r)) { ret false; }
    ret fs.exists(unwrap_ok[str, str](gp_r));
}

# is_dot_name: whether a null-terminated dirent name is "." or "..".
fun is_dot_name(name: *u8) bool {
    if (name[0] != '.') { ret false; }
    if (name[1] == 0) { ret true; }
    ret name[1] == '.' && name[2] == 0;
}

# dir_is_empty: whether the directory at `dir` holds no entries beyond `.`/`..`.
# a plain `git clone` (no --recurse-submodules) leaves a submodule dep dir as an
# empty placeholder; an empty dir has nothing to vendor, so the pull path treats
# it as absent and clones into it (#1329). a path that is not an openable
# directory (a file, or unreadable) reports non-empty so today's "not a git
# checkout" error still fires for a populated vendored tree.
fun dir_is_empty(dir: str) bool {
    val fd: i64 = os.open(os.AT_FDCWD, dir, os.O_RDONLY | os.O_DIRECTORY, 0);
    if (fd < 0) { ret false; }
    var buf: [4096]u8;
    var empty: bool = true;
    for (empty) {
        val nread: i64 = os.read_dir(fd::i32, (?buf[0])::*os.dirent64, 4096);
        if (nread <= 0) { brk; }
        var off: usize = 0;
        for (off < nread::usize) {
            val ent: *os.dirent64 = (?buf[off])::*os.dirent64;
            if (ent.d_reclen == 0) { brk; }
            if (!is_dot_name(?ent.d_name[0])) { empty = false; brk; }
            off = off + ent.d_reclen::usize;
        }
    }
    val ignore: i64 = os.close(fd::i32);
    ret empty;
}

# head_sha: the commit the checkout at `dir` sits on, read from its git directory's
# HEAD (the raw sha after a detached checkout). resolves a submodule's `.git`
# gitlink file to the real git directory, and a symbolic HEAD to its loose ref.
# returns "" when it cannot be read.
fun head_sha(alloc: *Allocator, dir: str) str {
    val gd_r: Result[str, str] = git_dir_of(alloc, dir);
    if (is_err[str, str](gd_r)) { ret ""; }
    val gd: str = unwrap_ok[str, str](gd_r);

    val head_r: Result[str, str] = join2(alloc, gd, "HEAD");
    if (is_err[str, str](head_r)) { ret ""; }
    val text_r: Result[str, str] = fs.read_all(alloc, unwrap_ok[str, str](head_r));
    if (is_err[str, str](text_r)) { ret ""; }
    val head: str = trim_owned(alloc, unwrap_ok[str, str](text_r));

    if (str_starts_with(head, "ref: ")) {
        val refp: str = drop_prefix(head, 5);
        val rp_r: Result[str, str] = join2(alloc, gd, refp::*u8);
        if (is_err[str, str](rp_r)) { ret ""; }
        val rt_r: Result[str, str] = fs.read_all(alloc, unwrap_ok[str, str](rp_r));
        if (is_err[str, str](rt_r)) { ret ""; }
        ret trim_owned(alloc, unwrap_ok[str, str](rt_r));
    }
    ret head;
}

# git_dir_of: the real git directory for the checkout at `dir`. `<dir>/.git` is
# either a directory (plain clone) or a file `gitdir: <path>` (submodule); the
# latter is resolved relative to `dir`.
fun git_dir_of(alloc: *Allocator, dir: str) Result[str, str] {
    val gp_r: Result[str, str] = join2(alloc, dir, ".git");
    if (is_err[str, str](gp_r)) { ret gp_r; }
    val gp: str = unwrap_ok[str, str](gp_r);
    if (fs.is_dir(gp)) { ret ok[str, str](gp); }
    if (!fs.is_file(gp)) { ret err[str, str]("no .git"); }

    val text_r: Result[str, str] = fs.read_all(alloc, gp);
    if (is_err[str, str](text_r)) { ret text_r; }
    val line: str = trim_owned(alloc, unwrap_ok[str, str](text_r));
    if (!str_starts_with(line, "gitdir: ")) { ret err[str, str]("malformed .git file"); }
    val rel: str = drop_prefix(line, 8);
    if (str_len(rel) > 0 && rel[0] == '/'::u8) { ret ok[str, str](own(alloc, rel)); }
    ret join2(alloc, dir, rel::*u8);
}

# trim_owned: an owned null-terminated copy of `s` with trailing whitespace
# removed. `str` is a bare null-terminated pointer with no length, so a trimmed
# view must be a fresh buffer terminated at the cut.
fun trim_owned(alloc: *Allocator, s: str) str {
    var n: usize = str_len(s);
    for (n > 0 && (s[n - 1] == '\n' || s[n - 1] == '\r' || s[n - 1] == ' ' || s[n - 1] == '\t')) {
        n = n - 1;
    }
    val r: Result[*u8, str] = allocate[u8](alloc, n + 1);
    if (is_err[*u8, str](r)) { ret ""; }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    put_n(buf, 0, s::*u8, n);
    buf[n] = 0;
    ret buf::str;
}

# is_hex_sha: true if `s` is a 7-to-40 char run of hex digits — a commit sha.
fun is_hex_sha(s: str) bool {
    val n: usize = str_len(s);
    if (n < 7 || n > 40) { ret false; }
    var i: usize = 0;
    for (i < n) {
        val c: u8 = s[i];
        val is_digit: bool = c >= '0' && c <= '9';
        val is_lower: bool = c >= 'a' && c <= 'f';
        val is_upper: bool = c >= 'A' && c <= 'F';
        if (!is_digit && !is_lower && !is_upper) { ret false; }
        i = i + 1;
    }
    ret true;
}

# sha_or: a commit sha for display, or a `(none)` placeholder when empty.
fun sha_or(sha: str) str {
    if (str_empty(sha)) { ret "(none)"; }
    ret sha;
}

# ref_or: a ref for display, or `(default)` for the empty (default-branch) ref.
fun ref_or(ref: str) str {
    if (str_empty(ref)) { ret "(default)"; }
    ret ref;
}

# read_lock_deps: parse `lock_path` and return its `[deps]` table, or nil when the
# lockfile is absent or unparseable.
fun read_lock_deps(alloc: *Allocator, lock_path: str) *toml.Table {
    val tr: Result[toml.Table, str] = parse_file(alloc, lock_path);
    if (is_err[toml.Table, str](tr)) { ret nil; }
    var t: toml.Table = unwrap_ok[toml.Table, str](tr);
    ret toml.get_table(?t, "deps");
}

# read_lock_nodes: read every `[deps.<name>]` lock entry into DepNode records (git
# nodes, with `dir` set to `<dep_root>/<name>`), for `update` to advance. a missing
# lockfile yields zero nodes.
fun read_lock_nodes(alloc: *Allocator, lock_path: str, dep_root: str, out: **DepNode, out_count: *usize) Result[bool, str] {
    @out = nil;
    @out_count = 0;
    val deps: *toml.Table = read_lock_deps(alloc, lock_path);
    if (deps == nil) { ret ok[bool, str](true); }
    val n: usize = toml.table_len(deps);
    if (n == 0) { ret ok[bool, str](true); }

    val r: Result[*DepNode, str] = allocate[DepNode](alloc, n);
    if (is_err[*DepNode, str](r)) { ret err[bool, str](unwrap_err[*DepNode, str](r)); }
    val arr: *DepNode = unwrap_ok[*DepNode, str](r);

    var i: usize = 0;
    for (i < n) {
        val name: str = toml.table_key(deps, i);
        val v: *toml.Value = toml.table_value(deps, i);
        var node: DepNode;
        node.name    = own(alloc, name);
        node.is_git  = true;
        node.path    = "";
        node.req     = "";
        node.git_url = "";
        node.ref     = "";
        node.commit  = "";
        if (v != nil && v.tag == toml.TYPE_TABLE) {
            node.git_url = own(alloc, toml.get_str(?v.data.table, "url"));
            node.ref     = own(alloc, toml.get_str(?v.data.table, "ref"));
            node.commit  = own(alloc, toml.get_str(?v.data.table, "commit"));
        }
        val dir_r: Result[str, str] = join2(alloc, dep_root, name::*u8);
        if (is_err[str, str](dir_r)) { ret err[bool, str]("out of memory"); }
        node.dir = unwrap_ok[str, str](dir_r);
        arr[i] = node;
        i = i + 1;
    }
    @out = arr;
    @out_count = n;
    ret ok[bool, str](true);
}

# lock_field: the value of `key` (`ref`/`commit`/`url`) for the lock entry named
# `name`, or "" when absent.
fun lock_field(lock_deps: *toml.Table, name: str, key: *u8) str {
    if (lock_deps == nil) { ret ""; }
    val count: usize = toml.table_len(lock_deps);
    var i: usize = 0;
    for (i < count) {
        if (str_equals(toml.table_key(lock_deps, i), name)) {
            val v: *toml.Value = toml.table_value(lock_deps, i);
            if (v != nil && v.tag == toml.TYPE_TABLE) { ret toml.get_str(?v.data.table, key::str); }
        }
        i = i + 1;
    }
    ret "";
}

# entry_size: the exact byte count one git node serializes to in the lockfile,
# derived from the same SEG_* literals write_lock emits. summing it over the git
# nodes yields the precise buffer size — no hand-counted literal lengths to fall
# out of sync with the emission (#1258).
fun entry_size(node: *DepNode) usize {
    ret util.slen(SEG_OPEN)   + str_len(node.name)
      + util.slen(SEG_URL)    + str_len(node.git_url)
      + util.slen(SEG_REF)    + str_len(node.ref)
      + util.slen(SEG_COMMIT) + str_len(node.commit)
      + util.slen(SEG_CLOSE);
}

# write_lock: write `mach.lock` at `lock_path` recording each git node's url, ref,
# and resolved commit (path nodes carry no lock entry). returns whether a write
# occurred — false when the on-disk lock already matches byte-for-byte, leaving
# its mtime untouched (idempotent, #1246).
fun write_lock(alloc: *Allocator, nodes: *DepNode, count: usize, lock_path: str) Result[bool, str] {
    var total: usize = util.slen(LOCK_HEAD);
    var i: usize = 0;
    for (i < count) {
        if (nodes[i].is_git) { total = total + entry_size(?nodes[i]); }
        i = i + 1;
    }

    val r: Result[*u8, str] = allocate[u8](alloc, total + 1);
    if (is_err[*u8, str](r)) { ret err[bool, str](unwrap_err[*u8, str](r)); }
    val buf: *u8 = unwrap_ok[*u8, str](r);

    var k: usize = put(buf, 0, LOCK_HEAD);
    i = 0;
    for (i < count) {
        if (nodes[i].is_git) {
            k = put(buf, k, SEG_OPEN);
            k = put_n(buf, k, nodes[i].name::*u8, str_len(nodes[i].name));
            k = put(buf, k, SEG_URL);
            k = put_n(buf, k, nodes[i].git_url::*u8, str_len(nodes[i].git_url));
            k = put(buf, k, SEG_REF);
            k = put_n(buf, k, nodes[i].ref::*u8, str_len(nodes[i].ref));
            k = put(buf, k, SEG_COMMIT);
            k = put_n(buf, k, nodes[i].commit::*u8, str_len(nodes[i].commit));
            k = put(buf, k, SEG_CLOSE);
        }
        i = i + 1;
    }
    buf[k] = 0;

    val cur_r: Result[str, str] = fs.read_all(alloc, lock_path);
    if (is_ok[str, str](cur_r)) {
        if (str_equals(unwrap_ok[str, str](cur_r), buf::str)) { ret ok[bool, str](false); }
    }

    val wr: Result[bool, str] = fs.write_file(lock_path, buf, k, 0o644);
    if (is_err[bool, str](wr)) { ret wr; }
    ret ok[bool, str](true);
}

# append_git_dep: append a `[deps.<name>]` git stanza — `git = "<url>"` plus an
# optional `ref = "<ref>"` — to the manifest.
fun append_git_dep(alloc: *Allocator, name: *u8, url: *u8, ref: *u8) Result[bool, str] {
    val has_ref: bool = util.slen(ref) > 0;

    var add: usize = util.slen(SEG_OPEN) + util.slen(name) + 2 + util.slen(SEG_GIT) + util.slen(url) + util.slen(SEG_CLOSE);
    if (has_ref) { add = add + util.slen(SEG_MREF) + util.slen(ref) + util.slen(SEG_CLOSE); }
    ret append_entry(alloc, name, add, SEG_GIT, url, ref, has_ref);
}

# append_path_dep: append a `[deps.<name>]` path stanza. path deps carry no ref.
fun append_path_dep(alloc: *Allocator, name: *u8, dir: *u8) Result[bool, str] {
    val add: usize = util.slen(SEG_OPEN) + util.slen(name) + 2 + util.slen(SEG_PATH) + util.slen(dir) + util.slen(SEG_CLOSE);
    ret append_entry(alloc, name, add, SEG_PATH, dir, "", false);
}

# append_entry: the shared manifest appender. the TOML reader has no serializer,
# so the stanza is appended verbatim to preserve existing comments and layout.
# `add` is the exact byte growth; the emission writes `[deps.<name>]\n<src_key><val>"\n`
# plus an optional `ref = "<ref>"\n`.
fun append_entry(alloc: *Allocator, name: *u8, add: usize, src_key: *u8, value: *u8, ref: *u8, has_ref: bool) Result[bool, str] {
    val text_r: Result[str, str] = fs.read_all(alloc, MANIFEST::str);
    if (is_err[str, str](text_r)) { ret err[bool, str](unwrap_err[str, str](text_r)); }
    val text: str = unwrap_ok[str, str](text_r);
    val base_len: usize = str_len(text);

    val total: usize = base_len + add;
    val r_buf: Result[*u8, str] = allocate[u8](alloc, total + 1);
    if (is_err[*u8, str](r_buf)) { ret err[bool, str](unwrap_err[*u8, str](r_buf)); }
    val buf: *u8 = unwrap_ok[*u8, str](r_buf);

    var k: usize = put_n(buf, 0, text::*u8, base_len);
    k = put(buf, k, SEG_OPEN);
    k = put_n(buf, k, name, util.slen(name));
    buf[k] = ']'::u8;  k = k + 1;
    buf[k] = '\n'::u8; k = k + 1;
    k = put(buf, k, src_key);
    k = put_n(buf, k, value, util.slen(value));
    k = put(buf, k, SEG_CLOSE);
    if (has_ref) {
        k = put(buf, k, SEG_MREF);
        k = put_n(buf, k, ref, util.slen(ref));
        k = put(buf, k, SEG_CLOSE);
    }
    buf[k] = 0;

    ret fs.write_file(MANIFEST::str, buf, k, 0o644);
}

# table_has_key: true when the table `deps` already contains key `name`.
fun table_has_key(deps: *toml.Table, name: *u8) bool {
    if (deps == nil) { ret false; }
    val count: usize = toml.table_len(deps);
    var i: usize = 0;
    for (i < count) {
        if (str_equals(toml.table_key(deps, i), name::str)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# dep_declared: true when a `[deps.<name>]` entry exists in the manifest.
fun dep_declared(alloc: *Allocator, name: *u8) bool {
    val tr: Result[toml.Table, str] = parse_file(alloc, MANIFEST::str);
    if (is_err[toml.Table, str](tr)) { ret false; }
    var t: toml.Table = unwrap_ok[toml.Table, str](tr);
    ret table_has_key(toml.get_table(?t, "deps"), name);
}

# strip_dep_entry: rewrite a TOML `file` with the `[deps.<name>]` table removed.
# operates on raw text line-by-line: the table header and every following line up
# to the next table header (or EOF) are dropped.
fun strip_dep_entry(alloc: *Allocator, file: *u8, name: *u8) Result[bool, str] {
    val text_r: Result[str, str] = fs.read_all(alloc, file::str);
    if (is_err[str, str](text_r)) { ret err[bool, str](unwrap_err[str, str](text_r)); }
    val text: str = unwrap_ok[str, str](text_r);
    val n: usize = str_len(text);

    val hr: Result[*u8, str] = dep_header(alloc, name);
    if (is_err[*u8, str](hr)) { ret err[bool, str](unwrap_err[*u8, str](hr)); }
    val hdr: *u8 = unwrap_ok[*u8, str](hr);

    val r_buf: Result[*u8, str] = allocate[u8](alloc, n + 1);
    if (is_err[*u8, str](r_buf)) { ret err[bool, str](unwrap_err[*u8, str](r_buf)); }
    val buf: *u8 = unwrap_ok[*u8, str](r_buf);

    var k: usize = 0;
    var i: usize = 0;
    var dropping: bool = false;
    for (i < n) {
        val ls: usize = i;
        for (i < n && text[i] != '\n') { i = i + 1; }
        val le: usize = i;
        if (i < n) { i = i + 1; }

        val is_header: bool = le > ls && text[ls] == '[';
        if (is_header) { dropping = line_matches(text, ls, le, hdr); }

        if (!dropping) {
            var j: usize = ls;
            for (j < i) { buf[k] = text[j]; k = k + 1; j = j + 1; }
        }
    }
    buf[k] = 0;

    ret fs.write_file(file::str, buf, k, 0o644);
}

# line_matches: true if `text[start..end]`, trimmed of trailing ASCII whitespace,
# equals the null-terminated `hdr`.
fun line_matches(text: str, start: usize, end: usize, hdr: *u8) bool {
    var e: usize = end;
    for (e > start && (text[e - 1] == ' ' || text[e - 1] == '\t' || text[e - 1] == '\r')) {
        e = e - 1;
    }
    ret str_region_equals(text, start, e - start, hdr::str);
}

# dep_header: build the null-terminated table header `[deps.<name>]`.
fun dep_header(alloc: *Allocator, name: *u8) Result[*u8, str] {
    val a_len: usize = util.slen(name);
    val r: Result[*u8, str] = allocate[u8](alloc, 7 + a_len + 1 + 1);
    if (is_err[*u8, str](r)) { ret r; }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put(buf, 0, "[deps.");
    k = put_n(buf, k, name, a_len);
    k = put(buf, k, "]");
    buf[k] = 0;
    ret ok[*u8, str](buf::str);
}

# dep_dir_path: the dep directory `<dep>/<name>/` for a dependency of the project
# in the current directory, resolved through the manifest's `[project].dep`.
fun dep_dir_path(alloc: *Allocator, name: *u8) Result[str, str] {
    val tr: Result[toml.Table, str] = parse_file(alloc, MANIFEST::str);
    if (is_err[toml.Table, str](tr)) { ret err[str, str](unwrap_err[toml.Table, str](tr)); }
    var t: toml.Table = unwrap_ok[toml.Table, str](tr);
    val root_r: Result[str, str] = join2(alloc, ".", dep_dir_name(?t)::*u8);
    if (is_err[str, str](root_r)) { ret root_r; }
    ret join2(alloc, unwrap_ok[str, str](root_r), name);
}

# remove_tree: best-effort recursive delete of a directory tree via the std
# filesystem primitive (no host `rm`). errors are ignored — the tree is cleared
# before re-vendoring, so a stale or partially removed dir is not fatal.
fun remove_tree(alloc: *Allocator, dir: str) {
    fs.remove_all(alloc, dir);
}

# find_on_path: resolve an absolute path to `name` via util.resolve_cmd.
# `os.spawn` uses execve with no PATH search, so a concrete path is required.
fun find_on_path(alloc: *Allocator, name: *u8) Result[str, str] {
    val r: Result[*u8, str] = util.resolve_cmd(alloc, name);
    if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
    ret ok[str, str](unwrap_ok[*u8, str](r)::str);
}

# ENV_COUNT: the number of allowlisted environment variables forwarded to git.
val ENV_COUNT: usize = 21;

# env_key: the name of the i-th forwarded environment variable. git's https/ssh
# transports need PATH and HOME at minimum; the rest cover credential helpers,
# custom CA bundles, proxies, and SSH agents so non-default setups still work.
# this is an explicit allowlist, not a fallback: the runtime exposes no handle to
# the raw inherited environ, so the child env is reconstructed from getenv.
fun env_key(i: usize) *u8 {
    if (i == 0)  { ret "PATH"; }
    if (i == 1)  { ret "HOME"; }
    if (i == 2)  { ret "USER"; }
    if (i == 3)  { ret "SSH_AUTH_SOCK"; }
    if (i == 4)  { ret "GIT_SSH"; }
    if (i == 5)  { ret "GIT_SSH_COMMAND"; }
    if (i == 6)  { ret "GIT_ASKPASS"; }
    if (i == 7)  { ret "GIT_CONFIG_GLOBAL"; }
    if (i == 8)  { ret "GIT_TERMINAL_PROMPT"; }
    if (i == 9)  { ret "XDG_CONFIG_HOME"; }
    if (i == 10) { ret "SSL_CERT_FILE"; }
    if (i == 11) { ret "SSL_CERT_DIR"; }
    if (i == 12) { ret "GIT_SSL_CAINFO"; }
    if (i == 13) { ret "HTTP_PROXY"; }
    if (i == 14) { ret "HTTPS_PROXY"; }
    if (i == 15) { ret "http_proxy"; }
    if (i == 16) { ret "https_proxy"; }
    if (i == 17) { ret "ALL_PROXY"; }
    if (i == 18) { ret "all_proxy"; }
    if (i == 19) { ret "NO_PROXY"; }
    ret "no_proxy";
}

# build_env: reconstruct a null-terminated envp for git from the allowlisted
# variables present in the parent environment.
fun build_env(alloc: *Allocator) Result[**u8, str] {
    val r_arr: Result[*usize, str] = allocate[usize](alloc, ENV_COUNT + 1);
    if (is_err[*usize, str](r_arr)) { ret err[**u8, str](unwrap_err[*usize, str](r_arr)); }
    val arr: *usize = unwrap_ok[*usize, str](r_arr);

    var count: usize = 0;
    var i: usize = 0;
    for (i < ENV_COUNT) {
        val name: *u8 = env_key(i);
        var vbuf: [4096]u8;
        val vl: i64 = os.getenv(name, ?vbuf[0], 4096);
        if (vl >= 0) {
            val nlen: usize = util.slen(name);
            val vlen: usize = vl::usize;
            val elen: usize = nlen + 1 + vlen;
            val re: Result[*u8, str] = allocate[u8](alloc, elen + 1);
            if (is_err[*u8, str](re)) { ret err[**u8, str](unwrap_err[*u8, str](re)); }
            val e: *u8 = unwrap_ok[*u8, str](re);
            var k: usize = put(e, 0, name);
            e[k] = '='::u8; k = k + 1;
            var j: usize = 0;
            for (j < vlen) { e[k] = vbuf[j]; k = k + 1; j = j + 1; }
            e[k] = 0;
            arr[count] = e::usize;
            count = count + 1;
        }
        i = i + 1;
    }
    arr[count] = 0;
    ret ok[**u8, str]((?arr[0])::**u8);
}

# dep_dir_name: the project's dep-dir name from a parsed manifest `mt`, reading
# `[project].dep`, defaulting to "dep".
fun dep_dir_name(mt: *toml.Table) str {
    val d: str = toml.get_str(mt, "project.dep");
    if (str_empty(d)) { ret "dep"; }
    ret d;
}

# arg_quiet: whether `--quiet`/`-q` is present, suppressing routine informational
# stdout (action confirmations and the lock status line).
fun arg_quiet(argc: usize, argv: **u8) bool {
    ret util.has_flag(argc, argv, "--quiet") || util.has_flag(argc, argv, "-q");
}

# opt_value: unwrap an Option[*u8] flag value into a c-string, "" when absent.
fun opt_value(o: Option[*u8]) *u8 {
    if (is_some[*u8](o)) { ret unwrap[*u8](o); }
    ret "";
}

# parse_file: read and TOML-parse a file, prefixing a parse error with the path.
fun parse_file(alloc: *Allocator, path: str) Result[toml.Table, str] {
    val text_r: Result[str, str] = fs.read_all(alloc, path);
    if (is_err[str, str](text_r)) { ret err[toml.Table, str](cc3(alloc, "cannot read ", path, "")); }
    val pr: Result[toml.Table, str] = toml.parse(alloc, unwrap_ok[str, str](text_r));
    if (is_err[toml.Table, str](pr)) { ret err[toml.Table, str](cc3(alloc, path, ": ", unwrap_err[toml.Table, str](pr))); }
    ret pr;
}

# own: duplicate a borrowed `str` view into an owned null-terminated copy, or ""
# on allocation failure.
fun own(alloc: *Allocator, s: str) str {
    val r: Result[str, str] = str_dup(alloc, s);
    if (is_err[str, str](r)) { ret ""; }
    ret unwrap_ok[str, str](r);
}

# put: copy a null-terminated literal into buf at offset k; return the new offset.
fun put(buf: *u8, k: usize, s: *u8) usize {
    var kk: usize = k;
    var i: usize = 0;
    for (s[i] != 0) { buf[kk] = s[i]; kk = kk + 1; i = i + 1; }
    ret kk;
}

# put_n: copy `n` bytes of a `*u8` into buf at offset k; return the new offset.
fun put_n(buf: *u8, k: usize, s: *u8, n: usize) usize {
    var kk: usize = k;
    var i: usize = 0;
    for (i < n) { buf[kk] = s[i]; kk = kk + 1; i = i + 1; }
    ret kk;
}

# drop_prefix: a view of `s` advanced past its first `n` bytes. the suffix of a
# null-terminated string is itself null-terminated, so no copy is needed.
fun drop_prefix(s: str, n: usize) str {
    ret (s::usize + n)::str;
}

# with_prefix: an owned copy of `prefix` followed by `s`.
fun with_prefix(alloc: *Allocator, prefix: *u8, s: str) str {
    val plen: usize = util.slen(prefix);
    val slen2: usize = str_len(s);
    val r: Result[*u8, str] = allocate[u8](alloc, plen + slen2 + 1);
    if (is_err[*u8, str](r)) { ret s; }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put(buf, 0, prefix);
    k = put_n(buf, k, s::*u8, slen2);
    buf[k] = 0;
    ret buf::str;
}

# join2: join `a` and `b` with a single '/', as an owned null-terminated path.
fun join2(alloc: *Allocator, a: str, b: *u8) Result[str, str] {
    val a_len: usize = str_len(a);
    val b_len: usize = util.slen(b);
    val total: usize = a_len + 1 + b_len;
    val r: Result[*u8, str] = allocate[u8](alloc, total + 1);
    if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put_n(buf, 0, a::*u8, a_len);
    if (k > 0 && buf[k - 1] != '/'::u8) { buf[k] = '/'::u8; k = k + 1; }
    k = put_n(buf, k, b, b_len);
    buf[k] = 0;
    ret ok[str, str](buf::str);
}

# cc3: concatenate three strings into a freshly-allocated owned string.
fun cc3(alloc: *Allocator, a: str, b: str, c: str) str {
    val la: usize = str_len(a);
    val lb: usize = str_len(b);
    val lc: usize = str_len(c);
    val r: Result[*u8, str] = allocate[u8](alloc, la + lb + lc + 1);
    if (is_err[*u8, str](r)) { ret b; }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put_n(buf, 0, a::*u8, la);
    k = put_n(buf, k, b::*u8, lb);
    k = put_n(buf, k, c::*u8, lc);
    buf[k] = 0;
    ret buf::str;
}

# cc5: concatenate five strings.
fun cc5(alloc: *Allocator, a: str, b: str, c: str, d: str, e: str) str {
    ret cc3(alloc, cc3(alloc, a, b, c), d, e);
}

test "dep: entry_size matches the serialized lock entry length (#1258)" {
    val expected: str = "\n[deps.std]\nurl = \"u\"\nref = \"r\"\ncommit = \"c\"\n";
    var node: DepNode;
    node.name    = "std";
    node.git_url = "u";
    node.ref     = "r";
    node.commit  = "c";
    node.is_git  = true;
    if (entry_size(?node) != str_len(expected)) { ret 1; }
    ret 0;
}

test "dep: write_lock round-trips several git nodes without overflow (#1258)" {
    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { ret 1; }

    var nodes: [2]DepNode;
    nodes[0].name = "a";   nodes[0].git_url = "ua";   nodes[0].ref = "ra";   nodes[0].commit = "ca";   nodes[0].is_git = true;
    nodes[1].name = "bee"; nodes[1].git_url = "ubee"; nodes[1].ref = "rbee"; nodes[1].commit = "cbee"; nodes[1].is_git = true;

    val tf_r: Result[fs.TempFile, str] = fs.temp_create(?alloc, "mach_test_lock");
    if (is_err[fs.TempFile, str](tf_r)) { ret 1; }
    var tf: fs.TempFile = unwrap_ok[fs.TempFile, str](tf_r);
    val path: str = fs.temp_path(?tf);

    val wr: Result[bool, str] = write_lock(?alloc, ?nodes[0], 2, path);
    if (is_err[bool, str](wr)) { fs.temp_close_and_remove(?tf); ret 1; }

    val rr: Result[str, str] = fs.read_all(?alloc, path);
    fs.temp_close_and_remove(?tf);
    if (is_err[str, str](rr)) { ret 1; }
    val got: str = unwrap_ok[str, str](rr);

    val want: str = "# this file is automatically generated; do not edit by hand.\n\n[deps.a]\nurl = \"ua\"\nref = \"ra\"\ncommit = \"ca\"\n\n[deps.bee]\nurl = \"ubee\"\nref = \"rbee\"\ncommit = \"cbee\"\n";
    if (!str_equals(got, want)) { ret 1; }
    ret 0;
}

test "dep: a path node carries no lock entry" {
    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { ret 1; }

    var nodes: [2]DepNode;
    nodes[0].name = "g"; nodes[0].git_url = "u"; nodes[0].ref = "r"; nodes[0].commit = "c"; nodes[0].is_git = true;
    nodes[1].name = "p"; nodes[1].path = "dep/p"; nodes[1].is_git = false;

    val tf_r: Result[fs.TempFile, str] = fs.temp_create(?alloc, "mach_test_lock_path");
    if (is_err[fs.TempFile, str](tf_r)) { ret 1; }
    var tf: fs.TempFile = unwrap_ok[fs.TempFile, str](tf_r);
    val path: str = fs.temp_path(?tf);

    write_lock(?alloc, ?nodes[0], 2, path);
    val rr: Result[str, str] = fs.read_all(?alloc, path);
    fs.temp_close_and_remove(?tf);
    if (is_err[str, str](rr)) { ret 1; }
    val got: str = unwrap_ok[str, str](rr);
    val want: str = "# this file is automatically generated; do not edit by hand.\n\n[deps.g]\nurl = \"u\"\nref = \"r\"\ncommit = \"c\"\n";
    if (!str_equals(got, want)) { ret 1; }
    ret 0;
}

test "dep: node_source_eq distinguishes ref and source mismatches" {
    var a: DepNode; a.is_git = true; a.git_url = "u"; a.ref = "branch/main"; a.path = "";
    var b: DepNode; b.is_git = true; b.git_url = "u"; b.ref = "branch/main"; b.path = "";
    if (!node_source_eq(?a, ?b)) { ret 1; }
    b.ref = "v1.0.0";
    if (node_source_eq(?a, ?b)) { ret 1; }
    var c: DepNode; c.is_git = false; c.path = "dep/x"; c.git_url = ""; c.ref = "";
    if (node_source_eq(?a, ?c)) { ret 1; }
    ret 0;
}

test "dep: ref_advanceable advances branches and the default, freezes tags/commits" {
    if (!ref_advanceable("")) { ret 1; }
    if (!ref_advanceable("branch/dev")) { ret 1; }
    if (ref_advanceable("tag/v1.0.0")) { ret 1; }
    if (ref_advanceable("commit/abcdef0")) { ret 1; }
    if (ref_advanceable("0123456789abcdef0123456789abcdef01234567")) { ret 1; }
    ret 0;
}

test "dep: path_segments counts real components, ignoring empty and '.' (#1370)" {
    if (path_segments("dep") != 1)         { ret 1; }
    if (path_segments("vendor/deps") != 2) { ret 1; }
    if (path_segments("./dep") != 1)       { ret 1; }
    if (path_segments("a//b") != 2)        { ret 1; }
    if (path_segments("") != 0)            { ret 1; }
    if (path_segments("/") != 0)           { ret 1; }
    ret 0;
}

test "dep: link_target climbs the dep dir, then applies the source path (#1370)" {
    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { ret 1; }
    # the vendor location sits one dir below the root for a single-segment dep dir.
    val t1: Result[str, str] = link_target(?alloc, "dep", "./../lib-x");
    if (is_err[str, str](t1)) { ret 1; }
    if (!str_equals(unwrap_ok[str, str](t1), ".././../lib-x")) { ret 1; }
    # a two-segment dep dir climbs twice.
    val t2: Result[str, str] = link_target(?alloc, "a/b", "x");
    if (is_err[str, str](t2)) { ret 1; }
    if (!str_equals(unwrap_ok[str, str](t2), "../../x")) { ret 1; }
    ret 0;
}
