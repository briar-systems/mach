# mach.cli.cmd.dep: `mach dep` — manages git-backed dependencies under the
# project's dir_dep directory.
#
# reads `argv[2]` as the sub-subcommand and dispatches: `list` prints every
# `[deps.<alias>]` entry from mach.toml; `add`/`remove`/`sync`/`vendor` mutate
# the dependency tree, the manifest, and the lockfile.
#
# a dependency is a git URL plus a ref (tag, branch, or commit). `sync` clones
# each declared dep into `<dir_dep>/<alias>/`, checks out its ref as a detached
# HEAD, records the resolved commit in `mach.lock`, and honours that lockfile on
# subsequent runs. resolution itself is unchanged: the build reads each dep's
# own mach.toml under `<dir_dep>/<alias>/`, so a git-fetched dep and a
# hand-vendored one are indistinguishable to the compiler.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;
use std.types.string.str_empty;
use std.types.string.str_equals;
use std.types.string.str_starts_with;
use std.types.string.str_region_equals;
use std.types.option.Option;
use std.types.option.is_some;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.is_ok;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;

use std.text.string.str_dup;
use std.text.string.str_free;

use page: std.allocator.page;

use os:    std.system.os;
use fs:    std.filesystem;
use toml:  std.data.toml;
use exec:  std.process.exec;
use print: std.print;

use util: mach.cli.util;

# the manifest and lockfile names, relative to the project root.
val MANIFEST: *u8 = "mach.toml";
val LOCKFILE: *u8 = "mach.lock";

# the fixed text framing a serialized `[deps.<alias>]` table, between the
# entry's dynamic alias/url/ref/commit values. both the manifest appender and
# the lockfile writer size their buffers and emit from this single set, so the
# byte estimate can never drift from the bytes written — the class of
# under-allocation that overflowed write_lock by 2 bytes per dep (#1258).
val SEG_OPEN:   *u8 = "\n[deps.";
val SEG_URL:    *u8 = "]\nurl = \"";
val SEG_REF:    *u8 = "\"\nref = \"";
val SEG_COMMIT: *u8 = "\"\ncommit = \"";
val SEG_CLOSE:  *u8 = "\"\n";
val SEG_MREF:   *u8 = "ref = \"";

# arg_after: return the argument immediately following the first occurrence of
# `flag`, or nil if the flag is absent or terminates the vector.
fun arg_after(argc: usize, argv: **u8, flag: *u8) *u8 {
    var i: usize = 0;
    for (i + 1 < argc) {
        if (str_equals(argv[i]::str, flag::str)) { ret argv[i + 1]; }
        i = i + 1;
    }
    ret nil;
}

# put: copy a null-terminated literal into buf at offset k; return the new offset.
fun put(buf: *u8, k: usize, s: *u8) usize {
    var kk: usize = k;
    var i: usize = 0;
    for (s[i] != 0) { buf[kk] = s[i]; kk = kk + 1; i = i + 1; }
    ret kk;
}

# put_n: copy `n` bytes of a `*u8` into buf at offset k; return the new offset.
fun put_n(buf: *u8, k: usize, s: *u8, n: usize) usize {
    var kk: usize = k;
    var i: usize = 0;
    for (i < n) { buf[kk] = s[i]; kk = kk + 1; i = i + 1; }
    ret kk;
}

# arg_quiet: whether `--quiet`/`-q` is present, suppressing mach's own
# informational stdout lines (the action confirmations and sync summaries).
fun arg_quiet(argc: usize, argv: **u8) bool {
    ret util.has_flag(argc, argv, "--quiet") || util.has_flag(argc, argv, "-q");
}

# run: `mach dep` subcommand entry point. dispatches on `argv[2]`. called by
# cmd.dispatch.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  0 on success, 1 on a user error, 2 on an internal error
pub fun run(argc: usize, argv: **u8) i64 {
    if (argc < 3) {
        print.eprint("error: missing dep action\n");
        print.eprint("usage: mach dep <list|add|remove|sync|vendor>\n");
        ret 1;
    }

    val action: str = argv[2]::str;
    val quiet:  bool = arg_quiet(argc, argv);

    if (str_equals(action, "list"))   { ret dep_list(); }
    if (str_equals(action, "add"))    { ret dep_add(argc, argv); }
    if (str_equals(action, "remove")) { ret dep_remove(argc, argv); }
    if (str_equals(action, "sync"))   { ret dep_sync(quiet); }
    if (str_equals(action, "vendor")) { ret dep_sync(quiet); }

    print.eprint("error: unknown dep action '");
    print.eprint(action);
    print.eprint("'\n");
    print.eprint("usage: mach dep <list|add|remove|sync|vendor>\n");
    ret 1;
}

# dep_url: read a dep entry's git URL. accepts `url`, then `source`, then the
# legacy `path` key — the first non-empty value wins.
fun dep_url(sub: *toml.Table) str {
    var u: str = toml.get_str(sub, "url");
    if (str_empty(u)) { u = toml.get_str(sub, "source"); }
    if (str_empty(u)) { u = toml.get_str(sub, "path"); }
    ret u;
}

# dep_ref: read a dep entry's git ref. accepts `ref`, then the legacy `version`
# key — the first non-empty value wins. an empty ref means the remote default
# branch.
fun dep_ref(sub: *toml.Table) str {
    var r: str = toml.get_str(sub, "ref");
    if (str_empty(r)) { r = toml.get_str(sub, "version"); }
    ret r;
}

# dep_list: print every `[deps.<alias>]` entry from the project's mach.toml
# along with its declared url and ref.
fun dep_list() i64 {
    var alloc: Allocator;
    val mk: Option[str] = page.make(?alloc);
    if (is_some[str](mk)) {
        print.eprint("error: failed to initialise allocator\n");
        ret 2;
    }

    val text_r: Result[str, str] = fs.read_all(?alloc, MANIFEST::str);
    if (is_err[str, str](text_r)) {
        print.eprint("error: no mach.toml in the current directory\n");
        ret 1;
    }
    val text: str = unwrap_ok[str, str](text_r);

    val tab_r: Result[toml.Table, str] = toml.parse(?alloc, text);
    if (is_err[toml.Table, str](tab_r)) {
        print.eprint("error: failed to parse mach.toml: ");
        print.eprint(unwrap_err[toml.Table, str](tab_r));
        print.eprint("\n");
        ret 1;
    }
    var t: toml.Table = unwrap_ok[toml.Table, str](tab_r);

    val deps: *toml.Table = toml.get_table(?t, "deps");
    if (deps == nil || toml.table_len(deps) == 0) {
        print.print("no dependencies\n");
        ret 0;
    }

    val count: usize = toml.table_len(deps);
    var i: usize = 0;
    for (i < count) {
        val alias: str = toml.table_key(deps, i);
        print.print("  ");
        print.print(alias);

        val v: *toml.Value = toml.table_value(deps, i);
        if (v != nil && v.tag == toml.TYPE_TABLE) {
            val sub: *toml.Table = ?v.data.table;
            val url: str = dep_url(sub);
            val ref: str = dep_ref(sub);
            if (str_len(url) > 0) { print.print("  url="); print.print(url); }
            if (str_len(ref) > 0) { print.print("  ref="); print.print(ref); }
        }
        print.print("\n");
        i = i + 1;
    }
    ret 0;
}

# dep_declared: returns true if a `[deps.<alias>]` entry already exists in the
# manifest table `t`.
fun table_has_key(deps: *toml.Table, alias: *u8) bool {
    if (deps == nil) { ret false; }
    val count: usize = toml.table_len(deps);
    var i: usize = 0;
    for (i < count) {
        if (str_equals(toml.table_key(deps, i), alias::str)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# dep_declared: returns true if a `[deps.<alias>]` entry already exists in the
# manifest.
fun dep_declared(alloc: *Allocator, alias: *u8) bool {
    val text_r: Result[str, str] = fs.read_all(alloc, MANIFEST::str);
    if (is_err[str, str](text_r)) { ret false; }
    val text: str = unwrap_ok[str, str](text_r);
    val tab_r: Result[toml.Table, str] = toml.parse(alloc, text);
    if (is_err[toml.Table, str](tab_r)) { ret false; }
    var t: toml.Table = unwrap_ok[toml.Table, str](tab_r);
    ret table_has_key(toml.get_table(?t, "deps"), alias);
}

# dep_add: `mach dep add <alias> <url> [--ref <ref>]`. appends a
# `[deps.<alias>]` entry to mach.toml, then syncs every declared dep.
fun dep_add(argc: usize, argv: **u8) i64 {
    if (argc < 5) {
        print.eprint("error: usage: mach dep add <alias> <url> [--ref <ref>]\n");
        ret 1;
    }
    val alias: *u8 = argv[3];
    val url:   *u8 = argv[4];
    var ref:   *u8 = arg_after(argc, argv, "--ref");
    if (ref == nil) { ref = ""; }
    val quiet: bool = arg_quiet(argc, argv);

    var alloc: Allocator;
    val mk: Option[str] = page.make(?alloc);
    if (is_some[str](mk)) {
        print.eprint("error: failed to initialise allocator\n");
        ret 2;
    }

    if (dep_declared(?alloc, alias)) {
        print.eprint("error: dependency '");
        print.eprint(alias::str);
        print.eprint("' is already declared in mach.toml\n");
        ret 1;
    }

    val wr: Result[bool, str] = append_dep_entry(?alloc, alias, url, ref);
    if (is_err[bool, str](wr)) {
        print.eprint("error: failed to update mach.toml: ");
        print.eprint(unwrap_err[bool, str](wr));
        print.eprint("\n");
        ret 2;
    }

    if (!quiet) {
        print.print("added [deps.");
        print.print(alias::str);
        print.print("]\n");
    }
    ret dep_sync(quiet);
}

# append_dep_entry: append a `[deps.<alias>]` table to the manifest text. the
# TOML reader has no serialiser, so the entry is appended verbatim to preserve
# the file's existing comments and layout.
fun append_dep_entry(alloc: *Allocator, alias: *u8, url: *u8, ref: *u8) Result[bool, str] {
    val text_r: Result[str, str] = fs.read_all(alloc, MANIFEST::str);
    if (is_err[str, str](text_r)) { ret err[bool, str](unwrap_err[str, str](text_r)); }
    val text: str = unwrap_ok[str, str](text_r);
    val base_len: usize = str_len(text);

    val a_len: usize = util.slen(alias);
    val u_len: usize = util.slen(url);
    val r_len: usize = util.slen(ref);
    val has_ref: bool = r_len > 0;

    # "\n[deps.<alias>]\nurl = \"<url>\"\n" plus optional "ref = \"<ref>\"\n",
    # sized from the same SEG_* literals the emission writes.
    var add: usize = util.slen(SEG_OPEN) + a_len + util.slen(SEG_URL) + u_len + util.slen(SEG_CLOSE);
    if (has_ref) { add = add + util.slen(SEG_MREF) + r_len + util.slen(SEG_CLOSE); }

    val total: usize = base_len + add;
    val r_buf: Result[*u8, str] = allocate[u8](alloc, total + 1);
    if (is_err[*u8, str](r_buf)) { ret err[bool, str](unwrap_err[*u8, str](r_buf)); }
    val buf: *u8 = unwrap_ok[*u8, str](r_buf);

    var k: usize = put_n(buf, 0, text::*u8, base_len);
    k = put(buf, k, SEG_OPEN);
    k = put_n(buf, k, alias, a_len);
    k = put(buf, k, SEG_URL);
    k = put_n(buf, k, url, u_len);
    k = put(buf, k, SEG_CLOSE);
    if (has_ref) {
        k = put(buf, k, SEG_MREF);
        k = put_n(buf, k, ref, r_len);
        k = put(buf, k, SEG_CLOSE);
    }
    buf[k] = 0;

    ret fs.write_file(MANIFEST::str, buf, k, 0o644);
}

# dep_remove: `mach dep remove <alias> [--purge]`. drops the `[deps.<alias>]`
# entry from mach.toml; with `--purge`, also deletes the vendored directory.
fun dep_remove(argc: usize, argv: **u8) i64 {
    if (argc < 4) {
        print.eprint("error: usage: mach dep remove <alias> [--purge]\n");
        ret 1;
    }
    val alias: *u8 = argv[3];
    val purge: bool = util.has_flag(argc, argv, "--purge");
    val quiet: bool = arg_quiet(argc, argv);

    var alloc: Allocator;
    val mk: Option[str] = page.make(?alloc);
    if (is_some[str](mk)) {
        print.eprint("error: failed to initialise allocator\n");
        ret 2;
    }

    if (!dep_declared(?alloc, alias)) {
        print.eprint("error: dependency '");
        print.eprint(alias::str);
        print.eprint("' is not declared in mach.toml\n");
        ret 1;
    }

    val rr: Result[bool, str] = strip_dep_entry(?alloc, MANIFEST, alias);
    if (is_err[bool, str](rr)) {
        print.eprint("error: failed to update mach.toml: ");
        print.eprint(unwrap_err[bool, str](rr));
        print.eprint("\n");
        ret 2;
    }

    # drop the matching lockfile entry too, if a lockfile exists.
    if (fs.exists(LOCKFILE::str)) { strip_dep_entry(?alloc, LOCKFILE, alias); }

    if (purge) {
        val dir_r: Result[str, str] = dep_path(?alloc, alias);
        if (is_ok[str, str](dir_r)) {
            val dir: str = unwrap_ok[str, str](dir_r);
            if (fs.exists(dir)) { remove_tree(?alloc, dir); }
        }
    }

    if (!quiet) {
        print.print("removed [deps.");
        print.print(alias::str);
        print.print("]\n");
    }
    ret 0;
}

# strip_dep_entry: rewrite a TOML `file` with the `[deps.<alias>]` table
# removed. operates on the raw text line-by-line: the table header and every
# following line up to the next table header (or EOF) are dropped.
fun strip_dep_entry(alloc: *Allocator, file: *u8, alias: *u8) Result[bool, str] {
    val text_r: Result[str, str] = fs.read_all(alloc, file::str);
    if (is_err[str, str](text_r)) { ret err[bool, str](unwrap_err[str, str](text_r)); }
    val text: str = unwrap_ok[str, str](text_r);
    val n: usize = str_len(text);

    val hr: Result[*u8, str] = dep_header(alloc, alias);
    if (is_err[*u8, str](hr)) { ret err[bool, str](unwrap_err[*u8, str](hr)); }
    val hdr: *u8 = unwrap_ok[*u8, str](hr);

    val r_buf: Result[*u8, str] = allocate[u8](alloc, n + 1);
    if (is_err[*u8, str](r_buf)) { ret err[bool, str](unwrap_err[*u8, str](r_buf)); }
    val buf: *u8 = unwrap_ok[*u8, str](r_buf);

    var k: usize = 0;
    var i: usize = 0;
    var dropping: bool = false;
    for (i < n) {
        val ls: usize = i;
        for (i < n && text[i] != '\n') { i = i + 1; }
        val le: usize = i;
        if (i < n) { i = i + 1; }

        val is_header: bool = le > ls && text[ls] == '[';
        if (is_header) { dropping = line_matches(text, ls, le, hdr); }

        if (!dropping) {
            var j: usize = ls;
            for (j < i) { buf[k] = text[j]; k = k + 1; j = j + 1; }
        }
    }
    buf[k] = 0;

    ret fs.write_file(file::str, buf, k, 0o644);
}

# line_matches: returns true if `text[start..end]`, trimmed of trailing ASCII
# whitespace, equals the null-terminated `hdr`.
fun line_matches(text: str, start: usize, end: usize, hdr: *u8) bool {
    var e: usize = end;
    for (e > start && (text[e - 1] == ' ' || text[e - 1] == '\t' || text[e - 1] == '\r')) {
        e = e - 1;
    }
    ret str_region_equals(text, start, e - start, hdr::str);
}

# dep_header: build the null-terminated table header `[deps.<alias>]`.
fun dep_header(alloc: *Allocator, alias: *u8) Result[*u8, str] {
    val a_len: usize = util.slen(alias);
    val r: Result[*u8, str] = allocate[u8](alloc, 7 + a_len + 1 + 1);
    if (is_err[*u8, str](r)) { ret r; }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put(buf, 0, "[deps.");
    k = put_n(buf, k, alias, a_len);
    k = put(buf, k, "]");
    buf[k] = 0;
    ret ok[*u8, str](buf);
}

# DepSpec: one resolved dependency to record in the lockfile — owned
# null-terminated alias, url, ref, and resolved commit SHA. `managed` is false
# for a dependency `sync` left untouched (a hand-vendored tree or submodule),
# which carries no commit and is excluded from the lockfile.
rec DepSpec {
    alias:   str;
    url:     str;
    ref:     str;
    commit:  str;
    managed: bool;
}

# dep_sync: sync every declared dependency for the project in the current
# directory. thin wrapper over sync_project.
fun dep_sync(quiet: bool) i64 {
    ret sync_project(".", quiet);
}

# sync_project: clone or update every declared dependency for the project rooted
# at `root` into `<root>/<dir_dep>/<alias>/`, checking out each dep's ref
# (honouring the lockfile when present), and rewrite `<root>/mach.lock` with the
# resolved commits.
# ---
# root:  project directory holding mach.toml ("." for the current directory)
# quiet: when true, suppress mach's own informational summaries (the per-dep
#        sync lines and the lockfile status); errors are always reported
# ret:   0 on success, 1 on a user error, 2 on an internal error
pub fun sync_project(root: str, quiet: bool) i64 {
    var alloc: Allocator;
    val mk: Option[str] = page.make(?alloc);
    if (is_some[str](mk)) {
        print.eprint("error: failed to initialise allocator\n");
        ret 2;
    }

    val manifest_r: Result[str, str] = join2(?alloc, root, MANIFEST);
    if (is_err[str, str](manifest_r)) {
        print.eprint("error: out of memory\n");
        ret 2;
    }
    val manifest_path: str = unwrap_ok[str, str](manifest_r);

    val text_r: Result[str, str] = fs.read_all(?alloc, manifest_path);
    if (is_err[str, str](text_r)) {
        print.eprint("error: no mach.toml in the project directory\n");
        ret 1;
    }
    var mt: toml.Table;
    val tab_r: Result[toml.Table, str] = toml.parse(?alloc, unwrap_ok[str, str](text_r));
    if (is_err[toml.Table, str](tab_r)) {
        print.eprint("error: failed to parse mach.toml: ");
        print.eprint(unwrap_err[toml.Table, str](tab_r));
        print.eprint("\n");
        ret 1;
    }
    mt = unwrap_ok[toml.Table, str](tab_r);

    val deps: *toml.Table = toml.get_table(?mt, "deps");
    if (deps == nil || toml.table_len(deps) == 0) {
        if (!quiet) { print.print("no dependencies to sync\n"); }
        ret 0;
    }
    val count: usize = toml.table_len(deps);

    val git_r: Result[str, str] = find_on_path(?alloc, "git");
    if (is_err[str, str](git_r)) {
        print.eprint("error: git not found on PATH\n");
        ret 2;
    }
    val git: str = unwrap_ok[str, str](git_r);

    val env_r: Result[**u8, str] = build_env(?alloc);
    if (is_err[**u8, str](env_r)) {
        print.eprint("error: failed to build child environment\n");
        ret 2;
    }
    val env: **u8 = unwrap_ok[**u8, str](env_r);

    val dep_root_r: Result[str, str] = resolve_dep_root(?alloc, root, ?mt);
    if (is_err[str, str](dep_root_r)) {
        print.eprint("error: out of memory\n");
        ret 2;
    }
    val dep_root: str = unwrap_ok[str, str](dep_root_r);

    val lock_r: Result[str, str] = join2(?alloc, root, LOCKFILE);
    if (is_err[str, str](lock_r)) {
        print.eprint("error: out of memory\n");
        ret 2;
    }
    val lock_path: str = unwrap_ok[str, str](lock_r);

    # read the existing lockfile (if any) so declared refs can be pinned.
    var lock_deps: *toml.Table = nil;
    var lock_tab: toml.Table;
    val lock_text_r: Result[str, str] = fs.read_all(?alloc, lock_path);
    if (is_ok[str, str](lock_text_r)) {
        val lr: Result[toml.Table, str] = toml.parse(?alloc, unwrap_ok[str, str](lock_text_r));
        if (is_ok[toml.Table, str](lr)) {
            lock_tab = unwrap_ok[toml.Table, str](lr);
            lock_deps = toml.get_table(?lock_tab, "deps");
        }
    }

    val r_specs: Result[*DepSpec, str] = allocate[DepSpec](?alloc, count);
    if (is_err[*DepSpec, str](r_specs)) {
        print.eprint("error: out of memory\n");
        ret 2;
    }
    val specs: *DepSpec = unwrap_ok[*DepSpec, str](r_specs);

    var i: usize = 0;
    for (i < count) {
        val alias_v: str = toml.table_key(deps, i);
        val v: *toml.Value = toml.table_value(deps, i);
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            print.eprint("error: [deps.");
            print.eprint(alias_v);
            print.eprint("] is not a table\n");
            ret 1;
        }
        val sub: *toml.Table = ?v.data.table;
        val url_v: str = dep_url(sub);
        if (str_empty(url_v)) {
            print.eprint("error: [deps.");
            print.eprint(alias_v);
            print.eprint("] has no git url (set 'url' or 'source')\n");
            ret 1;
        }
        val ref_v: str = dep_ref(sub);

        val alias: str = own(?alloc, alias_v);
        val url:   str = own(?alloc, url_v);
        val ref:   str = own(?alloc, ref_v);

        # a hand-vendored tree or submodule (a directory we did not clone) is
        # left untouched for backward compatibility.
        val dir_r: Result[str, str] = join2(?alloc, dep_root, alias::*u8);
        if (is_err[str, str](dir_r)) {
            print.eprint("error: out of memory\n");
            ret 2;
        }
        val dir: str = unwrap_ok[str, str](dir_r);
        if (fs.exists(dir) && !is_managed_clone(?alloc, dir)) {
            specs[i] = DepSpec{alias: alias, url: url, ref: ref, commit: "", managed: false};
            if (!quiet) {
                print.print("vendored ");
                print.print(alias);
                print.print(" (skipped)\n");
            }
            i = i + 1;
            cnt;
        }

        # a lockfile commit for this alias pins the checkout for reproducibility.
        var checkout: str = ref;
        val pinned: str = lock_commit(lock_deps, alias::*u8);
        if (!str_empty(pinned)) { checkout = own(?alloc, pinned); }

        val sr: Result[str, str] = fetch_dep(?alloc, git, env, dep_root, dir, url, checkout);
        if (is_err[str, str](sr)) {
            print.eprint("error: failed to sync '");
            print.eprint(alias);
            print.eprint("': ");
            print.eprint(unwrap_err[str, str](sr));
            print.eprint("\n");
            ret 2;
        }
        val commit: str = unwrap_ok[str, str](sr);
        specs[i] = DepSpec{alias: alias, url: url, ref: ref, commit: commit, managed: true};

        if (!quiet) {
            print.print("synced ");
            print.print(alias);
            print.print(" @ ");
            print.print(commit);
            print.print("\n");
        }
        i = i + 1;
    }

    val lw: Result[bool, str] = write_lock(?alloc, specs, count, lock_path);
    if (is_err[bool, str](lw)) {
        print.eprint("error: failed to write mach.lock: ");
        print.eprint(unwrap_err[bool, str](lw));
        print.eprint("\n");
        ret 2;
    }
    if (!quiet) {
        if (unwrap_ok[bool, str](lw)) { print.print("wrote mach.lock\n"); }
        or                           { print.print("mach.lock up to date\n"); }
    }
    ret 0;
}

# lock_commit: look up the recorded commit for `alias` in the lockfile's deps
# table, returning an empty view if absent.
fun lock_commit(lock_deps: *toml.Table, alias: *u8) str {
    if (lock_deps == nil) { ret ""; }
    val count: usize = toml.table_len(lock_deps);
    var i: usize = 0;
    for (i < count) {
        if (str_equals(toml.table_key(lock_deps, i), alias::str)) {
            val v: *toml.Value = toml.table_value(lock_deps, i);
            if (v != nil && v.tag == toml.TYPE_TABLE) {
                ret toml.get_str(?v.data.table, "commit");
            }
        }
        i = i + 1;
    }
    ret "";
}

# is_managed_clone: true if `<dir>/.git` is itself a directory — i.e. a plain
# clone `sync` created. a submodule's `.git` is a file and a hand-vendored tree
# has no `.git`, so both read as unmanaged and are left alone.
fun is_managed_clone(alloc: *Allocator, dir: str) bool {
    val git_dir_r: Result[str, str] = join2(alloc, dir, ".git");
    if (is_err[str, str](git_dir_r)) { ret false; }
    ret fs.is_dir(unwrap_ok[str, str](git_dir_r));
}

# fetch_dep: ensure `<dir>` is a git checkout of `url` at `ref`, then return the
# resolved commit SHA (an owned null-terminated copy). clones when absent, then
# checks out the ref as a detached HEAD so `.git/HEAD` holds the raw commit.
fun fetch_dep(alloc: *Allocator, git: str, env: **u8, dep_root: str, dir: str, url: str, ref: str) Result[str, str] {
    val is_repo: bool = is_managed_clone(alloc, dir);

    if (!is_repo) {
        fs.create_dir_all(alloc, dep_root, 0o755);

        var ca: [4]usize;
        ca[0] = "clone"::usize;
        ca[1] = url::usize;
        ca[2] = dir::usize;
        ca[3] = 0;
        val cl: Result[bool, str] = run_git(git, env, (?ca[0])::**u8);
        if (is_err[bool, str](cl)) { ret err[str, str]("git clone failed"); }
    }
    or {
        # refresh remotes so a moved branch or new tag resolves.
        var fa: [5]usize;
        fa[0] = "-C"::usize;
        fa[1] = dir::usize;
        fa[2] = "fetch"::usize;
        fa[3] = "--all"::usize;
        fa[4] = 0;
        run_git(git, env, (?fa[0])::**u8);
    }

    val cor: Result[bool, str] = git_checkout(alloc, git, env, dir, ref);
    if (is_err[bool, str](cor)) { ret err[str, str]("git checkout failed"); }

    ret read_head_sha(alloc, dir);
}

# git_checkout: detach HEAD onto the commit named by `ref`. an immutable commit
# SHA or an explicit `tag/<n>` / `branch/<n>` form checks out directly; a bare
# ref tries the remote-tracking branch `origin/<ref>` first (so a moved branch
# resolves to its current tip) and falls back to the literal ref for tags and
# commits.
fun git_checkout(alloc: *Allocator, git: str, env: **u8, dir: str, ref: str) Result[bool, str] {
    if (str_empty(ref)) { ret git_checkout_one(git, env, dir, "origin/HEAD"); }

    if (str_starts_with(ref, "branch/")) {
        ret git_checkout_one(git, env, dir, with_prefix(alloc, "origin/", drop_prefix(ref, 7)));
    }
    if (str_starts_with(ref, "tag/")) {
        ret git_checkout_one(git, env, dir, drop_prefix(ref, 4));
    }
    if (is_hex_sha(ref)) {
        ret git_checkout_one(git, env, dir, ref);
    }

    # bare ref: prefer the remote-tracking branch (so a moved branch resolves to
    # its tip), else the literal ref for a tag or commit.
    val remote_ref: str = with_prefix(alloc, "refs/remotes/origin/", ref);
    if (git_ref_exists(git, env, dir, remote_ref)) {
        ret git_checkout_one(git, env, dir, with_prefix(alloc, "origin/", ref));
    }
    ret git_checkout_one(git, env, dir, ref);
}

# git_ref_exists: true if the fully-qualified `ref` resolves, probed silently via
# `git show-ref --verify --quiet <ref>` (no stdout, exit code only).
fun git_ref_exists(git: str, env: **u8, dir: str, ref: str) bool {
    var sr: [7]usize;
    sr[0] = "-C"::usize;
    sr[1] = dir::usize;
    sr[2] = "show-ref"::usize;
    sr[3] = "--verify"::usize;
    sr[4] = "--quiet"::usize;
    sr[5] = ref::usize;
    sr[6] = 0;
    ret is_ok[bool, str](run_git(git, env, (?sr[0])::**u8));
}

# git_checkout_one: `git -C <dir> checkout --detach <committish>`.
fun git_checkout_one(git: str, env: **u8, dir: str, committish: str) Result[bool, str] {
    var co: [6]usize;
    co[0] = "-C"::usize;
    co[1] = dir::usize;
    co[2] = "checkout"::usize;
    co[3] = "--detach"::usize;
    co[4] = committish::usize;
    co[5] = 0;
    ret run_git(git, env, (?co[0])::**u8);
}

# drop_prefix: a view of `s` advanced past its first `n` bytes.
fun drop_prefix(s: str, n: usize) str {
    ret (s::usize + n)::str;
}

# with_prefix: an owned copy of `prefix` followed by `s`.
fun with_prefix(alloc: *Allocator, prefix: *u8, s: str) str {
    val plen: usize = util.slen(prefix);
    val slen2: usize = str_len(s);
    val r: Result[*u8, str] = allocate[u8](alloc, plen + slen2 + 1);
    if (is_err[*u8, str](r)) { ret s; }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put(buf, 0, prefix);
    k = put_n(buf, k, s::*u8, slen2);
    buf[k] = 0;
    ret buf::str;
}

# is_hex_sha: true if `s` is a 7-to-40 char run of hex digits — a commit SHA.
fun is_hex_sha(s: str) bool {
    val n: usize = str_len(s);
    if (n < 7 || n > 40) { ret false; }
    var i: usize = 0;
    for (i < n) {
        val c: u8 = s[i];
        val is_digit: bool = c >= '0' && c <= '9';
        val is_lower: bool = c >= 'a' && c <= 'f';
        val is_upper: bool = c >= 'A' && c <= 'F';
        if (!is_digit && !is_lower && !is_upper) { ret false; }
        i = i + 1;
    }
    ret true;
}

# run_git: spawn git (program path `git`) with a null-terminated argument
# vector `rest` (the trailing args after the program name), wait for it, and map
# a non-zero exit or spawn failure to an error.
fun run_git(git: str, env: **u8, rest: **u8) Result[bool, str] {
    # count the trailing args.
    var n: usize = 0;
    for (rest[n]::usize != 0) { n = n + 1; }

    # build argv = [git, rest..., nil].
    var alloc: Allocator;
    val mk: Option[str] = page.make(?alloc);
    if (is_some[str](mk)) { ret err[bool, str]("allocator init failed"); }
    val r: Result[*usize, str] = allocate[usize](?alloc, n + 2);
    if (is_err[*usize, str](r)) { ret err[bool, str](unwrap_err[*usize, str](r)); }
    val argv: *usize = unwrap_ok[*usize, str](r);
    argv[0] = git::usize;
    var i: usize = 0;
    for (i < n) { argv[i + 1] = rest[i]::usize; i = i + 1; }
    argv[n + 1] = 0;

    val rr: Result[exec.ExitStatus, str] = exec.run(git, (?argv[0])::**u8, env);
    if (is_err[exec.ExitStatus, str](rr)) { ret err[bool, str]("spawn failed"); }
    val s: exec.ExitStatus = unwrap_ok[exec.ExitStatus, str](rr);
    if (!exec.exited(s) || exec.code(s) != 0) { ret err[bool, str]("git exited non-zero"); }
    ret ok[bool, str](true);
}

# remove_tree: delete a directory tree by shelling to `rm -rf`. resolution and
# vendoring already depend on a working `rm`/`git` on PATH; reusing the system
# tool avoids a hand-rolled recursive unlink.
fun remove_tree(alloc: *Allocator, dir: str) {
    val rm_r: Result[str, str] = find_on_path(alloc, "rm");
    if (is_err[str, str](rm_r)) { ret; }
    val rm: str = unwrap_ok[str, str](rm_r);
    val env_r: Result[**u8, str] = build_env(alloc);
    if (is_err[**u8, str](env_r)) { ret; }
    val env: **u8 = unwrap_ok[**u8, str](env_r);

    var argv: [4]usize;
    argv[0] = rm::usize;
    argv[1] = "-rf"::usize;
    argv[2] = dir::usize;
    argv[3] = 0;
    exec.run(rm, (?argv[0])::**u8, env);
}

# read_head_sha: read `<dir>/.git/HEAD`, which after a detached checkout holds
# the raw 40-char commit SHA, and return an owned trimmed copy.
fun read_head_sha(alloc: *Allocator, dir: str) Result[str, str] {
    val head_r: Result[str, str] = join3(alloc, dir, ".git", "HEAD");
    if (is_err[str, str](head_r)) { ret head_r; }
    val head_path: str = unwrap_ok[str, str](head_r);

    val text_r: Result[str, str] = fs.read_all(alloc, head_path);
    if (is_err[str, str](text_r)) { ret text_r; }
    val text: str = unwrap_ok[str, str](text_r);

    var n: usize = str_len(text);
    for (n > 0 && (text[n - 1] == '\n' || text[n - 1] == '\r' || text[n - 1] == ' ')) {
        n = n - 1;
    }
    val r: Result[*u8, str] = allocate[u8](alloc, n + 1);
    if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    k_copy(buf, text, n);
    buf[n] = 0;
    ret ok[str, str](buf::str);
}

# k_copy: copy `n` bytes from a `str` into buf.
fun k_copy(buf: *u8, src: str, n: usize) {
    var i: usize = 0;
    for (i < n) { buf[i] = src[i]; i = i + 1; }
}

# managed_entry_size: the exact byte count one managed dep serializes to in the
# lockfile, derived from the same SEG_* literals write_lock emits. summing this
# over the managed deps yields the precise buffer size — no hand-counted
# literal lengths to fall out of sync with the emission (#1258).
fun managed_entry_size(spec: *DepSpec) usize {
    ret util.slen(SEG_OPEN)   + str_len(spec.alias)
      + util.slen(SEG_URL)    + str_len(spec.url)
      + util.slen(SEG_REF)    + str_len(spec.ref)
      + util.slen(SEG_COMMIT) + str_len(spec.commit)
      + util.slen(SEG_CLOSE);
}

# write_lock: write the `mach.lock` at `lock_path` recording each dep's url,
# ref, and resolved commit. the lockfile is TOML so the existing parser reads it
# back on the next sync. returns whether a write occurred — false when the
# existing lockfile already matches byte-for-byte, leaving its mtime untouched.
fun write_lock(alloc: *Allocator, specs: *DepSpec, count: usize, lock_path: str) Result[bool, str] {
    val head: *u8 = "# generated by `mach dep sync`; do not edit by hand.\nversion = 1\n";
    var total: usize = util.slen(head);
    var i: usize = 0;
    for (i < count) {
        if (specs[i].managed) { total = total + managed_entry_size(?specs[i]); }
        i = i + 1;
    }

    val r: Result[*u8, str] = allocate[u8](alloc, total + 1);
    if (is_err[*u8, str](r)) { ret err[bool, str](unwrap_err[*u8, str](r)); }
    val buf: *u8 = unwrap_ok[*u8, str](r);

    var k: usize = put(buf, 0, head);
    i = 0;
    for (i < count) {
        if (specs[i].managed) {
            k = put(buf, k, SEG_OPEN);
            k = put_n(buf, k, specs[i].alias::*u8, str_len(specs[i].alias));
            k = put(buf, k, SEG_URL);
            k = put_n(buf, k, specs[i].url::*u8, str_len(specs[i].url));
            k = put(buf, k, SEG_REF);
            k = put_n(buf, k, specs[i].ref::*u8, str_len(specs[i].ref));
            k = put(buf, k, SEG_COMMIT);
            k = put_n(buf, k, specs[i].commit::*u8, str_len(specs[i].commit));
            k = put(buf, k, SEG_CLOSE);
        }
        i = i + 1;
    }
    buf[k] = 0;

    # skip the write when the on-disk lockfile already matches, avoiding mtime churn.
    val cur_r: Result[str, str] = fs.read_all(alloc, lock_path);
    if (is_ok[str, str](cur_r)) {
        val cur: str = unwrap_ok[str, str](cur_r);
        if (str_equals(cur, buf::str)) { ret ok[bool, str](false); }
    }

    val wr: Result[bool, str] = fs.write_file(lock_path, buf, k, 0o644);
    if (is_err[bool, str](wr)) { ret wr; }
    ret ok[bool, str](true);
}

# find_on_path: resolve an absolute path to `name` by scanning the `PATH`
# environment variable. `os.spawn` uses execve with no PATH search, so a
# concrete path is required.
fun find_on_path(alloc: *Allocator, name: *u8) Result[str, str] {
    var path_buf: [4096]u8;
    val pl: i64 = os.getenv("PATH", ?path_buf[0], 4096);
    if (pl <= 0) { ret err[str, str]("PATH unset"); }
    val plen: usize = pl::usize;
    val nlen: usize = util.slen(name);

    var i: usize = 0;
    for (i < plen) {
        val start: usize = i;
        for (i < plen && path_buf[i] != ':'::u8) { i = i + 1; }
        val end: usize = i;
        if (i < plen) { i = i + 1; }
        if (end == start) { cnt; }

        val seg_len: usize = end - start;
        val cand_len: usize = seg_len + 1 + nlen;
        val r: Result[*u8, str] = allocate[u8](alloc, cand_len + 1);
        if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
        val cand: *u8 = unwrap_ok[*u8, str](r);
        var k: usize = 0;
        var j: usize = start;
        for (j < end) { cand[k] = path_buf[j]; k = k + 1; j = j + 1; }
        cand[k] = '/'::u8; k = k + 1;
        k = put_n(cand, k, name, nlen);
        cand[k] = 0;

        if (fs.is_file(cand::str)) { ret ok[str, str](cand::str); }
        deallocate[u8](alloc, cand, cand_len + 1);
    }
    ret err[str, str]("not found on PATH");
}

# ENV_COUNT: the number of allowlisted environment variables forwarded to git.
val ENV_COUNT: usize = 21;

# env_key: the name of the i-th forwarded environment variable. git's https/ssh
# transports need PATH and HOME at minimum; the rest cover credential helpers,
# custom CA bundles, proxies, and SSH agents so non-default setups still work.
# this is an explicit allowlist, not a fallback: the runtime exposes no handle
# to the raw inherited environ, so the child env is reconstructed from getenv.
fun env_key(i: usize) *u8 {
    if (i == 0)  { ret "PATH"; }
    if (i == 1)  { ret "HOME"; }
    if (i == 2)  { ret "USER"; }
    if (i == 3)  { ret "SSH_AUTH_SOCK"; }
    if (i == 4)  { ret "GIT_SSH"; }
    if (i == 5)  { ret "GIT_SSH_COMMAND"; }
    if (i == 6)  { ret "GIT_ASKPASS"; }
    if (i == 7)  { ret "GIT_CONFIG_GLOBAL"; }
    if (i == 8)  { ret "GIT_TERMINAL_PROMPT"; }
    if (i == 9)  { ret "XDG_CONFIG_HOME"; }
    if (i == 10) { ret "SSL_CERT_FILE"; }
    if (i == 11) { ret "SSL_CERT_DIR"; }
    if (i == 12) { ret "GIT_SSL_CAINFO"; }
    if (i == 13) { ret "HTTP_PROXY"; }
    if (i == 14) { ret "HTTPS_PROXY"; }
    if (i == 15) { ret "http_proxy"; }
    if (i == 16) { ret "https_proxy"; }
    if (i == 17) { ret "ALL_PROXY"; }
    if (i == 18) { ret "all_proxy"; }
    if (i == 19) { ret "NO_PROXY"; }
    ret "no_proxy";
}

# build_env: reconstruct a null-terminated envp for git from the allowlisted
# variables present in the parent environment.
fun build_env(alloc: *Allocator) Result[**u8, str] {
    val r_arr: Result[*usize, str] = allocate[usize](alloc, ENV_COUNT + 1);
    if (is_err[*usize, str](r_arr)) { ret err[**u8, str](unwrap_err[*usize, str](r_arr)); }
    val arr: *usize = unwrap_ok[*usize, str](r_arr);

    var count: usize = 0;
    var i: usize = 0;
    for (i < ENV_COUNT) {
        val name: *u8 = env_key(i);
        var vbuf: [4096]u8;
        val vl: i64 = os.getenv(name, ?vbuf[0], 4096);
        if (vl >= 0) {
            val nlen: usize = util.slen(name);
            val vlen: usize = vl::usize;
            val elen: usize = nlen + 1 + vlen;
            val re: Result[*u8, str] = allocate[u8](alloc, elen + 1);
            if (is_err[*u8, str](re)) { ret err[**u8, str](unwrap_err[*u8, str](re)); }
            val e: *u8 = unwrap_ok[*u8, str](re);
            var k: usize = put(e, 0, name);
            e[k] = '='::u8; k = k + 1;
            var j: usize = 0;
            for (j < vlen) { e[k] = vbuf[j]; k = k + 1; j = j + 1; }
            e[k] = 0;
            arr[count] = e::usize;
            count = count + 1;
        }
        i = i + 1;
    }
    arr[count] = 0;
    ret ok[**u8, str]((?arr[0])::**u8);
}

# dep_dir_name: the project's dep-dir name from a parsed manifest `mt`,
# defaulting to "dep" — the single source of truth for the dep-dir convention.
fun dep_dir_name(mt: *toml.Table) str {
    val d: str = toml.get_str(mt, "project.dir_dep");
    if (str_empty(d)) { ret "dep"; }
    ret d;
}

# resolve_dep_root: the project's dependency root, `<root>/<dir_dep>`, from its
# parsed manifest `mt`. root-aware so every dep entry point — sync, add,
# remove — resolves the dep tree through one path.
fun resolve_dep_root(alloc: *Allocator, root: str, mt: *toml.Table) Result[str, str] {
    ret join2(alloc, root, dep_dir_name(mt)::*u8);
}

# dep_path: the vendored directory `<dir_dep>/<alias>/` for a dependency of the
# project in the current directory, read through the shared resolution path.
fun dep_path(alloc: *Allocator, alias: *u8) Result[str, str] {
    val text_r: Result[str, str] = fs.read_all(alloc, MANIFEST::str);
    if (is_err[str, str](text_r)) { ret err[str, str](unwrap_err[str, str](text_r)); }
    val tab_r: Result[toml.Table, str] = toml.parse(alloc, unwrap_ok[str, str](text_r));
    if (is_err[toml.Table, str](tab_r)) { ret err[str, str](unwrap_err[toml.Table, str](tab_r)); }
    var t: toml.Table = unwrap_ok[toml.Table, str](tab_r);
    val root_r: Result[str, str] = resolve_dep_root(alloc, ".", ?t);
    if (is_err[str, str](root_r)) { ret root_r; }
    ret join2(alloc, unwrap_ok[str, str](root_r), alias);
}

# own: duplicate a borrowed `str` view into an owned null-terminated copy,
# returning an empty owned string on allocation failure.
fun own(alloc: *Allocator, s: str) str {
    val r: Result[str, str] = str_dup(alloc, s);
    if (is_err[str, str](r)) { ret ""; }
    ret unwrap_ok[str, str](r);
}

# join2: join `a` and `b` with a single '/', as an owned null-terminated path.
fun join2(alloc: *Allocator, a: str, b: *u8) Result[str, str] {
    val a_len: usize = str_len(a);
    val b_len: usize = util.slen(b);
    val total: usize = a_len + 1 + b_len;
    val r: Result[*u8, str] = allocate[u8](alloc, total + 1);
    if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = put_n(buf, 0, a::*u8, a_len);
    if (k > 0 && buf[k - 1] != '/'::u8) { buf[k] = '/'::u8; k = k + 1; }
    k = put_n(buf, k, b, b_len);
    buf[k] = 0;
    ret ok[str, str](buf::str);
}

# join3: join three components with '/' separators.
fun join3(alloc: *Allocator, a: str, b: *u8, c: *u8) Result[str, str] {
    val ab_r: Result[str, str] = join2(alloc, a, b);
    if (is_err[str, str](ab_r)) { ret ab_r; }
    val ab: str = unwrap_ok[str, str](ab_r);
    ret join2(alloc, ab, c);
}

test "dep: managed_entry_size matches the serialized lock entry length (#1258)" {
    # the size estimate must equal the bytes write_lock emits for one entry, or
    # the buffer under-allocates and overflows. the pre-fix arithmetic counted
    # 37 fixed bytes per entry where the emission writes 39.
    val expected: str = "\n[deps.std]\nurl = \"u\"\nref = \"r\"\ncommit = \"c\"\n";
    var spec: DepSpec;
    spec.alias  = "std";
    spec.url    = "u";
    spec.ref    = "r";
    spec.commit = "c";
    spec.managed = true;
    if (managed_entry_size(?spec) != str_len(expected)) { ret 1; }
    ret 0;
}

test "dep: write_lock round-trips several managed deps without overflow (#1258)" {
    var alloc: Allocator;
    if (is_some[str](page.make(?alloc))) { ret 1; }

    var specs: [2]DepSpec;
    specs[0].alias = "a";   specs[0].url = "ua";   specs[0].ref = "ra";   specs[0].commit = "ca";   specs[0].managed = true;
    specs[1].alias = "bee"; specs[1].url = "ubee"; specs[1].ref = "rbee"; specs[1].commit = "cbee"; specs[1].managed = true;

    val path: str = "/tmp/.mach_test_lock_1258";
    val wr: Result[bool, str] = write_lock(?alloc, ?specs[0], 2, path);
    if (is_err[bool, str](wr)) { ret 1; }

    val rr: Result[str, str] = fs.read_all(?alloc, path);
    if (is_err[str, str](rr)) { ret 1; }
    val got: str = unwrap_ok[str, str](rr);

    val want: str = "# generated by `mach dep sync`; do not edit by hand.\nversion = 1\n\n[deps.a]\nurl = \"ua\"\nref = \"ra\"\ncommit = \"ca\"\n\n[deps.bee]\nurl = \"ubee\"\nref = \"rbee\"\ncommit = \"cbee\"\n";
    if (!str_equals(got, want)) { ret 1; }
    ret 0;
}
