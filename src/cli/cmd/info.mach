# `mach info` - at-a-glance compiler identity and capabilities
#
# Prints, on one screen and line-oriented for scripts, the compiler version,
# the host (os/arch) this binary was built for, and the registered capability
# surface: the instruction sets, operating systems, ABIs, and object formats
# this binary can compose into a target. It needs no project. The version and
# host fold at compile time, and the capability surface is read from a
# locally-owned target registry after a registration pass.
#
# `mach info --version` is the one-line version alias for tooling: the version
# string alone. `mach info targets` prints the supported target-tuple matrix -
# one `<os>-<isa>` per line - derived from the registered vtables' joint
# capability declarations, never a curated list. Exit codes: 0 on success, 2 on
# an internal failure.

use std.print;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;

use O: std.types.option;
use R: std.types.result;

use mach.cli.args;
use mach.cli.util;
use mach.lang.target;
use mach.lang.target.abi;
use mach.lang.target.isa;
use mach.lang.target.of;
use mach.lang.target.os;

# the compiler version string, folded from the project manifest at compile time
val MACH_VERSION: str = $project.version;

# `mach info` subcommand entry point
#
# With `--version` prints the version string alone; with `targets` prints the
# supported target-tuple matrix; otherwise prints the full
# identity-and-capabilities screen.
# ---
# argc:  argument count including argv[0]
# argv:  the argument vector (argc null-terminated byte pointers)
# marks: consumption record parallel to argv, for the unknown-flag rejector
# ret:   0 on success, 1 on an unknown flag, 2 on an internal failure
pub fun run(argc: usize, argv: **u8, marks: *bool) i64 {
    # `--version` is the only flag; `targets` is a bare verb. mark the INFO table,
    # then reject any other flag token before the verb is read.
    args.mark_flags(marks, argc, argv, ?args.INFO[0], args.INFO_N);
    if (util.flag_reject_unknown(argc, argv, marks, 2, "mach info")) { ret 1; }

    if (argc >= 3 && str_equals(argv[2]::str, "--version")) {
        print.println(MACH_VERSION);
        ret 0;
    }

    # registration needs no interner: each vtable names itself with an immutable
    # str constant, read directly for the capability surface below.
    var reg: target.TargetRegistry = target.registry_init();
    val res_register_all: R.Result[bool, str] = target.register_all(?reg);
    if (R.is_err[bool, str](res_register_all)) {
        print.eprint("error: ");
        print.eprintln(R.unwrap_err[bool, str](res_register_all));
        ret 2;
    }

    # `mach info targets` prints the supported target-tuple matrix, one `<os>-<isa>`
    # per line, derived from the registered vtables' joint capability declarations.
    if (argc >= 3 && str_equals(argv[2]::str, "targets")) {
        print_targets(?reg);
        ret 0;
    }

    print.print("mach ");
    print.println(MACH_VERSION);

    # the host os/arch fold at compile time to the target this binary was built for.
    print.print("host: ");
    print.print(host_os_name());
    print.print("/");
    print.println(host_arch_name());

    print_capabilities(?reg);
    ret 0;
}

# the operating-system name of the host this binary was built for
#
# The `$mach.build.os == $mach.os.*` comparison folds at compile time to the
# active build's os, so this resolves with no runtime branch. The final arm is
# dead for every supported os and exists only for totality.
# ---
# ret: the host os name ("linux", "darwin", or "windows")
fun host_os_name() str {
    $if ($mach.build.os == $mach.os.linux)   { ret "linux"; }
    $or ($mach.build.os == $mach.os.darwin)  { ret "darwin"; }
    $or ($mach.build.os == $mach.os.windows) { ret "windows"; }
    $or                                      { ret "unknown"; }
}

# the architecture name of the host this binary was built for
#
# Folds at compile time like host_os_name; the final arm is dead for every
# supported architecture and exists only for totality.
# ---
# ret: the host architecture name ("x86_64", "aarch64", or "riscv64")
fun host_arch_name() str {
    $if ($mach.build.arch == $mach.arch.x86_64)  { ret "x86_64"; }
    $or ($mach.build.arch == $mach.arch.aarch64) { ret "aarch64"; }
    $or ($mach.build.arch == $mach.arch.riscv64) { ret "riscv64"; }
    $or                                          { ret "unknown"; }
}

# emit the four registry lines (isa / os / abi / object) from `reg`
# ---
# reg: the fully registered target registry to read
fun print_capabilities(reg: *target.TargetRegistry) {
    print_isa(?reg.isa);
    print_os(?reg.os);
    print_abi(?reg.abi);
    print_of(?reg.of);
}

# list the registered instruction sets in `reg` on one `isa:` line
# ---
# reg: the isa registry to enumerate
fun print_isa(reg: *isa.IsaRegistry) {
    print.print("isa:");
    var i:   u32 = 0;
    val len: u32 = isa.registered_count(reg);
    for (i < len) {
        val vt: *isa.IsaVTable = O.unwrap[*isa.IsaVTable](isa.registered(reg, i));
        print.print(" ");
        print.print(vt.name);
        i = i + 1;
    }
    print.print("\n");
}

# list the registered operating systems in `reg` on one `os:` line
# ---
# reg: the os registry to enumerate
fun print_os(reg: *os.OsRegistry) {
    print.print("os:");
    var i:   u32 = 0;
    val len: u32 = os.registered_count(reg);
    for (i < len) {
        val vt: *os.OsVTable = O.unwrap[*os.OsVTable](os.registered(reg, i));
        print.print(" ");
        print.print(vt.name);
        i = i + 1;
    }
    print.print("\n");
}

# list the registered calling conventions in `reg` on one `abi:` line
# ---
# reg: the abi registry to enumerate
fun print_abi(reg: *abi.AbiRegistry) {
    print.print("abi:");
    var i:   u32 = 0;
    val len: u32 = abi.registered_count(reg);
    for (i < len) {
        val vt: *abi.AbiVTable = O.unwrap[*abi.AbiVTable](abi.registered(reg, i));
        print.print(" ");
        print.print(vt.name);
        i = i + 1;
    }
    print.print("\n");
}

# list the registered object formats in `reg` on one `object:` line
# ---
# reg: the object-format registry to enumerate
fun print_of(reg: *of.OfRegistry) {
    print.print("object:");
    var i:   u32 = 0;
    val len: u32 = of.registered_count(reg);
    for (i < len) {
        val vt: *of.OfVTable = O.unwrap[*of.OfVTable](of.registered(reg, i));
        print.print(" ");
        print.print(vt.name);
        i = i + 1;
    }
    print.print("\n");
}

# print the supported target-tuple matrix, one `<os>-<isa>` per line
#
# Derives the matrix from the registered vtables: a `<os>-<isa>` tuple is supported
# when the compiler can emit it end-to-end through some registered (abi, of), which
# `target.tuple_capability` answers with TUPLE_OK. Nothing is curated - a new target
# vtable whose declarations line up appears here with no change to this command -
# and the names are the vtables' own, printed verbatim.
# ---
# reg: the fully registered target registry to read
fun print_targets(reg: *target.TargetRegistry) {
    var oi:     u32 = 0;
    val os_len: u32 = os.registered_count(?reg.os);
    for (oi < os_len) {
        val os_vt: *os.OsVTable = O.unwrap[*os.OsVTable](os.registered(?reg.os, oi));
        var ii:      u32 = 0;
        val isa_len: u32 = isa.registered_count(?reg.isa);
        for (ii < isa_len) {
            val isa_vt: *isa.IsaVTable = O.unwrap[*isa.IsaVTable](isa.registered(?reg.isa, ii));
            if (os_isa_supported(reg, os_vt, isa_vt)) {
                print.print(os_vt.name);
                print.print("-");
                print.print(isa_vt.name);
                print.print("\n");
            }
            ii = ii + 1;
        }
        oi = oi + 1;
    }
}

# whether some registered (abi, of) makes the `<os>-<isa>` tuple emittable
# end-to-end, per `target.tuple_capability`
#
# The display matrix keys on `<os>-<isa>`, so a cell is present when any calling
# convention and object format compose an emittable full tuple - the exact
# predicate `target.select_of` enforces for one named tuple.
# ---
# reg:    the fully registered target registry
# os_vt:  the operating-system vtable under test
# isa_vt: the instruction-set vtable under test
# ret:    true when some (abi, of) yields a supported tuple
fun os_isa_supported(reg: *target.TargetRegistry, os_vt: *os.OsVTable, isa_vt: *isa.IsaVTable) bool {
    var fi:     u32 = 0;
    val of_len: u32 = of.registered_count(?reg.of);
    for (fi < of_len) {
        val of_vt: *of.OfVTable = O.unwrap[*of.OfVTable](of.registered(?reg.of, fi));
        var ai:      u32 = 0;
        val abi_len: u32 = abi.registered_count(?reg.abi);
        for (ai < abi_len) {
            val abi_vt: *abi.AbiVTable = O.unwrap[*abi.AbiVTable](abi.registered(?reg.abi, ai));
            if (target.tuple_capability(os_vt, isa_vt, abi_vt, of_vt) == target.TUPLE_OK) { ret true; }
            ai = ai + 1;
        }
        fi = fi + 1;
    }
    ret false;
}
