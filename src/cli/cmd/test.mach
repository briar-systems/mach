# mach.cli.cmd.test: `mach test` — builds the test binary and runs the collected tests.
#
# builds the project with the test-runner entry point and runs the
# collected tests, surfacing the runner's exit code (0 = all passed, 1 =
# any failed, 2 = build/internal error). the runner stub iterates every
# test declaration the resolver collected; this command forwards `--filter
# <pattern>` and `--list` to it as the child argv so the runner can select
# or enumerate tests itself.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.is_err;
use std.types.result.unwrap_ok;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;

use page: std.allocator.page;

use os:   std.system.os;
use exec: std.process.exec;

use build: mach.cli.cmd.build;

# eq: byte-wise equality of two null-terminated `*u8` strings.
# ---
# a:   first null-terminated byte string
# b:   second null-terminated byte string
# ret: true if both reach the terminator at the same position with matching bytes
fun eq(a: *u8, b: *u8) bool {
    if (a == b)               { ret true; }
    if (a == nil || b == nil) { ret false; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}

# slen: length in bytes of a null-terminated `*u8` string.
# ---
# s:   null-terminated byte string
# ret: number of bytes before the terminator (0 for nil)
fun slen(s: *u8) usize {
    if (s == nil) { ret 0; }
    var n: usize = 0;
    for (s[n] != 0) { n = n + 1; }
    ret n;
}

# emit: write a null-terminated `*u8` string to stderr.
# ---
# s: null-terminated byte string to write
fun emit(s: *u8) {
    os.write(os.STDERR_FD, s, slen(s));
}

# get_value: returns the argument following `flag` in argv, or none.
fun get_value(argc: usize, argv: **u8, flag: *u8) Option[*u8] {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) {
            if (i + 1 < argc) { ret some[*u8](argv[i + 1]); }
            ret none[*u8]();
        }
        i = i + 1;
    }
    ret none[*u8]();
}

# has_flag: returns true if argv contains an exact match for `flag`.
fun has_flag(argc: usize, argv: **u8, flag: *u8) bool {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# run: `mach test` subcommand entry point. builds the test binary, then
# execs it forwarding `--filter`/`--list` so the runner selects tests.
# called by cmd.dispatch.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  0 if all tests passed, 1 if any failed, 2 on a build/internal error
pub fun run(argc: usize, argv: **u8) i64 {
    val filter_opt: Option[*u8] = get_value(argc, argv, "--filter");
    val list:       bool        = has_flag(argc, argv, "--list");

    var alloc: Allocator;
    val mk: Option[str] = page.make(?alloc);
    if (is_some[str](mk)) {
        emit("error: failed to initialise allocator\n");
        ret 2;
    }

    val br: build.BuildResult = build.build(?alloc, argc, argv, false);
    if (br.code != 0) {
        ret 2;
    }
    if (br.output_path == nil) {
        emit("error: build produced no test binary\n");
        ret 2;
    }

    # child argv: [binary, ("--list")?, ("--filter" pattern)?, nil]
    var extra: usize = 0;
    if (list)                       { extra = extra + 1; }
    if (is_some[*u8](filter_opt))   { extra = extra + 2; }

    val total: usize = 1 + extra + 1;
    val cv_r: Result[**u8, str] = allocate[*u8](?alloc, total);
    if (is_err[**u8, str](cv_r)) {
        deallocate[u8](?alloc, br.output_path, (slen(br.output_path) + 1));
        emit("error: out of memory\n");
        ret 2;
    }
    val child_argv: **u8 = unwrap_ok[**u8, str](cv_r);
    var k: usize = 0;
    child_argv[k] = br.output_path; k = k + 1;
    if (list) { child_argv[k] = "--list"; k = k + 1; }
    if (is_some[*u8](filter_opt)) {
        child_argv[k] = "--filter"; k = k + 1;
        child_argv[k] = unwrap[*u8](filter_opt); k = k + 1;
    }
    child_argv[k] = nil;

    val exec_r: Result[exec.ExitStatus, str] = exec.run(br.output_path, child_argv, nil);
    deallocate[*u8](?alloc, child_argv, total);
    deallocate[u8](?alloc, br.output_path, (slen(br.output_path) + 1));

    if (is_err[exec.ExitStatus, str](exec_r)) {
        emit("error: failed to execute the test binary\n");
        ret 2;
    }
    val status: exec.ExitStatus = unwrap_ok[exec.ExitStatus, str](exec_r);
    if (exec.exited(status)) {
        ret exec.code(status)::i64;
    }
    ret 1;
}
