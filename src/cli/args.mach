use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

# mach.cli.args: argument parsing utilities.
# ---
# provides helpers for parsing command-line arguments.

# Args: wrapper around argc/argv for easier argument access.
# ---
# argc: number of arguments
# argv: argument vector
pub rec Args {
    argc: i64;
    argv: &&u8;
}

# Create an Args wrapper from argc/argv.
# ---
# argc: argument count
# argv: argument vector
# ret:  Args wrapper
pub fun init(argc: i64, argv: &&u8) Args {
    ret Args { argc: argc, argv: argv };
}

# Get the number of arguments.
# ---
# ret: argument count
pub fun (this: Args) count() i64 {
    ret this.argc;
}

# Get an argument at the specified index.
# ---
# index: zero-based argument index
# ret:   argument string or none if out of bounds
pub fun (this: Args) get(index: i64) Option[str] {
    if (index < 0 || index >= this.argc) {
        ret none[str]();
    }
    ret some[str](this.argv[index]);
}

# Check if the argument at index equals the given string.
# ---
# index: argument index
# value: string to compare against
# ret:   true if equal, false otherwise
pub fun (this: Args) eq(index: i64, value: str) bool {
    val arg: Option[str] = this.get(index);
    if (arg.is_none()) {
        ret false;
    }
    ret arg.unwrap().equals(value);
}

# Check if an argument exists at the given index.
# ---
# index: argument index to check
# ret:   true if index is valid, false otherwise
pub fun (this: Args) has(index: i64) bool {
    ret index >= 0 && index < this.argc;
}

# Find the index of the first occurrence of a flag.
# ---
# flag: flag string to search for (e.g. "-o", "--target")
# ret:  index if found, or none if not found
pub fun (this: Args) find_flag(flag: str) Option[i64] {
    var i: i64 = 0;
    for (i < this.argc) {
        val arg: str = this.argv[i];
        if (arg.equals(flag)) {
            ret some[i64](i);
        }
        i = i + 1;
    }
    ret none[i64]();
}

# Get the value following a flag (e.g. "-o output.bin" returns "output.bin").
# ---
# flag: flag string to search for
# ret:  value following the flag, or none if flag not found or no value follows
pub fun (this: Args) get_flag_value(flag: str) Option[str] {
    val idx: Option[i64] = this.find_flag(flag);
    if (idx.is_none()) {
        ret none[str]();
    }

    val value_idx: i64 = idx.unwrap() + 1;
    if (value_idx >= this.argc) {
        ret none[str]();
    }

    ret some[str](this.argv[value_idx]);
}

# Check if a flag is present anywhere in the arguments.
# ---
# flag: flag string to search for
# ret:  true if flag is present, false otherwise
pub fun (this: Args) has_flag(flag: str) bool {
    ret this.find_flag(flag).is_some();
}

# Skip the first n arguments and return a new Args.
# ---
# n:   number of arguments to skip
# ret: new Args with first n arguments removed
pub fun (this: Args) skip(n: i64) Args {
    if (n >= this.argc) {
        ret Args { argc: 0, argv: this.argv };
    }
    val new_argc: i64 = this.argc - n;
    val new_argv: &&u8 = (this.argv::usize + (n::usize * $size_of(&u8)))::&&u8;
    ret Args { argc: new_argc, argv: new_argv };
}
