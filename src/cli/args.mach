# the parsed command line shared across subcommands
#
# centralises the cross-cutting settings every subcommand respects in the same
# way - verbosity, emission toggles, and target/profile selection - so each
# command's `run` does not reimplement the same flag handling. `parse` reads
# these flags out of the raw argv via the `util` helpers and leaves every
# per-subcommand flag in place for the subcommand to consume itself. verbosity
# (`-v`/`-vv`) and `quiet` are mutually exclusive: passing both is a parse error
# that yields an error message.

use std.collections.vector;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.build.request;
use mach.cli.util;
use mach.lang.manifest;

# the parsed-command-line record and the link-token path classifier live with
# the compose seam in `mach.lang.build.request`; re-exported here so every
# subcommand keeps spelling them `args.CliArgs` / `args.is_object_path`.
fwd request.CliArgs;
fwd request.is_object_path;

# one command-line flag: its spelling, whether it consumes a following value,
# and its one-line help text
#
# A command declares its accepted flags as a `FlagSpec` table; one shared parser
# walks the table to mark consumption and reject unknown flags, and `mach help`
# renders the same table, so help and behaviour cannot disagree.
# ---
# name:      the exact flag token to match (e.g. "--target", "-O0")
# has_value: the flag consumes the following token as its value
# doc:       one-line help text rendered under `mach help`
pub rec FlagSpec {
    name:      str;
    has_value: bool;
    doc:       str;
}

# selection flags: which target/profile/artifact/output a build resolves. shared
# by build/run/test/doc (cross-cutting; read by `parse`).
pub val SEL_N: usize = 5;
pub val SEL: [SEL_N]FlagSpec = [SEL_N]FlagSpec{
    FlagSpec{ name: "--target",  has_value: true, doc: "select a [target.<name>] entry" },
    FlagSpec{ name: "--profile", has_value: true, doc: "select a build profile (debug / release / ...)" },
    FlagSpec{ name: "-o",        has_value: true, doc: "override the linked-binary path (build/run/test)" },
    FlagSpec{ name: "--bin",     has_value: true, doc: "narrow the build to one [bin.<name>] artifact" },
    FlagSpec{ name: "--lib",     has_value: true, doc: "narrow the build to one [lib.<name>] artifact" },
};

# readout flags: verbosity and quiet. shared by build/run/test/doc.
pub val RDO_N: usize = 4;
pub val RDO: [RDO_N]FlagSpec = [RDO_N]FlagSpec{
    FlagSpec{ name: "-v",      has_value: false, doc: "verbose readout: build phase timing, or per-test lines under `mach test`" },
    FlagSpec{ name: "-vv",     has_value: false, doc: "-v plus per-module / per-file (or passing-test) detail" },
    FlagSpec{ name: "--quiet", has_value: false, doc: "suppress non-error output (mutually exclusive with -v / -vv)" },
    FlagSpec{ name: "-q",      has_value: false, doc: "alias for --quiet" },
};

# codegen flags: emission and codegen posture. shared by build/run/test/doc.
pub val CGEN_N: usize = 6;
pub val CGEN: [CGEN_N]FlagSpec = [CGEN_N]FlagSpec{
    FlagSpec{ name: "--all-targets", has_value: false, doc: "build every declared target rather than the manifest default" },
    FlagSpec{ name: "--pie",         has_value: false, doc: "emit a position-independent (ET_DYN) executable" },
    FlagSpec{ name: "-g",            has_value: false, doc: "emit debug info for this build (overrides the profile's debug key)" },
    FlagSpec{ name: "--emit-asm",    has_value: false, doc: "emit per-module .s assembly text beside each object" },
    FlagSpec{ name: "--emit-ir",     has_value: false, doc: "emit per-module .ir SSA text beside each object" },
    FlagSpec{ name: "--verify-ir",   has_value: false, doc: "run the IR verifier after each optimisation pass" },
};

# optimization level: an explicit `-O` override. build/run/test accept it (run
# as a no-op, since it does not build).
pub val OPT_N: usize = 3;
pub val OPT: [OPT_N]FlagSpec = [OPT_N]FlagSpec{
    FlagSpec{ name: "-O0", has_value: false, doc: "force the debug pipeline (overrides the profile)" },
    FlagSpec{ name: "-O1", has_value: false, doc: "select the release pipeline" },
    FlagSpec{ name: "-O2", has_value: false, doc: "select the release pipeline" },
};

# emission-target flag: `mach build` honours it; `mach test` accepts it for
# command-line compatibility as a no-op (its help documents that in prose).
pub val EMIT_N: usize = 1;
pub val EMIT: [EMIT_N]FlagSpec = [EMIT_N]FlagSpec{
    FlagSpec{ name: "--emit", has_value: true, doc: "obj | exe (default exe; obj stops at the objects)" },
};

# codegen worker-count flag as `mach build` documents it; `mach test` renders
# its own `--jobs` row (the one value also sizes the test-process pool there).
pub val JOBS_N: usize = 1;
pub val JOBS: [JOBS_N]FlagSpec = [JOBS_N]FlagSpec{
    FlagSpec{ name: "--jobs", has_value: true, doc: "codegen worker threads (default: host CPUs; 1 serialises)" },
};

# link-input flags, shared by build and test (both link).
pub val LINKIN_N: usize = 2;
pub val LINKIN: [LINKIN_N]FlagSpec = [LINKIN_N]FlagSpec{
    FlagSpec{ name: "-L", has_value: true, doc: "add a search directory for -l inputs; repeatable" },
    FlagSpec{ name: "-l", has_value: true, doc: "link a named object, archive, or shared library; repeatable" },
};

# `mach build`-only flags.
pub val BUILD_OWN_N: usize = 1;
pub val BUILD_OWN: [BUILD_OWN_N]FlagSpec = [BUILD_OWN_N]FlagSpec{
    FlagSpec{ name: "--explain", has_value: false, doc: "print the resolved build plan and exit without building" },
};

# `mach run`-only flags.
pub val RUN_OWN_N: usize = 1;
pub val RUN_OWN: [RUN_OWN_N]FlagSpec = [RUN_OWN_N]FlagSpec{
    FlagSpec{ name: "--runner", has_value: true, doc: "execute the binary as '<cmd> <binary> <args...>'; a command name or path resolved on PATH (e.g. wine for a foreign target)" },
};

# `mach test`-only flags.
pub val TEST_OWN_N: usize = 6;
pub val TEST_OWN: [TEST_OWN_N]FlagSpec = [TEST_OWN_N]FlagSpec{
    FlagSpec{ name: "--jobs",         has_value: true,  doc: "run up to <n> test processes at once, and size the build's codegen workers (default: host CPUs; 1 serialises)" },
    FlagSpec{ name: "--filter",       has_value: true,  doc: "run only tests whose name contains <substr>" },
    FlagSpec{ name: "--include-deps", has_value: false, doc: "also run tests declared in dependency modules" },
    FlagSpec{ name: "--list",         has_value: false, doc: "list the collected tests and exit" },
    FlagSpec{ name: "--format",       has_value: true,  doc: "human (default) or json NDJSON event stream" },
    FlagSpec{ name: "--runner",       has_value: true,  doc: "launch every test as '<cmd> <exe> <idx>'; a command name or path resolved on PATH (e.g. wine for a foreign target)" },
};

# `mach doc`-only flags.
pub val DOC_OWN_N: usize = 1;
pub val DOC_OWN: [DOC_OWN_N]FlagSpec = [DOC_OWN_N]FlagSpec{
    FlagSpec{ name: "--out", has_value: true, doc: "output directory, rooted at the project (default: doc/api)" },
};

# `mach init` flags.
pub val INIT_N: usize = 5;
pub val INIT: [INIT_N]FlagSpec = [INIT_N]FlagSpec{
    FlagSpec{ name: "--name",  has_value: true,  doc: "project id (default: the directory name)" },
    FlagSpec{ name: "--force", has_value: false, doc: "scaffold even when mach.toml / src already exist" },
    FlagSpec{ name: "--lib",   has_value: false, doc: "library project layout (default: binary)" },
    FlagSpec{ name: "--quiet", has_value: false, doc: "suppress non-error output" },
    FlagSpec{ name: "-q",      has_value: false, doc: "alias for --quiet" },
};

# `mach info` flags.
pub val INFO_N: usize = 1;
pub val INFO: [INFO_N]FlagSpec = [INFO_N]FlagSpec{
    FlagSpec{ name: "--version", has_value: false, doc: "print the version string alone, on one line" },
};

# `--quiet` / `-q`, marked by every `mach dep` action.
pub val QUIET_N: usize = 2;
pub val QUIET: [QUIET_N]FlagSpec = [QUIET_N]FlagSpec{
    FlagSpec{ name: "--quiet", has_value: false, doc: "suppress routine output" },
    FlagSpec{ name: "-q",      has_value: false, doc: "alias for --quiet" },
};

# `mach dep add` flags.
pub val DEP_ADD_N: usize = 3;
pub val DEP_ADD: [DEP_ADD_N]FlagSpec = [DEP_ADD_N]FlagSpec{
    FlagSpec{ name: "--git",  has_value: true, doc: "git url source" },
    FlagSpec{ name: "--path", has_value: true, doc: "local path source" },
    FlagSpec{ name: "--ref",  has_value: true, doc: "git ref (branch/<n>, tag/<n>, commit/<n>)" },
};

# `mach dep remove` flags.
pub val DEP_REMOVE_N: usize = 1;
pub val DEP_REMOVE: [DEP_REMOVE_N]FlagSpec = [DEP_REMOVE_N]FlagSpec{
    FlagSpec{ name: "--purge", has_value: false, doc: "also delete the dependency directory" },
};

# `mach dep update` flags.
pub val DEP_UPDATE_N: usize = 1;
pub val DEP_UPDATE: [DEP_UPDATE_N]FlagSpec = [DEP_UPDATE_N]FlagSpec{
    FlagSpec{ name: "--all", has_value: false, doc: "update every declared dependency" },
};

# mark every occurrence of each flag in `table` (and its following value, for a
# has_value flag) into `marks`, so the unknown-flag rejector treats them consumed
#
# The one shared table walker: a command applies the tables it accepts, replacing
# the per-command hand-wired `flag_mark`/`flag_mark_value` choreography. Marking a
# flag is consuming it (see `util.flag_mark`), so this both registers the flag for
# rejection and, for a value flag, claims the value token.
# ---
# marks: consumption record parallel to argv
# argc:  number of arguments to scan (the caller clips at `--`)
# argv:  argument vector (argc null-terminated byte pointers)
# table: the flag table to apply
# n:     number of entries in `table`
pub fun mark_flags(marks: *bool, argc: usize, argv: **u8, table: *FlagSpec, n: usize) {
    var i: usize = 0;
    for (i < n) {
        if (table[i].has_value) { util.flag_mark_value(marks, argc, argv, table[i].name); }
        or                      { util.flag_mark(marks, argc, argv, table[i].name); }
        i = i + 1;
    }
}

# mark the cross-cutting flags (selection, readout, codegen) shared by
# build/run/test/doc, the set `parse` reads
#
# Replaces the marking half of the old `parse(..., marks)`: `parse` now only reads
# these flags' values, and this claims them for the rejector from the same tables
# that document them.
# ---
# marks: consumption record parallel to argv
# argc:  number of arguments to scan (the caller clips at `--`)
# argv:  argument vector (argc null-terminated byte pointers)
pub fun mark_cross(marks: *bool, argc: usize, argv: **u8) {
    mark_flags(marks, argc, argv, ?SEL[0],  SEL_N);
    mark_flags(marks, argc, argv, ?RDO[0],  RDO_N);
    mark_flags(marks, argc, argv, ?CGEN[0], CGEN_N);
}

# read the cross-cutting flags out of `argv` and produce a populated CliArgs
#
# Reads only; the shared table walker (`mark_cross`) claims these flags for the
# rejector from the `SEL`/`RDO`/`CGEN` tables, so this needs no consumption
# record. Per-subcommand flags are left in argv for the subcommand to consume.
# Returns a specific error message on a parse error so the caller can tell the
# user which flag was wrong: a verbosity flag (`-v`/`-vv`) combined with
# `--quiet`.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  the populated CliArgs, or a message naming the offending flag
pub fun parse(argc: usize, argv: **u8) R.Result[request.CliArgs, str] {
    var c: request.CliArgs;

    # `-vv` is two levels of detail, `-v` one; the highest present wins.
    var verbosity: u8 = 0;
    if (util.flag_exists(argc, argv, "-v"))  { verbosity = 1; }
    if (util.flag_exists(argc, argv, "-vv")) { verbosity = 2; }
    val quiet: bool = util.flag_exists(argc, argv, "--quiet") || util.flag_exists(argc, argv, "-q");
    if (verbosity > 0 && quiet) {
        ret R.err[request.CliArgs, str]("`-v`/`-vv` and `--quiet`/`-q` cannot be combined");
    }

    c.verbosity   = verbosity;
    c.quiet       = quiet;
    c.verify_ir   = util.flag_exists(argc, argv, "--verify-ir");
    c.emit_asm    = util.flag_exists(argc, argv, "--emit-asm");
    c.emit_ir     = util.flag_exists(argc, argv, "--emit-ir");
    c.all_targets = util.flag_exists(argc, argv, "--all-targets");
    c.pie         = util.flag_exists(argc, argv, "--pie");
    c.g           = util.flag_exists(argc, argv, "-g");

    c.target    = flag_value_get(nil, argc, argv, "--target");
    c.output    = flag_value_get(nil, argc, argv, "-o");
    c.profile   = flag_value_get(nil, argc, argv, "--profile");
    c.bin       = flag_value_get(nil, argc, argv, "--bin");
    c.lib       = flag_value_get(nil, argc, argv, "--lib");

    # the build-flow captures (collect_build) start empty: only a build/test
    # command fills them, after its full flag set is marked.
    c.opt_set      = false;
    c.opt_release  = false;
    c.jobs         = nil;
    c.include_deps = false;
    c.link_tokens.a    = nil;
    c.link_tokens.data = nil;
    c.link_tokens.len  = 0;
    c.link_tokens.cap  = 0;
    c.lib_dirs.a    = nil;
    c.lib_dirs.data = nil;
    c.lib_dirs.len  = 0;
    c.lib_dirs.cap  = 0;

    ret R.ok[request.CliArgs, str](c);
}

# capture the build-flow values out of `argv` into `c`, after every flag is marked
#
# The second half of the argv boundary: `parse` reads the cross-cutting flags up
# front; this runs once the command's full flag set is marked and rejection has
# passed, because the link-token scan classifies exactly the unmarked non-flag
# tokens (a marked value - `--filter foo.o` - must never read as a link input).
# Captures the `-O<n>` level (first of `-O0`/`-O1`/`-O2` wins), the raw `--jobs`
# value, `--include-deps`, the `-L` directories, and the link tokens (`-l`
# values and bare object/archive path positionals) in invocation order. The
# project-path positional is stepped over. Beyond this call, argv is dead to the
# build flow: everything downstream reads the composed request.
# ---
# a:     allocator backing the captured vectors
# c:     the CliArgs to fill
# argc:  argument count including argv[0]
# argv:  the argument vector (argc null-terminated byte pointers)
# marks: consumption record parallel to argv, fully populated by the command
# ret:   ok(true), or an allocation error
pub fun collect_build(a: *A.Allocator, c: *request.CliArgs, argc: usize, argv: **u8, marks: *bool) R.Result[bool, str] {
    if (util.flag_exists(argc, argv, "-O0"))      { c.opt_set = true; c.opt_release = false; }
    or (util.flag_exists(argc, argv, "-O1"))      { c.opt_set = true; c.opt_release = true; }
    or (util.flag_exists(argc, argv, "-O2"))      { c.opt_set = true; c.opt_release = true; }

    c.jobs = flag_value_get(nil, argc, argv, "--jobs");
    c.include_deps = util.flag_exists(argc, argv, "--include-deps");

    c.link_tokens = vector.init[*u8](a);
    c.lib_dirs    = vector.init[*u8](a);

    val proj_ix: usize = util.arg_index_positional(argc, argv, marks, 2);
    var i: usize = 0;
    for (i < argc) {
        val tok: *u8 = argv[i];
        if (str_equals(tok::str, "-L") && i + 1 < argc) {
            val dr: R.Result[usize, str] = vector.push[*u8](?c.lib_dirs, argv[i + 1]);
            if (R.is_err[usize, str](dr)) { ret R.err[bool, str](R.unwrap_err[usize, str](dr)); }
            i = i + 2;
            cnt;
        }
        if (str_equals(tok::str, "-l") && i + 1 < argc) {
            val lr: R.Result[usize, str] = vector.push[*u8](?c.link_tokens, argv[i + 1]);
            if (R.is_err[usize, str](lr)) { ret R.err[bool, str](R.unwrap_err[usize, str](lr)); }
            i = i + 2;
            cnt;
        }
        if (marks[i]) { i = i + 1; cnt; }
        if (i > 1 && i != proj_ix && tok != nil && tok[0] != '-' && request.is_object_path(tok)) {
            val pr: R.Result[usize, str] = vector.push[*u8](?c.link_tokens, tok);
            if (R.is_err[usize, str](pr)) { ret R.err[bool, str](R.unwrap_err[usize, str](pr)); }
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# the value following `flag` in `argv`, or nil when the flag is absent or has
# no following argument
#
# Collapses the get/some/unwrap dance every `*u8` flag in `parse` shares; the
# nil sentinel matches the CliArgs fields' "flag not given" convention. Records the
# flag and its value into `marks` (when non-nil) for the unknown-flag rejector.
# ---
# marks: consumption record parallel to argv, or nil to only read
# argc:  argument count including argv[0]
# argv:  the argument vector (argc null-terminated byte pointers)
# flag:  the flag whose value to read
# ret:   the value pointer, or nil when the flag is not present
fun flag_value_get(marks: *bool, argc: usize, argv: **u8, flag: *u8) *u8 {
    val opt_value: O.Option[*u8] = util.flag_mark_value(marks, argc, argv, flag);
    if (O.is_none[*u8](opt_value)) { ret nil; }
    ret O.unwrap[*u8](opt_value);
}

# resolve the selected profile name from the parsed command line
#
# `--profile <name>` selects the profile; absent it, the empty string defers to
# the manifest default.
# ---
# config: the parsed command line
# ret:    the selected profile name, empty for the manifest default
fun profile_selection(config: *request.CliArgs) str {
    var profile_name: *u8 = config.profile;
    if (profile_name == nil) { profile_name = ""; }
    ret profile_name;
}

# build the manifest selection from the parsed command line
#
# Maps `--target`/`--profile`/`--bin`/`--lib` onto `out_sel`, shared by
# `mach build`, `mach run`, and `mach test` so every command narrows the
# (target, profile, artifact) the same way. An absent `--target` leaves the
# target empty so the driver defers to `[project].target` (resolving
# `native`/`host` to the host-matching entry). `--bin` and `--lib` are
# mutually exclusive.
# ---
# config:  the parsed command line
# out_sel: receives the populated selection
# ret:     ok(true), or err when `--bin` and `--lib` are combined
pub fun selection_from_config(config: *request.CliArgs, out_sel: *manifest.Selection) R.Result[bool, str] {
    if (config.bin != nil && config.lib != nil) {
        ret R.err[bool, str]("--bin and --lib cannot be combined");
    }
    var target_name: *u8 = config.target;
    if (target_name == nil) { target_name = ""; }
    var artifact_name: *u8  = "";
    var want_lib:      bool = false;
    var has_artifact:  bool = false;
    if (config.bin != nil) { artifact_name = config.bin; has_artifact = true; }
    or (config.lib != nil) { artifact_name = config.lib; want_lib = true; has_artifact = true; }
    out_sel.profile      = profile_selection(config);
    out_sel.target       = target_name;
    out_sel.artifact     = artifact_name;
    out_sel.want_lib     = want_lib;
    out_sel.has_artifact = has_artifact;
    ret R.ok[bool, str](true);
}

# the removed pre-flag-day flags (#1999) appear in no flag table, so the
# unknown-flag rejector reports them, while --emit-ir stays recognized (CGEN)
# and -O2 stays recognized (OPT) - the table walk is the accepted-flag set
test "mach.cli.config.parse:removed_flags_rejected" {
    var a:  [4]*u8;
    a[0] = "mach"; a[1] = "build"; a[3] = ".";
    var ma: [4]bool;

    # each removed flag is in no build table and so reported as unknown.
    var removed: [3]*u8;
    removed[0] = "--release"; removed[1] = "--no-emit-ir"; removed[2] = "--no-emit-asm";
    var r: usize = 0;
    for (r < 3) {
        a[2] = removed[r];
        var i: usize = 0;
        for (i < 4) { ma[i] = false; i = i + 1; }
        if (R.is_err[request.CliArgs, str](parse(4, ?a[0])))              { ret 1; }
        mark_cross(?ma[0], 4, ?a[0]);
        mark_flags(?ma[0], 4, ?a[0], ?OPT[0], OPT_N);
        mark_flags(?ma[0], 4, ?a[0], ?EMIT[0], EMIT_N);
        mark_flags(?ma[0], 4, ?a[0], ?JOBS[0], JOBS_N);
        mark_flags(?ma[0], 4, ?a[0], ?LINKIN[0], LINKIN_N);
        mark_flags(?ma[0], 4, ?a[0], ?BUILD_OWN[0], BUILD_OWN_N);
        if (!util.flag_reject_unknown(4, ?a[0], ?ma[0], 2, "mach build")) { ret 1; }
        r = r + 1;
    }

    # --emit-ir (CGEN) and -O2 (OPT) are recognized: their tables mark them, so
    # the rejector accepts them.
    var recognized: [2]*u8;
    recognized[0] = "--emit-ir"; recognized[1] = "-O2";
    var k: usize = 0;
    for (k < 2) {
        a[2] = recognized[k];
        var j: usize = 0;
        for (j < 4) { ma[j] = false; j = j + 1; }
        if (R.is_err[request.CliArgs, str](parse(4, ?a[0])))             { ret 1; }
        mark_cross(?ma[0], 4, ?a[0]);
        mark_flags(?ma[0], 4, ?a[0], ?OPT[0], OPT_N);
        if (util.flag_reject_unknown(4, ?a[0], ?ma[0], 2, "mach build")) { ret 1; }
        k = k + 1;
    }
    ret 0;
}

# the table walker marks each present flag from a table and, for a value flag,
# its following token; a bare positional and argv[0..1] stay unmarked
test "mach.cli.args.mark_flags:marks_table_and_values" {
    var a: [6]*u8;
    a[0] = "mach"; a[1] = "build"; a[2] = "--target"; a[3] = "linux";
    a[4] = "--pie"; a[5] = ".";
    var m: [6]bool;
    var i: usize = 0;
    for (i < 6) { m[i] = false; i = i + 1; }

    mark_cross(?m[0], 6, ?a[0]);

    if (!m[2] || !m[3]) { ret 1; }   # --target (SEL, value) marks flag + value
    if (!m[4])          { ret 1; }   # --pie (CGEN, bool) marks the flag
    if (m[5])           { ret 1; }   # the "." positional stays unmarked
    if (m[0] || m[1])   { ret 1; }   # argv[0..1] stay unmarked
    ret 0;
}
