# mach.cli.args: minimal command-line argument inspection.
#
# no allocation and no parse framework — just direct scans over the raw
# `argv` vector for exact flag matches and the value that follows a flag.
# `--flag=value` and combined short flags are intentionally not recognized.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;

# eq: byte-wise equality of two null-terminated `*u8` strings.
# ---
# a:   first null-terminated byte string
# b:   second null-terminated byte string
# ret: true if both reach the terminator at the same position with matching bytes
fun eq(a: *u8, b: *u8) bool {
    if (a == b)               { ret true; }
    if (a == nil || b == nil) { ret false; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}

# has_flag: returns true if argv contains an exact match for the given flag.
# ---
# argc: the number of arguments
# argv: the argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  true if the flag appears in argv
pub fun has_flag(argc: usize, argv: **u8, flag: *u8) bool {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) {
            ret true;
        }
        i = i + 1;
    }

    ret false;
}

# get_value: returns the argument following the given flag, if present.
# ---
# argc: the number of arguments
# argv: the argument vector (argc null-terminated byte pointers)
# flag: the flag to search for
# ret:  some(next arg) when the flag is found and followed by a value, else none
pub fun get_value(argc: usize, argv: **u8, flag: *u8) Option[*u8] {
    var i: usize = 0;
    for (i < argc) {
        if (eq(argv[i], flag)) {
            if (i + 1 < argc) {
                ret some[*u8](argv[i + 1]);
            }
            ret none[*u8]();
        }
        i = i + 1;
    }

    ret none[*u8]();
}
