# Helper module for cross-module testing.
# Tests in imports.mach will use these to verify `use` and `pub` work correctly.

pub fun add(a: i64, b: i64) i64 {
    ret a + b;
}

pub fun mul(a: i64, b: i64) i64 {
    ret a * b;
}

pub fun negate(x: i64) i64 {
    ret 0 - x;
}

pub val CONSTANT: i64 = 42;

pub rec Point {
    x: i64;
    y: i64;
}

pub fun make_point(x: i64, y: i64) Point {
    ret Point { x: x, y: y };
}

pub fun (p: *Point) sum() i64 {
    ret p.x + p.y;
}

# not public - should not be visible outside this module
fun private_fn() i64 {
    ret 999;
}

val PRIVATE_CONST: i64 = 123;
