# Control flow tests for conditionals and loops.

test "control: if/or chain chooses first branch" {
    var x: i64 = 5;
    var y: i64 = 0;

    if (x == 5) {
        y = 1;
    }
    or (x == 6) {
        y = 2;
    }
    or {
        y = 3;
    }

    if (y != 1) { ret 0; }
    ret 1;
}

test "control: if/or chain chooses middle branch" {
    var x: i64 = 6;
    var y: i64 = 0;

    if (x == 5) {
        y = 1;
    }
    or (x == 6) {
        y = 2;
    }
    or {
        y = 3;
    }

    if (y != 2) { ret 0; }
    ret 1;
}

test "control: if/or chain chooses else branch" {
    var x: i64 = 7;
    var y: i64 = 0;

    if (x == 5) {
        y = 1;
    }
    or (x == 6) {
        y = 2;
    }
    or {
        y = 3;
    }

    if (y != 3) { ret 0; }
    ret 1;
}

test "control: loop increments and breaks" {
    var i: i64 = 0;
    var sum: i64 = 0;

    for (i < 10) {
        i = i + 1;
        if (i == 7) {
            brk;
        }
        sum = sum + i;
    }

    if (sum != 21) { ret 0; }
    ret 1;
}

test "control: continue skips work" {
    var i: i64 = 0;
    var sum: i64 = 0;

    for (i < 6) {
        i = i + 1;
        if (i % 2 == 0) {
            cnt;
        }
        sum = sum + i;
    }

    if (sum != 9) { ret 0; }
    ret 1;
}

test "control: early return exits test" {
    var x: i64 = 1;
    if (x == 1) {
        if (x != 1) { ret 0; }
        ret 1;
    }
    ret 0;
}

test "control: nested loops update counters" {
    var outer: i64 = 0;
    var inner: i64 = 0;
    var sum: i64 = 0;

    for (outer < 3) {
        outer = outer + 1;
        inner = 0;
        for (inner < 2) {
            inner = inner + 1;
            sum = sum + 1;
        }
    }

    if (sum != 6) { ret 0; }
    ret 1;
}

# --- Break in nested loops ---

test "control: break inner loop only" {
    var count: i64 = 0;
    var i: i64 = 0;
    for (i < 3) {
        var j: i64 = 0;
        for (j < 10) {
            if (j == 2) {
                brk;
            }
            count = count + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    if (count != 6) { ret 0; }
    ret 1;
}

test "control: break outer loop with flag" {
    var count: i64 = 0;
    var done: u8 = 0;
    var i: i64 = 0;
    for (i < 10) {
        if (done == 1) {
            brk;
        }
        var j: i64 = 0;
        for (j < 10) {
            count = count + 1;
            if (count == 15) {
                done = 1;
                brk;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    if (count != 15) { ret 0; }
    ret 1;
}

# --- Deeply nested conditionals ---

test "control: deeply nested if statements" {
    var x: i64 = 5;
    var result: i64 = 0;
    if (x > 0) {
        if (x > 3) {
            if (x > 4) {
                result = 1;
            }
        }
    }
    if (result != 1) { ret 0; }
    ret 1;
}

test "control: nested if with multiple paths" {
    var x: i64 = 5;
    var y: i64 = 10;
    var result: i64 = 0;
    if (x > 0) {
        if (y > 5) {
            if (x + y > 10) {
                result = 1;
            }
            or {
                result = 2;
            }
        }
        or {
            result = 3;
        }
    }
    or {
        result = 4;
    }
    if (result != 1) { ret 0; }
    ret 1;
}

test "control: five levels deep" {
    var a: i64 = 1;
    var b: i64 = 2;
    var c: i64 = 3;
    var d: i64 = 4;
    var e: i64 = 5;
    var result: i64 = 0;
    if (a == 1) {
        if (b == 2) {
            if (c == 3) {
                if (d == 4) {
                    if (e == 5) {
                        result = 100;
                    }
                }
            }
        }
    }
    if (result != 100) { ret 0; }
    ret 1;
}

# --- Loop with complex conditions ---

test "control: loop with compound exit" {
    var i: i64 = 0;
    var found: u8 = 0;
    for (i < 100) {
        if (i == 42) {
            found = 1;
            brk;
        }
        i = i + 1;
    }
    if (found != 1) { ret 0; }
    ret 1;
}

test "control: nested loops sum" {
    var sum: i64 = 0;
    var i: i64 = 0;
    for (i < 5) {
        var j: i64 = 0;
        for (j < 5) {
            sum = sum + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    if (sum != 25) { ret 0; }
    ret 1;
}

# --- Multiple return paths ---

fun classify(x: i64) i64 {
    if (x < 0) {
        ret 0 - 1;
    }
    if (x == 0) {
        ret 0;
    }
    ret 1;
}

test "control: multiple return negative" {
    if (classify(0 - 5) != (0 - 1)) { ret 0; }
    ret 1;
}

test "control: multiple return zero" {
    if (classify(0) != 0) { ret 0; }
    ret 1;
}

test "control: multiple return positive" {
    if (classify(5) != 1) { ret 0; }
    ret 1;
}
