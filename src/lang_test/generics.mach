# Generic function and pointer edge case tests.

rec Wrap[T] {
    value: T;
}

fun make_wrap[T](value: T) Wrap[T] {
    var w: Wrap[T];
    w.value = value;
    ret w;
}

fun wrap_get[T](this: Wrap[T]) T {
    ret this.value;
}

fun wrap_set[T](this: *Wrap[T], value: T) {
    this.value = value;
}

fun identity[T](value: T) T {
    ret value;
}

fun add_pair[T](a: T, b: T) T {
    ret a + b;
}

fun swap[T](a: T, b: T) Wrap[T] {
    var w: Wrap[T];
    w.value = a;
    ret w;
}

fun take_ptr[T](p: *T) i64 {
    if (p == nil) { ret 0; }
    ret 1;
}

fun ptr_roundtrip[T](p: *T) *T {
    val raw: ptr = p::ptr;
    ret raw::*T;
}

fun pass_ptr_to_generic[T](p: *T) i64 {
    val q: *T = ptr_roundtrip[T](p);
    if (q != p) { ret 0; }
    ret 1;
}

rec Pair[T, U] {
    left:  T;
    right: U;
}

fun make_pair[T, U](a: T, b: U) Pair[T, U] {
    var p: Pair[T, U];
    p.left = a;
    p.right = b;
    ret p;
}

fun pair_left_val[T, U](this: Pair[T, U]) T {
    ret this.left;
}

fun pair_right_val[T, U](this: Pair[T, U]) U {
    ret this.right;
}

test "generics: identity for i64" {
    val x: i64 = 123;
    if (identity[i64](x) != x) { ret 0; }
    ret 1;
}

test "generics: identity for u64" {
    val x: u64 = 999;
    if (identity[u64](x) != x) { ret 0; }
    ret 1;
}

test "generics: identity for ptr" {
    var x: i64 = 7;
    val p: ptr = (?x)::ptr;
    if (identity[ptr](p) != p) { ret 0; }
    ret 1;
}

test "generics: add_pair for i64" {
    val sum: i64 = add_pair[i64](10, 20);
    if (sum != 30) { ret 0; }
    ret 1;
}

test "generics: wrap get returns value" {
    val w: Wrap[i64] = make_wrap[i64](55);
    if (wrap_get[i64](w) != 55) { ret 0; }
    ret 1;
}

test "generics: wrap pointer set updates value" {
    var w: Wrap[i64] = make_wrap[i64](1);
    wrap_set[i64](?w, 99);
    if (wrap_get[i64](w) != 99) { ret 0; }
    ret 1;
}

test "generics: pass record pointer to generic function" {
    var w: Wrap[i64] = make_wrap[i64](5);
    ret take_ptr[Wrap[i64]](?w);
}

test "generics: pointer roundtrip preserves address" {
    var x: i64 = 12;
    val p: *i64 = ?x;
    val q: *i64 = ptr_roundtrip[i64](p);
    if (q != p) { ret 0; }
    ret 1;
}

test "generics: pass record pointer through generic pipeline" {
    var w: Wrap[i64] = make_wrap[i64](8);
    ret pass_ptr_to_generic[Wrap[i64]](?w);
}

test "generics: pair fields preserve types" {
    val p: Pair[i64, u64] = make_pair[i64, u64](7, 11);
    val a: i64 = pair_left_val[i64, u64](p);
    val b: u64 = pair_right_val[i64, u64](p);
    if ((a + b::i64) != 18) { ret 0; }
    ret 1;
}

test "generics: pair roundtrip literal" {
    val p: Pair[i64, i64] = Pair[i64, i64]{left: 3, right: 4};
    if ((p.left + p.right) != 7) { ret 0; }
    ret 1;
}

test "generics: swap keeps first value" {
    val w: Wrap[i64] = swap[i64](42, 99);
    if (wrap_get[i64](w) != 42) { ret 0; }
    ret 1;
}

# Generic pointer indexing stride tests
fun generic_fill[T](p: *T, value: T, count: i64) {
    if (p == nil || count == 0) { ret; }
    var i: i64 = 0;
    for (i < count) {
        p[i] = value;
        i = i + 1;
    }
}

fun generic_read[T](p: *T, index: i64) T {
    ret p[index];
}

test "generics: fill u8 pointer stride" {
    var buf: [16]u8;
    var z: i64 = 0;
    for (z < 16) { buf[z] = 0; z = z + 1; }

    generic_fill[u8](?buf[0], 0xAA, 4);

    if (buf[0] != 0xAA) { ret 0; }
    if (buf[1] != 0xAA) { ret 0; }
    if (buf[2] != 0xAA) { ret 0; }
    if (buf[3] != 0xAA) { ret 0; }
    if (buf[4] != 0)    { ret 0; }
    ret 1;
}

test "generics: fill i32 pointer stride" {
    var buf: [8]i32;
    var z: i64 = 0;
    for (z < 8) { buf[z] = 0; z = z + 1; }

    generic_fill[i32](?buf[0], 42, 3);

    if (buf[0] != 42) { ret 0; }
    if (buf[1] != 42) { ret 0; }
    if (buf[2] != 42) { ret 0; }
    if (buf[3] != 0)  { ret 0; }
    ret 1;
}

test "generics: read u8 pointer stride" {
    var buf: [8]u8;
    buf[0] = 0x10;
    buf[1] = 0x20;
    buf[2] = 0x30;
    buf[3] = 0x40;

    if (generic_read[u8](?buf[0], 0) != 0x10) { ret 0; }
    if (generic_read[u8](?buf[0], 1) != 0x20) { ret 0; }
    if (generic_read[u8](?buf[0], 2) != 0x30) { ret 0; }
    if (generic_read[u8](?buf[0], 3) != 0x40) { ret 0; }
    ret 1;
}

test "generics: read i32 pointer stride" {
    var buf: [4]i32;
    buf[0] = 100;
    buf[1] = 200;
    buf[2] = 300;
    buf[3] = 400;

    if (generic_read[i32](?buf[0], 0) != 100) { ret 0; }
    if (generic_read[i32](?buf[0], 1) != 200) { ret 0; }
    if (generic_read[i32](?buf[0], 2) != 300) { ret 0; }
    if (generic_read[i32](?buf[0], 3) != 400) { ret 0; }
    ret 1;
}
