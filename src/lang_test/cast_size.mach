test "casts: u8 to u64 (zero extend)" {
    var a: u8  = 255;
    var b: u64 = a::u64;
    if (b == 255) { ret 1; }
    ret 0;
}

test "casts: u16 to u64 (zero extend)" {
    var a: u16 = 65535;
    var b: u64 = a::u64;
    if (b == 65535) { ret 1; }
    ret 0;
}

test "casts: u32 to u64 (zero extend)" {
    var a: u32 = 0xFFFFFFFF;
    var b: u64 = a::u64;

    # Expect 0x00000000FFFFFFFF
    var expected: u64 = 0;
    expected = ~expected;
    expected = expected >> 32;

    if (b == expected) { ret 1; }
    ret 0;
}

test "casts: u64 to u8 (truncate)" {
    var a: u64 = 0xDEADBEEF;
    var b: u8  = a::u8; # 0xEF = 239
    if (b == 0xEF) { ret 1; }
    ret 0;
}

test "casts: u64 to u16 (truncate)" {
    var a: u64 = 0xDEADBEEF;
    var b: u16 = a::u16; # 0xBEEF = 48879
    if (b == 0xBEEF) { ret 1; }
    ret 0;
}

test "casts: u64 to u32 (truncate)" {
    var a: u64 = 0xDEADBEEFCAFEBABE;
    var b: u32 = a::u32; # 0xCAFEBABE
    if (b == 0xCAFEBABE) { ret 1; }
    ret 0;
}

test "casts: i8 to u64 (sign extend not implicit)" {
    # Note: casts are purely bitwise, so this should zero-extend the 8-bit value, NOT sign extend.
    # If a is -1 (0xFF), casting to u64 should give 255 (0x00...00FF), NOT -1 (0xFF...FFFF).
    # Mach's '::' operator is a bitcast/reinterpret, not a semantic conversion.
    # However, for widening, we have to decide what bits fill the new space.
    # Since it's a "bit reinterpretation", usually that implies the value is loaded into a larger container.
    # If the user wants sign extension, they should use a specific conversion function.
    # The default behavior for register loading of small values is typically zero extension (MOVZX) or undefined high bits.
    # Given the proposal asked for "intrinsic ZEXT", we expect ZEXT behavior here.

    var a: i8  = -1; # 0xFF
    var b: u64 = a::u64;
    if (b == 255) { ret 1; } # Expect 0xFF zero-extended
    ret 0;
}

test "casts: i32 to u64 (zero extend)" {
    var a: i32 = -1; # 0xFFFFFFFF
    var b: u64 = a::u64;

    # Expect 0x00000000FFFFFFFF
    var expected: u64 = 0;
    expected = ~expected;
    expected = expected >> 32;

    if (b == expected) { ret 1; }
    ret 0;
}
