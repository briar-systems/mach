# sema edge case tests
#
# regression tests for known problem areas in the semantic analysis
# pipeline: anonymous record dedup, generic instantiation, nested
# generics, and type equality.

rec Pair[A, B] {
    first:  A;
    second: B;
}

fun make_pair[A, B](a: A, b: B) Pair[A, B] {
    var p: Pair[A, B];
    p.first  = a;
    p.second = b;
    ret p;
}

fun pair_first[A, B](p: Pair[A, B]) A {
    ret p.first;
}

fun pair_second[A, B](p: Pair[A, B]) B {
    ret p.second;
}

rec Container[T] {
    items: *T;
    count: u32;
}

fun anon_rec_result(x: i32) rec { a: i32; b: bool; } {
    var r: rec { a: i32; b: bool; };
    r.a = x;
    r.b = x > 0;
    ret r;
}

fun anon_rec_consumer(r: rec { a: i32; b: bool; }) i32 {
    if (r.b) { ret r.a; }
    ret 0;
}

test "sema: pair generic basic" {
    val p: Pair[i32, bool] = make_pair[i32, bool](42, true);
    if (pair_first[i32, bool](p) != 42) { ret 0; }
    ret 1;
}

test "sema: pair generic u64" {
    val p: Pair[u64, u64] = make_pair[u64, u64](100, 200);
    if (pair_second[u64, u64](p) != 200) { ret 0; }
    ret 1;
}

test "sema: nested generic Pair of Pair" {
    val inner: Pair[i32, i32] = make_pair[i32, i32](1, 2);
    val outer: Pair[Pair[i32, i32], bool] = make_pair[Pair[i32, i32], bool](inner, true);
    if (pair_first[Pair[i32, i32], bool](outer).first != 1) { ret 0; }
    ret 1;
}

test "sema: anonymous record round-trip" {
    val r: rec { a: i32; b: bool; } = anon_rec_result(10);
    val v: i32 = anon_rec_consumer(r);
    if (v != 10) { ret 0; }
    ret 1;
}

test "sema: anonymous record negative" {
    val r: rec { a: i32; b: bool; } = anon_rec_result(-5);
    val v: i32 = anon_rec_consumer(r);
    if (v != 0) { ret 0; }
    ret 1;
}

test "sema: generic with pointer field" {
    var x: i32 = 99;
    val p: Pair[*i32, bool] = make_pair[*i32, bool](?x, true);
    if (@pair_first[*i32, bool](p) != 99) { ret 0; }
    ret 1;
}

fun find_result[T](found: bool, idx: u32) rec { found: bool; idx: u32; } {
    var r: rec { found: bool; idx: u32; };
    r.found = found;
    r.idx   = idx;
    ret r;
}

fun use_find_a[T](x: T) u32 {
    val r: rec { found: bool; idx: u32; } = find_result[T](true, 7);
    if (r.found) { ret r.idx; }
    ret 0;
}

fun use_find_b[T](x: T) u32 {
    val r: rec { found: bool; idx: u32; } = find_result[T](false, 3);
    if (r.found) { ret r.idx; }
    ret 0;
}

test "sema: anon record from generic - multiple call sites" {
    val a: u32 = use_find_a[i32](0);
    val b: u32 = use_find_b[i32](0);
    if (a != 7) { ret 0; }
    if (b != 0) { ret 0; }
    ret 1;
}

test "sema: anon record from generic - different type args" {
    val a: u32 = use_find_a[u64](0);
    val b: u32 = use_find_a[u8](0);
    if (a != 7) { ret 0; }
    if (b != 7) { ret 0; }
    ret 1;
}

def MyInt: i32;

test "sema: type alias preserves semantics" {
    var x: MyInt = 42;
    var y: i32 = x;
    if (y != 42) { ret 0; }
    ret 1;
}

fun generic_alias[T](v: T) T {
    ret v;
}

test "sema: generic instantiated with alias type" {
    var x: MyInt = 10;
    val r: MyInt = generic_alias[MyInt](x);
    if (r != 10) { ret 0; }
    ret 1;
}

rec Wrapper[T] {
    inner: Pair[T, T];
}

test "sema: generic containing another generic" {
    var w: Wrapper[i32];
    w.inner = make_pair[i32, i32](3, 4);
    if (w.inner.first != 3) { ret 0; }
    if (w.inner.second != 4) { ret 0; }
    ret 1;
}

fun returns_container[T](ptr: *T, n: u32) Container[T] {
    var c: Container[T];
    c.items = ptr;
    c.count = n;
    ret c;
}

test "sema: generic container with pointer" {
    var arr: [4]i32;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    val c: Container[i32] = returns_container[i32](?arr[0], 4);
    if (c.count != 4) { ret 0; }
    if (c.items[2] != 30) { ret 0; }
    ret 1;
}
