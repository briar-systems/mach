# Bitwise, shift, arithmetic, and modulo operator tests.

# --- Bitwise AND ---

test "operators: bitwise and" {
    var a: u64 = 0xFF00;
    var b: u64 = 0x0FF0;
    var c: u64 = a & b;
    if (c != 0x0F00) { ret 0; }
    ret 1;
}

test "operators: bitwise and zero" {
    var a: u64 = 0xFFFF;
    var b: u64 = 0x0000;
    var c: u64 = a & b;
    if (c != 0) { ret 0; }
    ret 1;
}

test "operators: bitwise and identity" {
    var a: u64 = 0xABCD;
    var b: u64 = 0xFFFFFFFFFFFFFFFF;
    var c: u64 = a & b;
    if (c != 0xABCD) { ret 0; }
    ret 1;
}

# --- Bitwise OR ---

test "operators: bitwise or" {
    var a: u64 = 0xFF00;
    var b: u64 = 0x00FF;
    var c: u64 = a | b;
    if (c != 0xFFFF) { ret 0; }
    ret 1;
}

test "operators: bitwise or zero" {
    var a: u64 = 0xABCD;
    var b: u64 = 0x0000;
    var c: u64 = a | b;
    if (c != 0xABCD) { ret 0; }
    ret 1;
}

test "operators: bitwise or accumulate" {
    var rc: i64 = 0;
    rc = rc | 1;
    rc = rc | 2;
    rc = rc | 4;
    if (rc != 7) { ret 0; }
    ret 1;
}

fun returns_zero() i64 {
    ret 0;
}

fun returns_one() i64 {
    ret 1;
}

test "operators: bitwise or with local fn intermediate" {
    var rc: i64 = 0;
    var tmp: i64 = returns_zero();
    rc = rc | tmp;
    if (rc != 0) { ret 0; }
    ret 1;
}

test "operators: bitwise or with inline call" {
    var rc: i64 = 0;
    rc = rc | returns_one();
    if (rc != 1) { ret 0; }
    ret 1;
}

fun factorial_inline(n: i64) i64 {
    if (n <= 1) {
        ret 1;
    }
    ret n * factorial_inline(n - 1);
}

test "operators: multiply with inline recursive call" {
    var f: i64 = factorial_inline(5);
    if (f != 120) { ret 0; }
    ret 1;
}

fun fib_inline(n: i64) i64 {
    if (n <= 1) {
        ret n;
    }
    ret fib_inline(n - 1) + fib_inline(n - 2);
}

test "operators: add with inline recursive calls" {
    var f: i64 = fib_inline(10);
    if (f != 55) { ret 0; }
    ret 1;
}

# --- Bitwise XOR ---

test "operators: bitwise xor" {
    var a: u64 = 0xFF00;
    var b: u64 = 0xF0F0;
    var c: u64 = a ^ b;
    if (c != 0x0FF0) { ret 0; }
    ret 1;
}

test "operators: bitwise xor self is zero" {
    var a: u64 = 0xABCD1234;
    var c: u64 = a ^ a;
    if (c != 0) { ret 0; }
    ret 1;
}

test "operators: bitwise xor toggle" {
    var a: u64 = 0x00FF;
    var mask: u64 = 0xFFFF;
    var c: u64 = a ^ mask;
    if (c != 0xFF00) { ret 0; }
    ret 1;
}

# --- Bitwise NOT ---

test "operators: bitwise not u8" {
    var a: u8 = 0x0F;
    var b: u8 = ~a;
    if (b != 0xF0) { ret 0; }
    ret 1;
}

test "operators: bitwise not u8 zero" {
    var a: u8 = 0x00;
    var b: u8 = ~a;
    if (b != 0xFF) { ret 0; }
    ret 1;
}

test "operators: bitwise not u8 max" {
    var a: u8 = 0xFF;
    var b: u8 = ~a;
    if (b != 0x00) { ret 0; }
    ret 1;
}

# --- Left Shift ---

test "operators: left shift" {
    var a: u64 = 1;
    var b: u64 = a << 4;
    if (b != 16) { ret 0; }
    ret 1;
}

test "operators: left shift by zero" {
    var a: u64 = 0xABCD;
    var b: u64 = a << 0;
    if (b != 0xABCD) { ret 0; }
    ret 1;
}

test "operators: left shift multiple bits" {
    var a: u64 = 0x01;
    var b: u64 = a << 8;
    if (b != 0x100) { ret 0; }
    ret 1;
}

test "operators: left shift overflow discards high bits" {
    var a: u8 = 0x80;
    var b: u8 = a << 1;
    if (b != 0x00) { ret 0; }
    ret 1;
}

# --- Right Shift (unsigned) ---

test "operators: right shift unsigned" {
    var a: u64 = 0x80;
    var b: u64 = a >> 4;
    if (b != 0x08) { ret 0; }
    ret 1;
}

test "operators: right shift by zero" {
    var a: u64 = 0xABCD;
    var b: u64 = a >> 0;
    if (b != 0xABCD) { ret 0; }
    ret 1;
}

test "operators: right shift multiple bits" {
    var a: u64 = 0x100;
    var b: u64 = a >> 8;
    if (b != 0x01) { ret 0; }
    ret 1;
}

test "operators: right shift discards low bits" {
    var a: u8 = 0x01;
    var b: u8 = a >> 1;
    if (b != 0x00) { ret 0; }
    ret 1;
}

test "operators: right shift signed" {
    var a: i64 = 0 - 16;
    var b: i64 = a >> 2;
    if (b != (0 - 4)) { ret 0; }
    ret 1;
}

# --- Combined bitwise ---

test "operators: combined bitwise" {
    var a: u64 = 0xABCD;
    var mask: u64 = 0x00FF;
    var low: u64 = a & mask;
    var high: u64 = (a >> 8) & mask;
    if ((low + high) != (0xCD + 0xAB)) { ret 0; }
    ret 1;
}

test "operators: shift and mask pattern" {
    var flags: u64 = 0;
    flags = flags | (1 << 0);
    flags = flags | (1 << 3);
    flags = flags | (1 << 7);
    var has_bit_0: u64 = (flags >> 0) & 1;
    var has_bit_3: u64 = (flags >> 3) & 1;
    var has_bit_5: u64 = (flags >> 5) & 1;
    var has_bit_7: u64 = (flags >> 7) & 1;
    if ((has_bit_0 + has_bit_3 + has_bit_5 + has_bit_7) != 3) { ret 0; }
    ret 1;
}

test "operators: extract nibbles" {
    var x: u64 = 0x1234;
    var n0: u64 = (x >> 0) & 0xF;
    var n1: u64 = (x >> 4) & 0xF;
    var n2: u64 = (x >> 8) & 0xF;
    var n3: u64 = (x >> 12) & 0xF;
    if ((n0 + n1 + n2 + n3) != (4 + 3 + 2 + 1)) { ret 0; }
    ret 1;
}

# --- Nested bit-shift codegen ---

test "operators: nested shift-or inline u64" {
    var sym: u32 = 5;
    var rtype: u32 = 3;
    val r_info: u64 = (sym::u64 << 32) | rtype::u64;
    if (r_info != 0x0000000500000003) { ret 0; }
    ret 1;
}

test "operators: nested shift-or inline u32" {
    var a: u32 = 0xAB;
    var b: u32 = 0xCD;
    val result: u64 = (a::u64 << 8) | b::u64;
    if (result != 0xABCD) { ret 0; }
    ret 1;
}

test "operators: nested shift-or with variables" {
    var sym: u32 = 5;
    var rtype: u32 = 3;
    val sym_u64: u64 = sym::u64;
    val shifted: u64 = sym_u64 << 32;
    val rtype_u64: u64 = rtype::u64;
    val r_info: u64 = shifted | rtype_u64;
    if (r_info != 0x0000000500000003) { ret 0; }
    ret 1;
}

# --- Modulo ---

test "operators: modulo i64 positive" {
    var a: i64 = 17;
    var b: i64 = 5;
    var c: i64 = a % b;
    if (c != 2) { ret 0; }
    ret 1;
}

test "operators: modulo i64 exact division" {
    var a: i64 = 20;
    var b: i64 = 5;
    var c: i64 = a % b;
    if (c != 0) { ret 0; }
    ret 1;
}

test "operators: modulo i64 smaller dividend" {
    var a: i64 = 3;
    var b: i64 = 7;
    var c: i64 = a % b;
    if (c != 3) { ret 0; }
    ret 1;
}

test "operators: modulo u64 positive" {
    var a: u64 = 17;
    var b: u64 = 5;
    var c: u64 = a % b;
    if (c != 2) { ret 0; }
    ret 1;
}

test "operators: modulo u64 large values" {
    var a: u64 = 1000000007;
    var b: u64 = 1000000;
    var c: u64 = a % b;
    if (c != 7) { ret 0; }
    ret 1;
}

test "operators: modulo power of two" {
    var a: u64 = 123;
    var b: u64 = a % 16;
    if (b != 11) { ret 0; }
    ret 1;
}

test "operators: modulo in loop" {
    var count: i64 = 0;
    var i: i64 = 0;
    for (i < 20) {
        if (i % 3 == 0) {
            count = count + 1;
        }
        i = i + 1;
    }
    if (count != 7) { ret 0; }
    ret 1;
}

# --- Arithmetic ---

test "operators: addition i64" {
    var a: i64 = 100;
    var b: i64 = 200;
    var c: i64 = a + b;
    if (c != 300) { ret 0; }
    ret 1;
}

test "operators: subtraction i64" {
    var a: i64 = 500;
    var b: i64 = 300;
    var c: i64 = a - b;
    if (c != 200) { ret 0; }
    ret 1;
}

test "operators: multiplication i64" {
    var a: i64 = 12;
    var b: i64 = 11;
    var c: i64 = a * b;
    if (c != 132) { ret 0; }
    ret 1;
}

test "operators: division i64" {
    var a: i64 = 100;
    var b: i64 = 4;
    var c: i64 = a / b;
    if (c != 25) { ret 0; }
    ret 1;
}

test "operators: division truncates" {
    var a: i64 = 7;
    var b: i64 = 2;
    var c: i64 = a / b;
    if (c != 3) { ret 0; }
    ret 1;
}

test "operators: arithmetic precedence" {
    var result: i64 = 2 + 3 * 4;
    if (result != 14) { ret 0; }
    ret 1;
}

test "operators: arithmetic parentheses" {
    var result: i64 = (2 + 3) * 4;
    if (result != 20) { ret 0; }
    ret 1;
}

test "operators: arithmetic chain" {
    var result: i64 = 10 + 20 - 5 + 15;
    if (result != 40) { ret 0; }
    ret 1;
}

test "operators: arithmetic with negatives" {
    var a: i64 = 0 - 10;
    var b: i64 = 25;
    var c: i64 = a + b;
    if (c != 15) { ret 0; }
    ret 1;
}

test "operators: multiply by zero" {
    var a: i64 = 999999;
    var b: i64 = 0;
    var c: i64 = a * b;
    if (c != 0) { ret 0; }
    ret 1;
}

test "operators: shift by zero" {
    var x: u64 = 0xFF;
    var y: u64 = x << 0;
    if (y != 0xFF) { ret 0; }
    var z: u64 = x >> 0;
    if (z != 0xFF) { ret 0; }
    ret 1;
}

test "operators: modulo by one" {
    var x: i64 = 12345;
    var y: i64 = x % 1;
    if (y != 0) { ret 0; }
    ret 1;
}
