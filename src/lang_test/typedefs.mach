# Type alias (def) tests.

def Age: i64;
def Count: u64;
def Byte: u8;

test "typedefs: alias for i64" {
    var a: Age = 25;
    if (a != 25) { ret 0; }
    ret 1;
}

test "typedefs: alias for u64" {
    var c: Count = 100;
    if (c != 100) { ret 0; }
    ret 1;
}

test "typedefs: alias for u8" {
    var b: Byte = 255;
    if (b != 255) { ret 0; }
    ret 1;
}

test "typedefs: alias in arithmetic" {
    var a: Age = 30;
    var b: Age = 12;
    var sum: Age = a + b;
    if (sum != 42) { ret 0; }
    ret 1;
}

test "typedefs: alias assignment from literal" {
    var x: Age = 0;
    x = 99;
    if (x != 99) { ret 0; }
    ret 1;
}

def Ptr: ptr;

test "typedefs: alias for ptr" {
    var x: i64 = 123;
    var p: Ptr = ?x;
    var q: *i64 = p;
    if (@q != 123) { ret 0; }
    ret 1;
}

def IntPair: rec { a: i64; b: i64; };

test "typedefs: alias for record" {
    var p: IntPair = IntPair { a: 10, b: 20 };
    if ((p.a + p.b) != 30) { ret 0; }
    ret 1;
}
