# Minimal repros for aggregate copy, nested arrays/records, generics,
# and index extension (pointer arithmetic with narrow indices).

rec Point {
    x: i64;
    y: i64;
}

rec Pair {
    a: i64;
    b: i64;
}

rec Wrap[T] {
    value: T;
}

fun make_wrap[T](value: T) Wrap[T] {
    var w: Wrap[T];
    w.value = value;
    ret w;
}

fun wrap_get[T](this: Wrap[T]) T {
    ret this.value;
}

fun wrap_set[T](this: *Wrap[T], value: T) {
    this.value = value;
}

test "repro: record by-value copy preserves fields" {
    val p1: Point = Point{x: 2, y: 5};
    val p2: Point = p1;
    if ((p2.x + p2.y) != 7) { ret 0; }
    ret 1;
}

test "repro: array by-value copy preserves elements" {
    val a: [2]i64 = [2]i64{8, 9};
    val b: [2]i64 = a;
    if ((b[0] + b[1]) != 17) { ret 0; }
    ret 1;
}

test "repro: nested arrays layout" {
    val row0: [2]i64 = [2]i64{1, 2};
    val row1: [2]i64 = [2]i64{3, 4};
    val grid: [2][2]i64 = [2][2]i64{row0, row1};
    val sum: i64 = grid[0][0] + grid[0][1] + grid[1][0] + grid[1][1];
    if (sum != 10) { ret 0; }
    ret 1;
}

test "repro: array of records read" {
    val p0: Pair = Pair{a: 1, b: 2};
    val p1: Pair = Pair{a: 3, b: 4};
    val items: [2]Pair = [2]Pair{p0, p1};
    if ((items[0].a + items[1].b) != 5) { ret 0; }
    ret 1;
}

test "repro: generic wrap get" {
    val w: Wrap[i64] = make_wrap[i64](55);
    if (wrap_get[i64](w) != 55) { ret 0; }
    ret 1;
}

test "repro: generic wrap set" {
    var w: Wrap[i64] = make_wrap[i64](1);
    wrap_set[i64](?w, 99);
    if (wrap_get[i64](w) != 99) { ret 0; }
    ret 1;
}

# -----------------------------------------------------------------------------
# Index extension regression tests
#
# These tests verify that array/pointer indexing with indices smaller than
# pointer size (e.g., i32 on 64-bit) works correctly. The bug was that narrow
# indices weren't sign/zero extended before pointer arithmetic, causing
# garbage in the upper bits when the index vreg was spilled and reloaded.
# -----------------------------------------------------------------------------

# --- Signed index types (need SEXT) ---

test "repro: i8 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: i8 = 3;
    if (p[i] != 40) { ret 0; }
    ret 1;
}

test "repro: i16 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: i16 = 5;
    if (p[i] != 60) { ret 0; }
    ret 1;
}

test "repro: i32 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: i32 = 7;
    if (p[i] != 80) { ret 0; }
    ret 1;
}

test "repro: i64 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: i64 = 2;
    if (p[i] != 30) { ret 0; }
    ret 1;
}

# --- Unsigned index types (need ZEXT) ---

test "repro: u8 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: u8 = 4;
    if (p[i] != 50) { ret 0; }
    ret 1;
}

test "repro: u16 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: u16 = 6;
    if (p[i] != 70) { ret 0; }
    ret 1;
}

test "repro: u32 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: u32 = 1;
    if (p[i] != 20) { ret 0; }
    ret 1;
}

test "repro: u64 index on pointer" {
    var data: [8]u8 = [8]u8{10, 20, 30, 40, 50, 60, 70, 80};
    var p: *u8 = ?data[0];
    var i: u64 = 0;
    if (p[i] != 10) { ret 0; }
    ret 1;
}

# --- Array indexing (vs pointer indexing) ---

test "repro: i32 index on array" {
    var arr: [4]i64 = [4]i64{100, 200, 300, 400};
    var i: i32 = 2;
    if (arr[i] != 300) { ret 0; }
    ret 1;
}

test "repro: u32 index on array" {
    var arr: [4]i64 = [4]i64{100, 200, 300, 400};
    var i: u32 = 3;
    if (arr[i] != 400) { ret 0; }
    ret 1;
}

# --- Different element sizes with narrow index ---

test "repro: i32 index on i16 array" {
    var arr: [4]i16 = [4]i16{1000, 2000, 3000, 4000};
    var i: i32 = 2;
    if (arr[i] != 3000) { ret 0; }
    ret 1;
}

test "repro: i32 index on i32 array" {
    var arr: [4]i32 = [4]i32{10000, 20000, 30000, 40000};
    var i: i32 = 1;
    if (arr[i] != 20000) { ret 0; }
    ret 1;
}

test "repro: i32 index on i64 array" {
    var arr: [4]i64 = [4]i64{100000, 200000, 300000, 400000};
    var i: i32 = 3;
    if (arr[i] != 400000) { ret 0; }
    ret 1;
}

test "repro: i32 index on pointer array" {
    var a: i64 = 1;
    var b: i64 = 2;
    var c: i64 = 3;
    var arr: [3]*i64 = [3]*i64{?a, ?b, ?c};
    var i: i32 = 1;
    if (@arr[i] != 2) { ret 0; }
    ret 1;
}

# --- Index in loop (original bug trigger - vreg spilling) ---

fun sum_with_i32_index(p: *u8, len: i32) i32 {
    var sum: i32 = 0;
    var i: i32 = 0;
    for (i < len) {
        sum = sum + p[i]::i32;
        i = i + 1;
    }
    ret sum;
}

test "repro: i32 index in loop" {
    var data: [5]u8 = [5]u8{1, 2, 3, 4, 5};
    var p: *u8 = ?data[0];
    val sum: i32 = sum_with_i32_index(p, 5);
    if (sum != 15) { ret 0; }
    ret 1;
}

# --- Nested method calls with index (original crash pattern) ---

rec Iter {
    data: *u8;
    pos: i32;
    len: i32;
}

fun iter_new(s: *u8, length: i32) Iter {
    var it: Iter;
    it.data = s;
    it.pos = 0;
    it.len = length;
    ret it;
}

fun iter_done(this: *Iter) i32 {
    if (this.pos >= this.len) { ret 1; }
    ret 0;
}

fun iter_curr(this: *Iter) u8 {
    if (iter_done(this) != 0) { ret 0; }
    ret this.data[this.pos];
}

fun iter_advance(this: *Iter) {
    this.pos = this.pos + 1;
}

fun iter_sum_all(this: *Iter) i32 {
    var total: i32 = 0;
    for (iter_done(this) == 0) {
        total = total + iter_curr(this)::i32;
        iter_advance(this);
    }
    ret total;
}

test "repro: nested method with i32 index" {
    var data: [4]u8 = [4]u8{10, 20, 30, 40};
    var it: Iter = iter_new(?data[0], 4);
    val sum: i32 = iter_sum_all(?it);
    if (sum != 100) { ret 0; }
    ret 1;
}

# --- sret with conditional returns and narrow index (full original pattern) ---

rec Big {
    a: i32;
    b: i32;
    c: u8;
    d: u8;
}

fun make_big_a(x: i32) Big {
    ret Big { a: x, b: 0, c: 1, d: 0 };
}

fun make_big_b(x: i32) Big {
    ret Big { a: 0, b: x, c: 2, d: 0 };
}

fun iter_scan_to_space(this: *Iter) Big {
    for (iter_done(this) == 0) {
        val c: u8 = iter_curr(this);
        if (c == ' ') { brk; }
        iter_advance(this);
    }
    if (this.pos == 2) {
        ret make_big_a(this.pos);
    }
    ret make_big_b(this.pos);
}

test "repro: sret conditional with i32 index path A" {
    var data: [3]u8 = [3]u8{'a', 'b', 0};
    var it: Iter = iter_new(?data[0], 2);
    val r: Big = iter_scan_to_space(?it);
    if (r.c != 1) { ret 0; }
    if (r.a != 2) { ret 0; }
    ret 1;
}

test "repro: sret conditional with i32 index path B" {
    var data: [4]u8 = [4]u8{'a', 'b', 'c', 0};
    var it: Iter = iter_new(?data[0], 3);
    val r: Big = iter_scan_to_space(?it);
    if (r.c != 2) { ret 0; }
    if (r.b != 3) { ret 0; }
    ret 1;
}

test "repro: sret conditional with i32 index longer" {
    var data: [6]u8 = [6]u8{'h', 'e', 'l', 'l', 'o', 0};
    var it: Iter = iter_new(?data[0], 5);
    val r: Big = iter_scan_to_space(?it);
    if (r.c != 2) { ret 0; }
    if (r.b != 5) { ret 0; }
    ret 1;
}
