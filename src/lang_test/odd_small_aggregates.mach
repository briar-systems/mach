# Odd-size small aggregate (3/5/6/7 bytes) return and by-value tests.

rec S3 {
    a: u8;
    b: u8;
    c: u8;
}

rec S5 {
    a: u8;
    b: u8;
    c: u8;
    d: u8;
    e: u8;
}

rec S6 {
    a: u8;
    b: u8;
    c: u8;
    d: u8;
    e: u8;
    f: u8;
}

rec S7 {
    a: u8;
    b: u8;
    c: u8;
    d: u8;
    e: u8;
    f: u8;
    g: u8;
}

fun make_s3(v: u8) S3 {
    ret S3{a: v, b: (v + 1)::u8, c: (v + 2)::u8};
}

fun make_s5(v: u8) S5 {
    ret S5{a: v, b: (v + 1)::u8, c: (v + 2)::u8, d: (v + 3)::u8, e: (v + 4)::u8};
}

fun make_s6(v: u8) S6 {
    ret S6{a: v, b: (v + 1)::u8, c: (v + 2)::u8, d: (v + 3)::u8, e: (v + 4)::u8, f: (v + 5)::u8};
}

fun make_s7(v: u8) S7 {
    ret S7{a: v, b: (v + 1)::u8, c: (v + 2)::u8, d: (v + 3)::u8, e: (v + 4)::u8, f: (v + 5)::u8, g: (v + 6)::u8};
}

fun sum_s3(s: S3) i64 { ret s.a::i64 + s.b::i64 + s.c::i64; }
fun sum_s5(s: S5) i64 { ret s.a::i64 + s.b::i64 + s.c::i64 + s.d::i64 + s.e::i64; }
fun sum_s6(s: S6) i64 { ret s.a::i64 + s.b::i64 + s.c::i64 + s.d::i64 + s.e::i64 + s.f::i64; }
fun sum_s7(s: S7) i64 { ret s.a::i64 + s.b::i64 + s.c::i64 + s.d::i64 + s.e::i64 + s.f::i64 + s.g::i64; }

var g_s7: S7;

fun array_set_s5(arr: *S5, idx: i64, v: S5) {
    arr[idx] = v;
}

fun array_get_s5(arr: *S5, idx: i64) S5 {
    ret arr[idx];
}

fun set_global_s7(v: S7) {
    g_s7 = v;
}

fun get_global_s7() S7 {
    ret g_s7;
}

# --- Return by value ---

test "odd agg: return s3" {
    val s: S3 = make_s3(1::u8);
    if (sum_s3(s) != 6) { ret 0; }
    ret 1;
}

test "odd agg: return s5" {
    val s: S5 = make_s5(1::u8);
    if (sum_s5(s) != 15) { ret 0; }
    ret 1;
}

test "odd agg: return s6" {
    val s: S6 = make_s6(1::u8);
    if (sum_s6(s) != 21) { ret 0; }
    ret 1;
}

test "odd agg: return s7" {
    val s: S7 = make_s7(1::u8);
    if (sum_s7(s) != 28) { ret 0; }
    ret 1;
}

# --- By-value argument passing ---

test "odd agg: pass s3" {
    val s: S3 = make_s3(3::u8);
    if (sum_s3(s) != 12) { ret 0; }
    ret 1;
}

test "odd agg: pass s5" {
    val s: S5 = make_s5(3::u8);
    if (sum_s5(s) != 25) { ret 0; }
    ret 1;
}

test "odd agg: pass s6" {
    val s: S6 = make_s6(3::u8);
    if (sum_s6(s) != 30) { ret 0; }
    ret 1;
}

test "odd agg: pass s7" {
    val s: S7 = make_s7(3::u8);
    if (sum_s7(s) != 35) { ret 0; }
    ret 1;
}

# --- Aggregate store/load with indexing and globals ---

test "odd agg: array index store/load" {
    var items: [3]S5;
    val v: S5 = make_s5(2::u8);
    array_set_s5(?items[0], 1, v);
    val out: S5 = array_get_s5(?items[0], 1);
    if (sum_s5(out) != 20) { ret 0; }
    ret 1;
}

test "odd agg: global store/load" {
    val v: S7 = make_s7(2::u8);
    set_global_s7(v);
    val out: S7 = get_global_s7();
    if (sum_s7(out) != 35) { ret 0; }
    ret 1;
}
