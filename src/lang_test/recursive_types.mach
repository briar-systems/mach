# test recursive type definitions through pointer indirection

rec TestNode {
    value: i32;
    child: *TestNode;
}

test "recursive type: basic self-reference" {
    var parent: TestNode;
    parent.value = 10;
    parent.child = nil;

    var child: TestNode;
    child.value = 20;
    child.child = nil;

    parent.child = ?child;
    if (parent.child.value != 20) { ret 0; }
    ret 1;
}

rec TypeA {
    value: i32;
    other: *TypeB;
}

rec TypeB {
    value: i32;
    other: *TypeA;
}

test "recursive type: mutual pointer recursion" {
    var a: TypeA;
    var b: TypeB;
    a.value = 1;
    b.value = 2;
    a.other = ?b;
    b.other = ?a;
    if (a.other.value != 2) { ret 0; }
    if (b.other.value != 1) { ret 0; }
    ret 1;
}

rec LinkedList {
    data: i64;
    next: *LinkedList;
    prev: *LinkedList;
}

test "recursive type: doubly linked traversal" {
    var a: LinkedList;
    var b: LinkedList;
    var c: LinkedList;
    a.data = 1;
    b.data = 2;
    c.data = 3;
    a.next = ?b;
    a.prev = nil;
    b.next = ?c;
    b.prev = ?a;
    c.next = nil;
    c.prev = ?b;
    if (a.next.next.data != 3) { ret 0; }
    if (c.prev.prev.data != 1) { ret 0; }
    ret 1;
}

rec TreeNode {
    value: i32;
    left:  *TreeNode;
    right: *TreeNode;
}

test "recursive type: binary tree" {
    var root: TreeNode;
    var left: TreeNode;
    var right: TreeNode;
    root.value = 10;
    left.value = 5;
    right.value = 15;
    root.left  = ?left;
    root.right = ?right;
    left.left  = nil;
    left.right = nil;
    right.left  = nil;
    right.right = nil;
    if (root.left.value + root.right.value != 20) { ret 0; }
    ret 1;
}
