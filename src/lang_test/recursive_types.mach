# test recursive type definition

# recursive type like ast.Node
rec TestNode {
    value: i32;
    child: *TestNode;
}

test "recursive type: basic" {
    ret 1;
}

# test mutually recursive types
rec TypeA {
    value: i32;
    other: *TypeB;
}

rec TypeB {
    value: i32;
    other: *TypeA;
}

test "recursive type: mutual recursion" {
    ret 1;
}

# test nested pointer to self
rec LinkedList {
    data: i64;
    next: *LinkedList;
    prev: *LinkedList;
}

test "recursive type: doubly linked" {
    ret 1;
}
