# Floating-point arithmetic and comparison tests.

# --- f64 arithmetic ---

test "floats: f64 addition" {
    var a: f64 = 1.5;
    var b: f64 = 2.5;
    var c: f64 = a + b;
    if (c != 4.0) { ret 0; }
    ret 1;
}

test "floats: f64 addition negative" {
    var a: f64 = 0.0 - 5.0;
    var b: f64 = 3.0;
    var c: f64 = a + b;
    if (c != (0.0 - 2.0)) { ret 0; }
    ret 1;
}

test "floats: f64 subtraction" {
    var a: f64 = 5.0;
    var b: f64 = 3.0;
    var c: f64 = a - b;
    if (c != 2.0) { ret 0; }
    ret 1;
}

test "floats: f64 subtraction negative result" {
    var a: f64 = 3.0;
    var b: f64 = 5.0;
    var c: f64 = a - b;
    if (c != (0.0 - 2.0)) { ret 0; }
    ret 1;
}

test "floats: f64 multiplication" {
    var a: f64 = 3.0;
    var b: f64 = 4.0;
    var c: f64 = a * b;
    if (c != 12.0) { ret 0; }
    ret 1;
}

test "floats: f64 multiplication by negative" {
    var a: f64 = 3.0;
    var b: f64 = 0.0 - 4.0;
    var c: f64 = a * b;
    if (c != (0.0 - 12.0)) { ret 0; }
    ret 1;
}

test "floats: f64 division" {
    var a: f64 = 10.0;
    var b: f64 = 2.0;
    var c: f64 = a / b;
    if (c != 5.0) { ret 0; }
    ret 1;
}

test "floats: f64 division fractional result" {
    var a: f64 = 7.0;
    var b: f64 = 2.0;
    var c: f64 = a / b;
    if (c != 3.5) { ret 0; }
    ret 1;
}

test "floats: f64 combined operations" {
    var a: f64 = 2.0;
    var b: f64 = 3.0;
    var c: f64 = 4.0;
    var result: f64 = (a + b) * c;
    if (result != 20.0) { ret 0; }
    ret 1;
}

test "floats: f64 small values" {
    var a: f64 = 0.001;
    var b: f64 = 0.002;
    var c: f64 = a + b;
    if (c != 0.003) { ret 0; }
    ret 1;
}

test "floats: f64 large values" {
    var a: f64 = 1000000.0;
    var b: f64 = 2000000.0;
    var c: f64 = a + b;
    if (c != 3000000.0) { ret 0; }
    ret 1;
}

# --- f64 comparisons ---

test "floats: f64 greater than true" {
    var a: f64 = 3.0;
    var b: f64 = 2.0;
    if (a > b) {
        ret 1;
    }
    ret 0;
}

test "floats: f64 greater than false" {
    var a: f64 = 2.0;
    var b: f64 = 3.0;
    if (a > b) { ret 0; }
    ret 1;
}

test "floats: f64 greater than or equal true (greater)" {
    var a: f64 = 3.0;
    var b: f64 = 2.0;
    if (a >= b) {
        ret 1;
    }
    ret 0;
}

test "floats: f64 greater than or equal true (equal)" {
    var a: f64 = 2.0;
    var b: f64 = 2.0;
    if (a >= b) {
        ret 1;
    }
    ret 0;
}

test "floats: f64 greater than or equal false" {
    var a: f64 = 1.5;
    var b: f64 = 2.0;
    if (a >= b) { ret 0; }
    ret 1;
}

test "floats: f64 not equal true" {
    var a: f64 = 1.5;
    var b: f64 = 2.5;
    if (a != b) {
        ret 1;
    }
    ret 0;
}

test "floats: f64 not equal false" {
    var a: f64 = 2.5;
    var b: f64 = 2.5;
    if (a != b) { ret 0; }
    ret 1;
}

test "floats: f64 compare negative values" {
    var a: f64 = 0.0 - 1.0;
    var b: f64 = 0.0 - 2.0;
    if (a > b) { ret 1; }
    ret 0;
}

test "floats: f64 compare mixed signs" {
    var a: f64 = 1.0;
    var b: f64 = 0.0 - 1.0;
    if (a > b) {
        ret 1;
    }
    ret 0;
}

test "floats: f64 less than" {
    var a: f64 = 1.0;
    var b: f64 = 2.0;
    if (a < b) { ret 1; }
    ret 0;
}

test "floats: f64 less than or equal" {
    var a: f64 = 2.0;
    var b: f64 = 2.0;
    if (a <= b) { ret 1; }
    ret 0;
}

test "floats: f64 equal" {
    var a: f64 = 3.5;
    var b: f64 = 3.5;
    if (a == b) { ret 1; }
    ret 0;
}

# --- f64 in records ---

rec Point2D {
    x: f64;
    y: f64;
}

test "floats: f64 in record" {
    var p: Point2D = Point2D { x: 1.5, y: 2.5 };
    var sum: f64 = p.x + p.y;
    if (sum != 4.0) { ret 0; }
    ret 1;
}

test "floats: f64 record mutation" {
    var p: Point2D = Point2D { x: 0.0, y: 0.0 };
    p.x = 3.14;
    p.y = 2.71;
    var sum: f64 = p.x + p.y;
    if (sum != 5.85) { ret 0; }
    ret 1;
}

# --- f64 in arrays ---

test "floats: f64 array" {
    var arr: [3]f64;
    arr[0] = 1.0;
    arr[1] = 2.0;
    arr[2] = 3.0;
    var sum: f64 = arr[0] + arr[1] + arr[2];
    if (sum != 6.0) { ret 0; }
    ret 1;
}

test "floats: f64 array loop sum" {
    var arr: [5]f64;
    arr[0] = 1.0;
    arr[1] = 2.0;
    arr[2] = 3.0;
    arr[3] = 4.0;
    arr[4] = 5.0;
    var sum: f64 = 0.0;
    var i: i64 = 0;
    for (i < 5) {
        sum = sum + arr[i];
        i = i + 1;
    }
    if (sum != 15.0) { ret 0; }
    ret 1;
}

# --- f64 function parameters and returns ---

fun add_f64(a: f64, b: f64) f64 {
    ret a + b;
}

fun mul_f64(a: f64, b: f64) f64 {
    ret a * b;
}

test "floats: f64 function call" {
    var result: f64 = add_f64(1.5, 2.5);
    if (result != 4.0) { ret 0; }
    ret 1;
}

test "floats: f64 chained function calls" {
    var a: f64 = add_f64(1.0, 2.0);
    var b: f64 = mul_f64(a, 3.0);
    if (b != 9.0) { ret 0; }
    ret 1;
}

# --- f64 edge cases ---

test "floats: f64 zero" {
    var a: f64 = 0.0;
    var b: f64 = 0.0;
    var c: f64 = a + b;
    if (c != 0.0) { ret 0; }
    ret 1;
}

test "floats: f64 multiply by zero" {
    var a: f64 = 12345.6789;
    var b: f64 = 0.0;
    var c: f64 = a * b;
    if (c != 0.0) { ret 0; }
    ret 1;
}

test "floats: f64 divide one" {
    var a: f64 = 7.5;
    var b: f64 = 1.0;
    var c: f64 = a / b;
    if (c != 7.5) { ret 0; }
    ret 1;
}
