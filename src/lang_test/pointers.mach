# Pointer and dereference tests.

test "pointers: address-of and deref reads value" {
    var x: i64 = 10;
    var p: *i64 = ?x;
    if (@p != 10) { ret 0; }
    ret 1;
}

test "pointers: write through pointer" {
    var x: i64 = 5;
    var p: *i64 = ?x;
    @p = 25;
    if (x != 25) { ret 0; }
    ret 1;
}

test "pointers: pointer-to-pointer write" {
    var x: i64 = 3;
    var p: *i64 = ?x;
    var pp: **i64 = ?p;
    @(@pp) = 9;
    if (x != 9) { ret 0; }
    ret 1;
}

test "pointers: cast to ptr and back preserves address" {
    var x: i64 = 1;
    var p: *i64 = ?x;
    val raw: ptr = p::ptr;
    val p2: *i64 = raw::*i64;
    @p2 = 13;
    if (x != 13) { ret 0; }
    ret 1;
}

test "pointers: distinct addresses differ" {
    var a: i64 = 1;
    var b: i64 = 2;
    val pa: u64 = ((?a)::ptr)::u64;
    val pb: u64 = ((?b)::ptr)::u64;
    if (pa == pb) { ret 0; }
    ret 1;
}

test "pointers: nil is zero" {
    if (nil::u64 != 0) { ret 0; }
    ret 1;
}
