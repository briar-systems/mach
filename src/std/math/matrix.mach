def matrix_4x4: [4][4]f32;
def mat:        matrix_4x4;

fun multiply(a: mat, b: mat): mat {
    var result: mat;

    var i: u32 = 0;
    for (i < 4) {
        var j: u32 = 0;
        for (j < 4) {
            result[i][j] = a[i][0] * b[0][j] + a[i][1] * b[1][j] + a[i][2] * b[2][j] + a[i][3] * b[3][j];
            j = j + 1;
        }
        i = i + 1;
    }

    ret result;
}

fun dot(a: mat, b: mat): f32 {
    var result: f32 = 0.0;

    var i: u32 = 0;
    for (i < 4) {
        var j: u32 = 0;
        for (j < 4) {
            result = result + a[i][j] * b[j][i];
            j = j + 1;
        }
        i = i + 1;
    }

    ret result;
}
