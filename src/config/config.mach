# mach.config.config: project configuration types and loading.
# ---
# provides types for representing mach.toml configuration and functions for
# loading/saving configuration files.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use print:     std.print;
use toml:      std.data.toml;
use path:      std.types.path;

use target: mach.config.target;

# DepTypeKind: type of dependency (remote or local).
# ---
# remote: dependency fetched from a URL
# local:  dependency from a local filesystem path
pub uni DepTypeKind {
    remote: u8;
    local: u8;
}

# DepVersionKind: type of version specifier for dependencies.
# ---
# branch: track a git branch (e.g. "branch/main")
# semver: semantic version constraint (e.g. "^1.2.3", "~1.2.3", "1.2.3")
# commit: specific git commit hash
#
# NOTE: self-hosted config stores version as raw string; kind is inferred by prefix.
pub uni DepVersionKind {
    branch: str;
    semver: str;
    commit: str;
}

# IncludePath: a module prefix → directory mapping from -I flag.
pub rec IncludePath {
    prefix: str;
    dir:    str;
}

# Dep: dependency specification from [deps] table.
# ---
# name:     dependency name (key in [deps] table)
# dep_type: remote or local
# path:     remote URL or local filesystem path
# version:  raw version specifier (e.g., "branch/main", "commit/abcd", "^1.2.3")
pub rec Dep {
    name:     str;
    dep_type: DepTypeKind;
    path:     str;
    version:  str;
}

# Target: target-specific configuration from [targets] table.
# ---
# name:       target name (key in [targets] table)
# os:         target operating system
# isa:        target instruction set architecture
# abi:        target application binary interface
# mode:       build mode (executable, library, shared)
# entrypoint: main source file (relative to dir_src)
# artifacts:  artifacts directory (relative to dir_out)
# binary:     output binary path (relative to dir_out)
pub rec Target {
    name:       str;
    os:         str;
    isa:        str;
    abi:        str;
    mode:       target.TargetMode;
    entrypoint: str;
    artifacts:  str;
    binary:     str;
}

# Config: project configuration loaded from mach.toml.
# ---
# id:           project id (used for module prefix)
# name:         project name (human-readable)
# version:      project version
# dir_src:      source files directory
# dir_out:      output files directory
# dir_dep:      dependencies directory
# target:       default target name (or "native" for auto-detect)
# targets:      array of target configurations
# target_count: number of targets
# deps:         array of dependency specifications
# dep_count:    number of dependencies
pub rec Config {
    id:           str;
    name:         str;
    version:      str;
    dir_src:      str;
    dir_out:      str;
    dir_dep:      str;
    target:       str;
    targets:      *Target;
    target_count: i32;
    deps:         *Dep;
    dep_count:    i32;
}

# init: create an empty configuration with default values.
# ---
# ret: Config with nil/zero fields
pub fun init() Config {
    var cfg: Config;
    cfg.id = nil;
    cfg.name = nil;
    cfg.version = nil;
    cfg.dir_src = "src";
    cfg.dir_out = "out";
    cfg.dir_dep = "dep";
    cfg.target = "native";
    cfg.targets = nil;
    cfg.target_count = 0;
    cfg.deps = nil;
    cfg.dep_count = 0;
    ret cfg;
}

# dnit: free resources associated with a configuration.
# ---
# cfg:   configuration to clean up
# alloc: allocator used for allocations
# ret:   true on success
pub fun dnit(cfg: *Config, alloc: *allocator.Allocator) bool {
    if (cfg == nil) {
        ret true;
    }

    # All strings and arrays are allocated from the arena passed by the caller.
    # The caller (e.g. build, dep commands) owns the arena and frees it wholesale
    # via arena.arena_dnit(). No per-field free is needed here.

    ret true;
}

# get_entry_value: helper to find a string value in a TOML document by key.
# ---
# doc: TOML document to search
# key: dotted key to find (e.g. "project.id")
# ret: string value if found, nil otherwise
fun get_entry_value(doc: &toml.Document, key: str) str {
    if (doc == nil || key == nil) {
        ret nil;
    }

    var i: usize = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (str_equals(e.key, key)) {
            # return the string value (assumes caller knows the type)
            ret e.value.string;
        }
        i = i + 1;
    }

    ret nil;
}

# starts_with_prefix: check if a key starts with a given prefix.
# ---
# key: key to check
# prefix: prefix to match (e.g. "targets.")
# ret: true if key starts with prefix
fun starts_with_prefix(key: str, prefix: str) bool {
    if (key == nil || prefix == nil) {
        ret false;
    }
    ret str_starts_with(key, prefix);
}

# extract_target_name: extract target name from a key like "targets.linux.os".
# ---
# key: full dotted key
# alloc: allocator for name buffer
# ret: target name (e.g. "linux") or nil
fun extract_target_name(key: str, alloc: *allocator.Allocator) str {
    if (key == nil || alloc == nil) {
        ret nil;
    }

    # skip "targets."
    val prefix_len: usize = 8;  # len("targets.")
    if (str_len(key) <= prefix_len) {
        ret nil;
    }

    # find the next '.' after the target name
    var i: usize = prefix_len;
    val len: usize = str_len(key);
    for (i < len) {
        if (key[i] == '.') {
            brk;
        }
        i = i + 1;
    }

    if (i == prefix_len) {
        ret nil;
    }

    val name_len: usize = i - prefix_len;
    val res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, name_len + 1);
    if (result_is_err[*u8, allocator.AllocError](res)) {
        ret nil;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](res);
    var j: usize = 0;
    for (j < name_len) {
        buf[j] = key[prefix_len + j];
        j = j + 1;
    }
    buf[name_len] = '\0';
    ret buf::&u8;
}

# extract_field_name: extract field name from a key like "targets.linux.os".
# ---
# key: full dotted key
# ret: field name (e.g. "os") or nil
fun extract_field_name(key: str) str {
    if (key == nil) {
        ret nil;
    }

    # find the last '.'
    val len: usize = str_len(key);
    var last_dot: usize = len;
    var i: usize = 0;
    for (i < len) {
        if (key[i] == '.') {
            last_dot = i;
        }
        i = i + 1;
    }

    if (last_dot >= len - 1) {
        ret nil;
    }

    ret (key::usize + last_dot + 1)::str;
}

# find_or_create_target: find existing target by name or create new one.
# ---
# cfg: config to search/modify
# name: target name to find
# alloc: allocator for new targets
# ret: pointer to target or nil on error
fun find_or_create_target(cfg: *Config, name: str, alloc: *allocator.Allocator) *Target {
    if (cfg == nil || name == nil || alloc == nil) {
        ret nil;
    }

    # search existing targets
    var i: i32 = 0;
    for (i < cfg.target_count) {
        val t: *Target = ?cfg.targets[i];
        if (t.name != nil && str_equals(t.name, name)) {
            ret t;
        }
        i = i + 1;
    }

    # allocate new target array if needed
    if (cfg.targets == nil) {
        val res: Result[*Target, allocator.AllocError] = allocator.allocator_alloc[Target](alloc, 8);
        if (result_is_err[*Target, allocator.AllocError](res)) {
            ret nil;
        }
        cfg.targets = result_unwrap_ok[*Target, allocator.AllocError](res);
    } or (cfg.target_count >= 8) {
        # max 8 targets for now
        print.eprintln("error: maximum number of targets (8) reached");
        ret nil;
    }

    # initialize new target
    val idx: i32 = cfg.target_count;
    val t: *Target = ?cfg.targets[idx];
    t.name = name;
    t.os = nil;
    t.isa = nil;
    t.abi = nil;
    t.mode = target.tmode_executable();
    t.entrypoint = nil;
    t.artifacts = nil;
    t.binary = nil;
    cfg.target_count = idx + 1;

    ret t;
}

# parse_targets: parse [targets.*] entries from TOML document.
# ---
# cfg: config to populate
# doc: TOML document
# alloc: allocator
fun parse_targets(cfg: *Config, doc: &toml.Document, alloc: *allocator.Allocator) {
    if (cfg == nil || doc == nil || alloc == nil) {
        ret;
    }

    var i: usize = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (starts_with_prefix(e.key, "targets.")) {
            val tgt_name: str = extract_target_name(e.key, alloc);
            val field_name: str = extract_field_name(e.key);

            if (tgt_name != nil && field_name != nil) {
                val t: *Target = find_or_create_target(cfg, tgt_name, alloc);
                if (t != nil) {
                    val val_str: str = e.value.string;

                    if (str_equals(field_name, "os")) {
                        t.os = val_str;
                    } or (str_equals(field_name, "isa")) {
                        t.isa = val_str;
                    } or (str_equals(field_name, "abi")) {
                        t.abi = val_str;
                    } or (str_equals(field_name, "mode")) {
                        t.mode = target.parse_mode(val_str);
                    } or (str_equals(field_name, "entrypoint")) {
                        t.entrypoint = val_str;
                    } or (str_equals(field_name, "artifacts")) {
                        t.artifacts = val_str;
                    } or (str_equals(field_name, "binary")) {
                        t.binary = val_str;
                    }
                }
            }
        }
        i = i + 1;
    }
}

# parse_deps: parse [deps.*] entries from TOML document.
# ---
# cfg: config to populate
# doc: TOML document
# alloc: allocator
fun parse_deps(cfg: *Config, doc: &toml.Document, alloc: *allocator.Allocator) {
    if (cfg == nil || doc == nil || alloc == nil) {
        ret;
    }

    # count deps entries first
    var count: i32 = 0;
    var i: usize = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (starts_with_prefix(e.key, "deps.")) {
            # count unique dep names (entries like "deps.foo.path", "deps.foo.version")
            # for simplicity, count "deps.*.path" entries as one dep each
            val field_name: str = extract_field_name(e.key);
            if (field_name != nil && str_equals(field_name, "path")) {
                count = count + 1;
            }
        }
        i = i + 1;
    }

    if (count == 0) {
        ret;
    }

    # allocate deps array
    val res: Result[*Dep, allocator.AllocError] = allocator.allocator_alloc[Dep](alloc, count::usize);
    if (result_is_err[*Dep, allocator.AllocError](res)) {
        ret;
    }
    cfg.deps = result_unwrap_ok[*Dep, allocator.AllocError](res);

    # parse deps
    var dep_idx: i32 = 0;
    i = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (starts_with_prefix(e.key, "deps.")) {
            val field_name: str = extract_field_name(e.key);

            # extract dep name (between "deps." and the field)
            if (field_name != nil && str_equals(field_name, "path") && dep_idx < count) {
                # extract name: skip "deps." (5 chars), find next "."
                val key_after_deps: str = (e.key::usize + 5)::str;
                var name_end: usize = 0;
                for (key_after_deps[name_end] != '\0' && key_after_deps[name_end] != '.') {
                    name_end = name_end + 1;
                }

                val d: *Dep = ?cfg.deps[dep_idx];

                # allocate and copy just the dep name (not the full key suffix)
                val name_buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, name_end + 1);
                if (result_is_err[*u8, allocator.AllocError](name_buf_res)) {
                    i = i + 1;
                    cnt;
                }
                val name_buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](name_buf_res);
                var k: usize = 0;
                for (k < name_end) {
                    name_buf[k] = key_after_deps[k];
                    k = k + 1;
                }
                name_buf[name_end] = '\0';

                d.name = name_buf::&u8;
                d.path = e.value.string;
                d.dep_type = DepTypeKind { remote: 0 };  # default to remote
                d.version = "branch/main";

                # scan for type/version entries for this dep
                var j: usize = 0;
                for (j < doc.len) {
                    val e2: *toml.Entry = ?doc.entries[j];
                    if (!starts_with_prefix(e2.key, "deps.")) { j = j + 1; cnt; }

                    # build key prefix: deps.<name>.
                    # use name_end which is the length of just the dep name
                    if (str_len(e2.key) >= (5 + name_end + 1)) {
                        var matches: bool = true;
                        var m: usize = 0;
                        # compare "deps." + name
                        if (e2.key[0] != 'd' || e2.key[1] != 'e' || e2.key[2] != 'p' || e2.key[3] != 's' || e2.key[4] != '.') {
                            matches = false;
                        }
                        if (matches) {
                            m = 0;
                            for (m < name_end) {
                                if (e2.key[5 + m] != key_after_deps[m]) { matches = false; brk; }
                                m = m + 1;
                            }
                        }
                        if (matches && e2.key[5 + name_end] == '.') {
                            val field: str = (e2.key::usize + 6 + name_end)::str;
                            if (str_equals(field, "type")) {
                                if (e2.value.string != nil && str_equals(e2.value.string, "local")) {
                                    d.dep_type = DepTypeKind { local: 0 };
                                } or {
                                    d.dep_type = DepTypeKind { remote: 0 };
                                }
                            } or (str_equals(field, "version")) {
                                d.version = e2.value.string;
                            }
                        }
                    }
                    j = j + 1;
                }

                dep_idx = dep_idx + 1;
            }
        }
        i = i + 1;
    }

    cfg.dep_count = dep_idx;
}

# load: load configuration from a mach.toml file.
# ---
# config_path: path to mach.toml file
# alloc:       allocator for memory allocations
# ret:         Ok(Config) on success, Err(str) with error message on failure
pub fun load(config_path: str, alloc: *allocator.Allocator) Result[Config, str] {
    if (config_path == nil) {
        ret err[Config, str]("config path is nil");
    }

    if (alloc == nil) {
        ret err[Config, str]("allocator is nil");
    }

    # open and read the file
    val open_res: Result[fs.File, str] = fs.open(config_path);
    if (result_is_err[fs.File, str](open_res)) {
        ret err[Config, str](result_unwrap_err[fs.File, str](open_res));
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](open_res);

    # get file size
    val stat_res: Result[fs.Stat, str] = fs.file_stat(?file);
    if (result_is_err[fs.Stat, str](stat_res)) {
        fs.file_close(?file);
        ret err[Config, str](result_unwrap_err[fs.Stat, str](stat_res));
    }

    val st: fs.Stat = result_unwrap_ok[fs.Stat, str](stat_res);
    val file_size: usize = st.st_size::usize;

    # allocate buffer for file contents
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, file_size + 1);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        fs.file_close(?file);
        ret err[Config, str](result_unwrap_err[*u8, allocator.AllocError](buf_res));
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    # read file contents
    val read_res: Result[usize, str] = fs.file_read(?file, buf, file_size);
    if (result_is_err[usize, str](read_res)) {
        allocator.allocator_free[u8](alloc, buf, file_size + 1);
        fs.file_close(?file);
        ret err[Config, str](result_unwrap_err[usize, str](read_res));
    }

    # null-terminate
    buf[file_size] = '\0';
    fs.file_close(?file);

    # parse TOML
    val source: str = buf::&u8;
    val parse_res: Result[toml.Document, str] = toml.parse(alloc, source);
    if (result_is_err[toml.Document, str](parse_res)) {
        allocator.allocator_free[u8](alloc, buf, file_size + 1);
        ret err[Config, str](result_unwrap_err[toml.Document, str](parse_res));
    }

    val doc: toml.Document = result_unwrap_ok[toml.Document, str](parse_res);

    # extract configuration values
    var cfg: Config = init();

    cfg.id = get_entry_value(?doc, "project.id");
    cfg.name = get_entry_value(?doc, "project.name");
    cfg.version = get_entry_value(?doc, "project.version");

    val src: str = get_entry_value(?doc, "project.dir_src");
    if (src != nil) {
        cfg.dir_src = src;
    }

    val out: str = get_entry_value(?doc, "project.dir_out");
    if (out != nil) {
        cfg.dir_out = out;
    }

    val dep: str = get_entry_value(?doc, "project.dir_dep");
    if (dep != nil) {
        cfg.dir_dep = dep;
    }

    val tgt: str = get_entry_value(?doc, "project.target");
    if (tgt != nil) {
        cfg.target = tgt;
    }

    # parse [targets.*] sections
    parse_targets(?cfg, ?doc, alloc);

    # parse [deps.*] sections
    parse_deps(?cfg, ?doc, alloc);

    # note: we don't free buf here because strings in cfg point into it
    # the caller is responsible for calling dnit when done

    ret ok[Config, str](cfg);
}

# save: save configuration to a mach.toml file.
# ---
# cfg:  configuration to save
# path: path to write mach.toml
# ret:  Ok(true) on success, Err(str) with error message on failure
pub fun save(cfg: *Config, config_path: str) Result[bool, str] {
    if (cfg == nil) {
        ret err[bool, str]("config is nil");
    }

    if (config_path == nil) {
        ret err[bool, str]("path is nil");
    }

    # create/truncate the file
    val file_res: Result[fs.File, str] = fs.create(config_path, 420);  # 0644
    if (result_is_err[fs.File, str](file_res)) {
        ret err[bool, str](result_unwrap_err[fs.File, str](file_res));
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](file_res);

    # write [project] section
    fs.file_write(?file, "[project]\n", 10);

    if (cfg.id != nil) {
        fs.file_write(?file, "id      = \"", 11);
        fs.file_write(?file, cfg.id, str_len(cfg.id));
        fs.file_write(?file, "\"\n", 2);
    }

    if (cfg.name != nil) {
        fs.file_write(?file, "name    = \"", 11);
        fs.file_write(?file, cfg.name, str_len(cfg.name));
        fs.file_write(?file, "\"\n", 2);
    }

    if (cfg.version != nil) {
        fs.file_write(?file, "version = \"", 11);
        fs.file_write(?file, cfg.version, str_len(cfg.version));
        fs.file_write(?file, "\"\n", 2);
    }

    fs.file_write(?file, "\n", 1);

    if (cfg.dir_src != nil) {
        fs.file_write(?file, "dir_src = \"", 11);
        fs.file_write(?file, cfg.dir_src, str_len(cfg.dir_src));
        fs.file_write(?file, "\"\n", 2);
    }

    if (cfg.dir_out != nil) {
        fs.file_write(?file, "dir_out = \"", 11);
        fs.file_write(?file, cfg.dir_out, str_len(cfg.dir_out));
        fs.file_write(?file, "\"\n", 2);
    }

    if (cfg.dir_dep != nil) {
        fs.file_write(?file, "dir_dep = \"", 11);
        fs.file_write(?file, cfg.dir_dep, str_len(cfg.dir_dep));
        fs.file_write(?file, "\"\n", 2);
    }

    fs.file_write(?file, "\n", 1);

    if (cfg.target != nil) {
        fs.file_write(?file, "target  = \"", 11);
        fs.file_write(?file, cfg.target, str_len(cfg.target));
        fs.file_write(?file, "\"\n", 2);
    }

    # write [targets.*] sections
    var i: i32 = 0;
    for (i < cfg.target_count) {
        val t: *Target = ?cfg.targets[i];
        if (t != nil && t.name != nil) {
            fs.file_write(?file, "\n[targets.", 10);
            fs.file_write(?file, t.name, str_len(t.name));
            fs.file_write(?file, "]\n", 2);

            if (t.os != nil) {
                fs.file_write(?file, "os         = \"", 14);
                fs.file_write(?file, t.os, str_len(t.os));
                fs.file_write(?file, "\"\n", 2);
            }

            if (t.isa != nil) {
                fs.file_write(?file, "isa        = \"", 14);
                fs.file_write(?file, t.isa, str_len(t.isa));
                fs.file_write(?file, "\"\n", 2);
            }

            if (t.abi != nil) {
                fs.file_write(?file, "abi        = \"", 14);
                fs.file_write(?file, t.abi, str_len(t.abi));
                fs.file_write(?file, "\"\n", 2);
            }

            fs.file_write(?file, "mode       = \"", 14);
            fs.file_write(?file, target.mode_to_str(t.mode), str_len(target.mode_to_str(t.mode)));
            fs.file_write(?file, "\"\n", 2);

            if (t.entrypoint != nil) {
                fs.file_write(?file, "entrypoint = \"", 14);
                fs.file_write(?file, t.entrypoint, str_len(t.entrypoint));
                fs.file_write(?file, "\"\n", 2);
            }

            if (t.artifacts != nil) {
                fs.file_write(?file, "artifacts  = \"", 14);
                fs.file_write(?file, t.artifacts, str_len(t.artifacts));
                fs.file_write(?file, "\"\n", 2);
            }

            if (t.binary != nil) {
                fs.file_write(?file, "binary     = \"", 14);
                fs.file_write(?file, t.binary, str_len(t.binary));
                fs.file_write(?file, "\"\n", 2);
            }
        }
        i = i + 1;
    }

    # write [deps.*] sections
    i = 0;
    for (i < cfg.dep_count) {
        val d: *Dep = ?cfg.deps[i];
        if (d != nil && d.name != nil) {
            fs.file_write(?file, "\n[deps.", 7);
            fs.file_write(?file, d.name, str_len(d.name));
            fs.file_write(?file, "]\n", 2);

            if (d.path != nil) {
                fs.file_write(?file, "path = \"", 8);
                fs.file_write(?file, d.path, str_len(d.path));
                fs.file_write(?file, "\"\n", 2);
            }
            # write type if available
            if (d.dep_type.local != nil) {
                fs.file_write(?file, "type = \"local\"\n", 15);
            } or {
                fs.file_write(?file, "type = \"remote\"\n", 16);
            }
            if (d.version != nil) {
                fs.file_write(?file, "version = \"", 12);
                fs.file_write(?file, d.version, str_len(d.version));
                fs.file_write(?file, "\"\n", 2);
            }
        }
        i = i + 1;
    }

    fs.file_close(?file);
    ret ok[bool, str](true);
}

# get_target: find a target by name.
# ---
# cfg:  configuration to search
# name: target name to find
# ret:  Some(Target) if found, None if not found
pub fun get_target(cfg: *Config, name: str) Option[*Target] {
    if (cfg == nil || cfg.targets == nil) {
        ret none[*Target]();
    }

    var i: i32 = 0;
    for (i < cfg.target_count) {
        val t: *Target = ?cfg.targets[i];
        if (t.name != nil && str_equals(t.name, name)) {
            ret some[*Target](t);
        }
        i = i + 1;
    }

    ret none[*Target]();
}

# get_dep: find a dependency by name.
# ---
# cfg:  configuration to search
# name: dependency name to find
# ret:  Some(Dep) if found, None if not found
pub fun get_dep(cfg: *Config, name: str) Option[*Dep] {
    if (cfg == nil || cfg.deps == nil) {
        ret none[*Dep]();
    }

    var i: i32 = 0;
    for (i < cfg.dep_count) {
        val d: *Dep = ?cfg.deps[i];
        if (d.name != nil && str_equals(d.name, name)) {
            ret some[*Dep](d);
        }
        i = i + 1;
    }

    ret none[*Dep]();
}

# add_dep: add or update a dependency in config.
# ---
# cfg: config to modify
# alloc: allocator
# name: dep name
# path: dep path/url
# is_local: true if local dep
# version: version string (optional)
# ret: true on success
pub fun add_dep(cfg: *Config, alloc: *allocator.Allocator, name: str, path: str, is_local: bool, version: str) bool {
    if (cfg == nil || alloc == nil || name == nil || path == nil) {
        ret false;
    }

    # update existing
    val existing: Option[*Dep] = get_dep(cfg, name);
    if (option_is_some[*Dep](existing)) {
        val d: *Dep = option_unwrap[*Dep](existing);
        d.path = path;
        if (is_local) {
            d.dep_type = DepTypeKind { local: 0 };
        } or {
            d.dep_type = DepTypeKind { remote: 0 };
        }
        if (version != nil) { d.version = version; }
        ret true;
    }

    # grow deps array
    if (cfg.deps == nil) {
        val r: Result[*Dep, allocator.AllocError] = allocator.allocator_alloc[Dep](alloc, 8);
        if (result_is_err[*Dep, allocator.AllocError](r)) { ret false; }
        cfg.deps = result_unwrap_ok[*Dep, allocator.AllocError](r);
    } or (cfg.dep_count >= 8) {
        val new_cap: usize = (cfg.dep_count + 1)::usize;
        val r2: Result[*Dep, allocator.AllocError] = allocator.allocator_resize[Dep](alloc, cfg.deps, cfg.dep_count::usize, new_cap);
        if (result_is_err[*Dep, allocator.AllocError](r2)) { ret false; }
        cfg.deps = result_unwrap_ok[*Dep, allocator.AllocError](r2);
    }

    val idx: i32 = cfg.dep_count;
    val d: *Dep = ?cfg.deps[idx];
    d.name = name;
    d.path = path;
    if (is_local) {
        d.dep_type = DepTypeKind { local: 0 };
    } or {
        d.dep_type = DepTypeKind { remote: 0 };
    }
    if (version != nil) {
        d.version = version;
    } or {
        d.version = "branch/main";
    }

    cfg.dep_count = cfg.dep_count + 1;
    ret true;
}

# del_dep: remove a dependency from config.
# ---
# cfg: config to modify
# name: dep name
pub fun del_dep(cfg: *Config, name: str) bool {
    if (cfg == nil || cfg.deps == nil || name == nil) { ret false; }

    var i: i32 = 0;
    var found: bool = false;
    for (i < cfg.dep_count) {
        val d: *Dep = ?cfg.deps[i];
        if (!found && d.name != nil && str_equals(d.name, name)) {
            found = true;
        }
        if (found && i + 1 < cfg.dep_count) {
            cfg.deps[i] = cfg.deps[i + 1];
        }
        i = i + 1;
    }

    if (found) { cfg.dep_count = cfg.dep_count - 1; }
    ret found;
}
