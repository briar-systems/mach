use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use toml:      std.data.toml;
use path:      std.types.path;

use target: mach.config.target;

# mach.config.config: project configuration types and loading.
# ---
# provides types for representing mach.toml configuration and functions for
# loading/saving configuration files.

# DepTypeKind: type of dependency (remote or local).
# ---
# remote: dependency fetched from a URL
# local:  dependency from a local filesystem path
pub uni DepTypeKind {
    remote: u8;
    local: u8;
}

# DepVersionKind: type of version specifier for dependencies.
# ---
# branch: track a git branch (e.g. "branch/main")
# semver: semantic version constraint (e.g. "^1.2.3", "~1.2.3", "1.2.3")
# commit: specific git commit hash
pub uni DepVersionKind {
    branch: str;
    semver: str;
    commit: str;
}

# Dep: dependency specification from [deps] table.
# ---
# name:     dependency name (key in [deps] table)
# dep_type: remote or local
# path:     remote URL or local filesystem path
# version:  version specifier (for remote deps)
pub rec Dep {
    name:     str;
    dep_type: DepTypeKind;
    path:     str;
    version:  DepVersionKind;
}

# Target: target-specific configuration from [targets] table.
# ---
# name:       target name (key in [targets] table)
# os:         target operating system
# isa:        target instruction set architecture
# abi:        target application binary interface
# mode:       build mode (executable, library, shared)
# entrypoint: main source file (relative to dir_src)
# artifacts:  artifacts directory (relative to dir_out)
# binary:     output binary path (relative to dir_out)
pub rec Target {
    name:       str;
    os:         target.TargetOS;
    isa:        target.TargetISA;
    abi:        target.TargetABI;
    mode:       target.TargetMode;
    entrypoint: str;
    artifacts:  str;
    binary:     str;
}

# Config: project configuration loaded from mach.toml.
# ---
# id:           project id (used for module prefix)
# name:         project name (human-readable)
# version:      project version
# dir_src:      source files directory
# dir_out:      output files directory
# dir_dep:      dependencies directory
# target:       default target name (or "native" for auto-detect)
# targets:      array of target configurations
# target_count: number of targets
# deps:         array of dependency specifications
# dep_count:    number of dependencies
pub rec Config {
    id:           str;
    name:         str;
    version:      str;
    dir_src:      str;
    dir_out:      str;
    dir_dep:      str;
    target:       str;
    targets:      *Target;
    target_count: i32;
    deps:         *Dep;
    dep_count:    i32;
}

# init: create an empty configuration with default values.
# ---
# ret: Config with nil/zero fields
pub fun init() Config {
    var cfg: Config;
    cfg.id = nil;
    cfg.name = nil;
    cfg.version = nil;
    cfg.dir_src = "src";
    cfg.dir_out = "out";
    cfg.dir_dep = "dep";
    cfg.target = "native";
    cfg.targets = nil;
    cfg.target_count = 0;
    cfg.deps = nil;
    cfg.dep_count = 0;
    ret cfg;
}

# deinit: free resources associated with a configuration.
# ---
# cfg:   configuration to clean up
# alloc: allocator used for allocations
# ret:   true on success
pub fun deinit(cfg: *Config, alloc: *allocator.Allocator) bool {
    if (cfg == nil) {
        ret true;
    }

    # TODO: free allocated strings
    # TODO: free targets array
    # TODO: free deps array

    ret true;
}

# get_entry_value: helper to find a string value in a TOML document by key.
# ---
# doc: TOML document to search
# key: dotted key to find (e.g. "project.id")
# ret: string value if found, nil otherwise
fun get_entry_value(doc: *toml.Document, key: str) str {
    if (doc == nil || key == nil) {
        ret nil;
    }

    var i: usize = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (e.key.equals(key)) {
            # return the string value (assumes caller knows the type)
            ret e.value.string;
        }
        i = i + 1;
    }

    ret nil;
}

# starts_with_prefix: check if a key starts with a given prefix.
# ---
# key: key to check
# prefix: prefix to match (e.g. "targets.")
# ret: true if key starts with prefix
fun starts_with_prefix(key: str, prefix: str) bool {
    if (key == nil || prefix == nil) {
        ret false;
    }
    ret key.starts_with(prefix);
}

# extract_target_name: extract target name from a key like "targets.linux.os".
# ---
# key: full dotted key
# ret: target name (e.g. "linux") or nil
fun extract_target_name(key: str) str {
    if (key == nil) {
        ret nil;
    }

    # skip "targets."
    val prefix_len: usize = 8;  # len("targets.")
    if (key.len() <= prefix_len) {
        ret nil;
    }

    # find the next '.' after the target name
    var i: usize = prefix_len;
    val len: usize = key.len();
    for (i < len) {
        if (key[i] == 46) {  # '.'
            brk;
        }
        i = i + 1;
    }

    if (i == prefix_len) {
        ret nil;
    }

    # return pointer into the key string (no allocation needed for lookup)
    ret (key::usize + prefix_len)::str;
}

# extract_field_name: extract field name from a key like "targets.linux.os".
# ---
# key: full dotted key
# ret: field name (e.g. "os") or nil
fun extract_field_name(key: str) str {
    if (key == nil) {
        ret nil;
    }

    # find the last '.'
    val len: usize = key.len();
    var last_dot: usize = len;
    var i: usize = 0;
    for (i < len) {
        if (key[i] == 46) {  # '.'
            last_dot = i;
        }
        i = i + 1;
    }

    if (last_dot >= len - 1) {
        ret nil;
    }

    ret (key::usize + last_dot + 1)::str;
}

# find_or_create_target: find existing target by name or create new one.
# ---
# cfg: config to search/modify
# name: target name to find
# alloc: allocator for new targets
# ret: pointer to target or nil on error
fun find_or_create_target(cfg: *Config, name: str, alloc: *allocator.Allocator) *Target {
    if (cfg == nil || name == nil || alloc == nil) {
        ret nil;
    }

    # search existing targets
    var i: i32 = 0;
    for (i < cfg.target_count) {
        val t: *Target = ?cfg.targets[i];
        if (t.name != nil && t.name.starts_with(name)) {
            # check if it's an exact match (names might share prefix)
            val name_len: usize = name.len();
            val t_name_len: usize = t.name.len();
            # compare up to first '.' in extracted name
            var match_len: usize = 0;
            for (match_len < name_len && name[match_len] != 46) {
                match_len = match_len + 1;
            }
            var t_match_len: usize = 0;
            for (t_match_len < t_name_len && t.name[t_match_len] != 46) {
                t_match_len = t_match_len + 1;
            }
            if (match_len == t_match_len) {
                var j: usize = 0;
                var matches: bool = true;
                for (j < match_len) {
                    if (name[j] != t.name[j]) {
                        matches = false;
                        brk;
                    }
                    j = j + 1;
                }
                if (matches) {
                    ret t;
                }
            }
        }
        i = i + 1;
    }

    # allocate new target array if needed
    if (cfg.targets == nil) {
        val res: Result[*Target, allocator.AllocError] = alloc.alloc[Target](8);
        if (res.is_err()) {
            ret nil;
        }
        cfg.targets = res.unwrap_ok();
    } or (cfg.target_count >= 8) {
        # max 8 targets for now
        ret nil;
    }

    # initialize new target
    val idx: i32 = cfg.target_count;
    val t: *Target = ?cfg.targets[idx];
    t.name = name;
    t.os = target.tos_unknown();
    t.isa = target.tisa_unknown();
    t.abi = target.tabi_unknown();
    t.mode = target.tmode_executable();
    t.entrypoint = nil;
    t.artifacts = nil;
    t.binary = nil;
    cfg.target_count = idx + 1;

    ret t;
}

# parse_targets: parse [targets.*] entries from TOML document.
# ---
# cfg: config to populate
# doc: TOML document
# alloc: allocator
fun parse_targets(cfg: *Config, doc: *toml.Document, alloc: *allocator.Allocator) {
    if (cfg == nil || doc == nil || alloc == nil) {
        ret;
    }

    var i: usize = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (starts_with_prefix(e.key, "targets.")) {
            val tgt_name: str = extract_target_name(e.key);
            val field_name: str = extract_field_name(e.key);

            if (tgt_name != nil && field_name != nil) {
                val t: *Target = find_or_create_target(cfg, tgt_name, alloc);
                if (t != nil) {
                    val val_str: str = e.value.string;

                    if (field_name.equals("os")) {
                        t.os = target.parse_os(val_str);
                    } or (field_name.equals("isa")) {
                        t.isa = target.parse_isa(val_str);
                    } or (field_name.equals("abi")) {
                        t.abi = target.parse_abi(val_str);
                    } or (field_name.equals("mode")) {
                        t.mode = target.parse_mode(val_str);
                    } or (field_name.equals("entrypoint")) {
                        t.entrypoint = val_str;
                    } or (field_name.equals("artifacts")) {
                        t.artifacts = val_str;
                    } or (field_name.equals("binary")) {
                        t.binary = val_str;
                    }
                }
            }
        }
        i = i + 1;
    }
}

# parse_deps: parse [deps.*] entries from TOML document.
# ---
# cfg: config to populate
# doc: TOML document
# alloc: allocator
fun parse_deps(cfg: *Config, doc: *toml.Document, alloc: *allocator.Allocator) {
    if (cfg == nil || doc == nil || alloc == nil) {
        ret;
    }

    # count deps entries first
    var count: i32 = 0;
    var i: usize = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (starts_with_prefix(e.key, "deps.")) {
            # count unique dep names (entries like "deps.foo.path", "deps.foo.version")
            # for simplicity, count "deps.*.path" entries as one dep each
            val field_name: str = extract_field_name(e.key);
            if (field_name != nil && field_name.equals("path")) {
                count = count + 1;
            }
        }
        i = i + 1;
    }

    if (count == 0) {
        ret;
    }

    # allocate deps array
    val res: Result[*Dep, allocator.AllocError] = alloc.alloc[Dep](count::usize);
    if (res.is_err()) {
        ret;
    }
    cfg.deps = res.unwrap_ok();

    # parse deps
    var dep_idx: i32 = 0;
    i = 0;
    for (i < doc.len) {
        val e: *toml.Entry = ?doc.entries[i];
        if (starts_with_prefix(e.key, "deps.")) {
            val field_name: str = extract_field_name(e.key);

            # extract dep name (between "deps." and the field)
            if (field_name != nil && field_name.equals("path") && dep_idx < count) {
                # extract name: skip "deps." (5 chars), find next "."
                val key_after_deps: str = (e.key::usize + 5)::str;
                var name_end: usize = 0;
                for (key_after_deps[name_end] != 0 && key_after_deps[name_end] != 46) {
                    name_end = name_end + 1;
                }

                val d: *Dep = ?cfg.deps[dep_idx];
                d.name = key_after_deps;  # points into key string
                d.path = e.value.string;
                d.dep_type = DepTypeKind { remote: 0 };  # default to remote
                d.version = DepVersionKind { branch: "main" };

                dep_idx = dep_idx + 1;
            }
        }
        i = i + 1;
    }

    cfg.dep_count = dep_idx;
}

# load: load configuration from a mach.toml file.
# ---
# config_path: path to mach.toml file
# alloc:       allocator for memory allocations
# ret:         Ok(Config) on success, Err(str) with error message on failure
pub fun load(config_path: str, alloc: *allocator.Allocator) Result[Config, str] {
    if (config_path == nil) {
        ret err[Config, str]("config path is nil");
    }

    if (alloc == nil) {
        ret err[Config, str]("allocator is nil");
    }

    # open and read the file
    val open_res: Result[fs.File, str] = fs.open(config_path);
    if (open_res.is_err()) {
        ret err[Config, str](open_res.unwrap_err());
    }

    var file: fs.File = open_res.unwrap_ok();

    # get file size
    val stat_res: Result[fs.Stat, str] = file.stat();
    if (stat_res.is_err()) {
        file.close();
        ret err[Config, str](stat_res.unwrap_err());
    }

    val st: fs.Stat = stat_res.unwrap_ok();
    val file_size: usize = st.st_size::usize;

    # allocate buffer for file contents
    val buf_res: Result[*u8, allocator.AllocError] = alloc.alloc[u8](file_size + 1);
    if (buf_res.is_err()) {
        file.close();
        ret err[Config, str](buf_res.unwrap_err());
    }

    val buf: *u8 = buf_res.unwrap_ok();

    # read file contents
    val read_res: Result[usize, str] = file.read(buf, file_size);
    if (read_res.is_err()) {
        alloc.free[u8](buf, file_size + 1);
        file.close();
        ret err[Config, str](read_res.unwrap_err());
    }

    # null-terminate
    buf[file_size] = 0;
    file.close();

    # parse TOML
    val source: str = buf::&u8;
    val parse_res: Result[toml.Document, str] = toml.parse(alloc, source);
    if (parse_res.is_err()) {
        alloc.free[u8](buf, file_size + 1);
        ret err[Config, str](parse_res.unwrap_err());
    }

    val doc: toml.Document = parse_res.unwrap_ok();

    # extract configuration values
    var cfg: Config = init();

    cfg.id = get_entry_value(?doc, "project.id");
    cfg.name = get_entry_value(?doc, "project.name");
    cfg.version = get_entry_value(?doc, "project.version");

    val src: str = get_entry_value(?doc, "project.dir_src");
    if (src != nil) {
        cfg.dir_src = src;
    }

    val out: str = get_entry_value(?doc, "project.dir_out");
    if (out != nil) {
        cfg.dir_out = out;
    }

    val dep: str = get_entry_value(?doc, "project.dir_dep");
    if (dep != nil) {
        cfg.dir_dep = dep;
    }

    val tgt: str = get_entry_value(?doc, "project.target");
    if (tgt != nil) {
        cfg.target = tgt;
    }

    # parse [targets.*] sections
    parse_targets(?cfg, ?doc, alloc);

    # parse [deps.*] sections
    parse_deps(?cfg, ?doc, alloc);

    # note: we don't free buf here because strings in cfg point into it
    # the caller is responsible for calling deinit when done

    ret ok[Config, str](cfg);
}

# save: save configuration to a mach.toml file.
# ---
# cfg:  configuration to save
# path: path to write mach.toml
# ret:  Ok(true) on success, Err(str) with error message on failure
pub fun save(cfg: *Config, config_path: str) Result[bool, str] {
    if (cfg == nil) {
        ret err[bool, str]("config is nil");
    }

    if (config_path == nil) {
        ret err[bool, str]("path is nil");
    }

    # create/truncate the file
    val file_res: Result[fs.File, str] = fs.create(config_path, 420);  # 0644
    if (file_res.is_err()) {
        ret err[bool, str](file_res.unwrap_err());
    }

    var file: fs.File = file_res.unwrap_ok();

    # write [project] section
    file.write("[project]\n", 10);

    if (cfg.id != nil) {
        file.write("id      = \"", 11);
        file.write(cfg.id, cfg.id.len());
        file.write("\"\n", 2);
    }

    if (cfg.name != nil) {
        file.write("name    = \"", 11);
        file.write(cfg.name, cfg.name.len());
        file.write("\"\n", 2);
    }

    if (cfg.version != nil) {
        file.write("version = \"", 11);
        file.write(cfg.version, cfg.version.len());
        file.write("\"\n", 2);
    }

    file.write("\n", 1);

    if (cfg.dir_src != nil) {
        file.write("dir_src = \"", 11);
        file.write(cfg.dir_src, cfg.dir_src.len());
        file.write("\"\n", 2);
    }

    if (cfg.dir_out != nil) {
        file.write("dir_out = \"", 11);
        file.write(cfg.dir_out, cfg.dir_out.len());
        file.write("\"\n", 2);
    }

    if (cfg.dir_dep != nil) {
        file.write("dir_dep = \"", 11);
        file.write(cfg.dir_dep, cfg.dir_dep.len());
        file.write("\"\n", 2);
    }

    file.write("\n", 1);

    if (cfg.target != nil) {
        file.write("target  = \"", 11);
        file.write(cfg.target, cfg.target.len());
        file.write("\"\n", 2);
    }

    # write [targets.*] sections
    var i: i32 = 0;
    for (i < cfg.target_count) {
        val t: *Target = ?cfg.targets[i];
        if (t != nil && t.name != nil) {
            file.write("\n[targets.", 10);
            file.write(t.name, t.name.len());
            file.write("]\n", 2);

            if (t.entrypoint != nil) {
                file.write("entrypoint = \"", 14);
                file.write(t.entrypoint, t.entrypoint.len());
                file.write("\"\n", 2);
            }

            if (t.artifacts != nil) {
                file.write("artifacts  = \"", 14);
                file.write(t.artifacts, t.artifacts.len());
                file.write("\"\n", 2);
            }

            if (t.binary != nil) {
                file.write("binary     = \"", 14);
                file.write(t.binary, t.binary.len());
                file.write("\"\n", 2);
            }
        }
        i = i + 1;
    }

    # write [deps.*] sections
    i = 0;
    for (i < cfg.dep_count) {
        val d: *Dep = ?cfg.deps[i];
        if (d != nil && d.name != nil) {
            file.write("\n[deps.", 7);
            file.write(d.name, d.name.len());
            file.write("]\n", 2);

            if (d.path != nil) {
                file.write("path = \"", 8);
                file.write(d.path, d.path.len());
                file.write("\"\n", 2);
            }
        }
        i = i + 1;
    }

    file.close();
    ret ok[bool, str](true);
}

# get_target: find a target by name.
# ---
# cfg:  configuration to search
# name: target name to find
# ret:  Some(Target) if found, None if not found
pub fun get_target(cfg: *Config, name: str) Option[*Target] {
    if (cfg == nil || cfg.targets == nil) {
        ret none[*Target]();
    }

    var i: i32 = 0;
    for (i < cfg.target_count) {
        val t: *Target = ?cfg.targets[i];
        if (t.name != nil && t.name.equals(name)) {
            ret some[*Target](t);
        }
        i = i + 1;
    }

    ret none[*Target]();
}

# get_dep: find a dependency by name.
# ---
# cfg:  configuration to search
# name: dependency name to find
# ret:  Some(Dep) if found, None if not found
pub fun get_dep(cfg: *Config, name: str) Option[*Dep] {
    if (cfg == nil || cfg.deps == nil) {
        ret none[*Dep]();
    }

    var i: i32 = 0;
    for (i < cfg.dep_count) {
        val d: *Dep = ?cfg.deps[i];
        if (d.name != nil && d.name.equals(name)) {
            ret some[*Dep](d);
        }
        i = i + 1;
    }

    ret none[*Dep]();
}
