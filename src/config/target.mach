# mach.config.target: target configuration types.
# ---
# provides the TargetMode enumeration for build output modes.
# OS, ISA, and ABI are stored as plain strings in config.Target
# and resolved by compiler/target.select() at compilation time.

use std.types.bool;
use std.types.string;

# TargetMode tag constants
pub val TMODE_EXECUTABLE: u8 = 0;
pub val TMODE_LIBRARY:    u8 = 1;
pub val TMODE_SHARED:     u8 = 2;

# TargetMode: build output mode (tagged record pattern for enum-like behavior).
# ---
# tag: TMODE_EXECUTABLE, TMODE_LIBRARY, or TMODE_SHARED
pub rec TargetMode {
    tag: u8;
}

# TargetMode constructors
pub fun tmode_executable() TargetMode {
    ret TargetMode { tag: TMODE_EXECUTABLE };
}

pub fun tmode_library() TargetMode {
    ret TargetMode { tag: TMODE_LIBRARY };
}

pub fun tmode_shared() TargetMode {
    ret TargetMode { tag: TMODE_SHARED };
}

# parse_mode: parse a string into a TargetMode.
# ---
# s:   string to parse (e.g. "executable", "library", "shared")
# ret: corresponding TargetMode or executable as default
pub fun parse_mode(s: str) TargetMode {
    if (s == nil) {
        ret tmode_executable();
    }

    if (str_equals(s, "executable")) {
        ret tmode_executable();
    }

    if (str_equals(s, "library")) {
        ret tmode_library();
    }

    if (str_equals(s, "shared")) {
        ret tmode_shared();
    }

    ret tmode_executable();
}

# mode_to_str: convert a TargetMode to its string representation.
# ---
# mode: target mode to convert
# ret:  string name of the mode
pub fun mode_to_str(mode: TargetMode) str {
    if (mode.tag == TMODE_EXECUTABLE) {
        ret "executable";
    }
    if (mode.tag == TMODE_LIBRARY) {
        ret "library";
    }
    if (mode.tag == TMODE_SHARED) {
        ret "shared";
    }
    ret "executable";
}
