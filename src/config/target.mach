use std.types.bool;
use std.types.string;
use std.types.option;

# mach.config.target: target configuration types.
# ---
# provides enumerations for target operating systems, instruction set
# architectures, ABIs, and build modes.

# TargetOS tag constants
pub val TOS_LINUX:   u8 = 0;
pub val TOS_DARWIN:  u8 = 1;
pub val TOS_WINDOWS: u8 = 2;
pub val TOS_UNKNOWN: u8 = 3;

# TargetOS: target operating system (tagged record pattern for enum-like behavior).
# ---
# tag: TOS_LINUX, TOS_DARWIN, TOS_WINDOWS, or TOS_UNKNOWN
pub rec TargetOS {
    tag: u8;
}

# TargetOS constructors
pub fun tos_linux() TargetOS {
    ret TargetOS { tag: TOS_LINUX };
}

pub fun tos_darwin() TargetOS {
    ret TargetOS { tag: TOS_DARWIN };
}

pub fun tos_windows() TargetOS {
    ret TargetOS { tag: TOS_WINDOWS };
}

pub fun tos_unknown() TargetOS {
    ret TargetOS { tag: TOS_UNKNOWN };
}

# TargetISA tag constants
pub val TISA_X86_64:  u8 = 0;
pub val TISA_AARCH64: u8 = 1;
pub val TISA_UNKNOWN: u8 = 2;

# TargetISA: target instruction set architecture (tagged record pattern for enum-like behavior).
# ---
# tag: TISA_X86_64, TISA_AARCH64, or TISA_UNKNOWN
pub rec TargetISA {
    tag: u8;
}

# TargetISA constructors
pub fun tisa_x86_64() TargetISA {
    ret TargetISA { tag: TISA_X86_64 };
}

pub fun tisa_aarch64() TargetISA {
    ret TargetISA { tag: TISA_AARCH64 };
}

pub fun tisa_unknown() TargetISA {
    ret TargetISA { tag: TISA_UNKNOWN };
}

# TargetABI tag constants
pub val TABI_SYSV64:  u8 = 0;
pub val TABI_WIN64:   u8 = 1;
pub val TABI_UNKNOWN: u8 = 2;

# TargetABI: target application binary interface (tagged record pattern for enum-like behavior).
# ---
# tag: TABI_SYSV64, TABI_WIN64, or TABI_UNKNOWN
pub rec TargetABI {
    tag: u8;
}

# TargetABI constructors
pub fun tabi_sysv64() TargetABI {
    ret TargetABI { tag: TABI_SYSV64 };
}

pub fun tabi_win64() TargetABI {
    ret TargetABI { tag: TABI_WIN64 };
}

pub fun tabi_unknown() TargetABI {
    ret TargetABI { tag: TABI_UNKNOWN };
}

# TargetMode tag constants
pub val TMODE_EXECUTABLE: u8 = 0;
pub val TMODE_LIBRARY:    u8 = 1;
pub val TMODE_SHARED:     u8 = 2;

# TargetMode: build output mode (tagged record pattern for enum-like behavior).
# ---
# tag: TMODE_EXECUTABLE, TMODE_LIBRARY, or TMODE_SHARED
pub rec TargetMode {
    tag: u8;
}

# TargetMode constructors
pub fun tmode_executable() TargetMode {
    ret TargetMode { tag: TMODE_EXECUTABLE };
}

pub fun tmode_library() TargetMode {
    ret TargetMode { tag: TMODE_LIBRARY };
}

pub fun tmode_shared() TargetMode {
    ret TargetMode { tag: TMODE_SHARED };
}

# parse_os: parse a string into a TargetOS.
# ---
# s:   string to parse (e.g. "linux", "darwin", "windows")
# ret: corresponding TargetOS or unknown if not recognized
pub fun parse_os(s: str) TargetOS {
    if (s == nil) {
        ret tos_unknown();
    }

    if (str_equals(s, "linux")) {
        ret tos_linux();
    }

    if (str_equals(s, "darwin")) {
        ret tos_darwin();
    }

    if (str_equals(s, "windows")) {
        ret tos_windows();
    }

    ret tos_unknown();
}

# parse_isa: parse a string into a TargetISA.
# ---
# s:   string to parse (e.g. "x86_64", "aarch64")
# ret: corresponding TargetISA or unknown if not recognized
pub fun parse_isa(s: str) TargetISA {
    if (s == nil) {
        ret tisa_unknown();
    }

    if (str_equals(s, "x86_64")) {
        ret tisa_x86_64();
    }

    if (str_equals(s, "aarch64")) {
        ret tisa_aarch64();
    }

    ret tisa_unknown();
}

# parse_abi: parse a string into a TargetABI.
# ---
# s:   string to parse (e.g. "sysv64", "win64")
# ret: corresponding TargetABI or unknown if not recognized
pub fun parse_abi(s: str) TargetABI {
    if (s == nil) {
        ret tabi_unknown();
    }

    if (str_equals(s, "sysv64")) {
        ret tabi_sysv64();
    }

    if (str_equals(s, "win64")) {
        ret tabi_win64();
    }

    ret tabi_unknown();
}

# parse_mode: parse a string into a TargetMode.
# ---
# s:   string to parse (e.g. "executable", "library", "shared")
# ret: corresponding TargetMode or executable as default
pub fun parse_mode(s: str) TargetMode {
    if (s == nil) {
        ret tmode_executable();
    }

    if (str_equals(s, "executable")) {
        ret tmode_executable();
    }

    if (str_equals(s, "library")) {
        ret tmode_library();
    }

    if (str_equals(s, "shared")) {
        ret tmode_shared();
    }

    ret tmode_executable();
}

# os_to_str: convert a TargetOS to its string representation.
# ---
# os:  target OS to convert
# ret: string name of the OS
pub fun os_to_str(os: TargetOS) str {
    if (os.tag == TOS_LINUX) {
        ret "linux";
    }
    if (os.tag == TOS_DARWIN) {
        ret "darwin";
    }
    if (os.tag == TOS_WINDOWS) {
        ret "windows";
    }
    ret "unknown";
}

# isa_to_str: convert a TargetISA to its string representation.
# ---
# isa: target ISA to convert
# ret: string name of the ISA
pub fun isa_to_str(isa: TargetISA) str {
    if (isa.tag == TISA_X86_64) {
        ret "x86_64";
    }
    if (isa.tag == TISA_AARCH64) {
        ret "aarch64";
    }
    ret "unknown";
}

# abi_to_str: convert a TargetABI to its string representation.
# ---
# abi: target ABI to convert
# ret: string name of the ABI
pub fun abi_to_str(abi: TargetABI) str {
    if (abi.tag == TABI_SYSV64) {
        ret "sysv64";
    }
    if (abi.tag == TABI_WIN64) {
        ret "win64";
    }
    ret "unknown";
}

# mode_to_str: convert a TargetMode to its string representation.
# ---
# mode: target mode to convert
# ret:  string name of the mode
pub fun mode_to_str(mode: TargetMode) str {
    if (mode.tag == TMODE_EXECUTABLE) {
        ret "executable";
    }
    if (mode.tag == TMODE_LIBRARY) {
        ret "library";
    }
    if (mode.tag == TMODE_SHARED) {
        ret "shared";
    }
    ret "executable";
}
