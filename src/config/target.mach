use std.types.bool;
use std.types.string;
use std.types.option;

# mach.config.target: target configuration types.
# ---
# provides enumerations for target operating systems, instruction set
# architectures, ABIs, and build modes.

# TargetOS: target operating system.
# ---
# linux:   Linux
# darwin:  macOS
# windows: Windows
# unknown: unknown/unsupported OS
pub uni TargetOS {
    linux:   u8;
    darwin:  u8;
    windows: u8;
    unknown: u8;
}

# TargetISA: target instruction set architecture.
# ---
# x86_64:  AMD64/x86-64
# aarch64: ARM64
# unknown: unknown/unsupported ISA
pub uni TargetISA {
    x86_64:  u8;
    aarch64: u8;
    unknown: u8;
}

# TargetABI: target application binary interface.
# ---
# sysv64:  System V AMD64 ABI (Linux, macOS)
# win64:   Windows x64 ABI
# unknown: unknown/unsupported ABI
pub uni TargetABI {
    sysv64:  u8;
    win64:   u8;
    unknown: u8;
}

# TargetMode: build output mode.
# ---
# executable: standalone executable
# library:    static library
# shared:     shared/dynamic library
pub uni TargetMode {
    executable: u8;
    library:    u8;
    shared:     u8;
}

# parse_os: parse a string into a TargetOS.
# ---
# s:   string to parse (e.g. "linux", "darwin", "windows")
# ret: corresponding TargetOS or unknown if not recognized
pub fun parse_os(s: str) TargetOS {
    if (s == nil) {
        ret TargetOS { unknown: 0 };
    }

    if (s.equals("linux")) {
        ret TargetOS { linux: 0 };
    }

    if (s.equals("darwin")) {
        ret TargetOS { darwin: 0 };
    }

    if (s.equals("windows")) {
        ret TargetOS { windows: 0 };
    }

    ret TargetOS { unknown: 0 };
}

# parse_isa: parse a string into a TargetISA.
# ---
# s:   string to parse (e.g. "x86_64", "aarch64")
# ret: corresponding TargetISA or unknown if not recognized
pub fun parse_isa(s: str) TargetISA {
    if (s == nil) {
        ret TargetISA { unknown: 0 };
    }

    if (s.equals("x86_64")) {
        ret TargetISA { x86_64: 0 };
    }

    if (s.equals("aarch64")) {
        ret TargetISA { aarch64: 0 };
    }

    ret TargetISA { unknown: 0 };
}

# parse_abi: parse a string into a TargetABI.
# ---
# s:   string to parse (e.g. "sysv64", "win64")
# ret: corresponding TargetABI or unknown if not recognized
pub fun parse_abi(s: str) TargetABI {
    if (s == nil) {
        ret TargetABI { unknown: 0 };
    }

    if (s.equals("sysv64")) {
        ret TargetABI { sysv64: 0 };
    }

    if (s.equals("win64")) {
        ret TargetABI { win64: 0 };
    }

    ret TargetABI { unknown: 0 };
}

# parse_mode: parse a string into a TargetMode.
# ---
# s:   string to parse (e.g. "executable", "library", "shared")
# ret: corresponding TargetMode or executable as default
pub fun parse_mode(s: str) TargetMode {
    if (s == nil) {
        ret TargetMode { executable: 0 };
    }

    if (s.equals("executable")) {
        ret TargetMode { executable: 0 };
    }

    if (s.equals("library")) {
        ret TargetMode { library: 0 };
    }

    if (s.equals("shared")) {
        ret TargetMode { shared: 0 };
    }

    ret TargetMode { executable: 0 };
}

# os_to_str: convert a TargetOS to its string representation.
# ---
# os:  target OS to convert
# ret: string name of the OS
pub fun os_to_str(os: TargetOS) str {
    # TODO: implement union tag checking when available
    # for now, return a placeholder
    ret "unknown";
}

# isa_to_str: convert a TargetISA to its string representation.
# ---
# isa: target ISA to convert
# ret: string name of the ISA
pub fun isa_to_str(isa: TargetISA) str {
    # TODO: implement union tag checking when available
    ret "unknown";
}

# abi_to_str: convert a TargetABI to its string representation.
# ---
# abi: target ABI to convert
# ret: string name of the ABI
pub fun abi_to_str(abi: TargetABI) str {
    # TODO: implement union tag checking when available
    ret "unknown";
}

# mode_to_str: convert a TargetMode to its string representation.
# ---
# mode: target mode to convert
# ret:  string name of the mode
pub fun mode_to_str(mode: TargetMode) str {
    # TODO: implement union tag checking when available
    ret "executable";
}
