# mach.commands.run: run command implementation.
# ---
# runs a built Mach project executable.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use page:      std.allocator.page;
use print:     std.print;
use os:        std.system.os;

use args:     mach.cli.args;
use cmd_help: mach.commands.help;
use config:   mach.config.config;
use utilfs:   mach.util.filesystem;
use proc:     mach.util.process;

# RunOptions: parsed command-line options for run.
rec RunOptions {
    project_path: str;
    target_name:  str;
    exec_args:    &&u8;
    exec_argc:    i64;
    arg_start:    i64;
}

# parse_options: parse command-line arguments for run command.
# ---
# argc: argument count
# argv: argument vector
# ret: parsed RunOptions
fun parse_options(argc: i64, argv: &&u8) RunOptions {
    var opts: RunOptions;
    opts.project_path = ".";
    opts.target_name = nil;
    opts.exec_args = nil;
    opts.exec_argc = 0;
    opts.arg_start = argc;

    # argv[0] = "mach", argv[1] = "run", argv[2+] = options/path/args
    var i: i64 = 2;
    for (i < argc) {
        val arg: str = argv[i];

        # check for --target flag
        if (str_equals(arg, "--target")) {
            i = i + 1;
            if (i < argc) {
                opts.target_name = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --target=value format
        if (str_starts_with(arg, "--target=")) {
            opts.target_name = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # first non-flag positional is project path
        if (!str_starts_with(arg, "-")) {
            opts.project_path = arg;
            opts.arg_start = i + 1;
            brk;
        }

        i = i + 1;
    }

    # remaining args are for the executable
    if (opts.arg_start < argc) {
        opts.exec_argc = argc - opts.arg_start;
        opts.exec_args = (argv::usize + (opts.arg_start::usize * 8))::&&u8;
    }

    ret opts;
}

# execute_binary: execute a binary using fork/exec with inherited environment.
# ---
# binary_path: path to the executable
# argc: number of arguments to pass
# argv: argument array
# ret: exit code of the executed program
fun execute_binary(binary_path: str, argc: i64, argv: &&u8) i64 {
    val result: i64 = proc.run_binary(binary_path, argc, argv);
    if (result < 0) {
        print.eprintlnf("error: failed to execute '%s'", binary_path);
        ret 1;
    }
    ret result;
}

# handle: main entry point for the run command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    val opts: RunOptions = parse_options(argc, argv);

    # create allocator
    var alloc: allocator.Allocator;
    page.make(?alloc);

    # check for mach.toml in project directory
    val config_path: str = utilfs.path_join(opts.project_path, "mach.toml", ?alloc);
    if (config_path == nil || !utilfs.file_exists(config_path)) {
        print.eprintln("error: failed to find project root (no mach.toml)");
        ret 1;
    }

    # load configuration
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (is_err[config.Config, str](cfg_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = unwrap_ok[config.Config, str](cfg_res);

    # determine target
    var target_name: str = opts.target_name;
    if (target_name == nil) {
        target_name = cfg.target;
    }
    if (target_name != nil && str_equals(target_name, "native")) {
        target_name = nil; # auto-select first target
    }

    # look up target configuration and resolve binary path
    val out_dir: str = utilfs.path_join(opts.project_path, cfg.dir_out, ?alloc);
    var binary_path: str = nil;

    var target_cfg: *config.Target = nil;
    if (target_name != nil) {
        val t_opt: Option[*config.Target] = config.get_target(?cfg, target_name);
        if (is_some[*config.Target](t_opt)) {
            target_cfg = unwrap[*config.Target](t_opt);
        }
    }
    if (target_cfg == nil && cfg.targets != nil && cfg.target_count > 0) {
        target_cfg = ?cfg.targets[0];
    }
    if (target_cfg != nil && target_cfg.binary != nil) {
        binary_path = utilfs.path_join(out_dir, target_cfg.binary, ?alloc);
    }

    # fallback to default binary name
    if (binary_path == nil) {
        binary_path = utilfs.path_join(out_dir, "output", ?alloc);
    }

    if (binary_path == nil) {
        print.eprintln("error: could not determine binary path");
        ret 1;
    }

    # check if binary exists
    if (!utilfs.file_exists(binary_path)) {
        print.eprintlnf("error: binary not found: %s", binary_path);
        print.eprintln("hint: run 'mach build' first");
        ret 1;
    }

    # execute the binary
    val exit_code: i64 = execute_binary(binary_path, opts.exec_argc, opts.exec_args);

    ret exit_code;
}
