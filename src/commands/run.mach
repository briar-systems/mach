use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use print:     std.print;
use platform:  std.system.platform;

use args:     mach.cli.args;
use cmd_help: mach.commands.help;
use config:   mach.config.config;

# mach.commands.run: run command implementation.
# ---
# runs a built Mach project executable.

# RunOptions: parsed command-line options for run.
rec RunOptions {
    project_path: str;
    target_name:  str;
    exec_args:    &&u8;
    exec_argc:    i64;
    arg_start:    i64;
}

# parse_options: parse command-line arguments for run command.
# ---
# argc: argument count
# argv: argument vector
# ret: parsed RunOptions
fun parse_options(argc: i64, argv: &&u8) RunOptions {
    var opts: RunOptions;
    opts.project_path = ".";
    opts.target_name = nil;
    opts.exec_args = nil;
    opts.exec_argc = 0;
    opts.arg_start = argc;

    # argv[0] = "mach", argv[1] = "run", argv[2+] = options/path/args
    var i: i64 = 2;
    for (i < argc) {
        val arg: str = argv[i];

        # check for --target flag
        if (arg.equals("--target")) {
            i = i + 1;
            if (i < argc) {
                opts.target_name = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --target=value format
        if (arg.starts_with("--target=")) {
            opts.target_name = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # first non-flag positional is project path
        if (!arg.starts_with("-")) {
            opts.project_path = arg;
            opts.arg_start = i + 1;
            brk;
        }

        i = i + 1;
    }

    # remaining args are for the executable
    if (opts.arg_start < argc) {
        opts.exec_argc = argc - opts.arg_start;
        opts.exec_args = (argv::usize + (opts.arg_start::usize * 8))::&&u8;
    }

    ret opts;
}

# path_join: join two path components.
# ---
# base: base path
# rel: relative path to append
# alloc: allocator for result
# ret: joined path or nil on failure
fun path_join(base: str, rel: str, alloc: *allocator.Allocator) str {
    if (base == nil || rel == nil || alloc == nil) {
        ret nil;
    }

    val base_len: usize = base.len();
    val rel_len: usize = rel.len();
    val total: usize = base_len + 1 + rel_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = alloc.alloc[u8](total);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy base
    var j: usize = 0;
    for (j < base_len) {
        buf[pos] = base[j];
        pos = pos + 1;
        j = j + 1;
    }

    # add separator if needed
    if (base_len > 0 && base[base_len - 1] != 47) {  # '/'
        buf[pos] = 47;
        pos = pos + 1;
    }

    # copy rel
    j = 0;
    for (j < rel_len) {
        buf[pos] = rel[j];
        pos = pos + 1;
        j = j + 1;
    }

    buf[pos] = 0;
    ret buf::&u8;
}

# file_exists: check if a file exists.
# ---
# path: path to check
# ret: true if file exists
fun file_exists(path: str) bool {
    if (path == nil) {
        ret false;
    }

    val open_res: Result[fs.File, str] = fs.open(path);
    if (open_res.is_err()) {
        ret false;
    }

    var file: fs.File = open_res.unwrap_ok();
    file.close();
    ret true;
}

# execute_binary: execute a binary using fork/exec.
# ---
# binary_path: path to the executable
# argc: number of arguments to pass
# argv: argument array (null-terminated)
# ret: exit code of the executed program
fun execute_binary(binary_path: str, argc: i64, argv: &&u8) i64 {
    # fork the process
    val pid: i64 = platform.fork();

    if (pid < 0) {
        print.eprintln("error: failed to fork process");
        ret 1;
    }

    if (pid == 0) {
        # child process - execute the binary
        # build argv array: [binary_path, args..., NULL]
        var exec_argv: [64]&u8;
        exec_argv[0] = binary_path;

        var i: i64 = 0;
        for (i < argc && i < 62) {
            exec_argv[i + 1] = argv[i];
            i = i + 1;
        }
        exec_argv[i + 1] = nil;

        # empty environment (or could inherit from parent)
        var envp: [1]&u8;
        envp[0] = nil;

        val result: i64 = platform.execve(binary_path, ?exec_argv[0], ?envp[0]);

        # if execve returns, it failed
        print.eprint("error: failed to execute '");
        print.eprint(binary_path);
        print.eprintln("'");
        platform.terminate(1);
    }

    # parent process - wait for child
    var status: i32 = 0;
    val wait_result: i64 = platform.waitpid(pid, ?status, 0);

    if (wait_result < 0) {
        print.eprintln("error: failed to wait for process");
        ret 1;
    }

    if (platform.wifexited(status)) {
        ret platform.wexitstatus(status)::i64;
    } or (platform.wifsignaled(status)) {
        # process was terminated by a signal
        ret (128 + platform.wtermsig(status))::i64;
    }

    ret 1;
}

# handle: main entry point for the run command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    val opts: RunOptions = parse_options(argc, argv);

    # create allocator
    var alloc: allocator.Allocator = allocator.default();

    # check for mach.toml in project directory
    val config_path: str = path_join(opts.project_path, "mach.toml", ?alloc);
    if (config_path == nil || !file_exists(config_path)) {
        print.eprintln("error: failed to find project root (no mach.toml)");
        ret 1;
    }

    # load configuration
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (cfg_res.is_err()) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(cfg_res.unwrap_err());
        ret 1;
    }

    val cfg: config.Config = cfg_res.unwrap_ok();

    # determine target
    var target_name: str = opts.target_name;
    if (target_name == nil) {
        target_name = cfg.target;
    }
    if (target_name != nil && target_name.equals("native")) {
        target_name = nil; # auto-select first target
    }

    # look up target configuration
    # TODO: use config.get_target to find target-specific binary path
    # for now, use a default binary path pattern

    # construct binary path: <project>/out/<binary>
    # the binary path would come from the target configuration
    # for now, assume a default
    val out_dir: str = path_join(opts.project_path, cfg.dir_out, ?alloc);
    var binary_path: str = nil;

    # try to find the target and get its binary path
    if (cfg.targets != nil && cfg.target_count > 0) {
        # find matching target
        var i: i32 = 0;
        for (i < cfg.target_count) {
            val t: *config.Target = ?cfg.targets[i];
            if (t != nil && t.name != nil) {
                val matches: bool = target_name == nil || t.name.equals(target_name);
                if (matches && t.binary != nil) {
                    binary_path = path_join(out_dir, t.binary, ?alloc);
                    brk;
                }
            }
            i = i + 1;
        }
    }

    # fallback to default binary name
    if (binary_path == nil) {
        binary_path = path_join(out_dir, "output", ?alloc);
    }

    if (binary_path == nil) {
        print.eprintln("error: could not determine binary path");
        ret 1;
    }

    # check if binary exists
    if (!file_exists(binary_path)) {
        print.eprint("error: binary not found: ");
        print.eprintln(binary_path);
        print.eprintln("hint: run 'mach build' first");
        ret 1;
    }

    # execute the binary
    val exit_code: i64 = execute_binary(binary_path, opts.exec_argc, opts.exec_args);

    ret exit_code;
}
