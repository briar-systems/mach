use fmt: std.fmt;
use stream: std.stream;
use stdio: std.system.stdio;
use std.types.size;
use std.types.string;

pub fun handle(argc: i64, argv: &&u8) i64 {
    var w: stream.Writer = stdio.stderr();

    fmt.write_str(?w, "usage: mach <command> [args]\n");
    fmt.write_str(?w, "\n");
    fmt.write_str(?w, "commands:\n");
    fmt.write_str(?w, "  help\t show help\n");
    fmt.write_str(?w, "  lex\t lex a source file and print tokens\n");
    fmt.write_str(?w, "  parse\t parse a source file and print diagnostics\n");

    ret 0;
}
