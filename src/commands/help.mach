use std.types.string;

use print: std.print;

# mach.commands.help: help command implementation.
# ---
# provides general help and command-specific help output.

# print_general: print general usage and available commands.
# ---
# ret: none
pub fun print_general() {
    print.println("usage: mach <command> [options]");
    print.println("");
    print.println("commands:");
    print.println("  init  <name>         create a new Mach project");
    print.println("  build <path|file>    build a project or single file");
    print.println("  run   <path>         run a project executable");
    print.println("  test  <path>         run project tests");
    print.println("  dep   <subcommand>   manage project dependencies");
    print.println("");
    print.println("use 'mach help <command>' for more information on a specific command.");
}

# print_help: print help for the help command.
# ---
# ret: none
pub fun print_help() {
    print.println("usage: mach help <command>");
    print.println("");
    print.println("display help information for a specific command.");
}

# print_init: print help for the init command.
# ---
# ret: none
pub fun print_init() {
    print.println("usage: mach init <project_id>");
    print.println("");
    print.println("create a new Mach project in the current directory with the specified project ID.");
}

# print_build: print help for the build command.
# ---
# ret: none
pub fun print_build() {
    print.println("usage: mach build <project|file> [options]");
    print.println("");
    print.println("build a Mach project from the specified directory or compile a single Mach source file.");
    print.println("");
    print.println("options:");
    print.println("  --target <name>      select target from mach.toml (required for projects)");
    print.println("  -o <file>            output file (executable or object)");
    print.println("  -m <path>            set module path (e.g. 'std.print')");
    print.println("  -I n=dir             map module prefix 'n' to base directory 'dir'");
}

# print_run: print help for the run command.
# ---
# ret: none
pub fun print_run() {
    print.println("usage: mach run [--target <name>] <path> [args...]");
    print.println("");
    print.println("run the built executable for a Mach project.");
    print.println("");
    print.println("options:");
    print.println("  --target <name>      select target to run (default: default project target)");
    print.println("  [args...]            arguments to pass to the executable");
}

# print_test: print help for the test command.
# ---
# ret: none
pub fun print_test() {
    print.println("usage: mach test <path> [options]");
    print.println("");
    print.println("run project tests.");
    print.println("");
    print.println("options:");
    print.println("  --target <name>      select target for tests");
    print.println("  --filter <pattern>   filter tests by name pattern");
}

# print_dep: print help for the dep command.
# ---
# ret: none
pub fun print_dep() {
    print.println("usage: mach dep <subcommand> [options]");
    print.println("");
    print.println("manage project dependencies.");
    print.println("");
    print.println("subcommands:");
    print.println("  list                 list current dependencies");
    print.println("  info <name>          show dependency metadata");
    print.println("  tidy                 clean unused dependencies");
    print.println("  add <path> <name>    add a dependency");
    print.println("  del <name>           remove a dependency");
    print.println("  pull [name]          fetch/update dependencies");
    print.println("");
    print.println("options for 'add':");
    print.println("  --local              add as local dependency");
    print.println("  --version <version>  specify version (branch/main, ^1.2.3, etc.)");
}

# handle: main entry point for the help command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    # mach help (no subcommand)
    if (argc < 3) {
        print_general();
        ret 0;
    }

    val command: str = argv[2];

    if (str_equals(command, "init")) {
        print_init();
        ret 0;
    }

    if (str_equals(command, "build")) {
        print_build();
        ret 0;
    }

    if (str_equals(command, "run")) {
        print_run();
        ret 0;
    }

    if (str_equals(command, "test")) {
        print_test();
        ret 0;
    }

    if (str_equals(command, "dep")) {
        print_dep();
        ret 0;
    }

    if (str_equals(command, "help")) {
        print_help();
        ret 0;
    }

    print.eprint("error: unknown command '");
    print.eprint(command);
    print.eprintln("'");
    print_general();
    ret 1;
}
