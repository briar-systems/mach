# mach.commands.testing: test command implementation.
# ---
# discovers, compiles, and runs project tests.

# TestOptions: parsed command-line options for test.
rec TestOptions {
    project_path: str;
    target_name:  str;
    filter:       str;
}

# TestInfo: test metadata collected from AST.
rec TestInfo {
    name:    str;
    fn_name: str;
    body:    *ast.Node;
}

# TestList: dynamic list of tests.
rec TestList {
    items: *TestInfo;
    count: i32;
    cap:   i32;
}

# StringList: dynamic list of strings.
rec StringList {
    items: **u8;
    count: i32;
    cap:   i32;
}

# parse_options: parse command-line arguments for test command.
# ---
# argc: argument count
# argv: argument vector
# ret: parsed TestOptions
fun parse_options(argc: i64, argv: &&u8) TestOptions {
    var opts: TestOptions;
    opts.project_path = ".";
    opts.target_name = nil;
    opts.filter = nil;

    # argv[0] = "mach", argv[1] = "test", argv[2+] = options/path
    var i: i64 = 2;
    for (i < argc) {
        val arg: str = argv[i];

        # check for --target flag
        if (str_equals(arg, "--target")) {
            i = i + 1;
            if (i < argc) {
                opts.target_name = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --target=value format
        if (str_starts_with(arg, "--target=")) {
            opts.target_name = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # check for --filter flag
        if (str_equals(arg, "--filter")) {
            i = i + 1;
            if (i < argc) {
                opts.filter = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --filter=value format
        if (str_starts_with(arg, "--filter=")) {
            opts.filter = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # first non-flag positional is project path
        if (!str_starts_with(arg, "-")) {
            opts.project_path = arg;
        }

        i = i + 1;
    }

    ret opts;
}

# path_join: join two path components.
# ---
# base: base path
# rel: relative path to append
# alloc: allocator for result
# ret: joined path or nil on failure
fun path_join(base: str, rel: str, alloc: *allocator.Allocator) str {
    if (base == nil || rel == nil || alloc == nil) {
        ret nil;
    }

    val base_len: usize = str_len(base);
    val rel_len: usize = str_len(rel);
    val total: usize = base_len + 1 + rel_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret nil;
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);
    var pos: usize = 0;

    # copy base
    var j: usize = 0;
    for (j < base_len) {
        buf[pos] = base[j];
        pos = pos + 1;
        j = j + 1;
    }

    # add separator if needed
    if (base_len > 0 && base[base_len - 1] != 47) {  # '/'
        buf[pos] = 47;
        pos = pos + 1;
    }

    # copy rel
    j = 0;
    for (j < rel_len) {
        buf[pos] = rel[j];
        pos = pos + 1;
        j = j + 1;
    }

    buf[pos] = 0;
    ret buf::&u8;
}

# is_dot_entry: check if a directory entry is . or ..
fun is_dot_entry(name: str) bool {
    if (name == nil) {
        ret true;
    }
    if (name[0] == 46) {  # '.'
        if (name[1] == 0) {
            ret true;
        }
        if (name[1] == 46 && name[2] == 0) {
            ret true;
        }
    }
    ret false;
}

# string_list_init: create an empty StringList.
fun string_list_init() StringList {
    var list: StringList;
    list.items = nil;
    list.count = 0;
    list.cap = 0;
    ret list;
}

# string_list_append: append a string to the list (stores pointer).
fun string_list_append(list: *StringList, alloc: *allocator.Allocator, s: str) bool {
    if (list == nil || alloc == nil || s == nil) {
        ret false;
    }

    if (list.cap == 0) {
        val r: Result[**u8, allocator.AllocError] = allocator.allocator_alloc[*u8](alloc, 32);
        if (result_is_err[**u8, allocator.AllocError](r)) {
            ret false;
        }
        list.items = result_unwrap_ok[**u8, allocator.AllocError](r);
        list.cap = 32;
    } or (list.count >= list.cap) {
        val new_cap: i32 = list.cap * 2;
        val r2: Result[**u8, allocator.AllocError] = allocator.allocator_resize[*u8](alloc, list.items, list.cap::usize, new_cap::usize);
        if (result_is_err[**u8, allocator.AllocError](r2)) {
            ret false;
        }
        list.items = result_unwrap_ok[**u8, allocator.AllocError](r2);
        list.cap = new_cap;
    }

    list.items[list.count] = s::ptr;
    list.count = list.count + 1;
    ret true;
}

# list_files_recursive: collect all files under root directory.
fun list_files_recursive(root: str, alloc: *allocator.Allocator, out: *StringList) bool {
    if (root == nil || alloc == nil || out == nil) {
        ret false;
    }

    val dir_fd: i64 = pfs.openat(c.AT_FDCWD, root, c.O_RDONLY | c.O_DIRECTORY, 0);
    if (dir_fd < 0) {
        ret false;
    }

    # allocate buffer for directory entries
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, 4096);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        fs.file_close(pfs, dir_fd::i32);
        ret false;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    for {
    val nread: i64 = pfs.getdents64(dir_fd::i32, buf::ptr::*types.dirent64, 4096);
        if (nread <= 0) {
            brk;
        }

        var pos: usize = 0;
        for (pos < nread::usize) {
            val entry: *types.dirent64 = (buf::usize + pos)::*types.dirent64;
            val name: str = ?entry.d_name[0];

            if (!is_dot_entry(name)) {
                val full_path: str = path_join(root, name, alloc);
                if (full_path != nil) {
                    if (entry.d_type == 4) {  # DT_DIR
                        list_files_recursive(full_path, alloc, out);
                    } or {
                        string_list_append(out, alloc, full_path);
                    }
                }
            }

            pos = pos + entry.d_reclen::usize;
        }
    }

    fs.file_close(pfs, dir_fd::i32);
    ret true;
}

# test_list_init: create an empty TestList.
fun test_list_init() TestList {
    var list: TestList;
    list.items = nil;
    list.count = 0;
    list.cap = 0;
    ret list;
}

# test_list_append: append a test to the list.
fun test_list_append(list: *TestList, alloc: *allocator.Allocator, name: str, fn_name: str, body: *ast.Node) bool {
    if (list == nil || alloc == nil) {
        ret false;
    }

    if (list.cap == 0) {
        val r: Result[*TestInfo, allocator.AllocError] = allocator.allocator_alloc[TestInfo](alloc, 16);
        if (result_is_err[*TestInfo, allocator.AllocError](r)) {
            ret false;
        }
        list.items = result_unwrap_ok[*TestInfo, allocator.AllocError](r);
        list.cap = 16;
    }
    if (list.count >= list.cap) {
        val new_cap: i32 = list.cap * 2;
        val r2: Result[*TestInfo, allocator.AllocError] = allocator.allocator_resize[TestInfo](alloc, list.items, list.cap::usize, new_cap::usize);
        if (result_is_err[*TestInfo, allocator.AllocError](r2)) {
            ret false;
        }
        list.items = result_unwrap_ok[*TestInfo, allocator.AllocError](r2);
        list.cap = new_cap;
    }

    val idx: i32 = list.count;
    list.items[idx].name = name;
    list.items[idx].fn_name = fn_name;
    list.items[idx].body = body;
    list.count = list.count + 1;
    ret true;
}

# make_token helpers
fun make_tok_ident() tok.Token {
    ret tok.create_ident(0, 0);
}
fun make_tok_int() tok.Token {
    ret tok.create_int(0, 0);
}
fun make_tok_string() tok.Token {
    ret tok.create_string(0, 0);
}
fun make_tok_op(tag: u8) tok.Token {
    ret tok.create_punct(tag, 0, 0);
}

# make_node: allocate a node of the given kind.
fun make_node(alloc: *allocator.Allocator, kind: ast.NodeKind) *ast.Node {
    val r: Result[*ast.Node, str] = ast.create_node(alloc, kind, tok.create_error(0, 0));
    if (result_is_err[*ast.Node, str](r)) {
        ret nil;
    }
    ret result_unwrap_ok[*ast.Node, str](r);
}

# make_list: allocate a list.
fun make_list(alloc: *allocator.Allocator) *ast.List {
    val r: Result[*ast.List, str] = ast.create_list(alloc);
    if (result_is_err[*ast.List, str](r)) {
        ret nil;
    }
    ret result_unwrap_ok[*ast.List, str](r);
}

# make_type_name: create a type name node.
fun make_type_name(alloc: *allocator.Allocator, name: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_TYPE_NAME);
    if (n == nil) { ret nil; }
    n.info.type_name.path = name;
    ret n;
}

# make_ptr_type: create a pointer/ref type node.
fun make_ptr_type(alloc: *allocator.Allocator, base: *ast.Node, is_mutable: bool) *ast.Node {
    var kind: ast.NodeKind = ast.NODE_TYPE_REF;
    if (is_mutable) {
        kind = ast.NODE_TYPE_PTR;
    }
    val n: *ast.Node = make_node(alloc, kind);
    if (n == nil) { ret nil; }
    n.info.type_ptr.inner = base;
    ret n;
}

# make_ident: create identifier expression.
fun make_ident(alloc: *allocator.Allocator, name: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_IDENT);
    if (n == nil) { ret nil; }
    n.info.ident_expr.name = name;
    ret n;
}

# make_lit_int: create integer literal node with string content.
fun make_lit_int(alloc: *allocator.Allocator, value: i64) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_LIT_INT);
    if (n == nil) { ret nil; }

    # convert to string
    var buf: [32]u8;
    var pos: i32 = 31;
    buf[31] = 0;
    var v: i64 = value;
    var neg: bool = false;
    if (v < 0) {
        neg = true;
        v = -v;
    }
    if (v == 0) {
        buf[pos] = 48;
        pos = pos - 1;
    }
    for (v > 0 && pos >= 0) {
        val digit: i64 = v % 10;
        buf[pos] = (digit::u8 + 48);
        v = v / 10;
        pos = pos - 1;
    }
    if (neg && pos >= 0) {
        buf[pos] = 45; # '-'
        pos = pos - 1;
    }

    val start: i32 = pos + 1;
    val len: i32 = 32 - start;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, (len + 1)::usize);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret n; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var i: i32 = 0;
    for (i < len) {
        out[i] = buf[start + i];
        i = i + 1;
    }
    out[len] = 0;

    n.info.lit_expr.text = out::&u8;
    ret n;
}

# make_lit_string: create string literal node (data should include quotes).
fun make_lit_string(alloc: *allocator.Allocator, literal: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_LIT_STR);
    if (n == nil) { ret nil; }
    n.info.lit_expr.text = literal;
    ret n;
}

# make_binary: create binary expression node.
fun make_binary(alloc: *allocator.Allocator, op_tag: u8, left: *ast.Node, right: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_BINARY);
    if (n == nil) { ret nil; }
    n.info.binary_expr.op = op_tag;
    n.info.binary_expr.left = left;
    n.info.binary_expr.right = right;
    ret n;
}

# make_call: create call expression node.
fun make_call(alloc: *allocator.Allocator, name: str, args: *ast.List) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_CALL);
    if (n == nil) { ret nil; }
    val callee: *ast.Node = make_ident(alloc, name);
    n.info.call_expr.callee = callee;
    n.info.call_expr.args = args;
    ret n;
}

# make_stmt_expr: create expression statement.
fun make_stmt_expr(alloc: *allocator.Allocator, expr: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_EXPR);
    if (n == nil) { ret nil; }
    n.info.wrapper.inner = expr;
    ret n;
}

# make_var_stmt: create var declaration (with optional type + init).
fun make_var_stmt(alloc: *allocator.Allocator, name: str, typ: *ast.Node, init: *ast.Node, is_val: bool) *ast.Node {
    var kind: ast.NodeKind = ast.NODE_DECL_VAR;
    if (is_val) {
        kind = ast.NODE_DECL_VAL;
    }
    val n: *ast.Node = make_node(alloc, kind);
    if (n == nil) { ret nil; }
    n.info.var_decl.name = name;
    if (typ != nil) {
        n.info.var_decl.type_node = typ;
    }
    if (init != nil) {
        n.info.var_decl.init = init;
    }
    ret n;
}

# make_ret_stmt: create return statement.
fun make_ret_stmt(alloc: *allocator.Allocator, expr: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_RET);
    if (n == nil) { ret nil; }
    n.info.wrapper.inner = expr;
    ret n;
}

# make_block: create block with statements list.
fun make_block(alloc: *allocator.Allocator) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_BLOCK);
    if (n == nil) { ret nil; }
    val list: *ast.List = make_list(alloc);
    if (list == nil) { ret n; }
    n.info.block_stmt.stmts = list;
    ret n;
}

# block_append: append stmt to block.
fun block_append(alloc: *allocator.Allocator, block: *ast.Node, stmt: *ast.Node) {
    if (block == nil || stmt == nil) { ret; }
    val list: *ast.List = block.info.block_stmt.stmts;
    if (list == nil) { ret; }
    ast.list_append(list, alloc, stmt);
}

# make_param: create a parameter node.
fun make_param(alloc: *allocator.Allocator, name: str, typ: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_PARAM);
    if (n == nil) { ret nil; }
    n.info.field_decl.name = name;
    n.info.field_decl.type_node = typ;
    ret n;
}

# make_fun: create function node.
fun make_fun(alloc: *allocator.Allocator, name: str, params: *ast.List, ret_type: *ast.Node, body: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_DECL_FUN);
    if (n == nil) { ret nil; }
    n.info.fun_decl.name = name;
    n.info.fun_decl.params = params;
    n.info.fun_decl.ret_type = ret_type;
    n.info.fun_decl.body = body;
    ret n;
}

# make_if_stmt: create if with optional else block.
fun make_if_stmt(alloc: *allocator.Allocator, cond: *ast.Node, then_block: *ast.Node, else_block: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_IF);
    if (n == nil) { ret nil; }
    n.info.cond_stmt.cond = cond;
    n.info.cond_stmt.body = then_block;
    if (else_block != nil) {
        val or_node: *ast.Node = make_node(alloc, ast.NODE_STMT_OR);
        if (or_node != nil) {
            or_node.info.cond_stmt.body = else_block;
            n.info.cond_stmt.or_branch = or_node;
        }
    }
    ret n;
}

# make_masm_stmt: create inline asm statement.
fun make_masm_stmt(alloc: *allocator.Allocator, content: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_MASM);
    if (n == nil) { ret nil; }
    n.info.masm_stmt.content = content;
    ret n;
}


# sanitize_module_path: replace .,/,\ with _
fun sanitize_module_path(module_path: str, alloc: *allocator.Allocator) str {
    if (module_path == nil || alloc == nil) {
        ret "module";
    }
    val len: usize = str_len(module_path);
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret "module"; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: usize = 0;
    for (i < len) {
        val c: u8 = module_path[i];
        if (c == 46 || c == 47 || c == 92) {
            buf[i] = 95; # '_'
        } or {
            buf[i] = c;
        }
        i = i + 1;
    }
    buf[len] = 0;
    ret buf::&u8;
}

# make_test_fn_name: build __mach_test_<module>_<index>
fun make_test_fn_name(module_path: str, index: i32, alloc: *allocator.Allocator) str {
    val sanitized: str = sanitize_module_path(module_path, alloc);
    # build index string
    var buf: [16]u8;
    var pos: i32 = 15;
    var v: i32 = index;
    if (v == 0) {
        buf[pos] = 48;
        pos = pos - 1;
    }
    for (v > 0 && pos >= 0) {
        val digit: i32 = v % 10;
        buf[pos] = (digit::u8 + 48);
        v = v / 10;
        pos = pos - 1;
    }
    val start: i32 = pos + 1;
    buf[15] = 0;
    val idx_str: str = ?buf[start];

    # allocate output string
    val prefix: str = "__mach_test_";
    val total: usize = str_len(prefix) + str_len(sanitized) + 1 + str_len(idx_str) + 1;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) {
        ret "__mach_test";
    }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var p: usize = 0;
    var i: usize = 0;
    for (i < str_len(prefix)) {
        out[p] = prefix[i];
        p = p + 1;
        i = i + 1;
    }
    i = 0;
    for (i < str_len(sanitized)) {
        out[p] = sanitized[i];
        p = p + 1;
        i = i + 1;
    }
    out[p] = 95;
    p = p + 1; # '_'
    i = 0;
    for (i < str_len(idx_str)) {
        out[p] = idx_str[i];
        p = p + 1;
        i = i + 1;
    }
    out[p] = 0;
    ret out::&u8;
}

# build_mangled_symbol: build _M<path>N<name> mangled symbol for entry.
fun build_mangled_symbol(module_path: str, name: str, alloc: *allocator.Allocator) str {
    var module_path_local: str = module_path;
    if (module_path_local == nil) {
        module_path_local = "main";
    }
    if (name == nil) { ret nil; }

    # compute encoded length
    var encoded_len: usize = 0;
    var i: usize = 0;
    var seg_start: usize = 0;
    val mp_len: usize = str_len(module_path_local);
    for (i <= mp_len) {
        if (i == mp_len || module_path_local[i] == 46) {
            val seg_len: usize = i - seg_start;
            # length digits
            var tmp: usize = seg_len;
            var digits: usize = 1;
            for (tmp >= 10) {
                tmp = tmp / 10;
                digits = digits + 1;
            }
            encoded_len = encoded_len + digits + seg_len;
            seg_start = i + 1;
        }
        i = i + 1;
    }

    # name length digits
    var name_digits: usize = 1;
    var tmp2: usize = str_len(name);
    for (tmp2 >= 10) {
        tmp2 = tmp2 / 10;
        name_digits = name_digits + 1;
    }

    val total: usize = 2 + encoded_len + 1 + name_digits + str_len(name) + 1;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var p: usize = 0;
    out[p] = 95; p = p + 1; # '_'
    out[p] = 77; p = p + 1; # 'M'

    # append path segments
    i = 0; seg_start = 0;
    for (i <= mp_len) {
        if (i == mp_len || module_path_local[i] == 46) {
            val seg_len: usize = i - seg_start;
            # write length
            var tmp: usize = seg_len;
            var digits: [16]u8; var dpos: i32 = 0;
            if (tmp == 0) {
                digits[dpos] = 48;
                dpos = dpos + 1;
            }
            for (tmp > 0) {
                digits[dpos] = ((tmp % 10)::u8 + 48);
                dpos = dpos + 1;
                tmp = tmp / 10;
            }
            # reverse digits
            var j: i32 = dpos - 1;
            for (j >= 0) {
                out[p] = digits[j];
                p = p + 1;
                j = j - 1;
            }
            # write segment
            var k: usize = 0;
            for (k < seg_len) {
                out[p] = module_path[seg_start + k];
                p = p + 1;
                k = k + 1;
            }
            seg_start = i + 1;
        }
        i = i + 1;
    }

    out[p] = 78; p = p + 1; # 'N'

    # name length
    tmp2 = str_len(name);
    var digits2: [16]u8; var dpos2: i32 = 0;
    if (tmp2 == 0) {
        digits2[dpos2] = 48;
        dpos2 = dpos2 + 1;
    }
    for (tmp2 > 0) {
        digits2[dpos2] = ((tmp2 % 10)::u8 + 48);
        dpos2 = dpos2 + 1;
        tmp2 = tmp2 / 10;
    }
    var j2: i32 = dpos2 - 1;
    for (j2 >= 0) {
        out[p] = digits2[j2];
        p = p + 1;
        j2 = j2 - 1;
    }

    # name
    var n: usize = 0;
    for (n < str_len(name)) {
        out[p] = name[n];
        p = p + 1;
        n = n + 1;
    }

    out[p] = 0;
    ret out::&u8;
}

# program_has_fun_name: check for function name conflicts in program decls.
fun program_has_fun_name(program: *ast.Node, name: str) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }
    val decls: *ast.List = program.info.block_stmt.stmts;
    if (decls == nil) { ret false; }
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        var decl_node: *ast.Node = node;
        if (decl_node.kind == ast.NODE_DECL_PUB && decl_node.info.wrapper.inner != nil) {
            decl_node = decl_node.info.wrapper.inner;
        }

        if (decl_node != nil && decl_node.kind == ast.NODE_DECL_FUN) {
            val n: str = decl_node.info.fun_decl.name;
            if (n != nil && str_equals(n, name)) { ret true; }
        }
        i = i + 1;
    }
    ret false;
}

# build_test_write_fn: __mach_test_write(ptr: str, len: i64)
fun build_test_write_fn(alloc: *allocator.Allocator) *ast.Node {
    val params: *ast.List = make_list(alloc);
    if (params == nil) { ret nil; }

    val ptr_type: *ast.Node = make_type_name(alloc, "str");
    val len_type: *ast.Node = make_type_name(alloc, "i64");

    val param_ptr: *ast.Node = make_param(alloc, "ptr", ptr_type);
    val param_len: *ast.Node = make_param(alloc, "len", len_type);
    ast.list_append(params, alloc, param_ptr);
    ast.list_append(params, alloc, param_len);

    val body: *ast.Node = make_block(alloc);
    val masm_stmt: *ast.Node = make_masm_stmt(alloc,
        "x86_64 {\nmov rax, 1\nmov rdx, rsi\nmov rsi, rdi\nmov rdi, 1\nsyscall\n}\n"
    );
    block_append(alloc, body, masm_stmt);

    ret make_fun(alloc, "__mach_test_write", params, nil, body);
}

# build_test_main_fn: __mach_test_main() -> i64
fun build_test_main_fn(alloc: *allocator.Allocator, tests: *TestInfo, test_count: i32, types_ctx: *ty.TypeContext) *ast.Node {
    val body: *ast.Node = make_block(alloc);

    # var failures: i64 = 0;
    val failures_decl: *ast.Node = make_var_stmt(alloc, "failures", make_type_name(alloc, "i64"), make_lit_int(alloc, 0), false);
    block_append(alloc, body, failures_decl);

    var i: i32 = 0;
    for (i < test_count) {
        val info: *TestInfo = ?tests[i];

        # result = __mach_test_...()
        var result_name_buf: [64]u8;
        var pos: i32 = 0;
        val prefix: str = "__mach_test_result_";
        var k: usize = 0;
        for (k < str_len(prefix)) {
            result_name_buf[pos] = prefix[k];
            pos = pos + 1;
            k = k + 1;
        }
        # append index
        var v: i32 = i;
        var digits: [16]u8;
        var dpos: i32 = 0;
        if (v == 0) {
            digits[dpos] = 48;
            dpos = dpos + 1;
        }
        for (v > 0) {
            digits[dpos] = ((v % 10)::u8 + 48);
            dpos = dpos + 1;
            v = v / 10;
        }
        var j: i32 = dpos - 1;
        for (j >= 0) {
            result_name_buf[pos] = digits[j];
            pos = pos + 1;
            j = j - 1;
        }
        result_name_buf[pos] = 0;
        val result_name: str = ?result_name_buf[0];

        val call_test: *ast.Node = make_call(alloc, info.fn_name, make_list(alloc));
        val result_decl: *ast.Node = make_var_stmt(alloc, result_name, make_type_name(alloc, "i64"), call_test, false);
        block_append(alloc, body, result_decl);

        # if (result == 0) { ok } or { fail }
        val cond_zero: *ast.Node = make_lit_int(alloc, 0);
        if (cond_zero != nil && types_ctx != nil) {
            cond_zero.ty = ty.get_i64(types_ctx);
        }
        val cond: *ast.Node = make_binary(alloc, tok.TAG_EQ_EQ, make_ident(alloc, result_name), cond_zero);

        # then block
        val then_block: *ast.Node = make_block(alloc);
        val ok_args: *ast.List = make_list(alloc);
        val ok_len: *ast.Node = make_lit_int(alloc, 4);
        ast.list_append(ok_args, alloc, make_lit_string(alloc, "\"ok: \""));
        ast.list_append(ok_args, alloc, ok_len);
        val ok_call: *ast.Node = make_call(alloc, "__mach_test_write", ok_args);
        block_append(alloc, then_block, make_stmt_expr(alloc, ok_call));

        # else block
        val else_block: *ast.Node = make_block(alloc);
        val fail_args: *ast.List = make_list(alloc);
        val fail_len_node: *ast.Node = make_lit_int(alloc, 6);
        ast.list_append(fail_args, alloc, make_lit_string(alloc, "\"fail: \""));
        ast.list_append(fail_args, alloc, fail_len_node);
        val fail_call: *ast.Node = make_call(alloc, "__mach_test_write", fail_args);
        block_append(alloc, else_block, make_stmt_expr(alloc, fail_call));

        # print failing test name
        val fail_name: str = info.name;
        val fail_len: i64 = literal_string_len(fail_name);
        val fail_name_args: *ast.List = make_list(alloc);
        val fail_name_len_node: *ast.Node = make_lit_int(alloc, fail_len);
        ast.list_append(fail_name_args, alloc, make_lit_string(alloc, fail_name));
        ast.list_append(fail_name_args, alloc, fail_name_len_node);
        val fail_name_call: *ast.Node = make_call(alloc, "__mach_test_write", fail_name_args);
        block_append(alloc, else_block, make_stmt_expr(alloc, fail_name_call));

        val fail_nl_args: *ast.List = make_list(alloc);
        val fail_nl_len_node: *ast.Node = make_lit_int(alloc, 1);
        ast.list_append(fail_nl_args, alloc, make_lit_string(alloc, "\"\n\""));
        ast.list_append(fail_nl_args, alloc, fail_nl_len_node);
        val fail_nl_call: *ast.Node = make_call(alloc, "__mach_test_write", fail_nl_args);
        block_append(alloc, else_block, make_stmt_expr(alloc, fail_nl_call));

        # failures = failures + 1
        val fail_plus: *ast.Node = make_binary(alloc, tok.TAG_PLUS, make_ident(alloc, "failures"), make_lit_int(alloc, 1));
        val fail_assign: *ast.Node = make_binary(alloc, tok.TAG_EQ, make_ident(alloc, "failures"), fail_plus);
        block_append(alloc, else_block, make_stmt_expr(alloc, fail_assign));

        val if_stmt: *ast.Node = make_if_stmt(alloc, cond, then_block, else_block);
        block_append(alloc, body, if_stmt);

        # write test name + newline
        val name_literal: str = info.name;
        val name_len: i64 = literal_string_len(name_literal);
        val name_args: *ast.List = make_list(alloc);
        val name_len_node: *ast.Node = make_lit_int(alloc, name_len);
        ast.list_append(name_args, alloc, make_lit_string(alloc, name_literal));
        ast.list_append(name_args, alloc, name_len_node);
        val name_call: *ast.Node = make_call(alloc, "__mach_test_write", name_args);
        block_append(alloc, body, make_stmt_expr(alloc, name_call));

        val nl_args: *ast.List = make_list(alloc);
        val nl_len_node: *ast.Node = make_lit_int(alloc, 1);
        ast.list_append(nl_args, alloc, make_lit_string(alloc, "\"\\n\""));
        ast.list_append(nl_args, alloc, nl_len_node);
        val nl_call: *ast.Node = make_call(alloc, "__mach_test_write", nl_args);
        block_append(alloc, body, make_stmt_expr(alloc, nl_call));

        i = i + 1;
    }

    # return failures
    block_append(alloc, body, make_ret_stmt(alloc, make_ident(alloc, "failures")));

    ret make_fun(alloc, "__mach_test_main", make_list(alloc), make_type_name(alloc, "i64"), body);
}

# build_test_main_alias: main calls __mach_test_main
fun build_test_main_alias(alloc: *allocator.Allocator) *ast.Node {
    val body: *ast.Node = make_block(alloc);
    val call_main: *ast.Node = make_call(alloc, "__mach_test_main", make_list(alloc));
    block_append(alloc, body, make_ret_stmt(alloc, call_main));
    ret make_fun(alloc, "main", make_list(alloc), make_type_name(alloc, "i64"), body);
}

# literal_string_len: compute length of a string literal (strip quotes).
fun literal_string_len(lit: str) i64 {
    if (lit == nil) { ret 0; }
    val len: usize = str_len(lit);
    if (len >= 2 && lit[0] == 34 && lit[len - 1] == 34) { # '"'
        ret (len - 2)::i64;
    }
    ret len::i64;
}

# collect_tests: collect test declarations from program.
fun collect_tests(program: *ast.Node, module_path: str, alloc: *allocator.Allocator) TestList {
    var list: TestList = test_list_init();
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret list;
    }
    val decls: *ast.List = program.info.block_stmt.stmts;
    if (decls == nil) { ret list; }

    var i: i32 = 0;
    for (i < decls.count) {
        val stmt: *ast.Node = decls.nodes[i];
        if (stmt != nil && stmt.kind == ast.NODE_DECL_TEST) {
            val name: str = stmt.info.test_decl.name;
            val body: *ast.Node = stmt.info.test_decl.body;
            val fn_name: str = make_test_fn_name(module_path, list.count, alloc);
            test_list_append(?list, alloc, name, fn_name, body);
        }
        i = i + 1;
    }

    ret list;
}

# transform_tests: convert tests to functions + harness.
fun transform_tests(program: *ast.Node, module_path: str, alloc: *allocator.Allocator, types_ctx: *ty.TypeContext) i32 {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret 0;
    }

    val tests: TestList = collect_tests(program, module_path, alloc);
    if (tests.count <= 0) {
        ret 0;
    }

    # skip conflict checks for harness symbols to allow re-runs

    # build new declaration list: keep non-test decls, append test fns + harness
    val new_list: *ast.List = make_list(alloc);
    if (new_list == nil) { ret -1; }

    val decls: *ast.List = program.info.block_stmt.stmts;
    var i: i32 = 0;
    for (i < decls.count) {
        val stmt: *ast.Node = decls.nodes[i];
        if (stmt != nil && stmt.kind == ast.NODE_DECL_TEST) {
            i = i + 1;
            cnt;
        }
        ast.list_append(new_list, alloc, stmt);
        i = i + 1;
    }

    # add harness write function
    val write_decl: *ast.Node = build_test_write_fn(alloc);
    if (write_decl != nil) {
        ast.list_append(new_list, alloc, write_decl);
    }

    # add test functions
    var t: i32 = 0;
    for (t < tests.count) {
        val info: *TestInfo = ?tests.items[t];

        # append ret 0 to body
        val body: *ast.Node = info.body;
        if (body != nil && body.kind == ast.NODE_STMT_BLOCK) {
            val stmts: *ast.List = body.info.block_stmt.stmts;
            if (stmts != nil) {
                ast.list_append(stmts, alloc, make_ret_stmt(alloc, make_lit_int(alloc, 0)));
            }
        }

        val fn: *ast.Node = make_fun(alloc, info.fn_name, make_list(alloc), make_type_name(alloc, "i64"), body);
        ast.list_append(new_list, alloc, fn);
        t = t + 1;
    }

    # add harness fns
    ast.list_append(new_list, alloc, build_test_main_fn(alloc, tests.items, tests.count, types_ctx));
    if (!program_has_fun_name(program, "main")) {
        ast.list_append(new_list, alloc, build_test_main_alias(alloc));
    }

    program.info.block_stmt.stmts = new_list;
    ret tests.count;
}

# derive_module_path: compute module path from file path.
fun derive_module_path(project_root: str, cfg: *config.Config, file_path: str, alloc: *allocator.Allocator) str {
    if (project_root == nil || cfg == nil || file_path == nil) { ret nil; }
    if (cfg.id == nil) { ret nil; }

    val src_dir: str = path_join(project_root, cfg.dir_src, alloc);
    if (src_dir == nil) { ret nil; }

    if (!str_starts_with(file_path, src_dir)) {
        ret nil;
    }

    var rel: str = (file_path::usize + str_len(src_dir))::str;
    if (rel[0] == 47) { rel = (rel::usize + 1)::str; }

    # strip extension
    val rel_len: usize = str_len(rel);
    var end: usize = rel_len;
    if (rel_len >= 5 && str_ends_with(rel, ".mach")) {
        end = rel_len - 5;
    }

    # build rel_no_ext with path separators -> '.'
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, end + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: usize = 0;
    for (i < end) {
        val c: u8 = rel[i];
        if (c == 47 || c == 92) {
            buf[i] = 46;
        } or {
            buf[i] = c;
        }
        i = i + 1;
    }
    buf[end] = 0;
    val rel_no_ext: str = buf::&u8;

    # module_path = cfg.id + "." + rel_no_ext
    val total: usize = str_len(cfg.id) + 1 + str_len(rel_no_ext) + 1;
    val r2: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r2)) {
        ret nil;
    }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r2);
    var p: usize = 0;
    var k: usize = 0;
    for (k < str_len(cfg.id)) {
        out[p] = cfg.id[k];
        p = p + 1;
        k = k + 1;
    }
    out[p] = 46;
    p = p + 1;
    k = 0;
    for (k < str_len(rel_no_ext)) {
        out[p] = rel_no_ext[k];
        p = p + 1;
        k = k + 1;
    }
    out[p] = 0;
    ret out::&u8;
}

# build_test_output_path: compute output path for test binary.
fun build_test_output_path(project_root: str, cfg: *config.Config, target_cfg: *config.Target, file_path: str, alloc: *allocator.Allocator) str {
    if (project_root == nil || cfg == nil || target_cfg == nil || file_path == nil) {
        ret nil;
    }

    val src_root: str = path_join(project_root, cfg.dir_src, alloc);
    if (src_root == nil) { ret nil; }

    if (!str_starts_with(file_path, src_root)) { ret nil; }
    var rel: str = (file_path::usize + str_len(src_root))::str;
    if (rel[0] == 47) { rel = (rel::usize + 1)::str; }

    # strip extension
    val rel_len: usize = str_len(rel);
    var end: usize = rel_len;
    if (rel_len >= 5 && str_ends_with(rel, ".mach")) {
        end = rel_len - 5;
    }

    val out_root: str = path_join(project_root, cfg.dir_out, alloc);
    var artifacts: str = "linux";
    if (target_cfg.artifacts != nil) {
        artifacts = target_cfg.artifacts;
    }
    val out_target: str = path_join(out_root, artifacts, alloc);
    val tests_root: str = path_join(out_target, ".tests", alloc);

    # append rel path (without extension) + "_test" suffix
    val suffix: str = "_test";
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, str_len(tests_root) + 1 + end + str_len(suffix) + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var p: usize = 0;
    var i: usize = 0;
    for (i < str_len(tests_root)) {
        buf[p] = tests_root[i];
        p = p + 1;
        i = i + 1;
    }
    buf[p] = 47;
    p = p + 1;
    i = 0;
    for (i < end) {
        buf[p] = rel[i];
        p = p + 1;
        i = i + 1;
    }
    i = 0;
    for (i < str_len(suffix)) {
        buf[p] = suffix[i];
        p = p + 1;
        i = i + 1;
    }
    buf[p] = 0;
    ret buf::&u8;
}

# ensure_dir: mkdir -p via std.filesystem.
fun ensure_dir(path_str: str, alloc: *allocator.Allocator) bool {
    if (path_str == nil) { ret false; }
    if (alloc == nil) { ret false; }
    val len: usize = str_len(path_str);
    if (len == 0) { ret false; }

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) { ret false; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var i: usize = 0;
    for (i < len) {
        buf[i] = path_str[i];
        i = i + 1;
    }
    buf[len] = 0;

    i = 0;
    for (i < len) {
        if (buf[i] == 47 && i > 0) {
            val saved: u8 = buf[i];
            buf[i] = 0;
            val result: i64 = pfs.mkdirat(c.AT_FDCWD, buf::&u8, 0o755);
            if (result < 0 && result != c.EEXIST) {
                ret false;
            }
            buf[i] = saved;
        }
        i = i + 1;
    }

    val final_res: i64 = pfs.mkdirat(c.AT_FDCWD, buf::&u8, 0o755);
    if (final_res < 0 && final_res != c.EEXIST) {
        ret false;
    }

    ret true;
}

fun get_output_dir(file_path: str, alloc: *allocator.Allocator) str {
    if (file_path == nil || alloc == nil) { ret nil; }
    val len: usize = str_len(file_path);
    if (len == 0) { ret nil; }

    var i: usize = len;
    for (i > 0 && file_path[i - 1] != 47) {
        i = i - 1;
    }

    if (i == 0) { ret "."; }

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, i + 1);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var j: usize = 0;
    for (j < i) {
        buf[j] = file_path[j];
        j = j + 1;
    }
    buf[i] = 0;
    ret buf::&u8;
}

# execute_test_binary: execute a test binary and capture result.
# ---
# binary_path: path to the test executable
# ret: exit code of the test
fun execute_test_binary(binary_path: str) i32 {
    # fork the process
    val pid: i64 = platform.fork();

    if (pid < 0) {
        ret -1;
    }

    if (pid == 0) {
        # child process - execute the binary
        var exec_argv: [2]&u8;
        exec_argv[0] = binary_path;
        exec_argv[1] = nil;

        var envp: [1]&u8;
        envp[0] = nil;

        val result: i64 = platform.execve(binary_path, ?exec_argv[0], ?envp[0]);

        # if execve returns, it failed
        platform.terminate(127);
    }

    # parent process - wait for child
    var status: i32 = 0;
    val wait_result: i64 = platform.waitpid(pid, ?status, 0);

    if (wait_result < 0) {
        ret -1;
    }

    if (platform.wifexited(status)) {
        ret platform.wexitstatus(status);
    }

    if (platform.wifsignaled(status)) {
        # process was terminated by a signal
        ret 128 + platform.wtermsig(status);
    }

    ret -1;
}

# print_u32: print an unsigned 32-bit integer.
fun print_u32(n: u32) {
    if (n == 0) {
        print.print("0");
        ret;
    }

    var buf: [16]u8;
    var pos: i32 = 15;
    var num: u32 = n;

    for (num > 0 && pos >= 0) {
        buf[pos] = (num % 10)::u8 + 48;
        num = num / 10;
        pos = pos - 1;
    }

    pos = pos + 1;
    buf[15] = 0;

    var s: str = ?buf[pos];
    print.print(s);
}

# print_i32: print an i32 value to stderr.
fun print_i32(n: i32) {
    if (n < 0) {
        print.eprint("-");
        print_i32(-n);
        ret;
    }

    if (n == 0) {
        print.eprint("0");
        ret;
    }

    var buf: [16]u8;
    var len: i32 = 0;
    var num: i32 = n;

    for (num > 0) {
        buf[len] = (num % 10)::u8 + 48;
        num = num / 10;
        len = len + 1;
    }

    var i: i32 = 0;
    var j: i32 = len - 1;
    for (i < j) {
        val tmp: u8 = buf[i];
        buf[i] = buf[j];
        buf[j] = tmp;
        i = i + 1;
        j = j - 1;
    }

    buf[len] = 0;
    print.eprint(?buf[0]);
}

# print_parser_errors: print parser errors to stderr.
fun print_parser_errors(p: *parser.Parser) {
    if (p == nil) {
        print.eprintln("  (parser is nil)");
        ret;
    }

    print.eprint("  error_count = ");
    print_i32(p.error_count);
    print.eprintln("");

    print.eprint("  error_cap = ");
    print_i32(p.error_cap);
    print.eprintln("");

    print.eprint("  had_error = ");
    if (p.had_error) {
        print.eprintln("true");
    } or {
        print.eprintln("false");
    }

    print.eprint("  alloc = ");
    if (p.alloc == nil) {
        print.eprintln("nil (BUG!)");
    } or {
        print.eprintln("valid");
    }

    print.eprint("  errors ptr = ");
    if (p.errors == nil) {
        print.eprintln("nil");
    } or {
        print.eprintln("valid");
    }

    var i: i32 = 0;
    for (i < p.error_count) {
        val err: *parser.ParserError = ?p.errors[i];
        print.eprint("  ");
        print.eprint("pos ");
        print_i32(err.tok.pos);
        print.eprint(": ");
        print.eprintln(err.message);
        i = i + 1;
    }
}

# print_sema_errors: print semantic analysis errors to stderr.
fun print_sema_errors(sem: *sema.Sema) {
    if (sem == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < sem.error_count) {
        val err: *sema.SemaError = ?sem.errors[i];
        print.eprint("  ");
        if (err.file_path != nil) {
            print.eprint(err.file_path);
            print.eprint(":");
        }
        print_i32(err.line);
        print.eprint(": ");
        print.eprintln(err.message);
        i = i + 1;
    }
}

# handle: main entry point for the test command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    val opts: TestOptions = parse_options(argc, argv);

    # create arena-backed allocator for bulk allocation/deallocation
    var backing: allocator.Allocator = allocator.default();
    val arena_res: Result[arena.Arena, allocator.AllocError] = arena.init(backing, 67108864);
    if (result_is_err[arena.Arena, allocator.AllocError](arena_res)) {
        print.eprintln("error: failed to create arena allocator");
        ret 1;
    }
    var ar: arena.Arena = result_unwrap_ok[arena.Arena, allocator.AllocError](arena_res);
    var alloc: allocator.Allocator = arena.arena_allocator(ar);

    # find project root
    val root_res: Result[str, str] = utilfs.find_project_root(opts.project_path, ?alloc);
    if (result_is_err[str, str](root_res)) {
        print.eprintln("error: failed to find project root (no mach.toml)");
        ret 1;
    }
    val project_root: str = result_unwrap_ok[str, str](root_res);

    # load configuration
    val config_path: str = path_join(project_root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }
    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    # resolve target
    var target_cfg: *config.Target = nil;
    if (opts.target_name != nil) {
        val t_opt: Option[*config.Target] = config.get_target(?cfg, opts.target_name);
        if (option_is_some[*config.Target](t_opt)) { target_cfg = option_unwrap[*config.Target](t_opt); }
    }
    if (target_cfg == nil && cfg.target != nil && !str_equals(cfg.target, "native")) {
        val t_opt2: Option[*config.Target] = config.get_target(?cfg, cfg.target);
        if (option_is_some[*config.Target](t_opt2)) { target_cfg = option_unwrap[*config.Target](t_opt2); }
    }
    if (target_cfg == nil && cfg.targets != nil && cfg.target_count > 0) {
        target_cfg = ?cfg.targets[0];
    }
    if (target_cfg == nil) {
        print.eprintln("error: no targets found in mach.toml");
        ret 1;
    }

    # list source files
    val src_root: str = path_join(project_root, cfg.dir_src, ?alloc);
    val dep_root: str = path_join(project_root, cfg.dir_dep, ?alloc);
    if (src_root == nil) { ret 1; }
    var files: StringList = string_list_init();
    list_files_recursive(src_root, ?alloc, ?files);

    var total_tests: i32 = 0;
    var total_failures: i32 = 0;
    var compile_errors: i32 = 0;
    var had_error: bool = false;

    var i: i32 = 0;
    for (i < files.count) {
        val file_path: str = files.items[i]::str;
        if (!utilfs.is_mach_file(file_path)) {
            i = i + 1;
            cnt;
        }

        val module_path: str = derive_module_path(project_root, ?cfg, file_path, ?alloc);
        if (module_path == nil) {
            i = i + 1;
            cnt;
        }

        val source_res: Result[str, str] = utilfs.read_file(file_path, ?alloc);
        if (result_is_err[str, str](source_res)) {
            print.eprint("error: failed to read file: ");
            print.eprintln(file_path);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }
        val source: str = result_unwrap_ok[str, str](source_res);

        var p: parser.Parser = parser.init(source, ?alloc);
        val parse_res: Result[*ast.Node, str] = parser.parser_parse_program(p);
        if (result_is_err[*ast.Node, str](parse_res) || p.had_error) {
            print.eprint("error: parsing failed for '");
            print.eprint(file_path);
            print.eprintln("'");
            print_parser_errors(?p);
            parser.parser_deinit(p);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }
        val program: *ast.Node = result_unwrap_ok[*ast.Node, str](parse_res);

        var sem: sema.Sema = sema.init(?alloc);
        if (cfg.id != nil && src_root != nil) {
            sema.set_module_roots(?sem, cfg.id, src_root, dep_root, cfg.deps, cfg.dep_count);
        }

        val test_count: i32 = transform_tests(program, module_path, ?alloc, sema.get_type_context(?sem));
        if (test_count == 0) {
            parser.parser_deinit(sema, ?sem);
            parser.parser_deinit(p);
            i = i + 1;
            cnt;
        }
        if (test_count < 0) {
            parser.parser_deinit(sema, ?sem);
            parser.parser_deinit(p);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }

        val analyze_res: Result[bool, str] = sema.analyze(?sem, program, file_path, source, nil);
        if (result_is_err[bool, str](analyze_res) || parser.parser_has_errors(sema, ?sem)) {
            print.eprintln("error: semantic analysis failed");
            print_sema_errors(?sem);
            parser.parser_deinit(sema, ?sem);
            parser.parser_deinit(p);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }

        val symbols: *symbol.Table = sema.get_symbol_table(?sem);
        val types_ctx: *ty.TypeContext = sema.get_type_context(?sem);
        val tgt: target.Target = target.default_target();

        var loaded_mods: [256]*sema.SemaModule;
        val load_count: i32 = sema.get_loaded_modules(?sem, ?loaded_mods[0], 256);

        val lower_res: Result[*masm.Masm, str] = lower.lower_all_modules(program, symbols, types_ctx, ?alloc, tgt, ?loaded_mods[0], load_count, sem.method_insts, sem.func_insts, file_path, source);
        if (result_is_err[*masm.Masm, str](lower_res)) {
            print.eprintln("error: lowering failed");
            parser.parser_deinit(symbols);
            parser.parser_deinit(sema, ?sem);
            parser.parser_deinit(p);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }
        val m: *masm.Masm = result_unwrap_ok[*masm.Masm, str](lower_res);

        val output_path: str = build_test_output_path(project_root, ?cfg, target_cfg, file_path, ?alloc);
        if (output_path == nil) {
            print.eprintln("error: failed to compute output path");
            masm.destroy(m);
            parser.parser_deinit(symbols);
            parser.parser_deinit(sema, ?sem);
            parser.parser_deinit(p);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }

        # ensure output directory exists
    val out_dir: str = get_output_dir(output_path, ?alloc);
    if (out_dir != nil) {
        if (!ensure_dir(out_dir, ?alloc)) {
            print.eprint("error: output dir not created: ");
            print.eprintln(out_dir);
        }
    }

        val emit_res: Result[bool, str] = emit.emit_executable(m, output_path, ?alloc);
        if (result_is_err[bool, str](emit_res)) {
            print.eprint("error: failed to emit test binary: ");
            print.eprintln(result_unwrap_err[bool, str](emit_res));
            print.eprint("error: test output path: ");
            print.eprintln(output_path);
            masm.destroy(m);
            parser.parser_deinit(symbols);
            parser.parser_deinit(sema, ?sem);
            parser.parser_deinit(p);
            had_error = true;
            compile_errors = compile_errors + 1;
            i = i + 1;
            cnt;
        }

        # run test binary
        print.print("[test] ");
        print.print(module_path);
        print.print(" (");
        print_u32(test_count::u32);
        print.println(")");

        val exit_code: i32 = execute_test_binary(output_path);
        if (exit_code != 0) {
            print.print("[fail] ");
            print.print(module_path);
            print.print(" (");
            print_u32(exit_code::u32);
            print.println(")");
            total_failures = total_failures + 1;
        } or {
            print.print("[ok] ");
            print.println(module_path);
        }

        total_tests = total_tests + test_count;

        masm.destroy(m);
        parser.parser_deinit(symbols);
        parser.parser_deinit(sema, ?sem);
        parser.parser_deinit(p);

        i = i + 1;
    }

    parser.parser_deinit(ar);

    if (total_tests == 0) {
        if (had_error) { ret 1; }
        print.println("no tests found");
        ret 0;
    }

    if (compile_errors > 0) {
        print.print("tests: ");
        print_u32(total_tests::u32);
        print.print(", failures: ");
        print_u32(total_failures::u32);
        print.print(", compile errors: ");
        print_u32(compile_errors::u32);
        print.println("");
    } or {
        print.print("tests: ");
        print_u32(total_tests::u32);
        print.print(", failures: ");
        print_u32(total_failures::u32);
        print.println("");
    }

    if (total_failures != 0 || compile_errors != 0) {
        ret 1;
    }

    if (had_error) {
        ret 1;
    }
    ret 0;
}
