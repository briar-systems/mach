use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use print:     std.print;
use platform:  std.system.platform;

use args:     mach.cli.args;
use cmd_help: mach.commands.help;
use config:   mach.config.config;

# mach.commands.testing: test command implementation.
# ---
# discovers, compiles, and runs project tests.

# TestOptions: parsed command-line options for test.
rec TestOptions {
    project_path: str;
    target_name:  str;
    filter:       str;
}

# TestResult: result of running a single test.
rec TestResult {
    name:    str;
    passed:  bool;
    exit_code: i32;
}

# parse_options: parse command-line arguments for test command.
# ---
# argc: argument count
# argv: argument vector
# ret: parsed TestOptions
fun parse_options(argc: i64, argv: &&u8) TestOptions {
    var opts: TestOptions;
    opts.project_path = ".";
    opts.target_name = nil;
    opts.filter = nil;

    # argv[0] = "mach", argv[1] = "test", argv[2+] = options/path
    var i: i64 = 2;
    for (i < argc) {
        val arg: str = argv[i];

        # check for --target flag
        if (arg.equals("--target")) {
            i = i + 1;
            if (i < argc) {
                opts.target_name = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --target=value format
        if (arg.starts_with("--target=")) {
            opts.target_name = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # check for --filter flag
        if (arg.equals("--filter")) {
            i = i + 1;
            if (i < argc) {
                opts.filter = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --filter=value format
        if (arg.starts_with("--filter=")) {
            opts.filter = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # first non-flag positional is project path
        if (!arg.starts_with("-")) {
            opts.project_path = arg;
        }

        i = i + 1;
    }

    ret opts;
}

# path_join: join two path components.
# ---
# base: base path
# rel: relative path to append
# alloc: allocator for result
# ret: joined path or nil on failure
fun path_join(base: str, rel: str, alloc: *allocator.Allocator) str {
    if (base == nil || rel == nil || alloc == nil) {
        ret nil;
    }

    val base_len: usize = base.len();
    val rel_len: usize = rel.len();
    val total: usize = base_len + 1 + rel_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = alloc.alloc[u8](total);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy base
    var j: usize = 0;
    for (j < base_len) {
        buf[pos] = base[j];
        pos = pos + 1;
        j = j + 1;
    }

    # add separator if needed
    if (base_len > 0 && base[base_len - 1] != 47) {  # '/'
        buf[pos] = 47;
        pos = pos + 1;
    }

    # copy rel
    j = 0;
    for (j < rel_len) {
        buf[pos] = rel[j];
        pos = pos + 1;
        j = j + 1;
    }

    buf[pos] = 0;
    ret buf::&u8;
}

# file_exists: check if a file exists.
# ---
# path: path to check
# ret: true if file exists
fun file_exists(path: str) bool {
    if (path == nil) {
        ret false;
    }

    val open_res: Result[fs.File, str] = fs.open(path);
    if (open_res.is_err()) {
        ret false;
    }

    var file: fs.File = open_res.unwrap_ok();
    file.close();
    ret true;
}

# execute_test_binary: execute a test binary and capture result.
# ---
# binary_path: path to the test executable
# ret: exit code of the test
fun execute_test_binary(binary_path: str) i32 {
    # fork the process
    val pid: i64 = platform.fork();

    if (pid < 0) {
        ret -1;
    }

    if (pid == 0) {
        # child process - execute the binary
        var exec_argv: [2]&u8;
        exec_argv[0] = binary_path;
        exec_argv[1] = nil;

        var envp: [1]&u8;
        envp[0] = nil;

        val result: i64 = platform.execve(binary_path, ?exec_argv[0], ?envp[0]);

        # if execve returns, it failed
        platform.terminate(127);
    }

    # parent process - wait for child
    var status: i32 = 0;
    val wait_result: i64 = platform.waitpid(pid, ?status, 0);

    if (wait_result < 0) {
        ret -1;
    }

    if (platform.wifexited(status)) {
        ret platform.wexitstatus(status);
    } or (platform.wifsignaled(status)) {
        # process was terminated by a signal
        ret 128 + platform.wtermsig(status);
    }

    ret -1;
}

# print_u32: print an unsigned 32-bit integer.
fun print_u32(n: u32) {
    if (n == 0) {
        print.print("0");
        ret;
    }

    var buf: [16]u8;
    var pos: i32 = 15;
    var num: u32 = n;

    for (num > 0 && pos >= 0) {
        buf[pos] = (num % 10)::u8 + 48;
        num = num / 10;
        pos = pos - 1;
    }

    pos = pos + 1;
    buf[15] = 0;

    var s: str = ?buf[pos];
    print.print(s);
}

# run_tests_from_binary: run the test binary and report results.
# ---
# binary_path: path to the compiled test binary
# ret: number of failures
fun run_tests_from_binary(binary_path: str) i32 {
    # the test binary is expected to:
    # - run all tests internally
    # - exit 0 if all pass, non-zero otherwise
    #
    # for a more detailed approach, the test harness would:
    # - enumerate test functions
    # - fork for each test
    # - collect individual results

    print.print("running tests from: ");
    print.println(binary_path);

    val exit_code: i32 = execute_test_binary(binary_path);

    if (exit_code == 0) {
        print.println("  all tests passed");
        ret 0;
    } or (exit_code == 127) {
        print.println("  error: could not execute test binary");
        ret 1;
    } or {
        print.print("  tests failed with exit code: ");
        print_u32(exit_code::u32);
        print.println("");
        ret 1;
    }
}

# handle: main entry point for the test command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    val opts: TestOptions = parse_options(argc, argv);

    # create allocator
    var alloc: allocator.Allocator = allocator.default();

    # check for mach.toml in project directory
    val config_path: str = path_join(opts.project_path, "mach.toml", ?alloc);
    if (config_path == nil || !file_exists(config_path)) {
        print.eprintln("error: failed to find project root (no mach.toml)");
        ret 1;
    }

    # load configuration
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (cfg_res.is_err()) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(cfg_res.unwrap_err());
        ret 1;
    }

    val cfg: config.Config = cfg_res.unwrap_ok();

    # for now, the self-hosted compiler's test command relies on:
    # 1. tests being compiled into the main binary
    # 2. or a separate test binary being built
    #
    # a full implementation would:
    # - scan source files for `test` declarations
    # - generate a test harness
    # - compile and run the harness
    #
    # for now, we look for a test binary in the output directory

    val out_dir: str = path_join(opts.project_path, cfg.dir_out, ?alloc);
    var test_binary: str = path_join(out_dir, "test", ?alloc);

    # also try <out_dir>/tests or <out_dir>/<project>_test
    if (!file_exists(test_binary)) {
        test_binary = path_join(out_dir, "tests", ?alloc);
    }

    if (!file_exists(test_binary)) {
        # try to use the main binary if it contains tests
        test_binary = path_join(out_dir, "output", ?alloc);
    }

    if (test_binary == nil || !file_exists(test_binary)) {
        print.eprintln("error: no test binary found");
        print.eprintln("hint: build tests with 'mach build' first");
        print.eprintln("      or ensure a test binary exists in the output directory");
        ret 1;
    }

    # apply filter if specified
    if (opts.filter != nil) {
        print.print("filter: ");
        print.println(opts.filter);
    }

    # run the tests
    val failures: i32 = run_tests_from_binary(test_binary);

    if (failures == 0) {
        print.println("");
        print.println("test result: ok");
        ret 0;
    }

    print.println("");
    print.print("test result: FAILED (");
    print_u32(failures::u32);
    print.println(" failures)");
    ret 1;
}
