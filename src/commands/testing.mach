# mach.commands.testing: test command implementation.
# ---
# discovers, compiles, and runs project tests.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use arena:     std.allocator.arena;
use print:     std.print;
use platform:  std.system.platform;

use args:     mach.cli.args;
use cmd_help: mach.commands.help;
use config:   mach.config.config;
use utilfs:   mach.util.filesystem;
use proc:     mach.util.process;

use ast:      mach.compiler.frontend.ast;
use parser:   mach.compiler.frontend.parser;
use target:   mach.compiler.target;
use tok:      mach.compiler.frontend.token;

use pipeline: mach.compiler.pipeline;

use c:        std.system.platform.linux.constants;
use pfs:      std.system.platform.filesystem;
use types:    std.system.platform.linux.types;

# TestOptions: parsed command-line options for test.
rec TestOptions {
    project_path:  str;
    target_name:   str;
    test_filter:   str;
    module_filter: str;
    verbose:       bool;
}

# ModuleEntry: discovered module with test count for two-pass execution.
rec ModuleEntry {
    file_path:      str;
    module_path:    str;
    matching_tests: i32;
}

# FailureEntry: tracks a single test failure for the results summary.
rec FailureEntry {
    module_path: str;
    test_name:   str;
}

# TestInfo: test metadata collected from AST.
rec TestInfo {
    name:    str;
    fn_name: str;
    body:    *ast.Node;
}

# TestList: dynamic list of tests.
rec TestList {
    items: *TestInfo;
    count: i32;
    cap:   i32;
}

# StringList: dynamic list of strings.
rec StringList {
    items: **u8;
    count: i32;
    cap:   i32;
}

# parse_options: parse command-line arguments for test command.
# ---
# argc: argument count
# argv: argument vector
# ret: parsed TestOptions
fun parse_options(argc: i64, argv: &&u8) TestOptions {
    var opts: TestOptions;
    opts.project_path = ".";
    opts.target_name = nil;
    opts.test_filter = nil;
    opts.module_filter = nil;
    opts.verbose = false;

    # argv[0] = "mach", argv[1] = "test", argv[2+] = options/path
    var i: i64 = 2;
    for (i < argc) {
        val arg: str = argv[i];

        # check for --help / -h
        if (str_equals(arg, "--help") || str_equals(arg, "-h")) {
            cmd_help.print_test();
            platform.terminate(0);
        }

        # check for --verbose / -v
        if (str_equals(arg, "--verbose") || str_equals(arg, "-v")) {
            opts.verbose = true;
            i = i + 1;
            cnt;
        }

        # check for --target flag
        if (str_equals(arg, "--target")) {
            i = i + 1;
            if (i < argc) {
                opts.target_name = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --target=value format
        if (str_starts_with(arg, "--target=")) {
            opts.target_name = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # check for --test flag
        if (str_equals(arg, "--test")) {
            i = i + 1;
            if (i < argc) {
                opts.test_filter = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --test=value format
        if (str_starts_with(arg, "--test=")) {
            opts.test_filter = (arg::usize + 7)::str;
            i = i + 1;
            cnt;
        }

        # check for --module flag
        if (str_equals(arg, "--module")) {
            i = i + 1;
            if (i < argc) {
                opts.module_filter = argv[i];
            }
            i = i + 1;
            cnt;
        }

        # check for --module=value format
        if (str_starts_with(arg, "--module=")) {
            opts.module_filter = (arg::usize + 9)::str;
            i = i + 1;
            cnt;
        }

        # first non-flag positional is project path
        if (!str_starts_with(arg, "-")) {
            opts.project_path = arg;
        }

        i = i + 1;
    }

    ret opts;
}

# string_list_init: create an empty StringList.
fun string_list_init() StringList {
    var list: StringList;
    list.items = nil;
    list.count = 0;
    list.cap = 0;
    ret list;
}

# string_list_append: append a string to the list (stores pointer).
fun string_list_append(list: *StringList, alloc: *allocator.Allocator, s: str) bool {
    if (list == nil || alloc == nil || s == nil) {
        ret false;
    }

    if (list.cap == 0) {
        val r: Result[**u8, allocator.AllocError] = allocator.allocator_alloc[*u8](alloc, 32);
        if (result_is_err[**u8, allocator.AllocError](r)) {
            ret false;
        }
        list.items = result_unwrap_ok[**u8, allocator.AllocError](r);
        list.cap = 32;
    } or (list.count >= list.cap) {
        val new_cap: i32 = list.cap * 2;
        val r2: Result[**u8, allocator.AllocError] = allocator.allocator_resize[*u8](alloc, list.items, list.cap::usize, new_cap::usize);
        if (result_is_err[**u8, allocator.AllocError](r2)) {
            ret false;
        }
        list.items = result_unwrap_ok[**u8, allocator.AllocError](r2);
        list.cap = new_cap;
    }

    list.items[list.count] = s::ptr;
    list.count = list.count + 1;
    ret true;
}

# list_files_recursive: collect all files under root directory.
fun list_files_recursive(root: str, alloc: *allocator.Allocator, out: *StringList) bool {
    if (root == nil || alloc == nil || out == nil) {
        ret false;
    }

    val dir_fd: i64 = pfs.openat(c.AT_FDCWD, root, c.O_RDONLY | c.O_DIRECTORY, 0);
    if (dir_fd < 0) {
        ret false;
    }

    # allocate buffer for directory entries
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, 4096);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        pfs.close(dir_fd::i32);
        ret false;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    for {
    val nread: i64 = pfs.getdents64(dir_fd::i32, buf::ptr::*types.dirent64, 4096);
        if (nread <= 0) {
            brk;
        }

        var pos: usize = 0;
        for (pos < nread::usize) {
            val entry: *types.dirent64 = (buf::usize + pos)::*types.dirent64;
            val name: str = ?entry.d_name[0];

            if (!utilfs.is_dot_entry(name)) {
                val full_path: str = utilfs.path_join(root, name, alloc);
                if (full_path != nil) {
                    if (entry.d_type == 4) {  # DT_DIR
                        list_files_recursive(full_path, alloc, out);
                    } or {
                        string_list_append(out, alloc, full_path);
                    }
                }
            }

            pos = pos + entry.d_reclen::usize;
        }
    }

    pfs.close(dir_fd::i32);
    ret true;
}

# test_list_init: create an empty TestList.
fun test_list_init() TestList {
    var list: TestList;
    list.items = nil;
    list.count = 0;
    list.cap = 0;
    ret list;
}

# test_list_append: append a test to the list.
fun test_list_append(list: *TestList, alloc: *allocator.Allocator, name: str, fn_name: str, body: *ast.Node) bool {
    if (list == nil || alloc == nil) {
        ret false;
    }

    if (list.cap == 0) {
        val r: Result[*TestInfo, allocator.AllocError] = allocator.allocator_alloc[TestInfo](alloc, 16);
        if (result_is_err[*TestInfo, allocator.AllocError](r)) {
            ret false;
        }
        list.items = result_unwrap_ok[*TestInfo, allocator.AllocError](r);
        list.cap = 16;
    }
    if (list.count >= list.cap) {
        val new_cap: i32 = list.cap * 2;
        val r2: Result[*TestInfo, allocator.AllocError] = allocator.allocator_resize[TestInfo](alloc, list.items, list.cap::usize, new_cap::usize);
        if (result_is_err[*TestInfo, allocator.AllocError](r2)) {
            ret false;
        }
        list.items = result_unwrap_ok[*TestInfo, allocator.AllocError](r2);
        list.cap = new_cap;
    }

    val idx: i32 = list.count;
    list.items[idx].name = name;
    list.items[idx].fn_name = fn_name;
    list.items[idx].body = body;
    list.count = list.count + 1;
    ret true;
}

# make_token helpers
fun make_tok_ident() tok.Token {
    ret tok.create_ident(0, 0);
}
fun make_tok_int() tok.Token {
    ret tok.create_int(0, 0);
}
fun make_tok_string() tok.Token {
    ret tok.create_string(0, 0);
}
fun make_tok_op(tag: u8) tok.Token {
    ret tok.create_punct(tag, 0, 0);
}

# make_node: allocate a node of the given kind.
fun make_node(alloc: *allocator.Allocator, kind: ast.NodeKind) *ast.Node {
    val r: Result[*ast.Node, str] = ast.create_node(alloc, kind, tok.create_error(0, 0));
    if (result_is_err[*ast.Node, str](r)) {
        ret nil;
    }
    ret result_unwrap_ok[*ast.Node, str](r);
}

# make_use_stmt: create a bare use declaration node (e.g., use std.runtime;).
fun make_use_stmt(alloc: *allocator.Allocator, path: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_DECL_USE);
    if (n == nil) { ret nil; }
    n.info.use_decl.path = path;
    n.info.use_decl.alias = nil;
    ret n;
}

# make_field_expr: create a field access expression (e.g., foo.bar).
fun make_field_expr(alloc: *allocator.Allocator, obj_name: str, field: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_FIELD);
    if (n == nil) { ret nil; }
    n.info.field_expr.object = make_ident(alloc, obj_name);
    n.info.field_expr.field = field;
    ret n;
}

# make_comptime_symbol: create $name.symbol = "value"; directive.
fun make_comptime_symbol(alloc: *allocator.Allocator, name: str, value: str) *ast.Node {
    val ct: *ast.Node = make_node(alloc, ast.NODE_COMPTIME);
    if (ct == nil) { ret nil; }
    val lhs: *ast.Node = make_field_expr(alloc, name, "symbol");
    val rhs: *ast.Node = make_lit_string(alloc, value);
    if (lhs == nil || rhs == nil) { ret nil; }
    val assign: *ast.Node = make_binary(alloc, tok.TAG_EQ, lhs, rhs);
    if (assign == nil) { ret nil; }
    ct.info.wrapper.inner = assign;
    ret ct;
}

# make_list: allocate a list.
fun make_list(alloc: *allocator.Allocator) *ast.List {
    val r: Result[*ast.List, str] = ast.create_list(alloc);
    if (result_is_err[*ast.List, str](r)) {
        ret nil;
    }
    ret result_unwrap_ok[*ast.List, str](r);
}

# make_type_name: create a type name node.
fun make_type_name(alloc: *allocator.Allocator, name: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_TYPE_NAME);
    if (n == nil) { ret nil; }
    n.info.type_name.path = name;
    ret n;
}

# make_ptr_type: create a pointer/ref type node.
fun make_ptr_type(alloc: *allocator.Allocator, base: *ast.Node, is_mutable: bool) *ast.Node {
    var kind: ast.NodeKind = ast.NODE_TYPE_REF;
    if (is_mutable) {
        kind = ast.NODE_TYPE_PTR;
    }
    val n: *ast.Node = make_node(alloc, kind);
    if (n == nil) { ret nil; }
    n.info.type_ptr.inner = base;
    ret n;
}

# make_ident: create identifier expression.
fun make_ident(alloc: *allocator.Allocator, name: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_IDENT);
    if (n == nil) { ret nil; }
    n.info.ident_expr.name = name;
    ret n;
}

# make_lit_int: create integer literal node with string content.
fun make_lit_int(alloc: *allocator.Allocator, value: i64) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_LIT_INT);
    if (n == nil) { ret nil; }

    # convert to string
    var buf: [32]u8;
    var pos: i32 = 31;
    buf[31] = '\0';
    var v: i64 = value;
    var neg: bool = false;
    if (v < 0) {
        neg = true;
        v = -v;
    }
    if (v == 0) {
        buf[pos] = '0';
        pos = pos - 1;
    }
    for (v > 0 && pos >= 0) {
        val digit: i64 = v % 10;
        buf[pos] = (digit::u8 + '0');
        v = v / 10;
        pos = pos - 1;
    }
    if (neg && pos >= 0) {
        buf[pos] = '-';
        pos = pos - 1;
    }

    val start: i32 = pos + 1;
    val len: i32 = 32 - start;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, (len + 1)::usize);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret n; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var i: i32 = 0;
    for (i < len) {
        out[i] = buf[start + i];
        i = i + 1;
    }
    out[len] = '\0';

    n.info.lit_expr.text = out::&u8;
    ret n;
}

# make_lit_string: create string literal node (data should include quotes).
fun make_lit_string(alloc: *allocator.Allocator, literal: str) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_LIT_STR);
    if (n == nil) { ret nil; }
    n.info.lit_expr.text = literal;
    ret n;
}

# make_binary: create binary expression node.
fun make_binary(alloc: *allocator.Allocator, op_tag: u8, left: *ast.Node, right: *ast.Node) *ast.Node {
    val r: Result[*ast.Node, str] = ast.create_node(alloc, ast.NODE_EXPR_BINARY, make_tok_op(op_tag));
    if (result_is_err[*ast.Node, str](r)) { ret nil; }
    val n: *ast.Node = result_unwrap_ok[*ast.Node, str](r);
    n.info.binary_expr.op = op_tag;
    n.info.binary_expr.left = left;
    n.info.binary_expr.right = right;
    ret n;
}

# make_call: create call expression node.
fun make_call(alloc: *allocator.Allocator, name: str, args: *ast.List) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_CALL);
    if (n == nil) { ret nil; }
    val callee: *ast.Node = make_ident(alloc, name);
    n.info.call_expr.callee = callee;
    n.info.call_expr.args = args;
    ret n;
}

# make_stmt_expr: create expression statement.
fun make_stmt_expr(alloc: *allocator.Allocator, expr: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_EXPR);
    if (n == nil) { ret nil; }
    n.info.wrapper.inner = expr;
    ret n;
}

# make_var_stmt: create var declaration (with optional type + init).
fun make_var_stmt(alloc: *allocator.Allocator, name: str, typ: *ast.Node, init: *ast.Node, is_val: bool) *ast.Node {
    var kind: ast.NodeKind = ast.NODE_DECL_VAR;
    if (is_val) {
        kind = ast.NODE_DECL_VAL;
    }
    val n: *ast.Node = make_node(alloc, kind);
    if (n == nil) { ret nil; }
    n.info.var_decl.name = name;
    if (typ != nil) {
        n.info.var_decl.type_node = typ;
    }
    if (init != nil) {
        n.info.var_decl.init = init;
    }
    ret n;
}

# make_ret_stmt: create return statement.
fun make_ret_stmt(alloc: *allocator.Allocator, expr: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_RET);
    if (n == nil) { ret nil; }
    n.info.wrapper.inner = expr;
    ret n;
}

# make_block: create block with statements list.
fun make_block(alloc: *allocator.Allocator) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_BLOCK);
    if (n == nil) { ret nil; }
    val list: *ast.List = make_list(alloc);
    if (list == nil) { ret n; }
    n.info.block_stmt.stmts = list;
    ret n;
}

# block_append: append stmt to block.
fun block_append(alloc: *allocator.Allocator, block: *ast.Node, stmt: *ast.Node) {
    if (block == nil || stmt == nil) { ret; }
    val list: *ast.List = block.info.block_stmt.stmts;
    if (list == nil) { ret; }
    ast.list_append(list, alloc, stmt);
}

# make_param: create a parameter node.
fun make_param(alloc: *allocator.Allocator, name: str, typ: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_PARAM);
    if (n == nil) { ret nil; }
    n.info.field_decl.name = name;
    n.info.field_decl.type_node = typ;
    ret n;
}

# make_fun: create function node.
fun make_fun(alloc: *allocator.Allocator, name: str, params: *ast.List, ret_type: *ast.Node, body: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_DECL_FUN);
    if (n == nil) { ret nil; }
    n.info.fun_decl.name = name;
    n.info.fun_decl.params = params;
    n.info.fun_decl.ret_type = ret_type;
    n.info.fun_decl.body = body;
    ret n;
}

# make_if_stmt: create if with optional else block.
fun make_if_stmt(alloc: *allocator.Allocator, cond: *ast.Node, then_block: *ast.Node, else_block: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_STMT_IF);
    if (n == nil) { ret nil; }
    n.info.cond_stmt.cond = cond;
    n.info.cond_stmt.body = then_block;
    if (else_block != nil) {
        val or_node: *ast.Node = make_node(alloc, ast.NODE_STMT_OR);
        if (or_node != nil) {
            or_node.info.cond_stmt.body = else_block;
            n.info.cond_stmt.or_branch = or_node;
        }
    }
    ret n;
}

# make_index: create index expression (e.g., argv[1]).
fun make_index(alloc: *allocator.Allocator, base: *ast.Node, index: *ast.Node) *ast.Node {
    val n: *ast.Node = make_node(alloc, ast.NODE_EXPR_INDEX);
    if (n == nil) { ret nil; }
    n.info.index_expr.base = base;
    n.info.index_expr.index = index;
    ret n;
}

# make_quoted_int_str: create a quoted integer string literal (e.g., index 42 -> "\"42\"").
fun make_quoted_int_str(alloc: *allocator.Allocator, value: i32) str {
    var digits: [16]u8;
    var dpos: i32 = 0;
    var v: i32 = value;
    if (v == 0) {
        digits[dpos] = '0';
        dpos = dpos + 1;
    }
    for (v > 0) {
        digits[dpos] = ((v % 10)::u8 + '0');
        dpos = dpos + 1;
        v = v / 10;
    }
    val total: usize = (dpos + 3)::usize;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret "\"0\""; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    out[0] = '"';
    var i: i32 = 0;
    var j: i32 = dpos - 1;
    for (j >= 0) {
        out[i + 1] = digits[j];
        i = i + 1;
        j = j - 1;
    }
    out[i + 1] = '"';
    out[i + 2] = '\0';
    ret out::&u8;
}

# int_to_str: convert integer to unquoted string (for argv passing).
fun int_to_str(alloc: *allocator.Allocator, value: i32) str {
    var digits: [16]u8;
    var dpos: i32 = 0;
    var v: i32 = value;
    if (v == 0) {
        digits[dpos] = '0';
        dpos = dpos + 1;
    }
    for (v > 0) {
        digits[dpos] = ((v % 10)::u8 + '0');
        dpos = dpos + 1;
        v = v / 10;
    }
    val total: usize = (dpos + 1)::usize;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret "0"; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: i32 = 0;
    var j: i32 = dpos - 1;
    for (j >= 0) {
        out[i] = digits[j];
        i = i + 1;
        j = j - 1;
    }
    out[i] = '\0';
    ret out::&u8;
}


# strip_quotes: remove surrounding quotes from a string.
fun strip_quotes(s: str, alloc: *allocator.Allocator) str {
    if (s == nil || alloc == nil) { ret s; }
    val len: usize = str_len(s);
    if (len < 2 || s[0] != '"' || s[len - 1] != '"') { ret s; }
    val inner_len: usize = len - 2;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, inner_len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret s; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: usize = 0;
    for (i < inner_len) {
        out[i] = s[i + 1];
        i = i + 1;
    }
    out[inner_len] = '\0';
    ret out::&u8;
}

# sanitize_module_path: replace .,/,\ with _
fun sanitize_module_path(module_path: str, alloc: *allocator.Allocator) str {
    if (module_path == nil || alloc == nil) {
        ret "module";
    }
    val len: usize = str_len(module_path);
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret "module"; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: usize = 0;
    for (i < len) {
        val ch: u8 = module_path[i];
        if (ch == '.' || ch == '/' || ch == '\\') {
            buf[i] = '_';
        } or {
            buf[i] = ch;
        }
        i = i + 1;
    }
    buf[len] = '\0';
    ret buf::&u8;
}

# make_test_fn_name: build __mach_test_<module>_<index>
fun make_test_fn_name(module_path: str, index: i32, alloc: *allocator.Allocator) str {
    val sanitized: str = sanitize_module_path(module_path, alloc);
    # build index string (digits written right-to-left, null terminator after)
    var buf: [17]u8;
    var pos: i32 = 15;
    var v: i32 = index;
    if (v == 0) {
        buf[pos] = '0';
        pos = pos - 1;
    }
    for (v > 0 && pos >= 0) {
        val digit: i32 = v % 10;
        buf[pos] = (digit::u8 + '0');
        v = v / 10;
        pos = pos - 1;
    }
    val start: i32 = pos + 1;
    buf[16] = '\0';
    val idx_str: str = ?buf[start];

    # allocate output string
    val prefix: str = "__mach_test_";
    val total: usize = str_len(prefix) + str_len(sanitized) + 1 + str_len(idx_str) + 1;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) {
        ret "__mach_test";
    }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var p: usize = 0;
    var i: usize = 0;
    for (i < str_len(prefix)) {
        out[p] = prefix[i];
        p = p + 1;
        i = i + 1;
    }
    i = 0;
    for (i < str_len(sanitized)) {
        out[p] = sanitized[i];
        p = p + 1;
        i = i + 1;
    }
    out[p] = '_';
    p = p + 1;
    i = 0;
    for (i < str_len(idx_str)) {
        out[p] = idx_str[i];
        p = p + 1;
        i = i + 1;
    }
    out[p] = '\0';
    ret out::&u8;
}

# build_mangled_symbol: build _M<path>N<name> mangled symbol for entry.
fun build_mangled_symbol(module_path: str, name: str, alloc: *allocator.Allocator) str {
    var module_path_local: str = module_path;
    if (module_path_local == nil) {
        module_path_local = "main";
    }
    if (name == nil) { ret nil; }

    # compute encoded length
    var encoded_len: usize = 0;
    var i: usize = 0;
    var seg_start: usize = 0;
    val mp_len: usize = str_len(module_path_local);
    for (i <= mp_len) {
        if (i == mp_len || module_path_local[i] == '.') {
            val seg_len: usize = i - seg_start;
            # length digits
            var tmp: usize = seg_len;
            var digits: usize = 1;
            for (tmp >= 10) {
                tmp = tmp / 10;
                digits = digits + 1;
            }
            encoded_len = encoded_len + digits + seg_len;
            seg_start = i + 1;
        }
        i = i + 1;
    }

    # name length digits
    var name_digits: usize = 1;
    var tmp2: usize = str_len(name);
    for (tmp2 >= 10) {
        tmp2 = tmp2 / 10;
        name_digits = name_digits + 1;
    }

    val total: usize = 2 + encoded_len + 1 + name_digits + str_len(name) + 1;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var p: usize = 0;
    out[p] = '_'; p = p + 1;
    out[p] = 'M'; p = p + 1;

    # append path segments
    i = 0; seg_start = 0;
    for (i <= mp_len) {
        if (i == mp_len || module_path_local[i] == '.') {
            val seg_len: usize = i - seg_start;
            # write length
            var tmp: usize = seg_len;
            var digits: [16]u8; var dpos: i32 = 0;
            if (tmp == 0) {
                digits[dpos] = '0';
                dpos = dpos + 1;
            }
            for (tmp > 0) {
                digits[dpos] = ((tmp % 10)::u8 + '0');
                dpos = dpos + 1;
                tmp = tmp / 10;
            }
            # reverse digits
            var j: i32 = dpos - 1;
            for (j >= 0) {
                out[p] = digits[j];
                p = p + 1;
                j = j - 1;
            }
            # write segment
            var k: usize = 0;
            for (k < seg_len) {
                out[p] = module_path_local[seg_start + k];
                p = p + 1;
                k = k + 1;
            }
            seg_start = i + 1;
        }
        i = i + 1;
    }

    out[p] = 'N'; p = p + 1;

    # name length
    tmp2 = str_len(name);
    var digits2: [16]u8; var dpos2: i32 = 0;
    if (tmp2 == 0) {
        digits2[dpos2] = '0';
        dpos2 = dpos2 + 1;
    }
    for (tmp2 > 0) {
        digits2[dpos2] = ((tmp2 % 10)::u8 + '0');
        dpos2 = dpos2 + 1;
        tmp2 = tmp2 / 10;
    }
    var j2: i32 = dpos2 - 1;
    for (j2 >= 0) {
        out[p] = digits2[j2];
        p = p + 1;
        j2 = j2 - 1;
    }

    # name
    var n: usize = 0;
    for (n < str_len(name)) {
        out[p] = name[n];
        p = p + 1;
        n = n + 1;
    }

    out[p] = '\0';
    ret out::&u8;
}

# program_has_fun_name: check for function name conflicts in program decls.
fun program_has_fun_name(program: *ast.Node, name: str) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }
    val decls: *ast.List = program.info.block_stmt.stmts;
    if (decls == nil) { ret false; }
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        var decl_node: *ast.Node = node;
        if (decl_node.kind == ast.NODE_DECL_PUB && decl_node.info.wrapper.inner != nil) {
            decl_node = decl_node.info.wrapper.inner;
        }

        if (decl_node != nil && decl_node.kind == ast.NODE_DECL_FUN) {
            val fn_name: str = decl_node.info.fun_decl.name;
            if (fn_name != nil && str_equals(fn_name, name)) { ret true; }
        }
        i = i + 1;
    }
    ret false;
}


# build_dispatch_main: generate main(argc, argv) that dispatches to individual tests.
# ---
# argv[1] selects which test to run by index. test fn returns non-zero=pass, 0=fail.
# main converts: pass -> exit 0, fail -> exit 1.
#
# generated code:
#   fun main(argc: i64, argv: &&u8) i64 {
#       if (argc < 2) { ret 1; }
#       val __mach_arg: str = argv[1];
#       if (str_equals(__mach_arg, "0")) { if (test_0() != 0) { ret 0; } ret 1; }
#       if (str_equals(__mach_arg, "1")) { if (test_1() != 0) { ret 0; } ret 1; }
#       ...
#       ret 1;
#   }
fun build_dispatch_main(alloc: *allocator.Allocator, tests: *TestInfo, test_count: i32) *ast.Node {
    # parameters: argc: i64, argv: &&u8
    val params: *ast.List = make_list(alloc);
    if (params == nil) { ret nil; }
    ast.list_append(params, alloc, make_param(alloc, "argc", make_type_name(alloc, "i64")));
    val u8_type: *ast.Node = make_type_name(alloc, "u8");
    val ref_u8: *ast.Node = make_ptr_type(alloc, u8_type, false);
    val ref_ref_u8: *ast.Node = make_ptr_type(alloc, ref_u8, false);
    ast.list_append(params, alloc, make_param(alloc, "argv", ref_ref_u8));

    val body: *ast.Node = make_block(alloc);

    # if (argc < 2) { ret 1; }
    val argc_check: *ast.Node = make_binary(alloc, tok.TAG_LT, make_ident(alloc, "argc"), make_lit_int(alloc, 2));
    val early_ret: *ast.Node = make_block(alloc);
    block_append(alloc, early_ret, make_ret_stmt(alloc, make_lit_int(alloc, 1)));
    block_append(alloc, body, make_if_stmt(alloc, argc_check, early_ret, nil));

    # val __mach_arg: str = argv[1];
    val argv_1: *ast.Node = make_index(alloc, make_ident(alloc, "argv"), make_lit_int(alloc, 1));
    val arg_decl: *ast.Node = make_var_stmt(alloc, "__mach_arg", make_type_name(alloc, "str"), argv_1, true);
    block_append(alloc, body, arg_decl);

    # dispatch: for each test, if (str_equals(__mach_arg, "N")) { ... }
    var i: i32 = 0;
    for (i < test_count) {
        val info: *TestInfo = ?tests[i];
        val quoted_idx: str = make_quoted_int_str(alloc, i);

        # condition: str_equals(__mach_arg, "N")
        val eq_args: *ast.List = make_list(alloc);
        ast.list_append(eq_args, alloc, make_ident(alloc, "__mach_arg"));
        ast.list_append(eq_args, alloc, make_lit_string(alloc, quoted_idx));
        val cond: *ast.Node = make_call(alloc, "str_equals", eq_args);

        # body: if (test_fn() != 0) { ret 0; } ret 1;
        val dispatch_body: *ast.Node = make_block(alloc);
        val call_test: *ast.Node = make_call(alloc, info.fn_name, make_list(alloc));
        val inner_cond: *ast.Node = make_binary(alloc, tok.TAG_BANG_EQ, call_test, make_lit_int(alloc, 0));
        val inner_then: *ast.Node = make_block(alloc);
        block_append(alloc, inner_then, make_ret_stmt(alloc, make_lit_int(alloc, 0)));
        block_append(alloc, dispatch_body, make_if_stmt(alloc, inner_cond, inner_then, nil));
        block_append(alloc, dispatch_body, make_ret_stmt(alloc, make_lit_int(alloc, 1)));

        block_append(alloc, body, make_if_stmt(alloc, cond, dispatch_body, nil));
        i = i + 1;
    }

    # ret 1; (invalid index fallback)
    block_append(alloc, body, make_ret_stmt(alloc, make_lit_int(alloc, 1)));

    ret make_fun(alloc, "main", params, make_type_name(alloc, "i64"), body);
}


# collect_tests: collect test declarations from program.
fun collect_tests(program: *ast.Node, module_path: str, alloc: *allocator.Allocator) TestList {
    var list: TestList = test_list_init();
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret list;
    }
    val decls: *ast.List = program.info.block_stmt.stmts;
    if (decls == nil) { ret list; }

    var i: i32 = 0;
    for (i < decls.count) {
        val stmt: *ast.Node = decls.nodes[i];
        if (stmt != nil && stmt.kind == ast.NODE_DECL_TEST) {
            val name: str = strip_quotes(stmt.info.test_decl.name, alloc);
            val body: *ast.Node = stmt.info.test_decl.body;
            val fn_name: str = make_test_fn_name(module_path, list.count, alloc);
            test_list_append(?list, alloc, name, fn_name, body);
        }
        i = i + 1;
    }

    ret list;
}

# apply_test_transform: convert collected tests to functions + dispatch main.
# ---
# takes an already-collected TestList (from collect_tests) and transforms the
# program AST to include test functions and a dispatch main.
fun apply_test_transform(program: *ast.Node, module_path: str, tests: TestList, alloc: *allocator.Allocator) i32 {
    if (program == nil || program.kind != ast.NODE_PROGRAM) { ret 0; }
    if (tests.count <= 0) { ret 0; }

    val new_list: *ast.List = make_list(alloc);
    if (new_list == nil) { ret -1; }

    # inject std.runtime for _start entry point
    val use_runtime: *ast.Node = make_use_stmt(alloc, "std.runtime");
    if (use_runtime != nil) {
        ast.list_append(new_list, alloc, use_runtime);
    }

    # inject std.types.string for str_equals used in dispatch main
    val use_string: *ast.Node = make_use_stmt(alloc, "std.types.string");
    if (use_string != nil) {
        ast.list_append(new_list, alloc, use_string);
    }

    # keep non-test declarations
    val decls: *ast.List = program.info.block_stmt.stmts;
    var i: i32 = 0;
    for (i < decls.count) {
        val stmt: *ast.Node = decls.nodes[i];
        if (stmt != nil && stmt.kind == ast.NODE_DECL_TEST) {
            i = i + 1;
            cnt;
        }
        ast.list_append(new_list, alloc, stmt);
        i = i + 1;
    }

    # add test functions (each test block becomes a fun returning i64)
    var t: i32 = 0;
    for (t < tests.count) {
        val info: *TestInfo = ?tests.items[t];

        # append ret 1 to body (fallback: reaching end without explicit ret = pass)
        val body: *ast.Node = info.body;
        if (body != nil && body.kind == ast.NODE_STMT_BLOCK) {
            val stmts: *ast.List = body.info.block_stmt.stmts;
            if (stmts != nil) {
                ast.list_append(stmts, alloc, make_ret_stmt(alloc, make_lit_int(alloc, 1)));
            }
        }

        val fn: *ast.Node = make_fun(alloc, info.fn_name, make_list(alloc), make_type_name(alloc, "i64"), body);
        ast.list_append(new_list, alloc, fn);
        t = t + 1;
    }

    # add dispatch main (argv[1] selects which test to run)
    if (!program_has_fun_name(program, "main")) {
        val main_sym: *ast.Node = make_comptime_symbol(alloc, "main", "\"main\"");
        if (main_sym != nil) {
            ast.list_append(new_list, alloc, main_sym);
        }
        val dispatch: *ast.Node = build_dispatch_main(alloc, tests.items, tests.count);
        if (dispatch != nil) {
            ast.list_append(new_list, alloc, dispatch);
        }
    }

    program.info.block_stmt.stmts = new_list;
    ret tests.count;
}

# derive_module_path: compute module path from file path.
fun derive_module_path(project_root: str, cfg: *config.Config, file_path: str, alloc: *allocator.Allocator) str {
    if (cfg == nil) { ret nil; }
    ret utilfs.derive_module_path(project_root, cfg.dir_src, cfg.id, file_path, alloc);
}

# build_test_output_path: compute output path for test binary.
fun build_test_output_path(project_root: str, cfg: *config.Config, target_cfg: *config.Target, file_path: str, alloc: *allocator.Allocator) str {
    if (project_root == nil || cfg == nil || target_cfg == nil || file_path == nil) {
        ret nil;
    }

    val src_root: str = utilfs.path_join(project_root, cfg.dir_src, alloc);
    if (src_root == nil) { ret nil; }

    if (!str_starts_with(file_path, src_root)) { ret nil; }
    var rel: str = (file_path::usize + str_len(src_root))::str;
    if (rel[0] == '/') { rel = (rel::usize + 1)::str; }

    # strip extension
    val rel_len: usize = str_len(rel);
    var end: usize = rel_len;
    if (rel_len >= 5 && str_ends_with(rel, ".mach")) {
        end = rel_len - 5;
    }

    val out_root: str = utilfs.path_join(project_root, cfg.dir_out, alloc);
    var artifacts: str = "default";
    if (target_cfg.artifacts != nil) {
        artifacts = target_cfg.artifacts;
    }
    val out_target: str = utilfs.path_join(out_root, artifacts, alloc);
    val tests_root: str = utilfs.path_join(out_target, ".tests", alloc);

    # append rel path (without extension) + "_test" suffix
    val suffix: str = "_test";
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, str_len(tests_root) + 1 + end + str_len(suffix) + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var p: usize = 0;
    var i: usize = 0;
    for (i < str_len(tests_root)) {
        buf[p] = tests_root[i];
        p = p + 1;
        i = i + 1;
    }
    buf[p] = '/';
    p = p + 1;
    i = 0;
    for (i < end) {
        buf[p] = rel[i];
        p = p + 1;
        i = i + 1;
    }
    i = 0;
    for (i < str_len(suffix)) {
        buf[p] = suffix[i];
        p = p + 1;
        i = i + 1;
    }
    buf[p] = '\0';
    ret buf::&u8;
}

# execute_single_test: run one test from a module binary by index.
# ---
# binary_path: path to the compiled test binary
# index_str:   test index as a string (e.g., "0", "1", ...)
# ret: 0 = pass, 1 = fail, >128 = signal, -1 = error
fun execute_single_test(binary_path: str, index_str: str) i32 {
    var argv: [3]&u8;
    argv[0] = binary_path;
    argv[1] = index_str;
    argv[2] = nil;

    val result: i64 = proc.run_command(?argv[0]);
    ret result::i32;
}

# count_digits: number of decimal digits in a non-negative integer.
fun count_digits(n: i32) i32 {
    var d: i32 = 1;
    var v: i32 = n;
    for (v >= 10) {
        v = v / 10;
        d = d + 1;
    }
    ret d;
}

# print_padded_int: print integer right-aligned to the given width.
fun print_padded_int(n: i32, width: i32) {
    val d: i32 = count_digits(n);
    var spaces: i32 = width - d;
    for (spaces > 0) {
        print.print(" ");
        spaces = spaces - 1;
    }
    print.printf("%d", n::i64);
}

# print_test_line: print a formatted test result line.
# format: [<module>] [<n/total>] [pass|fail] <test name>
fun print_test_line(module_path: str, test_num: i32, total: i32, passed: bool, test_name: str) {
    val width: i32 = count_digits(total);
    print.printf("[%s] [", module_path);
    print_padded_int(test_num, width);
    if (passed) {
        print.printf("/%d] [pass] %s\n", total::i64, test_name);
    } or {
        print.printf("/%d] [fail] %s\n", total::i64, test_name);
    }
}

# test_matches_filter: check if a test name matches the --test filter.
fun test_matches_filter(test_name: str, filter: str) bool {
    if (filter == nil) { ret true; }
    if (test_name == nil) { ret false; }
    ret str_contains(test_name, filter);
}

# module_matches_filter: check if a module path matches the --module filter.
fun module_matches_filter(module_path: str, filter: str) bool {
    if (filter == nil) { ret true; }
    if (module_path == nil) { ret false; }
    ret str_contains(module_path, filter);
}

# handle: main entry point for the test command.
# ---
# two-pass approach:
#   pass 1: discover modules, count matching tests for progress counter
#   pass 2: compile and execute each test individually
pub fun handle(argc: i64, argv: &&u8) i64 {
    val opts: TestOptions = parse_options(argc, argv);

    var backing: allocator.Allocator = allocator.default();
    val arena_res: Result[arena.Arena, allocator.AllocError] = arena.init(backing, 268435456);
    if (result_is_err[arena.Arena, allocator.AllocError](arena_res)) {
        print.eprintln("error: failed to create arena allocator");
        ret 1;
    }
    var ar: arena.Arena = result_unwrap_ok[arena.Arena, allocator.AllocError](arena_res);
    var alloc: allocator.Allocator = arena.arena_allocator(?ar);

    val root_res: Result[str, str] = utilfs.find_project_root(opts.project_path, ?alloc);
    if (result_is_err[str, str](root_res)) {
        print.eprintln("error: failed to find project root (no mach.toml)");
        ret 1;
    }
    val project_root: str = result_unwrap_ok[str, str](root_res);

    val config_path: str = utilfs.path_join(project_root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprintlnf("error: failed to load mach.toml: %s", result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }
    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    var target_cfg: *config.Target = nil;
    if (opts.target_name != nil) {
        val t_opt: Option[*config.Target] = config.get_target(?cfg, opts.target_name);
        if (option_is_some[*config.Target](t_opt)) { target_cfg = option_unwrap[*config.Target](t_opt); }
    }
    if (target_cfg == nil && cfg.target != nil && !str_equals(cfg.target, "native")) {
        val t_opt2: Option[*config.Target] = config.get_target(?cfg, cfg.target);
        if (option_is_some[*config.Target](t_opt2)) { target_cfg = option_unwrap[*config.Target](t_opt2); }
    }
    if (target_cfg == nil && cfg.targets != nil && cfg.target_count > 0) {
        target_cfg = ?cfg.targets[0];
    }
    if (target_cfg == nil) {
        print.eprintln("error: no targets found in mach.toml");
        ret 1;
    }

    val src_root: str = utilfs.path_join(project_root, cfg.dir_src, ?alloc);
    val dep_root: str = utilfs.path_join(project_root, cfg.dir_dep, ?alloc);
    if (src_root == nil) { ret 1; }
    var files: StringList = string_list_init();
    list_files_recursive(src_root, ?alloc, ?files);

    # --- pass 1: discover modules and count matching tests ---
    var modules: [512]ModuleEntry;
    var module_count: i32 = 0;
    var total_tests: i32 = 0;

    var i: i32 = 0;
    for (i < files.count) {
        val file_path: str = files.items[i]::str;
        if (!utilfs.is_mach_file(file_path)) {
            i = i + 1;
            cnt;
        }

        val module_path: str = derive_module_path(project_root, ?cfg, file_path, ?alloc);
        if (module_path == nil) {
            i = i + 1;
            cnt;
        }

        if (!module_matches_filter(module_path, opts.module_filter)) {
            i = i + 1;
            cnt;
        }

        val source_res: Result[str, str] = utilfs.read_file(file_path, ?alloc);
        if (result_is_err[str, str](source_res)) {
            i = i + 1;
            cnt;
        }
        val source: str = result_unwrap_ok[str, str](source_res);

        var p: parser.Parser = parser.init(source, ?alloc);
        val parse_res: Result[*ast.Node, str] = parser.parser_parse_program(?p);
        if (result_is_err[*ast.Node, str](parse_res) || p.had_error) {
            parser.parser_dnit(?p);
            i = i + 1;
            cnt;
        }
        val program: *ast.Node = result_unwrap_ok[*ast.Node, str](parse_res);
        val tests: TestList = collect_tests(program, module_path, ?alloc);
        parser.parser_dnit(?p);

        if (tests.count <= 0) {
            i = i + 1;
            cnt;
        }

        # count tests matching --test filter
        var matching: i32 = 0;
        var t: i32 = 0;
        for (t < tests.count) {
            if (test_matches_filter(tests.items[t].name, opts.test_filter)) {
                matching = matching + 1;
            }
            t = t + 1;
        }

        if (matching == 0) {
            i = i + 1;
            cnt;
        }

        if (module_count < 512) {
            modules[module_count].file_path = file_path;
            modules[module_count].module_path = module_path;
            modules[module_count].matching_tests = matching;
            module_count = module_count + 1;
        }
        total_tests = total_tests + matching;

        i = i + 1;
    }

    if (total_tests == 0) {
        print.println("no tests found");
        arena.arena_dnit(?ar);
        ret 0;
    }

    # --- resolve host target ---
    val host_res: Result[target.Target, str] = target.host(?alloc);
    if (result_is_err[target.Target, str](host_res)) {
        print.eprintln("error: failed to get host target");
        arena.arena_dnit(?ar);
        ret 1;
    }
    val host_target: target.Target = result_unwrap_ok[target.Target, str](host_res);

    # --- pass 2: compile and execute ---
    var total_passed: i32 = 0;
    var total_failed: i32 = 0;
    var compile_fail_count: i32 = 0;
    var runtime_fail_count: i32 = 0;
    var compile_failures: [512]FailureEntry;
    var runtime_failures: [512]FailureEntry;
    var had_output: bool = false;

    var m: i32 = 0;
    for (m < module_count) {
        val entry_file: str = modules[m].file_path;
        val module_total: i32 = modules[m].matching_tests;
        var module_test_num: i32 = 0;
        val entry_module: str = modules[m].module_path;

        val source_res2: Result[str, str] = utilfs.read_file(entry_file, ?alloc);
        if (result_is_err[str, str](source_res2)) {
            print.eprintlnf("error: failed to read file: %s", entry_file);
            m = m + 1;
            cnt;
        }
        val source2: str = result_unwrap_ok[str, str](source_res2);

        var p2: parser.Parser = parser.init(source2, ?alloc);
        val parse_res2: Result[*ast.Node, str] = parser.parser_parse_program(?p2);
        if (result_is_err[*ast.Node, str](parse_res2) || p2.had_error) {
            # compile failure: mark all matching tests as failed
            parser.parser_dnit(?p2);

            # re-parse just to get test names for the failure list
            var p3: parser.Parser = parser.init(source2, ?alloc);
            val parse_res3: Result[*ast.Node, str] = parser.parser_parse_program(?p3);
            var test_names_available: bool = false;
            var fail_tests: TestList = test_list_init();
            if (!result_is_err[*ast.Node, str](parse_res3) && !p3.had_error) {
                val prog3: *ast.Node = result_unwrap_ok[*ast.Node, str](parse_res3);
                fail_tests = collect_tests(prog3, entry_module, ?alloc);
                test_names_available = true;
            }
            parser.parser_dnit(?p3);

            var t: i32 = 0;
            if (test_names_available) {
                for (t < fail_tests.count) {
                    if (test_matches_filter(fail_tests.items[t].name, opts.test_filter)) {
                        module_test_num = module_test_num + 1;
                        total_failed = total_failed + 1;
                        print_test_line(entry_module, module_test_num, module_total, false, fail_tests.items[t].name);
                        if (compile_fail_count < 512) {
                            compile_failures[compile_fail_count].module_path = entry_module;
                            compile_failures[compile_fail_count].test_name = fail_tests.items[t].name;
                            compile_fail_count = compile_fail_count + 1;
                        }
                    }
                    t = t + 1;
                }
            } or {
                # parse failed entirely, use module name
                module_test_num = module_test_num + 1;
                total_failed = total_failed + 1;
                print_test_line(entry_module, module_test_num, module_total, false, "(parse error)");
                if (compile_fail_count < 512) {
                    compile_failures[compile_fail_count].module_path = entry_module;
                    compile_failures[compile_fail_count].test_name = "(parse error)";
                    compile_fail_count = compile_fail_count + 1;
                }
            }

            m = m + 1;
            cnt;
        }
        val program2: *ast.Node = result_unwrap_ok[*ast.Node, str](parse_res2);
        val tests2: TestList = collect_tests(program2, entry_module, ?alloc);

        val xform_count: i32 = apply_test_transform(program2, entry_module, tests2, ?alloc);
        if (xform_count < 0) {
            parser.parser_dnit(?p2);
            m = m + 1;
            cnt;
        }

        # compute output path before compile
        val output_path: str = build_test_output_path(project_root, ?cfg, target_cfg, entry_file, ?alloc);
        if (output_path == nil) {
            print.eprintln("error: failed to compute output path");
            parser.parser_dnit(?p2);
            m = m + 1;
            cnt;
        }

        val out_dir: str = utilfs.get_output_dir(output_path, ?alloc);
        if (out_dir != nil) {
            utilfs.ensure_dir(out_dir, ?alloc);
        }

        # compile
        var popts: pipeline.CompileOptions;
        popts.target = host_target;
        popts.alloc = ?alloc;
        popts.project_id = cfg.id;
        popts.src_root = src_root;
        popts.dep_root = dep_root;
        popts.deps = cfg.deps;
        popts.dep_count = cfg.dep_count;
        popts.enable_comptime = true;
        popts.output_path = output_path;

        val compile_res: Result[pipeline.CompileResult, str] = pipeline.compile_ast(
            program2, entry_file, entry_module, source2, ?popts);
        parser.parser_dnit(?p2);

        if (result_is_err[pipeline.CompileResult, str](compile_res)) {
            # compile failure after transform: mark matching tests as compile failures
            var t: i32 = 0;
            for (t < tests2.count) {
                if (test_matches_filter(tests2.items[t].name, opts.test_filter)) {
                    module_test_num = module_test_num + 1;
                    total_failed = total_failed + 1;
                    print_test_line(entry_module, module_test_num, module_total, false, tests2.items[t].name);
                    if (compile_fail_count < 512) {
                        compile_failures[compile_fail_count].module_path = entry_module;
                        compile_failures[compile_fail_count].test_name = tests2.items[t].name;
                        compile_fail_count = compile_fail_count + 1;
                    }
                }
                t = t + 1;
            }
            m = m + 1;
            cnt;
        }
        val result: pipeline.CompileResult = result_unwrap_ok[pipeline.CompileResult, str](compile_res);

        # execute each matching test individually
        var t: i32 = 0;
        for (t < tests2.count) {
            if (!test_matches_filter(tests2.items[t].name, opts.test_filter)) {
                t = t + 1;
                cnt;
            }

            if (had_output) {
                print.println("");
                had_output = false;
            }

            module_test_num = module_test_num + 1;
            val idx_str: str = int_to_str(?alloc, t);
            val exit_code: i32 = execute_single_test(output_path, idx_str);

            if (exit_code == 0) {
                # pass
                total_passed = total_passed + 1;
                if (opts.verbose) {
                    print_test_line(entry_module, module_test_num, module_total, true, tests2.items[t].name);
                    had_output = false;
                }
            } or (exit_code > 128) {
                # crashed (signal)
                total_failed = total_failed + 1;
                print_test_line(entry_module, module_test_num, module_total, false, tests2.items[t].name);
                print.printlnf("signal: %d", (exit_code - 128)::i64);
                had_output = true;
                if (runtime_fail_count < 512) {
                    runtime_failures[runtime_fail_count].module_path = entry_module;
                    runtime_failures[runtime_fail_count].test_name = tests2.items[t].name;
                    runtime_fail_count = runtime_fail_count + 1;
                }
            } or {
                # runtime failure
                total_failed = total_failed + 1;
                print_test_line(entry_module, module_test_num, module_total, false, tests2.items[t].name);
                had_output = false;
                if (runtime_fail_count < 512) {
                    runtime_failures[runtime_fail_count].module_path = entry_module;
                    runtime_failures[runtime_fail_count].test_name = tests2.items[t].name;
                    runtime_fail_count = runtime_fail_count + 1;
                }
            }

            t = t + 1;
        }

        m = m + 1;
    }

    # --- results summary ---
    print.println("");
    print.printlnf("[results] [pass] %d", total_passed::i64);
    print.printlnf("[results] [fail] %d", total_failed::i64);

    print.printlnf("[results] [fail] [compile] %d", compile_fail_count::i64);
    var c: i32 = 0;
    for (c < compile_fail_count) {
        print.printlnf("- %s: %s", compile_failures[c].module_path, compile_failures[c].test_name);
        c = c + 1;
    }

    print.printlnf("[results] [fail] [runtime] %d", runtime_fail_count::i64);
    var r: i32 = 0;
    for (r < runtime_fail_count) {
        print.printlnf("- %s: %s", runtime_failures[r].module_path, runtime_failures[r].test_name);
        r = r + 1;
    }

    arena.arena_dnit(?ar);

    if (total_failed > 0) {
        ret 1;
    }
    ret 0;
}
