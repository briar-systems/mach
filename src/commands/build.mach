use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use arena:     std.allocator.arena;
use fs:        std.filesystem;
use print:     std.print;
use pfs:       std.system.platform.filesystem;

use args:     mach.cli.args;
use cmd_help: mach.commands.help;
use config:   mach.config.config;
use ctarget:  mach.config.target;

use archive:  mach.compiler.masm.archive;
use emit:     mach.compiler.masm.emit;
use link:     mach.compiler.masm.link;
use masm:     mach.compiler.masm.masm;
use target:   mach.compiler.masm.target;

use pipeline: mach.compiler.pipeline;
use utilfs:   mach.util.filesystem;

# mach.commands.build: build command implementation.
# ---
# compiles a Mach project or single source file.

# BuildOptions: parsed command-line options for build.
rec BuildOptions {
    input_path:   str;
    output_path:  str;
    module_path:  str;
    target_name:  str;
    is_project:   bool;
}

# parse_options: parse command-line arguments for build command.
# ---
# a: args wrapper
# ret: parsed BuildOptions
fun parse_options(a: args.Args) BuildOptions {
    var opts: BuildOptions;
    opts.input_path = nil;
    opts.output_path = nil;
    opts.module_path = nil;
    opts.target_name = nil;
    opts.is_project = false;

    # argv[0] = "mach", argv[1] = "build", argv[2+] = options/input
    if (!args.args_has(a, 2)) {
        ret opts;
    }

    # first positional argument is the input path
    var i: i64 = 2;
    for (i < args.args_count(a)) {
        val arg_opt: Option[str] = args.args_get(a, i);
        if (option_is_none[str](arg_opt)) {
            i = i + 1;
            cnt;
        }

        val arg: str = option_unwrap[str](arg_opt);

        # check for flags
        if (str_equals(arg, "-o")) {
            i = i + 1;
            val val_opt: Option[str] = args.args_get(a, i);
            if (option_is_some[str](val_opt)) {
                opts.output_path = option_unwrap[str](val_opt);
            }
            i = i + 1;
            cnt;
        }

        if (str_equals(arg, "-m")) {
            i = i + 1;
            val val_opt: Option[str] = args.args_get(a, i);
            if (option_is_some[str](val_opt)) {
                opts.module_path = option_unwrap[str](val_opt);
            }
            i = i + 1;
            cnt;
        }

        if (str_equals(arg, "--target")) {
            i = i + 1;
            val val_opt: Option[str] = args.args_get(a, i);
            if (option_is_some[str](val_opt)) {
                opts.target_name = option_unwrap[str](val_opt);
            }
            i = i + 1;
            cnt;
        }

        # first non-flag is input path
        if (opts.input_path == nil && !str_starts_with(arg, "-")) {
            opts.input_path = arg;
        }

        i = i + 1;
    }

    ret opts;
}

# is_directory: check if a path is a directory.
# ---
# path: path to check
# ret: true if directory, false otherwise
fun is_directory(path: str) bool {
    if (path == nil) {
        ret false;
    }

    val open_res: Result[fs.File, str] = fs.open(path);
    if (result_is_err[fs.File, str](open_res)) {
        ret false;
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](open_res);

    var st: fs.Stat;
    val raw: i64 = pfs.fstat(file.fd, ?st);
    fs.file_close(?file);

    if (raw < 0) {
        ret false;
    }

    val buf: *u8 = (?st)::*u8;
    val raw_mode: u32 = buf[24]::u32 | (buf[25]::u32 << 8) | (buf[26]::u32 << 16) | (buf[27]::u32 << 24);

    ret (raw_mode & 0o170000) == 0o040000;
}

# derive_module_path: compute module path from project root + source file.
fun derive_module_path(project_root: str, cfg: *config.Config, file_path: str, alloc: *allocator.Allocator) str {
    if (project_root == nil || cfg == nil || file_path == nil || alloc == nil) {
        ret nil;
    }
    if (cfg.id == nil) { ret nil; }

    var src_dir_name: str = cfg.dir_src;
    if (src_dir_name == nil) {
        src_dir_name = "src";
    }
    val src_dir: str = utilfs.path_join(project_root, src_dir_name, alloc);
    if (src_dir == nil) { ret nil; }
    if (!str_starts_with(file_path, src_dir)) { ret nil; }

    var rel: str = (file_path::usize + str_len(src_dir))::str;
    if (rel[0] == 47) { rel = (rel::usize + 1)::str; }

    # strip extension
    val rel_len: usize = str_len(rel);
    var end: usize = rel_len;
    if (rel_len >= 5 && str_ends_with(rel, ".mach")) { end = rel_len - 5; }

    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, end + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: usize = 0;
    for (i < end) {
        val c: u8 = rel[i];
        if (c == 47 || c == 92) {
            buf[i] = 46;
        } or {
            buf[i] = c;
        }
        i = i + 1;
    }
    buf[end] = 0;
    val rel_no_ext: str = buf::&u8;

    val total: usize = str_len(cfg.id) + 1 + str_len(rel_no_ext) + 1;
    val r2: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r2)) {
        ret nil;
    }
    val out: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r2);
    var p: usize = 0;
    i = 0;
    for (i < str_len(cfg.id)) {
        out[p] = cfg.id[i];
        p = p + 1;
        i = i + 1;
    }
    out[p] = 46;
    p = p + 1;
    i = 0;
    for (i < str_len(rel_no_ext)) {
        out[p] = rel_no_ext[i];
        p = p + 1;
        i = i + 1;
    }
    out[p] = 0;
    ret out::&u8;
}

# to_compiler_target: convert config target to compiler target.
fun to_compiler_target(cfg_target: *config.Target) target.Target {
    var tgt: target.Target = target.default_target();
    if (cfg_target == nil) {
        ret tgt;
    }

    # os
    if (cfg_target.os.tag == ctarget.TOS_LINUX) {
        tgt.os = target.os_linux();
    } or (cfg_target.os.tag == ctarget.TOS_DARWIN) {
        tgt.os = target.os_darwin();
    } or (cfg_target.os.tag == ctarget.TOS_WINDOWS) {
        tgt.os = target.os_windows();
    } or {
        tgt.os = target.os_unknown();
    }

    # isa
    if (cfg_target.isa.tag == ctarget.TISA_X86_64) {
        tgt.isa = target.isa_x86_64();
        tgt.ptr_size = 8;
        tgt.ptr_align = 8;
    } or (cfg_target.isa.tag == ctarget.TISA_AARCH64) {
        tgt.isa = target.isa_aarch64();
        tgt.ptr_size = 8;
        tgt.ptr_align = 8;
    } or {
        tgt.isa = target.isa_unknown();
    }

    # abi
    if (cfg_target.abi.tag == ctarget.TABI_SYSV64) {
        tgt.abi = target.abi_sysv64();
    } or (cfg_target.abi.tag == ctarget.TABI_WIN64) {
        tgt.abi = target.abi_win64();
    } or {
        tgt.abi = target.abi_unknown();
    }

    tgt.endian_big = false;
    ret tgt;
}

# make_pipeline_opts: create CompileOptions from build parameters.
fun make_pipeline_opts(tgt: target.Target, alloc: *allocator.Allocator,
    project_id: str, src_root: str, dep_root: str,
    deps: *config.Dep, dep_count: i32) pipeline.CompileOptions {
    var opts: pipeline.CompileOptions;
    opts.target = tgt;
    opts.alloc = alloc;
    opts.project_id = project_id;
    opts.src_root = src_root;
    opts.dep_root = dep_root;
    opts.deps = deps;
    opts.dep_count = dep_count;
    opts.enable_comptime = true;
    ret opts;
}

# compile_source: compile source to an executable via the pipeline.
fun compile_source(source: str, file_path: str, module_path: str, output_path: str,
    alloc: *allocator.Allocator, tgt: target.Target,
    project_id: str, src_root: str, dep_root: str, deps: *config.Dep, dep_count: i32,
    obj_dir: str) i64 {

    val popts: pipeline.CompileOptions = make_pipeline_opts(tgt, alloc,
        project_id, src_root, dep_root, deps, dep_count);

    val res: Result[pipeline.CompileResult, str] = pipeline.compile(source, file_path, module_path, popts);
    if (result_is_err[pipeline.CompileResult, str](res)) {
        ret 1;
    }
    val result: pipeline.CompileResult = result_unwrap_ok[pipeline.CompileResult, str](res);

    # emit per-module .o files if requested
    if (obj_dir != nil) {
        utilfs.ensure_dir(obj_dir, alloc);
        var mi: i32 = 0;
        for (mi < result.module_count) {
            val obj_path: str = make_obj_path(obj_dir, result.modules[mi].mod_name, alloc);
            if (obj_path != nil) {
                emit.emit_object(result.modules[mi].m, obj_path, alloc);
            }
            mi = mi + 1;
        }
    }

    # check for unresolved symbols
    val unresolved_count: i32 = link.check_unresolved(result.masm);
    if (unresolved_count > 0) {
        print.eprintln("error: linking failed: unresolved symbols remain");
        masm.destroy(result.masm);
        ret 1;
    }

    # emit executable
    val emit_res: Result[bool, str] = emit.emit_executable(result.masm, output_path, alloc);
    if (result_is_err[bool, str](emit_res)) {
        print.eprint("error: code emission failed: ");
        print.eprintln(result_unwrap_err[bool, str](emit_res));
        masm.destroy(result.masm);
        ret 1;
    }

    masm.destroy(result.masm);

    print.print("compiled: ");
    print.println(output_path);

    ret 0;
}

# make_obj_path: build an object file path from obj_dir and module name.
fun make_obj_path(obj_dir: str, mod_name: str, alloc: *allocator.Allocator) str {
    if (obj_dir == nil || mod_name == nil || alloc == nil) {
        ret nil;
    }

    val dir_len: usize = str_len(obj_dir);
    val name_len: usize = str_len(mod_name);
    val total: usize = dir_len + 1 + name_len + 2 + 1;

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret nil;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var pos: usize = 0;
    var i: usize = 0;
    for (i < dir_len) {
        buf[pos] = obj_dir[i];
        pos = pos + 1;
        i = i + 1;
    }
    buf[pos] = 47;
    pos = pos + 1;
    i = 0;
    for (i < name_len) {
        buf[pos] = mod_name[i];
        pos = pos + 1;
        i = i + 1;
    }
    buf[pos] = 46; pos = pos + 1;
    buf[pos] = 111; pos = pos + 1;
    buf[pos] = 0;

    ret buf::str;
}

# compile_library: compile source into a static archive (.a) via the pipeline.
fun compile_library(source: str, file_path: str, module_path: str, output_path: str,
    alloc: *allocator.Allocator, tgt: target.Target,
    project_id: str, src_root: str, dep_root: str, deps: *config.Dep, dep_count: i32,
    obj_dir: str) i64 {

    val popts: pipeline.CompileOptions = make_pipeline_opts(tgt, alloc,
        project_id, src_root, dep_root, deps, dep_count);

    val res: Result[pipeline.CompileResult, str] = pipeline.compile(source, file_path, module_path, popts);
    if (result_is_err[pipeline.CompileResult, str](res)) {
        ret 1;
    }
    val result: pipeline.CompileResult = result_unwrap_ok[pipeline.CompileResult, str](res);

    # emit per-module .o files and build archive members
    var lib_obj_dir: str = obj_dir;
    if (lib_obj_dir == nil) { lib_obj_dir = "."; }
    utilfs.ensure_dir(lib_obj_dir, alloc);

    var ar_members: [256]archive.ArMember;
    var oi: i32 = 0;
    for (oi < result.module_count) {
        val obj_path: str = make_obj_path(lib_obj_dir, result.modules[oi].mod_name, alloc);
        if (obj_path != nil) {
            emit.emit_object(result.modules[oi].m, obj_path, alloc);

            # read back .o bytes for archive member
            val read_obj_res: Result[str, str] = utilfs.read_file(obj_path, alloc);
            if (result_is_ok[str, str](read_obj_res)) {
                val obj_data: str = result_unwrap_ok[str, str](read_obj_res);
                val obj_len: usize = str_len(obj_data);
                var member_name: str = result.modules[oi].mod_name;
                if (member_name == nil) { member_name = "module"; }
                ar_members[oi].name = make_obj_path("", member_name, alloc);
                ar_members[oi].data = obj_data::ptr::*u8;
                ar_members[oi].size = obj_len;
            } or {
                ar_members[oi].name = nil;
                ar_members[oi].data = nil;
                ar_members[oi].size = 0;
            }
        }
        oi = oi + 1;
    }

    # emit archive
    val ar_res: Result[bool, str] = archive.emit_archive(?ar_members[0], result.module_count, output_path, alloc);
    if (result_is_err[bool, str](ar_res)) {
        print.eprint("error: archive creation failed: ");
        print.eprintln(result_unwrap_err[bool, str](ar_res));
        masm.destroy(result.masm);
        ret 1;
    }

    masm.destroy(result.masm);

    print.print("archived: ");
    print.println(output_path);

    ret 0;
}

# handle: main entry point for the build command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    # parse arguments
    val a: args.Args = args.init(argc, argv);
    val opts: BuildOptions = parse_options(a);

    if (opts.input_path == nil) {
        print.eprintln("error: no input file specified");
        cmd_help.print_build();
        ret 1;
    }

    # create arena-backed allocator for bulk allocation/deallocation
    var backing: allocator.Allocator = allocator.default();
    val arena_res: Result[arena.Arena, allocator.AllocError] = arena.init(backing, 268435456);
    if (result_is_err[arena.Arena, allocator.AllocError](arena_res)) {
        print.eprintln("error: failed to create arena allocator");
        ret 1;
    }
    var ar: arena.Arena = result_unwrap_ok[arena.Arena, allocator.AllocError](arena_res);
    var alloc: allocator.Allocator = arena.arena_allocator(?ar);

    # check if input is a project directory or single file
    val is_proj: bool = is_directory(opts.input_path);

    var source_path: str = nil;
    var output_path: str = opts.output_path;
    var module_path: str = opts.module_path;
    var project_id: str = nil;
    var src_root: str = nil;
    var dep_root: str = nil;
    var deps: *config.Dep = nil;
    var dep_count: i32 = 0;
    var target_cfg: *config.Target = nil;

    if (is_proj) {
        # project mode: load mach.toml
        val config_path: str = utilfs.path_join(opts.input_path, "mach.toml", ?alloc);
        if (config_path == nil || !utilfs.file_exists(config_path)) {
            print.eprintln("error: directory does not contain mach.toml");
            ret 1;
        }

        val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
        if (result_is_err[config.Config, str](cfg_res)) {
            print.eprint("error: failed to load config: ");
            print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
            ret 1;
        }

        var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

        # construct source path from entrypoint (target-aware)
        var src_dir_name: str = cfg.dir_src;
        if (src_dir_name == nil) {
            src_dir_name = "src";
        }
        val src_dir: str = utilfs.path_join(opts.input_path, src_dir_name, ?alloc);
        src_root = src_dir;
        project_id = cfg.id;
        if (cfg.dir_dep != nil) {
            dep_root = utilfs.path_join(opts.input_path, cfg.dir_dep, ?alloc);
        }
        deps = cfg.deps;
        dep_count = cfg.dep_count;

        # resolve target
        if (opts.target_name != nil) {
            val t_opt: Option[*config.Target] = config.get_target(?cfg, opts.target_name);
            if (option_is_some[*config.Target](t_opt)) {
                target_cfg = option_unwrap[*config.Target](t_opt);
            } or {
                print.eprint("error: target '");
                print.eprint(opts.target_name);
                print.eprintln("' not found in mach.toml");
                ret 1;
            }
        }
        if (target_cfg == nil && cfg.target != nil) {
            val t_opt2: Option[*config.Target] = config.get_target(?cfg, cfg.target);
            if (option_is_some[*config.Target](t_opt2)) { target_cfg = option_unwrap[*config.Target](t_opt2); }
        }
        if (target_cfg == nil && cfg.targets != nil && cfg.target_count > 0) {
            target_cfg = ?cfg.targets[0];
        }
        if (target_cfg == nil) {
            print.eprintln("error: no targets defined in mach.toml");
            ret 1;
        }

        if (target_cfg.mode.tag != ctarget.TMODE_EXECUTABLE && target_cfg.mode.tag != ctarget.TMODE_LIBRARY) {
            print.eprint("error: target '");
            print.eprint(target_cfg.name);
            print.eprintln("' is not an executable or library target");
            ret 1;
        }

        if (target_cfg.entrypoint == nil) {
            print.eprint("error: target '");
            print.eprint(target_cfg.name);
            print.eprintln("' has no entrypoint");
            ret 1;
        }
        val entry_src: str = target_cfg.entrypoint;
        source_path = utilfs.path_join(src_dir, entry_src, ?alloc);

        if (module_path == nil) {
            module_path = derive_module_path(opts.input_path, ?cfg, source_path, ?alloc);
            if (module_path == nil) {
                module_path = cfg.id;
                if (module_path == nil) {
                    module_path = "main";
                }
            }
        }

        if (output_path == nil) {
            # default output: <dir_out>/<binary>
            var out_dir_name: str = cfg.dir_out;
            if (out_dir_name == nil) {
                out_dir_name = "out";
            }
            val out_dir: str = utilfs.path_join(opts.input_path, out_dir_name, ?alloc);
            if (target_cfg.binary != nil) {
                output_path = utilfs.path_join(out_dir, target_cfg.binary, ?alloc);
            } or {
                output_path = utilfs.path_join(out_dir, "output", ?alloc);
            }
        }
    } or {
        # single file mode
        source_path = opts.input_path;

        if (module_path == nil) {
            module_path = "main";
        }

        if (output_path == nil) {
            output_path = "output";
        }
    }

    # ensure output directory exists
    val output_dir: str = utilfs.get_output_dir(output_path, ?alloc);
    if (output_dir != nil) {
        if (!utilfs.ensure_dir(output_dir, ?alloc)) {
            print.eprint("error: failed to create output dir '");
            print.eprint(output_dir);
            print.eprintln("'");
            ret 1;
        }
    }

    # read source file
    val read_res: Result[str, str] = utilfs.read_file(source_path, ?alloc);
    if (result_is_err[str, str](read_res)) {
        print.eprint("error: could not read file '");
        print.eprint(source_path);
        print.eprint("': ");
        print.eprintln(result_unwrap_err[str, str](read_res));
        ret 1;
    }

    val source: str = result_unwrap_ok[str, str](read_res);

    # compute obj_dir from artifact directory: <dir_out>/<artifacts>/obj
    var obj_dir: str = nil;
    if (is_proj && target_cfg != nil) {
        val base: str = utilfs.path_join(opts.input_path, cfg.dir_out, ?alloc);
        val artifact_dir: str = utilfs.path_join(base, target_cfg.artifacts, ?alloc);
        obj_dir = utilfs.path_join(artifact_dir, "obj", ?alloc);
    }

    # compile
    var tgt: target.Target = target.default_target();
    if (is_proj && target_cfg != nil) {
        tgt = to_compiler_target(target_cfg);
    }

    var exit_code: i64 = 0;

    # dispatch based on target mode
    if (is_proj && target_cfg != nil && target_cfg.mode.tag == ctarget.TMODE_LIBRARY) {
        exit_code = compile_library(source, source_path, module_path, output_path, ?alloc,
            tgt, project_id, src_root, dep_root, deps, dep_count, obj_dir);
    } or {
        exit_code = compile_source(source, source_path, module_path, output_path, ?alloc,
            tgt, project_id, src_root, dep_root, deps, dep_count, obj_dir);
    }

    arena.arena_dnit(?ar);
    ret exit_code;
}
