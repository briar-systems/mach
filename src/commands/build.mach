use          std.io.path;
use          std.types.bool;
use          std.types.list;
use          std.types.size;
use          std.types.string;
use          std.types.result;
use          std.types.option;
use fs:      std.io.filesystem;
use console: std.io.console;
use mem:     std.system.memory;

use std.lang.config;
use std.lang.driver;
use std.lang.driver.options;
use std.lang.driver.session;
use std.lang.target;

pub fun show_help() {
    console.print("usage: mach build <path> [options]\n");
    console.print("\n");
    console.print("builds a mach project or single source file\n");
    console.print("\n");
    console.print("arguments:\n");
    console.print("  <path>      path to mach.toml, source file, or directory containing mach.toml\n");
    console.print("\n");
    console.print("options:\n");
    console.print("  --target <name>       select build target (for projects with multiple targets)\n");
    console.print("  --debug               build with debug information (default: on)\n");
    console.print("  --release             build in release mode (disables debug, enables optimizations)\n");
    console.print("  --optimize            enable optimizations (disabled by default)\n");
    console.print("  --output <path>       specify output file path\n");
    console.print("  --link <lib>          link against library (can be specified multiple times)\n");
    console.print("  --dep <module>=<path> add module root mapping (can be specified multiple times)\n");
    console.print("  --emit-obj <path>     emit object file to specified path\n");
    console.print("  --emit-asm <path>     emit assembly file to specified path\n");
    console.print("  --emit-ir <path>      emit LLVM IR to specified path\n");
    console.print("  --emit-ast <path>     emit abstract syntax tree to specified path\n");
}

rec CliOptions {
    target_override: Option[str];
    dep_overrides:   List[ConfigDependency];
}

fun (this: *CliOptions) init() Option[str] {
    mem.zero[CliOptions](this, 1);
    this.target_override = none[str]();

    ret this.dep_overrides.init(4);
}

fun (this: *CliOptions) dnit() {
    if (this.dep_overrides.data != nil) {
        var i: usize = 0;
        for (i < this.dep_overrides.len) {
            val dep_ptr: *ConfigDependency = this.dep_overrides.data + i;
            dep_ptr.dnit();
            i = i + 1;
        }
    }

    this.dep_overrides.dnit();
    this.target_override = none[str]();
    mem.zero[CliOptions](this, 1);
}

fun (this: *CliOptions) apply_dependency_overrides(config: *Config) Option[str] {
    if (config == nil || this == nil) {
        ret some[str]("invalid dependency override request");
    }

    if (this.dep_overrides.data == nil) {
        ret none[str]();
    }

    var dep_index: usize = 0;
    for (dep_index < this.dep_overrides.len) {
        val dep_opt: Option[ConfigDependency] = this.dep_overrides.get(dep_index);
        if (dep_opt.is_none()) {
            dep_index = dep_index + 1;
            cnt;
        }

        val push_err: Option[str] = config.dependency_add(dep_opt.unwrap());
        if (push_err.is_some()) {
            ret push_err;
        }

        dep_index = dep_index + 1;
    }

    ret none[str]();
}

fun parse_dep_argument(arg: str) Result[ConfigDependency, str] {
    val eq_opt: Option[usize] = arg.index_of_char('=');
    if (eq_opt.is_none()) {
        ret err[ConfigDependency, str]("--dep expects '<module>=<path>'");
    }

    val eq_pos: usize = eq_opt.unwrap();
    if (eq_pos == 0 || eq_pos >= arg.len - 1) {
        ret err[ConfigDependency, str]("--dep expects non-empty <module> and <path>");
    }

    val module_opt: Option[str] = arg.substring(0, eq_pos);
    val path_opt:   Option[str] = arg.substring(eq_pos + 1, arg.len);

    if (module_opt.is_none() || path_opt.is_none()) {
        ret err[ConfigDependency, str]("invalid --dep mapping");
    }

    var dep: ConfigDependency;
    dep.init();
    dep.name = module_opt.unwrap();
    dep.type = "local";
    dep.path = path_opt.unwrap();

    ret ok[ConfigDependency, str](dep);
}

fun resolve_config_path(path: Path) Result[Path, str] {
    if (fs.is_dir(path)) {
        val res_join: Result[Path, str] = path_join(path, "mach.toml"::Path);
        if (res_join.is_err()) {
            ret err[Path, str](res_join.unwrap_err());
        }

        val config_path: Path = res_join.unwrap_ok();
        if (fs.exists(config_path) == false) {
            config_path.dnit();
            ret err[Path, str]("directory does not contain mach.toml");
        }

        ret ok[Path, str](config_path);
    }
    
    val path_str: str = path.as_str();

    if (path_str.ends_with("mach.toml")) {
        val clone_result: Result[Path, str] = path.clone();
        if (clone_result.is_err()) {
            ret err[Path, str](clone_result.unwrap_err());
        }
        ret ok[Path, str](clone_result.unwrap_ok());
    }

    if (path_str.ends_with(".mach")) {
        ret err[Path, str]("single-source builds are not implemented yet");
    }

    ret err[Path, str]("specified path is not a mach project or config file");
}

fun config_target_by_name(config: *Config, name: str) Option[*ConfigTarget] {
    if (config == nil || config.targets.len == 0) {
        ret none[*ConfigTarget]();
    }

    var i: usize = 0;
    for (i < config.targets.len) {
        val candidate: *ConfigTarget = config.targets.data + i;
        if (candidate.name.equals(name)) {
            ret some[*ConfigTarget](candidate);
        }
        i = i + 1;
    }

    ret none[*ConfigTarget]();
}

fun select_native_target(config: *Config) Option[*ConfigTarget] {
    if (config == nil || config.targets.len == 0) {
        ret none[*ConfigTarget]();
    }

    var i: usize = 0;
    for (i < config.targets.len) {
        val target_ptr: *ConfigTarget = config.targets.data + i;
        if (target_ptr.triple.data == nil || target_ptr.triple.len == 0) {
            i = i + 1;
            cnt;
        }

        if (target_triple_is_native(target_ptr.triple)) {
            ret some[*ConfigTarget](target_ptr);
        }

        i = i + 1;
    }

    val native: str = target_native_triple();
    console.print("info: native triple detected as '%s'\n", native);

    var i_print: usize = 0;
    for (i_print < config.targets.len) {
        val t_ptr: *ConfigTarget = config.targets.data + i_print;
        console.print("info: available target '%s' triple '%s'\n", t_ptr.name, t_ptr.triple);
        i_print = i_print + 1;
    }

    ret none[*ConfigTarget]();
}

fun resolve_target_selection(config: *Config, selection: str) Result[*ConfigTarget, str] {
    if (config == nil) {
        ret err[*ConfigTarget, str]("invalid project config");
    }

    var effective: str = selection;
    if (effective.data == nil || effective.len == 0) {
        effective = config.target;
    }

    if (effective.data == nil || effective.len == 0) {
        if (config.targets.len == 0) {
            ret err[*ConfigTarget, str]("project defines no build targets");
        }
        val default_target: *ConfigTarget = config.targets.data;
        config.target = default_target.name;
        ret ok[*ConfigTarget, str](default_target);
    }

    if (effective.equals("native")) {
        val native_opt: Option[*ConfigTarget] = select_native_target(config);
        if (native_opt.is_none()) {
            ret err[*ConfigTarget, str]("no targets match the native triple");
        }

        val native_target: *ConfigTarget = native_opt.unwrap();
        config.target = native_target.name;
        ret ok[*ConfigTarget, str](native_target);
    }

    val named_opt: Option[*ConfigTarget] = config_target_by_name(config, effective);
    if (named_opt.is_none()) {
        ret err[*ConfigTarget, str]("requested target was not found");
    }

    val named_target: *ConfigTarget = named_opt.unwrap();
    config.target = named_target.name;
    ret ok[*ConfigTarget, str](named_target);
}

fun execute_build(options: *Options) i64 {
    if (options == nil) {
        console.print("error: invalid build options\n");
        ret 1;
    }

    val selected_target_opt: Option[*ConfigTarget] = options.selected_target();
    if (selected_target_opt.is_none()) {
        console.print("error: selected target not found in configuration\n");
        ret 1;
    }

    val selected_target: *ConfigTarget = selected_target_opt.unwrap();
    console.print("info: building target '%s'\n", selected_target.name);

    var session: Session;
    val session_err: Option[str] = session.init(options);
    if (session_err.is_some()) {
        console.print("error: failed to initialize build session for target '%s': %s\n", selected_target.name, session_err.unwrap());
        ret 1;
    }

    var driver: Driver;
    val driver_err: Option[str] = driver.init(?session);
    if (driver_err.is_some()) {
        console.print("error: failed to initialize driver for target '%s': %s\n", selected_target.name, driver_err.unwrap());
        session.dnit();
        ret 1;
    }

    val pipeline_err: Option[str] = driver.run_pipeline(session.options.pipeline);
    if (pipeline_err.is_some()) {
        console.print("error: build pipeline failed for target '%s': %s\n", selected_target.name, pipeline_err.unwrap());
    }

    driver.print_diagnostics();

    val has_errors: bool = driver.has_errors();

    driver.dnit();
    session.dnit();

    if (pipeline_err.is_some() || has_errors) {
        ret 1;
    }

    ret 0;
}

fun determine_project_root(path_config: Path) Result[Path, str] {
    val dir_opt: Option[str] = path_config.dirname();
    if (dir_opt.is_some()) {
        ret path_from_string(dir_opt.unwrap());
    }

    ret path_from_string(".");
}

pub fun handle(args: []str) i64 {
    if (args.len < 3) {
        console.print("error: no path specified for build command\n");
        ret 1;
    }

    val res_input: Result[Path, str] = path_from_string(args[2]);
    if (res_input.is_err()) {
        console.print("error: invalid path '%s': %s\n", args[2], res_input.unwrap_err());
        ret 1;
    }

    var input_path: Path = res_input.unwrap_ok();

    if (fs.exists(input_path) == false) {
        console.print("error: specified path '%s' does not exist\n", args[2]);
        input_path.dnit();
        ret 1;
    }

    val res_config_path: Result[Path, str] = resolve_config_path(input_path);
    if (res_config_path.is_err()) {
        console.print("error: %s\n", res_config_path.unwrap_err());
        input_path.dnit();
        ret 1;
    }

    var config_path: Path = res_config_path.unwrap_ok();

    console.print("info: loading config from '%s'\n", config_path.as_str());

    var cli_opts: CliOptions;
    val cli_opts_err: Option[str] = cli_opts.init();
    if (cli_opts_err.is_some()) {
        console.print("error: failed to initialize build options: %s\n", cli_opts_err.unwrap());
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    var i: usize = 3;
    val target_inline_prefix: str = "--target=";
    for (i < args.len) {
        val option: str = args[i];

        if (option.equals("--target")) {
            if (i + 1 >= args.len) {
                console.print("error: --target expects a value\n");
                cli_opts.dnit();
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            i = i + 1;
            cli_opts.target_override = some[str](args[i]);
        }
        or (option.starts_with(target_inline_prefix)) {
            val inline_opt: Option[str] = option.substring(target_inline_prefix.len, option.len);
            if (inline_opt.is_none()) {
                console.print("error: --target expects a value\n");
                cli_opts.dnit();
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            val inline_value: str = inline_opt.unwrap();
            if (inline_value.len == 0) {
                console.print("error: --target expects a value\n");
                cli_opts.dnit();
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            cli_opts.target_override = some[str](inline_value);
        }
        or (option.equals("--dep")) {
            if (i + 1 >= args.len) {
                console.print("error: --dep expects '<module>=<path>'\n");
                cli_opts.dnit();
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            i = i + 1;
            val dep_res: Result[ConfigDependency, str] = parse_dep_argument(args[i]);
            if (dep_res.is_err()) {
                console.print("error: %s\n", dep_res.unwrap_err());
                cli_opts.dnit();
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            val push_err: Option[str] = cli_opts.dep_overrides.push(dep_res.unwrap_ok());
            if (push_err.is_some()) {
                console.print("error: failed to record dependency override: %s\n", push_err.unwrap());
                cli_opts.dnit();
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }
        }
        or {
            console.print("error: unknown build option '%s'\n", option);
            cli_opts.dnit();
            config_path.dnit();
            input_path.dnit();
            ret 1;
        }

        i = i + 1;
    }

    val config_result: Result[Config, str] = config_read(config_path.as_str());
    if (config_result.is_err()) {
        console.print("error: failed to read config '%s': %s\n", config_path.as_str(), config_result.unwrap_err());
        cli_opts.dnit();
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    var config: Config = config_result.unwrap_ok();

    var selection: str = config.target;
    if (cli_opts.target_override.is_some()) {
        selection = cli_opts.target_override.unwrap();
    }

    val target_res: Result[*ConfigTarget, str] = resolve_target_selection(?config, selection);
    if (target_res.is_err()) {
        console.print("error: %s\n", target_res.unwrap_err());
        config.dnit();
        cli_opts.dnit();
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    val dep_override_err: Option[str] = cli_opts.apply_dependency_overrides(?config);
    if (dep_override_err.is_some()) {
        console.print("error: failed to register dependency override: %s\n", dep_override_err.unwrap());
        config.dnit();
        cli_opts.dnit();
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    val root_res: Result[Path, str] = determine_project_root(config_path);
    if (root_res.is_err()) {
        console.print("error: failed to determine project root: %s\n", root_res.unwrap_err());
        config.dnit();
        cli_opts.dnit();
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    var project_root: Path = root_res.unwrap_ok();

    val options_res: Result[Options, str] = options_from_config(?config_path, ?project_root, ?config);
    if (options_res.is_err()) {
        console.print("error: failed to prepare build options: %s\n", options_res.unwrap_err());
        project_root.dnit();
        config.dnit();
        cli_opts.dnit();
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    var build_options: Options = options_res.unwrap_ok();

    val exit_code: i64 = execute_build(?build_options);

    build_options.dnit();
    cli_opts.dnit();
    input_path.dnit();

    ret exit_code;
}
