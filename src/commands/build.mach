use std.types.string;

use print: std.print;

use cmd_help: mach.commands.help;

# mach.commands.build: build command implementation.
# ---
# compiles a Mach project or single source file.

# handle: main entry point for the build command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    # argv[0] = "mach", argv[1] = "build", argv[2] = input path
    if (argc < 3) {
        print.eprintln("error: no input file specified");
        cmd_help.print_build();
        ret 1;
    }

    val input_path: str = argv[2];

    # TODO: parse options (-o, -m, -I, --target)
    # TODO: detect if input is a directory (project) or file
    # TODO: if project, load mach.toml and resolve target
    # TODO: invoke compiler pipeline (lexer -> parser -> sema -> masm -> emit)

    print.eprint("error: build command not yet implemented (input: ");
    print.eprint(input_path);
    print.eprintln(")");
    ret 1;
}
