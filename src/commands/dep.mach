use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;
use platform:  std.system.platform;

use cmd_help: mach.commands.help;
use config:   mach.config.config;
use utilfs:   mach.util.filesystem;
use proc:     mach.util.process;

use c: std.system.platform.linux.constants;
use pfs: std.system.platform.filesystem;
use types: std.system.platform.linux.types;

# mach.commands.dep: dependency management command implementation.
# ---
# manages project dependencies (list, info, tidy, add, del, pull).

# dirent buffer size for reading directories
val DIRENT_BUF_SIZE: usize = 4096;

# dir_exists: check if a directory exists and is a directory.
# ---
# path: path to check
# ret: true if directory exists
fun dir_exists(path: str) bool {
    if (path == nil) {
        ret false;
    }

    # try to open with O_DIRECTORY flag
    val raw: i64 = pfs.openat(c.AT_FDCWD, path, c.O_RDONLY | c.O_DIRECTORY, 0);
    if (raw < 0) {
        ret false;
    }

    pfs.close(raw::i32);
    ret true;
}

# find_project_root: find the project root by looking for mach.toml.
# ---
# start_path: starting path (or "." for current directory)
# alloc: allocator
# ret: path to project root or nil if not found
fun find_project_root(start_path: str, alloc: *allocator.Allocator) str {
    var path: str = start_path;
    if (path == nil) {
        path = ".";
    }

    val res: Result[str, str] = utilfs.find_project_root(path, alloc);
    if (result_is_err[str, str](res)) {
        ret nil;
    }
    ret result_unwrap_ok[str, str](res);
}

# is_dot_entry: check if a directory entry is . or ..
# ---
# name: entry name
# ret: true if . or ..
fun is_dot_entry(name: str) bool {
    if (name == nil) {
        ret true;
    }
    if (name[0] == '.') {
        if (name[1] == '\0') {
            ret true;  # "."
        }
        if (name[1] == '.' && name[2] == '\0') {
            ret true;  # ".."
        }
    }
    ret false;
}

# is_git_dir: check if a path contains a .git directory (is a git repo).
# ---
# path: path to check
# alloc: allocator
# ret: true if .git exists
fun is_git_dir(path: str, alloc: *allocator.Allocator) bool {
    val git_path: str = utilfs.path_join(path, ".git", alloc);
    if (git_path == nil) {
        ret false;
    }
    ret dir_exists(git_path) || utilfs.file_exists(git_path);
}

# handle: main entry point for the dep command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    # argv[0] = "mach", argv[1] = "dep", argv[2] = subcommand, argv[3..] = args
    if (argc < 3) {
        print.eprintln("error: no subcommand specified");
        cmd_help.print_dep();
        ret 1;
    }

    val subcommand: str = argv[2];

    if (str_equals(subcommand, "list")) {
        ret handle_list(argc, argv);
    }

    if (str_equals(subcommand, "info")) {
        ret handle_info(argc, argv);
    }

    if (str_equals(subcommand, "tidy")) {
        ret handle_tidy(argc, argv);
    }

    if (str_equals(subcommand, "add")) {
        ret handle_add(argc, argv);
    }

    if (str_equals(subcommand, "del")) {
        ret handle_del(argc, argv);
    }

    if (str_equals(subcommand, "pull")) {
        ret handle_pull(argc, argv);
    }

    print.eprint("error: unknown subcommand '");
    print.eprint(subcommand);
    print.eprintln("'");
    cmd_help.print_dep();
    ret 1;
}

# handle_list: list current dependencies.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
fun handle_list(argc: i64, argv: &&u8) i64 {
    var alloc: allocator.Allocator = allocator.default();

    # find project root
    val root: str = find_project_root(".", ?alloc);
    if (root == nil) {
        print.eprintln("error: not in a mach project (no mach.toml found)");
        ret 1;
    }

    # load configuration
    val config_path: str = utilfs.path_join(root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    # get dep directory path
    val dep_dir: str = utilfs.path_join(root, cfg.dir_dep, ?alloc);
    if (dep_dir == nil || !dir_exists(dep_dir)) {
        print.println("no dependencies installed");
        ret 0;
    }

    # open dep directory
    val dir_fd: i64 = pfs.openat(c.AT_FDCWD, dep_dir, c.O_RDONLY | c.O_DIRECTORY, 0);
    if (dir_fd < 0) {
        print.println("no dependencies installed");
        ret 0;
    }

    # allocate buffer for directory entries
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8]((?alloc), DIRENT_BUF_SIZE);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        pfs.close(dir_fd::i32);
        print.eprintln("error: failed to allocate buffer");
        ret 1;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    print.println("dependencies:");
    var count: i32 = 0;

    # read directory entries
    for {
        val nread: i64 = pfs.getdents64(dir_fd::i32, buf::*types.dirent64, DIRENT_BUF_SIZE);
        if (nread <= 0) {
            brk;
        }

        var pos: usize = 0;
        for (pos < nread::usize) {
            val entry: *types.dirent64 = (buf::usize + pos)::*types.dirent64;
            val name: str = ?entry.d_name[0];

            if (!is_dot_entry(name)) {
                # check if it's a directory (d_type == DT_DIR = 4)
                if (entry.d_type == 4) {
                    val dep_path: str = utilfs.path_join(dep_dir, name, ?alloc);
                    val is_git: bool = is_git_dir(dep_path, ?alloc);

                    print.print("  ");
                    print.print(name);
                    if (is_git) {
                        print.print(" (git)");
                    } or {
                        print.print(" (local)");
                    }
                    print.println("");
                    count = count + 1;
                }
            }

            pos = pos + entry.d_reclen::usize;
        }
    }

    pfs.close(dir_fd::i32);

    if (count == 0) {
        print.println("  (none)");
    }

    ret 0;
}

# handle_info: show dependency metadata.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
fun handle_info(argc: i64, argv: &&u8) i64 {
    if (argc < 4) {
        print.eprintln("error: dep info requires a dependency name");
        print.eprintln("usage: mach dep info <name>");
        ret 1;
    }

    val dep_name: str = argv[3];
    var alloc: allocator.Allocator = allocator.default();

    # find project root
    val root: str = find_project_root(".", ?alloc);
    if (root == nil) {
        print.eprintln("error: not in a mach project (no mach.toml found)");
        ret 1;
    }

    # load configuration
    val config_path: str = utilfs.path_join(root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    # check if dependency exists on disk
    val dep_path: str = utilfs.path_join(root, cfg.dir_dep, ?alloc);
    val full_dep_path: str = utilfs.path_join(dep_path, dep_name, ?alloc);

    if (!dir_exists(full_dep_path)) {
        print.eprint("error: dependency '");
        print.eprint(dep_name);
        print.eprintln("' not found");
        ret 1;
    }

    print.print("dependency: ");
    print.println(dep_name);
    print.print("  path: ");
    print.println(full_dep_path);

    # check if it's a git submodule
    val is_git: bool = is_git_dir(full_dep_path, ?alloc);
    print.print("  type: ");
    if (is_git) {
        print.println("git submodule");

        # note: we can't capture output easily, so just print the command hint
        print.println("  (run 'git -C <path> remote -v' for remote URL)");
    } or {
        print.println("local");
    }

    ret 0;
}

# handle_tidy: clean unused dependencies.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
fun handle_tidy(argc: i64, argv: &&u8) i64 {
    var alloc: allocator.Allocator = allocator.default();

    # find project root
    val root: str = find_project_root(".", ?alloc);
    if (root == nil) {
        print.eprintln("error: not in a mach project (no mach.toml found)");
        ret 1;
    }

    # load configuration
    val config_path: str = utilfs.path_join(root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    val dep_dir: str = utilfs.path_join(root, cfg.dir_dep, ?alloc);
    if (dep_dir == nil || !dir_exists(dep_dir)) {
        print.println("no dependencies installed");
        ret 0;
    }

    val dir_fd: i64 = pfs.openat(c.AT_FDCWD, dep_dir, c.O_RDONLY | c.O_DIRECTORY, 0);
    if (dir_fd < 0) {
        print.println("no dependencies installed");
        ret 0;
    }

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8]((?alloc), DIRENT_BUF_SIZE);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        pfs.close(dir_fd::i32);
        ret 1;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var removed: i32 = 0;

    for {
        val nread: i64 = pfs.getdents64(dir_fd::i32, buf::*types.dirent64, DIRENT_BUF_SIZE);
        if (nread <= 0) {
            brk;
        }

        var pos: usize = 0;
        for (pos < nread::usize) {
            val entry: *types.dirent64 = (buf::usize + pos)::*types.dirent64;
            val name: str = ?entry.d_name[0];

            if (!is_dot_entry(name) && entry.d_type == 4) {
                val dep_opt: Option[*config.Dep] = config.get_dep(?cfg, name);
                if (option_is_none[*config.Dep](dep_opt)) {
                    # orphaned dep dir; remove
                    val full_path: str = utilfs.path_join(dep_dir, name, ?alloc);
                    if (full_path != nil) {
                        val rm_path: str = proc.resolve_binary("rm", ?alloc);
                        if (rm_path != nil) {
                            var rm_argv: [4]&u8;
                            rm_argv[0] = rm_path;
                            rm_argv[1] = "-rf";
                            rm_argv[2] = full_path;
                            rm_argv[3] = nil;
                            var rm_res: i64 = proc.run_command(?rm_argv[0]);
                        }
                        removed = removed + 1;
                    }
                }
            }

            pos = pos + entry.d_reclen::usize;
        }
    }

    pfs.close(dir_fd::i32);

    if (removed == 0) {
        print.println("dependencies are tidy");
    } or {
        print.println("removed unused dependencies");
    }

    ret 0;
}

# handle_add: add a dependency.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
fun handle_add(argc: i64, argv: &&u8) i64 {
    # parse arguments: mach dep add [--local] <url-or-path> [name]
    if (argc < 4) {
        print.eprintln("error: dep add requires a path or URL");
        print.eprintln("usage: mach dep add [--local] <url-or-path> [name] [--version <ver>]");
        ret 1;
    }

    var is_local: bool = false;
    var source_path: str = nil;
    var dep_name: str = nil;
    var version_str: str = nil;

    var i: i64 = 3;
    for (i < argc) {
        val arg: str = argv[i];

        if (str_equals(arg, "--local")) {
            is_local = true;
            i = i + 1;
            cnt;
        }

        if (str_equals(arg, "--version")) {
            i = i + 1;
            if (i < argc) {
                version_str = argv[i];
            }
            i = i + 1;
            cnt;
        }

        if (source_path == nil) {
            source_path = arg;
            i = i + 1;
            cnt;
        }

        if (dep_name == nil) {
            dep_name = arg;
            i = i + 1;
            cnt;
        }

        i = i + 1;
    }

    if (source_path == nil) {
        print.eprintln("error: dep add requires a path or URL");
        ret 1;
    }

    var alloc: allocator.Allocator = allocator.default();

    # find project root
    val root: str = find_project_root(".", ?alloc);
    if (root == nil) {
        print.eprintln("error: not in a mach project (no mach.toml found)");
        ret 1;
    }

    # load configuration
    val config_path: str = utilfs.path_join(root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    # derive name from URL/path if not provided
    if (dep_name == nil) {
        dep_name = extract_name_from_path(source_path);
        if (dep_name == nil) {
            print.eprintln("error: could not derive dependency name from path");
            print.eprintln("hint: provide a name explicitly: mach dep add <url> <name>");
            ret 1;
        }
    }

    val dep_dir: str = utilfs.path_join(root, cfg.dir_dep, ?alloc);
    val dest_path: str = utilfs.path_join(dep_dir, dep_name, ?alloc);

    # check if already exists
    if (dir_exists(dest_path)) {
        print.eprint("error: dependency '");
        print.eprint(dep_name);
        print.eprintln("' already exists");
        ret 1;
    }

    if (is_local) {
        # for local deps, create a symlink
        print.print("adding local dependency: ");
        print.println(dep_name);

        # use symlinkat via the process utility
        val result: i64 = proc.symlinkat(source_path, c.AT_FDCWD, dest_path);
        if (result < 0) {
            print.eprintln("error: failed to create symlink");
            print.eprintln("hint: you may need to copy the directory manually");
            ret 1;
        }

        print.println("created symlink to local dependency");
    } or {
        # for remote deps, use git submodule add
        print.print("adding git dependency: ");
        print.println(dep_name);

        val git_path: str = proc.resolve_binary("git", ?alloc);
        if (git_path == nil) {
            print.eprintln("error: git not found in PATH");
            print.eprintln("hint: ensure git is installed");
            ret 1;
        }

        var git_argv: [6]&u8;
        git_argv[0] = git_path;
        git_argv[1] = "submodule";
        git_argv[2] = "add";
        git_argv[3] = source_path;
        git_argv[4] = dest_path;
        git_argv[5] = nil;

        val result: i64 = proc.run_command(?git_argv[0]);
        if (result != 0) {
            print.eprintln("error: git submodule add failed");
            print.eprintln("hint: ensure git is installed and the URL is correct");
            ret 1;
        }

        print.println("added git submodule");
    }

    # update mach.toml
    if (!config.add_dep(?cfg, ?alloc, dep_name, source_path, is_local, version_str)) {
        print.eprintln("warning: failed to update mach.toml");
    } or {
        val save_res: Result[bool, str] = config.save(?cfg, config_path);
        if (result_is_err[bool, str](save_res)) {
            print.eprintln("warning: failed to save mach.toml");
        }
    }

    print.print("dependency '");
    print.print(dep_name);
    print.println("' added successfully");

    ret 0;
}

# extract_name_from_path: extract dependency name from URL or path.
# ---
# path: URL or filesystem path
# ret: extracted name or nil
fun extract_name_from_path(path: str) str {
    if (path == nil) {
        ret nil;
    }

    val len: usize = str_len(path);
    if (len == 0) {
        ret nil;
    }

    # find last '/' (for both URLs and paths)
    var last_slash: usize = len;
    var i: usize = 0;
    for (i < len) {
        if (path[i] == '/') {
            last_slash = i;
        }
        i = i + 1;
    }

    var name_start: usize = 0;
    if (last_slash < len) {
        name_start = last_slash + 1;
    }

    # the name is everything after the last slash
    # also strip .git suffix if present
    var name_end: usize = len;

    # check for trailing .git
    if (len >= 4) {
        val suffix_start: usize = len - 4;
        if (path[suffix_start] == '.' &&
            path[suffix_start + 1] == 'g' &&
            path[suffix_start + 2] == 'i' &&
            path[suffix_start + 3] == 't') {
            name_end = suffix_start;
        }
    }

    if (name_start >= name_end) {
        ret nil;
    }

    # return pointer into original string (no allocation)
    ret (path::usize + name_start)::str;
}

# handle_del: remove a dependency.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
fun handle_del(argc: i64, argv: &&u8) i64 {
    if (argc < 4) {
        print.eprintln("error: dep del requires a dependency name");
        print.eprintln("usage: mach dep del <name>");
        ret 1;
    }

    val dep_name: str = argv[3];
    var alloc: allocator.Allocator = allocator.default();

    # find project root
    val root: str = find_project_root(".", ?alloc);
    if (root == nil) {
        print.eprintln("error: not in a mach project (no mach.toml found)");
        ret 1;
    }

    # load configuration
    val config_path: str = utilfs.path_join(root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    val dep_dir: str = utilfs.path_join(root, cfg.dir_dep, ?alloc);
    val full_dep_path: str = utilfs.path_join(dep_dir, dep_name, ?alloc);

    if (!dir_exists(full_dep_path)) {
        print.eprint("error: dependency '");
        print.eprint(dep_name);
        print.eprintln("' not found");
        ret 1;
    }

    print.print("removing dependency: ");
    print.println(dep_name);

    # check if it's a git submodule
    val is_git: bool = is_git_dir(full_dep_path, ?alloc);

    val git_path: str = proc.resolve_binary("git", ?alloc);

    if (is_git) {
        # for git submodules, use git submodule deinit and git rm
        if (git_path == nil) {
            print.eprintln("error: git not found in PATH");
            ret 1;
        }

        print.println("deinitializing git submodule...");

        # git submodule deinit -f <path>
        var deinit_argv: [5]&u8;
        deinit_argv[0] = git_path;
        deinit_argv[1] = "submodule";
        deinit_argv[2] = "deinit";
        deinit_argv[3] = full_dep_path;
        deinit_argv[4] = nil;

        val deinit_result: i64 = proc.run_command(?deinit_argv[0]);
        if (deinit_result != 0) {
            print.eprintln("warning: git submodule deinit failed");
        }

        # git rm -f <path>
        var rm_argv: [5]&u8;
        rm_argv[0] = git_path;
        rm_argv[1] = "rm";
        rm_argv[2] = "-rf";
        rm_argv[3] = full_dep_path;
        rm_argv[4] = nil;

        val rm_result: i64 = proc.run_command(?rm_argv[0]);
        if (rm_result != 0) {
            print.eprintln("warning: git rm failed");
            print.eprintln("hint: manually remove the directory and .gitmodules entry");
            ret 1;
        }

        print.println("removed git submodule");
    } or {
        # for local deps (symlinks or directories), use rm -rf
        val rm_path: str = proc.resolve_binary("rm", ?alloc);
        if (rm_path == nil) {
            print.eprintln("error: rm not found in PATH");
            ret 1;
        }

        var rm_argv: [4]&u8;
        rm_argv[0] = rm_path;
        rm_argv[1] = "-rf";
        rm_argv[2] = full_dep_path;
        rm_argv[3] = nil;

        val result: i64 = proc.run_command(?rm_argv[0]);
        if (result != 0) {
            print.eprintln("error: failed to remove dependency directory");
            ret 1;
        }

        print.println("removed local dependency");
    }

    # update mach.toml
    if (config.del_dep(?cfg, dep_name)) {
        val save_res: Result[bool, str] = config.save(?cfg, config_path);
        if (result_is_err[bool, str](save_res)) {
            print.eprintln("warning: failed to save mach.toml");
        }
    }

    print.print("dependency '");
    print.print(dep_name);
    print.println("' removed successfully");

    ret 0;
}

# handle_pull: fetch/update dependencies.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
fun handle_pull(argc: i64, argv: &&u8) i64 {
    # optional: mach dep pull [name]
    var specific_dep: str = nil;
    if (argc >= 4) {
        specific_dep = argv[3];
    }

    var alloc: allocator.Allocator = allocator.default();

    # find project root
    val root: str = find_project_root(".", ?alloc);
    if (root == nil) {
        print.eprintln("error: not in a mach project (no mach.toml found)");
        ret 1;
    }

    # load configuration
    val config_path: str = utilfs.path_join(root, "mach.toml", ?alloc);
    val cfg_res: Result[config.Config, str] = config.load(config_path, ?alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        print.eprint("error: failed to load mach.toml: ");
        print.eprintln(result_unwrap_err[config.Config, str](cfg_res));
        ret 1;
    }

    var cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);

    if (specific_dep != nil) {
        # pull a specific dependency
        val dep_dir: str = utilfs.path_join(root, cfg.dir_dep, ?alloc);
        val full_dep_path: str = utilfs.path_join(dep_dir, specific_dep, ?alloc);

        if (!dir_exists(full_dep_path)) {
            print.eprint("error: dependency '");
            print.eprint(specific_dep);
            print.eprintln("' not found");
            ret 1;
        }

        if (!is_git_dir(full_dep_path, ?alloc)) {
            print.eprint("note: '");
            print.eprint(specific_dep);
            print.eprintln("' is a local dependency, nothing to pull");
            ret 0;
        }

        print.print("pulling dependency: ");
        print.println(specific_dep);

        ret pull_git_dep(full_dep_path);
    }

    # pull all dependencies using git submodule update
    print.println("updating all git submodules...");

    val git_path: str = proc.resolve_binary("git", ?alloc);
    if (git_path == nil) {
        print.eprintln("error: git not found in PATH");
        print.eprintln("hint: ensure git is installed");
        ret 1;
    }

    var argv_update: [5]&u8;
    argv_update[0] = git_path;
    argv_update[1] = "submodule";
    argv_update[2] = "update";
    argv_update[3] = "--init";
    argv_update[4] = nil;

    val result: i64 = proc.run_command(?argv_update[0]);
    if (result != 0) {
        print.eprintln("warning: git submodule update failed");
        print.eprintln("hint: ensure git is installed and you're in a git repository");
        ret 1;
    }

    print.println("dependencies updated");
    ret 0;
}

# pull_git_dep: pull updates for a single git dependency.
# ---
# dep_path: path to the dependency directory
# ret: 0 on success, non-zero on failure
fun pull_git_dep(dep_path: str) i64 {
    var alloc: allocator.Allocator = allocator.default();
    val git_path: str = proc.resolve_binary("git", ?alloc);
    if (git_path == nil) {
        print.eprintln("error: git not found in PATH");
        ret 1;
    }

    # git -C <path> pull
    var argv: [5]&u8;
    argv[0] = git_path;
    argv[1] = "-C";
    argv[2] = dep_path;
    argv[3] = "pull";
    argv[4] = nil;

    val result: i64 = proc.run_command(?argv[0]);
    if (result != 0) {
        print.eprintln("error: git pull failed");
        ret 1;
    }

    print.println("pulled latest changes");
    ret 0;
}
