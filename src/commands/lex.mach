use fmt: std.fmt;
use stream: std.stream;
use stdio: std.system.stdio;
use std.types.size;
use std.types.string;
use std.types.bool;

use fs: mach.util.fs;
use lexmod: mach.compiler.lexer;
use tok: mach.compiler.token;

fun write_kind(w: *stream.Writer, kind: i32) {
    # avoid returning `str` from helpers; bootstrap runtime currently miscompiles
    # some cross-function `str` returns.
    if (kind < 0) { fmt.write_str(w, "TOKEN_ERROR"); ret; }
    if (kind == 0) { fmt.write_str(w, "TOKEN_EOF"); ret; }
    if (kind == 1) { fmt.write_str(w, "TOKEN_COMMENT"); ret; }

    if (kind == 2) { fmt.write_str(w, "TOKEN_LIT_INT"); ret; }
    if (kind == 3) { fmt.write_str(w, "TOKEN_LIT_FLOAT"); ret; }
    if (kind == 4) { fmt.write_str(w, "TOKEN_LIT_CHAR"); ret; }
    if (kind == 5) { fmt.write_str(w, "TOKEN_LIT_STRING"); ret; }

    if (kind == 6) { fmt.write_str(w, "TOKEN_IDENTIFIER"); ret; }

    if (kind == 7) { fmt.write_str(w, "TOKEN_KW_USE"); ret; }
    if (kind == 8) { fmt.write_str(w, "TOKEN_KW_EXT"); ret; }
    if (kind == 9) { fmt.write_str(w, "TOKEN_KW_DEF"); ret; }
    if (kind == 10) { fmt.write_str(w, "TOKEN_KW_PUB"); ret; }
    if (kind == 11) { fmt.write_str(w, "TOKEN_KW_REC"); ret; }
    if (kind == 12) { fmt.write_str(w, "TOKEN_KW_UNI"); ret; }
    if (kind == 13) { fmt.write_str(w, "TOKEN_KW_VAL"); ret; }
    if (kind == 14) { fmt.write_str(w, "TOKEN_KW_VAR"); ret; }
    if (kind == 15) { fmt.write_str(w, "TOKEN_KW_FUN"); ret; }
    if (kind == 16) { fmt.write_str(w, "TOKEN_KW_RET"); ret; }
    if (kind == 17) { fmt.write_str(w, "TOKEN_KW_IF"); ret; }
    if (kind == 18) { fmt.write_str(w, "TOKEN_KW_OR"); ret; }
    if (kind == 19) { fmt.write_str(w, "TOKEN_KW_FOR"); ret; }
    if (kind == 20) { fmt.write_str(w, "TOKEN_KW_CNT"); ret; }
    if (kind == 21) { fmt.write_str(w, "TOKEN_KW_BRK"); ret; }
    if (kind == 22) { fmt.write_str(w, "TOKEN_KW_NIL"); ret; }
    if (kind == 23) { fmt.write_str(w, "TOKEN_KW_FIN"); ret; }
    if (kind == 24) { fmt.write_str(w, "TOKEN_KW_MASM"); ret; }

    fmt.write_str(w, "TOKEN_UNKNOWN");
}

pub fun handle(argc: i64, argv: &&u8) i64 {
    var w: stream.Writer = stdio.stdout();
    if (argc < 3) {
        fmt.write_str(?w, "usage: mach lex <file>\n");
        ret 1;
    }

    val path: str = argv[2]::str;
    var source_p: ptr = nil;
    var err_p: ptr = nil;
    val ok: bool = fs.read_file(path, ?source_p, ?err_p);
    if (!ok) {
        fmt.write_str(?w, "error: ");
        fmt.write_str(?w, err_p::str);
        fmt.write_newline(?w);
        ret 1;
    }

    if (source_p == nil) {
        fmt.write_str(?w, "error: read_file returned ok but source is nil\n");
        ret 1;
    }

    val source: str = source_p::str;

    var lx: lexmod.Lexer;
    lx.source = source;
    lx.pos = 0;

    # debug: print a short prefix of source to ensure bytes are printable
    fmt.write_str(?w, "SOURCE:");
    var jj: usize = 0;
    for (jj < 20 && jj < source.len()) {
        fmt.write_byte(?w, source[jj]);
        jj = jj + 1;
    }
    fmt.write_newline(?w);

    var had_err: bool = false;
    for {
        var tokv: tok.Token;
        lexmod.next(?lx, ?tokv);
        write_kind(?w, tokv.kind);
        fmt.write_str(?w, "\t");

        # debug: print pos and len and numeric kind
        fmt.write_str(?w, "[");
        fmt.write_u64(?w, tokv.pos::u64);
        fmt.write_str(?w, ":");
        fmt.write_u64(?w, tokv.len::u64);
        fmt.write_str(?w, "] ");
        fmt.write_i64(?w, tokv.kind::i64);
        fmt.write_str(?w, "\t");

        # print lexeme
        var i: usize = 0;
        for (i < tokv.len) {
            fmt.write_byte(?w, source[tokv.pos + i]);
            i = i + 1;
        }

        fmt.write_newline(?w);

        if (tokv.kind < 0) { had_err = true; brk; }
        if (tokv.kind == 0) { brk; }
    }

    if (had_err) { ret 1; }
    ret 0;
}
