use std.types.string;

use print: std.print;

use cmd_help: mach.commands.help;

# mach.commands.init: init command implementation.
# ---
# creates a new Mach project with standard structure.

# handle: main entry point for the init command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    # argv[0] = "mach", argv[1] = "init", argv[2] = project_id
    if (argc < 3) {
        cmd_help.print_init();
        ret 1;
    }

    val project_id: str = argv[2];

    # TODO: validate project_id length (max 127 chars)
    # TODO: check if directory already exists
    # TODO: create project directory structure:
    #   - project_id/
    #   - project_id/src/
    #   - project_id/dep/
    #   - project_id/out/
    # TODO: create mach.toml with project configuration
    # TODO: create src/main.mach with hello world template
    # TODO: initialize git repository
    # TODO: create .gitignore
    # TODO: initialize mach-std dependency as submodule

    print.eprint("error: init command not yet implemented (project: ");
    print.eprint(project_id);
    print.eprintln(")");
    ret 1;
}
