use          std.types.string;
use console: std.io.console;

pub fun show_help() {
    console.print("usage: mach init <name>\n");
    console.print("\n");
    console.print("initializes a new mach project with the specified name\n");
}

pub fun handle(args: []str) i64 {
    console.print("init command not yet implemented\n");
    ret 1;
}
