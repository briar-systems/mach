use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use print:     std.print;

use args:     mach.cli.args;
use cmd_help: mach.commands.help;

use c: std.system.platform.linux.constants;
use pfs: std.system.platform.filesystem;

# mach.commands.init: init command implementation.
# ---
# creates a new Mach project with standard directory structure.

# default file mode for created files (0644)
val FILE_MODE: i32 = 420;

# default directory mode (0755)
val DIR_MODE: i32 = 493;

# write_mach_toml: write mach.toml with the given project id.
# ---
# file: file to write to
# id: project id
# ret: true on success
fun write_mach_toml(file: *fs.File, id: str) bool {
    file.write("[project]\n", 10);
    file.write("id      = \"", 11);
    file.write(id, id.len());
    file.write("\"\n", 2);
    file.write("name    = \"", 11);
    file.write(id, id.len());
    file.write("\"\n", 2);
    file.write("version = \"0.1.0\"\n", 18);
    file.write("\n", 1);
    file.write("dir_src = \"src\"\n", 16);
    file.write("dir_out = \"out\"\n", 16);
    file.write("dir_dep = \"dep\"\n", 16);
    file.write("\n", 1);
    file.write("target  = \"linux\"\n", 18);
    file.write("\n", 1);
    file.write("[targets.linux]\n", 16);
    file.write("os         = \"linux\"\n", 21);
    file.write("isa        = \"x86_64\"\n", 22);
    file.write("abi        = \"sysv64\"\n", 22);
    file.write("mode       = \"executable\"\n", 26);
    file.write("entrypoint = \"main.mach\"\n", 25);
    file.write("artifacts  = \"linux\"\n", 21);
    file.write("binary     = \"linux/bin/", 24);
    file.write(id, id.len());
    file.write("\"\n", 2);
    ret true;
}

# write_main_mach: write the main.mach template.
# ---
# file: file to write to
# ret: true on success
fun write_main_mach(file: *fs.File) bool {
    file.write("use print: std.print;\n", 22);
    file.write("\n", 1);
    file.write("# main: program entry point.\n", 29);
    file.write("$main.symbol = \"main\";\n", 23);
    file.write("fun main(argc: i64, argv: &&u8) i64 {\n", 38);
    file.write("    print.println(\"Hello, Mach!\");\n", 35);
    file.write("    ret 0;\n", 11);
    file.write("}\n", 2);
    ret true;
}

# write_gitignore: write the .gitignore template.
# ---
# file: file to write to
# ret: true on success
fun write_gitignore(file: *fs.File) bool {
    file.write("# build output\n", 15);
    file.write("out/\n", 5);
    file.write("\n", 1);
    file.write("# editor files\n", 15);
    file.write("*.swp\n", 6);
    file.write("*~\n", 3);
    file.write(".vscode/\n", 9);
    file.write(".idea/\n", 7);
    ret true;
}

# mkdir: create a directory.
# ---
# path: path to create
# ret: true on success, false on failure
fun mkdir(path: str) bool {
    if (path == nil) {
        ret false;
    }

    val result: i64 = pfs.mkdirat(c.AT_FDCWD, path, DIR_MODE);
    if (result < 0 && result != c.EEXIST) {
        ret false;
    }

    ret true;
}

# create_file: create a file and return the file handle.
# ---
# path: path to the file
# ret: Ok(File) on success, Err on failure
fun create_file(path: str) Result[fs.File, str] {
    if (path == nil) {
        ret err[fs.File, str]("path is nil");
    }

    ret fs.create(path, FILE_MODE);
}

# path_join: join two path components.
# ---
# base: base path
# rel: relative path to append
# alloc: allocator for result
# ret: joined path or nil on failure
fun path_join(base: str, rel: str, alloc: *allocator.Allocator) str {
    if (base == nil || rel == nil || alloc == nil) {
        ret nil;
    }

    val base_len: usize = base.len();
    val rel_len: usize = rel.len();
    val total: usize = base_len + 1 + rel_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = alloc.alloc[u8](total);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy base
    var j: usize = 0;
    for (j < base_len) {
        buf[pos] = base[j];
        pos = pos + 1;
        j = j + 1;
    }

    # add separator if needed
    if (base_len > 0 && base[base_len - 1] != 47) {  # '/'
        buf[pos] = 47;
        pos = pos + 1;
    }

    # copy rel
    j = 0;
    for (j < rel_len) {
        buf[pos] = rel[j];
        pos = pos + 1;
        j = j + 1;
    }

    buf[pos] = 0;
    ret buf::&u8;
}

# validate_project_id: check if project ID is valid.
# ---
# id: project ID to validate
# ret: true if valid, false otherwise
fun validate_project_id(id: str) bool {
    if (id == nil) {
        ret false;
    }

    val len: usize = id.len();
    if (len == 0 || len > 127) {
        ret false;
    }

    # first character must be a letter or underscore
    val first: u8 = id[0];
    if (!((first >= 65 && first <= 90) ||    # A-Z
          (first >= 97 && first <= 122) ||   # a-z
          first == 95)) {                     # _
        ret false;
    }

    # remaining characters: letters, digits, underscore, hyphen
    var i: usize = 1;
    for (i < len) {
        val ch: u8 = id[i];
        val valid: bool = (ch >= 65 && ch <= 90) ||    # A-Z
                          (ch >= 97 && ch <= 122) ||   # a-z
                          (ch >= 48 && ch <= 57) ||    # 0-9
                          ch == 95 ||                   # _
                          ch == 45;                     # -
        if (!valid) {
            ret false;
        }
        i = i + 1;
    }

    ret true;
}

# handle: main entry point for the init command.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code (0 = success, non-zero = error)
pub fun handle(argc: i64, argv: &&u8) i64 {
    # argv[0] = "mach", argv[1] = "init", argv[2] = project_id
    if (argc < 3) {
        cmd_help.print_init();
        ret 1;
    }

    val project_id: str = argv[2];

    # validate project ID
    if (!validate_project_id(project_id)) {
        print.eprintln("error: invalid project ID");
        print.eprintln("  - must be 1-127 characters");
        print.eprintln("  - must start with a letter or underscore");
        print.eprintln("  - can contain letters, digits, underscores, and hyphens");
        ret 1;
    }

    # create allocator
    var alloc: allocator.Allocator = allocator.init();

    print.print("creating project: ");
    print.println(project_id);

    # create project directory
    if (!mkdir(project_id)) {
        print.eprint("error: failed to create directory '");
        print.eprint(project_id);
        print.eprintln("'");
        ret 1;
    }

    # create subdirectories
    val src_dir: str = path_join(project_id, "src", ?alloc);
    val out_dir: str = path_join(project_id, "out", ?alloc);
    val dep_dir: str = path_join(project_id, "dep", ?alloc);

    if (!mkdir(src_dir)) {
        print.eprintln("error: failed to create src directory");
        ret 1;
    }

    if (!mkdir(out_dir)) {
        print.eprintln("error: failed to create out directory");
        ret 1;
    }

    if (!mkdir(dep_dir)) {
        print.eprintln("error: failed to create dep directory");
        ret 1;
    }

    # create mach.toml
    val config_path: str = path_join(project_id, "mach.toml", ?alloc);
    val cfg_res: Result[fs.File, str] = create_file(config_path);
    if (cfg_res.is_err()) {
        print.eprintln("error: failed to create mach.toml");
        ret 1;
    }
    var cfg_file: fs.File = cfg_res.unwrap_ok();
    write_mach_toml(?cfg_file, project_id);
    cfg_file.close();

    # create src/main.mach
    val main_path: str = path_join(src_dir, "main.mach", ?alloc);
    val main_res: Result[fs.File, str] = create_file(main_path);
    if (main_res.is_err()) {
        print.eprintln("error: failed to create src/main.mach");
        ret 1;
    }
    var main_file: fs.File = main_res.unwrap_ok();
    write_main_mach(?main_file);
    main_file.close();

    # create .gitignore
    val gitignore_path: str = path_join(project_id, ".gitignore", ?alloc);
    val git_res: Result[fs.File, str] = create_file(gitignore_path);
    if (git_res.is_ok()) {
        var git_file: fs.File = git_res.unwrap_ok();
        write_gitignore(?git_file);
        git_file.close();
    }

    print.println("");
    print.println("project created successfully!");
    print.println("");
    print.print("  cd ");
    print.println(project_id);
    print.println("  mach build .");
    print.println("  mach run");
    print.println("");

    ret 0;
}
