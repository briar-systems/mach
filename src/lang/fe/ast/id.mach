# per-Ast node identifier types
#
# Each is a u32 handle into the corresponding array on an Ast; the type
# alias exists to make signatures self-describing.

# handle into Ast.exprs
pub def ExprId: u32;

# handle into Ast.stmts
pub def StmtId: u32;

# handle into Ast.decls
pub def DeclId: u32;

# handle into Ast.types
pub def TypeId: u32;

# handle into Ast.modules
pub def ModuleId: u32;

# sentinel value marking an absent node handle, one per id type
pub val EXPR_NIL:   ExprId   = 0xFFFFFFFF;
pub val STMT_NIL:   StmtId   = 0xFFFFFFFF;
pub val DECL_NIL:   DeclId   = 0xFFFFFFFF;
pub val TYPE_NIL:   TypeId   = 0xFFFFFFFF;
pub val MODULE_NIL: ModuleId = 0xFFFFFFFF;
