# mach.lang.fe.ast.decl: declaration AST nodes.
#
# each Decl is stored by value in Ast.decls; subnodes are referenced by
# DeclId, StmtId, ExprId, and TypeId handles.

use std.types.bool.bool;

use token: mach.lang.fe.token;
use id:    mach.lang.fe.ast.id;

# DeclKind: discriminator for Decl.data.
pub def DeclKind: u8;

pub val DECL_KIND_USE:            DeclKind = 0;
pub val DECL_KIND_FWD:            DeclKind = 1;
pub val DECL_KIND_FUN:            DeclKind = 2;
pub val DECL_KIND_REC:            DeclKind = 3;
pub val DECL_KIND_VAL:            DeclKind = 4;
pub val DECL_KIND_VAR:            DeclKind = 5;
pub val DECL_KIND_DEF:            DeclKind = 6;
pub val DECL_KIND_TEST:           DeclKind = 7;
pub val DECL_KIND_COMPTIME_IF:    DeclKind = 8;
pub val DECL_KIND_COMPTIME_ATTR:  DeclKind = 9;
pub val DECL_KIND_UNI:            DeclKind = 10;
pub val DECL_KIND_ERROR:          DeclKind = 255;

# flag bits stored in Decl.flags
pub val DECL_FLAG_PUB: u8 = 1;
pub val DECL_FLAG_EXT: u8 = 2;

# TypedName: a name paired with an explicit type, used for function parameters and record fields.
# ---
# name:     span of the identifier
# ty:       declared type
# comptime: true when the entry was declared comptime (a `$name: T` function parameter); false for ordinary parameters and record fields
pub rec TypedName {
    name:     token.Span;
    ty:       id.TypeId;
    comptime: bool;
}

# DeclUse: a `use` declaration importing a module, optionally under an alias.
# ---
# alias: span of the alias identifier, or an empty span (len 0) if absent
# path:  span covering the dotted module path
pub rec DeclUse {
    alias: token.Span;
    path:  token.Span;
}

# DeclFwd: a `fwd` declaration re-exporting an imported symbol, optionally under an alias.
# ---
# alias: span of the alias identifier, or an empty span (len 0) if absent
# path:  span covering the dotted symbol path being re-exported
pub rec DeclFwd {
    alias: token.Span;
    path:  token.Span;
}

# DeclFun: a function declaration.
# ---
# name:           span of the function identifier
# generics_start: start index into ast.generic_names; each slot holds a Span (type param name)
# generics_len:   number of generic parameters
# params_start:   start index into ast.typed_names; each slot holds a TypedName
# params_len:     number of parameters
# return_type:    declared return type, or TYPE_NIL for no explicit return
# body:           body statement (typically STMT_KIND_BLOCK), or STMT_NIL for a forward-only declaration
pub rec DeclFun {
    name:           token.Span;
    generics_start: u32;
    generics_len:   u32;
    params_start:   u32;
    params_len:     u32;
    return_type:    id.TypeId;
    body:           id.StmtId;
}

# DeclRec: a record declaration.
# ---
# name:           span of the record identifier
# generics_start: start index into ast.generic_names
# generics_len:   number of generic parameters
# fields_start:   start index into ast.typed_names; each slot holds a TypedName
# fields_len:     number of fields
pub rec DeclRec {
    name:           token.Span;
    generics_start: u32;
    generics_len:   u32;
    fields_start:   u32;
    fields_len:     u32;
}

# DeclUni: a raw union declaration.
# ---
# name:           span of the union identifier
# generics_start: start index into ast.generic_names
# generics_len:   number of generic parameters
# fields_start:   start index into ast.typed_names; each slot holds a TypedName
# fields_len:     number of variants
pub rec DeclUni {
    name:           token.Span;
    generics_start: u32;
    generics_len:   u32;
    fields_start:   u32;
    fields_len:     u32;
}

# DeclBind: a binding declaration, used for both DECL_KIND_VAL and DECL_KIND_VAR (kind discriminates mutability).
# ---
# name: span of the bound identifier
# ty:   declared type, or TYPE_NIL if inferred
# init: initializer expression, or EXPR_NIL if absent
pub rec DeclBind {
    name: token.Span;
    ty:   id.TypeId;
    init: id.ExprId;
}

# DeclDef: a type alias declaration `def Name: Type`.
# ---
# name: span of the alias identifier
# ty:   underlying type
pub rec DeclDef {
    name: token.Span;
    ty:   id.TypeId;
}

# DeclTest: a `test "label" { body }` declaration.
# ---
# label: span of the string literal naming the test
# body:  body statement (typically STMT_KIND_BLOCK)
pub rec DeclTest {
    label: token.Span;
    body:  id.StmtId;
}

# ComptimeBranch: one arm of a comptime if/or chain, shared between decl-level and stmt-level comptime_if.
# ---
# cond:       arm condition, or EXPR_NIL for the final unconditional `$or { ... }`
# body_start: start index into ast.decl_ids (decl-level) or ast.stmt_ids (stmt-level), determined by the parent node's kind
# body_len:   number of entries in the arm body
pub rec ComptimeBranch {
    cond:       id.ExprId;
    body_start: u32;
    body_len:   u32;
}

# DeclComptimeIf: a `$if (cond) { decls } $or (cond) { decls } $or { decls }` chain at declaration scope.
# ---
# branches_start: start index into ast.comptime_branches
# branches_len:   number of arms (at least 1)
pub rec DeclComptimeIf {
    branches_start: u32;
    branches_len:   u32;
}

# DeclComptimeAttr: a bare compile-time comptime-channel directive
# `$intrinsic(args);` (e.g. `$error("msg")`). the legacy attribute-write setter
# `$sym.attr = value;` was removed in v2.0.0 (superseded by backtick decorators).
# ---
# target: the directive call expression
pub rec DeclComptimeAttr {
    target: id.ExprId;
}

# Decorator: a leading backtick per-declaration codegen directive (#1476), e.g.
# `#[symbol("_start")]` / `#[inline]` / `#[align($align_of(u64))]`.
# codegen-only (never visibility). attached to the following decl via the decl's
# decorators_start/decorators_len range.
# ---
# name:       span of the directive identifier (symbol/section/inline/align/library)
# args_start: start index into ast.expr_ids; each slot is a comptime-expr arg ExprId
# args_len:   number of arguments (0 for a bare flag like `inline`)
pub rec Decorator {
    name:       token.Span;
    args_start: u32;
    args_len:   u32;
}

# Decl: a syntactic declaration node.
# ---
# span:            byte range of the declaration in source
# kind:            which DECL_KIND_* variant is active
# flags:           bitfield of DECL_FLAG_* values (pub, ext)
# decorators_start: start index into ast.decorators of this decl's leading decorators
# decorators_len:  number of leading decorators, backtick or `#[...]` (0 if none)
# data:            kind-specific payload; unused for ERROR (discriminated by kind alone)
pub rec Decl {
    span:  token.Span;
    kind:  DeclKind;
    flags: u8;
    decorators_start: u32;
    decorators_len:   u32;
    data: uni {
        use_:          DeclUse;
        fwd_:          DeclFwd;
        fun_:          DeclFun;
        rec_:          DeclRec;
        uni_:          DeclUni;
        bind:          DeclBind;
        def_:          DeclDef;
        test_:         DeclTest;
        comptime_if:   DeclComptimeIf;
        comptime_attr: DeclComptimeAttr;
    };
}
