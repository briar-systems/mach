# mach.lang.fe.ast.type: syntactic type AST nodes, the parser's representation of types as written in source.
#
# each Type is stored by value in Ast.types. distinct from the semantic
# mach.lang.type.Type, which is the interned type sema produces from these
# syntactic nodes.

use std.types.bool.bool;

use token: mach.lang.fe.token;
use id:    mach.lang.fe.ast.id;

# TypeKind: discriminator for Type.data.
pub def TypeKind: u8;

pub val TYPE_KIND_NAMED: TypeKind = 0;
pub val TYPE_KIND_PTR:   TypeKind = 1;
pub val TYPE_KIND_ARRAY: TypeKind = 2;
pub val TYPE_KIND_FUN:   TypeKind = 3;
pub val TYPE_KIND_REC:   TypeKind = 4;
pub val TYPE_KIND_UNI:   TypeKind = 5;
# a comptime variadic pack type `...` on a named trailing parameter (#1474):
# `fun f(va: ...)`. carries no payload — the pack's element types are fixed per
# call site and supplied by monomorphization (#1475), not at declaration.
pub val TYPE_KIND_PACK:  TypeKind = 6;
pub val TYPE_KIND_ERROR: TypeKind = 255;

# TypeNamed: a named type reference, optionally with generic arguments.
# ---
# name:       span of the identifier or dotted path as written in source
# args_start: start index into ast.type_ids
# args_len:   number of generic arguments (0 for a non-generic name)
pub rec TypeNamed {
    name:       token.Span;
    args_start: u32;
    args_len:   u32;
}

# TypePtr: a pointer type *T.
# ---
# pointee: element type being pointed to
pub rec TypePtr {
    pointee: id.TypeId;
}

# TypeArray: a fixed-length array type [N]T.
# ---
# length:  expression that evaluates to the array length
# element: element type
pub rec TypeArray {
    length:  id.ExprId;
    element: id.TypeId;
}

# TypeFun: a function type fun(T, U) R.
# ---
# params_start: start index into ast.type_ids
# params_len:   number of parameter types
# ret_type:       return type, or TYPE_NIL for no explicit return
pub rec TypeFun {
    params_start: u32;
    params_len:   u32;
    ret_type:       id.TypeId;
}

# TypeRec: an anonymous record type `rec { name: T; ... }`.
# ---
# fields_start: start index into ast.typed_names; each slot holds a TypedName
# fields_len:   number of fields
pub rec TypeRec {
    fields_start: u32;
    fields_len:   u32;
}

# TypeUni: an anonymous raw union type `uni { name: T; ... }`.
# ---
# fields_start: start index into ast.typed_names; each slot holds a TypedName
# fields_len:   number of variants
pub rec TypeUni {
    fields_start: u32;
    fields_len:   u32;
}

# Type: a syntactic type reference as it appears in source.
# ---
# span: byte range of the type expression
# kind: which TYPE_KIND_* variant is active
# data: kind-specific payload; unused for ERROR (discriminated by kind alone)
pub rec Type {
    span: token.Span;
    kind: TypeKind;
    data: uni {
        named: TypeNamed;
        ptr:   TypePtr;
        array: TypeArray;
        fun_:  TypeFun;
        rec_:  TypeRec;
        uni_:  TypeUni;
    };
}
