# mach.lang.fe.ast.module: the top-level AST node for one parsed source file.

use token: mach.lang.fe.token;

# Module: the top-level AST node for one parsed source file.
# ---
# span:        byte range covering the whole module
# decls_start: start index into ast.decl_ids
# decls_len:   number of declarations at module scope
pub rec Module {
    span:        token.Span;
    decls_start: u32;
    decls_len:   u32;
}
