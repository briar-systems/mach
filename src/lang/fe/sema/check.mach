# type checking for semantic analysis
#
# where infer computes the type of every expression bottom-up, check
# validates that those types compose correctly at the sites that constrain
# them - assignments, calls, index and member access, casts, returns, and
# conditions - and reports a diagnostic with the canonical sema prefix when
# they do not.
#
# every check tolerates the poison type: a `TYPE_ERROR` operand short-
# circuits to success (or to an error-typed result) so a single upstream
# failure produces exactly one diagnostic instead of a cascade.
#
# assignability is literal coercion followed by identity (see `coerce`):
# an untyped literal is first offered the expected type, and only if that
# fails are the two types compared for identity. there is no implicit
# widening between typed values.

use std.memory;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.char.char;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema.coerce;
use mach.lang.fe.sema.context;
use mach.lang.fe.sema.generics;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.session;
use mach.lang.type;

# checks that a value of type `actual` may flow into a slot of type `expected`
#
# callers coerce literals themselves before delegating here, so this is a pure
# type relation: identity first, then the structural assignability rule from
# `coerce`. records a `type mismatch:` diagnostic against `span` on failure.
# ---
# sc:       the active sema context
# expected: the destination slot's type
# actual:   the source value's (already-coerced) type
# span:     source range to attribute a mismatch to
# ret:      true when the value is assignable, false (with a diagnostic) otherwise
pub fun check_assignable(sc: *context.SemaContext, expected: type.TypeId, actual: type.TypeId, span: token.Span) bool {
    if (expected == type.TYPE_ERROR || actual == type.TYPE_ERROR) { ret true; }
    if (expected == actual)                                       { ret true; }

    if (coerce.is_assignable(sc, actual, expected)) { ret true; }

    report_mismatch(sc, span, expected, actual,
        "mach has no implicit widening; cast the value with `value::Type`");
    ret false;
}

# checks a call against the callee's function signature
#
# the callee type must be a function, the argument count must match the fixed
# parameter count (or be at least that many for a pack-tailed function), and
# each fixed argument must be assignable to its parameter. trailing pack
# arguments carry their inferred types unchecked here; their element types are
# fixed per call site at monomorphization. argument expressions are taken from
# `sc.a.expr_ids[args_start ..]`, which lets untyped-literal arguments coerce to
# their parameter type.
# ---
# sc:         the active sema context
# callee_sig: the callee's type; must be TYPE_FUN
# args_start: start index into sc.a.expr_ids for the argument expressions
# args_len:   number of arguments supplied at the call site
# span:       source range of the call
# ret:        true when the call is well-typed, false (with a diagnostic) otherwise
pub fun check_call(sc: *context.SemaContext, callee_sig: type.TypeId, args_start: u32, args_len: u32, span: token.Span) bool {
    if (callee_sig == type.TYPE_ERROR) { ret true; }

    val opt_fun: O.Option[*type.Type] = type.get(?sc.s.types, callee_sig);
    if (O.is_none[*type.Type](opt_fun)) {
        report(sc, span, "not callable: callee is not a function");
        ret false;
    }
    val fun_type: *type.Type = O.unwrap[*type.Type](opt_fun);
    if (fun_type.kind != type.TYPE_FUN) {
        report_typed(sc, span, "not callable: `", callee_sig, "` is not a function", "not callable: callee is not a function");
        ret false;
    }

    val params_len:   u32 = fun_type.data.fn.params_len;
    val params_start: u32 = fun_type.data.fn.params_start;

    # a trailing comptime variadic pack param absorbs every trailing argument:
    # arity is `>= the leading fixed count`, and the collected args carry their
    # inferred types unchecked here - their concrete element types are fixed per
    # call site and bound at monomorphization.
    var fixed_len: u32  = params_len;
    val has_pack:  bool = params_len > 0 && param_is_pack(sc, params_start + params_len - 1);
    if (has_pack) { fixed_len = params_len - 1; }

    # a `va...` pack spread forwards a whole pack; reject an ill-placed one first
    # - before arity and the per-argument check - so a misplaced spread reports
    # its own clear diagnostic rather than an arity mismatch, and a pack operand
    # is never additionally diagnosed against a fixed parameter type.
    if (!validate_pack_spreads(sc, has_pack, fixed_len, args_start, args_len, span)) {
        ret false;
    }

    if (has_pack) {
        if (args_len < fixed_len) {
            report_arity(sc, span, fixed_len, args_len, true);
            ret false;
        }
    }
    or (args_len != params_len) {
        report_arity(sc, span, params_len, args_len, false);
        ret false;
    }

    var all_ok: bool = true;
    var i:      u32  = 0;
    for (i < fixed_len) {
        val opt_param_type: O.Option[type.TypeId] = type.get_param(?sc.s.types, params_start + i);
        if (O.is_none[type.TypeId](opt_param_type)) { all_ok = false; brk; }
        val expected: type.TypeId = O.unwrap[type.TypeId](opt_param_type);

        val arg_eid: id.ExprId = sc.a.expr_ids[args_start + i];
        var actual: type.TypeId = expr_type_of(sc, arg_eid);
        # a bare integer / float literal argument adopts the parameter's type, so
        # `err[i64, i32](-1)` passes `-1` as an i32.
        val opt_coerced: O.Option[type.TypeId] = coerce.try_coerce_literal(sc, arg_eid, expected);
        if (O.is_some[type.TypeId](opt_coerced)) { actual = O.unwrap[type.TypeId](opt_coerced); }
        val arg_span: token.Span = expr_span_of(sc, arg_eid, span);
        if (!check_assignable(sc, expected, actual, arg_span)) {
            all_ok = false;
        }
        i = i + 1;
    }
    ret all_ok;
}

# checks a call to a function with comptime value parameters
#
# arity is checked against the AST parameter list (which includes the comptime
# ones); each `$`-parameter's argument must be compile-time foldable (else a
# diagnostic); each runtime-parameter's argument is checked assignable against
# the stripped TYPE_FUN signature, whose params omit the comptime ordinals.
# ---
# sc:         the active sema context
# callee_sig: the callee's stripped TYPE_FUN (comptime params removed)
# callee:     the call's callee expression id (to resolve the origin DeclFun)
# f:          the callee's DeclFun, read from its origin AST
# args_start: start index into sc.a.expr_ids for the argument expressions
# args_len:   number of arguments supplied at the call site
# span:       source range of the call
# ret:        true when the call is well-typed, false (with a diagnostic) otherwise
pub fun check_comptime_call(sc: *context.SemaContext, callee_sig: type.TypeId, callee: id.ExprId, f: *decl.DeclFun, args_start: u32, args_len: u32, span: token.Span) bool {
    val params_ast: *ast.Ast = callee_origin_ast(sc, callee);
    if (params_ast == nil) { ret true; }

    val param_total: u32 = f.params_len;
    if (args_len != param_total) {
        report_arity(sc, span, param_total, args_len, false);
        ret false;
    }

    val opt_sig: O.Option[*type.Type] = type.get(?sc.s.types, callee_sig);
    if (O.is_none[*type.Type](opt_sig)) { ret true; }
    val sig:      *type.Type = O.unwrap[*type.Type](opt_sig);
    val rt_start: u32        = sig.data.fn.params_start;
    val rt_len:   u32        = sig.data.fn.params_len;

    var all_ok:  bool = true;
    var i:       u32  = 0;
    var rt_seen: u32  = 0;
    for (i < param_total) {
        val tn:       *decl.TypedName = ?params_ast.typed_names[f.params_start + i];
        val arg_eid:  id.ExprId       = sc.a.expr_ids[args_start + i];
        val arg_span: token.Span      = expr_span_of(sc, arg_eid, span);

        if (tn.comptime) {
            # the argument bound to a `$`-parameter must fold to a compile-time
            # constant in the caller's comptime context. an argument that itself
            # references a comptime parameter (a recursive comptime-param call,
            # e.g. `f($n - 1)`) is unfoldable at sema (the parameter's value is
            # per call site) but IS foldable at lowering, where the value is
            # bound; its constness is checked there, with an instantiation cap
            # guarding unbounded recursion.
            if (!arg_references_comptime_param(sc, arg_eid) && !arg_names_module_constant(sc, arg_eid)) {
                val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, arg_eid, ?sc.s.interner);
                if (R.is_err[comptime.CTValue, str](res_eval)) {
                    # the evaluator's reason (a static string) clarifies why the
                    # fold failed; surface it on a note line.
                    report_note(sc, arg_span, "comptime argument is not a compile-time constant", R.unwrap_err[comptime.CTValue, str](res_eval));
                    all_ok = false;
                }
            }
            i = i + 1;
            cnt;
        }

        # a runtime parameter: check the argument against the next stripped
        # signature param.
        if (rt_seen < rt_len) {
            val opt_param_type: O.Option[type.TypeId] = type.get_param(?sc.s.types, rt_start + rt_seen);
            if (O.is_some[type.TypeId](opt_param_type)) {
                val expected: type.TypeId = O.unwrap[type.TypeId](opt_param_type);
                var actual: type.TypeId = expr_type_of(sc, arg_eid);
                val opt_coerced: O.Option[type.TypeId] = coerce.try_coerce_literal(sc, arg_eid, expected);
                if (O.is_some[type.TypeId](opt_coerced))               { actual = O.unwrap[type.TypeId](opt_coerced); }
                if (!check_assignable(sc, expected, actual, arg_span)) { all_ok = false; }
            }
            rt_seen = rt_seen + 1;
        }
        i = i + 1;
    }
    ret all_ok;
}

# reports whether `sym` is an import that resolves to a module-level `val` in
# its origin module
#
# the only imports whose constness fold can be deferred to lowering.
# SYM_IMPORTED alone is too broad: it covers every imported symbol (functions,
# records, runtime bindings included), so an imported non-constant used as a
# `$if` gate or `$`-argument would otherwise pass sema and then fail span-less
# at lowering. reads the origin AST through the session registry.
# ---
# sc:  the active sema context
# sym: the resolved symbol to classify
# ret: true when `sym` imports a module-level `val`, false otherwise
pub fun imported_module_const_sym(sc: *context.SemaContext, sym: *resolve.Symbol) bool {
    if (sym.kind != resolve.SYM_IMPORTED) { ret false; }
    val origin_ast: *ast.Ast = session.module_ast(sc.s, sym.origin);
    if (origin_ast == nil) { ret false; }
    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(origin_ast, sym.decl);
    if (O.is_none[*decl.Decl](opt_decl)) { ret false; }
    ret O.unwrap[*decl.Decl](opt_decl).kind == decl.DECL_KIND_VAL;
}

# checks an index expression `object[index]`
#
# the object must be a pointer or array; the index must be an integer. the
# result type is the pointee / element type. on failure a `not indexable:`
# diagnostic is recorded and `none` is returned (the caller poisons the
# expression).
# ---
# sc:     the active sema context
# object: the indexed object's type
# index:  the index expression's type
# span:   source range of the index expression
# ret:    some(element type) on success, none (with a diagnostic) otherwise
pub fun check_index(sc: *context.SemaContext, object: type.TypeId, index: type.TypeId, span: token.Span) O.Option[type.TypeId] {
    if (object == type.TYPE_ERROR) { ret O.some[type.TypeId](type.TYPE_ERROR); }

    val opt_object: O.Option[*type.Type] = type.get(?sc.s.types, object);
    if (O.is_none[*type.Type](opt_object)) {
        report(sc, span, "not indexable: object is neither a pointer nor an array");
        ret O.none[type.TypeId]();
    }
    val object_type: *type.Type = O.unwrap[*type.Type](opt_object);

    var elem: type.TypeId = type.TYPE_NIL;
    if (object_type.kind == type.TYPE_POINTER) {
        elem = object_type.data.pointer.base;
    }
    or (object_type.kind == type.TYPE_ARRAY) {
        elem = object_type.data.array.base;
    }
    or {
        report(sc, span, "not indexable: object is neither a pointer nor an array");
        ret O.none[type.TypeId]();
    }

    if (index != type.TYPE_ERROR && !is_integer(sc, index)) {
        report(sc, span, "type mismatch: index must be an integer");
    }
    ret O.some[type.TypeId](elem);
}

# checks a member access `object.name`
#
# delegates field lookup to the sema field tables (which know the fields of
# every record, union, and the builtin `str`). member access auto-dereferences
# a single pointer level: `p.x` on a `*Point` denotes the field through the
# pointer. on a missing field a `no such field:` diagnostic is recorded and
# `none` is returned.
# ---
# sc:     the active sema context
# object: the type of the expression to the left of the dot
# name:   interned identifier of the accessed field
# span:   source range of the member access
# ret:    some(field type) on success, none (with a diagnostic) otherwise
pub fun check_member(sc: *context.SemaContext, object: type.TypeId, name: intern.StrId, span: token.Span) O.Option[type.TypeId] {
    if (object == type.TYPE_ERROR) { ret O.some[type.TypeId](type.TYPE_ERROR); }

    val record: type.TypeId = deref_one(sc, object);
    val opt_field: O.Option[type.TypeId] = context.field_lookup(sc, record, name);
    if (O.is_some[type.TypeId](opt_field)) { ret opt_field; }

    report_no_field(sc, span, name, record);
    ret O.none[type.TypeId]();
}

# checks an explicit cast `value::Type`
#
# two casts are legal: a numeric conversion between primitive numeric types, or
# a bit reinterpretation between any two types of identical byte size. anything
# else is rejected with a `cast:` diagnostic.
# ---
# sc:   the active sema context
# from: the operand's type
# to:   the target type written after `::`
# span: source range of the cast
# ret:  some(to) when the cast is legal, none (with a diagnostic) otherwise
pub fun check_cast(sc: *context.SemaContext, from: type.TypeId, to: type.TypeId, span: token.Span) O.Option[type.TypeId] {
    if (from == type.TYPE_ERROR || to == type.TYPE_ERROR) { ret O.some[type.TypeId](to); }
    if (from == to)                                       { ret O.some[type.TypeId](to); }

    # primitive numeric <-> primitive numeric conversion
    if (is_numeric(sc, from) && is_numeric(sc, to)) {
        ret O.some[type.TypeId](to);
    }

    # same-size bit reinterpretation for everything else (covers
    # pointer <-> pointer, since every pointer type has size 8)
    val size_from: u32 = byte_size(sc, from);
    val size_to:   u32 = byte_size(sc, to);
    if (size_from != 0 && size_from == size_to) {
        ret O.some[type.TypeId](to);
    }

    report_note(sc, span, "cast: conversion is invalid",
        "`::` casts numeric types or reinterprets equal-size values only");
    ret O.none[type.TypeId]();
}

# checks a bit-reinterpret cast `value:~Type`
#
# legal only when `from` and `to` have a known, identical byte size; the
# operand's exact bits are reinterpreted as the target type. a size mismatch (or
# an unknown-layout operand) is rejected with a `bit reinterpret:` diagnostic
# naming both types and their sizes.
# ---
# sc:   the active sema context
# from: the operand's type
# to:   the target type written after `:~`
# span: source range of the cast
# ret:  some(to) when the reinterpret is legal, none (with a diagnostic) otherwise
pub fun check_reinterpret(sc: *context.SemaContext, from: type.TypeId, to: type.TypeId, span: token.Span) O.Option[type.TypeId] {
    if (from == type.TYPE_ERROR || to == type.TYPE_ERROR) { ret O.some[type.TypeId](to); }

    val size_from: u32 = byte_size(sc, from);
    val size_to:   u32 = byte_size(sc, to);
    if (size_from != 0 && size_from == size_to) { ret O.some[type.TypeId](to); }

    report_reinterpret_mismatch(sc, span, from, size_from, to, size_to);
    ret O.none[type.TypeId]();
}

# checks a `ret value;` against the enclosing function's declared return type
#
# a bare `ret;` is signalled by `value == TYPE_NIL` and is valid only when the
# function returns nothing (fn_ret TYPE_NIL); a value is required otherwise and
# must be assignable to the return type. `value` is the already-inferred (and
# caller-coerced) type of the returned expression.
# ---
# sc:     the active sema context
# fn_ret: the enclosing function's declared return type (TYPE_NIL = no return)
# value:  the returned value's inferred type (TYPE_NIL for a bare `ret;`)
# span:   source range of the return statement
# ret:    true when the return is well-typed, false (with a diagnostic) otherwise
pub fun check_return(sc: *context.SemaContext, fn_ret: type.TypeId, value: type.TypeId, span: token.Span) bool {
    if (value == type.TYPE_NIL) {
        if (fn_ret == type.TYPE_NIL || fn_ret == type.TYPE_ERROR) { ret true; }
        report(sc, span, "type mismatch: function must return a value");
        ret false;
    }
    if (fn_ret == type.TYPE_NIL) {
        report(sc, span, "type mismatch: function returns no value");
        ret false;
    }
    ret check_assignable(sc, fn_ret, value, span);
}

# checks that a control-flow condition is usable as a truth value
#
# Mach has no distinct boolean type; comparisons and logical operators produce
# `u8` (the stdlib `bool`), so a condition must be an integer primitive. a
# non-integer condition records a `type mismatch:` diagnostic.
# ---
# sc:   the active sema context
# cond: the condition expression's inferred type
# span: source range of the condition
# ret:  true when the condition is an integer primitive, false otherwise
pub fun check_condition(sc: *context.SemaContext, cond: type.TypeId, span: token.Span) bool {
    if (cond == type.TYPE_ERROR) { ret true; }
    if (is_integer(sc, cond))    { ret true; }
    report_note(sc, span, "type mismatch: condition must be an integer",
        "mach has no `bool` type; comparisons yield an integer truth value");
    ret false;
}

# reports whether `t` is any numeric primitive (integer or float)
#
# delegates to the shared kind-based predicate in the type layer.
# ---
# sc:  the active sema context
# t:   a TypeId
# ret: true for u8..u64, i8..i64, f32, f64
pub fun is_numeric(sc: *context.SemaContext, t: type.TypeId) bool {
    ret type.is_numeric(?sc.s.types, t);
}

# reports whether `t` is an integer primitive (any signed or unsigned width)
#
# delegates to the shared kind-based predicate in the type layer.
# ---
# sc:  the active sema context
# t:   a TypeId
# ret: true for u8..u64 and i8..i64
pub fun is_integer(sc: *context.SemaContext, t: type.TypeId) bool {
    ret type.is_integer(?sc.s.types, t);
}

# the byte size of a type, resolving pointers/arrays/records via the interner
#
# pointer and function values are pointer-sized, read from the target's pointer
# width; records and unions report 0 because their layout is not computed in
# sema (the backend owns layout). a 0 result signals "size unknown" and disables
# same-size cast reinterpretation.
# ---
# sc:  the active sema context
# t:   a TypeId
# ret: the size in bytes, or 0 when the size is not known at this layer
pub fun byte_size(sc: *context.SemaContext, t: type.TypeId) u32 {
    val opt_type: O.Option[*type.Type] = type.get(?sc.s.types, t);
    if (O.is_none[*type.Type](opt_type)) { ret 0; }
    val tp: *type.Type    = O.unwrap[*type.Type](opt_type);
    val k:  type.TypeKind = tp.kind;
    val d:  type.PrimDesc = type.prim_desc(k);
    if (d.class == type.PRIM_CLASS_INT || d.class == type.PRIM_CLASS_FLOAT) { ret d.bits / 8; }
    # a raw `ptr`, a typed `*T`, and a function value (a code address) are all
    # pointer-sized, read from the target's pointer width.
    if (k == type.TYPE_PTR || k == type.TYPE_POINTER || k == type.TYPE_FUN) { ret ptr_width(sc); }
    if (k == type.TYPE_ARRAY) {
        # widen the multiply: a >4GiB array would wrap a u32 product and report a
        # wrong size to cast legality, so saturate to the 0 "unknown" sentinel.
        val total: u64 = byte_size(sc, tp.data.array.base)::u64 * tp.data.array.count::u64;
        if (total > 4294967295) { ret 0; }
        ret total::u32;
    }
    ret 0;
}

# render `t` to an owned, human-readable spelling for diagnostics
#
# primitives render to their keyword (`i64`, `f32`, `ptr`); a pointer to `*T`;
# an array to `[N]T`; a record / union / generic parameter to its declared name;
# a function to `fun(A, B) R`; and a generic instance to `Name[Arg, ...]`.
# composite forms recurse over their components; an unknown or unnamed type
# renders to a `<error>` / `<anon>` placeholder. the result is allocated from
# the session allocator and must be released with type_str_free.
# ---
# sc: the active sema context (type universe, interner, AST registry)
# t:  the type to render
# ret: an owned, null-terminated spelling, or an allocation error
pub fun type_to_str(sc: *context.SemaContext, t: type.TypeId) R.Result[str, str] {
    val len: usize = type_str_len(sc, t);
    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, len + 1);
    if (R.is_err[*char, str](res_buf)) { ret R.err[str, str](R.unwrap_err[*char, str](res_buf)); }
    val buf: str   = R.unwrap_ok[*char, str](res_buf);
    val w:   usize = write_type_str(sc, buf, 0, t);
    buf[w] = 0;
    ret R.ok[str, str](buf);
}

# release a string returned by type_to_str
# ---
# sc: the sema context whose allocator backed the string
# s:  the owned string to free (nil is a no-op)
pub fun type_str_free(sc: *context.SemaContext, s: str) {
    if (s == nil) { ret; }
    A.deallocate[char](sc.s.alloc, s, str_len(s) + 1);
}

# report a `no such field `<name>` on type <T>` diagnostic
#
# names the missing field and the record type it was looked up on. any
# allocation failure degrades to a static, name-free message so the error is
# always reported.
# ---
# sc:     the active sema context
# span:   source range to pin the diagnostic to
# name:   interned identifier of the missing field
# record: the record/union type the field was looked up on
pub fun report_no_field(sc: *context.SemaContext, span: token.Span, name: intern.StrId, record: type.TypeId) {
    val res_type: R.Result[str, str] = type_to_str(sc, record);
    if (R.is_err[str, str](res_type)) {
        report(sc, span, "no such field: type has no field with that name");
        ret;
    }
    val type_str: str = R.unwrap_ok[str, str](res_type);

    val prefix: str   = "no such field `";
    val mid:    str   = "` on type ";
    val total:  usize = str_len(prefix) + name_str_len(sc, name) + str_len(mid) + str_len(type_str);

    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report(sc, span, "no such field: type has no field with that name");
        type_str_free(sc, type_str);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_name(sc, msg, w, name);
    w = write_kw(msg, w, mid);
    w = write_kw(msg, w, type_str);
    msg[w] = 0;

    report(sc, span, msg);
    A.deallocate[char](sc.s.alloc, msg, total + 1);
    type_str_free(sc, type_str);
}

# report `<prefix><name><suffix>` at `span`, interpolating the interned
# identifier `name`
#
# on any allocation failure it degrades to the static `fallback` so the
# diagnostic always lands.
# ---
# sc:       the active sema context
# span:     source range to pin the diagnostic to
# prefix:   text before the rendered name
# name:     interned identifier to embed
# suffix:   text after the rendered name
# fallback: name-free message used when allocation fails
pub fun report_named(sc: *context.SemaContext, span: token.Span, prefix: str, name: intern.StrId, suffix: str, fallback: str) {
    val total: usize = str_len(prefix) + name_str_len(sc, name) + str_len(suffix);
    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report(sc, span, fallback);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_name(sc, msg, w, name);
    w = write_kw(msg, w, suffix);
    msg[w] = 0;

    report(sc, span, msg);
    A.deallocate[char](sc.s.alloc, msg, total + 1);
}

# report `<prefix><type><suffix>` at `span`, rendering `t` through type_to_str
#
# on any allocation failure it degrades to the static `fallback` so the
# diagnostic always lands.
# ---
# sc:       the active sema context
# span:     source range to pin the diagnostic to
# prefix:   text before the rendered type
# t:        the type to render into the message
# suffix:   text after the rendered type
# fallback: type-free message used when rendering or allocation fails
pub fun report_typed(sc: *context.SemaContext, span: token.Span, prefix: str, t: type.TypeId, suffix: str, fallback: str) {
    val res_type: R.Result[str, str] = type_to_str(sc, t);
    if (R.is_err[str, str](res_type)) {
        report(sc, span, fallback);
        ret;
    }
    val type_str: str = R.unwrap_ok[str, str](res_type);

    val total: usize = str_len(prefix) + str_len(type_str) + str_len(suffix);
    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report(sc, span, fallback);
        type_str_free(sc, type_str);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_kw(msg, w, type_str);
    w = write_kw(msg, w, suffix);
    msg[w] = 0;

    report(sc, span, msg);
    A.deallocate[char](sc.s.alloc, msg, total + 1);
    type_str_free(sc, type_str);
}

# report `<prefix><a><mid><b><suffix>` at `span`, rendering both `a` and `b`
# through type_to_str
#
# degrades to the static `fallback` on any allocation failure so the diagnostic
# always lands.
# ---
# sc:       the active sema context
# span:     source range to pin the diagnostic to
# prefix:   text before the first rendered type
# a:        the first type to render
# mid:      text between the two rendered types
# b:        the second type to render
# suffix:   text after the second rendered type
# fallback: type-free message used when rendering or allocation fails
pub fun report_typed2(sc: *context.SemaContext, span: token.Span, prefix: str, a: type.TypeId, mid: str, b: type.TypeId, suffix: str, fallback: str) {
    val res_a: R.Result[str, str] = type_to_str(sc, a);
    val res_b: R.Result[str, str] = type_to_str(sc, b);
    if (R.is_err[str, str](res_a) || R.is_err[str, str](res_b)) {
        report(sc, span, fallback);
        if (R.is_ok[str, str](res_a)) { type_str_free(sc, R.unwrap_ok[str, str](res_a)); }
        if (R.is_ok[str, str](res_b)) { type_str_free(sc, R.unwrap_ok[str, str](res_b)); }
        ret;
    }
    val a_str: str = R.unwrap_ok[str, str](res_a);
    val b_str: str = R.unwrap_ok[str, str](res_b);

    val total: usize = str_len(prefix) + str_len(a_str) + str_len(mid) + str_len(b_str) + str_len(suffix);
    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report(sc, span, fallback);
        type_str_free(sc, a_str);
        type_str_free(sc, b_str);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_kw(msg, w, a_str);
    w = write_kw(msg, w, mid);
    w = write_kw(msg, w, b_str);
    w = write_kw(msg, w, suffix);
    msg[w] = 0;

    report(sc, span, msg);
    A.deallocate[char](sc.s.alloc, msg, total + 1);
    type_str_free(sc, a_str);
    type_str_free(sc, b_str);
}

# whether the parameter interned at `param_idx` is a comptime variadic pack
#
# the trailing form that absorbs a call's remaining arguments.
# ---
# sc:        the active sema context
# param_idx: index into the type interner's parameter pool
# ret:       true when the parameter's type is TYPE_PACK
fun param_is_pack(sc: *context.SemaContext, param_idx: u32) bool {
    val opt_param_type: O.Option[type.TypeId] = type.get_param(?sc.s.types, param_idx);
    if (O.is_none[type.TypeId](opt_param_type)) { ret false; }
    val opt_type: O.Option[*type.Type] = type.get(?sc.s.types, O.unwrap[type.TypeId](opt_param_type));
    if (O.is_none[*type.Type](opt_type)) { ret false; }
    ret O.unwrap[*type.Type](opt_type).kind == type.TYPE_PACK;
}

# whether the argument at `eid` is a `va...` pack spread
# ---
# sc:  the active sema context
# eid: the argument expression id
# ret: true when the expression is an EXPR_KIND_SPREAD
fun arg_is_spread(sc: *context.SemaContext, eid: id.ExprId) bool {
    val opt_expr: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](opt_expr)) { ret false; }
    ret O.unwrap[*expr.Expr](opt_expr).kind == expr.EXPR_KIND_SPREAD;
}

# validates the placement of any `va...` pack spread among a call's arguments
#
# a spread forwards a whole pack and is valid ONLY as the sole trailing argument
# of a pack-tailed callee - i.e. at index `fixed_len` with `args_len == fixed_len
# + 1`. spreading into fixed parameters (no pack tail) or a spread mixed with
# other trailing args is rejected. a spread whose operand is not a pack already
# reported in `infer_spread`, so it is not re-diagnosed here.
# ---
# sc:         the active sema context
# has_pack:   whether the callee has a trailing pack parameter
# fixed_len:  number of leading fixed parameters
# args_start: start index into sc.a.expr_ids for the argument expressions
# args_len:   number of arguments supplied at the call site
# span:       fallback source range for a spread whose own span is unavailable
# ret:        true when every spread is well-placed, false (with a diagnostic) otherwise
fun validate_pack_spreads(sc: *context.SemaContext, has_pack: bool, fixed_len: u32, args_start: u32, args_len: u32, span: token.Span) bool {
    var all_ok: bool = true;
    var i:      u32  = 0;
    for (i < args_len) {
        val arg_eid: id.ExprId = sc.a.expr_ids[args_start + i];
        if (arg_is_spread(sc, arg_eid)) {
            val arg_span: token.Span = expr_span_of(sc, arg_eid, span);
            if (expr_type_of(sc, arg_eid) == type.TYPE_ERROR) {
                all_ok = false;
            }
            or (!has_pack) {
                report(sc, arg_span, "cannot spread `...` into fixed parameters: the callee has no variadic pack parameter");
                all_ok = false;
            }
            or (i != fixed_len || args_len != fixed_len + 1) {
                report(sc, arg_span, "a `...` pack spread must be the sole trailing argument, forwarding the whole pack");
                all_ok = false;
            }
        }
        i = i + 1;
    }
    ret all_ok;
}

# reports whether `eid` names a constant imported from another module
#
# an imported binding that resolves to a module-level `val` in its origin
# module. such a value lives only in the defining module's comptime context,
# which sema does not hold, so its constness fold is deferred to lowering. a
# local or module-level SYM_VAL is NOT deferred: a comptime one folds in the
# eager check here, and a non-foldable (runtime) one is reported eagerly rather
# than slipping through an uninstantiated template whose body never lowers.
# ---
# sc:  the active sema context
# eid: the argument expression id
# ret: true when `eid` names an imported module-level constant
fun arg_names_module_constant(sc: *context.SemaContext, eid: id.ExprId) bool {
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret false; }
    ret imported_module_const_sym(sc, O.unwrap[*resolve.Symbol](opt_sym));
}

# walks `eid` reporting whether any leaf identifier resolves to a comptime value
# parameter (SYM_PARAM with SYM_FLAG_COMPTIME)
#
# such an argument is foldable only at lowering, so its constness check is
# deferred there.
# ---
# sc:  the active sema context
# eid: the argument expression id (EXPR_NIL terminates the walk)
# ret: true when any leaf resolves to a comptime value parameter
fun arg_references_comptime_param(sc: *context.SemaContext, eid: id.ExprId) bool {
    if (eid == id.EXPR_NIL) { ret false; }
    val opt_expr: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](opt_expr)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](opt_expr);

    if (e.kind == expr.EXPR_KIND_IDENT) {
        val opt_sym: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
        if (O.is_none[*resolve.Symbol](opt_sym)) { ret false; }
        val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
        ret sym.kind == resolve.SYM_PARAM && (sym.flags & resolve.SYM_FLAG_COMPTIME) != 0;
    }
    if (e.kind == expr.EXPR_KIND_BINARY) {
        ret arg_references_comptime_param(sc, e.data.binary.lhs)
         || arg_references_comptime_param(sc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret arg_references_comptime_param(sc, e.data.unary.operand);
    }
    ret false;
}

# the AST a call's callee is declared in
#
# the caller's own AST for a local callee, or the origin module's AST for a
# cross-module one. nil when the callee does not resolve to a declaration.
# ---
# sc:     the active sema context
# callee: the callee expression id
# ret:    the declaring AST, or nil when the callee does not resolve
fun callee_origin_ast(sc: *context.SemaContext, callee: id.ExprId) *ast.Ast {
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, callee);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret nil; }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    if (sym.origin == sc.own_module) { ret sc.a; }
    ret session.module_ast(sc.s, sym.origin);
}

# the pointee of a single pointer level, or the type itself when not a pointer
#
# field access uses this so a record reached through a pointer is looked up in
# the record's own field table.
# ---
# sc:     the active sema context
# object: the type to peel a single pointer level from
# ret:    the pointee type, or `object` unchanged when it is not a pointer
fun deref_one(sc: *context.SemaContext, object: type.TypeId) type.TypeId {
    val opt_type: O.Option[*type.Type] = type.get(?sc.s.types, object);
    if (O.is_none[*type.Type](opt_type)) { ret object; }
    val tp: *type.Type = O.unwrap[*type.Type](opt_type);
    if (tp.kind == type.TYPE_POINTER) { ret tp.data.pointer.base; }
    ret object;
}

# the target's pointer width in bytes
#
# read from the comptime context the driver seeds with the active target's
# parameters. cast/reinterpret legality is a target-dependent type rule, so the
# width must come from the target layer rather than a hardcoded constant.
# ---
# sc:  the active sema context
# ret: the active target's pointer width in bytes
fun ptr_width(sc: *context.SemaContext) u32 {
    ret sc.ctx.pointer_width;
}

# reads expr_type[eid] from the parallel array
#
# returns TYPE_ERROR for an out-of-range or nil id so callers never read past
# the array.
# ---
# sc:  the active sema context
# eid: the expression id to read the inferred type of
# ret: the inferred type, or TYPE_ERROR when the id is nil or out of range
fun expr_type_of(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    if (eid == id.EXPR_NIL)                                 { ret type.TYPE_ERROR; }
    if (sc.expr_type == nil || eid::usize >= sc.a.expr_len) { ret type.TYPE_ERROR; }
    ret sc.expr_type[eid];
}

# the source span of an expression, falling back to `fallback` when the id is
# out of range
# ---
# sc:       the active sema context
# eid:      the expression id to read the span of
# fallback: span returned when the id does not resolve
# ret:      the expression's span, or `fallback`
fun expr_span_of(sc: *context.SemaContext, eid: id.ExprId, fallback: token.Span) token.Span {
    val opt_expr: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](opt_expr)) { ret fallback; }
    ret O.unwrap[*expr.Expr](opt_expr).span;
}

# records an error-severity diagnostic against the module's file
#
# the allocation result of the sink is intentionally dropped: a failed
# diagnostic append cannot itself be reported, and sema never halts on it.
# ---
# sc:      the active sema context
# span:    source range to pin the diagnostic to
# message: the diagnostic text (copied by the sink)
fun report(sc: *context.SemaContext, span: token.Span, message: str) {
    diagnostic.error(?sc.s.diags, sc.a.file_id, span, message);
}

# report plus a static clarifying `note:` line on the same diagnostic
#
# the note attaches only when the error itself landed, so a failed error emit
# never misattaches the note to the previous diagnostic.
# ---
# sc:      the active sema context
# span:    source range to pin the diagnostic to
# message: the diagnostic text
# note:    clarifying note attached when the error lands
fun report_note(sc: *context.SemaContext, span: token.Span, message: str, note: str) {
    val res_emit: R.Result[bool, str] = diagnostic.error(?sc.s.diags, sc.a.file_id, span, message);
    if (R.is_err[bool, str](res_emit)) { ret; }
    diagnostic.attach_note(?sc.s.diags, note);
}

# report a `type mismatch: expected <X>, found <Y>` diagnostic
#
# the two types are rendered via type_to_str, plus a static clarifying note. the
# assembled message and both type spellings are owned only for the duration of
# the call (the diagnostic sink copies them) and freed before returning. any
# allocation failure degrades to the static, type-free message so a mismatch is
# always reported.
# ---
# sc:       the active sema context
# span:     source range to pin the diagnostic to
# expected: the destination slot's type
# actual:   the source value's type
# note:     clarifying note attached to whichever message lands
fun report_mismatch(sc: *context.SemaContext, span: token.Span, expected: type.TypeId, actual: type.TypeId, note: str) {
    # a value-less actual (a call to a function with no return type) carries
    # TYPE_NIL, which has no spelling: rendering it would print the misleading
    # `<error>` placeholder, and the widening note does not apply. name the
    # missing value instead.
    if (actual == type.TYPE_NIL) {
        report_typed_note(sc, span, "type mismatch: expected ", expected,
            ", found no value",
            "type mismatch: a value is required, but the expression produces none",
            "a call to a function with no return type produces no value");
        ret;
    }

    val res_expected: R.Result[str, str] = type_to_str(sc, expected);
    val res_actual:   R.Result[str, str] = type_to_str(sc, actual);
    if (R.is_err[str, str](res_expected) || R.is_err[str, str](res_actual)) {
        report_note(sc, span, "type mismatch: incompatible types in assignment", note);
        if (R.is_ok[str, str](res_expected)) { type_str_free(sc, R.unwrap_ok[str, str](res_expected)); }
        if (R.is_ok[str, str](res_actual))   { type_str_free(sc, R.unwrap_ok[str, str](res_actual)); }
        ret;
    }
    val expected_str: str = R.unwrap_ok[str, str](res_expected);
    val actual_str:   str = R.unwrap_ok[str, str](res_actual);

    val prefix: str   = "type mismatch: expected ";
    val mid:    str   = ", found ";
    val total:  usize = str_len(prefix) + str_len(expected_str) + str_len(mid) + str_len(actual_str);

    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report_note(sc, span, "type mismatch: incompatible types in assignment", note);
        type_str_free(sc, expected_str);
        type_str_free(sc, actual_str);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_kw(msg, w, expected_str);
    w = write_kw(msg, w, mid);
    w = write_kw(msg, w, actual_str);
    msg[w] = 0;

    report_note(sc, span, msg, note);

    A.deallocate[char](sc.s.alloc, msg, total + 1);
    type_str_free(sc, expected_str);
    type_str_free(sc, actual_str);
}

# report_typed plus a static clarifying `note:` line
#
# on any allocation failure it degrades to the static `fallback` message, still
# carrying the note so the explanation is never lost.
# ---
# sc:       the active sema context
# span:     source range to pin the diagnostic to
# prefix:   text before the rendered type
# t:        the type to render into the message
# suffix:   text after the rendered type
# fallback: type-free message used when rendering or allocation fails
# note:     clarifying note attached to whichever message lands
fun report_typed_note(sc: *context.SemaContext, span: token.Span, prefix: str, t: type.TypeId, suffix: str, fallback: str, note: str) {
    val res_type: R.Result[str, str] = type_to_str(sc, t);
    if (R.is_err[str, str](res_type)) {
        report_note(sc, span, fallback, note);
        ret;
    }
    val type_str: str = R.unwrap_ok[str, str](res_type);

    val total: usize = str_len(prefix) + str_len(type_str) + str_len(suffix);
    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report_note(sc, span, fallback, note);
        type_str_free(sc, type_str);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_kw(msg, w, type_str);
    w = write_kw(msg, w, suffix);
    msg[w] = 0;

    report_note(sc, span, msg, note);
    A.deallocate[char](sc.s.alloc, msg, total + 1);
    type_str_free(sc, type_str);
}

# report an `arity mismatch: expected <E>, found <A>` diagnostic
#
# both counts render as decimals. `at_least` distinguishes a pack-tailed callee
# (`expected at least <E>`) from a fixed one (`expected <E>`). any allocation
# failure degrades to a static, count-free message so the error is always
# reported.
# ---
# sc:       the active sema context
# span:     source range to pin the diagnostic to
# expected: the expected argument count
# actual:   the supplied argument count
# at_least: whether `expected` is a lower bound (a pack-tailed callee)
fun report_arity(sc: *context.SemaContext, span: token.Span, expected: u32, actual: u32, at_least: bool) {
    val prefix:  str = "arity mismatch: expected ";
    val atleast: str = "at least ";
    val mid:     str = ", found ";
    var total: usize = str_len(prefix) + decimal_len(expected::usize)
        + str_len(mid) + decimal_len(actual::usize);
    if (at_least) { total = total + str_len(atleast); }

    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report(sc, span, "arity mismatch: wrong number of call arguments");
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    if (at_least) { w = write_kw(msg, w, atleast); }
    w = write_decimal(msg, w, expected::usize);
    w = write_kw(msg, w, mid);
    w = write_decimal(msg, w, actual::usize);
    msg[w] = 0;

    report(sc, span, msg);
    A.deallocate[char](sc.s.alloc, msg, total + 1);
}

# report a `bit reinterpret requires equal-size types: <X> (<n> bytes) vs <Y>
# (<m> bytes)` diagnostic
#
# renders each type via type_to_str and its byte size as a decimal. the
# assembled message and type spellings are owned only for the call; any
# allocation failure degrades to a static, size-free message so the error is
# always reported.
# ---
# sc:        the active sema context
# span:      source range to pin the diagnostic to
# from:      the operand's type
# size_from: the operand's byte size
# to:        the target type
# size_to:   the target type's byte size
fun report_reinterpret_mismatch(sc: *context.SemaContext, span: token.Span, from: type.TypeId, size_from: u32, to: type.TypeId, size_to: u32) {
    val res_from: R.Result[str, str] = type_to_str(sc, from);
    val res_to:   R.Result[str, str] = type_to_str(sc, to);
    if (R.is_err[str, str](res_from) || R.is_err[str, str](res_to)) {
        report_note(sc, span, "bit reinterpret requires equal-size types",
            "`:~` reinterprets bits between types of identical, known byte size");
        if (R.is_ok[str, str](res_from)) { type_str_free(sc, R.unwrap_ok[str, str](res_from)); }
        if (R.is_ok[str, str](res_to))   { type_str_free(sc, R.unwrap_ok[str, str](res_to)); }
        ret;
    }
    val from_str: str = R.unwrap_ok[str, str](res_from);
    val to_str:   str = R.unwrap_ok[str, str](res_to);

    val prefix: str = "bit reinterpret requires equal-size types: ";
    val open:   str = " (";
    val unit:   str = " bytes) vs ";
    val close:  str = " bytes)";
    val total: usize = str_len(prefix) + str_len(from_str) + str_len(open)
        + decimal_len(size_from::usize) + str_len(unit) + str_len(to_str) + str_len(open)
        + decimal_len(size_to::usize) + str_len(close);

    val res_buf: R.Result[*char, str] = A.allocate[char](sc.s.alloc, total + 1);
    if (R.is_err[*char, str](res_buf)) {
        report_note(sc, span, "bit reinterpret requires equal-size types",
            "`:~` reinterprets bits between types of identical, known byte size");
        type_str_free(sc, from_str);
        type_str_free(sc, to_str);
        ret;
    }
    val msg: str = R.unwrap_ok[*char, str](res_buf);
    var w: usize = write_kw(msg, 0, prefix);
    w = write_kw(msg, w, from_str);
    w = write_kw(msg, w, open);
    w = write_decimal(msg, w, size_from::usize);
    w = write_kw(msg, w, unit);
    w = write_kw(msg, w, to_str);
    w = write_kw(msg, w, open);
    w = write_decimal(msg, w, size_to::usize);
    w = write_kw(msg, w, close);
    msg[w] = 0;

    report(sc, span, msg);

    A.deallocate[char](sc.s.alloc, msg, total + 1);
    type_str_free(sc, from_str);
    type_str_free(sc, to_str);
}

# the byte length type_to_str will write for `t`, excluding the null terminator
#
# mirrors write_type_str branch-for-branch so the single allocation in
# type_to_str is sized exactly.
# ---
# sc:  the active sema context
# t:   the type to measure
# ret: the number of bytes write_type_str will emit for `t`
fun type_str_len(sc: *context.SemaContext, t: type.TypeId) usize {
    if (t == type.TYPE_U8)                          { ret 2; }
    if (t == type.TYPE_U16)                         { ret 3; }
    if (t == type.TYPE_U32)                         { ret 3; }
    if (t == type.TYPE_U64)                         { ret 3; }
    if (t == type.TYPE_I8)                          { ret 2; }
    if (t == type.TYPE_I16)                         { ret 3; }
    if (t == type.TYPE_I32)                         { ret 3; }
    if (t == type.TYPE_I64)                         { ret 3; }
    if (t == type.TYPE_F32)                         { ret 3; }
    if (t == type.TYPE_F64)                         { ret 3; }
    if (t == type.TYPE_PTR)                         { ret 3; }
    if (t == type.TYPE_ERROR || t == type.TYPE_NIL) { ret 7; }

    val opt_type: O.Option[*type.Type] = type.get(?sc.s.types, t);
    if (O.is_none[*type.Type](opt_type)) { ret 7; }
    val tp: *type.Type    = O.unwrap[*type.Type](opt_type);
    val k:  type.TypeKind = tp.kind;

    if (k == type.TYPE_POINTER) {
        ret 1 + type_str_len(sc, tp.data.pointer.base);
    }
    if (k == type.TYPE_ARRAY) {
        ret 1 + decimal_len(tp.data.array.count::usize) + 1 + type_str_len(sc, tp.data.array.base);
    }
    if (k == type.TYPE_REC || k == type.TYPE_UNI) {
        ret name_str_len(sc, tp.data.nominal.name);
    }
    if (k == type.TYPE_GENERIC_PARAM) {
        ret name_str_len(sc, tp.data.generic_param.name);
    }
    if (k == type.TYPE_INSTANCE) {
        ret instance_str_len(sc, tp);
    }
    if (k == type.TYPE_FUN) {
        ret fun_str_len(sc, tp);
    }
    ret 7;
}

# write type_to_str's spelling for `t` into `buf` at offset `k`
# ---
# sc:  the active sema context
# buf: destination buffer
# k:   offset to begin writing at
# t:   the type to render
# ret: the offset just past the written spelling
fun write_type_str(sc: *context.SemaContext, buf: str, k: usize, t: type.TypeId) usize {
    if (t == type.TYPE_U8)                          { ret write_kw(buf, k, "u8"); }
    if (t == type.TYPE_U16)                         { ret write_kw(buf, k, "u16"); }
    if (t == type.TYPE_U32)                         { ret write_kw(buf, k, "u32"); }
    if (t == type.TYPE_U64)                         { ret write_kw(buf, k, "u64"); }
    if (t == type.TYPE_I8)                          { ret write_kw(buf, k, "i8"); }
    if (t == type.TYPE_I16)                         { ret write_kw(buf, k, "i16"); }
    if (t == type.TYPE_I32)                         { ret write_kw(buf, k, "i32"); }
    if (t == type.TYPE_I64)                         { ret write_kw(buf, k, "i64"); }
    if (t == type.TYPE_F32)                         { ret write_kw(buf, k, "f32"); }
    if (t == type.TYPE_F64)                         { ret write_kw(buf, k, "f64"); }
    if (t == type.TYPE_PTR)                         { ret write_kw(buf, k, "ptr"); }
    if (t == type.TYPE_ERROR || t == type.TYPE_NIL) { ret write_kw(buf, k, "<error>"); }

    val opt_type: O.Option[*type.Type] = type.get(?sc.s.types, t);
    if (O.is_none[*type.Type](opt_type)) { ret write_kw(buf, k, "<error>"); }
    val tp:   *type.Type    = O.unwrap[*type.Type](opt_type);
    val kind: type.TypeKind = tp.kind;

    if (kind == type.TYPE_POINTER) {
        val w: usize = write_char(buf, k, '*');
        ret write_type_str(sc, buf, w, tp.data.pointer.base);
    }
    if (kind == type.TYPE_ARRAY) {
        var w: usize = write_char(buf, k, '[');
        w = write_decimal(buf, w, tp.data.array.count::usize);
        w = write_char(buf, w, ']');
        ret write_type_str(sc, buf, w, tp.data.array.base);
    }
    if (kind == type.TYPE_REC || kind == type.TYPE_UNI) {
        ret write_name(sc, buf, k, tp.data.nominal.name);
    }
    if (kind == type.TYPE_GENERIC_PARAM) {
        ret write_name(sc, buf, k, tp.data.generic_param.name);
    }
    if (kind == type.TYPE_INSTANCE) {
        ret write_instance(sc, buf, k, tp);
    }
    if (kind == type.TYPE_FUN) {
        ret write_fun(sc, buf, k, tp);
    }
    ret write_kw(buf, k, "<error>");
}

# the rendered length of a generic instance `Name[Arg, ...]`
#
# the name recovered from the generic declaration via generics.generic_nominal_of
# and the arguments measured recursively.
# ---
# sc:  the active sema context
# tp:  the TYPE_INSTANCE payload to measure
# ret: the number of bytes write_instance will emit
fun instance_str_len(sc: *context.SemaContext, tp: *type.Type) usize {
    var total: usize = instance_name_len(sc, tp);
    total = total + 1;
    val args_start: u32 = tp.data.instance.args_start;
    val args_len:   u32 = tp.data.instance.args_len;
    var i: u32 = 0;
    for (i < args_len) {
        if (i > 0) { total = total + 2; }
        total = total + type_str_len(sc, instance_arg(sc, args_start + i));
        i = i + 1;
    }
    total = total + 1;
    ret total;
}

# write a generic instance `Name[Arg, ...]` into `buf` at offset `k`
# ---
# sc:  the active sema context
# buf: destination buffer
# k:   offset to begin writing at
# tp:  the TYPE_INSTANCE payload to render
# ret: the offset just past the written spelling
fun write_instance(sc: *context.SemaContext, buf: str, k: usize, tp: *type.Type) usize {
    var w: usize = write_instance_name(sc, buf, k, tp);
    w = write_char(buf, w, '[');
    val args_start: u32 = tp.data.instance.args_start;
    val args_len:   u32 = tp.data.instance.args_len;
    var i: u32 = 0;
    for (i < args_len) {
        if (i > 0) { w = write_kw(buf, w, ", "); }
        w = write_type_str(sc, buf, w, instance_arg(sc, args_start + i));
        i = i + 1;
    }
    w = write_char(buf, w, ']');
    ret w;
}

# the concrete argument TypeId at pool slot `idx`
#
# returns TYPE_ERROR when out of range so rendering stays total.
# ---
# sc:  the active sema context
# idx: index into the type interner's parameter pool
# ret: the argument type, or TYPE_ERROR when out of range
fun instance_arg(sc: *context.SemaContext, idx: u32) type.TypeId {
    val opt_arg: O.Option[type.TypeId] = type.get_param(?sc.s.types, idx);
    if (O.is_none[type.TypeId](opt_arg)) { ret type.TYPE_ERROR; }
    ret O.unwrap[type.TypeId](opt_arg);
}

# the rendered length of a generic instance's declared name
#
# recovered through generics.generic_nominal_of (which re-interns the name the
# declaring module used). falls back to `<anon>` when the declaration cannot be
# reached.
# ---
# sc:  the active sema context
# tp:  the TYPE_INSTANCE payload
# ret: the rendered length of the instance's name
fun instance_name_len(sc: *context.SemaContext, tp: *type.Type) usize {
    val generic_nominal: type.TypeId = generics.generic_nominal_of(sc.s, tp.data.instance.target_origin, tp.data.instance.target_decl);
    val name: intern.StrId = nominal_name_of(sc, generic_nominal);
    if (name == intern.STR_NIL) { ret 6; }
    ret name_str_len(sc, name);
}

# write a generic instance's declared name into `buf` at offset `k`
# ---
# sc:  the active sema context
# buf: destination buffer
# k:   offset to begin writing at
# tp:  the TYPE_INSTANCE payload
# ret: the offset just past the written name
fun write_instance_name(sc: *context.SemaContext, buf: str, k: usize, tp: *type.Type) usize {
    val generic_nominal: type.TypeId = generics.generic_nominal_of(sc.s, tp.data.instance.target_origin, tp.data.instance.target_decl);
    val name: intern.StrId = nominal_name_of(sc, generic_nominal);
    if (name == intern.STR_NIL) { ret write_kw(buf, k, "<anon>"); }
    ret write_name(sc, buf, k, name);
}

# the `name` StrId of a nominal TypeId, or STR_NIL when `t` is not a nominal
# ---
# sc:  the active sema context
# t:   the type to read the nominal name of
# ret: the nominal's interned name, or STR_NIL when `t` is not rec/uni
fun nominal_name_of(sc: *context.SemaContext, t: type.TypeId) intern.StrId {
    if (t == type.TYPE_ERROR || t == type.TYPE_NIL) { ret intern.STR_NIL; }
    val opt_type: O.Option[*type.Type] = type.get(?sc.s.types, t);
    if (O.is_none[*type.Type](opt_type)) { ret intern.STR_NIL; }
    val tp: *type.Type = O.unwrap[*type.Type](opt_type);
    if (tp.kind != type.TYPE_REC && tp.kind != type.TYPE_UNI) { ret intern.STR_NIL; }
    ret tp.data.nominal.name;
}

# the rendered length of a function type `fun(A, B) R`
#
# a void return renders as the bare `fun(A, B)` with no trailing type.
# ---
# sc:  the active sema context
# tp:  the TYPE_FUN payload to measure
# ret: the number of bytes write_fun will emit
fun fun_str_len(sc: *context.SemaContext, tp: *type.Type) usize {
    var total: usize = 4;
    val params_start: u32 = tp.data.fn.params_start;
    val params_len:   u32 = tp.data.fn.params_len;
    var i: u32 = 0;
    for (i < params_len) {
        if (i > 0) { total = total + 2; }
        total = total + type_str_len(sc, instance_arg(sc, params_start + i));
        i = i + 1;
    }
    total = total + 1;
    if (tp.data.fn.ret_type != type.TYPE_NIL) {
        total = total + 1 + type_str_len(sc, tp.data.fn.ret_type);
    }
    ret total;
}

# write a function type `fun(A, B) R` into `buf` at offset `k`
# ---
# sc:  the active sema context
# buf: destination buffer
# k:   offset to begin writing at
# tp:  the TYPE_FUN payload to render
# ret: the offset just past the written spelling
fun write_fun(sc: *context.SemaContext, buf: str, k: usize, tp: *type.Type) usize {
    var w: usize = write_kw(buf, k, "fun");
    w = write_char(buf, w, '(');
    val params_start: u32 = tp.data.fn.params_start;
    val params_len:   u32 = tp.data.fn.params_len;
    var i: u32 = 0;
    for (i < params_len) {
        if (i > 0) { w = write_kw(buf, w, ", "); }
        w = write_type_str(sc, buf, w, instance_arg(sc, params_start + i));
        i = i + 1;
    }
    w = write_char(buf, w, ')');
    if (tp.data.fn.ret_type != type.TYPE_NIL) {
        w = write_char(buf, w, ' ');
        w = write_type_str(sc, buf, w, tp.data.fn.ret_type);
    }
    ret w;
}

# the rendered length of an interned identifier
#
# falls back to `<anon>` (length 6) when the StrId is nil or unresolvable.
# ---
# sc:   the active sema context
# name: the interned identifier to measure
# ret:  the identifier's length, or 6 for the `<anon>` fallback
fun name_str_len(sc: *context.SemaContext, name: intern.StrId) usize {
    val opt_name: O.Option[str] = intern.lookup(?sc.s.interner, name);
    if (O.is_none[str](opt_name)) { ret 6; }
    val name_str: str = O.unwrap[str](opt_name);
    if (str_len(name_str) == 0) { ret 6; }
    ret str_len(name_str);
}

# write an interned identifier into `buf` at offset `k`
#
# falls back to `<anon>` when the StrId is nil or unresolvable.
# ---
# sc:   the active sema context
# buf:  destination buffer
# k:    offset to begin writing at
# name: the interned identifier to render
# ret:  the offset just past the written name
fun write_name(sc: *context.SemaContext, buf: str, k: usize, name: intern.StrId) usize {
    val opt_name: O.Option[str] = intern.lookup(?sc.s.interner, name);
    if (O.is_none[str](opt_name)) { ret write_kw(buf, k, "<anon>"); }
    val name_str: str = O.unwrap[str](opt_name);
    if (str_len(name_str) == 0) { ret write_kw(buf, k, "<anon>"); }
    ret write_kw(buf, k, name_str);
}

# write a single character into `buf` at offset `k`
# ---
# buf: destination buffer
# k:   offset to write at
# c:   the character to write
# ret: the offset just past it (`k + 1`)
fun write_char(buf: str, k: usize, c: char) usize {
    buf[k] = c;
    ret k + 1;
}

# copy a string's bytes into `buf` at offset `k`
# ---
# buf: destination buffer
# k:   offset to begin writing at
# s:   source string to copy
# ret: the offset just past the copied bytes
fun write_kw(buf: str, k: usize, s: str) usize {
    val len: usize = str_len(s);
    memory.raw_copy((buf::usize + k)::ptr, s::ptr, len);
    ret k + len;
}

# the number of base-10 digits in `n` (1 for 0)
# ---
# n:   the value to measure
# ret: the digit count
fun decimal_len(n: usize) usize {
    if (n == 0) { ret 1; }
    var len: usize = 0;
    var v:   usize = n;
    for (v > 0) {
        len = len + 1;
        v = v / 10;
    }
    ret len;
}

# write the base-10 digits of `n` into `buf` at offset `k`
# ---
# buf: destination buffer
# k:   offset to begin writing at
# n:   the value to render
# ret: the offset just past the digits
fun write_decimal(buf: str, k: usize, n: usize) usize {
    if (n == 0) { ret write_char(buf, k, '0'); }

    var tmp:    [24]char;
    var digits: usize = 0;
    var v:      usize = n;
    for (v > 0) {
        tmp[digits] = (v % 10)::char + '0';
        v = v / 10;
        digits = digits + 1;
    }

    var w: usize = k;
    var i: usize = 0;
    for (i < digits) {
        w = write_char(buf, w, tmp[digits - 1 - i]);
        i = i + 1;
    }
    ret w;
}
