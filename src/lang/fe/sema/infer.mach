# bottom-up type inference
#
# Computes the semantic `type.TypeId` of every expression and the interned
# `type.TypeId` each syntactic AstType refers to. Drives the rest of sema by
# calling `check` at composing sites and `coerce` where the language allows
# literal narrowing.
#
# The public entry points, called by sema's pass loop, are resolve_type_ref
# (syntactic AstType to interned semantic TypeId), infer_decl (a decl's declared
# or inferred type), and infer_expr (an expression's type, bottom-up, writing
# expr_type). All three tolerate holes: an unresolved name or a failed
# sub-inference yields TYPE_ERROR, which absorbs further operations without
# cascading diagnostics.
#
# `str` is the stdlib alias `def str: *u8`; it resolves transparently to a
# pointer and has no special field table. Anonymous inline rec/uni types are
# structurally typed: two inline shapes with the same field names and field
# types intern to the same nominal, so a value of one is interchangeable with
# the other (a `def`-named record stays nominal -- identity by declaration).

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_region_equals;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use atype: mach.lang.fe.ast.type;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema.check;
use mach.lang.fe.sema.coerce;
use mach.lang.fe.sema.context;
use mach.lang.fe.sema.generics;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.session;
use mach.lang.type;

# seed the field tables of built-in nominal types
#
# The only built-in string type is the stdlib `def str: *u8`, which resolves
# transparently to a pointer and has no fields, so there is nothing to seed; the
# function exists so sema can call it unconditionally and future built-ins have
# a home.
# ---
# sc:  sema context
# ret: true on success, or an allocation error
pub fun seed_builtins(sc: *context.SemaContext) R.Result[bool, str] {
    ret R.ok[bool, str](true);
}

# compute the declared type of one decl, dispatching per DeclKind
#
# Binding decls (val/var) use their annotation when present, else infer from the
# initializer; functions intern a TYPE_FUN; records / unions intern a nominal
# and build a field table; `def` is transparent (returns the underlying type).
# Non-typed decls (use, fwd, test, comptime) carry no type.
# ---
# sc:  sema context
# did: decl to compute the type of
# ret: the declared TypeId, or TYPE_NIL / TYPE_ERROR
pub fun infer_decl(sc: *context.SemaContext, did: id.DeclId) type.TypeId {
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(sc.a, did);
    if (O.is_none[*decl.Decl](d_opt)) { ret type.TYPE_ERROR; }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);

    if (d.kind == decl.DECL_KIND_FUN) { ret infer_fun_sig(sc, ?d.data.fun_); }
    if (d.kind == decl.DECL_KIND_REC) { ret infer_nominal(sc, did, d.data.rec_.name, ?d.data.rec_, type.TYPE_REC); }
    if (d.kind == decl.DECL_KIND_UNI) { ret infer_nominal_uni(sc, did, d.data.uni_.name, ?d.data.uni_, type.TYPE_UNI); }
    if (d.kind == decl.DECL_KIND_DEF) { ret context.resolved_type_of(sc, d.data.def_.ty); }
    if (d.kind == decl.DECL_KIND_VAL || d.kind == decl.DECL_KIND_VAR) {
        ret infer_binding(sc, ?d.data.bind);
    }
    ret type.TYPE_NIL;
}

# intern the TYPE_FUN signature of a function declaration from its resolved
# parameter and return types
#
# Comptime value parameters (`$name: T`) are EXCLUDED from the interned
# signature: they are folded per call site and stripped from both the runtime
# ABI and the lowered IR, so the semantic TYPE_FUN carries only the runtime
# parameters. Call arity is checked against the AST parameter list (which
# includes the comptime ones) in `check_call`.
# ---
# sc:  sema context
# f:   the function declaration
# ret: the interned TYPE_FUN TypeId, or TYPE_ERROR
fun infer_fun_sig(sc: *context.SemaContext, f: *decl.DeclFun) type.TypeId {
    val ret_type: type.TypeId = context.resolved_type_of(sc, f.return_type);

    var runtime_count: u32 = 0;
    var i: u32 = 0;
    for (i < f.params_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[f.params_start + i];
        if (!tn.comptime) { runtime_count = runtime_count + 1; }
        i = i + 1;
    }

    if (runtime_count == 0) {
        val r: R.Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_type, nil, 0);
        if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret R.unwrap_ok[type.TypeId, str](r);
    }

    val pr: R.Result[*type.TypeId, str] = allocate_params(sc, runtime_count);
    if (R.is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val params: *type.TypeId = R.unwrap_ok[*type.TypeId, str](pr);

    var w: u32 = 0;
    i = 0;
    for (i < f.params_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[f.params_start + i];
        if (!tn.comptime) {
            params[w] = context.resolved_type_of(sc, tn.ty);
            w = w + 1;
        }
        i = i + 1;
    }

    val r: R.Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_type, params, runtime_count);
    free_params(sc, params, runtime_count);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# intern the nominal TYPE_REC for a record declaration and build its field
# table (name -> resolved field type) on the context
# ---
# sc:        sema context
# did:       the record declaration
# name_span: the record's name span (diagnostic only)
# r:         the record declaration payload
# kind:      TYPE_REC
# ret:       the nominal TypeId, or TYPE_ERROR
fun infer_nominal(sc: *context.SemaContext, did: id.DeclId, name_span: token.Span, r: *decl.DeclRec, kind: type.TypeKind) type.TypeId {
    val name_id: intern.StrId = intern_span_or_nil(sc, name_span);
    val tr: R.Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, name_id, sc.own_module, did, kind);
    if (R.is_err[type.TypeId, str](tr)) { ret type.TYPE_ERROR; }
    val ty: type.TypeId = R.unwrap_ok[type.TypeId, str](tr);

    build_field_table(sc, ty, r.fields_start, r.fields_len);
    record_type_align(sc, did, ty);
    ret ty;
}

# union variant of infer_nominal (DeclUni has the same field layout)
# ---
# sc:        sema context
# did:       the union declaration
# name_span: the union's name span (diagnostic only)
# u:         the union declaration payload
# kind:      TYPE_UNI
# ret:       the nominal TypeId, or TYPE_ERROR
fun infer_nominal_uni(sc: *context.SemaContext, did: id.DeclId, name_span: token.Span, u: *decl.DeclUni, kind: type.TypeKind) type.TypeId {
    val name_id: intern.StrId = intern_span_or_nil(sc, name_span);
    val tr: R.Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, name_id, sc.own_module, did, kind);
    if (R.is_err[type.TypeId, str](tr)) { ret type.TYPE_ERROR; }
    val ty: type.TypeId = R.unwrap_ok[type.TypeId, str](tr);

    build_field_table(sc, ty, u.fields_start, u.fields_len);
    check_uni_secrecy(sc, u.fields_start, u.fields_len);
    record_type_align(sc, did, ty);
    ret ty;
}

# enforce that a union's overlapping variants agree on secrecy (#1645)
#
# A `uni`'s fields share storage, so a mixed-secrecy union would let the same
# bytes be read as both secret and public - the welded-storage aliasing leak. All
# variants must be uniformly secret or uniformly public. The first variant whose
# secrecy disagrees with the first variant's is reported on its own field span.
# ---
# sc:           sema context
# fields_start: start index into ast.typed_names
# fields_len:   number of variants
fun check_uni_secrecy(sc: *context.SemaContext, fields_start: u32, fields_len: u32) {
    if (fields_len < 2) { ret; }

    val first_tn:     *decl.TypedName = ?sc.a.typed_names[fields_start];
    val first_secret: bool            = type.is_secret(?sc.s.types, context.resolved_type_of(sc, first_tn.ty));

    var i: u32 = 1;
    for (i < fields_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[fields_start + i];
        if (type.is_secret(?sc.s.types, context.resolved_type_of(sc, tn.ty)) != first_secret) {
            context.report(sc, tn.name, "union variants must agree on secrecy: overlapping fields are part secret `^` and part public, which would alias the same storage at two classifications");
        }
        i = i + 1;
    }
}

# fold an `#[align(...)]` decorator on `did` and record the resulting alignment
# for nominal TypeId `ty` on the session
#
# The middle end over-aligns the lowered IR struct from this record. The
# argument is a compile-time constant (a literal or `$mach.build.*`) folded by
# `comptime.eval`; a non-constant (e.g. a layout intrinsic, which has no value
# before layout) or non-power-of-two is reported. An absent decorator or a
# non-`align` set leaves the natural alignment.
# ---
# sc:  sema context
# did: the record/union declaration carrying the decorator
# ty:  the nominal TypeId to align
fun record_type_align(sc: *context.SemaContext, did: id.DeclId, ty: type.TypeId) {
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(sc.a, did);
    if (O.is_none[*decl.Decl](d_opt)) { ret; }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);

    var i: u32 = 0;
    for (i < d.decorators_len) {
        val dec: *decl.Decorator = ?sc.a.decorators[d.decorators_start + i];
        if (str_region_equals(sc.source, dec.name.offset, dec.name.len, "align")) {
            if (dec.args_len != 1) { ret; }
            val arg: id.ExprId = sc.a.expr_ids[dec.args_start];
            val ev: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, arg, ?sc.s.interner);
            if (R.is_err[comptime.CTValue, str](ev)) {
                context.report(sc, dec.name, "`align` on a type must be a compile-time constant");
                ret;
            }
            val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](ev);
            # the body-pass validator skips the type-arg checks for rec/uni (it
            # would double-report against this fold), so every invalid case is
            # reported here -- a non-integer, a negative, a non-power-of-two, or
            # one overflowing the u32 alignment field -- never silently dropped.
            if (cv.kind != comptime.CT_KIND_INT) {
                context.report(sc, dec.name, "`align` value must be an integer");
                ret;
            }
            if (comptime.ct_is_negative(cv)) {
                context.report(sc, dec.name, "`align` value must be a non-zero power of two");
                ret;
            }
            val n: u64 = cv.data.i:~u64;
            if (n == 0 || (n & (n - 1)) != 0) {
                context.report(sc, dec.name, "`align` value must be a non-zero power of two");
                ret;
            }
            if (n > 0xFFFFFFFF) {
                context.report(sc, dec.name, "`align` value exceeds the maximum alignment");
                ret;
            }
            val rr: R.Result[bool, str] = session.register_type_align(sc.s, ty::u32, n::u32);
            if (R.is_err[bool, str](rr)) { ret; }
            ret;
        }
        i = i + 1;
    }
}

# populate a field table for nominal `ty` from a typed_names slice, mapping each
# field's interned name to its resolved semantic type
#
# An up-to-date table (built this build epoch -- e.g. a repeated reference to the
# same anonymous shape) is left untouched; a table from an older epoch is
# rebuilt, since a record keeps its TypeId across a rebuild while its field types
# may have changed (#1583).
# ---
# sc:           sema context
# ty:           the nominal TypeId the table describes
# fields_start: start index into ast.typed_names
# fields_len:   number of fields
fun build_field_table(sc: *context.SemaContext, ty: type.TypeId, fields_start: u32, fields_len: u32) {
    val existing: O.Option[*context.FieldTable] = context.field_table_for(sc, ty);
    if (O.is_some[*context.FieldTable](existing)) {
        if (O.unwrap[*context.FieldTable](existing).epoch == context.field_epoch(sc)) { ret; }
    }

    # reserve the whole run before opening the table: an allocation failure then
    # happens here, before any table is registered, rather than mid-push leaving a
    # half-built table that a later builder reuses as complete. after this the
    # pushes cannot grow the pool, so they cannot fail.
    val res_reserve: R.Result[bool, str] = context.field_table_reserve(sc, fields_len);
    if (R.is_err[bool, str](res_reserve)) { ret; }

    val tbl_r: R.Result[u32, str] = context.field_table_begin(sc, ty);
    if (R.is_err[u32, str](tbl_r)) { ret; }
    val tbl: u32 = R.unwrap_ok[u32, str](tbl_r);

    var i: u32 = 0;
    for (i < fields_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[fields_start + i];
        val fname: intern.StrId = intern_span_or_nil(sc, tn.name);
        val fty: type.TypeId = context.resolved_type_of(sc, tn.ty);
        context.field_table_push(sc, tbl, fname, fty);
        i = i + 1;
    }
}

# compute a binding's declared type: the annotation if written, otherwise the
# inferred type of the initializer
#
# An absent annotation with no initializer cannot be typed and yields
# TYPE_ERROR.
# ---
# sc:  sema context
# b:   the binding declaration payload
# ret: the binding's TypeId, or TYPE_ERROR
fun infer_binding(sc: *context.SemaContext, b: *decl.DeclBind) type.TypeId {
    if (b.ty != id.TYPE_NIL) {
        ret context.resolved_type_of(sc, b.ty);
    }
    if (b.init != id.EXPR_NIL) {
        ret infer_expr(sc, b.init);
    }
    ret type.TYPE_ERROR;
}

# compute the type of one expression, recursively inferring subexpressions
#
# Dispatches per ExprKind, writes the result into expr_type[eid], and returns
# it.
# ---
# sc:  sema context
# eid: expression to type
# ret: the inferred TypeId (TYPE_ERROR on failure)
pub fun infer_expr(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    if (eid == id.EXPR_NIL) { ret type.TYPE_ERROR; }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret type.TYPE_ERROR; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);

    var t: type.TypeId = type.TYPE_ERROR;

    if (e.kind == expr.EXPR_KIND_LIT_INT) {
        t = prim_or_error(sc, type.TYPE_I64);
    }
    or (e.kind == expr.EXPR_KIND_LIT_FLOAT) {
        t = prim_or_error(sc, type.TYPE_F64);
    }
    or (e.kind == expr.EXPR_KIND_LIT_CHAR) {
        t = prim_or_error(sc, type.TYPE_U8);
    }
    or (e.kind == expr.EXPR_KIND_LIT_STR) {
        t = ptr_to(sc, prim_or_error(sc, type.TYPE_U8));
    }
    or (e.kind == expr.EXPR_KIND_LIT_NIL) {
        t = ptr_to(sc, prim_or_error(sc, type.TYPE_U8));
    }
    or (e.kind == expr.EXPR_KIND_IDENT) {
        t = infer_ident(sc, eid);
    }
    or (e.kind == expr.EXPR_KIND_COMPTIME_IDENT) {
        # a bare `$ident` in value position is not one of the closed comptime
        # channel shapes: comptime parameters are referenced without `$`, and
        # comptime paths are rooted. eval owns the single rejection rule;
        # surface its teaching diagnostic against this span rather than inventing
        # a sema-local message. a rooted path arrives as a MEMBER chain instead.
        val ev: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
        if (R.is_err[comptime.CTValue, str](ev)) {
            context.report(sc, e.span, R.unwrap_err[comptime.CTValue, str](ev));
        }
        t = type.TYPE_ERROR;
    }
    or (e.kind == expr.EXPR_KIND_BINARY) {
        t = infer_binary(sc, eid, ?e.data.binary, e.span);
    }
    or (e.kind == expr.EXPR_KIND_UNARY) {
        t = infer_unary(sc, ?e.data.unary, e.span);
    }
    or (e.kind == expr.EXPR_KIND_CALL) {
        t = infer_call(sc, ?e.data.call, e.span);
    }
    or (e.kind == expr.EXPR_KIND_INDEX) {
        t = infer_index(sc, ?e.data.index, e.span);
    }
    or (e.kind == expr.EXPR_KIND_MEMBER) {
        t = infer_member(sc, eid, ?e.data.member, e.span);
    }
    or (e.kind == expr.EXPR_KIND_PROJECT) {
        t = infer_project(sc, ?e.data.project, e.span);
    }
    or (e.kind == expr.EXPR_KIND_SPREAD) {
        t = infer_spread(sc, ?e.data.spread, e.span);
    }
    or (e.kind == expr.EXPR_KIND_CAST) {
        t = infer_cast(sc, ?e.data.cast, e.span);
    }
    or (e.kind == expr.EXPR_KIND_STRIP) {
        t = infer_strip(sc, ?e.data.strip, e.span);
    }
    or (e.kind == expr.EXPR_KIND_ARRAY_LIT) {
        t = infer_array_lit(sc, ?e.data.array_lit, e.span);
    }
    or (e.kind == expr.EXPR_KIND_STRUCT_LIT) {
        t = infer_struct_lit(sc, ?e.data.struct_lit, e.span);
    }
    or (e.kind == expr.EXPR_KIND_VECTOR_LIT) {
        t = infer_vector_lit(sc, ?e.data.vector_lit, e.span);
    }
    or {
        t = type.TYPE_ERROR;
    }

    if (sc.expr_type != nil && eid < sc.a.expr_len::u32) {
        sc.expr_type[eid] = t;
    }
    ret t;
}

# IDENT: the type of the resolved symbol
#
# An unresolved symbol (SYMBOL_NIL upstream) yields TYPE_ERROR without a fresh
# diagnostic -- resolve already reported the root cause.
# ---
# sc:  sema context
# eid: the identifier expression
# ret: the symbol's value type, or TYPE_ERROR
fun infer_ident(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    val sym_opt: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
    if (O.is_none[*resolve.Symbol](sym_opt)) { ret type.TYPE_ERROR; }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](sym_opt);

    # a `$each a in va` pack loop variable: a comptime-flagged `SYM_VAL` with no
    # declaration, bound during monomorphization to a pack-element descriptor
    # carrying the element's concrete type. its value-position type is that
    # element type (the body is re-inferred per element at instantiation).
    val pe: type.TypeId = pack_elem_loop_var_type(sc, sym);
    if (pe != type.TYPE_NIL) { ret pe; }

    # a `$each x in ARR` constant-array loop variable: a comptime-flagged `SYM_VAL`
    # with no declaration, bound during the unroll to a constant-element descriptor
    # carrying the element's concrete type. its value-position type is that element
    # type, so `x` and `x.field` type against the array's element type per iteration.
    val ce: type.TypeId = const_elem_loop_var_type(sc, sym);
    if (ce != type.TYPE_NIL) { ret ce; }

    # a symbol that names a module or a type (module alias, record, union, def
    # alias, generic parameter, primitive) resolves cleanly but can never be a
    # value; report it loudly -- a silent poison here lets a clean sema pass hand
    # the broken expression to lowering (#1348).
    if (report_never_value(sc, eid, sym)) { ret type.TYPE_ERROR; }

    # a comptime-parameter function is a TEMPLATE: it is only ever emitted as a
    # per-value instance at a call site, never as a standalone symbol.
    # referencing it as a VALUE (assigning it, passing it, comparing it) would
    # bind to a never-emitted symbol, so reject it -- unless this is the callee
    # of a call, where it is legitimately invoked.
    if (eid != sc.callee_eid && ident_is_comptime_param_fn(sc, sym)) {
        ret report_comptime_param_fn_ref(sc, eid);
    }

    ret context.decl_type_for(sc, sym);
}

# the concrete element type of a `$each a in va` pack loop variable, or TYPE_NIL
# when `sym` is not such a variable
#
# The loop variable is a comptime-flagged `SYM_VAL` with no declaration
# (DECL_NIL); during monomorphization the unroller binds its name in the
# comptime context to a CT_KIND_PACK_ELEM descriptor whose `.ty` carries the
# element's concrete sema type. Consulted before the general symbol-type path so
# the body re-infers `a` to the right element type per iteration.
# ---
# sc:  sema context
# sym: the resolved symbol behind the identifier
# ret: the element TypeId, or TYPE_NIL
fun pack_elem_loop_var_type(sc: *context.SemaContext, sym: *resolve.Symbol) type.TypeId {
    if (sym.kind != resolve.SYM_VAL)                  { ret type.TYPE_NIL; }
    if ((sym.flags & resolve.SYM_FLAG_COMPTIME) == 0) { ret type.TYPE_NIL; }
    if (sym.decl != id.DECL_NIL)                      { ret type.TYPE_NIL; }
    val nc: O.Option[*comptime.NamedConst] = comptime.lookup(sc.ctx, sym.name);
    if (O.is_none[*comptime.NamedConst](nc)) { ret type.TYPE_NIL; }
    val cv: comptime.CTValue = O.unwrap[*comptime.NamedConst](nc).value;
    if (cv.kind != comptime.CT_KIND_PACK_ELEM) { ret type.TYPE_NIL; }
    ret cv.data.pelem.ty::type.TypeId;
}

# the element type of a `$each x in ARR` constant-array loop variable, or TYPE_NIL
# when `sym` is not such a variable
#
# The loop variable is a comptime-flagged `SYM_VAL` with no declaration (DECL_NIL);
# the unroll binds its name in the comptime context to a CT_KIND_CONST_ELEM
# descriptor whose `.ty` carries the array's element type. Consulted before the
# general symbol-type path so the body types `x` (and `x.field`) against the
# element type each iteration.
# ---
# sc:  sema context
# sym: the resolved symbol behind the identifier
# ret: the element TypeId, or TYPE_NIL
fun const_elem_loop_var_type(sc: *context.SemaContext, sym: *resolve.Symbol) type.TypeId {
    if (sym.kind != resolve.SYM_VAL)                  { ret type.TYPE_NIL; }
    if ((sym.flags & resolve.SYM_FLAG_COMPTIME) == 0) { ret type.TYPE_NIL; }
    if (sym.decl != id.DECL_NIL)                      { ret type.TYPE_NIL; }
    val nc: O.Option[*comptime.NamedConst] = comptime.lookup(sc.ctx, sym.name);
    if (O.is_none[*comptime.NamedConst](nc)) { ret type.TYPE_NIL; }
    val cv: comptime.CTValue = O.unwrap[*comptime.NamedConst](nc).value;
    if (cv.kind != comptime.CT_KIND_CONST_ELEM) { ret type.TYPE_NIL; }
    ret cv.data.celem.ty::type.TypeId;
}

# whether `sym` names a function declaring at least one comptime value parameter
# (a template that is never emitted standalone)
#
# Reads the DeclFun from the symbol's origin module.
# ---
# sc:  sema context
# sym: the resolved symbol to inspect
# ret: true when the symbol is a function with a comptime value parameter
fun ident_is_comptime_param_fn(sc: *context.SemaContext, sym: *resolve.Symbol) bool {
    if (sym.kind != resolve.SYM_FUN && sym.kind != resolve.SYM_IMPORTED) { ret false; }
    if (sym.decl == id.DECL_NIL)                                         { ret false; }
    val a: *ast.Ast = symbol_ast(sc, sym);
    if (a == nil) { ret false; }
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(a, sym.decl);
    if (O.is_none[*decl.Decl](d_opt)) { ret false; }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);
    if (d.kind != decl.DECL_KIND_FUN) { ret false; }
    val f: *decl.DeclFun = ?d.data.fun_;
    var i: u32 = 0;
    for (i < f.params_len) {
        if (a.typed_names[f.params_start + i].comptime) { ret true; }
        i = i + 1;
    }
    ret false;
}

# report a symbol that can never carry a value type (a module alias, a type
# name, or a generic type parameter) referenced in value position
#
# Each case gets a per-kind teaching diagnostic. Returns true when the reference
# was reported, so the caller poisons the expression; false when `sym` can
# legitimately be a value. An imported symbol is classified by its origin
# declaration's kind.
# ---
# sc:  sema context
# eid: the offending expression
# sym: the resolved symbol in value position
# ret: true when reported (caller poisons), false when `sym` may be a value
fun report_never_value(sc: *context.SemaContext, eid: id.ExprId, sym: *resolve.Symbol) bool {
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret false; }
    val span: token.Span = O.unwrap[*expr.Expr](e_opt).span;

    if (sym.kind == resolve.SYM_USE) {
        context.report(sc, span, "a module alias is not a value; name one of the module's members");
        ret true;
    }
    if (sym.kind == resolve.SYM_GENERIC) {
        check.report_named(sc, span, "`", sym.name, "` is a generic type parameter, not a value; use it in type position or a comptime intrinsic like `$size_of(T)`", "a generic type parameter is not a value");
        ret true;
    }
    if (sym.kind == resolve.SYM_PRIM) {
        check.report_named(sc, span, "`", sym.name, "` is a primitive type, not a value; write a literal of that type", "a primitive type is not a value");
        ret true;
    }
    if (sym.kind == resolve.SYM_VECTOR) {
        check.report_named(sc, span, "`", sym.name, "` is a vector type, not a value; write a literal of that type", "a vector type is not a value");
        ret true;
    }

    # a local type declaration carries its kind on the symbol; an imported one is
    # uniformly SYM_IMPORTED and is classified by its origin decl.
    var dk: decl.DeclKind = decl.DECL_KIND_ERROR;
    if (sym.kind == resolve.SYM_REC)      { dk = decl.DECL_KIND_REC; }
    or (sym.kind == resolve.SYM_UNI)      { dk = decl.DECL_KIND_UNI; }
    or (sym.kind == resolve.SYM_DEF)      { dk = decl.DECL_KIND_DEF; }
    or (sym.kind == resolve.SYM_IMPORTED) { dk = symbol_decl_kind(sc, sym); }

    if (dk == decl.DECL_KIND_REC) {
        check.report_named(sc, span, "`", sym.name, "` is a record type, not a value; construct an instance with `Type{ ... }`", "a record type is not a value");
        ret true;
    }
    if (dk == decl.DECL_KIND_UNI) {
        check.report_named(sc, span, "`", sym.name, "` is a union type, not a value; construct an instance with `Type{ ... }`", "a union type is not a value");
        ret true;
    }
    if (dk == decl.DECL_KIND_DEF) {
        check.report_named(sc, span, "`", sym.name, "` is a type alias, not a value; use a value of the aliased type", "a type alias is not a value");
        ret true;
    }
    ret false;
}

# the declaration kind behind a symbol, read from its origin module's AST
#
# The symbol may be imported. DECL_KIND_ERROR when the decl is unavailable.
# ---
# sc:  sema context
# sym: the resolved symbol to classify
# ret: the symbol's DeclKind, or DECL_KIND_ERROR
fun symbol_decl_kind(sc: *context.SemaContext, sym: *resolve.Symbol) decl.DeclKind {
    if (sym.decl == id.DECL_NIL) { ret decl.DECL_KIND_ERROR; }
    val a: *ast.Ast = symbol_ast(sc, sym);
    if (a == nil) { ret decl.DECL_KIND_ERROR; }
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(a, sym.decl);
    if (O.is_none[*decl.Decl](d_opt)) { ret decl.DECL_KIND_ERROR; }
    ret O.unwrap[*decl.Decl](d_opt).kind;
}

# report a comptime-parameter-function value reference against the ident span
# and poison the expression
# ---
# sc:  sema context
# eid: the offending reference expression
# ret: TYPE_ERROR
fun report_comptime_param_fn_ref(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_some[*expr.Expr](e_opt)) {
        context.report(sc, O.unwrap[*expr.Expr](e_opt).span, "cannot reference a comptime-parameter function as a value");
    }
    ret type.TYPE_ERROR;
}

# BINARY: per-operator type rules
#
# Arithmetic / bitwise / shift return the common operand type; comparisons,
# equality, and logical ops return u8; assignment returns the LHS type after
# checking assignability.
# ---
# sc:   sema context
# eid:  the binary expression
# b:    the binary operation payload
# span: the operator span for diagnostics
# ret:  the result TypeId, or TYPE_ERROR
fun infer_binary(sc: *context.SemaContext, eid: id.ExprId, b: *expr.ExprBinary, span: token.Span) type.TypeId {
    if (b.op == expr.BIN_ASSIGN) { ret infer_assign(sc, b, span); }

    # a type comparison (`$type_of(...) == TypeName`) is a comptime-only bool:
    # its operands name types, not values, so they are typed specially and never
    # reach the value comparison below (which would mis-infer the `$type_of(...)`
    # call).
    if ((b.op == expr.BIN_EQ || b.op == expr.BIN_NEQ)
        && (comptime.is_type_comparison(sc.a, sc.source, b)
         || is_field_type_operand(sc, b.lhs)
         || is_field_type_operand(sc, b.rhs))) {
        ret infer_type_comparison(sc, b, span);
    }

    var lt: type.TypeId = infer_expr(sc, b.lhs);
    var rt: type.TypeId = infer_expr(sc, b.rhs);
    if (lt == type.TYPE_ERROR || rt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    # secrecy JOIN: an operation with any secret operand yields a secret result
    # (public is the bottom of the lattice). taint is read from the original
    # operands here and reapplied to whatever result type each operator computes.
    val lhs_secret:    bool = type.is_secret(?sc.s.types, lt);
    val either_secret: bool = lhs_secret || type.is_secret(?sc.s.types, rt);

    # vector operands follow the lane-wise op table (#1965), a separate ladder
    # from the scalar rules below: exact same-shape match, no scalar<->vector
    # mixing, and no literal unification into a vector.
    if (type.is_vector(?sc.s.types, lt) || type.is_vector(?sc.s.types, rt)) {
        ret infer_vector_binary(sc, b.op, lt, rt, either_secret, span);
    }

    # GATE: `/` and `%` are variable-latency on every target (the leakage model
    # always observes them), so a secret operand is a compile error here.
    if ((b.op == expr.BIN_DIV || b.op == expr.BIN_MOD) && either_secret) {
        context.report(sc, span, "secret value used as an operand of a variable-latency `/` or `%`; a secret divisor or dividend leaks through timing");
    }

    # GATE: floating-point operations are variable-latency on typical hardware
    # (subnormal / NaN handling adds cycles), so a secret FP operand leaks through
    # timing. gated by default on every target regardless of the CT capability flag,
    # which governs integer multiply alone - no mainstream FP unit documents
    # data-independent timing (#1646). div / mod are gated above for every type; this
    # covers the remaining FP arithmetic and comparison forms. the integer-multiply
    # gate is target-dependent, so it lands at MIR lowering where the target is known.
    if (either_secret && (is_float(sc, lt) || is_float(sc, rt))
        && b.op != expr.BIN_DIV && b.op != expr.BIN_MOD) {
        context.report(sc, span, "secret value used as an operand of a variable-latency floating-point operation; the FP unit's timing can depend on the secret operand");
    }

    # let a literal operand take the shape of the other side
    val co: O.Option[type.TypeId] = unify_literals(sc, b.lhs, lt, b.rhs, rt);
    if (O.is_some[type.TypeId](co)) {
        lt = O.unwrap[type.TypeId](co);
        rt = lt;
    }

    val u8t: type.TypeId = prim_or_error(sc, type.TYPE_U8);

    # integer operands compare and combine across widths: a Mach scalar integer
    # operation is value-based, not identity-based, so two integer primitives
    # need not share a TypeId (e.g. a `u32`-backed `def` against a `u8`-backed
    # `def`). this width-agnostic integer compatibility is distinct from
    # assignment, which stays identity-only (no implicit widening between
    # variables). non-integer operands still require an exact TypeId match.
    val both_int:    bool = is_integer(sc, lt) && is_integer(sc, rt);
    val operands_ok: bool = lt == rt || both_int;

    # comparisons relate mathematical values, so any integer signedness/width mix
    # and any float-width mix are legal -- the lowering yields order-independent,
    # value-correct results. a mixed integer/float pair is rejected: f64 rounding
    # above 2^53 makes a silent widening hidden behavior, so the cast is explicit.
    val both_float:    bool = is_float(sc, lt) && is_float(sc, rt);
    val int_float_mix: bool = (is_integer(sc, lt) && is_float(sc, rt))
                           || (is_float(sc, lt) && is_integer(sc, rt));

    if (b.op == expr.BIN_EQ || b.op == expr.BIN_NEQ) {
        # equality also relates two address-shaped operands (pointers and
        # functions, both runtime code/data addresses). this covers a bare
        # `fn == fn2` where neither side is a coercible literal; a comparison
        # against `nil` instead coerces nil to the function type first (see
        # `coerce`), so it arrives here already address-typed on both sides.
        if (int_float_mix) { report_int_float_cmp(sc, span); ret type.TYPE_ERROR; }
        val addr_ok: bool = is_pointer_like(sc, lt) && is_pointer_like(sc, rt);
        if (!operands_ok && !both_float && !addr_ok) { type_mismatch(sc, span, lt, rt); ret type.TYPE_ERROR; }
        ret join_secret(sc, u8t, either_secret);
    }
    if (b.op == expr.BIN_LT || b.op == expr.BIN_LEQ || b.op == expr.BIN_GT || b.op == expr.BIN_GEQ) {
        if (int_float_mix)            { report_int_float_cmp(sc, span); ret type.TYPE_ERROR; }
        if (!both_int && !both_float) { type_mismatch(sc, span, lt, rt); ret type.TYPE_ERROR; }
        ret join_secret(sc, u8t, either_secret);
    }
    if (b.op == expr.BIN_AND || b.op == expr.BIN_OR) {
        if (!both_int) {
            context.report(sc, span, "type mismatch: logical operands must be integer types");
            ret type.TYPE_ERROR;
        }
        # GATE: `&&` / `||` short-circuit by branching on the LEFT operand (the
        # right is evaluated conditionally), so a secret left operand is the
        # secret-dependent branch the leakage model observes. a secret right
        # operand only taints the result (no branch keys on it).
        if (lhs_secret) {
            context.report(sc, span, "secret value used as the left operand of a short-circuiting `&&` / `||`; the branch it controls leaks through control flow");
        }
        ret join_secret(sc, u8t, either_secret);
    }
    if (b.op == expr.BIN_BIT_AND || b.op == expr.BIN_BIT_OR || b.op == expr.BIN_BIT_XOR
        || b.op == expr.BIN_SHL || b.op == expr.BIN_SHR) {
        if (!both_int) { type_mismatch(sc, span, lt, rt); ret type.TYPE_ERROR; }
        ret join_secret(sc, lt, either_secret);
    }
    # arithmetic: ADD, SUB, MUL, DIV, MOD
    if (!operands_ok || !is_numeric(sc, lt)) { type_mismatch(sc, span, lt, rt); ret type.TYPE_ERROR; }
    ret join_secret(sc, lt, either_secret);
}

# the lane-wise binary operator table for vector operands (#1965)
#
# Operands must be the same vector shape (exact TypeId match, no implicit casts,
# no scalar<->vector mixing). The honest table of what is 1:1 on the SSE2/NEON
# baselines: float lanes `+ - * /`; integer lanes `+ -` at all widths and `*` on
# 16-bit lanes only; bitwise `& | ^ << >>` on integer lanes; comparisons yield
# the same-shape unsigned mask vector. There is no vector `%` and no integer
# vector `/`. Result secrecy is the join of the operands'.
# ---
# sc:            sema context
# op:            the binary operator
# lt:            the left operand type
# rt:            the right operand type
# either_secret: whether either operand was secret
# span:          the operator span for diagnostics
# ret:           the result TypeId, or TYPE_ERROR
fun infer_vector_binary(sc: *context.SemaContext, op: expr.BinOp, lt: type.TypeId, rt: type.TypeId, either_secret: bool, span: token.Span) type.TypeId {
    val lbase: type.TypeId = type.strip_secret(?sc.s.types, lt);
    val rbase: type.TypeId = type.strip_secret(?sc.s.types, rt);

    # both operands must be vectors of exactly the same shape.
    if (!type.is_vector(?sc.s.types, lt) || !type.is_vector(?sc.s.types, rt) || lbase != rbase) {
        type_mismatch(sc, span, lt, rt);
        ret type.TYPE_ERROR;
    }

    val d: type.PrimDesc = type.prim_desc(type.vector_element(?sc.s.types, lbase));
    val float_lane: bool = d.class == type.PRIM_CLASS_FLOAT;
    val int_lane:   bool = d.class == type.PRIM_CLASS_INT;

    # comparisons -> same-shape unsigned mask vector (all-ones / all-zeros lanes).
    if (op == expr.BIN_EQ || op == expr.BIN_NEQ || op == expr.BIN_LT
        || op == expr.BIN_LEQ || op == expr.BIN_GT || op == expr.BIN_GEQ) {
        val mr: R.Result[type.TypeId, str] = type.vector_mask(?sc.s.types, lbase);
        if (R.is_err[type.TypeId, str](mr)) { ret type.TYPE_ERROR; }
        ret join_secret(sc, R.unwrap_ok[type.TypeId, str](mr), either_secret);
    }

    # `<<` / `>>` are out of the increment-1 table (#2030): the lowered form is a
    # per-lane variable shift, which is AVX2-only on x86_64 (VPSLLVD-class) and has
    # no 8-bit packed form at all, so it is not 1:1 on the SSE2 baseline. shifts
    # return in a later increment as a deliberate choice between the uniform-count
    # shape (SSE2-1:1 with splat) and the per-lane shape (NEON-native, AVX2-gated).
    if (op == expr.BIN_SHL || op == expr.BIN_SHR) {
        check.report_typed(sc, span, "vector shift `<<` / `>>` is not in the increment-1 operator table (`", lbase, "`); a per-lane variable shift is not 1:1 on the SSE2 baseline (AVX2-only, no 8-bit packed form), so shifts are deferred to a later increment", "vector shift is not in the increment-1 operator table");
        ret type.TYPE_ERROR;
    }

    # bitwise `& | ^` require integer lanes.
    if (op == expr.BIN_BIT_AND || op == expr.BIN_BIT_OR || op == expr.BIN_BIT_XOR) {
        if (!int_lane) {
            context.report(sc, span, "type mismatch: bitwise vector operands must have integer lanes");
            ret type.TYPE_ERROR;
        }
        ret join_secret(sc, lbase, either_secret);
    }

    # no vector `%` on any lane type.
    if (op == expr.BIN_MOD) {
        context.report(sc, span, "vector `%` is not supported");
        ret type.TYPE_ERROR;
    }

    # `/` is float-lane only; integer vector division is not supported.
    if (op == expr.BIN_DIV) {
        if (!float_lane) {
            context.report(sc, span, "integer vector `/` is not supported");
            ret type.TYPE_ERROR;
        }
        ret join_secret(sc, lbase, either_secret);
    }

    # `*` is float lanes, or 16-bit integer lanes only (pmulld is out of baseline).
    if (op == expr.BIN_MUL) {
        if (float_lane || (int_lane && d.bits == 16)) {
            ret join_secret(sc, lbase, either_secret);
        }
        context.report(sc, span, "vector `*` on this lane width is not supported (integer multiply is 16-bit lanes only)");
        ret type.TYPE_ERROR;
    }

    # `+` / `-` on float or integer lanes at any width.
    if (op == expr.BIN_ADD || op == expr.BIN_SUB) {
        if (float_lane || int_lane) { ret join_secret(sc, lbase, either_secret); }
        type_mismatch(sc, span, lt, rt);
        ret type.TYPE_ERROR;
    }

    # `&&` / `||` and anything else are not lane-wise vector operators.
    context.report(sc, span, "operator not supported on vector operands");
    ret type.TYPE_ERROR;
}

# apply the secrecy JOIN to a binary/unary result base type (#1645)
#
# Strips any secrecy already on `base` and re-wraps in `^` exactly when an
# operand was secret, so a doubled qualifier never forms and the result's
# secrecy is precisely the join of its operands'.
# ---
# sc:     sema context
# base:   the operator's computed result type
# secret: true when any operand was secret
# ret:    `^strip(base)` when `secret`, else `strip(base)`
fun join_secret(sc: *context.SemaContext, base: type.TypeId, secret: bool) type.TypeId {
    val pub: type.TypeId = type.strip_secret(?sc.s.types, base);
    if (!secret) { ret pub; }
    val r: R.Result[type.TypeId, str] = type.intern_secret(?sc.s.types, pub);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# type a type comparison (`$type_of(...) == TypeName`)
#
# Each operand is typed for its type identity -- a `$type_of(e)` operand by
# inferring its inner value `e`, a type-name operand by resolving the named type
# into its expr_type slot -- so the type resolver reads a populated type either
# way. The comparison itself is a bool (u8); it folds once both operand types are
# known -- at sema for a concrete-typed body (the resolver sema installs), else at
# monomorphization for a pack / generic body deferred to lowering.
# ---
# sc:   sema context
# b:    the equality/inequality payload
# span: the operator span for diagnostics
# ret:  u8, or TYPE_ERROR
fun infer_type_comparison(sc: *context.SemaContext, b: *expr.ExprBinary, span: token.Span) type.TypeId {
    # a type comparison is comptime-only: it folds to a selected arm at compile
    # time and has no runtime value. valid only as a `$if` gate condition; in any
    # runtime value position it is a misuse, reported at its own span.
    if (!sc.in_comptime_gate) {
        context.report(sc, span, "a `$type_of` type comparison is comptime-only; it is valid only as a `$if` gate condition");
        ret type.TYPE_ERROR;
    }
    val lt: type.TypeId = infer_type_operand(sc, b.lhs, span);
    val rt: type.TypeId = infer_type_operand(sc, b.rhs, span);
    if (lt == type.TYPE_ERROR || rt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    ret prim_or_error(sc, type.TYPE_U8);
}

# type one type-comparison operand and return the type it names
#
# A `$type_of(e)` operand names the type of its inner value `e` (inferred so its
# expr_type slot populates); any other operand is a type-name spelling resolved
# through the same path as a `$size_of` argument, with the named type written
# into its expr_type slot.
# ---
# sc:      sema context
# operand: the operand expression
# span:    the operand span for diagnostics
# ret:     the named TypeId, or TYPE_ERROR
fun infer_type_operand(sc: *context.SemaContext, operand: id.ExprId, span: token.Span) type.TypeId {
    if (comptime.is_type_of_call(sc.a, sc.source, operand)) {
        val arg: id.ExprId = comptime.type_of_arg(sc.a, operand);
        if (arg == id.EXPR_NIL) {
            context.report(sc, span, "$type_of: expected one argument");
            ret type.TYPE_ERROR;
        }
        ret infer_expr(sc, arg);
    }
    # an `f.type` field-descriptor type names the bound field's type.
    if (is_field_type_operand(sc, operand)) {
        ret field_type_operand_type(sc, operand);
    }
    val op_ty: type.TypeId = intrinsic_operand_type(sc, operand, span);
    set_expr_type(sc, operand, op_ty);
    ret op_ty;
}

# whether `eid` is an `f.type` operand whose object evaluates to a comptime field
# descriptor
#
# This is the sema-time recognition of a field-descriptor type operand, valid
# during the `$each` unroll where the loop variable is bound.
# ---
# sc:  sema context
# eid: the candidate member expression
# ret: true when `eid` is an `f.type` over a field descriptor
pub fun is_field_type_operand(sc: *context.SemaContext, eid: id.ExprId) bool {
    if (!comptime.is_field_type_member(sc.a, sc.source, eid)) { ret false; }
    val n_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](n_opt)) { ret false; }
    val obj: id.ExprId = O.unwrap[*expr.Expr](n_opt).data.member.object;
    val r: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, obj, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](r)) { ret false; }
    ret R.unwrap_ok[comptime.CTValue, str](r).kind == comptime.CT_KIND_FIELD;
}

# the type an `f.type` operand names: the bound field's type, read from the
# descriptor the object evaluates to
# ---
# sc:  sema context
# eid: the `f.type` member expression
# ret: the bound field's TypeId, or TYPE_ERROR
fun field_type_operand_type(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    val n_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](n_opt)) { ret type.TYPE_ERROR; }
    val obj: id.ExprId = O.unwrap[*expr.Expr](n_opt).data.member.object;
    val r: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, obj, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](r)) { ret type.TYPE_ERROR; }
    val fv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](r);
    if (fv.kind != comptime.CT_KIND_FIELD) { ret type.TYPE_ERROR; }
    val fa: O.Option[*type.FieldEntry] = type.field_at(?sc.s.types, fv.data.fld.owner::type.TypeId, fv.data.fld.index);
    if (O.is_none[*type.FieldEntry](fa)) { ret type.TYPE_ERROR; }
    ret O.unwrap[*type.FieldEntry](fa).ty;
}

# ASSIGN: RHS must be assignable to LHS; result is the LHS type
#
# A literal RHS is coerced toward the LHS type first.
# ---
# sc:   sema context
# b:    the assignment payload
# span: the operator span for diagnostics
# ret:  the LHS TypeId, or TYPE_ERROR
fun infer_assign(sc: *context.SemaContext, b: *expr.ExprBinary, span: token.Span) type.TypeId {
    val lt: type.TypeId = infer_expr(sc, b.lhs);
    val rt: type.TypeId = infer_expr(sc, b.rhs);
    if (lt == type.TYPE_ERROR || rt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    check.check_coercible(sc, lt, b.rhs, rt, span);
    ret lt;
}

# UNARY: per-operator rules
#
# NEG returns the operand type, NOT returns u8, BIT_NOT returns the operand
# type, ADDR returns a pointer to the operand type, DEREF returns the pointee of
# a pointer operand. The value operators (`-`, `!`, `~`) join the operand's
# secrecy onto their result; `&` instead nests it (`&^T` is the public pointer
# `*^T`), and DEREF recovers it from the pointee (`@(*^T)` is `^T`).
# ---
# sc:   sema context
# u:    the unary operation payload
# span: the operator span for diagnostics
# ret:  the result TypeId, or TYPE_ERROR
fun infer_unary(sc: *context.SemaContext, u: *expr.ExprUnary, span: token.Span) type.TypeId {
    val ot: type.TypeId = infer_expr(sc, u.operand);
    if (ot == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val ot_secret: bool = type.is_secret(?sc.s.types, ot);

    if (u.op == expr.UN_NEG) {
        if (!is_numeric(sc, ot)) { context.report(sc, span, "type mismatch: unary - requires a numeric operand"); ret type.TYPE_ERROR; }
        ret join_secret(sc, ot, ot_secret);
    }
    if (u.op == expr.UN_NOT) {
        if (!is_integer(sc, ot)) { context.report(sc, span, "type mismatch: unary ! requires an integer operand"); ret type.TYPE_ERROR; }
        ret join_secret(sc, prim_or_error(sc, type.TYPE_U8), ot_secret);
    }
    if (u.op == expr.UN_BIT_NOT) {
        # `~v` on an integer-lane vector yields the operand vector type (#1965).
        if (type.is_vector(?sc.s.types, ot)) {
            val base: type.TypeId = type.strip_secret(?sc.s.types, ot);
            if (type.prim_desc(type.vector_element(?sc.s.types, base)).class != type.PRIM_CLASS_INT) {
                context.report(sc, span, "type mismatch: unary ~ requires integer lanes");
                ret type.TYPE_ERROR;
            }
            ret join_secret(sc, base, ot_secret);
        }
        if (!is_integer(sc, ot)) { context.report(sc, span, "type mismatch: unary ~ requires an integer operand"); ret type.TYPE_ERROR; }
        ret join_secret(sc, ot, ot_secret);
    }
    if (u.op == expr.UN_ADDR) {
        # a comptime value parameter has no runtime storage -- it folds to a
        # constant per instance -- so its address is meaningless. reject it here
        # with a clear message, rather than fabricating an extern global at lower.
        if (operand_is_comptime_param(sc, u.operand)) {
            context.report(sc, span, "cannot take the address of a comptime parameter");
            ret type.TYPE_ERROR;
        }
        ret ptr_to(sc, ot);
    }
    if (u.op == expr.UN_DEREF) {
        ret pointee_of(sc, ot, span);
    }
    ret type.TYPE_ERROR;
}

# whether `eid` is a direct reference to a comptime value parameter (SYM_PARAM
# with SYM_FLAG_COMPTIME)
#
# Used to reject taking its address.
# ---
# sc:  sema context
# eid: the operand expression
# ret: true when `eid` names a comptime value parameter
fun operand_is_comptime_param(sc: *context.SemaContext, eid: id.ExprId) bool {
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](e_opt))                             { ret false; }
    if (O.unwrap[*expr.Expr](e_opt).kind != expr.EXPR_KIND_IDENT) { ret false; }
    val so: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
    if (O.is_none[*resolve.Symbol](so)) { ret false; }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](so);
    ret sym.kind == resolve.SYM_PARAM && (sym.flags & resolve.SYM_FLAG_COMPTIME) != 0;
}

# CALL: callee must be TYPE_FUN; check arity and each argument against the
# parameter types; result is the function's return type
#
# A call carrying explicit type arguments `callee[T, ...](args)` instantiates the
# generic callee's signature before checking. A call whose callee is a comptime
# intrinsic (`$size_of`, `$align_of`, `$offset_of`) is a value intrinsic yielding
# an unsigned integer, handled before normal callee inference.
# ---
# sc:   sema context
# c:    the call payload
# span: the call span for diagnostics
# ret:  the call's result TypeId, or TYPE_ERROR
fun infer_call(sc: *context.SemaContext, c: *expr.ExprCall, span: token.Span) type.TypeId {
    val intr: type.TypeId = infer_comptime_intrinsic(sc, c, span);
    if (intr != type.TYPE_NIL) { ret intr; }

    # mark the callee position so infer_ident permits a comptime-parameter
    # function here (callable as a template) while still rejecting it as a value.
    val saved_callee: id.ExprId = sc.callee_eid;
    sc.callee_eid = c.callee;
    val ct: type.TypeId = infer_expr(sc, c.callee);
    sc.callee_eid = saved_callee;

    # infer argument types so their expr_type slots are populated
    var i: u32 = 0;
    for (i < c.args_len) {
        infer_expr(sc, sc.a.expr_ids[c.args_start + i]);
        i = i + 1;
    }

    val cf_opt: O.Option[*decl.DeclFun] = callee_fun_decl(sc, c.callee);

    # a callee that is BOTH generic (`[T]`) and comptime-param (`$mode`) would
    # need a combined type+value instance, which is not yet supported. reject it
    # EARLY -- before both the generic-call path (which checks against the
    # comptime-stripped signature) and the comptime-call path (which ignores the
    # type parameters) -- regardless of whether explicit type arguments were
    # written, so neither produces a confusing arity / "expected T, found ..."
    # error or a miscompile.
    if (O.is_some[*decl.DeclFun](cf_opt)) {
        val cf: *decl.DeclFun = O.unwrap[*decl.DeclFun](cf_opt);
        if (cf.generics_len > 0 && decl_has_comptime_param(sc, c.callee, cf)) {
            context.report(sc, span, "comptime value parameters on a generic function are not yet supported");
            ret type.TYPE_ERROR;
        }
    }

    if (c.type_args_len > 0) {
        ret infer_generic_call(sc, c, ct, span);
    }

    if (ct == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val fn_opt: O.Option[*type.Type] = type.get(?sc.s.types, ct);
    if (O.is_none[*type.Type](fn_opt)) { ret type.TYPE_ERROR; }
    val fn: *type.Type = O.unwrap[*type.Type](fn_opt);
    if (fn.kind != type.TYPE_FUN) {
        check.report_typed(sc, span, "not callable: `", ct, "` is not a function", "not callable: target is not a function");
        ret type.TYPE_ERROR;
    }

    val ret_type: type.TypeId = fn.data.fn.ret_type;

    # a callee with comptime value parameters is checked against its AST
    # parameter list (the stripped TYPE_FUN omits the comptime ordinals), and
    # each `$`-argument is required to be compile-time foldable.
    if (O.is_some[*decl.DeclFun](cf_opt)) {
        val cf: *decl.DeclFun = O.unwrap[*decl.DeclFun](cf_opt);
        if (decl_has_comptime_param(sc, c.callee, cf)) {
            check.check_comptime_call(sc, ct, c.callee, cf, c.args_start, c.args_len, span);
            ret ret_type;
        }
    }

    check.check_call(sc, ct, c.args_start, c.args_len, span);
    ret ret_type;
}

# resolve a call's callee to its DeclFun, reading the origin module's AST for a
# cross-module callee
#
# None when the callee does not name a function.
# ---
# sc:     sema context
# callee: the callee expression
# ret:    some(*DeclFun) when the callee names a function, else none
fun callee_fun_decl(sc: *context.SemaContext, callee: id.ExprId) O.Option[*decl.DeclFun] {
    val so: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, callee);
    if (O.is_none[*resolve.Symbol](so)) { ret O.none[*decl.DeclFun](); }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](so);
    if (sym.kind != resolve.SYM_FUN && sym.kind != resolve.SYM_IMPORTED) { ret O.none[*decl.DeclFun](); }
    if (sym.decl == id.DECL_NIL)                                         { ret O.none[*decl.DeclFun](); }

    val a: *ast.Ast = symbol_ast(sc, sym);
    if (a == nil) { ret O.none[*decl.DeclFun](); }
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(a, sym.decl);
    if (O.is_none[*decl.Decl](d_opt)) { ret O.none[*decl.DeclFun](); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);
    if (d.kind != decl.DECL_KIND_FUN) { ret O.none[*decl.DeclFun](); }
    ret O.some[*decl.DeclFun](?d.data.fun_);
}

# whether the callee DeclFun declares any comptime value parameter
#
# The typed_names slice is read from the callee's origin AST (the caller and
# callee may differ).
# ---
# sc:     sema context
# callee: the callee expression
# f:      the callee's DeclFun
# ret:    true when any parameter is comptime
fun decl_has_comptime_param(sc: *context.SemaContext, callee: id.ExprId, f: *decl.DeclFun) bool {
    val so: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, callee);
    if (O.is_none[*resolve.Symbol](so)) { ret false; }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](so);

    val a: *ast.Ast = symbol_ast(sc, sym);
    if (a == nil) { ret false; }
    var i: u32 = 0;
    for (i < f.params_len) {
        if (a.typed_names[f.params_start + i].comptime) { ret true; }
        i = i + 1;
    }
    ret false;
}

# recognise and type a comptime value intrinsic call
#
# `$size_of(T)` / `$align_of(T)` take one type-naming argument; `$offset_of(T,
# field)` takes a type and a field. Each yields an unsigned integer (`u64`),
# matching the closed intrinsic set in the language. The type argument is
# resolved so its expr_type slot carries the operand type the lowerer needs to
# fold the size. Returns TYPE_NIL when the call is not a comptime intrinsic
# (caller proceeds with normal call inference), the result type when it is, or
# TYPE_ERROR for a malformed intrinsic.
# ---
# sc:   sema context
# c:    the call payload
# span: the call span for diagnostics
# ret:  u64 for a valid intrinsic, TYPE_NIL when not one, TYPE_ERROR if malformed
fun infer_comptime_intrinsic(sc: *context.SemaContext, c: *expr.ExprCall, span: token.Span) type.TypeId {
    val ce_opt: O.Option[*expr.Expr] = ast.get_expr(sc.a, c.callee);
    if (O.is_none[*expr.Expr](ce_opt)) { ret type.TYPE_NIL; }
    val ce: *expr.Expr = O.unwrap[*expr.Expr](ce_opt);
    if (ce.kind != expr.EXPR_KIND_COMPTIME_IDENT) { ret type.TYPE_NIL; }

    val name: intern.StrId = comptime_ident_name(sc, ce.span);
    if (name == intern.STR_NIL) { ret type.TYPE_NIL; }

    # `$type_of(...)` is not a value: it yields a comptime TYPE, valid only as a
    # type-comparison operand inside a `$if` gate (typed by
    # infer_type_comparison, which never reaches here). any `$type_of` arriving
    # in a value call position is a misuse, reported precisely rather than left
    # to surface as an opaque bare-comptime-ident error at lowering.
    if (name == interned(sc, "type_of")) {
        context.report(sc, span, "`$type_of` yields a comptime type, not a value; use it as a type-comparison operand inside a `$if` gate");
        ret type.TYPE_ERROR;
    }

    val is_size:   bool = name == interned(sc, "size_of");
    val is_align:  bool = name == interned(sc, "align_of");
    val is_offset: bool = name == interned(sc, "offset_of");
    if (!is_size && !is_align && !is_offset) { ret type.TYPE_NIL; }

    var need: u32 = 1;
    if (is_offset) { need = 2; }
    if (c.args_len != need) {
        var iname: str = "$size_of: expected ";
        if (is_align)  { iname = "$align_of: expected "; }
        if (is_offset) { iname = "$offset_of: expected "; }
        context.report_numbered(sc, span, iname, need::usize, " argument(s)", "comptime intrinsic: wrong number of arguments");
        ret type.TYPE_ERROR;
    }

    # the first argument names the operand type, so it is resolved as a type
    # spelling rather than a value: a primitive (`i64`, `bool`, `ptr`, ...), a
    # user record/union/def, or a `module.Type`. the resolved operand type is
    # written into the argument's expr_type slot, which the lowerer reads to fold
    # the size / alignment / offset. the `$offset_of` field argument is a bare
    # field name resolved against the record at lowering time, not here.
    val arg0: id.ExprId = sc.a.expr_ids[c.args_start];
    val op_ty: type.TypeId = intrinsic_operand_type(sc, arg0, span);
    set_expr_type(sc, arg0, op_ty);
    if (op_ty == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    ret prim_or_error(sc, type.TYPE_U64);
}

# resolve a comptime intrinsic's type-naming argument to its semantic type
#
# The argument is a name expression bound in the resolve pass: a single IDENT
# (primitive or user type) or a `module.Type` member chain. Both carry their
# resolved SymbolId on the argument expression, mapped to a type by
# `type_for_symbol` (which handles primitives, records, unions, and defs).
# ---
# sc:   sema context
# eid:  the type-naming argument expression
# span: the argument span for diagnostics
# ret:  the named TypeId, or TYPE_ERROR
fun intrinsic_operand_type(sc: *context.SemaContext, eid: id.ExprId, span: token.Span) type.TypeId {
    val sym_opt: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
    if (O.is_none[*resolve.Symbol](sym_opt)) {
        # resolve already reported the unresolved name; absorb silently
        ret type.TYPE_ERROR;
    }
    ret type_for_symbol(sc, O.unwrap[*resolve.Symbol](sym_opt), span);
}

# write `ty` into an expression's expr_type slot, the parallel array sema fills
# for the lowerer
#
# Out-of-range ids are ignored, matching `infer_expr`.
# ---
# sc:  sema context
# eid: the expression to annotate
# ty:  the TypeId to record
fun set_expr_type(sc: *context.SemaContext, eid: id.ExprId, ty: type.TypeId) {
    if (sc.expr_type == nil)       { ret; }
    if (eid >= sc.a.expr_len::u32) { ret; }
    sc.expr_type[eid] = ty;
}

# resolve a `$fields(T)` sequence to its owning record TypeId, requiring T to be
# a record
#
# The type-argument's expr_type slot is populated for the lowerer. TYPE_ERROR
# when the sequence is malformed or T is not a record. Returns the
# TYPE_GENERIC_PARAM TypeId when T is an unbound generic param -- the caller
# defers the unroll to monomorphization. Shared by the `$each` unroll (sema and
# lowering).
# ---
# sc:      sema context
# seq_eid: the `$fields(T)` sequence expression
# span:    the sequence span for diagnostics
# ret:     the owning record TypeId, an unbound generic-param TypeId, or TYPE_ERROR
pub fun field_seq_owner(sc: *context.SemaContext, seq_eid: id.ExprId, span: token.Span) type.TypeId {
    val targ: id.ExprId = comptime.fields_type_arg(sc.a, seq_eid);
    if (targ == id.EXPR_NIL) {
        context.report(sc, span, "$fields: expected one type argument `$fields(T)`");
        ret type.TYPE_ERROR;
    }
    val owner: type.TypeId = intrinsic_operand_type(sc, targ, span);
    set_expr_type(sc, targ, owner);
    if (owner == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    # an unbound generic type param: defer the record check to monomorphization
    if (type_is_generic_param(sc, owner)) { ret owner; }
    if (!type_is_record(sc, owner)) {
        context.report(sc, span, "$fields requires a record type");
        ret type.TYPE_ERROR;
    }
    ret owner;
}

# type a `.name` / `.type` / `.offset` projection off a `$each` field descriptor,
# or TYPE_NIL when the object is not a field descriptor (a normal member access)
#
# Detection evaluates the object: only a CT_KIND_FIELD is a descriptor, so a
# member of any other value falls through. `.name` is a string (`*u8`), `.offset`
# an unsigned `usize` (`u64`); `.type` is a comptime-only TYPE value, valid only
# as a type-comparison operand, rejected here in a value position.
# ---
# sc:   sema context
# m:    the member-access payload
# span: the member span for diagnostics
# ret:  the projection type, TYPE_NIL when not a descriptor, or TYPE_ERROR
fun infer_field_member(sc: *context.SemaContext, m: *expr.ExprMember, span: token.Span) type.TypeId {
    val obj_r: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, m.object, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](obj_r))                                   { ret type.TYPE_NIL; }
    if (R.unwrap_ok[comptime.CTValue, str](obj_r).kind != comptime.CT_KIND_FIELD) { ret type.TYPE_NIL; }

    if (str_region_equals(sc.source, m.name.offset, m.name.len, "name")) {
        ret ptr_to(sc, prim_or_error(sc, type.TYPE_U8));
    }
    if (str_region_equals(sc.source, m.name.offset, m.name.len, "offset")) {
        ret prim_or_error(sc, type.TYPE_U64);
    }
    if (str_region_equals(sc.source, m.name.offset, m.name.len, "type")) {
        context.report(sc, span, "`f.type` is a comptime type, not a value; use it as a type-comparison operand inside a `$if` gate");
        ret type.TYPE_ERROR;
    }
    context.report(sc, span, "a field descriptor has only `.name`, `.type`, and `.offset`");
    ret type.TYPE_ERROR;
}

# whether a `v.[f]` receiver type names the field's owning record directly or via
# a single pointer indirection (auto-deref, mirroring member access)
# ---
# sc:     sema context
# obj_ty: the receiver's TypeId
# owner:  the field descriptor's owning record TypeId
# ret:    true when the receiver matches the owner (or a pointer to it)
fun project_receiver_matches(sc: *context.SemaContext, obj_ty: type.TypeId, owner: type.TypeId) bool {
    if (obj_ty == owner) { ret true; }
    val to: O.Option[*type.Type] = type.get(?sc.s.types, obj_ty);
    if (O.is_none[*type.Type](to)) { ret false; }
    val t: *type.Type = O.unwrap[*type.Type](to);
    # unbound generic type param (T) during deferred $fields re-inference:
    # lowering will substitute T to `owner`; accept the projection.
    if (t.kind == type.TYPE_GENERIC_PARAM) { ret true; }
    if (t.kind != type.TYPE_POINTER)       { ret false; }
    val base: type.TypeId = t.data.pointer.base;
    if (base == owner) { ret true; }
    # *T where T is an unbound generic param: also valid for the same reason.
    val bo: O.Option[*type.Type] = type.get(?sc.s.types, base);
    if (O.is_none[*type.Type](bo)) { ret false; }
    ret O.unwrap[*type.Type](bo).kind == type.TYPE_GENERIC_PARAM;
}

# whether `ty` is a comptime variadic pack
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for the singleton pack type
fun type_is_pack(sc: *context.SemaContext, ty: type.TypeId) bool {
    val to: O.Option[*type.Type] = type.get(?sc.s.types, ty);
    if (O.is_none[*type.Type](to)) { ret false; }
    ret O.unwrap[*type.Type](to).kind == type.TYPE_PACK;
}

# whether `ty` is an unbound generic type parameter
#
# Signals that a `$fields(T)` unroll must be deferred to monomorphization.
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for a TYPE_GENERIC_PARAM
pub fun type_is_generic_param(sc: *context.SemaContext, ty: type.TypeId) bool {
    val to: O.Option[*type.Type] = type.get(?sc.s.types, ty);
    if (O.is_none[*type.Type](to)) { ret false; }
    ret O.unwrap[*type.Type](to).kind == type.TYPE_GENERIC_PARAM;
}

# SPREAD: type a `va...` pack spread
#
# A spread may only spread a comptime variadic pack; its type is that pack. It
# forwards the whole pack into a trailing pack parameter -- that placement is
# validated at the call site (check_call). A spread of a non-pack operand is
# malformed.
# ---
# sc:   sema context
# sp:   the spread payload
# span: the spread span for diagnostics
# ret:  the pack TypeId, or TYPE_ERROR
fun infer_spread(sc: *context.SemaContext, sp: *expr.ExprSpread, span: token.Span) type.TypeId {
    val it: type.TypeId = infer_expr(sc, sp.inner);
    if (it == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    if (!type_is_pack(sc, it)) {
        context.report(sc, span, "`...` may only spread a variadic pack");
        ret type.TYPE_ERROR;
    }
    ret it;
}

# whether `ty` is a record (or a generic record instance), the aggregate
# `$fields` accepts
#
# Unions and non-aggregates are rejected.
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for a record or a fielded generic instance
fun type_is_record(sc: *context.SemaContext, ty: type.TypeId) bool {
    val to: O.Option[*type.Type] = type.get(?sc.s.types, ty);
    if (O.is_none[*type.Type](to)) { ret false; }
    val k: type.TypeKind = O.unwrap[*type.Type](to).kind;
    if (k == type.TYPE_REC)                                                                            { ret true; }
    if (k == type.TYPE_INSTANCE && O.is_some[*type.FieldTable](type.field_table_for(?sc.s.types, ty))) { ret true; }
    ret false;
}

# PROJECT: type a `v.[f]` field projection
#
# The field operand `f` evaluates to a comptime FIELD descriptor (bound by an
# enclosing `$each`) naming the owning record and a field ordinal; the
# projection's type is that field's type, and the instance `v` must be of the
# owning record type.
# ---
# sc:   sema context
# p:    the projection payload
# span: the projection span for diagnostics
# ret:  the projected field's TypeId, or TYPE_ERROR
fun infer_project(sc: *context.SemaContext, p: *expr.ExprProject, span: token.Span) type.TypeId {
    val obj_ty: type.TypeId = infer_expr(sc, p.object);
    val fr: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, p.field, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](fr)) {
        context.report(sc, span, "`v.[f]` requires a comptime field descriptor bound by an enclosing `$each`");
        ret type.TYPE_ERROR;
    }
    val fv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](fr);
    if (fv.kind != comptime.CT_KIND_FIELD) {
        context.report(sc, span, "`v.[f]` requires a comptime field descriptor bound by an enclosing `$each`");
        ret type.TYPE_ERROR;
    }
    if (obj_ty == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    val owner: type.TypeId = fv.data.fld.owner::type.TypeId;
    # the instance is the owning record, or a pointer to it (auto-deref, like a
    # member access `p.field` on `p: *T`).
    if (!project_receiver_matches(sc, obj_ty, owner)) {
        context.report(sc, span, "`v.[f]`: the instance type does not match the field descriptor's owning record");
        ret type.TYPE_ERROR;
    }
    val fa: O.Option[*type.FieldEntry] = type.field_at(?sc.s.types, owner, fv.data.fld.index);
    if (O.is_none[*type.FieldEntry](fa)) {
        context.report(sc, span, "`v.[f]`: field ordinal out of range");
        ret type.TYPE_ERROR;
    }
    ret O.unwrap[*type.FieldEntry](fa).ty;
}

# intern the identifier text of a `$ident` comptime ident, with the leading `$`
# stripped, returning its StrId
#
# STR_NIL on failure or an empty name. The span surgery is owned by
# `comptime.comptime_ident_name`.
# ---
# sc:   sema context
# full: the full `$ident` span
# ret:  the interned StrId, or STR_NIL
fun comptime_ident_name(sc: *context.SemaContext, full: token.Span) intern.StrId {
    val s: token.Span = comptime.comptime_ident_name(full);
    if (s.len == 0) { ret intern.STR_NIL; }
    ret intern_span_or_nil(sc, s);
}

# intern a static literal in the session interner, returning its StrId or STR_NIL
# on allocation failure
# ---
# sc:   sema context
# text: the literal text to intern
# ret:  the interned StrId, or STR_NIL
fun interned(sc: *context.SemaContext, text: str) intern.StrId {
    val r: R.Result[intern.StrId, str] = intern.intern(?sc.s.interner, text);
    if (R.is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](r);
}

# instantiate a generic call's signature and check its arguments
#
# Resolves each call-site type argument, checks arity against the callee generic
# declaration, substitutes the argument sequence into the callee's TYPE_FUN, and
# checks the call arguments against the concrete parameter types. The call's
# result type is the substituted return type.
# ---
# sc:   sema context
# c:    the call payload
# ct:   the callee's (pre-substitution) TYPE_FUN TypeId
# span: the call span for diagnostics
# ret:  the substituted return TypeId, or TYPE_ERROR
fun infer_generic_call(sc: *context.SemaContext, c: *expr.ExprCall, ct: type.TypeId, span: token.Span) type.TypeId {
    val sym_opt: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, c.callee);
    if (O.is_none[*resolve.Symbol](sym_opt)) { ret type.TYPE_ERROR; }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](sym_opt);

    val pr: R.Result[*type.TypeId, str] = allocate_params(sc, c.type_args_len);
    if (R.is_err[*type.TypeId, str](pr)) {
        # the type-argument scratch buffer failed to allocate; without a report
        # the call would reach lowering on a clean sema pass (#1348).
        context.report(sc, span, "internal: out of memory allocating generic type arguments");
        ret type.TYPE_ERROR;
    }
    val args: *type.TypeId = R.unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    for (i < c.type_args_len) {
        val arg_tid: id.TypeId = sc.a.type_ids[c.type_args_start + i];
        args[i] = resolve_type_ref(sc, arg_tid);
        i = i + 1;
    }

    if (!generics.check_arity(sc, sym.decl, sym.origin, c.type_args_len, span)) {
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }

    if (ct == type.TYPE_ERROR) {
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }
    val fn_opt: O.Option[*type.Type] = type.get(?sc.s.types, ct);
    if (O.is_none[*type.Type](fn_opt)) {
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }
    if (O.unwrap[*type.Type](fn_opt).kind != type.TYPE_FUN) {
        check.report_typed(sc, span, "not callable: `", ct, "` is not a function", "not callable: target is not a function");
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }

    val sig: type.TypeId = generics.substitute(sc.s, ct, args, c.type_args_len);
    free_params(sc, args, c.type_args_len);
    if (sig == type.TYPE_ERROR) {
        # substitute collapses every failure (an out-of-range generic parameter,
        # an allocation failure interning a rebuilt type) to the poison type;
        # arity is pre-checked, so reaching here is an internal failure that must
        # be reported rather than poisoning the call on a clean sema pass (#1348).
        context.report(sc, span, "internal: generic substitution failed");
        ret type.TYPE_ERROR;
    }

    val sfn_opt: O.Option[*type.Type] = type.get(?sc.s.types, sig);
    if (O.is_none[*type.Type](sfn_opt)) { ret type.TYPE_ERROR; }
    val sfn: *type.Type = O.unwrap[*type.Type](sfn_opt);
    if (sfn.kind != type.TYPE_FUN) { ret type.TYPE_ERROR; }

    val ret_type: type.TypeId = sfn.data.fn.ret_type;
    check.check_call(sc, sig, c.args_start, c.args_len, span);
    ret ret_type;
}

# INDEX: object must be a pointer or array, index must be an integer; result is
# the element type
# ---
# sc:   sema context
# ix:   the index payload
# span: the index span for diagnostics
# ret:  the element TypeId, or TYPE_ERROR
fun infer_index(sc: *context.SemaContext, ix: *expr.ExprIndex, span: token.Span) type.TypeId {
    val ot: type.TypeId = infer_expr(sc, ix.object);
    val it: type.TypeId = infer_expr(sc, ix.index);
    if (ot == type.TYPE_ERROR || it == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    # lane access `v[i]` on a vector: the index must be a comptime constant in
    # bounds, and the result is the lane scalar (#1965). a dynamic index is a
    # defined error, deferred by design (a memory round-trip breaks 1:1 on SSE2).
    if (type.is_vector(?sc.s.types, ot)) {
        ret infer_vector_lane(sc, ix, ot, span);
    }

    val r: O.Option[type.TypeId] = check.check_index(sc, ot, it, span);
    if (O.is_none[type.TypeId](r)) { ret type.TYPE_ERROR; }
    ret O.unwrap[type.TypeId](r);
}

# lane access on a vector: demand a comptime-constant, in-bounds index and yield
# the lane scalar, joining any secrecy on the vector onto the result (#1965)
# ---
# sc:   sema context
# ix:   the index payload
# ot:   the (possibly secret) vector object type
# span: the index span for diagnostics
# ret:  the lane scalar TypeId, or TYPE_ERROR
fun infer_vector_lane(sc: *context.SemaContext, ix: *expr.ExprIndex, ot: type.TypeId, span: token.Span) type.TypeId {
    val base:      type.TypeId = type.strip_secret(?sc.s.types, ot);
    val lanes:     u32         = type.vector_lanes(?sc.s.types, base);
    val lane_kind: type.TypeKind = type.vector_element(?sc.s.types, base);
    val lane_ty:   type.TypeId = prim_or_error(sc, lane_kind);

    val cr: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, ix.index, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](cr)) {
        context.report(sc, span, "dynamic lane index not supported: a vector lane index must be a comptime constant");
        ret type.TYPE_ERROR;
    }
    val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](cr);
    if (cv.kind != comptime.CT_KIND_INT) {
        context.report(sc, span, "dynamic lane index not supported: a vector lane index must be a comptime constant");
        ret type.TYPE_ERROR;
    }
    if (comptime.ct_is_negative(cv)) {
        context.report(sc, span, "vector lane index out of bounds: index must be non-negative");
        ret type.TYPE_ERROR;
    }
    if (cv.data.i:~u64 >= lanes::u64) {
        context.report(sc, span, "vector lane index out of bounds for the lane count");
        ret type.TYPE_ERROR;
    }

    ret join_secret(sc, lane_ty, type.is_secret(?sc.s.types, ot));
}

# MEMBER: a member access is either a qualified module reference `alias.symbol`
# or a field access `object.field`
#
# A qualified reference is resolved during name resolution and recorded on the
# member expression, whose type is that symbol's. For a field access the object
# must be a record or union (or a pointer to one), and a generic instance's field
# layout is materialized on demand before the field lookup.
# ---
# sc:   sema context
# eid:  the member expression
# m:    the member-access payload
# span: the member span for diagnostics
# ret:  the member's TypeId, or TYPE_ERROR
fun infer_member(sc: *context.SemaContext, eid: id.ExprId, m: *expr.ExprMember, span: token.Span) type.TypeId {
    val qsym_opt: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
    if (O.is_some[*resolve.Symbol](qsym_opt)) {
        val qsym: *resolve.Symbol = O.unwrap[*resolve.Symbol](qsym_opt);
        # a qualified member that resolved to a module alias (`lib.alpha` through
        # a `fwd` re-export) or to an exported type name is a misuse in value
        # position, exactly like a bare ident (see infer_ident).
        if (report_never_value(sc, eid, qsym)) { ret type.TYPE_ERROR; }
        ret context.decl_type_for(sc, qsym);
    }

    # an unresolved member whose object IS a module alias: resolve already
    # reported the failure (a missing export, or a missing dep-set target), so
    # poison silently like any other unresolved reference instead of inferring
    # the alias object as a value.
    val osym_opt: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, m.object);
    if (O.is_some[*resolve.Symbol](osym_opt) && O.unwrap[*resolve.Symbol](osym_opt).kind == resolve.SYM_USE) {
        ret type.TYPE_ERROR;
    }

    # a rooted comptime member chain (`$mach.*`, `$project.*`, `$bin.*`) is a
    # comptime path, not a field access; its object is not a real record value.
    # fold it to a comptime-int type when it resolves to an integer, or to the
    # string-literal type when it resolves to a string.
    val cti: type.TypeId = infer_comptime_int_path(sc, eid);
    if (cti != type.TYPE_NIL) { ret cti; }
    val cts: type.TypeId = infer_comptime_str_path(sc, eid);
    if (cts != type.TYPE_NIL) { ret cts; }

    # `f.name` / `f.type` / `f.offset` on a `$each` field descriptor.
    val fdm: type.TypeId = infer_field_member(sc, m, span);
    if (fdm != type.TYPE_NIL) { ret fdm; }

    val ot: type.TypeId = infer_expr(sc, m.object);
    if (ot == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    # `va.len` on a comptime variadic pack is the comptime element count.
    if (type_is_pack(sc, ot)) {
        if (str_region_equals(sc.source, m.name.offset, m.name.len, "len")) {
            ret prim_or_error(sc, type.TYPE_U64);
        }
        context.report(sc, span, "a variadic pack has only `.len`; iterate its elements with `$each`");
        ret type.TYPE_ERROR;
    }

    if (ot == type.TYPE_NIL) {
        # a value-less object (a call to a function with no return type) yields
        # no value; without a report the broken access would reach lowering with
        # a clean sema pass (#1348).
        context.report(sc, span, "a call that returns nothing has no members; a member access requires a record or union value");
        ret type.TYPE_ERROR;
    }

    ensure_record_fields(sc, ot);

    val name_id: intern.StrId = intern_span_or_nil(sc, m.name);
    val r: O.Option[type.TypeId] = check.check_member(sc, ot, name_id, span);
    if (O.is_none[type.TypeId](r)) { ret type.TYPE_ERROR; }
    ret O.unwrap[type.TypeId](r);
}

# type a value-context comptime path that folds to an integer (`$mach.build.os`,
# `$mach.os.linux`, `$mach.build.pointer_width`, ...)
#
# Such a path takes the default concrete comptime-int type (TYPE_I64) and then
# narrows to the usage-site type via `coerce.try_coerce_literal`, exactly like an
# integer literal. Returns TYPE_NIL when `eid` is not a comptime path or the path
# does not fold to an integer, so the caller falls back to its normal handling.
# ---
# sc:  sema context
# eid: the candidate member-chain expression
# ret: TYPE_I64 when the path folds to an integer, else TYPE_NIL
fun infer_comptime_int_path(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    if (!comptime.is_comptime_path(sc.a, eid)) { ret type.TYPE_NIL; }
    val ev: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](ev)) { ret type.TYPE_NIL; }
    val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](ev);
    if (cv.kind != comptime.CT_KIND_INT) { ret type.TYPE_NIL; }
    ret prim_or_error(sc, type.TYPE_I64);
}

# type a value-context comptime path that folds to a string
# (`$mach.compiler.name`, `$project.version`, `$project.target.os`, `$bin.name`,
# ...)
#
# A folded comptime string is materialised exactly as a string literal -- an
# anonymous rodata blob referenced by pointer -- so it takes the string-literal
# type `*u8` and shares the literal's assignability (a `*u8` flows into a
# `str`/`*char` slot). Returns TYPE_NIL when `eid` is not a comptime path or does
# not fold to a string, so the caller falls back to its normal handling.
# ---
# sc:  sema context
# eid: the candidate member-chain expression
# ret: `*u8` when the path folds to a string, else TYPE_NIL
fun infer_comptime_str_path(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    if (!comptime.is_comptime_path(sc.a, eid)) { ret type.TYPE_NIL; }
    val ev: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](ev)) { ret type.TYPE_NIL; }
    val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](ev);
    if (cv.kind != comptime.CT_KIND_STR) { ret type.TYPE_NIL; }
    ret ptr_to(sc, prim_or_error(sc, type.TYPE_U8));
}

# materialize the field layout of `tid` (and, if `tid` is a pointer, its pointee)
# for an upcoming field access
#
# Only generic instances need this -- nominal layouts are built when their
# declaring module is analysed -- but a pointer-to-instance reaches a field
# through one level of indirection.
# ---
# sc:  sema context
# tid: the TypeId whose field layout to ensure
fun ensure_record_fields(sc: *context.SemaContext, tid: type.TypeId) {
    generics.ensure_fields(sc.s, tid);
    val t_opt: O.Option[*type.Type] = type.get(?sc.s.types, tid);
    if (O.is_none[*type.Type](t_opt)) { ret; }
    val t: *type.Type = O.unwrap[*type.Type](t_opt);
    if (t.kind == type.TYPE_POINTER) {
        generics.ensure_fields(sc.s, t.data.pointer.base);
    }
}

# CAST: delegate to check.check_cast (value-convert `::`) or
# check.check_reinterpret (bit-reinterpret `:~`), selected by the node's
# `reinterpret` flag
# ---
# sc:   sema context
# c:    the cast payload
# span: the cast span for diagnostics
# ret:  the target TypeId, or TYPE_ERROR
fun infer_cast(sc: *context.SemaContext, c: *expr.ExprCast, span: token.Span) type.TypeId {
    val ft: type.TypeId = infer_expr(sc, c.value);
    val tt: type.TypeId = context.resolved_type_of(sc, c.ty);
    if (ft == type.TYPE_ERROR || tt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    var r: O.Option[type.TypeId] = O.none[type.TypeId]();
    if (c.reinterpret) {
        r = check.check_reinterpret(sc, ft, tt, span);
    }
    or {
        r = check.check_cast(sc, ft, tt, span);
    }
    if (O.is_none[type.TypeId](r)) { ret type.TYPE_ERROR; }
    ret O.unwrap[type.TypeId](r);
}

# STRIP: the `:^` secret-qualifier strip cast - the sole downgrade (#1645)
#
# Removes the outer `^` from the operand's type, producing a NEW public value
# (the only secret->public crossing the type system permits). It peels exactly
# the top-level qualifier: a welded `*^T` pointer's pointee secrecy is never
# laundered by `:^` since the outer type there is a (public) pointer. A bare
# `value:^` strips in place; `value:^Type` strips to an explicit target, which
# must itself be public (a `^Type` target would re-add the qualifier the cast
# removes).
# ---
# sc:   sema context
# st:   the strip payload
# span: the cast span for diagnostics
# ret:  the stripped (public) TypeId, or TYPE_ERROR
fun infer_strip(sc: *context.SemaContext, st: *expr.ExprStrip, span: token.Span) type.TypeId {
    val vt: type.TypeId = infer_expr(sc, st.value);
    if (vt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val stripped: type.TypeId = type.strip_secret(?sc.s.types, vt);

    if (st.ty == id.TYPE_NIL) { ret stripped; }

    val tt: type.TypeId = context.resolved_type_of(sc, st.ty);
    if (tt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    if (type.is_secret(?sc.s.types, tt)) {
        context.report(sc, span, "secret strip: a `:^` target type must be public; `:^` only removes the `^` qualifier");
        ret type.TYPE_ERROR;
    }
    # `:^` removes secrecy only; it never reinterprets storage, so an explicit
    # target must name the operand's own stripped type.
    if (tt != stripped) {
        context.report(sc, span, "secret strip: a `:^Type` target must name the operand's stripped (public) type; `:^` does not convert the value");
        ret type.TYPE_ERROR;
    }
    ret tt;
}

# ARRAY_LIT: result is [count]elem of the declared array type
#
# Every element is checked against the element type via check.check_coercible,
# and the element count must match the declared length exactly (`[N]T` holds
# exactly N values -- see doc/language/types.md).
# ---
# sc:   sema context
# al:   the array-literal payload
# span: the literal span for diagnostics
# ret:  the array TypeId
fun infer_array_lit(sc: *context.SemaContext, al: *expr.ExprArrayLit, span: token.Span) type.TypeId {
    val arr_ty: type.TypeId = context.resolved_type_of(sc, al.ty);
    var elem_ty:    type.TypeId = type.TYPE_ERROR;
    var has_count:  bool        = false;
    var decl_count: u32         = 0;
    val at_opt: O.Option[*type.Type] = type.get(?sc.s.types, arr_ty);
    if (O.is_some[*type.Type](at_opt)) {
        val at: *type.Type = O.unwrap[*type.Type](at_opt);
        if (at.kind == type.TYPE_ARRAY) {
            elem_ty    = at.data.array.base;
            decl_count = at.data.array.count;
            has_count  = true;
        }
    }

    var i: u32 = 0;
    for (i < al.elems_len) {
        val ee: id.ExprId = sc.a.expr_ids[al.elems_start + i];
        val et: type.TypeId = infer_expr(sc, ee);
        if (elem_ty != type.TYPE_ERROR && et != type.TYPE_ERROR) {
            check.check_coercible(sc, elem_ty, ee, et, span);
        }
        i = i + 1;
    }

    if (has_count && al.elems_len > decl_count) {
        context.report(sc, span, "array literal: too many elements for declared length");
    }
    or (has_count && al.elems_len < decl_count) {
        context.report(sc, span, "array literal: too few elements for declared length");
    }
    ret arr_ty;
}

# VECTOR_LIT: result is the declared vector type; each element is checked against
# the lane scalar and the element count must equal the lane count exactly (#1965)
#
# Mirrors infer_array_lit: full-arity, positional, one value per lane. Splat
# (`f32x4{1.0}` broadcast) is deferred (#2019).
# ---
# sc:   sema context
# vl:   the vector-literal payload
# span: the literal span for diagnostics
# ret:  the vector TypeId
fun infer_vector_lit(sc: *context.SemaContext, vl: *expr.ExprVectorLit, span: token.Span) type.TypeId {
    val vec_ty: type.TypeId = context.resolved_type_of(sc, vl.ty);
    val is_vec: bool        = type.is_vector(?sc.s.types, vec_ty);

    var lane_ty: type.TypeId = type.TYPE_ERROR;
    var lanes:   u32         = 0;
    if (is_vec) {
        lanes   = type.vector_lanes(?sc.s.types, vec_ty);
        lane_ty = prim_or_error(sc, type.vector_element(?sc.s.types, vec_ty));
    }

    var i: u32 = 0;
    for (i < vl.elems_len) {
        val ee: id.ExprId   = sc.a.expr_ids[vl.elems_start + i];
        val et: type.TypeId = infer_expr(sc, ee);
        if (is_vec && lane_ty != type.TYPE_ERROR && et != type.TYPE_ERROR) {
            check.check_coercible(sc, lane_ty, ee, et, span);
        }
        i = i + 1;
    }

    # a positional-brace body `T{a, b, ...}` is only a vector literal; a non-vector
    # prefix (`Point{1, 2}`, `i32{5}`) is a specific error, never a silent accept.
    # a record is constructed with named fields and an array with a `[N]T` prefix.
    if (!is_vec) {
        if (vec_ty != type.TYPE_ERROR) {
            check.report_typed(sc, span, "positional-brace literal requires a vector type; `", vec_ty, "` is not a vector (a record uses named fields, an array a `[N]T` prefix)", "positional-brace literal requires a vector type");
        }
        ret type.TYPE_ERROR;
    }

    if (vl.elems_len > lanes) {
        context.report(sc, span, "vector literal: too many elements for the lane count");
    }
    or (vl.elems_len < lanes) {
        context.report(sc, span, "vector literal: too few elements for the lane count");
    }
    ret vec_ty;
}

# STRUCT_LIT: result is the named record type; each field initializer is checked
# against the record's field of the same name
#
# Field validation is skipped when no field table exists for the type (an
# imported record whose fields were tabled in its own module's pass, or an
# upstream type error) -- the initializers are still inferred so their expr_type
# slots fill.
# ---
# sc:   sema context
# sl:   the struct-literal payload
# span: the literal span for diagnostics
# ret:  the record TypeId
fun infer_struct_lit(sc: *context.SemaContext, sl: *expr.ExprStructLit, span: token.Span) type.TypeId {
    val rec_ty: type.TypeId = context.resolved_type_of(sc, sl.ty);
    generics.ensure_fields(sc.s, rec_ty);
    val have_table: bool = O.is_some[*context.FieldTable](context.field_table_for(sc, rec_ty));

    var i: u32 = 0;
    for (i < sl.fields_len) {
        val fi: *expr.FieldInit = ?sc.a.field_inits[sl.fields_start + i];
        val vt: type.TypeId = infer_expr(sc, fi.value);
        if (rec_ty != type.TYPE_ERROR && vt != type.TYPE_ERROR && have_table) {
            val fname: intern.StrId = intern_span_or_nil(sc, fi.name);
            val ft_opt: O.Option[type.TypeId] = context.field_lookup(sc, rec_ty, fname);
            if (O.is_none[type.TypeId](ft_opt)) {
                check.report_no_field(sc, fi.name, fname, rec_ty);
            }
            or {
                val ft: type.TypeId = O.unwrap[type.TypeId](ft_opt);
                check.check_coercible(sc, ft, fi.value, vt, span);
            }
        }
        i = i + 1;
    }
    ret rec_ty;
}

# translate a syntactic AstType into an interned semantic TypeId
#
# Walks the TypeKind variants and dispatches to the matching type.intern_*.
# Writes the result into type_resolved_ty[tid].
# ---
# sc:  sema context
# tid: syntactic AstType id to resolve
# ret: the interned semantic TypeId (TYPE_ERROR on failure)
pub fun resolve_type_ref(sc: *context.SemaContext, tid: id.TypeId) type.TypeId {
    val t_opt: O.Option[*atype.Type] = ast.get_type(sc.a, tid);
    if (O.is_none[*atype.Type](t_opt)) { ret type.TYPE_ERROR; }
    val t: *atype.Type = O.unwrap[*atype.Type](t_opt);

    if (t.kind == atype.TYPE_KIND_NAMED)  { ret resolve_type_named(sc, tid, ?t.data.named, t.span); }
    if (t.kind == atype.TYPE_KIND_PTR)    { ret resolve_type_ptr(sc, ?t.data.ptr); }
    if (t.kind == atype.TYPE_KIND_SECRET) { ret resolve_type_secret(sc, ?t.data.secret); }
    if (t.kind == atype.TYPE_KIND_ARRAY)  { ret resolve_type_array(sc, ?t.data.array, t.span); }
    if (t.kind == atype.TYPE_KIND_FUN)   { ret resolve_type_fun(sc, ?t.data.fun_); }
    if (t.kind == atype.TYPE_KIND_REC)   { ret resolve_type_anon(sc, tid, t.data.rec_.fields_start, t.data.rec_.fields_len, type.TYPE_REC); }
    if (t.kind == atype.TYPE_KIND_UNI)   { ret resolve_type_anon(sc, tid, t.data.uni_.fields_start, t.data.uni_.fields_len, type.TYPE_UNI); }
    # a `...` comptime variadic pack: the singleton pack type.
    if (t.kind == atype.TYPE_KIND_PACK) {
        val r: R.Result[type.TypeId, str] = type.intern_pack(?sc.s.types);
        if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret R.unwrap_ok[type.TypeId, str](r);
    }
    ret type.TYPE_ERROR;
}

# NAMED: resolve the symbol the name refers to and map it to the type it names
#
# The symbol is recorded by resolve in type_resolved; it maps to the nominal /
# primitive / transparent type it names, and -- when generic args are present --
# instantiates.
# ---
# sc:    sema context
# tid:   syntactic AstType id of the name
# named: the named-type payload
# span:  the name span for diagnostics
# ret:   the resolved TypeId, or TYPE_ERROR
fun resolve_type_named(sc: *context.SemaContext, tid: id.TypeId, named: *atype.TypeNamed, span: token.Span) type.TypeId {
    val sym_opt: O.Option[*resolve.Symbol] = context.symbol_for_type(sc, tid);
    if (O.is_none[*resolve.Symbol](sym_opt)) {
        # resolve already reported the unresolved name; absorb silently
        ret type.TYPE_ERROR;
    }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](sym_opt);

    if (named.args_len > 0) {
        ret instantiate_named(sc, sym, named, span);
    }

    ret type_for_symbol(sc, sym, span);
}

# map a resolved type-name symbol to the semantic type it names
#
# Generic params become TYPE_GENERIC_PARAM, `def`s are transparent (their
# underlying type), records / unions become nominals. A cross-module reference
# resolves to SYM_IMPORTED (the originating rec/uni/def kind is not carried on
# the import symbol), so its type is read from the dependency's recorded
# decl_type, which already holds the nominal TypeId or the def's underlying.
# ---
# sc:   sema context
# sym:  the resolved type-name symbol
# span: the name span for diagnostics
# ret:  the named TypeId, or TYPE_ERROR
fun type_for_symbol(sc: *context.SemaContext, sym: *resolve.Symbol, span: token.Span) type.TypeId {
    if (sym.kind == resolve.SYM_PRIM) {
        ret prim_or_error(sc, sym.slot::type.TypeKind);
    }
    # a vector symbol carries the pre-interned semantic vector TypeId in `slot`.
    if (sym.kind == resolve.SYM_VECTOR) {
        ret sym.slot::type.TypeId;
    }
    if (sym.kind == resolve.SYM_GENERIC) {
        val r: R.Result[type.TypeId, str] = type.intern_generic_param(?sc.s.types, sym.name, sym.decl, sym.slot);
        if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret R.unwrap_ok[type.TypeId, str](r);
    }
    if (sym.kind == resolve.SYM_REC || sym.kind == resolve.SYM_UNI) {
        var kind: type.TypeKind = type.TYPE_REC;
        if (sym.kind == resolve.SYM_UNI) { kind = type.TYPE_UNI; }
        val r: R.Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, sym.name, sym.origin, sym.decl, kind);
        if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret R.unwrap_ok[type.TypeId, str](r);
    }
    if (sym.kind == resolve.SYM_DEF) {
        ret def_underlying(sc, sym, span);
    }
    if (sym.kind == resolve.SYM_IMPORTED) {
        val imported: type.TypeId = context.decl_type_for(sc, sym);
        if (imported == type.TYPE_NIL || imported == type.TYPE_ERROR) {
            check.report_named(sc, span, "imported `", sym.name, "` does not resolve to a type", "imported name does not resolve to a type");
            ret type.TYPE_ERROR;
        }
        ret imported;
    }
    check.report_named(sc, span, "`", sym.name, "` does not name a type", "name does not denote a type");
    ret type.TYPE_ERROR;
}

# resolve a `def` alias to its underlying semantic type
#
# Local defs resolve the annotation directly (recomputing rather than reading the
# parallel array, so a forward reference to a later-indexed def still resolves);
# imported defs read from the dep's decl_type snapshot.
# ---
# sc:   sema context
# sym:  the resolved def symbol
# span: the name span for diagnostics
# ret:  the underlying TypeId, or TYPE_ERROR
fun def_underlying(sc: *context.SemaContext, sym: *resolve.Symbol, span: token.Span) type.TypeId {
    if (sym.origin == sc.own_module) {
        val d_opt: O.Option[*decl.Decl] = ast.get_decl(sc.a, sym.decl);
        if (O.is_none[*decl.Decl](d_opt)) { ret type.TYPE_ERROR; }
        val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);
        if (d.kind != decl.DECL_KIND_DEF)  { ret type.TYPE_ERROR; }
        if (d.data.def_.ty == id.TYPE_NIL) { ret type.TYPE_ERROR; }
        ret resolve_type_ref(sc, d.data.def_.ty);
    }
    ret context.decl_type_for(sc, sym);
}

# instantiate a generic type name `Name[args...]`
#
# Resolves each arg type and delegates to generics.instantiate.
# ---
# sc:    sema context
# sym:   the resolved generic type symbol
# named: the named-type payload carrying the args
# span:  the name span for diagnostics
# ret:   the instance TypeId, or TYPE_ERROR
fun instantiate_named(sc: *context.SemaContext, sym: *resolve.Symbol, named: *atype.TypeNamed, span: token.Span) type.TypeId {
    val pr: R.Result[*type.TypeId, str] = allocate_params(sc, named.args_len);
    if (R.is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val args: *type.TypeId = R.unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    for (i < named.args_len) {
        val arg_tid: id.TypeId = sc.a.type_ids[named.args_start + i];
        args[i] = resolve_type_ref(sc, arg_tid);
        i = i + 1;
    }

    val r: R.Result[type.TypeId, str] = generics.instantiate(sc, sym.decl, sym.origin, args, named.args_len, span);
    free_params(sc, args, named.args_len);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# PTR: recurse on the pointee and intern a pointer
# ---
# sc:  sema context
# p:   the pointer-type payload
# ret: the `*pointee` TypeId, or TYPE_ERROR
fun resolve_type_ptr(sc: *context.SemaContext, p: *atype.TypePtr) type.TypeId {
    val base: type.TypeId = resolve_type_ref(sc, p.pointee);
    ret ptr_to(sc, base);
}

# SECRET: recurse on the inner type and intern a `^inner` qualifier (#1645)
#
# A poisoned inner poisons the qualifier. `^^T` collapses in intern_secret, so
# the secrecy lattice stays two-point.
# ---
# sc:  sema context
# s:   the secret-type payload
# ret: the `^inner` TypeId, or TYPE_ERROR
fun resolve_type_secret(sc: *context.SemaContext, s: *atype.TypeSecret) type.TypeId {
    val inner: type.TypeId = resolve_type_ref(sc, s.inner);
    if (inner == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    val r: R.Result[type.TypeId, str] = type.intern_secret(?sc.s.types, inner);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# ARRAY: resolve the element type, evaluate the length via the comptime
# evaluator demanding CT_KIND_INT, and intern a fixed-size array
# ---
# sc:   sema context
# ar:   the array-type payload
# span: the array-type span for diagnostics
# ret:  the `[len]elem` TypeId, or TYPE_ERROR
fun resolve_type_array(sc: *context.SemaContext, ar: *atype.TypeArray, span: token.Span) type.TypeId {
    val elem: type.TypeId = resolve_type_ref(sc, ar.element);
    if (elem == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val len_r: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, ar.length, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](len_r)) {
        context.report(sc, span, "cannot infer type: array length is not a comptime constant");
        ret type.TYPE_ERROR;
    }
    val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](len_r);
    if (cv.kind != comptime.CT_KIND_INT) {
        context.report(sc, span, "type mismatch: array length must be an integer");
        ret type.TYPE_ERROR;
    }
    if (comptime.ct_is_negative(cv)) {
        context.report(sc, span, "type mismatch: array length must be non-negative");
        ret type.TYPE_ERROR;
    }
    # the count is the value's non-negative magnitude (a u64-range length is a
    # huge positive, not a negative, under the comptime signedness model). it is
    # interned as a u32, so anything past u32 max would wrap silently -- reject it
    # rather than truncating to a wrong element count.
    val len_u: u64 = cv.data.i:~u64;
    if (len_u > 4294967295) {
        context.report(sc, span, "type mismatch: array length exceeds the maximum of 4294967295 elements");
        ret type.TYPE_ERROR;
    }

    val r: R.Result[type.TypeId, str] = type.intern_array(?sc.s.types, elem, len_u::u32);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# FUN: resolve each parameter and the return type, intern a TYPE_FUN
# ---
# sc:  sema context
# fn:  the function-type payload
# ret: the TYPE_FUN TypeId, or TYPE_ERROR
fun resolve_type_fun(sc: *context.SemaContext, fn: *atype.TypeFun) type.TypeId {
    var ret_type: type.TypeId = type.TYPE_NIL;
    if (fn.ret_type != id.TYPE_NIL) { ret_type = resolve_type_ref(sc, fn.ret_type); }

    if (fn.params_len == 0) {
        val r: R.Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_type, nil, 0);
        if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret R.unwrap_ok[type.TypeId, str](r);
    }

    val pr: R.Result[*type.TypeId, str] = allocate_params(sc, fn.params_len);
    if (R.is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val params: *type.TypeId = R.unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    for (i < fn.params_len) {
        val pt: id.TypeId = sc.a.type_ids[fn.params_start + i];
        params[i] = resolve_type_ref(sc, pt);
        i = i + 1;
    }

    val r: R.Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_type, params, fn.params_len);
    free_params(sc, params, fn.params_len);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# REC / UNI (anonymous): intern a structurally-keyed nominal so two inline
# records (or unions) with the same field names and field types resolve to a
# single TypeId
#
# The identity key is a canonical signature of the shape, interned to a StrId and
# carried in the nominal `decl` slot under the reserved `MODULE_NIL` origin; the
# StrId interner guarantees the key is exact (equal shapes -> equal StrId,
# distinct shapes -> distinct StrId), so the match is collision-free. Builds the
# field table on first occurrence.
# ---
# sc:           sema context
# tid:          syntactic AstType id of the anonymous shape
# fields_start: start index into ast.typed_names
# fields_len:   number of fields
# kind:         TYPE_REC or TYPE_UNI
# ret:          the structurally-keyed nominal TypeId, or TYPE_ERROR
fun resolve_type_anon(sc: *context.SemaContext, tid: id.TypeId, fields_start: u32, fields_len: u32, kind: type.TypeKind) type.TypeId {
    val name_id: intern.StrId = synth_anon_name(sc, kind);

    val key: intern.StrId = anon_struct_key(sc, fields_start, fields_len, kind);
    if (key == intern.STR_NIL) { ret type.TYPE_ERROR; }

    val r: R.Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, name_id, session.MODULE_NIL, key::id.DeclId, kind);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    val ty: type.TypeId = R.unwrap_ok[type.TypeId, str](r);

    build_field_table(sc, ty, fields_start, fields_len);
    ret ty;
}

# build a canonical structural-identity key for an anonymous rec/uni
#
# A hex signature of the kind, the field count, and each field's interned name
# and resolved type, interned to a StrId. Equal shapes intern to the same StrId,
# distinct shapes to distinct StrIds. The buffer is sized to the exact shape --
# one 8-hex-digit chunk for the kind and count, two per field -- so the key never
# truncates and the collision-free guarantee actually holds at any field count.
# STR_NIL signals an allocation failure.
# ---
# sc:           sema context
# fields_start: start index into ast.typed_names
# fields_len:   number of fields
# kind:         TYPE_REC or TYPE_UNI
# ret:          the interned shape key, or STR_NIL on allocation failure
fun anon_struct_key(sc: *context.SemaContext, fields_start: u32, fields_len: u32, kind: type.TypeKind) intern.StrId {
    val cap: usize = (2 + fields_len::usize * 2) * 8;
    val br: R.Result[*u8, str] = A.allocate[u8](sc.s.alloc, cap);
    if (R.is_err[*u8, str](br)) { ret intern.STR_NIL; }
    val buf: *u8 = R.unwrap_ok[*u8, str](br);

    var len: usize = 0;
    len = put_hex_u32(buf, len, cap, kind::u32);
    len = put_hex_u32(buf, len, cap, fields_len);

    var i: u32 = 0;
    for (i < fields_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[fields_start + i];
        val fname: intern.StrId = intern_span_or_nil(sc, tn.name);
        val fty: type.TypeId = context.resolved_type_of(sc, tn.ty);
        len = put_hex_u32(buf, len, cap, fname::u32);
        len = put_hex_u32(buf, len, cap, fty::u32);
        i = i + 1;
    }

    val r: R.Result[intern.StrId, str] = intern.intern_bytes(?sc.s.interner, buf::str, len);
    A.deallocate[u8](sc.s.alloc, buf, cap);
    if (R.is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](r);
}

# append the 8 lowercase hex digits of `v` to `buf` at offset `off`, never
# writing past `cap`
#
# Hex avoids NUL bytes so the buffer is safe to intern as a string key.
# ---
# buf: the output byte buffer
# off: the byte offset to write at
# cap: the buffer capacity (writes stop here)
# v:   the value to encode
# ret: the new offset after the written digits
fun put_hex_u32(buf: *u8, off: usize, cap: usize, v: u32) usize {
    var pos: usize = off;
    var i: u32 = 0;
    for (i < 8) {
        if (pos >= cap) { ret pos; }
        val shift: u32 = (7 - i) * 4;
        val nib: u32 = (v >> shift) & 0xF;
        var c: u8 = nib::u8 + 0x30;
        if (nib > 9) { c = nib::u8 - 10 + 0x61; }
        buf[pos] = c;
        pos = pos + 1;
        i = i + 1;
    }
    ret pos;
}

# intern a synthetic display name for an anonymous rec/uni nominal
#
# Identity is carried by the (origin, decl=tid) pair, not the name, so a single
# fixed label per kind is sufficient.
# ---
# sc:   sema context
# kind: TYPE_REC or TYPE_UNI
# ret:  the interned display-name StrId, or STR_NIL on allocation failure
fun synth_anon_name(sc: *context.SemaContext, kind: type.TypeKind) intern.StrId {
    var label: str = "__anon_rec";
    if (kind == type.TYPE_UNI) { label = "__anon_uni"; }
    ret interned(sc, label);
}

# intern the pointer type *base
#
# A poisoned base poisons the pointer.
# ---
# sc:   sema context
# base: the pointee TypeId
# ret:  the `*base` TypeId, or TYPE_ERROR
fun ptr_to(sc: *context.SemaContext, base: type.TypeId) type.TypeId {
    if (base == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    val r: R.Result[type.TypeId, str] = type.intern_pointer(?sc.s.types, base);
    if (R.is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](r);
}

# the pointee type of a pointer
#
# Non-pointer operands report a diagnostic and yield TYPE_ERROR. A secret pointer
# `^*T` is peeled to its pointer first, so dereferencing recovers the pointee
# `T`; the canonical welded form `*^T` is already a (public) pointer whose
# pointee is the secret `^T`.
# ---
# sc:   sema context
# ty:   the operand TypeId
# span: the operand span for diagnostics
# ret:  the pointee TypeId, or TYPE_ERROR
fun pointee_of(sc: *context.SemaContext, ty: type.TypeId, span: token.Span) type.TypeId {
    val base: type.TypeId = type.strip_secret(?sc.s.types, ty);
    val t_opt: O.Option[*type.Type] = type.get(?sc.s.types, base);
    if (O.is_none[*type.Type](t_opt)) { ret type.TYPE_ERROR; }
    val t: *type.Type = O.unwrap[*type.Type](t_opt);
    if (t.kind != type.TYPE_POINTER) {
        context.report(sc, span, "type mismatch: dereference of non-pointer type");
        ret type.TYPE_ERROR;
    }
    ret t.data.pointer.base;
}

# fetch a primitive TypeId by kind
#
# Returns TYPE_ERROR when the kind is not a primitive (a compiler-internal
# misuse).
# ---
# sc:   sema context
# kind: a primitive TypeKind
# ret:  the primitive's TypeId, or TYPE_ERROR
fun prim_or_error(sc: *context.SemaContext, kind: type.TypeKind) type.TypeId {
    val p: O.Option[type.TypeId] = type.prim(?sc.s.types, kind);
    if (O.is_none[type.TypeId](p)) { ret type.TYPE_ERROR; }
    ret O.unwrap[type.TypeId](p);
}

# whether `ty` is one of the numeric primitives (u8..f64)
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for any integer or float primitive
fun is_numeric(sc: *context.SemaContext, ty: type.TypeId) bool {
    ret type.is_numeric(?sc.s.types, ty);
}

# whether `ty` is one of the integer primitives (u8..i64)
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for any integer primitive
fun is_integer(sc: *context.SemaContext, ty: type.TypeId) bool {
    ret type.is_integer(?sc.s.types, ty);
}

# whether `ty` is one of the float primitives (f32 / f64)
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for f32 or f64
fun is_float(sc: *context.SemaContext, ty: type.TypeId) bool {
    ret type.is_float(?sc.s.types, ty);
}

# whether `ty` is address-shaped -- a raw `ptr`, a typed `*T`, or a function
# (`TYPE_FUN`, a code address)
#
# Used by equality to relate `nil` against pointer and function operands.
# ---
# sc:  sema context
# ty:  the TypeId to classify
# ret: true for TYPE_PTR / TYPE_POINTER / TYPE_FUN
fun is_pointer_like(sc: *context.SemaContext, ty: type.TypeId) bool {
    ret type.is_pointer_like(?sc.s.types, ty);
}

# the AST that owns `sym`'s declaration: this module's AST when the symbol is
# local, otherwise the origin module's AST from the session
# ---
# sc:  sema context
# sym: the symbol whose declaring AST is wanted
# ret: the owning Ast, or nil when the origin module has no loaded AST
fun symbol_ast(sc: *context.SemaContext, sym: *resolve.Symbol) *ast.Ast {
    if (sym.origin == sc.own_module) { ret sc.a; }
    ret session.module_ast(sc.s, sym.origin);
}

# make a binary operation's two operands share a type when one side is a
# coercible literal
#
# Returns the unified type, or none when no coercion applies (operands either
# already agree or genuinely differ).
# ---
# sc:  sema context
# lhs: the left operand expression
# lt:  the left operand type
# rhs: the right operand expression
# rt:  the right operand type
# ret: some(unified type), or none
fun unify_literals(sc: *context.SemaContext, lhs: id.ExprId, lt: type.TypeId, rhs: id.ExprId, rt: type.TypeId) O.Option[type.TypeId] {
    if (lt == rt) { ret O.none[type.TypeId](); }
    # a try-fallback site: only a genuine coercion unifies the operands. an
    # out-of-range literal declines here exactly like a non-literal (the hard-
    # failure sites report the overflow when it matters), preserving the
    # non-reporting try semantics. try the RHS literal toward the LHS type, then
    # vice-versa.
    val cr: coerce.CoerceResult = coerce.try_coerce_literal(sc, rhs, lt);
    if (cr.kind == coerce.COERCE_COERCED) { ret O.some[type.TypeId](lt); }
    val cl: coerce.CoerceResult = coerce.try_coerce_literal(sc, lhs, rt);
    if (cl.kind == coerce.COERCE_COERCED) { ret O.some[type.TypeId](rt); }
    ret O.none[type.TypeId]();
}

# emit a `type mismatch:` diagnostic for a binary operand-type clash, naming both
# operand types via type_to_str
# ---
# sc:   sema context
# span: the operator span
# lt:   the left operand type
# rt:   the right operand type
fun type_mismatch(sc: *context.SemaContext, span: token.Span, lt: type.TypeId, rt: type.TypeId) {
    check.report_typed2(sc, span, "type mismatch: incompatible operand types `", lt, "` and `", rt, "`", "type mismatch: incompatible operand types");
}

# report an integer-versus-float comparison
#
# Rejected because a silent widening would hide f64 rounding above 2^53; the
# operand must be cast first.
# ---
# sc:   sema context
# span: the operator span
fun report_int_float_cmp(sc: *context.SemaContext, span: token.Span) {
    context.report(sc, span, "type mismatch: cannot compare an integer and a float; cast one operand explicitly (`::`)");
}

# intern the identifier text covered by `span`, or STR_NIL for an empty span
# ---
# sc:   sema context
# span: the span to intern
# ret:  the interned StrId, or STR_NIL
fun intern_span_or_nil(sc: *context.SemaContext, span: token.Span) intern.StrId {
    if (span.len == 0) { ret intern.STR_NIL; }
    val r: R.Result[intern.StrId, str] = intern.intern_span(?sc.s.interner, sc.source, span);
    if (R.is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](r);
}

# allocate a scratch TypeId array of `count` slots for assembling a parameter /
# argument list before interning
# ---
# sc:    sema context
# count: number of TypeId slots to allocate
# ret:   the scratch array, or an allocation error
fun allocate_params(sc: *context.SemaContext, count: u32) R.Result[*type.TypeId, str] {
    ret A.allocate[type.TypeId](sc.s.alloc, count::usize);
}

# release a scratch TypeId array allocated by allocate_params
# ---
# sc:     sema context
# params: the scratch array to free
# count:  the slot count passed to allocate_params
fun free_params(sc: *context.SemaContext, params: *type.TypeId, count: u32) {
    A.deallocate[type.TypeId](sc.s.alloc, params, count::usize);
}
