# mach.lang.fe.sema.infer: bottom-up type inference.
#
# computes the semantic `type.TypeId` of every expression and the interned
# `type.TypeId` each syntactic AstType refers to. drives the rest of sema by
# calling `check` at composing sites and `coerce` where the language allows
# literal narrowing.
#
# the public entry points, called by `sema`'s pass loop, are
# resolve_type_ref (syntactic AstType to interned semantic TypeId),
# infer_decl (a decl's declared or inferred type), and infer_expr (an
# expression's type, bottom-up, writing expr_type). all three tolerate
# holes: an unresolved name or a failed sub-inference yields TYPE_ERROR,
# which absorbs further operations without cascading diagnostics.
#
# `str` is the stdlib alias `def str: *u8`; it resolves transparently to a
# pointer and has no special field table. anonymous inline rec/uni types are
# structurally typed: two inline shapes with the same field names and field
# types intern to the same nominal, so a value of one is interchangeable with
# the other (a `def`-named record stays nominal — identity by declaration).

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;

use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.is_none;
use std.types.option.unwrap;

use std.types.size.usize;

use std.types.string.str;

use std.types.result.Result;
use std.types.result.ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;

use std.allocator.allocate;
use std.allocator.deallocate;

use intern:   mach.lang.intern;
use type:     mach.lang.type;
use sess:     mach.lang.module;
use session:  mach.lang.session;

use ast:      mach.lang.fe.ast;
use id:       mach.lang.fe.ast.id;
use decl:     mach.lang.fe.ast.decl;
use expr:     mach.lang.fe.ast.expr;
use atype:    mach.lang.fe.ast.type;
use token:    mach.lang.fe.token;
use comptime: mach.lang.fe.comptime;
use resolve:  mach.lang.fe.resolve;
use sema:     mach.lang.fe.sema.context;
use check:    mach.lang.fe.sema.check;
use coerce:   mach.lang.fe.sema.coerce;
use generics: mach.lang.fe.sema.generics;

# seeds field tables for built-in nominal types. the only built-in string
# type in this codebase is the stdlib `def str: *u8`, which resolves
# transparently to a pointer and has no fields, so there is nothing to seed;
# the function exists so `sema` can call it unconditionally and so future
# built-ins have a home.
# ---
# sc:  sema context
# ret: true on success, or an allocation error
pub fun seed_builtins(sc: *sema.SemaContext) Result[bool, str] {
    ret ok[bool, str](true);
}

# computes the declared type of one decl, dispatching per DeclKind. binding
# decls (val/var) use their annotation when present, else infer from the
# initializer; functions intern a TYPE_FUN; records / unions intern a
# nominal and build a field table; `def` is transparent (returns the
# underlying type). non-typed decls (use, test, comptime) return TYPE_NIL.
# ---
# sc:  sema context
# did: decl to compute the type of
# ret: the declared TypeId, or TYPE_NIL / TYPE_ERROR
pub fun infer_decl(sc: *sema.SemaContext, did: id.DeclId) type.TypeId {
    val d_opt: Option[*decl.Decl] = ast.get_decl(sc.a, did);
    if (is_none[*decl.Decl](d_opt)) { ret type.TYPE_ERROR; }
    val d: *decl.Decl = unwrap[*decl.Decl](d_opt);

    if (d.kind == decl.DECL_KIND_FUN) { ret infer_fun_sig(sc, ?d.data.fun_); }
    if (d.kind == decl.DECL_KIND_REC) { ret infer_nominal(sc, did, d.data.rec_.name, ?d.data.rec_, type.TYPE_REC); }
    if (d.kind == decl.DECL_KIND_UNI) { ret infer_nominal_uni(sc, did, d.data.uni_.name, ?d.data.uni_, type.TYPE_UNI); }
    if (d.kind == decl.DECL_KIND_DEF) { ret sema.resolved_type_of(sc, d.data.def_.ty); }
    if (d.kind == decl.DECL_KIND_VAL || d.kind == decl.DECL_KIND_VAR) {
        ret infer_binding(sc, ?d.data.bind);
    }
    # use, fwd, test, comptime_if, comptime_attr, error: no carried type
    ret type.TYPE_NIL;
}

# interns the TYPE_FUN signature of a function declaration from its resolved
# parameter and return types. comptime value parameters (`$name: T`) are EXCLUDED
# from the interned signature: they are folded per call site and stripped from
# both the runtime ABI and the lowered IR, so the semantic TYPE_FUN carries only
# the runtime parameters. call arity is checked against the AST parameter list
# (which includes the comptime ones) in `check_call`.
fun infer_fun_sig(sc: *sema.SemaContext, f: *decl.DeclFun) type.TypeId {
    val ret_ty: type.TypeId = sema.resolved_type_of(sc, f.return_type);

    var runtime_count: u32 = 0;
    var ci: u32 = 0;
    for (ci < f.params_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[f.params_start + ci];
        if (!tn.comptime) { runtime_count = runtime_count + 1; }
        ci = ci + 1;
    }

    if (runtime_count == 0) {
        val r: Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_ty, nil, 0, f.variadic);
        if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret unwrap_ok[type.TypeId, str](r);
    }

    val pr: Result[*type.TypeId, str] = allocate_params(sc, runtime_count);
    if (is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val params: *type.TypeId = unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    var w: u32 = 0;
    for (i < f.params_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[f.params_start + i];
        if (!tn.comptime) {
            params[w] = sema.resolved_type_of(sc, tn.ty);
            w = w + 1;
        }
        i = i + 1;
    }

    val r: Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_ty, params, runtime_count, f.variadic);
    free_params(sc, params, runtime_count);
    if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret unwrap_ok[type.TypeId, str](r);
}

# interns the nominal TYPE_REC for a record declaration and builds its field
# table (name -> resolved field type) on the context.
fun infer_nominal(sc: *sema.SemaContext, did: id.DeclId, name_span: token.Span, r: *decl.DeclRec, kind: type.TypeKind) type.TypeId {
    val name_id: intern.StrId = intern_span_or_nil(sc, name_span);
    val tr: Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, name_id, sc.own_module, did, kind);
    if (is_err[type.TypeId, str](tr)) { ret type.TYPE_ERROR; }
    val ty: type.TypeId = unwrap_ok[type.TypeId, str](tr);

    build_field_table(sc, ty, r.fields_start, r.fields_len);
    ret ty;
}

# union variant of infer_nominal (DeclUni has the same field layout).
fun infer_nominal_uni(sc: *sema.SemaContext, did: id.DeclId, name_span: token.Span, u: *decl.DeclUni, kind: type.TypeKind) type.TypeId {
    val name_id: intern.StrId = intern_span_or_nil(sc, name_span);
    val tr: Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, name_id, sc.own_module, did, kind);
    if (is_err[type.TypeId, str](tr)) { ret type.TYPE_ERROR; }
    val ty: type.TypeId = unwrap_ok[type.TypeId, str](tr);

    build_field_table(sc, ty, u.fields_start, u.fields_len);
    ret ty;
}

# populates a field table for nominal `ty` from a typed_names slice, mapping
# each field's interned name to its resolved semantic type. a table already
# built (the nominal interned before) is left untouched.
fun build_field_table(sc: *sema.SemaContext, ty: type.TypeId, fields_start: u32, fields_len: u32) {
    val existing: Option[*sema.FieldTable] = sema.field_table_for(sc, ty);
    if (is_some[*sema.FieldTable](existing)) { ret; }

    val tbl_r: Result[u32, str] = sema.field_table_begin(sc, ty);
    if (is_err[u32, str](tbl_r)) { ret; }
    val tbl: u32 = unwrap_ok[u32, str](tbl_r);

    var i: u32 = 0;
    for (i < fields_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[fields_start + i];
        val fname: intern.StrId = intern_span_or_nil(sc, tn.name);
        val fty: type.TypeId = sema.resolved_type_of(sc, tn.ty);
        sema.field_table_push(sc, tbl, fname, fty);
        i = i + 1;
    }
}

# computes a binding's declared type: the annotation if written, otherwise
# the inferred type of the initializer. an absent annotation with no
# initializer cannot be typed and yields TYPE_ERROR.
fun infer_binding(sc: *sema.SemaContext, b: *decl.DeclBind) type.TypeId {
    if (b.ty != id.TYPE_NIL) {
        ret sema.resolved_type_of(sc, b.ty);
    }
    if (b.init != id.EXPR_NIL) {
        ret infer_expr(sc, b.init);
    }
    ret type.TYPE_ERROR;
}

# computes the type of one expression, recursively inferring subexpressions,
# dispatching per ExprKind, writing the result into expr_type[eid], and
# returning it.
# ---
# sc:  sema context
# eid: expression to type
# ret: the inferred TypeId (TYPE_ERROR on failure)
pub fun infer_expr(sc: *sema.SemaContext, eid: id.ExprId) type.TypeId {
    if (eid == id.EXPR_NIL) { ret type.TYPE_ERROR; }
    val e_opt: Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (is_none[*expr.Expr](e_opt)) { ret type.TYPE_ERROR; }
    val e: *expr.Expr = unwrap[*expr.Expr](e_opt);

    var t: type.TypeId = type.TYPE_ERROR;

    if (e.kind == expr.EXPR_KIND_LIT_INT) {
        t = prim_or_error(sc, type.TYPE_I64);
    }
    or (e.kind == expr.EXPR_KIND_LIT_FLOAT) {
        t = prim_or_error(sc, type.TYPE_F64);
    }
    or (e.kind == expr.EXPR_KIND_LIT_CHAR) {
        t = prim_or_error(sc, type.TYPE_U8);
    }
    or (e.kind == expr.EXPR_KIND_LIT_STR) {
        t = ptr_to(sc, prim_or_error(sc, type.TYPE_U8));
    }
    or (e.kind == expr.EXPR_KIND_LIT_NIL) {
        t = ptr_to(sc, prim_or_error(sc, type.TYPE_U8));
    }
    or (e.kind == expr.EXPR_KIND_IDENT) {
        t = infer_ident(sc, eid);
    }
    or (e.kind == expr.EXPR_KIND_COMPTIME_IDENT) {
        t = infer_comptime_int_path(sc, eid);
        if (t == type.TYPE_NIL) {
            sema.report(sc, e.span, "cannot infer type: comptime identifier in value context");
            t = type.TYPE_ERROR;
        }
    }
    or (e.kind == expr.EXPR_KIND_BINARY) {
        t = infer_binary(sc, eid, ?e.data.binary, e.span);
    }
    or (e.kind == expr.EXPR_KIND_UNARY) {
        t = infer_unary(sc, ?e.data.unary, e.span);
    }
    or (e.kind == expr.EXPR_KIND_CALL) {
        t = infer_call(sc, ?e.data.call, e.span);
    }
    or (e.kind == expr.EXPR_KIND_INDEX) {
        t = infer_index(sc, ?e.data.index, e.span);
    }
    or (e.kind == expr.EXPR_KIND_MEMBER) {
        t = infer_member(sc, eid, ?e.data.member, e.span);
    }
    or (e.kind == expr.EXPR_KIND_CAST) {
        t = infer_cast(sc, ?e.data.cast, e.span);
    }
    or (e.kind == expr.EXPR_KIND_ARRAY_LIT) {
        t = infer_array_lit(sc, ?e.data.array_lit, e.span);
    }
    or (e.kind == expr.EXPR_KIND_STRUCT_LIT) {
        t = infer_struct_lit(sc, ?e.data.struct_lit, e.span);
    }
    or {
        t = type.TYPE_ERROR;
    }

    if (sc.expr_type != nil && eid < sc.a.expr_len::u32) {
        sc.expr_type[eid] = t;
    }
    ret t;
}

# IDENT: the type of the resolved symbol. an unresolved symbol (SYMBOL_NIL
# upstream) yields TYPE_ERROR without a fresh diagnostic — resolve already
# reported the root cause.
fun infer_ident(sc: *sema.SemaContext, eid: id.ExprId) type.TypeId {
    val sym_opt: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, eid);
    if (is_none[*resolve.Symbol](sym_opt)) { ret type.TYPE_ERROR; }
    val sym: *resolve.Symbol = unwrap[*resolve.Symbol](sym_opt);
    ret sema.decl_type_for(sc, sym);
}

# BINARY: per-operator type rules. arithmetic / bitwise / shift return the
# common operand type; comparisons, equality, and logical ops return u8;
# assignment returns the LHS type after checking assignability.
fun infer_binary(sc: *sema.SemaContext, eid: id.ExprId, b: *expr.ExprBinary, span: token.Span) type.TypeId {
    if (b.op == expr.BIN_ASSIGN) { ret infer_assign(sc, b, span); }

    var lt: type.TypeId = infer_expr(sc, b.lhs);
    var rt: type.TypeId = infer_expr(sc, b.rhs);
    if (lt == type.TYPE_ERROR || rt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    # let a literal operand take the shape of the other side
    val co: Option[type.TypeId] = unify_literals(sc, b.lhs, lt, b.rhs, rt);
    if (is_some[type.TypeId](co)) {
        lt = unwrap[type.TypeId](co);
        rt = lt;
    }

    val u8t: type.TypeId = prim_or_error(sc, type.TYPE_U8);

    # integer operands compare and combine across widths: a Mach scalar
    # integer operation is value-based, not identity-based, so two integer
    # primitives need not share a TypeId (e.g. a `u32`-backed `def` against a
    # `u8`-backed `def`). this width-agnostic integer compatibility is distinct
    # from assignment, which stays identity-only (no implicit widening between
    # variables). non-integer operands still require an exact TypeId match.
    val both_int:  bool = is_integer(sc, lt) && is_integer(sc, rt);
    val operands_ok: bool = lt == rt || both_int;

    if (b.op == expr.BIN_EQ || b.op == expr.BIN_NEQ) {
        # equality also relates two address-shaped operands (pointers and
        # functions, both runtime code/data addresses). this covers `fn == nil`
        # / `fn != nil`, where `nil` types as `*u8`, without permitting nil to
        # be assignable to a function type. cmach performs no operand-type
        # check on comparisons at all.
        val addr_ok: bool = is_pointer_like(sc, lt) && is_pointer_like(sc, rt);
        if (!operands_ok && !addr_ok) { type_mismatch(sc, span); ret type.TYPE_ERROR; }
        ret u8t;
    }
    if (b.op == expr.BIN_LT || b.op == expr.BIN_LEQ || b.op == expr.BIN_GT || b.op == expr.BIN_GEQ) {
        if (!operands_ok || !is_numeric(sc, lt)) { type_mismatch(sc, span); ret type.TYPE_ERROR; }
        ret u8t;
    }
    if (b.op == expr.BIN_AND || b.op == expr.BIN_OR) {
        if (!both_int) {
            sema.report(sc, span, "type mismatch: logical operands must be integer types");
            ret type.TYPE_ERROR;
        }
        ret u8t;
    }
    if (b.op == expr.BIN_BIT_AND || b.op == expr.BIN_BIT_OR || b.op == expr.BIN_BIT_XOR
        || b.op == expr.BIN_SHL || b.op == expr.BIN_SHR) {
        if (!both_int) { type_mismatch(sc, span); ret type.TYPE_ERROR; }
        ret lt;
    }
    # arithmetic: ADD, SUB, MUL, DIV, MOD
    if ((!operands_ok) || !is_numeric(sc, lt)) { type_mismatch(sc, span); ret type.TYPE_ERROR; }
    ret lt;
}

# ASSIGN: RHS must be assignable to LHS; result is the LHS type. a literal
# RHS is coerced toward the LHS type first.
fun infer_assign(sc: *sema.SemaContext, b: *expr.ExprBinary, span: token.Span) type.TypeId {
    val lt: type.TypeId = infer_expr(sc, b.lhs);
    var rt: type.TypeId = infer_expr(sc, b.rhs);
    if (lt == type.TYPE_ERROR || rt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val co: Option[type.TypeId] = coerce.try_coerce_literal(sc, b.rhs, lt);
    if (is_some[type.TypeId](co)) { rt = unwrap[type.TypeId](co); }

    check.check_assignable(sc, lt, rt, span);
    ret lt;
}

# UNARY: per-operator rules. NEG returns the operand type, NOT returns u8,
# BIT_NOT returns the operand type, ADDR returns a pointer to the operand
# type, DEREF returns the pointee of a pointer operand.
fun infer_unary(sc: *sema.SemaContext, u: *expr.ExprUnary, span: token.Span) type.TypeId {
    val ot: type.TypeId = infer_expr(sc, u.operand);
    if (ot == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    if (u.op == expr.UN_NEG) {
        if (!is_numeric(sc, ot)) { sema.report(sc, span, "type mismatch: unary - requires a numeric operand"); ret type.TYPE_ERROR; }
        ret ot;
    }
    if (u.op == expr.UN_NOT) {
        if (!is_integer(sc, ot)) { sema.report(sc, span, "type mismatch: unary ! requires an integer operand"); ret type.TYPE_ERROR; }
        ret prim_or_error(sc, type.TYPE_U8);
    }
    if (u.op == expr.UN_BIT_NOT) {
        if (!is_integer(sc, ot)) { sema.report(sc, span, "type mismatch: unary ~ requires an integer operand"); ret type.TYPE_ERROR; }
        ret ot;
    }
    if (u.op == expr.UN_ADDR) {
        # a comptime value parameter has no runtime storage — it folds to a
        # constant per instance — so its address is meaningless. reject it here
        # with a clear message, rather than fabricating an extern global at lower.
        if (operand_is_comptime_param(sc, u.operand)) {
            sema.report(sc, span, "cannot take the address of a comptime parameter");
            ret type.TYPE_ERROR;
        }
        ret ptr_to(sc, ot);
    }
    if (u.op == expr.UN_DEREF) {
        ret pointee_of(sc, ot, span);
    }
    ret type.TYPE_ERROR;
}

# reports whether `eid` is a direct reference to a comptime value parameter
# (SYM_PARAM with SYM_FLAG_COMPTIME). used to reject taking its address.
fun operand_is_comptime_param(sc: *sema.SemaContext, eid: id.ExprId) bool {
    val e_opt: Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (is_none[*expr.Expr](e_opt)) { ret false; }
    if (unwrap[*expr.Expr](e_opt).kind != expr.EXPR_KIND_IDENT) { ret false; }
    val so: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, eid);
    if (is_none[*resolve.Symbol](so)) { ret false; }
    val sym: *resolve.Symbol = unwrap[*resolve.Symbol](so);
    ret sym.kind == resolve.SYM_PARAM && (sym.flags & resolve.SYM_FLAG_COMPTIME) != 0;
}

# CALL: callee must be TYPE_FUN; check arity and each argument against the
# parameter types; result is the function's return type. a call carrying
# explicit type arguments `callee[T, ...](args)` instantiates the generic
# callee's signature before checking. a call whose callee is a comptime
# intrinsic (`$size_of`, `$align_of`, `$offset_of`) is a value intrinsic
# yielding an unsigned integer, handled before normal callee inference.
fun infer_call(sc: *sema.SemaContext, c: *expr.ExprCall, span: token.Span) type.TypeId {
    val intr: type.TypeId = infer_comptime_intrinsic(sc, c, span);
    if (intr != type.TYPE_NIL) { ret intr; }

    # the variadic intrinsics are typed specially: `va_start`/`va_end` are
    # void `(*va_list)`, `va_arg[T]` yields T from a `*va_list`. handled before
    # normal callee inference, whose bare ident would not resolve.
    val va: Option[type.TypeId] = infer_va_intrinsic(sc, c, span);
    if (is_some[type.TypeId](va)) { ret unwrap[type.TypeId](va); }

    val ct: type.TypeId = infer_expr(sc, c.callee);
    # infer argument types so their expr_type slots are populated
    var ai: u32 = 0;
    for (ai < c.args_len) {
        infer_expr(sc, sc.a.expr_ids[c.args_start + ai]);
        ai = ai + 1;
    }

    if (c.type_args_len > 0) {
        # a callee that is BOTH generic (`[T]`) and comptime-param (`$mode`) would
        # need a combined type+value instance; that is not yet supported. report a
        # clear diagnostic instead of a confusing downstream arity mismatch.
        val gcf: Option[*decl.DeclFun] = callee_fun_decl(sc, c.callee);
        if (is_some[*decl.DeclFun](gcf)) {
            if (decl_has_comptime_param(sc, c.callee, unwrap[*decl.DeclFun](gcf))) {
                sema.report(sc, span, "comptime value parameters on a generic function are not yet supported");
                ret type.TYPE_ERROR;
            }
        }
        ret infer_generic_call(sc, c, ct, span);
    }

    if (ct == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val fn_opt: Option[*type.Type] = type.get(?sc.s.types, ct);
    if (is_none[*type.Type](fn_opt)) { ret type.TYPE_ERROR; }
    val fn: *type.Type = unwrap[*type.Type](fn_opt);
    if (fn.kind != type.TYPE_FUN) {
        sema.report(sc, span, "not callable: target is not a function");
        ret type.TYPE_ERROR;
    }

    val ret_ty: type.TypeId = fn.data.fn.ret_ty;

    # a callee with comptime value parameters is checked against its AST
    # parameter list (the stripped TYPE_FUN omits the comptime ordinals), and
    # each `$`-argument is required to be compile-time foldable.
    val cf: Option[*decl.DeclFun] = callee_fun_decl(sc, c.callee);
    if (is_some[*decl.DeclFun](cf)) {
        val f: *decl.DeclFun = unwrap[*decl.DeclFun](cf);
        if (decl_has_comptime_param(sc, c.callee, f)) {
            check.check_comptime_call(sc, ct, c.callee, f, c.args_start, c.args_len, span);
            ret ret_ty;
        }
    }

    check.check_call(sc, ct, c.args_start, c.args_len, span);
    ret ret_ty;
}

# resolves a call's callee to its DeclFun, reading the origin module's AST for a
# cross-module callee. none when the callee does not name a function.
fun callee_fun_decl(sc: *sema.SemaContext, callee: id.ExprId) Option[*decl.DeclFun] {
    val so: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, callee);
    if (is_none[*resolve.Symbol](so)) { ret none[*decl.DeclFun](); }
    val sym: *resolve.Symbol = unwrap[*resolve.Symbol](so);
    if (sym.kind != resolve.SYM_FUN && sym.kind != resolve.SYM_IMPORTED) { ret none[*decl.DeclFun](); }
    if (sym.decl == id.DECL_NIL) { ret none[*decl.DeclFun](); }

    var a: *ast.Ast = sc.a;
    if (sym.origin != sc.own_module) {
        a = session.module_ast(sc.s, sym.origin);
        if (a == nil) { ret none[*decl.DeclFun](); }
    }
    val d_opt: Option[*decl.Decl] = ast.get_decl(a, sym.decl);
    if (is_none[*decl.Decl](d_opt)) { ret none[*decl.DeclFun](); }
    val d: *decl.Decl = unwrap[*decl.Decl](d_opt);
    if (d.kind != decl.DECL_KIND_FUN) { ret none[*decl.DeclFun](); }
    ret some[*decl.DeclFun](?d.data.fun_);
}

# reports whether the callee DeclFun declares any comptime value parameter. the
# typed_names slice is read from the callee's origin AST (the caller and callee
# may differ).
fun decl_has_comptime_param(sc: *sema.SemaContext, callee: id.ExprId, f: *decl.DeclFun) bool {
    val so: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, callee);
    if (is_none[*resolve.Symbol](so)) { ret false; }
    val sym: *resolve.Symbol = unwrap[*resolve.Symbol](so);

    var a: *ast.Ast = sc.a;
    if (sym.origin != sc.own_module) {
        a = session.module_ast(sc.s, sym.origin);
        if (a == nil) { ret false; }
    }
    var i: u32 = 0;
    for (i < f.params_len) {
        if (a.typed_names[f.params_start + i].comptime) { ret true; }
        i = i + 1;
    }
    ret false;
}

# recognises and types a comptime value intrinsic call. `$size_of(T)` /
# `$align_of(T)` take one type-naming argument; `$offset_of(T, field)` takes a
# type and a field. each yields an unsigned integer (`u64`), matching the
# closed intrinsic set in the language. the type argument is resolved so its
# expr_type slot carries the operand type the lowerer needs to fold the size.
# returns TYPE_NIL when the call is not a comptime intrinsic (caller proceeds
# with normal call inference), the result type when it is, or TYPE_ERROR for a
# malformed intrinsic.
fun infer_comptime_intrinsic(sc: *sema.SemaContext, c: *expr.ExprCall, span: token.Span) type.TypeId {
    val ce_opt: Option[*expr.Expr] = ast.get_expr(sc.a, c.callee);
    if (is_none[*expr.Expr](ce_opt)) { ret type.TYPE_NIL; }
    val ce: *expr.Expr = unwrap[*expr.Expr](ce_opt);
    if (ce.kind != expr.EXPR_KIND_COMPTIME_IDENT) { ret type.TYPE_NIL; }

    val name: intern.StrId = comptime_ident_name(sc, ce.span);
    if (name == intern.STR_NIL) { ret type.TYPE_NIL; }
    val is_size:   bool = name == interned(sc, "size_of");
    val is_align:  bool = name == interned(sc, "align_of");
    val is_offset: bool = name == interned(sc, "offset_of");
    if (!is_size && !is_align && !is_offset) { ret type.TYPE_NIL; }

    val want: u32 = 1;
    var need: u32 = want;
    if (is_offset) { need = 2; }
    if (c.args_len != need) {
        sema.report(sc, span, "comptime intrinsic: wrong number of arguments");
        ret type.TYPE_ERROR;
    }

    # the first argument names the operand type, so it is resolved as a type
    # spelling rather than a value: a primitive (`i64`, `bool`, `ptr`, ...), a
    # user record/union/def, or a `module.Type`. the resolved operand type is
    # written into the argument's expr_type slot, which the lowerer reads to
    # fold the size / alignment / offset. the `$offset_of` field argument is a
    # bare field name resolved against the record at lowering time, not here.
    val arg0: id.ExprId = sc.a.expr_ids[c.args_start];
    val op_ty: type.TypeId = intrinsic_operand_type(sc, arg0, span);
    set_expr_type(sc, arg0, op_ty);
    if (op_ty == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    ret prim_or_error(sc, type.TYPE_U64);
}

# types a variadic intrinsic call. `va_start(ap)` / `va_end(ap)` take one
# `*va_list` argument and yield void (TYPE_NIL); `va_arg[T](ap)` takes one
# `*va_list` and yields T (its single type argument). returns none when the
# callee is not a variadic intrinsic, so `infer_call` proceeds normally; some
# (TYPE_NIL) for the void intrinsics, distinguished from the none sentinel.
fun infer_va_intrinsic(sc: *sema.SemaContext, c: *expr.ExprCall, span: token.Span) Option[type.TypeId] {
    val ce_opt: Option[*expr.Expr] = ast.get_expr(sc.a, c.callee);
    if (is_none[*expr.Expr](ce_opt)) { ret none[type.TypeId](); }
    val ce: *expr.Expr = unwrap[*expr.Expr](ce_opt);
    if (ce.kind != expr.EXPR_KIND_IDENT) { ret none[type.TypeId](); }

    val name: intern.StrId = intern_span_or_nil(sc, ce.span);
    if (name == intern.STR_NIL) { ret none[type.TypeId](); }
    val is_start: bool = name == interned(sc, "va_start");
    val is_arg:   bool = name == interned(sc, "va_arg");
    val is_end:   bool = name == interned(sc, "va_end");
    if (!is_start && !is_arg && !is_end) { ret none[type.TypeId](); }

    if (c.args_len != 1) {
        sema.report(sc, span, "va intrinsic: expected one va_list pointer argument");
        ret some[type.TypeId](type.TYPE_ERROR);
    }

    # the argument is a `*va_list`; infer it so its expr_type slot populates and
    # require a pointer (the va_list address `va_start(?ap)` / the `ap: *va_list`
    # parameter passed through).
    val arg_eid: id.ExprId = sc.a.expr_ids[c.args_start];
    val arg_ty: type.TypeId = infer_expr(sc, arg_eid);
    if (arg_ty != type.TYPE_ERROR) {
        val at_opt: Option[*type.Type] = type.get(?sc.s.types, arg_ty);
        if (is_some[*type.Type](at_opt) && unwrap[*type.Type](at_opt).kind != type.TYPE_POINTER) {
            sema.report(sc, span, "va intrinsic: argument must be a va_list pointer");
        }
    }

    if (is_arg) {
        if (c.type_args_len != 1) {
            sema.report(sc, span, "va_arg: expected one type argument `va_arg[T](ap)`");
            ret some[type.TypeId](type.TYPE_ERROR);
        }
        val targ: id.TypeId = sc.a.type_ids[c.type_args_start];
        ret some[type.TypeId](resolve_type_ref(sc, targ));
    }

    # `va_start` / `va_end` yield void.
    ret some[type.TypeId](type.TYPE_NIL);
}

# resolves a comptime intrinsic's type-naming argument to its semantic type.
# the argument is a name expression bound in the resolve pass: a single IDENT
# (primitive or user type) or a `module.Type` member chain. both carry their
# resolved SymbolId on the argument expression, mapped to a type by
# `type_for_symbol` (which handles primitives, records, unions, and defs).
fun intrinsic_operand_type(sc: *sema.SemaContext, eid: id.ExprId, span: token.Span) type.TypeId {
    val sym_opt: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, eid);
    if (is_none[*resolve.Symbol](sym_opt)) {
        # resolve already reported the unresolved name; absorb silently
        ret type.TYPE_ERROR;
    }
    ret type_for_symbol(sc, unwrap[*resolve.Symbol](sym_opt), span);
}

# writes `ty` into an expression's expr_type slot, the parallel array sema fills
# for the lowerer. out-of-range ids are ignored, matching `infer_expr`.
fun set_expr_type(sc: *sema.SemaContext, eid: id.ExprId, ty: type.TypeId) {
    if (sc.expr_type == nil) { ret; }
    if (eid >= sc.a.expr_len::u32) { ret; }
    sc.expr_type[eid] = ty;
}

# interns the identifier text of a `$ident` comptime ident, with the leading
# `$` stripped, returning its StrId (STR_NIL on failure or an empty name).
fun comptime_ident_name(sc: *sema.SemaContext, full: token.Span) intern.StrId {
    if (full.len <= 1) { ret intern.STR_NIL; }
    var s: token.Span;
    s.offset = full.offset + 1;
    s.len    = full.len - 1;
    ret intern_span_or_nil(sc, s);
}

# interns a static literal in the session interner, returning its StrId or
# STR_NIL on allocation failure.
fun interned(sc: *sema.SemaContext, text: str) intern.StrId {
    val r: Result[intern.StrId, str] = intern.intern(?sc.s.interner, text);
    if (is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret unwrap_ok[intern.StrId, str](r);
}

# instantiates a generic call's signature: resolves each call-site type
# argument, checks arity against the callee generic declaration, substitutes
# the argument sequence into the callee's TYPE_FUN, and checks the call
# arguments against the concrete parameter types. the call's result type is
# the substituted return type.
fun infer_generic_call(sc: *sema.SemaContext, c: *expr.ExprCall, ct: type.TypeId, span: token.Span) type.TypeId {
    val sym_opt: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, c.callee);
    if (is_none[*resolve.Symbol](sym_opt)) { ret type.TYPE_ERROR; }
    val sym: *resolve.Symbol = unwrap[*resolve.Symbol](sym_opt);

    val pr: Result[*type.TypeId, str] = allocate_params(sc, c.type_args_len);
    if (is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val args: *type.TypeId = unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    for (i < c.type_args_len) {
        val arg_tid: id.TypeId = sc.a.type_ids[c.type_args_start + i];
        args[i] = resolve_type_ref(sc, arg_tid);
        i = i + 1;
    }

    if (!generics.check_arity(sc, sym.decl, sym.origin, c.type_args_len, span)) {
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }

    if (ct == type.TYPE_ERROR) {
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }
    val fn_opt: Option[*type.Type] = type.get(?sc.s.types, ct);
    if (is_none[*type.Type](fn_opt)) {
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }
    if (unwrap[*type.Type](fn_opt).kind != type.TYPE_FUN) {
        sema.report(sc, span, "not callable: target is not a function");
        free_params(sc, args, c.type_args_len);
        ret type.TYPE_ERROR;
    }

    val sig: type.TypeId = generics.substitute(sc.s, ct, args, c.type_args_len);
    free_params(sc, args, c.type_args_len);
    if (sig == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val sfn_opt: Option[*type.Type] = type.get(?sc.s.types, sig);
    if (is_none[*type.Type](sfn_opt)) { ret type.TYPE_ERROR; }
    val sfn: *type.Type = unwrap[*type.Type](sfn_opt);
    if (sfn.kind != type.TYPE_FUN) { ret type.TYPE_ERROR; }

    val ret_ty: type.TypeId = sfn.data.fn.ret_ty;
    check.check_call(sc, sig, c.args_start, c.args_len, span);
    ret ret_ty;
}

# INDEX: object must be a pointer or array, index must be an integer; result
# is the element type.
fun infer_index(sc: *sema.SemaContext, ix: *expr.ExprIndex, span: token.Span) type.TypeId {
    val ot: type.TypeId = infer_expr(sc, ix.object);
    val it: type.TypeId = infer_expr(sc, ix.index);
    if (ot == type.TYPE_ERROR || it == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val r: Option[type.TypeId] = check.check_index(sc, ot, it, span);
    if (is_none[type.TypeId](r)) { ret type.TYPE_ERROR; }
    ret unwrap[type.TypeId](r);
}

# MEMBER: a member access is either a qualified module reference
# `alias.symbol` — resolved during name resolution and recorded on the member
# expression, whose type is that symbol's — or a field access `object.field`.
# for the latter the object must be a record or union (or a pointer to one),
# and a generic instance's field layout is materialized on demand before the
# field lookup.
fun infer_member(sc: *sema.SemaContext, eid: id.ExprId, m: *expr.ExprMember, span: token.Span) type.TypeId {
    val qsym_opt: Option[*resolve.Symbol] = sema.symbol_for_expr(sc, eid);
    if (is_some[*resolve.Symbol](qsym_opt)) {
        ret sema.decl_type_for(sc, unwrap[*resolve.Symbol](qsym_opt));
    }

    # a `$mach.*` member chain (rooted at a `$` comptime ident) is a comptime
    # path, not a field access; its object is not a real record value. fold it
    # to a comptime-int type when it resolves to an integer.
    val cti: type.TypeId = infer_comptime_int_path(sc, eid);
    if (cti != type.TYPE_NIL) { ret cti; }

    val ot: type.TypeId = infer_expr(sc, m.object);
    if (ot == type.TYPE_ERROR || ot == type.TYPE_NIL) { ret type.TYPE_ERROR; }

    ensure_record_fields(sc, ot);

    val name_id: intern.StrId = intern_span_or_nil(sc, m.name);
    val r: Option[type.TypeId] = check.check_member(sc, ot, name_id, span);
    if (is_none[type.TypeId](r)) { ret type.TYPE_ERROR; }
    ret unwrap[type.TypeId](r);
}

# types a value-context comptime path (`$mach.target.os`, `$mach.os.linux`,
# `$mach.target.pointer_width`, ...) that folds to an integer. such a path
# takes the default concrete comptime-int type (TYPE_I64) and then narrows to
# the usage-site type via `coerce.try_coerce_literal`, exactly like an integer
# literal. returns TYPE_NIL when `eid` is not a comptime path or the path does
# not fold to an integer, so the caller falls back to its normal handling.
fun infer_comptime_int_path(sc: *sema.SemaContext, eid: id.ExprId) type.TypeId {
    if (!comptime.is_comptime_path(sc.a, eid)) { ret type.TYPE_NIL; }
    val ev: Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
    if (is_err[comptime.CTValue, str](ev)) { ret type.TYPE_NIL; }
    val cv: comptime.CTValue = unwrap_ok[comptime.CTValue, str](ev);
    if (cv.kind != comptime.CT_KIND_INT) { ret type.TYPE_NIL; }
    ret prim_or_error(sc, type.TYPE_I64);
}

# materializes the field layout of `tid` (and, if `tid` is a pointer, its
# pointee) for an upcoming field access. only generic instances need this —
# nominal layouts are built when their declaring module is analysed — but a
# pointer-to-instance reaches a field through one level of indirection.
fun ensure_record_fields(sc: *sema.SemaContext, tid: type.TypeId) {
    generics.ensure_fields(sc.s, tid);
    val t_opt: Option[*type.Type] = type.get(?sc.s.types, tid);
    if (is_none[*type.Type](t_opt)) { ret; }
    val t: *type.Type = unwrap[*type.Type](t_opt);
    if (t.kind == type.TYPE_POINTER) {
        generics.ensure_fields(sc.s, t.data.pointer.base);
    }
}

# CAST: delegates to check.check_cast under the primitive-numeric /
# same-size-reinterpret rules.
fun infer_cast(sc: *sema.SemaContext, c: *expr.ExprCast, span: token.Span) type.TypeId {
    val ft: type.TypeId = infer_expr(sc, c.value);
    val tt: type.TypeId = sema.resolved_type_of(sc, c.ty);
    if (ft == type.TYPE_ERROR || tt == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val r: Option[type.TypeId] = check.check_cast(sc, ft, tt, span);
    if (is_none[type.TypeId](r)) { ret type.TYPE_ERROR; }
    ret unwrap[type.TypeId](r);
}

# ARRAY_LIT: result is [count]elem of the declared array type; every element
# is checked against the element type via check.check_assignable, and the
# element count must match the declared length exactly (`[N]T` holds exactly
# N values — see doc/language/types.md).
fun infer_array_lit(sc: *sema.SemaContext, al: *expr.ExprArrayLit, span: token.Span) type.TypeId {
    val arr_ty: type.TypeId = sema.resolved_type_of(sc, al.ty);
    var elem_ty: type.TypeId = type.TYPE_ERROR;
    var has_count: bool = false;
    var decl_count: u32 = 0;
    val at_opt: Option[*type.Type] = type.get(?sc.s.types, arr_ty);
    if (is_some[*type.Type](at_opt)) {
        val at: *type.Type = unwrap[*type.Type](at_opt);
        if (at.kind == type.TYPE_ARRAY) {
            elem_ty = at.data.array.base;
            decl_count = at.data.array.count;
            has_count = true;
        }
    }

    var i: u32 = 0;
    for (i < al.elems_len) {
        val ee: id.ExprId = sc.a.expr_ids[al.elems_start + i];
        var et: type.TypeId = infer_expr(sc, ee);
        if (elem_ty != type.TYPE_ERROR && et != type.TYPE_ERROR) {
            val co: Option[type.TypeId] = coerce.try_coerce_literal(sc, ee, elem_ty);
            if (is_some[type.TypeId](co)) { et = unwrap[type.TypeId](co); }
            check.check_assignable(sc, elem_ty, et, span);
        }
        i = i + 1;
    }

    if (has_count && al.elems_len > decl_count) {
        sema.report(sc, span, "array literal: too many elements for declared length");
    } or (has_count && al.elems_len < decl_count) {
        sema.report(sc, span, "array literal: too few elements for declared length");
    }
    ret arr_ty;
}

# STRUCT_LIT: result is the named record type; each field initializer is
# checked against the record's field of the same name. field validation is
# skipped when no field table exists for the type (an imported record whose
# fields were tabled in its own module's pass, or an upstream type error) —
# the initializers are still inferred so their expr_type slots fill.
fun infer_struct_lit(sc: *sema.SemaContext, sl: *expr.ExprStructLit, span: token.Span) type.TypeId {
    val rec_ty: type.TypeId = sema.resolved_type_of(sc, sl.ty);
    generics.ensure_fields(sc.s, rec_ty);
    val have_table: bool = is_some[*sema.FieldTable](sema.field_table_for(sc, rec_ty));

    var i: u32 = 0;
    for (i < sl.fields_len) {
        val fi: *expr.FieldInit = ?sc.a.field_inits[sl.fields_start + i];
        var vt: type.TypeId = infer_expr(sc, fi.value);
        if (rec_ty != type.TYPE_ERROR && vt != type.TYPE_ERROR && have_table) {
            val fname: intern.StrId = intern_span_or_nil(sc, fi.name);
            val ft_opt: Option[type.TypeId] = sema.field_lookup(sc, rec_ty, fname);
            if (is_none[type.TypeId](ft_opt)) {
                sema.report(sc, fi.name, "no such field: in struct literal");
            }
            or {
                val ft: type.TypeId = unwrap[type.TypeId](ft_opt);
                val co: Option[type.TypeId] = coerce.try_coerce_literal(sc, fi.value, ft);
                if (is_some[type.TypeId](co)) { vt = unwrap[type.TypeId](co); }
                check.check_assignable(sc, ft, vt, span);
            }
        }
        i = i + 1;
    }
    ret rec_ty;
}

# translates a syntactic AstType into an interned semantic TypeId, walking
# the TypeKind variants and dispatching to the matching type.intern_*.
# writes the result into type_resolved_ty[tid].
# ---
# sc:  sema context
# tid: syntactic AstType id to resolve
# ret: the interned semantic TypeId (TYPE_ERROR on failure)
pub fun resolve_type_ref(sc: *sema.SemaContext, tid: id.TypeId) type.TypeId {
    val t_opt: Option[*atype.Type] = ast.get_type(sc.a, tid);
    if (is_none[*atype.Type](t_opt)) { ret type.TYPE_ERROR; }
    val t: *atype.Type = unwrap[*atype.Type](t_opt);

    if (t.kind == atype.TYPE_KIND_NAMED) { ret resolve_type_named(sc, tid, ?t.data.named, t.span); }
    if (t.kind == atype.TYPE_KIND_PTR)   { ret resolve_type_ptr(sc, ?t.data.ptr); }
    if (t.kind == atype.TYPE_KIND_ARRAY) { ret resolve_type_array(sc, ?t.data.array, t.span); }
    if (t.kind == atype.TYPE_KIND_FUN)   { ret resolve_type_fun(sc, ?t.data.fun_); }
    if (t.kind == atype.TYPE_KIND_REC)   { ret resolve_type_anon(sc, tid, t.data.rec_.fields_start, t.data.rec_.fields_len, type.TYPE_REC); }
    if (t.kind == atype.TYPE_KIND_UNI)   { ret resolve_type_anon(sc, tid, t.data.uni_.fields_start, t.data.uni_.fields_len, type.TYPE_UNI); }
    ret type.TYPE_ERROR;
}

# NAMED: resolves the symbol the name refers to (recorded by resolve in
# type_resolved), maps it to the nominal / primitive / transparent type it
# names, and — when generic args are present — instantiates.
fun resolve_type_named(sc: *sema.SemaContext, tid: id.TypeId, named: *atype.TypeNamed, span: token.Span) type.TypeId {
    val sym_opt: Option[*resolve.Symbol] = sema.symbol_for_type(sc, tid);
    if (is_none[*resolve.Symbol](sym_opt)) {
        # resolve already reported the unresolved name; absorb silently
        ret type.TYPE_ERROR;
    }
    val sym: *resolve.Symbol = unwrap[*resolve.Symbol](sym_opt);

    if (named.args_len > 0) {
        ret instantiate_named(sc, sym, named, span);
    }

    ret type_for_symbol(sc, sym, span);
}

# maps a resolved type-name symbol to the semantic type it names: generic
# params become TYPE_GENERIC_PARAM, `def`s are transparent (their underlying
# type), records / unions become nominals. a cross-module reference resolves
# to SYM_IMPORTED (the originating rec/uni/def kind is not carried on the
# import symbol), so its type is read from the dependency's recorded
# decl_type, which already holds the nominal TypeId or the def's underlying.
fun type_for_symbol(sc: *sema.SemaContext, sym: *resolve.Symbol, span: token.Span) type.TypeId {
    if (sym.kind == resolve.SYM_PRIM) {
        ret prim_or_error(sc, sym.slot::type.TypeKind);
    }
    if (sym.kind == resolve.SYM_GENERIC) {
        val r: Result[type.TypeId, str] = type.intern_generic_param(?sc.s.types, sym.name, sym.decl, sym.slot);
        if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret unwrap_ok[type.TypeId, str](r);
    }
    if (sym.kind == resolve.SYM_REC || sym.kind == resolve.SYM_UNI) {
        var kind: type.TypeKind = type.TYPE_REC;
        if (sym.kind == resolve.SYM_UNI) { kind = type.TYPE_UNI; }
        val r: Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, sym.name, sym.origin, sym.decl, kind);
        if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret unwrap_ok[type.TypeId, str](r);
    }
    if (sym.kind == resolve.SYM_DEF) {
        ret def_underlying(sc, sym, span);
    }
    if (sym.kind == resolve.SYM_IMPORTED) {
        val imported: type.TypeId = sema.decl_type_for(sc, sym);
        if (imported == type.TYPE_NIL || imported == type.TYPE_ERROR) {
            sema.report(sc, span, "unresolved type: name does not denote a type");
            ret type.TYPE_ERROR;
        }
        ret imported;
    }
    sema.report(sc, span, "unresolved type: name does not denote a type");
    ret type.TYPE_ERROR;
}

# resolves a `def` alias to its underlying semantic type. local defs resolve
# the annotation directly (recomputing rather than reading the parallel
# array, so a forward reference to a later-indexed def still resolves);
# imported defs read from the dep's decl_type snapshot.
fun def_underlying(sc: *sema.SemaContext, sym: *resolve.Symbol, span: token.Span) type.TypeId {
    if (sym.origin == sc.own_module) {
        val d_opt: Option[*decl.Decl] = ast.get_decl(sc.a, sym.decl);
        if (is_none[*decl.Decl](d_opt)) { ret type.TYPE_ERROR; }
        val d: *decl.Decl = unwrap[*decl.Decl](d_opt);
        if (d.kind != decl.DECL_KIND_DEF) { ret type.TYPE_ERROR; }
        if (d.data.def_.ty == id.TYPE_NIL) { ret type.TYPE_ERROR; }
        ret resolve_type_ref(sc, d.data.def_.ty);
    }
    ret sema.decl_type_for(sc, sym);
}

# instantiates a generic type name `Name[args...]` by resolving each arg type
# and delegating to generics.instantiate.
fun instantiate_named(sc: *sema.SemaContext, sym: *resolve.Symbol, named: *atype.TypeNamed, span: token.Span) type.TypeId {
    val pr: Result[*type.TypeId, str] = allocate_params(sc, named.args_len);
    if (is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val args: *type.TypeId = unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    for (i < named.args_len) {
        val arg_tid: id.TypeId = sc.a.type_ids[named.args_start + i];
        args[i] = resolve_type_ref(sc, arg_tid);
        i = i + 1;
    }

    val r: Result[type.TypeId, str] = generics.instantiate(sc, sym.decl, sym.origin, args, named.args_len, span);
    free_params(sc, args, named.args_len);
    if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret unwrap_ok[type.TypeId, str](r);
}

# PTR: recurses on the pointee and interns a pointer.
fun resolve_type_ptr(sc: *sema.SemaContext, p: *atype.TypePtr) type.TypeId {
    val base: type.TypeId = resolve_type_ref(sc, p.pointee);
    ret ptr_to(sc, base);
}

# ARRAY: resolves the element type, evaluates the length via the comptime
# evaluator demanding CT_KIND_INT, and interns a fixed-size array.
fun resolve_type_array(sc: *sema.SemaContext, ar: *atype.TypeArray, span: token.Span) type.TypeId {
    val elem: type.TypeId = resolve_type_ref(sc, ar.element);
    if (elem == type.TYPE_ERROR) { ret type.TYPE_ERROR; }

    val len_r: Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, ar.length, ?sc.s.interner);
    if (is_err[comptime.CTValue, str](len_r)) {
        sema.report(sc, span, "cannot infer type: array length is not a comptime constant");
        ret type.TYPE_ERROR;
    }
    val cv: comptime.CTValue = unwrap_ok[comptime.CTValue, str](len_r);
    if (cv.kind != comptime.CT_KIND_INT) {
        sema.report(sc, span, "type mismatch: array length must be an integer");
        ret type.TYPE_ERROR;
    }
    if (cv.data.i < 0) {
        sema.report(sc, span, "type mismatch: array length must be non-negative");
        ret type.TYPE_ERROR;
    }

    val r: Result[type.TypeId, str] = type.intern_array(?sc.s.types, elem, cv.data.i::u32);
    if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret unwrap_ok[type.TypeId, str](r);
}

# FUN: resolves each parameter and the return type, interns a TYPE_FUN.
fun resolve_type_fun(sc: *sema.SemaContext, fn: *atype.TypeFun) type.TypeId {
    var ret_ty: type.TypeId = type.TYPE_NIL;
    if (fn.ret_ty != id.TYPE_NIL) { ret_ty = resolve_type_ref(sc, fn.ret_ty); }

    if (fn.params_len == 0) {
        val r: Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_ty, nil, 0, fn.variadic);
        if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret unwrap_ok[type.TypeId, str](r);
    }

    val pr: Result[*type.TypeId, str] = allocate_params(sc, fn.params_len);
    if (is_err[*type.TypeId, str](pr)) { ret type.TYPE_ERROR; }
    val params: *type.TypeId = unwrap_ok[*type.TypeId, str](pr);

    var i: u32 = 0;
    for (i < fn.params_len) {
        val pt: id.TypeId = sc.a.type_ids[fn.params_start + i];
        params[i] = resolve_type_ref(sc, pt);
        i = i + 1;
    }

    val r: Result[type.TypeId, str] = type.intern_function(?sc.s.types, ret_ty, params, fn.params_len, fn.variadic);
    free_params(sc, params, fn.params_len);
    if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret unwrap_ok[type.TypeId, str](r);
}

# REC / UNI (anonymous): interns a structurally-keyed nominal so two inline
# records (or unions) with the same field names and field types resolve to a
# single TypeId. the identity key is a canonical signature of the shape,
# interned to a StrId and carried in the nominal `decl` slot under the
# reserved `MODULE_NIL` origin; the StrId interner guarantees the key is exact
# (equal shapes -> equal StrId, distinct shapes -> distinct StrId), so the
# match is collision-free. builds the field table on first occurrence.
fun resolve_type_anon(sc: *sema.SemaContext, tid: id.TypeId, fields_start: u32, fields_len: u32, kind: type.TypeKind) type.TypeId {
    val name_id: intern.StrId = synth_anon_name(sc, kind);

    # consume an anon ordinal so the per-pass counter stays meaningful for
    # diagnostics, then derive the structural identity key.
    sema.next_anon_ordinal(sc);
    val key: intern.StrId = anon_struct_key(sc, fields_start, fields_len, kind);
    if (key == intern.STR_NIL) { ret type.TYPE_ERROR; }

    val r: Result[type.TypeId, str] = type.intern_nominal(?sc.s.types, name_id, sess.MODULE_NIL, key::id.DeclId, kind);
    if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    val ty: type.TypeId = unwrap_ok[type.TypeId, str](r);

    build_field_table(sc, ty, fields_start, fields_len);
    ret ty;
}

# builds a canonical structural-identity key for an anonymous rec/uni: a hex
# signature of the kind, the field count, and each field's interned name and
# resolved type, interned to a StrId. equal shapes intern to the same StrId,
# distinct shapes to distinct StrIds. STR_NIL signals an allocation failure.
fun anon_struct_key(sc: *sema.SemaContext, fields_start: u32, fields_len: u32, kind: type.TypeKind) intern.StrId {
    var buf: [1024]u8;
    var n: usize = 0;
    n = put_hex_u32(?buf[0], n, 1024, kind::u32);
    n = put_hex_u32(?buf[0], n, 1024, fields_len);

    var i: u32 = 0;
    for (i < fields_len) {
        val tn: *decl.TypedName = ?sc.a.typed_names[fields_start + i];
        val fname: intern.StrId = intern_span_or_nil(sc, tn.name);
        val fty: type.TypeId = sema.resolved_type_of(sc, tn.ty);
        n = put_hex_u32(?buf[0], n, 1024, fname::u32);
        n = put_hex_u32(?buf[0], n, 1024, fty::u32);
        i = i + 1;
    }

    val r: Result[intern.StrId, str] = intern.intern_bytes(?sc.s.interner, (?buf[0])::str, n);
    if (is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret unwrap_ok[intern.StrId, str](r);
}

# appends the 8 lowercase hex digits of `v` to `buf` at offset `off`, never
# writing past `cap`; returns the new offset. hex avoids NUL bytes so the
# buffer is safe to intern as a string key.
fun put_hex_u32(buf: *u8, off: usize, cap: usize, v: u32) usize {
    var o: usize = off;
    var d: u32 = 0;
    for (d < 8) {
        if (o >= cap) { ret o; }
        val shift: u32 = (7 - d) * 4;
        val nib: u32 = (v >> shift) & 0xF;
        var c: u8 = nib::u8 + 0x30;
        if (nib > 9) { c = nib::u8 - 10 + 0x61; }
        buf[o] = c;
        o = o + 1;
        d = d + 1;
    }
    ret o;
}

# interns a synthetic display name for an anonymous rec/uni nominal. identity
# is carried by the (origin, decl=tid) pair, not the name, so a single fixed
# label per kind is sufficient.
fun synth_anon_name(sc: *sema.SemaContext, kind: type.TypeKind) intern.StrId {
    if (kind == type.TYPE_UNI) {
        val r: Result[intern.StrId, str] = intern.intern(?sc.s.interner, "__anon_uni");
        if (is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
        ret unwrap_ok[intern.StrId, str](r);
    }
    val r: Result[intern.StrId, str] = intern.intern(?sc.s.interner, "__anon_rec");
    if (is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret unwrap_ok[intern.StrId, str](r);
}

# interns the pointer type *base. a poisoned base poisons the pointer.
fun ptr_to(sc: *sema.SemaContext, base: type.TypeId) type.TypeId {
    if (base == type.TYPE_ERROR) { ret type.TYPE_ERROR; }
    val r: Result[type.TypeId, str] = type.intern_pointer(?sc.s.types, base);
    if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
    ret unwrap_ok[type.TypeId, str](r);
}

# returns the pointee type of a pointer; non-pointer operands report a
# diagnostic and yield TYPE_ERROR.
fun pointee_of(sc: *sema.SemaContext, ty: type.TypeId, span: token.Span) type.TypeId {
    val t_opt: Option[*type.Type] = type.get(?sc.s.types, ty);
    if (is_none[*type.Type](t_opt)) { ret type.TYPE_ERROR; }
    val t: *type.Type = unwrap[*type.Type](t_opt);
    if (t.kind != type.TYPE_POINTER) {
        sema.report(sc, span, "type mismatch: dereference of non-pointer type");
        ret type.TYPE_ERROR;
    }
    ret t.data.pointer.base;
}

# fetches a primitive TypeId by kind; returns TYPE_ERROR when the kind is not
# a primitive (a compiler-internal misuse). the builtin `va_list` spelling is
# seeded as a SYM_PRIM carrying TYPE_VA_LIST, so it is interned on demand here.
fun prim_or_error(sc: *sema.SemaContext, kind: type.TypeKind) type.TypeId {
    if (kind == type.TYPE_VA_LIST) {
        val r: Result[type.TypeId, str] = type.intern_va_list(?sc.s.types);
        if (is_err[type.TypeId, str](r)) { ret type.TYPE_ERROR; }
        ret unwrap_ok[type.TypeId, str](r);
    }
    val p: Option[type.TypeId] = type.prim(?sc.s.types, kind);
    if (is_none[type.TypeId](p)) { ret type.TYPE_ERROR; }
    ret unwrap[type.TypeId](p);
}

# is the TypeId one of the numeric primitives u8..f64?
fun is_numeric(sc: *sema.SemaContext, ty: type.TypeId) bool {
    val t_opt: Option[*type.Type] = type.get(?sc.s.types, ty);
    if (is_none[*type.Type](t_opt)) { ret false; }
    val k: type.TypeKind = unwrap[*type.Type](t_opt).kind;
    ret k::u32 <= type.TYPE_F64::u32;
}

# is the TypeId one of the integer primitives u8..i64?
fun is_integer(sc: *sema.SemaContext, ty: type.TypeId) bool {
    val t_opt: Option[*type.Type] = type.get(?sc.s.types, ty);
    if (is_none[*type.Type](t_opt)) { ret false; }
    val k: type.TypeKind = unwrap[*type.Type](t_opt).kind;
    ret k::u32 <= type.TYPE_I64::u32;
}

# is the TypeId address-shaped — a raw `ptr`, a typed `*T`, or a function
# (`TYPE_FUN`, a code address)? used by equality to relate `nil` against
# pointer and function operands.
fun is_pointer_like(sc: *sema.SemaContext, ty: type.TypeId) bool {
    val t_opt: Option[*type.Type] = type.get(?sc.s.types, ty);
    if (is_none[*type.Type](t_opt)) { ret false; }
    val k: type.TypeKind = unwrap[*type.Type](t_opt).kind;
    ret k == type.TYPE_PTR || k == type.TYPE_POINTER || k == type.TYPE_FUN;
}

# attempts to make a binary operation's two operands share a type when one
# side is a coercible literal. returns the unified type, or none when no
# coercion applies (operands either already agree or genuinely differ).
fun unify_literals(sc: *sema.SemaContext, lhs: id.ExprId, lt: type.TypeId, rhs: id.ExprId, rt: type.TypeId) Option[type.TypeId] {
    if (lt == rt) { ret none[type.TypeId](); }
    # try coercing the RHS literal toward the LHS type, then vice-versa
    val cr: Option[type.TypeId] = coerce.try_coerce_literal(sc, rhs, lt);
    if (is_some[type.TypeId](cr)) { ret some[type.TypeId](lt); }
    val cl: Option[type.TypeId] = coerce.try_coerce_literal(sc, lhs, rt);
    if (is_some[type.TypeId](cl)) { ret some[type.TypeId](rt); }
    ret none[type.TypeId]();
}

# emits a `type mismatch:` diagnostic for a binary operand-type clash.
fun type_mismatch(sc: *sema.SemaContext, span: token.Span) {
    sema.report(sc, span, "type mismatch: incompatible operand types");
}

# interns the identifier text covered by `span`, or STR_NIL for an empty span.
fun intern_span_or_nil(sc: *sema.SemaContext, span: token.Span) intern.StrId {
    if (span.len == 0) { ret intern.STR_NIL; }
    val r: Result[intern.StrId, str] = intern.intern_span(?sc.s.interner, sc.source, span);
    if (is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret unwrap_ok[intern.StrId, str](r);
}

# allocates a scratch TypeId array of `count` slots for assembling a
# parameter / argument list before interning.
fun allocate_params(sc: *sema.SemaContext, count: u32) Result[*type.TypeId, str] {
    ret allocate[type.TypeId](sc.s.alloc, count::usize);
}

# releases a scratch TypeId array allocated by allocate_params.
fun free_params(sc: *sema.SemaContext, params: *type.TypeId, count: u32) {
    deallocate[type.TypeId](sc.s.alloc, params, count::usize);
}
