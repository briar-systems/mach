# generic instantiation and substitution
#
# Mach monomorphizes per use site: every `Name[Arg, ...]` reference to a generic
# record, union, or function produces a concrete `TYPE_INSTANCE` interned against
# the generic declaration and its argument sequence. `substitute` is the
# companion that rewrites a generic body type - replacing each
# `TYPE_GENERIC_PARAM` by its ordinal with the corresponding argument - so a
# field table or function signature can be specialized for the instance.
#
# Instances are interned, so a recursive generic that mentions itself (for
# example a tree node whose field is a pointer to the same instance) is handled
# by the interner returning the in-progress TypeId for the inner reference;
# substitution never has to unfold recursion.

use std.format;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.char.char;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.id;
use sema: mach.lang.fe.sema.context;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.session;
use mach.lang.source;
use mach.lang.type;

# the set of nominal TypeIds entered during a single generic-parameter search
#
# A recursive nominal (`rec Node { next: *Node; }`) would otherwise recurse
# forever; recording each entered nominal lets a re-entry break its own cycle.
# ---
# visited: dynamic array of entered nominal TypeIds
# len:     number of ids stored
# cap:     allocated slots
rec GParamScan {
    visited: *type.TypeId;
    len:     u32;
    cap:     u32;
}

# instantiate a generic declaration with concrete type arguments, producing an
# interned `TYPE_INSTANCE`
#
# The supplied argument count is checked against the declaration's
# generic-parameter count, read from the declaring module's AST whether that is
# this module or a dependency (a use site's arity cannot be validated at the
# declaration site, so a cross-module instantiation is checked here too). A
# non-generic declaration, or a count mismatch, is reported. Every argument must
# be a real, non-error type. On success the interned instance TypeId is returned.
# ---
# sc:             the active sema context
# generic_decl:   DeclId of the generic declaration in `generic_origin`
# generic_origin: ModuleId of the module that declared the generic
# args:           pointer to a contiguous array of concrete argument types
# arg_count:      number of arguments supplied at the use site
# span:           source range of the instantiation, for diagnostics
# ret:            the interned TYPE_INSTANCE TypeId, or an allocation error
pub fun instantiate(
    sc:             *sema.SemaContext,
    generic_decl:   id.DeclId,
    generic_origin: session.ModuleId,
    args:           *type.TypeId,
    arg_count:      u32,
    span:           token.Span
) R.Result[type.TypeId, str] {
    if (generic_decl == id.DECL_NIL) {
        sema.report(sc, span, "not a generic: declaration is not generic");
        ret R.ok[type.TypeId, str](type.TYPE_ERROR);
    }

    if (!check_arity(sc, generic_decl, generic_origin, arg_count, span)) {
        ret R.ok[type.TypeId, str](type.TYPE_ERROR);
    }

    var i: u32 = 0;
    for (i < arg_count) {
        if (args[i] == type.TYPE_NIL || args[i] == type.TYPE_ERROR) {
            sema.report_numbered(sc, span, "generic argument ", (i + 1)::usize, " is not a valid type", "generic argument is not a valid type");
            ret R.ok[type.TypeId, str](type.TYPE_ERROR);
        }
        i = i + 1;
    }

    ret type.intern_instance(?sc.s.types, generic_origin, generic_decl, args, arg_count);
}

# validate the supplied argument count against a generic declaration's parameter
# count
#
# The parameter count is read from the declaring module's AST: this module for a
# local generic, or the origin dependency's AST (reached through the session
# registry) for a cross-module one, since a use site's arity is its own to
# validate, never the declaration site's. A non-generic declaration, or a count
# mismatch, is reported and returns false. An origin AST that cannot be reached
# is accepted - the reference will fail elsewhere - so a missing dependency never
# masquerades as an arity error.
# ---
# sc:             the active sema context
# generic_decl:   DeclId of the generic declaration
# generic_origin: ModuleId that declared the generic
# arg_count:      number of arguments supplied at the use site
# span:           source range for diagnostics
# ret:            true when the arity is acceptable, false otherwise
pub fun check_arity(
    sc:             *sema.SemaContext,
    generic_decl:   id.DeclId,
    generic_origin: session.ModuleId,
    arg_count:      u32,
    span:           token.Span
) bool {
    var a: *ast.Ast = sc.a;
    if (generic_origin != sc.own_module) {
        a = session.module_ast(sc.s, generic_origin);
        if (a == nil) { ret true; }
    }

    val opt_want: O.Option[u32] = generic_count_in(a, generic_decl);
    if (O.is_none[u32](opt_want)) {
        sema.report(sc, span, "not a generic: declaration takes no type parameters");
        ret false;
    }

    val want: u32 = O.unwrap[u32](opt_want);
    if (arg_count != want) {
        report_type_arg_count(sc, span, "wrong number of type arguments", want, arg_count);
        ret false;
    }
    ret true;
}

# rewrite a generic body type by substituting each generic parameter with the
# matching argument
#
# `TYPE_GENERIC_PARAM` entries are replaced by index (a param whose ordinal is
# out of range becomes the error type); pointer, array, function, and instance
# types are rebuilt structurally so substitution reaches every nested position;
# primitives and fully concrete nominal types pass through unchanged. An
# allocation failure during a structural rebuild degrades to `TYPE_ERROR` rather
# than aborting the whole module.
# ---
# s:         the shared session (type universe, allocator)
# body_type: the generic type to specialize (a field type, signature, etc.)
# args:      pointer to the concrete argument types, indexed by param ordinal
# arg_count: number of arguments (= the declaration's generic-param count)
# ret:       the specialized TypeId, or TYPE_ERROR on an allocation failure
pub fun substitute(s: *session.Session, body_type: type.TypeId, args: *type.TypeId, arg_count: u32) type.TypeId {
    if (body_type == type.TYPE_NIL || body_type == type.TYPE_ERROR) { ret body_type; }

    val opt_type: O.Option[*type.Type] = type.get(?s.types, body_type);
    if (O.is_none[*type.Type](opt_type)) { ret body_type; }
    val t: *type.Type = O.unwrap[*type.Type](opt_type);

    if (t.kind == type.TYPE_GENERIC_PARAM) {
        val index: u32 = t.data.generic_param.index;
        if (index < arg_count) { ret args[index]; }
        ret type.TYPE_ERROR;
    }

    # snapshot the base (and count) before recursing: substitution may intern new
    # types, growing the universe and invalidating the borrowed `t`.
    if (t.kind == type.TYPE_POINTER) {
        val original_base: type.TypeId = t.data.pointer.base;
        val base:          type.TypeId = substitute(s, original_base, args, arg_count);
        if (base == original_base) { ret body_type; }
        ret unwrap_or_error(type.intern_pointer(?s.types, base));
    }

    if (t.kind == type.TYPE_ARRAY) {
        val original_base: type.TypeId = t.data.array.base;
        val count:         u32         = t.data.array.count;
        val base:          type.TypeId = substitute(s, original_base, args, arg_count);
        if (base == original_base) { ret body_type; }
        ret unwrap_or_error(type.intern_array(?s.types, base, count));
    }

    # a `^T` body type specializes its inner type and re-wraps the qualifier, so
    # `^T` instantiated at `u32` becomes `^u32` (#1645).
    if (t.kind == type.TYPE_SECRET) {
        val original_base: type.TypeId = t.data.secret.base;
        val base:          type.TypeId = substitute(s, original_base, args, arg_count);
        if (base == original_base) { ret body_type; }
        ret unwrap_or_error(type.intern_secret(?s.types, base));
    }

    if (t.kind == type.TYPE_FUN)      { ret substitute_fun(s, t, args, arg_count, body_type); }
    if (t.kind == type.TYPE_INSTANCE) { ret substitute_instance(s, t, args, arg_count, body_type); }

    # a nominal rec/uni whose field layout mentions a generic parameter is a
    # nested aggregate inside the generic body (e.g. the anonymous `uni {ok: T}`
    # in `Result[T, E]`); it must be specialized too. it interns to a
    # TYPE_INSTANCE over the nominal's own (origin, decl) carrying the current
    # arguments, whose substituted field table is built eagerly. a nominal with
    # no generic-parameter field is fully concrete and passes through.
    if (t.kind == type.TYPE_REC || t.kind == type.TYPE_UNI) {
        if (!nominal_has_gparam(s, body_type)) { ret body_type; }
        ret substitute_aggregate(s, t, args, arg_count, body_type);
    }

    # primitives and raw ptr have nothing to substitute
    ret body_type;
}

# ensure a field table exists for TypeId `tid`, materializing one on demand for a
# generic instance
#
# A `TYPE_INSTANCE` carries no fields of its own: this resolves the generic
# nominal it specializes (whose field table, built with `TYPE_GENERIC_PARAM`
# placeholders by the declaring module, holds the unsubstituted layout) and
# registers a fresh table for the instance with every field type substituted by
# the instance's concrete arguments. Nominal and primitive types already have (or
# need) no synthesized table, so they return immediately. Idempotent once the
# table exists at the current epoch.
# ---
# s:   the shared session (type universe, AST registry, sources)
# tid: the TypeId whose field layout must be available
pub fun ensure_fields(s: *session.Session, tid: type.TypeId) {
    val opt_existing: O.Option[*type.FieldTable] = type.field_table_for(?s.types, tid);
    if (O.is_some[*type.FieldTable](opt_existing)) {
        # reuse an up-to-date table; rebuild one from an older epoch, since a
        # re-layout (a substituted field type changed across a rebuild) keeps the
        # instance TypeId but must refresh the cached layout (#1583).
        if (O.unwrap[*type.FieldTable](opt_existing).epoch == type.field_epoch(?s.types)) { ret; }
    }

    val opt_type: O.Option[*type.Type] = type.get(?s.types, tid);
    if (O.is_none[*type.Type](opt_type)) { ret; }
    val t: *type.Type = O.unwrap[*type.Type](opt_type);
    if (t.kind != type.TYPE_INSTANCE) { ret; }

    val origin: session.ModuleId = t.data.instance.target_origin;
    val gdecl:  id.DeclId        = t.data.instance.target_decl;

    val gnom: type.TypeId = generic_nominal_of(s, origin, gdecl);
    if (gnom == type.TYPE_ERROR) { ret; }

    build_instance_table(s, tid, gnom);
}

# whether type `tid` transitively contains a secret `^` ANYWHERE (#2162)
#
# The DEEP counterpart to `type.carries_secret`: it follows the pointer / array spine
# AND recurses INTO record / union / generic-instance field graphs, so an aggregate that
# WRAPS a secret (`rec P { x: ^u32 }`, a nested record, an all-secret union, a
# `Box[^u32]`) is caught. `carries_secret` treats a nominal as a leaf - correct for the
# welded-storage aliasing rules it guards, but an under-approximation at any boundary
# where a secret could be observed / aliased / erased, since the secrecy erasure there is
# deep. Use this wherever a secret must not cross into a secrecy-erasing context.
#
# It lives here, not in `type`, because a generic-instance field table is materialized
# LAZILY: a `Box[^u32]` that reaches a boundary with no prior field elaboration has no
# registered table, and the shallow read would see zero fields and BYPASS. Each
# TYPE_INSTANCE is materialized via `ensure_fields` before its fields are walked, so the
# result is independent of materialization order; if a nominal's field table still cannot
# be resolved it FAILS CLOSED (treated as possibly-secret), never bypassed.
# ---
# s:   the session (type universe + lazy instance field materialization)
# tid: the type to inspect
# ret: true when `tid` reaches a `^` through any pointer / array / field
pub fun contains_secret_deep(s: *session.Session, tid: type.TypeId) bool {
    var scan: type.SecretScan;
    scan.len = 0;
    ret secret_deep_walk(s, tid, ?scan);
}

# the recursive worker for `contains_secret_deep`, threading the visited set
fun secret_deep_walk(s: *session.Session, tid: type.TypeId, scan: *type.SecretScan) bool {
    val opt_type: O.Option[*type.Type] = type.get(?s.types, tid);
    if (O.is_none[*type.Type](opt_type)) { ret false; }
    val t: *type.Type = O.unwrap[*type.Type](opt_type);

    if (t.kind == type.TYPE_SECRET)  { ret true; }
    if (t.kind == type.TYPE_POINTER) { ret secret_deep_walk(s, t.data.pointer.base, scan); }
    if (t.kind == type.TYPE_ARRAY)   { ret secret_deep_walk(s, t.data.array.base, scan); }

    if (t.kind == type.TYPE_REC || t.kind == type.TYPE_UNI || t.kind == type.TYPE_INSTANCE) {
        # an already-visited nominal contributes no new secret (its fields were fully
        # explored on the first visit); this also terminates a cyclic record graph.
        var i: u32 = 0;
        for (i < scan.len) {
            if (scan.seen[i] == tid) { ret false; }
            i = i + 1;
        }
        # a graph beyond the visited-set bound fails CLOSED (never under-reports).
        if (scan.len >= 256) { ret true; }
        scan.seen[scan.len] = tid;
        scan.len = scan.len + 1;

        # materialize a generic instance's field table from its template, independent of
        # whether/when lazy elaboration ran, so the walk never reads an absent table as
        # "no fields".
        if (t.kind == type.TYPE_INSTANCE) { ensure_fields(s, tid); }

        # FAIL CLOSED: a nominal whose field table cannot be resolved is treated as
        # possibly-secret rather than bypassed. A resolvable empty aggregate (a table with
        # zero fields) is genuinely secret-free and is allowed.
        val opt_tab: O.Option[*type.FieldTable] = type.field_table_for(?s.types, tid);
        if (O.is_none[*type.FieldTable](opt_tab)) { ret true; }
        val fields_len: u32 = O.unwrap[*type.FieldTable](opt_tab).fields_len;

        var f: u32 = 0;
        for (f < fields_len) {
            val opt_e: O.Option[*type.FieldEntry] = type.field_at(?s.types, tid, f);
            if (O.is_some[*type.FieldEntry](opt_e)) {
                if (secret_deep_walk(s, O.unwrap[*type.FieldEntry](opt_e).ty, scan)) { ret true; }
            }
            f = f + 1;
        }
        ret false;
    }
    ret false;
}

# resolve the generic nominal TypeId that instance `(origin, gdecl)` specializes
#
# Reads the nominal's name and rec/uni kind from the declaration in its origin
# module's AST (reached through the session registry), then re-interns it.
# `intern_nominal` is keyed by `(origin, decl)`, so this returns exactly the id
# the declaring module tabled its fields against (and whose `name` StrId
# diagnostics render). Returns TYPE_ERROR when the origin AST or declaration is
# unavailable.
# ---
# s:      the shared session (type universe, AST registry, sources)
# origin: module that declared the generic
# gdecl:  the generic declaration in origin's AST
# ret:    the generic's nominal TypeId, or TYPE_ERROR when unavailable
pub fun generic_nominal_of(s: *session.Session, origin: session.ModuleId, gdecl: id.DeclId) type.TypeId {
    val ga: *ast.Ast = session.module_ast(s, origin);
    if (ga == nil) { ret type.TYPE_ERROR; }

    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(ga, gdecl);
    if (O.is_none[*decl.Decl](opt_decl)) { ret type.TYPE_ERROR; }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_decl);

    var gname: intern.StrId  = intern.STR_NIL;
    var gkind: type.TypeKind = type.TYPE_REC;
    if (d.kind == decl.DECL_KIND_REC) {
        gname = intern_name_in(s, ga, d.data.rec_.name);
        gkind = type.TYPE_REC;
    }
    or (d.kind == decl.DECL_KIND_UNI) {
        gname = intern_name_in(s, ga, d.data.uni_.name);
        gkind = type.TYPE_UNI;
    }
    or {
        ret type.TYPE_ERROR;
    }

    val res_nominal: R.Result[type.TypeId, str] = type.intern_nominal(?s.types, gname, origin, gdecl, gkind);
    if (R.is_err[type.TypeId, str](res_nominal)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](res_nominal);
}

# build and register `instance`'s field table by substituting each field of the
# generic nominal `gnom`'s table with `instance`'s concrete arguments
#
# This is the shared core behind both a top-level generic instance and a nested
# anonymous aggregate (a `uni {ok: T}` inside `Result[T, E]`), both of which
# intern to a TYPE_INSTANCE over the generic nominal. Nested substituted
# aggregates are materialized recursively via `substitute`. A no-op when `gnom`
# has no table or `instance` already has an up-to-date one.
# ---
# s:        the shared session (type universe, allocator)
# instance: the TYPE_INSTANCE whose field table is built
# gnom:     the generic nominal whose unsubstituted table is the template
fun build_instance_table(s: *session.Session, instance: type.TypeId, gnom: type.TypeId) {
    val opt_instance_table: O.Option[*type.FieldTable] = type.field_table_for(?s.types, instance);
    if (O.is_some[*type.FieldTable](opt_instance_table)) {
        if (O.unwrap[*type.FieldTable](opt_instance_table).epoch == type.field_epoch(?s.types)) { ret; }
    }

    val opt_generic_table: O.Option[*type.FieldTable] = type.field_table_for(?s.types, gnom);
    if (O.is_none[*type.FieldTable](opt_generic_table)) { ret; }
    val fields_len: u32 = O.unwrap[*type.FieldTable](opt_generic_table).fields_len;

    val opt_instance: O.Option[*type.Type] = type.get(?s.types, instance);
    if (O.is_none[*type.Type](opt_instance)) { ret; }
    val instance_type: *type.Type = O.unwrap[*type.Type](opt_instance);
    if (instance_type.kind != type.TYPE_INSTANCE) { ret; }
    val args_start: u32 = instance_type.data.instance.args_start;
    val args_len:   u32 = instance_type.data.instance.args_len;

    # copy the instance args out of the param pool; substitution may append to it
    # and invalidate a borrowed read.
    var args: *type.TypeId = nil;
    if (args_len > 0) {
        val res_alloc_args: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](s.alloc, args_len::usize);
        if (R.is_err[*type.TypeId, str](res_alloc_args)) { ret; }
        args = R.unwrap_ok[*type.TypeId, str](res_alloc_args);

        var i: u32 = 0;
        for (i < args_len) {
            val opt_arg: O.Option[type.TypeId] = type.get_param(?s.types, args_start + i);
            if (O.is_none[type.TypeId](opt_arg)) {
                A.deallocate[type.TypeId](s.alloc, args, args_len::usize);
                ret;
            }
            args[i] = O.unwrap[type.TypeId](opt_arg);
            i = i + 1;
        }
    }

    if (fields_len == 0) {
        type.field_table_begin(?s.types, instance);
        if (args_len > 0) { A.deallocate[type.TypeId](s.alloc, args, args_len::usize); }
        ret;
    }

    # substitute every field type into side buffers FIRST. a substituted field may
    # itself be a nested aggregate whose own table is built here (recursively); the
    # global field pool requires each table's fields to be pushed contiguously, so
    # all nested tables must be finished before this table's own fields are
    # appended.
    val res_alloc_types: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](s.alloc, fields_len::usize);
    if (R.is_err[*type.TypeId, str](res_alloc_types)) {
        if (args_len > 0) { A.deallocate[type.TypeId](s.alloc, args, args_len::usize); }
        ret;
    }
    val field_types: *type.TypeId = R.unwrap_ok[*type.TypeId, str](res_alloc_types);

    val res_alloc_names: R.Result[*intern.StrId, str] = A.allocate[intern.StrId](s.alloc, fields_len::usize);
    if (R.is_err[*intern.StrId, str](res_alloc_names)) {
        A.deallocate[type.TypeId](s.alloc, field_types, fields_len::usize);
        if (args_len > 0) { A.deallocate[type.TypeId](s.alloc, args, args_len::usize); }
        ret;
    }
    val field_names: *intern.StrId = R.unwrap_ok[*intern.StrId, str](res_alloc_names);

    var i: u32 = 0;
    for (i < fields_len) {
        val opt_entry: O.Option[*type.FieldEntry] = type.field_at(?s.types, gnom, i);
        if (O.is_none[*type.FieldEntry](opt_entry)) {
            field_names[i] = intern.STR_NIL;
            field_types[i] = type.TYPE_ERROR;
        }
        or {
            val entry: *type.FieldEntry = O.unwrap[*type.FieldEntry](opt_entry);
            field_names[i] = entry.name;
            field_types[i] = substitute(s, entry.ty, args, args_len);
        }
        i = i + 1;
    }

    # all nested tables are now complete; this table's own fields can be appended
    # contiguously. reserve the run first so the pushes below cannot grow the pool
    # and fail partway, which would leave a half-built table registered at the
    # current epoch; an allocation failure here leaves no table at all.
    val res_reserve: R.Result[bool, str] = type.field_table_reserve(?s.types, fields_len);
    if (R.is_err[bool, str](res_reserve)) {
        A.deallocate[intern.StrId](s.alloc, field_names, fields_len::usize);
        A.deallocate[type.TypeId](s.alloc, field_types, fields_len::usize);
        if (args_len > 0) { A.deallocate[type.TypeId](s.alloc, args, args_len::usize); }
        ret;
    }

    val res_table: R.Result[u32, str] = type.field_table_begin(?s.types, instance);
    if (R.is_ok[u32, str](res_table)) {
        val table: u32 = R.unwrap_ok[u32, str](res_table);
        i = 0;
        for (i < fields_len) {
            type.field_table_push(?s.types, table, field_names[i], field_types[i]);
            i = i + 1;
        }
    }

    A.deallocate[intern.StrId](s.alloc, field_names, fields_len::usize);
    A.deallocate[type.TypeId](s.alloc, field_types, fields_len::usize);
    if (args_len > 0) { A.deallocate[type.TypeId](s.alloc, args, args_len::usize); }
}

# rebuild a function type with each parameter and the return type substituted
#
# Reads the parameter sequence out of the interner's param pool into a fresh
# buffer before re-interning, since substitution may grow the pool and invalidate
# the original `*Type` pointer. Returns `original` unchanged when no position
# substituted.
# ---
# s:         the shared session (type universe, allocator)
# t:         the TYPE_FUN being rewritten
# args:      the concrete argument types, indexed by param ordinal
# arg_count: number of arguments
# original:  the function's own TypeId, returned when nothing changed
# ret:       the rebuilt function TypeId, or TYPE_ERROR on failure
fun substitute_fun(s: *session.Session, t: *type.Type, args: *type.TypeId, arg_count: u32, original: type.TypeId) type.TypeId {
    val original_ret: type.TypeId = t.data.fn.ret_type;
    val params_start: u32         = t.data.fn.params_start;
    val params_len:   u32         = t.data.fn.params_len;

    var changed:   bool         = false;
    var param_buf: *type.TypeId = nil;
    if (params_len > 0) {
        val res_alloc_params: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](s.alloc, params_len::usize);
        if (R.is_err[*type.TypeId, str](res_alloc_params)) { ret type.TYPE_ERROR; }
        param_buf = R.unwrap_ok[*type.TypeId, str](res_alloc_params);

        var i: u32 = 0;
        for (i < params_len) {
            val opt_param: O.Option[type.TypeId] = type.get_param(?s.types, params_start + i);
            if (O.is_none[type.TypeId](opt_param)) {
                A.deallocate[type.TypeId](s.alloc, param_buf, params_len::usize);
                ret type.TYPE_ERROR;
            }
            val original_param: type.TypeId = O.unwrap[type.TypeId](opt_param);
            param_buf[i] = substitute(s, original_param, args, arg_count);
            if (param_buf[i] != original_param) { changed = true; }
            i = i + 1;
        }
    }

    val new_ret: type.TypeId = substitute(s, original_ret, args, arg_count);
    if (new_ret != original_ret) { changed = true; }

    if (!changed) {
        if (params_len > 0) { A.deallocate[type.TypeId](s.alloc, param_buf, params_len::usize); }
        ret original;
    }

    val res_fun: R.Result[type.TypeId, str] = type.intern_function(?s.types, new_ret, param_buf, params_len);
    if (params_len > 0) { A.deallocate[type.TypeId](s.alloc, param_buf, params_len::usize); }
    ret unwrap_or_error(res_fun);
}

# rebuild a generic instance with each argument substituted
#
# Like substitute_fun, copies the argument sequence out of the param pool first so
# a pool growth during substitution cannot invalidate the read. Returns `original`
# unchanged when no argument substituted.
# ---
# s:         the shared session (type universe, allocator)
# t:         the TYPE_INSTANCE being rewritten
# args:      the concrete argument types, indexed by param ordinal
# arg_count: number of arguments
# original:  the instance's own TypeId, returned when nothing changed
# ret:       the rebuilt instance TypeId, or TYPE_ERROR on failure
fun substitute_instance(s: *session.Session, t: *type.Type, args: *type.TypeId, arg_count: u32, original: type.TypeId) type.TypeId {
    val origin:     session.ModuleId = t.data.instance.target_origin;
    val decl_id:    id.DeclId        = t.data.instance.target_decl;
    val args_start: u32              = t.data.instance.args_start;
    val args_len:   u32              = t.data.instance.args_len;

    if (args_len == 0) { ret original; }

    val res_alloc_args: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](s.alloc, args_len::usize);
    if (R.is_err[*type.TypeId, str](res_alloc_args)) { ret type.TYPE_ERROR; }
    val arg_buf: *type.TypeId = R.unwrap_ok[*type.TypeId, str](res_alloc_args);

    var changed: bool = false;
    var i:       u32  = 0;
    for (i < args_len) {
        val opt_arg: O.Option[type.TypeId] = type.get_param(?s.types, args_start + i);
        if (O.is_none[type.TypeId](opt_arg)) {
            A.deallocate[type.TypeId](s.alloc, arg_buf, args_len::usize);
            ret type.TYPE_ERROR;
        }
        val original_arg: type.TypeId = O.unwrap[type.TypeId](opt_arg);
        arg_buf[i] = substitute(s, original_arg, args, arg_count);
        if (arg_buf[i] != original_arg) { changed = true; }
        i = i + 1;
    }

    if (!changed) {
        A.deallocate[type.TypeId](s.alloc, arg_buf, args_len::usize);
        ret original;
    }

    val res_instance: R.Result[type.TypeId, str] = type.intern_instance(?s.types, origin, decl_id, arg_buf, args_len);
    A.deallocate[type.TypeId](s.alloc, arg_buf, args_len::usize);
    ret unwrap_or_error(res_instance);
}

# specialize a nested nominal aggregate that mentions generic parameters
#
# Interns a TYPE_INSTANCE over the aggregate's own (origin, decl) with the active
# argument sequence and eagerly materializes its substituted field table from the
# original nominal's table. The generic-param ordinals in the aggregate's fields
# are the enclosing declaration's, so the same `args` apply.
# ---
# s:         the shared session (type universe, allocator)
# t:         the nominal TYPE_REC / TYPE_UNI being specialized
# args:      the concrete argument types, indexed by param ordinal
# arg_count: number of arguments
# original:  the nominal's own TypeId, the template for its field table
# ret:       the specialized instance TypeId, or TYPE_ERROR on failure
fun substitute_aggregate(s: *session.Session, t: *type.Type, args: *type.TypeId, arg_count: u32, original: type.TypeId) type.TypeId {
    val origin:  session.ModuleId = t.data.nominal.origin;
    val decl_id: id.DeclId        = t.data.nominal.decl;

    val res_instance: R.Result[type.TypeId, str] = type.intern_instance(?s.types, origin, decl_id, args, arg_count);
    if (R.is_err[type.TypeId, str](res_instance)) { ret type.TYPE_ERROR; }
    val instance: type.TypeId = R.unwrap_ok[type.TypeId, str](res_instance);

    build_instance_table(s, instance, original);
    ret instance;
}

# whether the field table registered for nominal TypeId `tid` mentions any
# `TYPE_GENERIC_PARAM`
#
# Directly, or nested under a pointer, array, instance, or a further nominal. Such
# a nominal is part of an unspecialized generic body and must be substituted per
# instance; a fully concrete one need not be. A fresh cycle-guard scan bounds the
# search against recursive nominals.
# ---
# s:   the shared session (type universe, allocator)
# tid: the nominal TypeId to inspect
# ret: true when any field mentions a generic parameter
fun nominal_has_gparam(s: *session.Session, tid: type.TypeId) bool {
    var scan: GParamScan;
    scan.visited = nil;
    scan.len     = 0;
    scan.cap     = 0;

    val mentioned: bool = nominal_fields_mention(s, tid, ?scan);
    if (scan.visited != nil && scan.cap > 0) {
        A.deallocate[type.TypeId](s.alloc, scan.visited, scan.cap::usize);
    }
    ret mentioned;
}

# whether any field of nominal `tid` mentions a generic parameter
#
# Guards against recursive nominals via `scan`: a TypeId already on the search
# stack yields false here (its own frame examines every field), so a cycle cannot
# recurse forever. An allocation failure recording the visit degrades to true,
# forcing a harmless substitution attempt rather than risking a missed one.
# ---
# s:    the shared session (type universe, allocator)
# tid:  the nominal TypeId whose fields are scanned
# scan: the in-progress cycle guard
# ret:  true when a field mentions a generic parameter
fun nominal_fields_mention(s: *session.Session, tid: type.TypeId, scan: *GParamScan) bool {
    if (scan_contains(scan, tid)) { ret false; }
    if (!scan_push(s, scan, tid)) { ret true; }

    val opt_table: O.Option[*type.FieldTable] = type.field_table_for(?s.types, tid);
    if (O.is_none[*type.FieldTable](opt_table)) { ret false; }
    val fields_len: u32 = O.unwrap[*type.FieldTable](opt_table).fields_len;

    var i: u32 = 0;
    for (i < fields_len) {
        val opt_entry: O.Option[*type.FieldEntry] = type.field_at(?s.types, tid, i);
        if (O.is_some[*type.FieldEntry](opt_entry)) {
            if (mentions_gparam(s, O.unwrap[*type.FieldEntry](opt_entry).ty, scan)) { ret true; }
        }
        i = i + 1;
    }
    ret false;
}

# whether `tid` is, or structurally contains, a generic parameter
#
# Descends pointers, arrays, and instance arguments; a nested nominal is checked
# through its own field table (`nominal_fields_mention`), which carries the cycle
# guard so two-plus levels of nested anonymous aggregate are reached without
# unbounded recursion on a recursive nominal.
# ---
# s:    the shared session (type universe, allocator)
# tid:  the TypeId to inspect
# scan: the in-progress cycle guard
# ret:  true when `tid` mentions a generic parameter
fun mentions_gparam(s: *session.Session, tid: type.TypeId, scan: *GParamScan) bool {
    if (tid == type.TYPE_NIL || tid == type.TYPE_ERROR) { ret false; }

    val opt_type: O.Option[*type.Type] = type.get(?s.types, tid);
    if (O.is_none[*type.Type](opt_type)) { ret false; }
    val t: *type.Type = O.unwrap[*type.Type](opt_type);

    if (t.kind == type.TYPE_GENERIC_PARAM) { ret true; }
    if (t.kind == type.TYPE_POINTER)       { ret mentions_gparam(s, t.data.pointer.base, scan); }
    if (t.kind == type.TYPE_SECRET)        { ret mentions_gparam(s, t.data.secret.base, scan); }
    if (t.kind == type.TYPE_ARRAY)         { ret mentions_gparam(s, t.data.array.base, scan); }
    if (t.kind == type.TYPE_REC || t.kind == type.TYPE_UNI) {
        ret nominal_fields_mention(s, tid, scan);
    }

    if (t.kind == type.TYPE_INSTANCE) {
        val args_start: u32 = t.data.instance.args_start;
        val args_len:   u32 = t.data.instance.args_len;
        var i: u32 = 0;
        for (i < args_len) {
            val opt_arg: O.Option[type.TypeId] = type.get_param(?s.types, args_start + i);
            if (O.is_some[type.TypeId](opt_arg)) {
                if (mentions_gparam(s, O.unwrap[type.TypeId](opt_arg), scan)) { ret true; }
            }
            i = i + 1;
        }
    }
    ret false;
}

# whether nominal TypeId `tid` is already recorded in `scan`
# ---
# scan: the cycle guard to search
# tid:  the TypeId to look for
# ret:  true when `tid` is present
fun scan_contains(scan: *GParamScan, tid: type.TypeId) bool {
    var i: u32 = 0;
    for (i < scan.len) {
        if (scan.visited[i] == tid) { ret true; }
        i = i + 1;
    }
    ret false;
}

# record nominal TypeId `tid` in `scan`, growing the backing array as needed
# ---
# s:    the shared session (allocator)
# scan: the cycle guard to extend
# tid:  the TypeId to record
# ret:  true on success, false only on an allocation failure
fun scan_push(s: *session.Session, scan: *GParamScan, tid: type.TypeId) bool {
    if (scan.len == scan.cap) {
        var new_cap: u32 = scan.cap * 2;
        if (new_cap == 0) { new_cap = 8; }

        if (scan.visited == nil) {
            val res_alloc: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](s.alloc, new_cap::usize);
            if (R.is_err[*type.TypeId, str](res_alloc)) { ret false; }
            scan.visited = R.unwrap_ok[*type.TypeId, str](res_alloc);
        }
        or {
            val res_realloc: R.Result[*type.TypeId, str] = A.reallocate[type.TypeId](s.alloc, scan.visited, scan.cap::usize, new_cap::usize);
            if (R.is_err[*type.TypeId, str](res_realloc)) { ret false; }
            scan.visited = R.unwrap_ok[*type.TypeId, str](res_realloc);
        }

        scan.cap = new_cap;
    }

    scan.visited[scan.len] = tid;
    scan.len = scan.len + 1;
    ret true;
}

# intern the identifier text of a name `span` taken from module `ga`'s source
#
# The generic nominal must be re-interned under exactly the name its declaring
# module used, so the text is read from that module's source (via the session
# source map keyed by `ga.file_id`), not the current module's.
# ---
# s:    the shared session (sources, interner)
# ga:   the AST of the module the name belongs to
# span: the source range of the identifier
# ret:  the interned StrId, or STR_NIL when the source or interning fails
fun intern_name_in(s: *session.Session, ga: *ast.Ast, span: token.Span) intern.StrId {
    val opt_source: O.Option[*source.SourceFile] = source.get(?s.sources, ga.file_id);
    if (O.is_none[*source.SourceFile](opt_source)) { ret intern.STR_NIL; }
    val text: str = O.unwrap[*source.SourceFile](opt_source).text;

    val res_intern: R.Result[intern.StrId, str] = intern.intern_span(?s.interner, text, span);
    if (R.is_err[intern.StrId, str](res_intern)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](res_intern);
}

# the generic-parameter count of a declaration in AST `a`, or none when the
# declaration cannot carry generic parameters
#
# Only `fun`, `rec`, and `uni` declarations are generic-capable. A zero count is a
# valid `some(0)`: the named decl exists but is not parameterized, which
# `check_arity` reports as a mismatch when args were supplied. `a` is the
# declaring module's AST, so the same check serves a local or a cross-module
# generic.
# ---
# a:       the declaring module's AST
# decl_id: the declaration to inspect
# ret:     some(count) for a generic-capable decl, none otherwise
fun generic_count_in(a: *ast.Ast, decl_id: id.DeclId) O.Option[u32] {
    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(a, decl_id);
    if (O.is_none[*decl.Decl](opt_decl)) { ret O.none[u32](); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_decl);

    if (d.kind == decl.DECL_KIND_FUN) { ret O.some[u32](d.data.fun_.generics_len); }
    if (d.kind == decl.DECL_KIND_REC) { ret O.some[u32](d.data.rec_.generics_len); }
    if (d.kind == decl.DECL_KIND_UNI) { ret O.some[u32](d.data.uni_.generics_len); }
    ret O.none[u32]();
}

# unwrap an intern result to its TypeId, mapping an allocation error to the poison
# type so a structural rebuild degrades instead of propagating
# ---
# res: the intern result to unwrap
# ret: the interned TypeId, or TYPE_ERROR on error
fun unwrap_or_error(res: R.Result[type.TypeId, str]) type.TypeId {
    if (R.is_err[type.TypeId, str](res)) { ret type.TYPE_ERROR; }
    ret R.unwrap_ok[type.TypeId, str](res);
}

# report a `<prefix>: expected <E>, found <A>` diagnostic naming the declared and
# supplied type-argument counts
#
# Any allocation failure degrades to the static `prefix` text so the error is
# always reported.
# ---
# sc:       the active sema context
# span:     source range for the diagnostic
# prefix:   text before the counts
# expected: the declared type-parameter count
# actual:   the supplied type-argument count
fun report_type_arg_count(sc: *sema.SemaContext, span: token.Span, prefix: str, expected: u32, actual: u32) {
    val res_msg: R.Result[str, str] = format.sprint(sc.s.alloc, "{}: expected {}, found {}", prefix, expected::usize, actual::usize);
    if (R.is_err[str, str](res_msg)) {
        sema.report(sc, span, prefix);
        ret;
    }
    val msg: str = R.unwrap_ok[str, str](res_msg);
    sema.report(sc, span, msg);
    A.deallocate[char](sc.s.alloc, msg, str_len(msg) + 1);
}
