# mach.lang.fe.sema.coerce: literal coercion and assignability rules.
#
# Mach is explicit-everything: there is no implicit numeric widening
# between variables, no implicit float<->int conversion, no pointer-base
# widening, no automatic deref or address-of, and no mutability coercion.
# the only implicit conversion the language permits is fixing an untyped
# literal to the concrete type demanded by its surrounding context.
#
# `try_coerce_literal` retypes a literal expression to a requested
# destination type when the literal can legally take that type (an integer
# literal to any integer the value fits, a float literal to f32/f64, a nil
# literal to any pointer-like type — `ptr`, `*T`, or `fun(...)`), rewriting
# the expression's entry in the parallel `expr_type` array so downstream
# phases observe the coerced type.
# `is_assignable` is identity-only: two types are assignable iff their
# interned `TypeId`s are equal. the type interner canonicalizes every
# compound type (pointers, arrays, nominals, instances) so identity of
# `TypeId`s is the complete assignability relation for non-literals.
# function-type identity additionally falls back to structural signature
# equality, since function types are not deduplicated.

use std.types.bool.bool;
use std.types.size.usize;
use std.types.bool.true;
use std.types.bool.false;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_none;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.is_err;
use std.types.result.unwrap_ok;

use ty:       mach.lang.type;
use ast:      mach.lang.fe.ast;
use id:       mach.lang.fe.ast.id;
use expr:     mach.lang.fe.ast.expr;
use comptime: mach.lang.fe.comptime;
use sema:     mach.lang.fe.sema.context;

# attempts to fix an untyped literal expression to a requested destination
# type. only literal expressions whose form admits the destination are
# coerced; on success the expression's entry in `sc.expr_type` is rewritten
# to `to` and `some(to)` is returned. all other expressions (including
# already-typed variable references) return `none`, because Mach performs
# no implicit widening between typed values.
#
# coercion descends through the value-preserving arithmetic/bitwise operators
# that wrap a literal: a unary `-`/`~` operand and the operands of binary
# arithmetic/bitwise operators are themselves coercion targets, mirroring the
# way these nodes adopt their operand type during inference. so a folded or
# negated literal such as `-1` or `1 << 3` takes its surrounding context type
# just as a bare literal does. a unary `-` additionally flips the sign domain
# used to range-check its inner integer literal, so `-1` legally takes a
# signed type narrower than i64.
#
# accepted coercions:
#   - integer / char literal -> any integer primitive that can hold the
#     literal's value (range-checked against the destination width and
#     signedness)
#   - float literal -> f32 or f64
#   - nil literal -> any pointer-like type (raw `ptr`, `*T`, or `fun(...)`)
#   - unary -/~ over a coercible operand -> the coerced operand type
#   - binary arithmetic/bitwise over coercible operands -> the coerced type
# ---
# sc:  the active sema context
# eid: the expression being coerced (must index sc.a.exprs)
# to:  the destination TypeId the surrounding context requires
# ret: some(to) when the literal legally takes `to` (and expr_type[eid] is
#      updated), none when no literal coercion applies
pub fun try_coerce_literal(sc: *sema.SemaContext, eid: id.ExprId, to: ty.TypeId) Option[ty.TypeId] {
    if (to == ty.TYPE_NIL || to == ty.TYPE_ERROR) { ret none[ty.TypeId](); }
    ret coerce_to(sc, eid, to, false);
}

# recursive core of try_coerce_literal. `negated` is set when an odd number of
# unary `-` operators enclose the expression, so a leaf integer literal is
# range-checked against the signed negative domain of `to`.
fun coerce_to(sc: *sema.SemaContext, eid: id.ExprId, to: ty.TypeId, negated: bool) Option[ty.TypeId] {
    if (eid == id.EXPR_NIL) { ret none[ty.TypeId](); }

    val e_opt: Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (is_none[*expr.Expr](e_opt)) { ret none[ty.TypeId](); }
    val e: *expr.Expr = unwrap[*expr.Expr](e_opt);

    if (e.kind == expr.EXPR_KIND_LIT_INT) {
        if (!int_literal_fits(sc, e.data.lit_int, to, negated)) { ret none[ty.TypeId](); }
        ret commit(sc, eid, to);
    }
    if (e.kind == expr.EXPR_KIND_LIT_CHAR) {
        if (!int_literal_fits(sc, e.data.lit_char::u64, to, negated)) { ret none[ty.TypeId](); }
        ret commit(sc, eid, to);
    }
    if (e.kind == expr.EXPR_KIND_LIT_FLOAT) {
        if (to != ty.TYPE_F32 && to != ty.TYPE_F64) { ret none[ty.TypeId](); }
        ret commit(sc, eid, to);
    }
    if (e.kind == expr.EXPR_KIND_LIT_NIL) {
        # nil is the null address; it takes any pointer-like type — a raw `ptr`,
        # a typed `*T`, or a `fun(...)` (a function value is a code address, so
        # the null address is a valid null callback). `fn == nil` / `fn != nil`
        # are still related as comparisons in `infer_binary`, independently of
        # this coercion.
        if (!ty.is_pointer_like(?sc.s.types, to)) { ret none[ty.TypeId](); }
        ret commit(sc, eid, to);
    }
    if (e.kind == expr.EXPR_KIND_COMPTIME_IDENT || e.kind == expr.EXPR_KIND_MEMBER) {
        ret coerce_comptime_int_path(sc, eid, to, negated);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret coerce_unary(sc, eid, ?e.data.unary, to, negated);
    }
    if (e.kind == expr.EXPR_KIND_BINARY) {
        ret coerce_binary(sc, eid, ?e.data.binary, to, negated);
    }

    ret none[ty.TypeId]();
}

# coerces a comptime path that folds to an integer (`$mach.build.os`, ...)
# to a destination integer type, mirroring an integer literal: the folded
# value is range-checked against the destination width/signedness, and on a
# fit the path's expr_type slot is committed to `to`. a path that is not a
# comptime path or does not fold to an integer yields none, so it is treated
# as an ordinary (non-coercible) expression.
fun coerce_comptime_int_path(sc: *sema.SemaContext, eid: id.ExprId, to: ty.TypeId, negated: bool) Option[ty.TypeId] {
    if (!comptime.is_comptime_path(sc.a, eid)) { ret none[ty.TypeId](); }
    val ev: Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
    if (is_err[comptime.CTValue, str](ev)) { ret none[ty.TypeId](); }
    val cv: comptime.CTValue = unwrap_ok[comptime.CTValue, str](ev);
    if (cv.kind != comptime.CT_KIND_INT) { ret none[ty.TypeId](); }
    if (!int_literal_fits(sc, cv.data.i::u64, to, negated)) { ret none[ty.TypeId](); }
    ret commit(sc, eid, to);
}

# coerces a unary `-`/`~` node by coercing its operand to `to`; `+`-domain
# operators (`!`, `&`, `*`) wrap typed results, not untyped literals, so they
# are not coercion-transparent. a `-` flips the negation domain for the
# operand's range check. on success the unary node itself is retyped to `to`.
fun coerce_unary(sc: *sema.SemaContext, eid: id.ExprId, u: *expr.ExprUnary, to: ty.TypeId, negated: bool) Option[ty.TypeId] {
    if (u.op != expr.UN_NEG && u.op != expr.UN_BIT_NOT) { ret none[ty.TypeId](); }
    var operand_negated: bool = negated;
    if (u.op == expr.UN_NEG) { operand_negated = !negated; }
    val co: Option[ty.TypeId] = coerce_to(sc, u.operand, to, operand_negated);
    if (is_none[ty.TypeId](co)) { ret none[ty.TypeId](); }
    ret commit(sc, eid, to);
}

# coerces a binary arithmetic/bitwise node by coercing both operands to `to`;
# comparison, logical, and assignment operators yield fixed or independent
# result types and are not coercion-transparent. the negation domain does not
# cross a binary operator (each operand carries its own literal sign), so the
# operands are coerced in the non-negated domain. on success the binary node
# itself is retyped to `to`.
fun coerce_binary(sc: *sema.SemaContext, eid: id.ExprId, b: *expr.ExprBinary, to: ty.TypeId, negated: bool) Option[ty.TypeId] {
    if (!is_value_preserving_binop(b.op)) { ret none[ty.TypeId](); }
    val cl: Option[ty.TypeId] = coerce_to(sc, b.lhs, to, false);
    if (is_none[ty.TypeId](cl)) { ret none[ty.TypeId](); }
    val cr: Option[ty.TypeId] = coerce_to(sc, b.rhs, to, false);
    if (is_none[ty.TypeId](cr)) { ret none[ty.TypeId](); }
    ret commit(sc, eid, to);
}

# reports whether a binary operator yields its operand type (arithmetic and
# bitwise ops), as opposed to a fixed boolean (comparisons, logical) or an
# lvalue result (assignment). only the former propagate a literal's coerced
# type to the operation node.
fun is_value_preserving_binop(op: expr.BinOp) bool {
    if (op == expr.BIN_ADD || op == expr.BIN_SUB || op == expr.BIN_MUL
        || op == expr.BIN_DIV || op == expr.BIN_MOD) { ret true; }
    if (op == expr.BIN_BIT_AND || op == expr.BIN_BIT_OR || op == expr.BIN_BIT_XOR
        || op == expr.BIN_SHL || op == expr.BIN_SHR) { ret true; }
    ret false;
}

# reports whether a value of type `from` may be assigned to a slot of type
# `to` without any conversion. assignability is identity of interned TypeIds;
# the interner canonicalizes pointers, arrays, nominals, and instances so
# identical structure always yields the same TypeId. function types are not
# deduplicated, so a structural signature comparison is the fallback when both
# operands are function types. the one structural relaxation is the raw
# pointer rule: the untyped `ptr` and any typed `*T` are mutually assignable,
# since `ptr` is the language's type-erased pointer (`*T` flows into a `ptr`
# slot and a `ptr` flows back into a `*T` slot without a cast). no other
# widening, no float<->int, no pointer-base widening, no deref/addr/mutability
# coercion is ever performed here. an error type on either side is treated as
# assignable so a single upstream failure does not cascade.
# ---
# sc:   the active sema context
# from: the source value's type
# to:   the destination slot's type
# ret:  true when `from` and `to` denote the same type
pub fun is_assignable(sc: *sema.SemaContext, from: ty.TypeId, to: ty.TypeId) bool {
    if (from == to) { ret true; }
    if (from == ty.TYPE_ERROR || to == ty.TYPE_ERROR) { ret true; }
    if (ptr_compatible(sc, from, to)) { ret true; }
    ret ty.type_equals_signatures(?sc.s.types, from, to);
}

# reports whether `from` and `to` are a raw `ptr` paired with a typed `*T` in
# either direction. the untyped `ptr` is type-erased, so it interconverts with
# any typed pointer without a cast; two distinct typed pointers remain
# unrelated (only `from == to` matches those).
fun ptr_compatible(sc: *sema.SemaContext, from: ty.TypeId, to: ty.TypeId) bool {
    if (from == ty.TYPE_PTR && is_typed_pointer(sc, to)) { ret true; }
    if (to == ty.TYPE_PTR && is_typed_pointer(sc, from)) { ret true; }
    ret false;
}

# reports whether `t` is an interned `*T` pointer (TYPE_POINTER), as opposed to
# the raw `ptr` primitive or a non-pointer.
fun is_typed_pointer(sc: *sema.SemaContext, t: ty.TypeId) bool {
    val to_opt: Option[*ty.Type] = ty.get(?sc.s.types, t);
    if (is_none[*ty.Type](to_opt)) { ret false; }
    ret unwrap[*ty.Type](to_opt).kind == ty.TYPE_POINTER;
}

# rewrites expr_type[eid] to the coerced type and returns some(to).
fun commit(sc: *sema.SemaContext, eid: id.ExprId, to: ty.TypeId) Option[ty.TypeId] {
    if (sc.expr_type != nil && eid::usize < sc.a.expr_len) {
        sc.expr_type[eid] = to;
    }
    ret some[ty.TypeId](to);
}

# reports whether `to` is an integer primitive that can hold the literal whose
# unsigned magnitude is `v`. `negated` indicates the literal appears under an
# odd number of unary `-`, so a signed destination is checked against its
# negative bound (|min| = max+1) rather than its positive maximum; a negated
# literal never targets an unsigned destination. unsigned destinations are
# checked against their unsigned maximum, non-negated signed destinations
# against their signed maximum. non-integer destinations never fit.
fun int_literal_fits(sc: *sema.SemaContext, v: u64, to: ty.TypeId, negated: bool) bool {
    val to_opt: Option[*ty.Type] = ty.get(?sc.s.types, to);
    if (is_none[*ty.Type](to_opt)) { ret false; }
    val k: ty.TypeKind = unwrap[*ty.Type](to_opt).kind;
    if (negated) {
        if (k == ty.TYPE_I8)  { ret v <= 0x80; }
        if (k == ty.TYPE_I16) { ret v <= 0x8000; }
        if (k == ty.TYPE_I32) { ret v <= 0x80000000; }
        if (k == ty.TYPE_I64) { ret v <= 0x8000000000000000; }
        ret false;
    }
    if (k == ty.TYPE_U8)  { ret v <= 0xFF; }
    if (k == ty.TYPE_U16) { ret v <= 0xFFFF; }
    if (k == ty.TYPE_U32) { ret v <= 0xFFFFFFFF; }
    if (k == ty.TYPE_U64) { ret true; }
    if (k == ty.TYPE_I8)  { ret v <= 0x7F; }
    if (k == ty.TYPE_I16) { ret v <= 0x7FFF; }
    if (k == ty.TYPE_I32) { ret v <= 0x7FFFFFFF; }
    if (k == ty.TYPE_I64) { ret v <= 0x7FFFFFFFFFFFFFFF; }
    ret false;
}
