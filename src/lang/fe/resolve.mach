# per-module name resolution
#
# walks one parsed Ast in two passes:
#
#   1. collect - registers a Symbol for every binding decl reachable from
#      module scope, evaluating `$if` predicates via the comptime evaluator
#      and binding comptime-evaluable module-level val initializers into the
#      comptime module frame (idempotent against the driver's load-pass
#      binding). `use` decls bind a single leaf name into the module scope (a
#      module alias when the path ends at a module, a symbol binding when it
#      ends at a pub symbol).
#   2. bind - walks every decl, stmt, expr, and type, looking up name
#      references against the scope chain and writing the resolved SymbolId
#      into parallel arrays sized to the AST. `fwd` decls are resolved here and
#      re-published into this module's pub surface.
#
# unresolved names become SYMBOL_NIL and emit an error diagnostic but do not
# halt the pass; sema treats SYMBOL_NIL bindings as having an error type that
# absorbs further operations.

use std.collections.map;
use std.memory;
use std.text.string.str_free;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.char.char;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.module;
use mach.lang.fe.ast.stmt;
use atype: mach.lang.fe.ast.type;
use mach.lang.fe.comptime;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.session;
use src: mach.lang.source;
use mach.lang.type;

# identifier for a Symbol within one ResolveResult / ResolveContext
pub def SymbolId: u32;

# sentinel value marking an absent or unresolved symbol
pub val SYMBOL_NIL: SymbolId = 0xFFFFFFFF;

# kind of a resolved Symbol
pub def SymKind: u8;

# the SymKind variants a resolved symbol may take
pub val SYM_FUN:      SymKind = 0;
pub val SYM_REC:      SymKind = 1;
pub val SYM_DEF:      SymKind = 2;
pub val SYM_VAL:      SymKind = 3;
pub val SYM_VAR:      SymKind = 4;
pub val SYM_PARAM:    SymKind = 5;
pub val SYM_GENERIC:  SymKind = 6;
pub val SYM_USE:      SymKind = 7;
pub val SYM_IMPORTED: SymKind = 8;
pub val SYM_TEST:     SymKind = 9;
pub val SYM_UNI:      SymKind = 10;
pub val SYM_PRIM:     SymKind = 11;

# pub-flag bit, set when the symbol's source decl is `pub`, or when it is
# re-exported by `fwd`
pub val SYM_FLAG_PUB: u8 = 1;

# comptime-flag bit, set on a SYM_PARAM declared with a leading `$`
# (a comptime value parameter)
pub val SYM_FLAG_COMPTIME: u8 = 2;

# module-scope bit, set on every symbol declared at module
# scope. distinguishes a module-level `val` (a comptime-foldable constant whose
# name is unique in its module) from a block-local `val` that merely shares a
# name with one, so the comptime-gate check folds on resolution identity rather
# than on name text a shadowing local would spuriously satisfy
pub val SYM_FLAG_MODULE: u8 = 4;

# a resolved symbol
# ---
# kind:   one of SYM_*
# flags:  bitfield of SYM_FLAG_*
# name:   interned identifier (STR_NIL for anonymous symbols)
# decl:   originating DeclId in `origin`'s Ast (DECL_NIL when synthetic)
# slot:   kind-dependent extra payload; param index for SYM_PARAM, generic
#         index for SYM_GENERIC, target ModuleId for SYM_USE, the primitive
#         TypeKind ordinal for SYM_PRIM, otherwise 0
# origin: ModuleId of the module that owns `decl` (this module for locally
#         declared symbols, the dependency for SYM_USE / SYM_IMPORTED)
# origin_stable: build-stable identity of `origin`, captured at resolve time. a
#         ResolveResult reused across builds carries the per-build `origin` of the
#         build that produced it; remap_result rewrites `origin` from this stable
#         snapshot into the new build's ModuleId space (#1582). STABLE_MODULE_NIL
#         when origin is MODULE_NIL or has no stable id
# slot_stable: build-stable identity of the SYM_USE target `slot` names, the slot's
#         twin of origin_stable. STABLE_MODULE_NIL for every non-SYM_USE symbol
#         (their slot is an index, not a ModuleId, and is build-independent)
pub rec Symbol {
    kind:   SymKind;
    flags:  u8;
    name:   intern.StrId;
    decl:   id.DeclId;
    slot:   u32;
    origin: session.ModuleId;
    origin_stable: session.StableModuleId;
    slot_stable:   session.StableModuleId;
}

# a snapshot of one pub symbol, copied by the driver into a dependent
# module's ResolveDeps so resolve can bind cross-module references
# ---
# kind:   one of SYM_*
# name:   interned identifier
# decl:   DeclId in the owning module's Ast
# slot:   kind-dependent payload, mirrored from the source Symbol; for a
#         re-exported module alias (SYM_USE) it carries the target ModuleId so a
#         downstream consumer can resolve through the `fwd`
# origin: ModuleId of the owning module (= the dep this entry came from)
pub rec PublicSymbol {
    kind:   SymKind;
    name:   intern.StrId;
    decl:   id.DeclId;
    slot:   u32;
    origin: session.ModuleId;
}

# the public surface of one module, indexed by interned path text, produced
# by the driver from a previously resolved module's ResolveResult
# ---
# path:    interned FQN of the module (e.g. "std.types.bool")
# module:  ModuleId of the module
# symbols: array of pub symbols
# count:   number of entries in symbols
pub rec ModuleExports {
    path:    intern.StrId;
    module:  session.ModuleId;
    symbols: *PublicSymbol;
    count:   u32;
}

# every dependency's exports, supplied by the driver; resolve looks these up
# by interned path when handling `use` decls
# ---
# entries: array of ModuleExports records, one per loaded dep
# count:   number of entries
pub rec ResolveDeps {
    entries: *ModuleExports;
    count:   u32;
}

# parallel scope-chain identifier
def ScopeId: u32;
val SCOPE_NIL: ScopeId = 0xFFFFFFFF;

rec ScopeEntry {
    name: intern.StrId;
    sym:  SymbolId;
}

rec Scope {
    parent:  ScopeId;
    entries: *ScopeEntry;
    len:     u32;
    cap:     u32;
}

val INITIAL_SCOPE_ENTRY_CAP: u32 = 8;
val INITIAL_SCOPES_CAP:      u32 = 8;
val INITIAL_SYMBOLS_CAP:     u32 = 32;

# resolve's working state for one module
rec ResolveContext {
    s:          *session.Session;
    a:          *ast.Ast;
    deps:       *ResolveDeps;
    ctx:        *comptime.ComptimeCtx;
    own_module: session.ModuleId;
    source:     str;

    symbols:    *Symbol;
    sym_len:    u32;
    sym_cap:    u32;

    expr_resolved: *SymbolId;
    type_resolved: *SymbolId;
    decl_symbol:   *SymbolId;

    scopes:        *Scope;
    scope_len:     u32;
    scope_cap:     u32;

    module_scope:  ScopeId;
    current_scope: ScopeId;

    # primitive type registry: the SYM_PRIM symbols for u8..f64 / ptr, keyed by
    # interned name. primitives are recognised in type position only (never bound
    # into a value scope), so a module may declare a value named `u32` without
    # colliding with the primitive type spelling.
    prim_names: [11]intern.StrId;
    prim_syms:  [11]SymbolId;

    # caches (origin << 32 | decl) -> SymbolId for already-created
    # SYM_IMPORTED entries, so repeated `print.println` use-sites share one
    # Symbol instead of inflating the symbol table per reference.
    imported_cache: map.Map[u64, SymbolId];

    # name -> SymbolId index for the module scope only. the module/top-level scope
    # can hold many symbols and every chain lookup ends there, so a linear scan made
    # name binding ~O(references * module-symbols). kept in lockstep with the module
    # scope's entries in scope_add; lookups route through it in scope_lookup_local.
    # block scopes stay linear (small, not worth a map). the module scope never holds
    # duplicate names (every add is guarded by a lookup), so a single entry per name
    # matches the first-match the scan would have returned.
    module_index: map.Map[intern.StrId, SymbolId];
}

# number of primitive type names (u8..f64, ptr)
val PRIM_COUNT: u32 = 11;

# the contract resolve produces for sema and the driver's export step
# ---
# alloc:         allocator backing all owned arrays
# symbols:       universe of symbols; pub symbols sorted to indices [0, pub_count)
# symbol_count:  total number of symbols
# pub_count:     number of pub symbols at the front of `symbols`
# expr_resolved: parallel to ast.exprs; SYMBOL_NIL outside binding sites
# type_resolved: parallel to ast.types; SYMBOL_NIL outside binding sites
# decl_symbol:   parallel to ast.decls; SYMBOL_NIL for non-binding decls
# expr_count:    length of expr_resolved (= ast.expr_len), for teardown
# type_count:    length of type_resolved (= ast.type_len), for teardown
# decl_count:    length of decl_symbol (= ast.decl_len), for teardown
# param_index:   (decl::u64 << 32 | slot) -> SymbolId for every SYM_PARAM, so a
#                consumer resolves a function parameter by (owning decl, ordinal)
#                in O(1) instead of scanning the whole symbol universe per param
# pub_const_fp:  owned byte fingerprint of this module's pub module-level comptime
#                constant VALUES (name + evaluated CTValue), in pub-symbol order. an
#                importer's resolution forks on these via `$if` over imported
#                consts, but the values live in the comptime ctx, not in the symbol
#                identities - so Q_EXPORTS folds this blob into the firewall
#                fingerprint to re-resolve importers when a dep's const value (even
#                a transitively-derived one) changes (#1582). nil/0 when none
# pub_const_fp_len: length of pub_const_fp in bytes
pub rec ResolveResult {
    alloc:         *A.Allocator;
    symbols:       *Symbol;
    symbol_count:  u32;
    pub_count:     u32;
    expr_resolved: *SymbolId;
    type_resolved: *SymbolId;
    decl_symbol:   *SymbolId;
    expr_count:    u32;
    type_count:    u32;
    decl_count:    u32;

    param_index:   map.Map[u64, SymbolId];

    pub_const_fp:     *u8;
    pub_const_fp_len: u32;
}

# the SymbolId of function `decl`'s parameter at ordinal `slot`,
# or SYMBOL_NIL when no such parameter exists. resolves through `param_index`
# in O(1)
# ---
# r:    the resolve result
# decl: the function declaration owning the parameter
# slot: the parameter ordinal
# ret:  the parameter's SymbolId, or SYMBOL_NIL
pub fun param_symbol(r: *ResolveResult, decl: id.DeclId, slot: u32) SymbolId {
    var key: u64 = (decl::u64 << 32) | slot::u64;
    val g: R.Result[*SymbolId, str] = map.get[u64, SymbolId](?r.param_index, ?key);
    if (R.is_ok[*SymbolId, str](g)) { ret @R.unwrap_ok[*SymbolId, str](g); }
    ret SYMBOL_NIL;
}

# the build-stable identity of ModuleId `mid` on session `s`, or
# STABLE_MODULE_NIL when `mid` is MODULE_NIL or names no registered module. resolve
# runs after register_module_asts, so every loaded module's FQN and stable id are
# already present; a lookup miss therefore means a synthetic/absent origin
# ---
# s:   the session resolve is running against
# mid: the per-build module id to translate
# ret: mid's build-stable id, or STABLE_MODULE_NIL when absent
fun stable_of_module(s: *session.Session, mid: session.ModuleId) session.StableModuleId {
    if (mid == session.MODULE_NIL) { ret session.STABLE_MODULE_NIL; }
    val fqn: intern.StrId = session.module_fqn(s, mid);
    if (fqn == intern.STR_NIL) { ret session.STABLE_MODULE_NIL; }
    ret session.stable_module_id_lookup(s, fqn);
}

# rewrite every ModuleId-valued field of `r` from the build-stable
# snapshot captured at resolve time into session `s`'s CURRENT per-build ModuleId
# numbering. the cross-build-reuse correctness step (#1582): a ResolveResult reused
# from an earlier build still carries that build's `origin` / SYM_USE `slot`
# ModuleIds, which a graph reshape may have renumbered. driven once per build by the
# driver after fetching the (possibly reused) result; idempotent - a freshly
# computed result already holds the current build's mids, and re-deriving them from
# the immutable stable snapshot reproduces the same values. every ModuleId-valued
# field is covered: Symbol.origin (all symbols) and Symbol.slot (SYM_USE only)
# ---
# r: the result to remap in place
# s: the session whose per-build StableModuleId -> ModuleId map drives the rewrite
pub fun remap_result(r: *ResolveResult, s: *session.Session) {
    if (r == nil || r.symbols == nil) { ret; }
    var i: u32 = 0;
    for (i < r.symbol_count) {
        val sym: *Symbol = ?r.symbols[i];
        sym.origin = session.module_id_for_stable(s, sym.origin_stable);
        if (sym.kind == SYM_USE) {
            sym.slot = session.module_id_for_stable(s, sym.slot_stable)::u32;
        }
        i = i + 1;
    }
}

# releases every array owned by the result and zeroes its fields
# ---
# r: result to tear down
pub fun dnit_result(r: *ResolveResult) {
    if (r == nil) { ret; }
    if (r.symbols != nil && r.symbol_count > 0) {
        A.deallocate[Symbol](r.alloc, r.symbols, r.symbol_count::usize);
    }
    if (r.expr_resolved != nil) {
        A.deallocate[SymbolId](r.alloc, r.expr_resolved, r.expr_count::usize);
    }
    if (r.type_resolved != nil) {
        A.deallocate[SymbolId](r.alloc, r.type_resolved, r.type_count::usize);
    }
    if (r.decl_symbol != nil) {
        A.deallocate[SymbolId](r.alloc, r.decl_symbol, r.decl_count::usize);
    }
    if (r.pub_const_fp != nil && r.pub_const_fp_len > 0) {
        A.deallocate[u8](r.alloc, r.pub_const_fp, r.pub_const_fp_len::usize);
    }
    map.dnit[u64, SymbolId](?r.param_index);
    r.symbols       = nil;
    r.symbol_count  = 0;
    r.pub_count     = 0;
    r.expr_resolved = nil;
    r.type_resolved = nil;
    r.decl_symbol   = nil;
    r.expr_count    = 0;
    r.type_count    = 0;
    r.decl_count    = 0;
    r.pub_const_fp     = nil;
    r.pub_const_fp_len = 0;
}

# resolves one module against its already-resolved dependencies
# ---
# s:          shared session (allocator, sources, diagnostics, interner)
# a:          parsed Ast for the module being resolved
# deps:       exports of every dependency, populated by the driver
# ctx:        comptime evaluator context, pre-populated by the driver with
#             target params and imported comptime constants. resolve mutates
#             it as it discovers comptime-evaluable val decls in this module
# own_module: project-wide ModuleId of the module being resolved
# ret:        the populated ResolveResult, or an allocation error
pub fun resolve(
    s:          *session.Session,
    a:          *ast.Ast,
    deps:       *ResolveDeps,
    ctx:        *comptime.ComptimeCtx,
    own_module: session.ModuleId
) R.Result[ResolveResult, str] {
    var rc: ResolveContext;
    val init_r: R.Result[bool, str] = init_context(?rc, s, a, deps, ctx, own_module);
    if (R.is_err[bool, str](init_r)) {
        ret R.err[ResolveResult, str](R.unwrap_err[bool, str](init_r));
    }

    val ms_r: R.Result[ScopeId, str] = open_scope(?rc, SCOPE_NIL);
    if (R.is_err[ScopeId, str](ms_r)) {
        dnit_context(?rc);
        ret R.err[ResolveResult, str](R.unwrap_err[ScopeId, str](ms_r));
    }
    rc.module_scope  = R.unwrap_ok[ScopeId, str](ms_r);
    rc.current_scope = rc.module_scope;

    val sp_r: R.Result[bool, str] = seed_primitives(?rc);
    if (R.is_err[bool, str](sp_r)) {
        dnit_context(?rc);
        ret R.err[ResolveResult, str](R.unwrap_err[bool, str](sp_r));
    }

    val m_opt: O.Option[*module.Module] = ast.get_module(a, a.root_module);
    if (O.is_none[*module.Module](m_opt)) {
        dnit_context(?rc);
        ret R.err[ResolveResult, str]("root_module is not set on this Ast");
    }
    val mnode: *module.Module = O.unwrap[*module.Module](m_opt);

    val c1: R.Result[bool, str] = collect_decl_list(?rc, mnode.decls_start, mnode.decls_len, rc.module_scope, true);
    if (R.is_err[bool, str](c1)) {
        dnit_context(?rc);
        ret R.err[ResolveResult, str](R.unwrap_err[bool, str](c1));
    }

    val b1: R.Result[bool, str] = bind_decl_list(?rc, mnode.decls_start, mnode.decls_len);
    if (R.is_err[bool, str](b1)) {
        dnit_context(?rc);
        ret R.err[ResolveResult, str](R.unwrap_err[bool, str](b1));
    }

    ret build_result(?rc);
}

# populate `rc` for resolving one module, allocating its side tables
# ---
# rc:         the context to populate
# s:          the shared session
# a:          the parsed Ast to resolve
# deps:       the dependency exports supplied by the driver
# ctx:        the comptime evaluator context
# own_module: project-wide module id of this module
# ret:        ok(true) once populated, or an allocation error (rc is torn down)
fun init_context(
    rc:         *ResolveContext,
    s:          *session.Session,
    a:          *ast.Ast,
    deps:       *ResolveDeps,
    ctx:        *comptime.ComptimeCtx,
    own_module: session.ModuleId
) R.Result[bool, str] {
    rc.s          = s;
    rc.a          = a;
    rc.deps       = deps;
    rc.ctx        = ctx;
    rc.own_module = own_module;

    val src_opt: O.Option[*src.SourceFile] = src.get(?s.sources, a.file_id);
    if (O.is_none[*src.SourceFile](src_opt)) {
        ret R.err[bool, str]("Ast.file_id not registered with the session");
    }
    rc.source = O.unwrap[*src.SourceFile](src_opt).text;

    rc.symbols  = nil;
    rc.sym_len  = 0;
    rc.sym_cap  = 0;

    rc.expr_resolved = nil;
    rc.type_resolved = nil;
    rc.decl_symbol   = nil;

    rc.scopes        = nil;
    rc.scope_len     = 0;
    rc.scope_cap     = 0;
    rc.module_scope  = SCOPE_NIL;
    rc.current_scope = SCOPE_NIL;

    var pi: u32 = 0;
    for (pi < PRIM_COUNT) {
        rc.prim_names[pi] = intern.STR_NIL;
        rc.prim_syms[pi]  = SYMBOL_NIL;
        pi = pi + 1;
    }

    rc.imported_cache = map.init[u64, SymbolId](s.alloc, map.hash_u64, map.eq_u64);
    rc.module_index   = map.init[intern.StrId, SymbolId](s.alloc, map.hash_u32, map.eq_u32);

    # every allocation past this point is owned by the context; on a failure
    # dnit_context tears down whatever has been allocated so far (the array
    # handles are nil and the cache is initialised), leaving no partial state
    # leaked on the OOM path.
    val sa: R.Result[*Symbol, str] = A.allocate[Symbol](s.alloc, INITIAL_SYMBOLS_CAP::usize);
    if (R.is_err[*Symbol, str](sa)) {
        dnit_context(rc);
        ret R.err[bool, str](R.unwrap_err[*Symbol, str](sa));
    }
    rc.symbols = R.unwrap_ok[*Symbol, str](sa);
    rc.sym_cap = INITIAL_SYMBOLS_CAP;

    val sca: R.Result[*Scope, str] = A.allocate[Scope](s.alloc, INITIAL_SCOPES_CAP::usize);
    if (R.is_err[*Scope, str](sca)) {
        dnit_context(rc);
        ret R.err[bool, str](R.unwrap_err[*Scope, str](sca));
    }
    rc.scopes    = R.unwrap_ok[*Scope, str](sca);
    rc.scope_cap = INITIAL_SCOPES_CAP;

    if (a.expr_len > 0) {
        val r: R.Result[*SymbolId, str] = A.allocate[SymbolId](s.alloc, a.expr_len);
        if (R.is_err[*SymbolId, str](r)) { dnit_context(rc); ret R.err[bool, str](R.unwrap_err[*SymbolId, str](r)); }
        rc.expr_resolved = R.unwrap_ok[*SymbolId, str](r);
        fill_nil(rc.expr_resolved, a.expr_len::u32);
    }
    if (a.type_len > 0) {
        val r: R.Result[*SymbolId, str] = A.allocate[SymbolId](s.alloc, a.type_len);
        if (R.is_err[*SymbolId, str](r)) { dnit_context(rc); ret R.err[bool, str](R.unwrap_err[*SymbolId, str](r)); }
        rc.type_resolved = R.unwrap_ok[*SymbolId, str](r);
        fill_nil(rc.type_resolved, a.type_len::u32);
    }
    if (a.decl_len > 0) {
        val r: R.Result[*SymbolId, str] = A.allocate[SymbolId](s.alloc, a.decl_len);
        if (R.is_err[*SymbolId, str](r)) { dnit_context(rc); ret R.err[bool, str](R.unwrap_err[*SymbolId, str](r)); }
        rc.decl_symbol = R.unwrap_ok[*SymbolId, str](r);
        fill_nil(rc.decl_symbol, a.decl_len::u32);
    }

    ret R.ok[bool, str](true);
}

# fill `arr` with SYMBOL_NIL
# ---
# arr: the SymbolId array to clear
# len: number of slots to fill
fun fill_nil(arr: *SymbolId, len: u32) {
    var i: u32 = 0;
    for (i < len) {
        arr[i] = SYMBOL_NIL;
        i = i + 1;
    }
}

# release every array and map owned by `rc`
# ---
# rc: the context to tear down
fun dnit_context(rc: *ResolveContext) {
    var i: u32 = 0;
    for (i < rc.scope_len) {
        val sc: *Scope = ?rc.scopes[i];
        if (sc.entries != nil && sc.cap > 0) {
            A.deallocate[ScopeEntry](rc.s.alloc, sc.entries, sc.cap::usize);
        }
        i = i + 1;
    }
    if (rc.scopes != nil && rc.scope_cap > 0) {
        A.deallocate[Scope](rc.s.alloc, rc.scopes, rc.scope_cap::usize);
    }
    if (rc.symbols != nil && rc.sym_cap > 0) {
        A.deallocate[Symbol](rc.s.alloc, rc.symbols, rc.sym_cap::usize);
    }
    if (rc.expr_resolved != nil) {
        A.deallocate[SymbolId](rc.s.alloc, rc.expr_resolved, rc.a.expr_len);
    }
    if (rc.type_resolved != nil) {
        A.deallocate[SymbolId](rc.s.alloc, rc.type_resolved, rc.a.type_len);
    }
    if (rc.decl_symbol != nil) {
        A.deallocate[SymbolId](rc.s.alloc, rc.decl_symbol, rc.a.decl_len);
    }
    map.dnit[u64, SymbolId](?rc.imported_cache);
    map.dnit[intern.StrId, SymbolId](?rc.module_index);
}

# push a fresh empty scope as a child of `parent` and return its id
# ---
# rc:     resolver state for the module being resolved
# parent: the parent scope, or SCOPE_NIL for a root
# ret:    the new scope's id, or an allocation error
fun open_scope(rc: *ResolveContext, parent: ScopeId) R.Result[ScopeId, str] {
    if (rc.scope_len == rc.scope_cap) {
        val new_cap: u32 = rc.scope_cap * 2;
        val r: R.Result[*Scope, str] = A.reallocate[Scope](rc.s.alloc, rc.scopes, rc.scope_cap::usize, new_cap::usize);
        if (R.is_err[*Scope, str](r)) {
            ret R.err[ScopeId, str](R.unwrap_err[*Scope, str](r));
        }
        rc.scopes    = R.unwrap_ok[*Scope, str](r);
        rc.scope_cap = new_cap;
    }
    var sc: Scope;
    sc.parent  = parent;
    sc.entries = nil;
    sc.len     = 0;
    sc.cap     = 0;
    val sid: ScopeId = rc.scope_len;
    rc.scopes[rc.scope_len] = sc;
    rc.scope_len = rc.scope_len + 1;
    ret R.ok[ScopeId, str](sid);
}

# bind `name` to `sym` in `scope`, mirroring module-scope adds into the name index
# ---
# rc:    resolver state for the module being resolved
# scope: the scope to add to
# name:  interned name to bind
# sym:   the symbol to bind it to
# ret:   ok(true), or an allocation error
fun scope_add(rc: *ResolveContext, scope: ScopeId, name: intern.StrId, sym: SymbolId) R.Result[bool, str] {
    val sc: *Scope = ?rc.scopes[scope];
    if (sc.entries == nil) {
        val r: R.Result[*ScopeEntry, str] = A.allocate[ScopeEntry](rc.s.alloc, INITIAL_SCOPE_ENTRY_CAP::usize);
        if (R.is_err[*ScopeEntry, str](r)) { ret R.err[bool, str](R.unwrap_err[*ScopeEntry, str](r)); }
        sc.entries = R.unwrap_ok[*ScopeEntry, str](r);
        sc.cap     = INITIAL_SCOPE_ENTRY_CAP;
    }
    or (sc.len == sc.cap) {
        val new_cap: u32 = sc.cap * 2;
        val r: R.Result[*ScopeEntry, str] = A.reallocate[ScopeEntry](rc.s.alloc, sc.entries, sc.cap::usize, new_cap::usize);
        if (R.is_err[*ScopeEntry, str](r)) { ret R.err[bool, str](R.unwrap_err[*ScopeEntry, str](r)); }
        sc.entries = R.unwrap_ok[*ScopeEntry, str](r);
        sc.cap     = new_cap;
    }
    var e: ScopeEntry;
    e.name = name;
    e.sym  = sym;
    sc.entries[sc.len] = e;
    sc.len = sc.len + 1;

    # mirror module-scope adds into the name index so scope_lookup_local can answer
    # in O(1); other scopes stay linear-only.
    if (scope == rc.module_scope) {
        val ins: R.Result[bool, str] = map.insert[intern.StrId, SymbolId](?rc.module_index, name, sym);
        if (R.is_err[bool, str](ins)) { ret R.err[bool, str](R.unwrap_err[bool, str](ins)); }
    }
    ret R.ok[bool, str](true);
}

# look `name` up in `scope` alone, not its parents
# ---
# rc:    resolver state for the module being resolved
# scope: the scope to search
# name:  interned name to find
# ret:   the bound SymbolId, or SYMBOL_NIL when unbound
fun scope_lookup_local(rc: *ResolveContext, scope: ScopeId, name: intern.StrId) SymbolId {
    if (scope == SCOPE_NIL) { ret SYMBOL_NIL; }
    if (scope == rc.module_scope) {
        val g: R.Result[*SymbolId, str] = map.get[intern.StrId, SymbolId](?rc.module_index, ?name);
        if (R.is_ok[*SymbolId, str](g)) { ret @R.unwrap_ok[*SymbolId, str](g); }
        ret SYMBOL_NIL;
    }
    val sc: *Scope = ?rc.scopes[scope];
    var i: u32 = 0;
    for (i < sc.len) {
        if (sc.entries[i].name == name) { ret sc.entries[i].sym; }
        i = i + 1;
    }
    ret SYMBOL_NIL;
}

# look `name` up through `scope` and every ancestor
# ---
# rc:    resolver state for the module being resolved
# scope: the innermost scope to search from
# name:  interned name to find
# ret:   the nearest bound SymbolId, or SYMBOL_NIL
fun scope_lookup_chain(rc: *ResolveContext, scope: ScopeId, name: intern.StrId) SymbolId {
    var cur: ScopeId = scope;
    for (cur != SCOPE_NIL) {
        val found: SymbolId = scope_lookup_local(rc, cur, name);
        if (found != SYMBOL_NIL) { ret found; }
        cur = rc.scopes[cur].parent;
    }
    ret SYMBOL_NIL;
}

# append a Symbol to the universe and return its id
# ---
# rc:      resolver state for the module being resolved
# kind:    the symbol's SymKind
# flags:   its SYM_FLAG_* bitfield
# name:    interned identifier
# decl_id: originating DeclId
# slot:    kind-dependent payload
# origin:  owning module id
# ret:     the new SymbolId, or an allocation error
fun add_symbol(rc: *ResolveContext, kind: SymKind, flags: u8, name: intern.StrId, decl_id: id.DeclId, slot: u32, origin: session.ModuleId) R.Result[SymbolId, str] {
    if (rc.sym_len == rc.sym_cap) {
        val new_cap: u32 = rc.sym_cap * 2;
        val r: R.Result[*Symbol, str] = A.reallocate[Symbol](rc.s.alloc, rc.symbols, rc.sym_cap::usize, new_cap::usize);
        if (R.is_err[*Symbol, str](r)) {
            ret R.err[SymbolId, str](R.unwrap_err[*Symbol, str](r));
        }
        rc.symbols = R.unwrap_ok[*Symbol, str](r);
        rc.sym_cap = new_cap;
    }
    var sym: Symbol;
    sym.kind   = kind;
    sym.flags  = flags;
    sym.name   = name;
    sym.decl   = decl_id;
    sym.slot   = slot;
    sym.origin = origin;
    # the stable snapshots are filled in build_result once every symbol exists.
    sym.origin_stable = session.STABLE_MODULE_NIL;
    sym.slot_stable   = session.STABLE_MODULE_NIL;
    val sid: SymbolId = rc.sym_len;
    rc.symbols[rc.sym_len] = sym;
    rc.sym_len = rc.sym_len + 1;
    ret R.ok[SymbolId, str](sid);
}

# intern `name`, reject a duplicate in `scope`, then add and bind a Symbol
# ---
# rc:      resolver state for the module being resolved
# kind:    the symbol's SymKind
# flags:   its SYM_FLAG_* bitfield
# name:    source span of the identifier
# decl_id: originating DeclId
# slot:    kind-dependent payload
# origin:  owning module id
# scope:   scope to bind into
# ret:     the bound SymbolId, SYMBOL_NIL for an empty or duplicate name, or an error
fun declare(
    rc:      *ResolveContext,
    kind:    SymKind,
    flags:   u8,
    name:    token.Span,
    decl_id: id.DeclId,
    slot:    u32,
    origin:  session.ModuleId,
    scope:   ScopeId
) R.Result[SymbolId, str] {
    if (name.len == 0) {
        ret R.ok[SymbolId, str](SYMBOL_NIL);
    }
    val r_id: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, name);
    if (R.is_err[intern.StrId, str](r_id)) {
        ret R.err[SymbolId, str](R.unwrap_err[intern.StrId, str](r_id));
    }
    val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_id);

    val existing: SymbolId = scope_lookup_local(rc, scope, name_id);
    if (existing != SYMBOL_NIL) {
        val de: R.Result[bool, str] = report_named(rc, name, "duplicate definition: `", name_id, "` is already bound in this scope");
        if (R.is_ok[bool, str](de)) {
            report_prior_binding(rc, existing);
        }
        ret R.ok[SymbolId, str](SYMBOL_NIL);
    }

    val r_sym: R.Result[SymbolId, str] = add_symbol(rc, kind, flags, name_id, decl_id, slot, origin);
    if (R.is_err[SymbolId, str](r_sym)) { ret r_sym; }
    val sid: SymbolId = R.unwrap_ok[SymbolId, str](r_sym);

    val r_add: R.Result[bool, str] = scope_add(rc, scope, name_id, sid);
    if (R.is_err[bool, str](r_add)) {
        ret R.err[SymbolId, str](R.unwrap_err[bool, str](r_add));
    }

    ret R.ok[SymbolId, str](sid);
}

# attach the prior binding of a name-collision error to the last diagnostic
#
# When `prior` was declared in this module and its declaration carries a name
# span, the location is attached as a secondary span labelled `previous
# definition here`. A prior binding declared in another module (an imported or
# re-exported symbol whose source this module does not hold) has no local
# location to point at, so it degrades to a plain clarifying note instead. Shared
# by the duplicate-definition site and the import / re-export collision sites.
# ---
# rc:    resolver state for the module being resolved
# prior: SymbolId of the existing binding the new declaration collides with
fun report_prior_binding(rc: *ResolveContext, prior: SymbolId) {
    if (rc.symbols[prior].origin == rc.own_module && rc.symbols[prior].decl != id.DECL_NIL) {
        val prev: token.Span = prior_name_span(rc, rc.symbols[prior].decl);
        if (prev.len != 0) {
            diagnostic.attach_related(?rc.s.diags, rc.a.file_id, prev, "previous definition here");
            ret;
        }
    }
    diagnostic.attach_note(?rc.s.diags, "a name with this spelling is already bound here");
}

# the name span of a prior binding's declaration for a "previous definition here"
# secondary span
#
# Delegates to `ast.decl_name_span`, which returns an empty span for an unaliased
# `use`/`fwd` (its alias span is empty). In that case the dotted path's leaf
# segment - the name the binding actually introduces - is used instead, resolved
# against the module source `decl_name_span` cannot reach.
# ---
# rc:      resolver state for the module being resolved
# decl_id: the prior binding's declaration
# ret:     the name span, or an empty span when the decl carries no name
fun prior_name_span(rc: *ResolveContext, decl_id: id.DeclId) token.Span {
    val span: token.Span = ast.decl_name_span(rc.a, decl_id);
    if (span.len != 0) { ret span; }

    val opt_d: O.Option[*decl.Decl] = ast.get_decl(rc.a, decl_id);
    if (O.is_none[*decl.Decl](opt_d)) { ret span; }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_d);

    if (d.kind == decl.DECL_KIND_USE) { ret leaf_span(rc, d.data.use_.path); }
    if (d.kind == decl.DECL_KIND_FWD) { ret leaf_span(rc, d.data.fwd_.path); }
    ret span;
}

# seeds the primitive type names (u8..f64, ptr) into the resolver's primitive
# registry as SYM_PRIM symbols whose `slot` carries the primitive TypeKind
# ordinal. primitives are recognised in type position only (see
# `prim_symbol_for`), never bound into a value scope, so a declaration may
# reuse a primitive spelling (e.g. `fun u64()`) without colliding. mirrors
# cmach's string-based primitive resolution in sema_resolve_type
# ---
# rc:  resolver state for the module being resolved
# ret: ok(true), or an allocation error
fun seed_primitives(rc: *ResolveContext) R.Result[bool, str] {
    val r0:  R.Result[bool, str] = seed_one_primitive(rc, 0,  "u8",  type.TYPE_U8::u32);  if (R.is_err[bool, str](r0))  { ret r0; }
    val r1:  R.Result[bool, str] = seed_one_primitive(rc, 1,  "u16", type.TYPE_U16::u32); if (R.is_err[bool, str](r1))  { ret r1; }
    val r2:  R.Result[bool, str] = seed_one_primitive(rc, 2,  "u32", type.TYPE_U32::u32); if (R.is_err[bool, str](r2))  { ret r2; }
    val r3:  R.Result[bool, str] = seed_one_primitive(rc, 3,  "u64", type.TYPE_U64::u32); if (R.is_err[bool, str](r3))  { ret r3; }
    val r4:  R.Result[bool, str] = seed_one_primitive(rc, 4,  "i8",  type.TYPE_I8::u32);  if (R.is_err[bool, str](r4))  { ret r4; }
    val r5:  R.Result[bool, str] = seed_one_primitive(rc, 5,  "i16", type.TYPE_I16::u32); if (R.is_err[bool, str](r5))  { ret r5; }
    val r6:  R.Result[bool, str] = seed_one_primitive(rc, 6,  "i32", type.TYPE_I32::u32); if (R.is_err[bool, str](r6))  { ret r6; }
    val r7:  R.Result[bool, str] = seed_one_primitive(rc, 7,  "i64", type.TYPE_I64::u32); if (R.is_err[bool, str](r7))  { ret r7; }
    val r8:  R.Result[bool, str] = seed_one_primitive(rc, 8,  "f32", type.TYPE_F32::u32); if (R.is_err[bool, str](r8))  { ret r8; }
    val r9:  R.Result[bool, str] = seed_one_primitive(rc, 9,  "f64", type.TYPE_F64::u32); if (R.is_err[bool, str](r9))  { ret r9; }
    val r10: R.Result[bool, str] = seed_one_primitive(rc, 10, "ptr", type.TYPE_PTR::u32); if (R.is_err[bool, str](r10)) { ret r10; }
    ret R.ok[bool, str](true);
}

# interns one primitive name and records it in the registry at `index` as a
# SYM_PRIM symbol carrying the TypeKind ordinal in `slot`
# ---
# rc:           resolver state for the module being resolved
# index:        registry slot to fill
# name:         the primitive spelling
# kind_ordinal: the primitive's TypeKind ordinal
# ret:          ok(true), or an allocation error
fun seed_one_primitive(rc: *ResolveContext, index: u32, name: str, kind_ordinal: u32) R.Result[bool, str] {
    val r_id: R.Result[intern.StrId, str] = intern.intern(?rc.s.interner, name);
    if (R.is_err[intern.StrId, str](r_id)) { ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_id)); }
    val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_id);

    val r_sym: R.Result[SymbolId, str] = add_symbol(rc, SYM_PRIM, 0, name_id, id.DECL_NIL, kind_ordinal, rc.own_module);
    if (R.is_err[SymbolId, str](r_sym)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](r_sym)); }
    val sid: SymbolId = R.unwrap_ok[SymbolId, str](r_sym);

    rc.prim_names[index] = name_id;
    rc.prim_syms[index]  = sid;
    ret R.ok[bool, str](true);
}

# returns the SYM_PRIM symbol for a primitive type spelling, or SYMBOL_NIL
# when `name` is not a primitive. consulted in type position, taking priority
# over scope so a same-named value declaration never shadows the type
# ---
# rc:   resolver state for the module being resolved
# name: interned spelling to test
# ret:  the SYM_PRIM symbol, or SYMBOL_NIL when `name` is not a primitive
fun prim_symbol_for(rc: *ResolveContext, name: intern.StrId) SymbolId {
    var i: u32 = 0;
    for (i < PRIM_COUNT) {
        if (rc.prim_names[i] == name) { ret rc.prim_syms[i]; }
        i = i + 1;
    }
    ret SYMBOL_NIL;
}

# collect every decl in `[start, start + len)` of the decl-id pool
# ---
# rc:              resolver state for the module being resolved
# start:           first index into the decl-id pool
# len:             number of decls
# scope:           scope to declare into
# at_module_scope: whether these are module-scope decls
# ret:             ok(true), or an error from collecting a decl
fun collect_decl_list(rc: *ResolveContext, start: u32, len: u32, scope: ScopeId, at_module_scope: bool) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val decl_id: id.DeclId = rc.a.decl_ids[start + i];
        val r: R.Result[bool, str] = collect_one_decl(rc, decl_id, scope, at_module_scope);
        if (R.is_err[bool, str](r)) { ret r; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# register the binding (if any) introduced by one decl
# ---
# rc:              resolver state for the module being resolved
# decl_id:         the decl to collect
# scope:           scope to declare into
# at_module_scope: whether the decl sits at module scope
# ret:             ok(true), or an allocation or eval error
fun collect_one_decl(rc: *ResolveContext, decl_id: id.DeclId, scope: ScopeId, at_module_scope: bool) R.Result[bool, str] {
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(rc.a, decl_id);
    if (O.is_none[*decl.Decl](d_opt)) { ret R.err[bool, str]("DeclId out of range"); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);
    val flags_in: u8 = d.flags;

    if (d.kind == decl.DECL_KIND_COMPTIME_IF) {
        ret collect_comptime_if(rc, ?d.data.comptime_if, scope, at_module_scope, true);
    }
    if (d.kind == decl.DECL_KIND_COMPTIME_ATTR) {
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_TEST || d.kind == decl.DECL_KIND_ERROR) {
        ret R.ok[bool, str](true);
    }

    # fwd re-exports are resolved in the bind pass once dep symbols are reachable
    if (d.kind == decl.DECL_KIND_FWD) {
        ret R.ok[bool, str](true);
    }

    val sym_flags: u8 = symbol_flags_from(flags_in, at_module_scope);

    if (d.kind == decl.DECL_KIND_USE) {
        ret collect_use(rc, decl_id, ?d.data.use_, scope);
    }
    if (d.kind == decl.DECL_KIND_FUN) {
        ret declare_decl(rc, SYM_FUN, sym_flags, d.data.fun_.name, decl_id, scope);
    }
    if (d.kind == decl.DECL_KIND_REC) {
        ret declare_decl(rc, SYM_REC, sym_flags, d.data.rec_.name, decl_id, scope);
    }
    if (d.kind == decl.DECL_KIND_UNI) {
        ret declare_decl(rc, SYM_UNI, sym_flags, d.data.uni_.name, decl_id, scope);
    }
    if (d.kind == decl.DECL_KIND_DEF) {
        ret declare_decl(rc, SYM_DEF, sym_flags, d.data.def_.name, decl_id, scope);
    }
    if (d.kind == decl.DECL_KIND_VAL) {
        val r: R.Result[bool, str] = declare_decl(rc, SYM_VAL, sym_flags, d.data.bind.name, decl_id, scope);
        if (R.is_err[bool, str](r)) { ret r; }
        if (d.data.bind.init != id.EXPR_NIL) {
            val rcr: R.Result[bool, str] = try_register_comptime_const(rc, d.data.bind.name, d.data.bind.init);
            if (R.is_err[bool, str](rcr)) { ret rcr; }
        }
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_VAR) {
        ret declare_decl(rc, SYM_VAR, sym_flags, d.data.bind.name, decl_id, scope);
    }
    ret R.ok[bool, str](true);
}

# declare a named decl's symbol and record it on `decl_symbol`
# ---
# rc:        resolver state for the module being resolved
# kind:      the symbol's SymKind
# flags:     its SYM_FLAG_* bitfield
# name_span: span of the decl's name
# decl_id:   the decl's DeclId
# scope:     scope to bind into
# ret:       ok(true), or an allocation error
fun declare_decl(rc: *ResolveContext, kind: SymKind, flags: u8, name_span: token.Span, decl_id: id.DeclId, scope: ScopeId) R.Result[bool, str] {
    val r: R.Result[SymbolId, str] = declare(rc, kind, flags, name_span, decl_id, 0, rc.own_module, scope);
    if (R.is_err[SymbolId, str](r)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](r)); }
    if (rc.decl_symbol != nil) {
        rc.decl_symbol[decl_id] = R.unwrap_ok[SymbolId, str](r);
    }
    ret R.ok[bool, str](true);
}

# derive a symbol's flag bits from its decl flags and scope
# ---
# decl_flags:      the decl's flag bits
# at_module_scope: whether the decl sits at module scope
# ret:             the SYM_FLAG_* bitfield
fun symbol_flags_from(decl_flags: u8, at_module_scope: bool) u8 {
    if (!at_module_scope) { ret 0; }
    var f: u8 = SYM_FLAG_MODULE;
    if ((decl_flags & decl.DECL_FLAG_PUB) != 0) { f = f | SYM_FLAG_PUB; }
    ret f;
}

# binds a module-level comptime-evaluable val into the module frame. idempotent:
# a name the driver's load pass already bound (this-module pub vals, imported pub
# consts) is skipped, so the load+collect double-registration does not grow the
# frame with a duplicate. module scope forbids same-name decls, so skipping by
# name never drops a legitimate distinct binding. a non-foldable initializer is
# skipped (ok): the comptime requirement is enforced at the use site, not here.
# only a bind failure (allocation) propagates
# ---
# rc:        resolver state for the module being resolved
# name_span: span of the val's name
# init_expr: the initializer expression
# ret:       ok(true); only a bind allocation failure is reported as an error
fun try_register_comptime_const(rc: *ResolveContext, name_span: token.Span, init_expr: id.ExprId) R.Result[bool, str] {
    if (name_span.len == 0) { ret R.ok[bool, str](true); }
    val r_id: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, name_span);
    if (R.is_err[intern.StrId, str](r_id)) { ret R.ok[bool, str](true); }
    val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_id);

    if (O.is_some[*comptime.NamedConst](comptime.lookup(rc.ctx, name_id))) { ret R.ok[bool, str](true); }

    val r_val: R.Result[comptime.CTValue, str] = comptime.eval(rc.ctx, rc.a, rc.source, init_expr, ?rc.s.interner);
    if (R.is_err[comptime.CTValue, str](r_val)) { ret R.ok[bool, str](true); }
    val v: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](r_val);

    ret comptime.bind(rc.ctx, name_id, v);
}

# collect the first comptime-active arm of a `$if` decl chain
# ---
# rc:              resolver state for the module being resolved
# ci:              the comptime-if decl payload
# scope:           scope to declare into
# at_module_scope: whether the chain sits at module scope
# at_decl_scope:   whether the chain sits in decl position
# ret:             ok(true), or an eval or allocation error
fun collect_comptime_if(rc: *ResolveContext, ci: *decl.DeclComptimeIf, scope: ScopeId, at_module_scope: bool, at_decl_scope: bool) R.Result[bool, str] {
    var bi: u32 = 0;
    for (bi < ci.branches_len) {
        val br: *decl.ComptimeBranch = ?rc.a.comptime_branches[ci.branches_start + bi];
        val take_r: R.Result[bool, str] = comptime_branch_active(rc, br);
        if (R.is_err[bool, str](take_r)) { ret take_r; }
        if (R.unwrap_ok[bool, str](take_r)) {
            if (at_decl_scope) {
                ret collect_decl_list(rc, br.body_start, br.body_len, scope, at_module_scope);
            }
            ret R.ok[bool, str](true);
        }
        bi = bi + 1;
    }
    ret R.ok[bool, str](true);
}

# evaluate a `$if` branch condition to a bool, reporting a non-bool value
# ---
# rc:  resolver state for the module being resolved
# br:  the branch to test
# ret: ok(true) when the branch is taken, ok(false) otherwise, or an error
fun comptime_branch_active(rc: *ResolveContext, br: *decl.ComptimeBranch) R.Result[bool, str] {
    if (br.cond == id.EXPR_NIL) { ret R.ok[bool, str](true); }
    val r: R.Result[comptime.CTValue, str] = comptime.eval(rc.ctx, rc.a, rc.source, br.cond, ?rc.s.interner);
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, br.cond);
    if (O.is_none[*expr.Expr](e_opt)) { ret R.err[bool, str]("comptime branch cond ExprId out of range"); }
    val cond_span: token.Span = O.unwrap[*expr.Expr](e_opt).span;
    if (R.is_err[comptime.CTValue, str](r)) {
        val de: R.Result[bool, str] = diagnostic.error(?rc.s.diags, rc.a.file_id, cond_span, R.unwrap_err[comptime.CTValue, str](r));
        if (R.is_err[bool, str](de)) { ret de; }
        ret R.ok[bool, str](false);
    }
    val v: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](r);
    if (v.kind != comptime.CT_KIND_BOOL) {
        # the BOOL case is excluded above, so the value is int, float, or str.
        var msg: str = "comptime branch condition must be a bool, found int";
        if (v.kind == comptime.CT_KIND_FLOAT) { msg = "comptime branch condition must be a bool, found float"; }
        or (v.kind == comptime.CT_KIND_STR)   { msg = "comptime branch condition must be a bool, found str"; }
        val de: R.Result[bool, str] = diagnostic.error(?rc.s.diags, rc.a.file_id, cond_span, msg);
        if (R.is_err[bool, str](de)) { ret de; }
        ret R.ok[bool, str](false);
    }
    ret R.ok[bool, str](v.data.b);
}

# binds a single `use PATH;` / `use ALIAS: PATH;` decl. with no implicit
# splat: a no-alias `use` binds the single leaf name of PATH (a module
# alias when PATH ends at a module, a pub symbol when it ends at a symbol);
# an aliased `use` binds the alias to the same target
# ---
# rc:      resolver state for the module being resolved
# decl_id: the use decl
# du:      the use payload
# scope:   scope to bind into
# ret:     ok(true), or an allocation error
fun collect_use(rc: *ResolveContext, decl_id: id.DeclId, du: *decl.DeclUse, scope: ScopeId) R.Result[bool, str] {
    if (du.path.len == 0) {
        ret R.ok[bool, str](true);
    }

    val r_path: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, du.path);
    if (R.is_err[intern.StrId, str](r_path)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_path));
    }
    val path_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_path);

    # PATH ends at a module: bind a module alias (explicit alias span, or the
    # leaf segment of PATH when no alias is written).
    val mx: *ModuleExports = find_module_exports(rc, path_id);
    if (mx != nil) {
        var alias_span: token.Span = du.alias;
        if (alias_span.len == 0) {
            alias_span = leaf_span(rc, du.path);
        }
        val r: R.Result[SymbolId, str] = declare(rc, SYM_USE, 0, alias_span, decl_id, mx.module::u32, rc.own_module, scope);
        if (R.is_err[SymbolId, str](r)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](r)); }
        if (rc.decl_symbol != nil) {
            rc.decl_symbol[decl_id] = R.unwrap_ok[SymbolId, str](r);
        }
        ret R.ok[bool, str](true);
    }

    # PATH ends at a symbol: split into prefix module + leaf symbol, look the
    # symbol up among the prefix module's exports, and bind it under the alias
    # (or the leaf name when no alias is written).
    val leaf: token.Span = leaf_span(rc, du.path);
    val prefix: token.Span = prefix_span(rc, du.path);
    if (prefix.len == 0 || leaf.len == 0) {
        diagnostic.error(?rc.s.diags, rc.a.file_id, du.path, "imported module is not in the dep set");
        ret R.ok[bool, str](true);
    }

    val pmx: *ModuleExports = find_module_exports_span(rc, prefix);
    if (pmx == nil) {
        diagnostic.error(?rc.s.diags, rc.a.file_id, du.path, "imported module is not in the dep set");
        ret R.ok[bool, str](true);
    }

    val r_leaf: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, leaf);
    if (R.is_err[intern.StrId, str](r_leaf)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_leaf));
    }
    val leaf_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_leaf);

    val ps: *PublicSymbol = find_export(pmx, leaf_id);
    if (ps == nil) {
        report_named2(rc, du.path, "`", leaf_id, "` is not exported by `", pmx.path, "`");
        ret R.ok[bool, str](true);
    }

    var bind_span: token.Span = du.alias;
    if (bind_span.len == 0) {
        bind_span = leaf;
    }
    ret bind_imported_symbol(rc, decl_id, bind_span, ps, scope);
}

# adds a SYM_IMPORTED binding for `ps` under `bind_span`, deduping the
# underlying (origin, decl) Symbol through `imported_cache`
# ---
# rc:        resolver state for the module being resolved
# decl_id:   the use decl
# bind_span: span to bind the import under
# ps:        the source pub symbol
# scope:     scope to bind into
# ret:       ok(true), or an allocation error
fun bind_imported_symbol(rc: *ResolveContext, decl_id: id.DeclId, bind_span: token.Span, ps: *PublicSymbol, scope: ScopeId) R.Result[bool, str] {
    if (bind_span.len == 0) { ret R.ok[bool, str](true); }
    val r_name: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, bind_span);
    if (R.is_err[intern.StrId, str](r_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_name));
    }
    val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_name);

    val existing: SymbolId = scope_lookup_local(rc, scope, name_id);
    if (existing != SYMBOL_NIL) {
        val de: R.Result[bool, str] = report_named(rc, bind_span, "imported name `", name_id, "` is already defined in this scope");
        if (R.is_ok[bool, str](de)) {
            report_prior_binding(rc, existing);
        }
        ret R.ok[bool, str](true);
    }

    val sid_r: R.Result[SymbolId, str] = imported_symbol_for(rc, ps);
    if (R.is_err[SymbolId, str](sid_r)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](sid_r)); }
    val sid: SymbolId = R.unwrap_ok[SymbolId, str](sid_r);

    val r_add: R.Result[bool, str] = scope_add(rc, scope, name_id, sid);
    if (R.is_err[bool, str](r_add)) { ret r_add; }
    if (rc.decl_symbol != nil) {
        rc.decl_symbol[decl_id] = sid;
    }
    ret R.ok[bool, str](true);
}

# returns a Symbol for `ps`, reusing the cached one when an earlier use-site
# already imported the same (origin, decl) pair. an ordinary export degrades to
# a plain SYM_IMPORTED reference; a re-exported module alias (SYM_USE) keeps its
# kind and target-module slot so a downstream consumer can resolve through the
# `fwd` (the slot is a project-wide ModuleId, shared across the one build)
# ---
# rc:  resolver state for the module being resolved
# ps:  the pub symbol to import
# ret: the cached or freshly minted SymbolId, or an allocation error
fun imported_symbol_for(rc: *ResolveContext, ps: *PublicSymbol) R.Result[SymbolId, str] {
    val key: u64 = (ps.origin::u64 << 32) | ps.decl::u64;
    val cached: R.Result[*SymbolId, str] = map.get[u64, SymbolId](?rc.imported_cache, ?key);
    if (R.is_ok[*SymbolId, str](cached)) {
        ret R.ok[SymbolId, str](@R.unwrap_ok[*SymbolId, str](cached));
    }
    var kind: SymKind = SYM_IMPORTED;
    var slot: u32     = 0;
    if (ps.kind == SYM_USE) {
        kind = SYM_USE;
        slot = ps.slot;
    }
    val r: R.Result[SymbolId, str] = add_symbol(rc, kind, 0, ps.name, ps.decl, slot, ps.origin);
    if (R.is_err[SymbolId, str](r)) { ret r; }
    val sid: SymbolId = R.unwrap_ok[SymbolId, str](r);
    val ins: R.Result[bool, str] = map.insert[u64, SymbolId](?rc.imported_cache, key, sid);
    if (R.is_err[bool, str](ins)) { ret R.err[SymbolId, str](R.unwrap_err[bool, str](ins)); }
    ret R.ok[SymbolId, str](sid);
}

# byte offset of the last `.` within `path`, or path.offset when there is none
# ---
# rc:   resolver state for the module being resolved
# path: the dotted path span
# ret:  byte offset of the final `.`, or path.offset when there is none
fun last_dot_offset(rc: *ResolveContext, path: token.Span) usize {
    val start: usize = path.offset;
    val end:   usize = path.offset + path.len;
    var dot:   usize = start;
    var found: bool  = false;
    var i:     usize = start;
    for (i < end) {
        if (rc.source[i] == '.') {
            dot   = i;
            found = true;
        }
        i = i + 1;
    }
    if (!found) { ret start; }
    ret dot;
}

# span of the final dotted segment of `path` (the leaf component). for a
# single-segment path the whole span is returned
# ---
# rc:   resolver state for the module being resolved
# path: the dotted path span
# ret:  span of the path's final segment
fun leaf_span(rc: *ResolveContext, path: token.Span) token.Span {
    val end: usize = path.offset + path.len;
    val dot: usize = last_dot_offset(rc, path);
    var out: token.Span;
    if (dot == path.offset && rc.source[path.offset] != '.') {
        out.offset = path.offset;
        out.len    = path.len;
        ret out;
    }
    out.offset = dot + 1;
    out.len    = end - (dot + 1);
    ret out;
}

# span covering everything before the final `.` of `path` (the module prefix),
# or an empty span when `path` is a single segment
# ---
# rc:   resolver state for the module being resolved
# path: the dotted path span
# ret:  span before the final `.`, empty for a single-segment path
fun prefix_span(rc: *ResolveContext, path: token.Span) token.Span {
    val dot: usize = last_dot_offset(rc, path);
    var out: token.Span;
    if (dot == path.offset && rc.source[path.offset] != '.') {
        out.offset = path.offset;
        out.len    = 0;
        ret out;
    }
    out.offset = path.offset;
    out.len    = dot - path.offset;
    ret out;
}

# the dependency exports whose interned FQN equals `path`
# ---
# rc:   resolver state for the module being resolved
# path: interned module FQN to find
# ret:  the matching exports, or nil when not a dep
fun find_module_exports(rc: *ResolveContext, path: intern.StrId) *ModuleExports {
    var i: u32 = 0;
    for (i < rc.deps.count) {
        val mx: *ModuleExports = ?rc.deps.entries[i];
        if (mx.path == path) { ret mx; }
        i = i + 1;
    }
    ret nil;
}

# finds the dependency exports for module id `mid`, or nil when not a dep
# ---
# rc:  resolver state for the module being resolved
# mid: the module id to find
# ret: the matching exports, or nil when not a dep
fun find_module_exports_by_module(rc: *ResolveContext, mid: session.ModuleId) *ModuleExports {
    var i: u32 = 0;
    for (i < rc.deps.count) {
        val mx: *ModuleExports = ?rc.deps.entries[i];
        if (mx.module == mid) { ret mx; }
        i = i + 1;
    }
    ret nil;
}

# resolves a qualified member access `alias.symbol`, recording the referenced
# symbol on the member expression. when the object expression resolves to a
# module alias (a `SYM_USE` whose `slot` names the aliased module) - a bare
# ident bound by `use`, or a nested member that itself resolved to a `fwd`
# module re-export - the leaf names a public symbol of that module rather than
# a record field; this looks it up among the module's exports and records an
# imported symbol on the member's `expr_resolved` slot so sema can type it
# directly. the object is bound before this runs, so a chain resolves left to
# right through any depth of module aliases. a non-module object (an ordinary
# value) is left for sema's field-access path; an unexported or missing leaf
# reports an error. `member` is the ExprMember payload and `eid` its
# expression id
# ---
# rc:     resolver state for the module being resolved
# eid:    the member expression id
# member: the member payload
# ret:    ok(true), or an allocation error
fun bind_member_qualified(rc: *ResolveContext, eid: id.ExprId, member: *expr.ExprMember) R.Result[bool, str] {
    if (rc.expr_resolved == nil) { ret R.ok[bool, str](true); }

    val obj_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, member.object);
    if (O.is_none[*expr.Expr](obj_opt)) { ret R.ok[bool, str](true); }

    val osid: SymbolId = rc.expr_resolved[member.object];
    if (osid == SYMBOL_NIL || osid >= rc.sym_len) { ret R.ok[bool, str](true); }
    val osym: *Symbol = ?rc.symbols[osid];
    if (osym.kind != SYM_USE) { ret R.ok[bool, str](true); }

    val target: session.ModuleId = osym.slot::session.ModuleId;
    val mx: *ModuleExports = find_module_exports_by_module(rc, target);
    if (mx == nil) {
        # a SYM_USE always names a module the driver's dep-set closure included,
        # so a miss is a broken build graph; report it rather than silently
        # falling through to sema's field-access path.
        diagnostic.error(?rc.s.diags, rc.a.file_id, member.name, "module alias names a module that is not in the dep set");
        ret R.ok[bool, str](true);
    }

    val r_leaf: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, member.name);
    if (R.is_err[intern.StrId, str](r_leaf)) { ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_leaf)); }
    val leaf_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_leaf);

    val ps: *PublicSymbol = find_export(mx, leaf_id);
    if (ps == nil) {
        # the object is a real module but the leaf names no public export of
        # it - a genuinely undefined or non-`pub` qualified member. cmach
        # (`sema.c:3634`) errors for `!sym || !sym->is_public`; mirror that
        # here, since sema's later TYPE_NIL early-out would otherwise drop the
        # access silently.
        report_named2(rc, member.name, "no symbol `", leaf_id, "` exported by `", mx.path, "`");
        ret R.ok[bool, str](true);
    }

    # reuse the imported-symbol cache instead of minting a fresh Symbol per
    # qualified reference, the exact use-case the cache documents; this also
    # preserves a re-exported module alias as SYM_USE so `alias.member` chains
    # through a `fwd`.
    val r_sym: R.Result[SymbolId, str] = imported_symbol_for(rc, ps);
    if (R.is_err[SymbolId, str](r_sym)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](r_sym)); }
    rc.expr_resolved[eid] = R.unwrap_ok[SymbolId, str](r_sym);
    ret R.ok[bool, str](true);
}

# resolves a ModuleExports entry whose FQN equals the interned text of `span`
# ---
# rc:   resolver state for the module being resolved
# span: source span naming a module FQN
# ret:  the matching exports, or nil
fun find_module_exports_span(rc: *ResolveContext, span: token.Span) *ModuleExports {
    val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, span);
    if (R.is_err[intern.StrId, str](r)) { ret nil; }
    ret find_module_exports(rc, R.unwrap_ok[intern.StrId, str](r));
}

# resolves the module prefix of a `use`/`fwd` path to its exports. mirrors
# cmach's two-step prefix resolution: a `use`-alias bound into the module scope
# names its target module directly, otherwise the prefix text is a literal FQN.
# nil only when the prefix names no in-scope alias and no dependency
# ---
# rc:     resolver state for the module being resolved
# prefix: the path-prefix span
# ret:    the prefix module's exports, or nil
fun resolve_prefix_module(rc: *ResolveContext, prefix: token.Span) *ModuleExports {
    val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, prefix);
    if (R.is_err[intern.StrId, str](r)) { ret nil; }
    val prefix_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r);

    val sid: SymbolId = scope_lookup_chain(rc, rc.module_scope, prefix_id);
    if (sid != SYMBOL_NIL && sid < rc.sym_len) {
        val sym: *Symbol = ?rc.symbols[sid];
        if (sym.kind == SYM_USE) {
            ret find_module_exports_by_module(rc, sym.slot::session.ModuleId);
        }
    }
    ret find_module_exports(rc, prefix_id);
}

# finds the pub symbol named `name` among a module's exports
# ---
# mx:   the module's exports
# name: interned symbol name
# ret:  the matching pub symbol, or nil
fun find_export(mx: *ModuleExports, name: intern.StrId) *PublicSymbol {
    var i: u32 = 0;
    for (i < mx.count) {
        val ps: *PublicSymbol = ?mx.symbols[i];
        if (ps.name == name) { ret ps; }
        i = i + 1;
    }
    ret nil;
}

# bind every decl in `[start, start + len)` of the decl-id pool
# ---
# rc:    resolver state for the module being resolved
# start: first index into the decl-id pool
# len:   number of decls
# ret:   ok(true), or an error from binding a decl
fun bind_decl_list(rc: *ResolveContext, start: u32, len: u32) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val decl_id: id.DeclId = rc.a.decl_ids[start + i];
        val r: R.Result[bool, str] = bind_one_decl(rc, decl_id);
        if (R.is_err[bool, str](r)) { ret r; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# binds the identifiers in each of decl `d`'s backtick decorator arguments
# ---
# rc:  resolver state for the module being resolved
# d:   the decl whose decorator arguments to bind
# ret: ok(true), or a binding error
fun bind_decorator_args(rc: *ResolveContext, d: *decl.Decl) R.Result[bool, str] {
    var k: u32 = 0;
    for (k < d.decorators_len) {
        val dec: *decl.Decorator = ?rc.a.decorators[d.decorators_start + k];
        var j: u32 = 0;
        for (j < dec.args_len) {
            val r: R.Result[bool, str] = bind_expr(rc, rc.a.expr_ids[dec.args_start + j]);
            if (R.is_err[bool, str](r)) { ret r; }
            j = j + 1;
        }
        k = k + 1;
    }
    ret R.ok[bool, str](true);
}

# bind the types and bodies referenced by one decl
# ---
# rc:      resolver state for the module being resolved
# decl_id: the decl to bind
# ret:     ok(true), or a binding error
fun bind_one_decl(rc: *ResolveContext, decl_id: id.DeclId) R.Result[bool, str] {
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(rc.a, decl_id);
    if (O.is_none[*decl.Decl](d_opt)) { ret R.err[bool, str]("DeclId out of range"); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);

    # a decl's backtick decorator arguments are comptime expressions; bind their
    # identifiers (e.g. the operand of `#[align($size_of(T))]`) so sema can type them.
    val rda: R.Result[bool, str] = bind_decorator_args(rc, d);
    if (R.is_err[bool, str](rda)) { ret rda; }

    if (d.kind == decl.DECL_KIND_COMPTIME_IF) {
        val ci: *decl.DeclComptimeIf = ?d.data.comptime_if;
        ret bind_comptime_if(rc, ci.branches_start, ci.branches_len, true);
    }
    if (d.kind == decl.DECL_KIND_USE || d.kind == decl.DECL_KIND_ERROR) {
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_FWD) {
        ret bind_fwd(rc, decl_id, ?d.data.fwd_, d.flags);
    }
    if (d.kind == decl.DECL_KIND_COMPTIME_ATTR) {
        # a bare comptime directive (`$error(...)`) binds nothing; its evaluation
        # is handled out of band.
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_FUN) {
        ret bind_fun(rc, ?d.data.fun_, decl_id);
    }
    if (d.kind == decl.DECL_KIND_REC) {
        ret bind_rec(rc, ?d.data.rec_, decl_id);
    }
    if (d.kind == decl.DECL_KIND_UNI) {
        ret bind_uni(rc, ?d.data.uni_, decl_id);
    }
    if (d.kind == decl.DECL_KIND_DEF) {
        ret bind_type(rc, d.data.def_.ty);
    }
    if (d.kind == decl.DECL_KIND_VAL || d.kind == decl.DECL_KIND_VAR) {
        if (d.data.bind.ty != id.TYPE_NIL) {
            val r: R.Result[bool, str] = bind_type(rc, d.data.bind.ty);
            if (R.is_err[bool, str](r)) { ret r; }
        }
        if (d.data.bind.init != id.EXPR_NIL) {
            ret bind_expr(rc, d.data.bind.init);
        }
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_TEST) {
        if (d.data.test_.body != id.STMT_NIL) {
            ret bind_stmt(rc, d.data.test_.body);
        }
        ret R.ok[bool, str](true);
    }
    ret R.ok[bool, str](true);
}

# resolves a `fwd ALIAS: PATH;` / `fwd PATH;` re-export. the path must end at
# a pub symbol of a dependency; that symbol is re-published into this module's
# pub surface (SYM_FLAG_PUB) under the alias (or the leaf name), with origin
# and decl pointing at the originator so consumers bind through to the source
# ---
# rc:      resolver state for the module being resolved
# decl_id: the fwd decl
# df:      the fwd payload
# flags:   the decl's flag bits
# ret:     ok(true), or an allocation error
fun bind_fwd(rc: *ResolveContext, decl_id: id.DeclId, df: *decl.DeclFwd, flags: u8) R.Result[bool, str] {
    if ((flags & decl.DECL_FLAG_PUB) != 0) {
        diagnostic.error(?rc.s.diags, rc.a.file_id, df.path, "`fwd` always re-exports; `pub fwd` is not allowed");
        ret R.ok[bool, str](true);
    }
    if (df.path.len == 0) {
        ret R.ok[bool, str](true);
    }

    # PATH ends at a module: re-export it as a public module alias (the explicit
    # alias, or the path's leaf segment). mirrors `collect_use`'s module branch
    # but publishes the alias. a library surface that re-exports whole sibling
    # submodules (`fwd std.types.bool;`) takes this path; the prefix+symbol split
    # below would otherwise misread the module leaf as a symbol of a non-module
    # prefix.
    val r_full: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, df.path);
    if (R.is_err[intern.StrId, str](r_full)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_full));
    }
    val full_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_full);
    val full_mx: *ModuleExports = find_module_exports(rc, full_id);
    if (full_mx != nil) {
        ret bind_fwd_module(rc, decl_id, df, full_mx.module);
    }

    val leaf: token.Span = leaf_span(rc, df.path);
    val prefix: token.Span = prefix_span(rc, df.path);
    if (prefix.len == 0 || leaf.len == 0) {
        diagnostic.error(?rc.s.diags, rc.a.file_id, df.path, "`fwd` path must name a symbol of a module");
        ret R.ok[bool, str](true);
    }

    val pmx: *ModuleExports = resolve_prefix_module(rc, prefix);
    if (pmx == nil) {
        diagnostic.error(?rc.s.diags, rc.a.file_id, df.path, "re-exported module is not in the dep set");
        ret R.ok[bool, str](true);
    }

    val r_leaf: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, leaf);
    if (R.is_err[intern.StrId, str](r_leaf)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_leaf));
    }
    val leaf_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_leaf);

    val ps: *PublicSymbol = find_export(pmx, leaf_id);
    if (ps == nil) {
        diagnostic.error(?rc.s.diags, rc.a.file_id, df.path, "re-exported symbol is not exported by its module");
        ret R.ok[bool, str](true);
    }

    var bind_span: token.Span = df.alias;
    if (bind_span.len == 0) {
        bind_span = leaf;
    }

    val r_name: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, bind_span);
    if (R.is_err[intern.StrId, str](r_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_name));
    }
    val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_name);

    val existing: SymbolId = scope_lookup_local(rc, rc.module_scope, name_id);
    if (existing != SYMBOL_NIL) {
        val de: R.Result[bool, str] = report_named(rc, bind_span, "re-exported name `", name_id, "` is already defined in this scope");
        if (R.is_ok[bool, str](de)) {
            report_prior_binding(rc, existing);
        }
        ret R.ok[bool, str](true);
    }

    # a leaf that is itself a module re-export (SYM_USE) keeps its target-module
    # slot, so a fwd of another library's fwd stays consumable downstream
    # (mirrors imported_symbol_for's slot preservation)
    var slot: u32 = 0;
    if (ps.kind == SYM_USE) { slot = ps.slot; }

    val r_sym: R.Result[SymbolId, str] = add_symbol(rc, ps.kind, SYM_FLAG_PUB, name_id, ps.decl, slot, ps.origin);
    if (R.is_err[SymbolId, str](r_sym)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](r_sym)); }
    val sid: SymbolId = R.unwrap_ok[SymbolId, str](r_sym);

    val r_add: R.Result[bool, str] = scope_add(rc, rc.module_scope, name_id, sid);
    if (R.is_err[bool, str](r_add)) { ret r_add; }
    if (rc.decl_symbol != nil) {
        rc.decl_symbol[decl_id] = sid;
    }
    ret R.ok[bool, str](true);
}

# re-exports module `mid` as a public module alias under a `fwd`'s alias (or the
# path's leaf segment when none is written). a SYM_USE bound at module scope whose
# slot names the target module, but carrying SYM_FLAG_PUB so it joins this
# module's pub surface - the public counterpart of `collect_use`'s module branch
# ---
# rc:      resolver state for the module being resolved
# decl_id: the fwd decl
# df:      the fwd payload
# mid:     module id to re-export
# ret:     ok(true), or an allocation error
fun bind_fwd_module(rc: *ResolveContext, decl_id: id.DeclId, df: *decl.DeclFwd, mid: session.ModuleId) R.Result[bool, str] {
    var alias_span: token.Span = df.alias;
    if (alias_span.len == 0) {
        alias_span = leaf_span(rc, df.path);
    }

    val r_name: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, alias_span);
    if (R.is_err[intern.StrId, str](r_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r_name));
    }
    val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](r_name);

    val existing: SymbolId = scope_lookup_local(rc, rc.module_scope, name_id);
    if (existing != SYMBOL_NIL) {
        val de: R.Result[bool, str] = report_named(rc, alias_span, "re-exported name `", name_id, "` is already defined in this scope");
        if (R.is_ok[bool, str](de)) {
            report_prior_binding(rc, existing);
        }
        ret R.ok[bool, str](true);
    }

    val r: R.Result[SymbolId, str] = declare(rc, SYM_USE, SYM_FLAG_PUB, alias_span, decl_id, mid::u32, rc.own_module, rc.module_scope);
    if (R.is_err[SymbolId, str](r)) { ret R.err[bool, str](R.unwrap_err[SymbolId, str](r)); }
    if (rc.decl_symbol != nil) {
        rc.decl_symbol[decl_id] = R.unwrap_ok[SymbolId, str](r);
    }
    ret R.ok[bool, str](true);
}

# binds the bodies of a `$if` / `$or` chain. ordinarily only the comptime-active
# arm is bound (discarded arms never reach name resolution). but a chain gated on
# a comptime VALUE PARAMETER cannot be selected during resolve - the parameter's
# value is fixed only per call site, at lowering - so EVERY arm is bound
# structurally; arm selection is deferred to per-value monomorphization
# ---
# rc:             resolver state for the module being resolved
# branches_start: first branch index
# branches_len:   number of branches
# at_decl_scope:  whether the chain sits in decl position
# ret:            ok(true), or a binding or eval error
fun bind_comptime_if(rc: *ResolveContext, branches_start: u32, branches_len: u32, at_decl_scope: bool) R.Result[bool, str] {
    if (!at_decl_scope && (comptime_if_gated_on_param(rc, branches_start, branches_len)
                        || comptime_if_has_type_comparison(rc, branches_start, branches_len)
                        || comptime_if_gated_on_field_descriptor(rc, branches_start, branches_len))) {
        var ai: u32 = 0;
        for (ai < branches_len) {
            val arm: *decl.ComptimeBranch = ?rc.a.comptime_branches[branches_start + ai];
            if (arm.cond != id.EXPR_NIL) {
                val rc_e: R.Result[bool, str] = bind_expr(rc, arm.cond);
                if (R.is_err[bool, str](rc_e)) { ret rc_e; }
            }
            val rb: R.Result[bool, str] = bind_stmt_list(rc, arm.body_start, arm.body_len);
            if (R.is_err[bool, str](rb)) { ret rb; }
            ai = ai + 1;
        }
        ret R.ok[bool, str](true);
    }

    var bi: u32 = 0;
    for (bi < branches_len) {
        val br: *decl.ComptimeBranch = ?rc.a.comptime_branches[branches_start + bi];
        # resolve the gate's identifiers before folding it, recording each leaf's
        # resolution identity, then reject any leaf whose binding the name-keyed
        # fold would silently misread (a runtime local/param shadowing a comptime
        # constant). eval failures themselves are reported by
        # comptime_branch_active; this check covers exactly the case where the
        # fold SUCCEEDS against the wrong binding.
        if (br.cond != id.EXPR_NIL) {
            val rce: R.Result[bool, str] = bind_expr(rc, br.cond);
            if (R.is_err[bool, str](rce)) { ret rce; }
            val rcs: R.Result[bool, str] = check_gate_shadowing(rc, br.cond);
            if (R.is_err[bool, str](rcs)) { ret rcs; }
        }
        val take_r: R.Result[bool, str] = comptime_branch_active(rc, br);
        if (R.is_err[bool, str](take_r)) { ret take_r; }
        if (R.unwrap_ok[bool, str](take_r)) {
            if (at_decl_scope) {
                ret bind_decl_list(rc, br.body_start, br.body_len);
            }
            ret bind_stmt_list(rc, br.body_start, br.body_len);
        }
        bi = bi + 1;
    }
    ret R.ok[bool, str](true);
}

# walks a folded (non-param) `$if` gate and rejects any
# leaf identifier that resolves to a runtime binding whose NAME also names a
# comptime constant in the env. the comptime fold is name-keyed, so such a gate
# folds against the constant while the resolver bound the ident to the runtime
# local / parameter - a silent wrong-arm miscompile. a runtime ident whose name
# is not in the env is left alone: the fold fails on it and
# comptime_branch_active reports that failure, so reporting here would
# duplicate it. reports at the offending leaf's span
# ---
# rc:  resolver state for the module being resolved
# eid: the gate expression to walk
# ret: ok(true), or a reported shadowing error
fun check_gate_shadowing(rc: *ResolveContext, eid: id.ExprId) R.Result[bool, str] {
    if (eid == id.EXPR_NIL) { ret R.ok[bool, str](true); }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret R.ok[bool, str](true); }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);

    if (e.kind == expr.EXPR_KIND_BINARY) {
        val rl: R.Result[bool, str] = check_gate_shadowing(rc, e.data.binary.lhs);
        if (R.is_err[bool, str](rl)) { ret rl; }
        ret check_gate_shadowing(rc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret check_gate_shadowing(rc, e.data.unary.operand);
    }
    if (e.kind != expr.EXPR_KIND_IDENT) { ret R.ok[bool, str](true); }

    if (rc.expr_resolved == nil) { ret R.ok[bool, str](true); }
    val sid: SymbolId = rc.expr_resolved[eid];
    if (sid == SYMBOL_NIL || sid >= rc.sym_len) { ret R.ok[bool, str](true); }
    val sym: *Symbol = ?rc.symbols[sid];

    # runtime by resolution identity: a block-local val/var, or a non-`$`
    # parameter. module-scope vals, imports, and comptime params are foldable.
    var runtime: bool = false;
    if (sym.kind == SYM_VAL || sym.kind == SYM_VAR) {
        runtime = (sym.flags & SYM_FLAG_MODULE) == 0;
    }
    if (sym.kind == SYM_PARAM) {
        runtime = (sym.flags & SYM_FLAG_COMPTIME) == 0;
    }
    if (!runtime) { ret R.ok[bool, str](true); }

    val id_r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, e.span);
    if (R.is_err[intern.StrId, str](id_r)) { ret R.err[bool, str](R.unwrap_err[intern.StrId, str](id_r)); }
    val nc: O.Option[*comptime.NamedConst] = comptime.lookup(rc.ctx, R.unwrap_ok[intern.StrId, str](id_r));
    if (O.is_none[*comptime.NamedConst](nc)) { ret R.ok[bool, str](true); }

    ret diagnostic.error(?rc.s.diags, rc.a.file_id, e.span,
        "comptime branch condition references a runtime binding that shadows a comptime constant");
}

# reports whether any arm gate of a `$if` chain references a comptime value
# parameter in scope. such a gate cannot be folded during resolve (the
# parameter's value is per-call-site), so the chain's arms are all bound and arm
# selection deferred to lowering
# ---
# rc:             resolver state for the module being resolved
# branches_start: first branch index
# branches_len:   number of branches
# ret:            true when an arm gate reads a comptime value parameter
fun comptime_if_gated_on_param(rc: *ResolveContext, branches_start: u32, branches_len: u32) bool {
    var bi: u32 = 0;
    for (bi < branches_len) {
        val br: *decl.ComptimeBranch = ?rc.a.comptime_branches[branches_start + bi];
        if (br.cond != id.EXPR_NIL && expr_references_comptime_param(rc, br.cond)) {
            ret true;
        }
        bi = bi + 1;
    }
    ret false;
}

# reports whether any arm of a `$if` chain is gated on a type comparison
# (`$type_of(...) == TypeName`, #1472). a type comparison cannot fold before
# types exist, so - like a comptime-param gate - its chain binds every arm and
# defers arm selection to lowering, where the type resolver is installed
# ---
# rc:             resolver state for the module being resolved
# branches_start: first branch index
# branches_len:   number of branches
# ret:            true when an arm gate contains a type comparison
fun comptime_if_has_type_comparison(rc: *ResolveContext, branches_start: u32, branches_len: u32) bool {
    var bi: u32 = 0;
    for (bi < branches_len) {
        val br: *decl.ComptimeBranch = ?rc.a.comptime_branches[branches_start + bi];
        if (br.cond != id.EXPR_NIL && gate_has_type_comparison(rc, br.cond)) {
            ret true;
        }
        bi = bi + 1;
    }
    ret false;
}

# reports whether any arm gate of a `$if` chain reads a `$each` field descriptor
# (`f.name` / `f.type` / `f.offset`). such a gate folds only once the loop variable
# is bound at the `$each` unroll, so - like a comptime-param or type-comparison
# gate - its chain binds every arm and defers arm selection to that unroll. the
# `.type` case overlaps comptime_if_has_type_comparison; the `.name` / `.offset`
# cases are covered only here.
# ---
# rc:             resolver state for the module being resolved
# branches_start: first branch index
# branches_len:   number of branches
# ret:            true when an arm gate reads a `$each` field descriptor
fun comptime_if_gated_on_field_descriptor(rc: *ResolveContext, branches_start: u32, branches_len: u32) bool {
    var bi: u32 = 0;
    for (bi < branches_len) {
        val br: *decl.ComptimeBranch = ?rc.a.comptime_branches[branches_start + bi];
        if (br.cond != id.EXPR_NIL && gate_references_field_descriptor(rc, br.cond)) {
            ret true;
        }
        bi = bi + 1;
    }
    ret false;
}

# walks a `$if` gate reporting whether it reads a `$each` field-descriptor
# projection (`f.name` / `f.type` / `f.offset`) at any depth.
# ---
# rc:  resolver state for the module being resolved
# eid: the gate expression to walk
# ret: true when a field-descriptor projection appears at any depth
fun gate_references_field_descriptor(rc: *ResolveContext, eid: id.ExprId) bool {
    if (eid == id.EXPR_NIL) { ret false; }
    if (is_field_descriptor_operand(rc, eid)) { ret true; }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);
    if (e.kind == expr.EXPR_KIND_BINARY) {
        ret gate_references_field_descriptor(rc, e.data.binary.lhs)
         || gate_references_field_descriptor(rc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret gate_references_field_descriptor(rc, e.data.unary.operand);
    }
    ret false;
}

# walks a `$if` gate reporting whether it contains a type comparison - an
# `==` / `!=` with a `$type_of(...)` operand - at any depth
# ---
# rc:  resolver state for the module being resolved
# eid: the gate expression to walk
# ret: true when a type comparison appears at any depth
fun gate_has_type_comparison(rc: *ResolveContext, eid: id.ExprId) bool {
    if (eid == id.EXPR_NIL) { ret false; }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);
    if (e.kind == expr.EXPR_KIND_BINARY) {
        if ((e.data.binary.op == expr.BIN_EQ || e.data.binary.op == expr.BIN_NEQ)
            && (comptime.is_type_comparison(rc.a, rc.source, ?e.data.binary)
             || is_field_type_operand(rc, e.data.binary.lhs)
             || is_field_type_operand(rc, e.data.binary.rhs))) {
            ret true;
        }
        ret gate_has_type_comparison(rc, e.data.binary.lhs)
         || gate_has_type_comparison(rc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret gate_has_type_comparison(rc, e.data.unary.operand);
    }
    ret false;
}

# walks `eid` reporting whether any leaf identifier resolves, in the current
# scope chain, to a comptime value parameter (SYM_PARAM with SYM_FLAG_COMPTIME).
# the lookup is valid here because parameters are already declared in the
# enclosing param scope before a body's statements are bound
# ---
# rc:  resolver state for the module being resolved
# eid: the expression to walk
# ret: true when a leaf resolves to a comptime value parameter
fun expr_references_comptime_param(rc: *ResolveContext, eid: id.ExprId) bool {
    if (eid == id.EXPR_NIL) { ret false; }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);

    if (e.kind == expr.EXPR_KIND_IDENT) {
        val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, e.span);
        if (R.is_err[intern.StrId, str](r)) { ret false; }
        val name: intern.StrId = R.unwrap_ok[intern.StrId, str](r);
        val sid: SymbolId = scope_lookup_chain(rc, rc.current_scope, name);
        if (sid == SYMBOL_NIL) { ret false; }
        val sym: *Symbol = ?rc.symbols[sid];
        ret sym.kind == SYM_PARAM && (sym.flags & SYM_FLAG_COMPTIME) != 0;
    }
    if (e.kind == expr.EXPR_KIND_BINARY) {
        ret expr_references_comptime_param(rc, e.data.binary.lhs)
         || expr_references_comptime_param(rc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret expr_references_comptime_param(rc, e.data.unary.operand);
    }
    ret false;
}

# bind a function's generics, parameter types, return type, and body
#
# generics and parameters open fresh nested scopes restored on the way out.
# ---
# rc:      resolver state for the module being resolved
# f:       the function decl payload
# decl_id: the function's DeclId
# ret:     ok(true), or a binding error
fun bind_fun(rc: *ResolveContext, f: *decl.DeclFun, decl_id: id.DeclId) R.Result[bool, str] {
    val r_g: R.Result[ScopeId, str] = open_scope(rc, rc.current_scope);
    if (R.is_err[ScopeId, str](r_g)) { ret R.err[bool, str](R.unwrap_err[ScopeId, str](r_g)); }
    val gen_scope: ScopeId = R.unwrap_ok[ScopeId, str](r_g);
    val saved_scope: ScopeId = rc.current_scope;
    rc.current_scope = gen_scope;

    var gi: u32 = 0;
    for (gi < f.generics_len) {
        val name: token.Span = rc.a.generic_names[f.generics_start + gi];
        val r: R.Result[SymbolId, str] = declare(rc, SYM_GENERIC, 0, name, decl_id, gi, rc.own_module, gen_scope);
        if (R.is_err[SymbolId, str](r)) {
            rc.current_scope = saved_scope;
            ret R.err[bool, str](R.unwrap_err[SymbolId, str](r));
        }
        gi = gi + 1;
    }

    val r_p: R.Result[ScopeId, str] = open_scope(rc, gen_scope);
    if (R.is_err[ScopeId, str](r_p)) {
        rc.current_scope = saved_scope;
        ret R.err[bool, str](R.unwrap_err[ScopeId, str](r_p));
    }
    val param_scope: ScopeId = R.unwrap_ok[ScopeId, str](r_p);
    rc.current_scope = param_scope;

    var pi: u32 = 0;
    for (pi < f.params_len) {
        val tn: *decl.TypedName = ?rc.a.typed_names[f.params_start + pi];
        val rt: R.Result[bool, str] = bind_type(rc, tn.ty);
        if (R.is_err[bool, str](rt)) {
            rc.current_scope = saved_scope;
            ret rt;
        }
        val pflags: u8 = param_flags(tn);
        val r: R.Result[SymbolId, str] = declare(rc, SYM_PARAM, pflags, tn.name, decl_id, pi, rc.own_module, param_scope);
        if (R.is_err[SymbolId, str](r)) {
            rc.current_scope = saved_scope;
            ret R.err[bool, str](R.unwrap_err[SymbolId, str](r));
        }
        pi = pi + 1;
    }

    if (f.return_type != id.TYPE_NIL) {
        val rt: R.Result[bool, str] = bind_type(rc, f.return_type);
        if (R.is_err[bool, str](rt)) {
            rc.current_scope = saved_scope;
            ret rt;
        }
    }

    if (f.body != id.STMT_NIL) {
        val rb: R.Result[bool, str] = bind_stmt(rc, f.body);
        if (R.is_err[bool, str](rb)) {
            rc.current_scope = saved_scope;
            ret rb;
        }
    }

    rc.current_scope = saved_scope;
    ret R.ok[bool, str](true);
}

# maps a parameter's comptime marker to a SYM_PARAM flag bitfield
# ---
# tn:  the typed-name (parameter) to inspect
# ret: the SYM_PARAM flag bitfield
fun param_flags(tn: *decl.TypedName) u8 {
    if (tn.comptime) { ret SYM_FLAG_COMPTIME; }
    ret 0;
}

# bind a record declaration's generics and field types
# ---
# rc:      resolver state for the module being resolved
# r:       the record decl payload
# decl_id: the record's DeclId
# ret:     ok(true), or a binding error
fun bind_rec(rc: *ResolveContext, r: *decl.DeclRec, decl_id: id.DeclId) R.Result[bool, str] {
    ret bind_aggregate(rc, r.generics_start, r.generics_len, r.fields_start, r.fields_len, decl_id);
}

# bind a union declaration's generics and field types
# ---
# rc:      resolver state for the module being resolved
# u:       the union decl payload
# decl_id: the union's DeclId
# ret:     ok(true), or a binding error
fun bind_uni(rc: *ResolveContext, u: *decl.DeclUni, decl_id: id.DeclId) R.Result[bool, str] {
    ret bind_aggregate(rc, u.generics_start, u.generics_len, u.fields_start, u.fields_len, decl_id);
}

# binds the generic params and field types of a rec/uni declaration. generics
# are declared in a fresh scope so field types can reference them; the fields
# themselves are not scope bindings (member access is resolved later by sema)
# ---
# rc:             resolver state for the module being resolved
# generics_start: first generic-name index
# generics_len:   number of generics
# fields_start:   first field index
# fields_len:     number of fields
# decl_id:        the aggregate's DeclId
# ret:            ok(true), or a binding error
fun bind_aggregate(rc: *ResolveContext, generics_start: u32, generics_len: u32, fields_start: u32, fields_len: u32, decl_id: id.DeclId) R.Result[bool, str] {
    val r_g: R.Result[ScopeId, str] = open_scope(rc, rc.current_scope);
    if (R.is_err[ScopeId, str](r_g)) { ret R.err[bool, str](R.unwrap_err[ScopeId, str](r_g)); }
    val gen_scope: ScopeId = R.unwrap_ok[ScopeId, str](r_g);
    val saved_scope: ScopeId = rc.current_scope;
    rc.current_scope = gen_scope;

    var gi: u32 = 0;
    for (gi < generics_len) {
        val name: token.Span = rc.a.generic_names[generics_start + gi];
        val rd: R.Result[SymbolId, str] = declare(rc, SYM_GENERIC, 0, name, decl_id, gi, rc.own_module, gen_scope);
        if (R.is_err[SymbolId, str](rd)) {
            rc.current_scope = saved_scope;
            ret R.err[bool, str](R.unwrap_err[SymbolId, str](rd));
        }
        gi = gi + 1;
    }

    var fi: u32 = 0;
    for (fi < fields_len) {
        val tn: *decl.TypedName = ?rc.a.typed_names[fields_start + fi];
        val rt: R.Result[bool, str] = bind_type(rc, tn.ty);
        if (R.is_err[bool, str](rt)) {
            rc.current_scope = saved_scope;
            ret rt;
        }
        fi = fi + 1;
    }

    rc.current_scope = saved_scope;
    ret R.ok[bool, str](true);
}

# bind every statement in `[start, start + len)` of the stmt-id pool
# ---
# rc:    resolver state for the module being resolved
# start: first index into the stmt-id pool
# len:   number of statements
# ret:   ok(true), or a binding error
fun bind_stmt_list(rc: *ResolveContext, start: u32, len: u32) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val sid: id.StmtId = rc.a.stmt_ids[start + i];
        val r: R.Result[bool, str] = bind_stmt(rc, sid);
        if (R.is_err[bool, str](r)) { ret r; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# bind the names referenced by one statement and its substatements
# ---
# rc:  resolver state for the module being resolved
# sid: the statement to bind
# ret: ok(true), or a binding error
fun bind_stmt(rc: *ResolveContext, sid: id.StmtId) R.Result[bool, str] {
    if (sid == id.STMT_NIL) { ret R.ok[bool, str](true); }
    val s_opt: O.Option[*stmt.Stmt] = ast.get_stmt(rc.a, sid);
    if (O.is_none[*stmt.Stmt](s_opt)) { ret R.err[bool, str]("StmtId out of range"); }
    val s: *stmt.Stmt = O.unwrap[*stmt.Stmt](s_opt);

    if (s.kind == stmt.STMT_KIND_BLOCK) { ret bind_block(rc, ?s.data.block); }
    if (s.kind == stmt.STMT_KIND_EXPR)  { ret bind_expr(rc, s.data.expr.expr); }
    if (s.kind == stmt.STMT_KIND_RET) {
        if (s.data.ret_.value == id.EXPR_NIL) { ret R.ok[bool, str](true); }
        ret bind_expr(rc, s.data.ret_.value);
    }
    if (s.kind == stmt.STMT_KIND_FIN)   { ret bind_stmt(rc, s.data.fin_.body); }
    if (s.kind == stmt.STMT_KIND_BRK || s.kind == stmt.STMT_KIND_CNT) {
        ret R.ok[bool, str](true);
    }
    if (s.kind == stmt.STMT_KIND_IF) {
        val rc_e: R.Result[bool, str] = bind_expr(rc, s.data.if_.cond);
        if (R.is_err[bool, str](rc_e)) { ret rc_e; }
        val rt: R.Result[bool, str] = bind_stmt(rc, s.data.if_.then_block);
        if (R.is_err[bool, str](rt)) { ret rt; }
        ret bind_stmt(rc, s.data.if_.else_block);
    }
    if (s.kind == stmt.STMT_KIND_FOR) {
        if (s.data.for_.cond != id.EXPR_NIL) {
            val rc_e: R.Result[bool, str] = bind_expr(rc, s.data.for_.cond);
            if (R.is_err[bool, str](rc_e)) { ret rc_e; }
        }
        ret bind_stmt(rc, s.data.for_.body);
    }
    if (s.kind == stmt.STMT_KIND_DECL) {
        ret bind_local_decl(rc, s.data.decl.decl);
    }
    if (s.kind == stmt.STMT_KIND_ASM) {
        ret R.ok[bool, str](true);
    }
    if (s.kind == stmt.STMT_KIND_COMPTIME_IF) {
        ret bind_comptime_if(rc, s.data.comptime_if.branches_start, s.data.comptime_if.branches_len, false);
    }
    if (s.kind == stmt.STMT_KIND_COMPTIME_EACH) {
        ret bind_comptime_each(rc, ?s.data.comptime_each);
    }
    if (s.kind == stmt.STMT_KIND_COMPTIME_ATTR) {
        # a bare comptime directive (`$error(...)`) binds nothing; its evaluation
        # is handled out of band at sema.
        ret R.ok[bool, str](true);
    }
    ret R.ok[bool, str](true);
}

# binds a `$each <ident> in <seq> { body }` (#1473): the sequence's `$fields(T)`
# binds T as a type; the loop variable is declared in a fresh scope as a comptime
# binding visible to the body, which is then bound. arm selection / expansion is
# deferred to sema + lowering
# ---
# rc:  resolver state for the module being resolved
# ce:  the `$each` statement payload
# ret: ok(true), or a binding error
fun bind_comptime_each(rc: *ResolveContext, ce: *stmt.StmtComptimeEach) R.Result[bool, str] {
    if (comptime.is_fields_call(rc.a, rc.source, ce.seq)) {
        val targ: id.ExprId = comptime.fields_type_arg(rc.a, ce.seq);
        if (targ != id.EXPR_NIL) {
            val rt: R.Result[bool, str] = bind_intrinsic_type_arg(rc, targ);
            if (R.is_err[bool, str](rt)) { ret rt; }
        }
    }
    or {
        val rs: R.Result[bool, str] = bind_expr(rc, ce.seq);
        if (R.is_err[bool, str](rs)) { ret rs; }
    }

    val r_s: R.Result[ScopeId, str] = open_scope(rc, rc.current_scope);
    if (R.is_err[ScopeId, str](r_s)) { ret R.err[bool, str](R.unwrap_err[ScopeId, str](r_s)); }
    val saved: ScopeId = rc.current_scope;
    rc.current_scope = R.unwrap_ok[ScopeId, str](r_s);

    val rd: R.Result[SymbolId, str] = declare(rc, SYM_VAL, SYM_FLAG_COMPTIME, ce.var_name, id.DECL_NIL, 0, rc.own_module, rc.current_scope);
    if (R.is_err[SymbolId, str](rd)) { rc.current_scope = saved; ret R.err[bool, str](R.unwrap_err[SymbolId, str](rd)); }

    val rb: R.Result[bool, str] = bind_stmt_list(rc, ce.body_start, ce.body_len);
    rc.current_scope = saved;
    ret rb;
}

# bind a block's statements in a fresh child scope
# ---
# rc:  resolver state for the module being resolved
# b:   the block payload
# ret: ok(true), or a binding error
fun bind_block(rc: *ResolveContext, b: *stmt.StmtBlock) R.Result[bool, str] {
    val r_s: R.Result[ScopeId, str] = open_scope(rc, rc.current_scope);
    if (R.is_err[ScopeId, str](r_s)) { ret R.err[bool, str](R.unwrap_err[ScopeId, str](r_s)); }
    val saved: ScopeId = rc.current_scope;
    rc.current_scope = R.unwrap_ok[ScopeId, str](r_s);

    val r: R.Result[bool, str] = bind_stmt_list(rc, b.stmts_start, b.stmts_len);
    rc.current_scope = saved;
    ret r;
}

# locals (val/var inside a block) introduce sequentially visible bindings:
# the type and initializer are bound first against the existing scope, then
# the new symbol is added so subsequent statements can see it
# ---
# rc:      resolver state for the module being resolved
# decl_id: the local val/var decl
# ret:     ok(true), or an allocation error
fun bind_local_decl(rc: *ResolveContext, decl_id: id.DeclId) R.Result[bool, str] {
    if (decl_id == id.DECL_NIL) { ret R.ok[bool, str](true); }
    val d_opt: O.Option[*decl.Decl] = ast.get_decl(rc.a, decl_id);
    if (O.is_none[*decl.Decl](d_opt)) { ret R.err[bool, str]("DeclId out of range"); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](d_opt);

    if (d.kind != decl.DECL_KIND_VAL && d.kind != decl.DECL_KIND_VAR) {
        ret R.ok[bool, str](true);
    }

    if (d.data.bind.ty != id.TYPE_NIL) {
        val rt: R.Result[bool, str] = bind_type(rc, d.data.bind.ty);
        if (R.is_err[bool, str](rt)) { ret rt; }
    }
    if (d.data.bind.init != id.EXPR_NIL) {
        val re: R.Result[bool, str] = bind_expr(rc, d.data.bind.init);
        if (R.is_err[bool, str](re)) { ret re; }
    }

    val kind: SymKind = if_val_kind(d.kind == decl.DECL_KIND_VAL);
    val r_sym: R.Result[SymbolId, str] = declare(rc, kind, 0, d.data.bind.name, decl_id, 0, rc.own_module, rc.current_scope);
    if (R.is_err[SymbolId, str](r_sym)) {
        ret R.err[bool, str](R.unwrap_err[SymbolId, str](r_sym));
    }
    if (rc.decl_symbol != nil) {
        rc.decl_symbol[decl_id] = R.unwrap_ok[SymbolId, str](r_sym);
    }

    # a block-local comptime val is deliberately NOT bound into the comptime ctx:
    # the ctx holds only the never-closed module frame plus a transient value-
    # instance param frame, with no poppable block frames in any pass. binding a
    # block local here would never be popped and could shadow a same-named module
    # const in a later function (the #1143 leak). its lexical scope above still
    # makes runtime uses of the local resolve.

    ret R.ok[bool, str](true);
}

# SYM_VAL when `is_val`, otherwise SYM_VAR
# ---
# is_val: whether the local is a `val`
# ret:    the matching SymKind
fun if_val_kind(is_val: bool) SymKind {
    if (is_val) { ret SYM_VAL; }
    ret SYM_VAR;
}

# bind the names referenced by one expression and its subexpressions
# ---
# rc:  resolver state for the module being resolved
# eid: the expression to bind
# ret: ok(true), or a binding error
fun bind_expr(rc: *ResolveContext, eid: id.ExprId) R.Result[bool, str] {
    if (eid == id.EXPR_NIL) { ret R.ok[bool, str](true); }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret R.err[bool, str]("ExprId out of range"); }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);

    if (e.kind == expr.EXPR_KIND_IDENT) {
        ret bind_ident(rc, eid, e.span);
    }
    if (e.kind == expr.EXPR_KIND_BINARY) {
        # a type comparison (`$type_of(...) == TypeName`, #1472) binds its operands
        # specially: a `$type_of(e)` operand binds only its inner value `e` (the
        # comptime-ident callee is a builtin), and the other operand is a type-name
        # spelling bound as a type so sema can recover the named type.
        if ((e.data.binary.op == expr.BIN_EQ || e.data.binary.op == expr.BIN_NEQ)
            && (comptime.is_type_comparison(rc.a, rc.source, ?e.data.binary)
             || is_field_type_operand(rc, e.data.binary.lhs)
             || is_field_type_operand(rc, e.data.binary.rhs))) {
            ret bind_type_comparison(rc, ?e.data.binary);
        }
        val rl: R.Result[bool, str] = bind_expr(rc, e.data.binary.lhs);
        if (R.is_err[bool, str](rl)) { ret rl; }
        ret bind_expr(rc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret bind_expr(rc, e.data.unary.operand);
    }
    if (e.kind == expr.EXPR_KIND_SPREAD) {
        # `va...`: bind the spread operand (the pack identifier).
        ret bind_expr(rc, e.data.spread.inner);
    }
    if (e.kind == expr.EXPR_KIND_CALL) {
        # a provisional bracket call `callee[x](args)` whose payload read as both
        # a type list and an index expression: choose the reading now from the
        # callee's resolved kind and canonicalize the node before ordinary call
        # binding sees it.
        if (e.data.call.index_callee != id.EXPR_NIL) {
            ret resolve_bracket_call(rc, eid);
        }

        # a comptime value intrinsic (`$size_of`/`$align_of`/`$offset_of`) takes
        # a type-naming first argument (and, for `$offset_of`, a bare field name)
        # rather than value expressions, so it binds its arguments specially.
        val intr: O.Option[R.Result[bool, str]] = bind_comptime_intrinsic_call(rc, ?e.data.call);
        if (O.is_some[R.Result[bool, str]](intr)) { ret O.unwrap[R.Result[bool, str]](intr); }

        val rc_e: R.Result[bool, str] = bind_expr(rc, e.data.call.callee);
        if (R.is_err[bool, str](rc_e)) { ret rc_e; }
        ret bind_generic_call(rc, e.data.call.type_args_start, e.data.call.type_args_len, e.data.call.args_start, e.data.call.args_len);
    }
    if (e.kind == expr.EXPR_KIND_INDEX) {
        val ro: R.Result[bool, str] = bind_expr(rc, e.data.index.object);
        if (R.is_err[bool, str](ro)) { ret ro; }
        ret bind_expr(rc, e.data.index.index);
    }
    if (e.kind == expr.EXPR_KIND_PROJECT) {
        # `v.[f]`: bind the instance, then the field descriptor (the `$each` loop
        # variable, resolved against the enclosing `$each` scope).
        val ro: R.Result[bool, str] = bind_expr(rc, e.data.project.object);
        if (R.is_err[bool, str](ro)) { ret ro; }
        ret bind_expr(rc, e.data.project.field);
    }
    if (e.kind == expr.EXPR_KIND_MEMBER) {
        val ro: R.Result[bool, str] = bind_expr(rc, e.data.member.object);
        if (R.is_err[bool, str](ro)) { ret ro; }
        ret bind_member_qualified(rc, eid, ?e.data.member);
    }
    if (e.kind == expr.EXPR_KIND_CAST) {
        val rv: R.Result[bool, str] = bind_expr(rc, e.data.cast.value);
        if (R.is_err[bool, str](rv)) { ret rv; }
        ret bind_type(rc, e.data.cast.ty);
    }
    if (e.kind == expr.EXPR_KIND_ARRAY_LIT) {
        val rt: R.Result[bool, str] = bind_type(rc, e.data.array_lit.ty);
        if (R.is_err[bool, str](rt)) { ret rt; }
        ret bind_expr_list(rc, e.data.array_lit.elems_start, e.data.array_lit.elems_len);
    }
    if (e.kind == expr.EXPR_KIND_STRUCT_LIT) {
        val rt: R.Result[bool, str] = bind_type(rc, e.data.struct_lit.ty);
        if (R.is_err[bool, str](rt)) { ret rt; }
        var fi: u32 = 0;
        for (fi < e.data.struct_lit.fields_len) {
            val finit: *expr.FieldInit = ?rc.a.field_inits[e.data.struct_lit.fields_start + fi];
            val rf: R.Result[bool, str] = bind_expr(rc, finit.value);
            if (R.is_err[bool, str](rf)) { ret rf; }
            fi = fi + 1;
        }
        ret R.ok[bool, str](true);
    }
    ret R.ok[bool, str](true);
}

# bind every expression in `[start, start + len)` of the expr-id pool
# ---
# rc:    resolver state for the module being resolved
# start: first index into the expr-id pool
# len:   number of expressions
# ret:   ok(true), or a binding error
fun bind_expr_list(rc: *ResolveContext, start: u32, len: u32) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val eid: id.ExprId = rc.a.expr_ids[start + i];
        val r: R.Result[bool, str] = bind_expr(rc, eid);
        if (R.is_err[bool, str](r)) { ret r; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# resolves a provisional bracket call `callee[x](args)` (ExprCall.index_callee
# set) that the parser could not classify: `[x]` read as both a type-argument
# list and an index expression. the choice is the callee's resolved kind - a
# function, type, or imported name takes the type arguments (a generic call); a
# value, or any non-name callee, makes `[x]` an index (index-then-call). the
# node is canonicalized to the chosen shape (index_callee cleared) and its parts
# bound exactly once, so sema sees an ordinary generic call or index-then-call
# ---
# rc:  resolver state for the module being resolved
# eid: the provisional bracket-call expression
# ret: ok(true), or a binding error
fun resolve_bracket_call(rc: *ResolveContext, eid: id.ExprId) R.Result[bool, str] {
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret R.err[bool, str]("ExprId out of range"); }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);

    val callee:          id.ExprId = e.data.call.callee;
    val index_callee:    id.ExprId = e.data.call.index_callee;
    val type_args_start: u32       = e.data.call.type_args_start;
    val type_args_len:   u32       = e.data.call.type_args_len;
    val args_start:      u32       = e.data.call.args_start;
    val args_len:        u32       = e.data.call.args_len;

    # bind the callee once and read its kind: a function, type, or imported name
    # takes the type arguments; anything else (a value, an index/call result, or
    # an unresolved name) makes the bracket an index.
    val rc_e: R.Result[bool, str] = bind_expr(rc, callee);
    if (R.is_err[bool, str](rc_e)) { ret rc_e; }

    if (callee_accepts_type_args(rc, callee)) {
        # generic call: drop the index reading and bind the type arguments.
        # `e` stays valid - resolve binding never appends to ast.exprs.
        e.data.call.index_callee = id.EXPR_NIL;
        ret bind_generic_call(rc, type_args_start, type_args_len, args_start, args_len);
    }

    # index-then-call: the effective callee is the pre-built `INDEX(callee, x)`,
    # whose object (the now-bound callee) needs no rebinding. bind the subscript,
    # then canonicalize the call onto the index.
    val idx_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, index_callee);
    if (O.is_none[*expr.Expr](idx_opt)) { ret R.err[bool, str]("ExprId out of range"); }
    val idxn: *expr.Expr = O.unwrap[*expr.Expr](idx_opt);
    val rs: R.Result[bool, str] = bind_expr(rc, idxn.data.index.index);
    if (R.is_err[bool, str](rs)) { ret rs; }

    e.data.call.callee          = index_callee;
    e.data.call.index_callee    = id.EXPR_NIL;
    e.data.call.type_args_start = 0;
    e.data.call.type_args_len   = 0;
    ret bind_expr_list(rc, args_start, args_len);
}

# binds a generic call's type arguments and value arguments - the tail shared by
# the ordinary call path and a provisional bracket call resolved to a generic
# call
# ---
# rc:              resolver state for the module being resolved
# type_args_start: first type-argument index
# type_args_len:   number of type arguments
# args_start:      first value-argument index
# args_len:        number of value arguments
# ret:             ok(true), or a binding error
fun bind_generic_call(rc: *ResolveContext, type_args_start: u32, type_args_len: u32, args_start: u32, args_len: u32) R.Result[bool, str] {
    var ti: u32 = 0;
    for (ti < type_args_len) {
        val arg_id: id.TypeId = rc.a.type_ids[type_args_start + ti];
        val rt: R.Result[bool, str] = bind_type(rc, arg_id);
        if (R.is_err[bool, str](rt)) { ret rt; }
        ti = ti + 1;
    }
    ret bind_expr_list(rc, args_start, args_len);
}

# true when a provisional bracket call's callee resolves to a name that can take
# generic type arguments (a function, type, or imported symbol). a value callee
# - or a non-name callee such as an index or call result - means the bracket was
# an index. an unresolved name returns false so the index reading is taken and
# the single unresolved diagnostic from binding the callee is not compounded by
# spurious type-argument errors
# ---
# rc:     resolver state for the module being resolved
# callee: the resolved callee expression
# ret:    true when the callee can take generic type arguments
fun callee_accepts_type_args(rc: *ResolveContext, callee: id.ExprId) bool {
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, callee);
    if (O.is_none[*expr.Expr](e_opt)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);
    if (e.kind != expr.EXPR_KIND_IDENT && e.kind != expr.EXPR_KIND_MEMBER) { ret false; }
    if (rc.expr_resolved == nil)                                           { ret false; }
    val sid: SymbolId = rc.expr_resolved[callee];
    if (sid == SYMBOL_NIL || sid >= rc.sym_len) { ret false; }
    val sym: *Symbol = ?rc.symbols[sid];
    ret sym.kind == SYM_FUN || sym.kind == SYM_REC || sym.kind == SYM_UNI
     || sym.kind == SYM_DEF || sym.kind == SYM_GENERIC || sym.kind == SYM_PRIM
     || sym.kind == SYM_IMPORTED;
}

# resolve an identifier against the scope chain, reporting an unresolved name
# ---
# rc:   resolver state for the module being resolved
# eid:  the identifier expression
# span: the identifier's source span
# ret:  ok(true) (an unresolved name is reported, not failed), or an allocation error
fun bind_ident(rc: *ResolveContext, eid: id.ExprId, span: token.Span) R.Result[bool, str] {
    val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, span);
    if (R.is_err[intern.StrId, str](r)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r));
    }
    val name: intern.StrId = R.unwrap_ok[intern.StrId, str](r);
    val sid: SymbolId = scope_lookup_chain(rc, rc.current_scope, name);
    if (sid == SYMBOL_NIL) {
        val re: R.Result[bool, str] = report_named(rc, span, "unresolved identifier `", name, "`");
        if (R.is_ok[bool, str](re)) { attach_suggestion(rc, name); }
    }
    or {
        if (rc.expr_resolved != nil) { rc.expr_resolved[eid] = sid; }
    }
    ret R.ok[bool, str](true);
}

# scan the visible scope chain for the in-scope name
# closest to the unresolved `target` and, when one is near enough, attach a
# `did you mean `<name>`?` note to the just-reported diagnostic. names within
# edit distance MAX_SUGGEST_DISTANCE (and no further than half the target's
# length) qualify; the nearest qualifying name wins. a no-op when nothing is
# close enough
# ---
# rc:     resolver state for the module being resolved
# target: the unresolved name
fun attach_suggestion(rc: *ResolveContext, target: intern.StrId) {
    val to: O.Option[str] = intern.lookup(?rc.s.interner, target);
    if (O.is_none[str](to)) { ret; }
    val tname: str = O.unwrap[str](to);
    val tlen: usize = str_len(tname);
    if (tlen == 0) { ret; }

    var best_sym:  SymbolId = SYMBOL_NIL;
    var best_dist: usize = MAX_SUGGEST_DISTANCE + 1;
    var max_dist:  usize = tlen / 2;
    if (max_dist > MAX_SUGGEST_DISTANCE) { max_dist = MAX_SUGGEST_DISTANCE; }

    var cur: ScopeId = rc.current_scope;
    for (cur != SCOPE_NIL) {
        val sc: *Scope = ?rc.scopes[cur];
        var i: u32 = 0;
        for (i < sc.len) {
            val cname_id: intern.StrId = sc.entries[i].name;
            if (cname_id != target) {
                val co: O.Option[str] = intern.lookup(?rc.s.interner, cname_id);
                if (O.is_some[str](co)) {
                    val cname: str = O.unwrap[str](co);
                    val dist: usize = edit_distance(tname, cname, best_dist);
                    if (dist <= max_dist && dist < best_dist) {
                        best_dist = dist;
                        best_sym  = sc.entries[i].sym;
                    }
                }
            }
            i = i + 1;
        }
        cur = rc.scopes[cur].parent;
    }

    if (best_sym == SYMBOL_NIL) { ret; }
    val bo: O.Option[str] = intern.lookup(?rc.s.interner, rc.symbols[best_sym].name);
    if (O.is_none[str](bo)) { ret; }
    val bname: str = O.unwrap[str](bo);

    val note: str = diagnostic.suggestion_build(rc.s.alloc, bname);
    if (note == nil) { ret; }
    diagnostic.attach_help(?rc.s.diags, note);
    str_free(rc.s.alloc, note);
}

# emit an error at `span` whose message embeds the interned name
# `name_id` between `prefix` and `suffix`, e.g. `unresolved identifier `<name>``.
# returns the sink's append result so a caller can gate an attached note on the
# error actually landing. on any allocation failure the message degrades to the
# static `prefix` text alone so the diagnostic is always reported
# ---
# rc:      resolver state for the module being resolved
# span:    span to report at
# prefix:  text before the name
# name_id: interned name to embed
# suffix:  text after the name
# ret:     the diagnostic sink's append result
fun report_named(rc: *ResolveContext, span: token.Span, prefix: str, name_id: intern.StrId, suffix: str) R.Result[bool, str] {
    val no: O.Option[str] = intern.lookup(?rc.s.interner, name_id);
    if (O.is_none[str](no)) {
        ret diagnostic.error(?rc.s.diags, rc.a.file_id, span, prefix);
    }
    val name: str = O.unwrap[str](no);

    val pn: usize = str_len(prefix);
    val nn: usize = str_len(name);
    val sn: usize = str_len(suffix);
    val total: usize = pn + nn + sn;

    val r: R.Result[*char, str] = A.allocate[char](rc.s.alloc, total + 1);
    if (R.is_err[*char, str](r)) {
        ret diagnostic.error(?rc.s.diags, rc.a.file_id, span, prefix);
    }
    val buf: str = R.unwrap_ok[*char, str](r);

    memory.raw_copy(buf::ptr, prefix::ptr, pn);
    memory.raw_copy((buf::usize + pn)::ptr, name::ptr, nn);
    memory.raw_copy((buf::usize + pn + nn)::ptr, suffix::ptr, sn);
    buf[total] = 0;

    val emit: R.Result[bool, str] = diagnostic.error(?rc.s.diags, rc.a.file_id, span, buf);
    A.deallocate[char](rc.s.alloc, buf, total + 1);
    ret emit;
}

# emit an error at `span` interpolating two interned names into
# `<prefix><a><mid><b><suffix>`, e.g. ``no symbol `x` exported by `mod` ``. like
# report_named it degrades to the static `prefix` on any lookup or allocation
# failure so the diagnostic always lands
# ---
# rc:     resolver state for the module being resolved
# span:   span to report at
# prefix: text before the first name
# a_id:   first interned name
# mid:    text between the names
# b_id:   second interned name
# suffix: text after the second name
# ret:    the diagnostic sink's append result
fun report_named2(rc: *ResolveContext, span: token.Span, prefix: str, a_id: intern.StrId, mid: str, b_id: intern.StrId, suffix: str) R.Result[bool, str] {
    val ao: O.Option[str] = intern.lookup(?rc.s.interner, a_id);
    val bo: O.Option[str] = intern.lookup(?rc.s.interner, b_id);
    if (O.is_none[str](ao) || O.is_none[str](bo)) {
        ret diagnostic.error(?rc.s.diags, rc.a.file_id, span, prefix);
    }
    val a: str = O.unwrap[str](ao);
    val b: str = O.unwrap[str](bo);

    val pn: usize = str_len(prefix);
    val an: usize = str_len(a);
    val mn: usize = str_len(mid);
    val bn: usize = str_len(b);
    val sn: usize = str_len(suffix);
    val total: usize = pn + an + mn + bn + sn;

    val r: R.Result[*char, str] = A.allocate[char](rc.s.alloc, total + 1);
    if (R.is_err[*char, str](r)) {
        ret diagnostic.error(?rc.s.diags, rc.a.file_id, span, prefix);
    }
    val buf: str = R.unwrap_ok[*char, str](r);

    var off: usize = 0;
    memory.raw_copy((buf::usize + off)::ptr, prefix::ptr, pn); off = off + pn;
    memory.raw_copy((buf::usize + off)::ptr, a::ptr, an);      off = off + an;
    memory.raw_copy((buf::usize + off)::ptr, mid::ptr, mn);    off = off + mn;
    memory.raw_copy((buf::usize + off)::ptr, b::ptr, bn);      off = off + bn;
    memory.raw_copy((buf::usize + off)::ptr, suffix::ptr, sn);
    buf[total] = 0;

    val emit: R.Result[bool, str] = diagnostic.error(?rc.s.diags, rc.a.file_id, span, buf);
    A.deallocate[char](rc.s.alloc, buf, total + 1);
    ret emit;
}

# largest edit distance a "did you mean" candidate may
# differ from the unresolved name by
val MAX_SUGGEST_DISTANCE: usize = 2;

# Levenshtein distance between `a` and `b`, capped so the search
# can abandon a candidate early. returns a value strictly greater than `cap`
# (specifically `cap + 1`) the moment every cell in a row exceeds `cap`,
# letting callers prune candidates that cannot beat the current best
# ---
# a:   first string
# b:   second string
# cap: abandon threshold
# ret: the Levenshtein distance, or cap + 1 once every row exceeds cap
fun edit_distance(a: str, b: str, cap: usize) usize {
    val la: usize = str_len(a);
    val lb: usize = str_len(b);
    if (la == 0) { ret lb; }
    if (lb == 0) { ret la; }

    var prev: [128]usize;
    var curr: [128]usize;
    if (lb + 1 > SUGGEST_ROW) { ret cap + 1; }

    var j: usize = 0;
    for (j <= lb) { prev[j] = j; j = j + 1; }

    var i: usize = 1;
    for (i <= la) {
        curr[0] = i;
        var row_min: usize = i;
        var k: usize = 1;
        for (k <= lb) {
            var cost: usize = 1;
            if (a[i - 1] == b[k - 1]) { cost = 0; }
            var m: usize = prev[k] + 1;
            val del: usize = curr[k - 1] + 1;
            if (del < m) { m = del; }
            val sub: usize = prev[k - 1] + cost;
            if (sub < m) { m = sub; }
            curr[k] = m;
            if (m < row_min) { row_min = m; }
            k = k + 1;
        }
        if (row_min > cap) { ret cap + 1; }
        var t: usize = 0;
        for (t <= lb) { prev[t] = curr[t]; t = t + 1; }
        i = i + 1;
    }
    ret prev[lb];
}

# capacity of the edit-distance DP rows (matches the literal row
# array length); candidates whose length reaches this bound are skipped, since
# their distance cannot be small anyway
val SUGGEST_ROW: usize = 128;

# classifies a call's callee as a comptime value intrinsic by its name: 1 for
# `$size_of`/`$align_of` (one type argument), 2 for `$offset_of` (a type plus a
# field), or 0 when the callee is not one of these. recognizing the intrinsic
# in the bind pass lets its type-naming argument resolve through the primitive
# registry (so `$size_of(i64)` works) and lets `$offset_of`'s bare field name
# escape value-scope lookup
# ---
# rc:     resolver state for the module being resolved
# callee: the call's callee expression
# ret:    1 for a one-type intrinsic, 2 for `$offset_of`, 0 otherwise
fun comptime_intrinsic_kind(rc: *ResolveContext, callee: id.ExprId) u8 {
    val ce_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, callee);
    if (O.is_none[*expr.Expr](ce_opt)) { ret 0; }
    val ce: *expr.Expr = O.unwrap[*expr.Expr](ce_opt);
    if (ce.kind != expr.EXPR_KIND_COMPTIME_IDENT) { ret 0; }

    val ns: token.Span = comptime.comptime_ident_name(ce.span);
    if (ns.len == 0) { ret 0; }
    val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, ns);
    if (R.is_err[intern.StrId, str](r)) { ret 0; }
    val name: intern.StrId = R.unwrap_ok[intern.StrId, str](r);

    if (name == interned_literal(rc, "size_of"))   { ret 1; }
    if (name == interned_literal(rc, "align_of"))  { ret 1; }
    if (name == interned_literal(rc, "offset_of")) { ret 2; }
    ret 0;
}

# binds a comptime value intrinsic call's arguments. the first argument names a
# type, so it resolves as a type spelling (primitive registry first, then the
# value scope for user types) rather than as a value reference; `$offset_of`'s
# second argument is a bare field name resolved against the record at lowering
# time and is left unbound here. returns none when the call is not an intrinsic,
# letting the caller fall back to ordinary call binding
# ---
# rc:  resolver state for the module being resolved
# c:   the call payload
# ret: some(result) when handled as an intrinsic, none to fall through
fun bind_comptime_intrinsic_call(rc: *ResolveContext, c: *expr.ExprCall) O.Option[R.Result[bool, str]] {
    val kind: u8 = comptime_intrinsic_kind(rc, c.callee);
    if (kind == 0)      { ret O.none[R.Result[bool, str]](); }
    if (c.args_len < 1) { ret O.some[R.Result[bool, str]](R.ok[bool, str](true)); }

    val arg0: id.ExprId = rc.a.expr_ids[c.args_start];
    ret O.some[R.Result[bool, str]](bind_intrinsic_type_arg(rc, arg0));
}

# resolves an intrinsic's type-naming argument expression. a bare single
# identifier resolves to a primitive (`i64`, `bool`, `ptr`, ...) before the
# value scope, mirroring `resolve_type_path`; a `module.Type` member chain
# resolves through the module's exports. the resolved SymbolId is recorded in
# `expr_resolved` so sema can recover the operand type
# ---
# rc:  resolver state for the module being resolved
# eid: the type-naming argument expression
# ret: ok(true), or a binding error
fun bind_intrinsic_type_arg(rc: *ResolveContext, eid: id.ExprId) R.Result[bool, str] {
    if (eid == id.EXPR_NIL) { ret R.ok[bool, str](true); }
    val e_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](e_opt)) { ret R.ok[bool, str](true); }
    val e: *expr.Expr = O.unwrap[*expr.Expr](e_opt);

    if (e.kind == expr.EXPR_KIND_IDENT) {
        val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, e.span);
        if (R.is_err[intern.StrId, str](r)) { ret R.err[bool, str](R.unwrap_err[intern.StrId, str](r)); }
        val name: intern.StrId = R.unwrap_ok[intern.StrId, str](r);

        var sid: SymbolId = prim_symbol_for(rc, name);
        if (sid == SYMBOL_NIL) { sid = scope_lookup_chain(rc, rc.current_scope, name); }
        if (sid == SYMBOL_NIL) {
            val re: R.Result[bool, str] = report_named(rc, e.span, "unresolved type name `", name, "`");
            if (R.is_ok[bool, str](re)) { attach_suggestion(rc, name); }
        }
        or {
            if (rc.expr_resolved != nil) { rc.expr_resolved[eid] = sid; }
        }
        ret R.ok[bool, str](true);
    }

    if (e.kind == expr.EXPR_KIND_MEMBER) {
        # a qualified `module.Type` argument: bind the object alias first, then
        # resolve the leaf against the module's exports (reuses the qualified
        # member machinery used for value-position module references).
        val ro: R.Result[bool, str] = bind_expr(rc, e.data.member.object);
        if (R.is_err[bool, str](ro)) { ret ro; }
        ret bind_member_qualified(rc, eid, ?e.data.member);
    }

    # any other argument shape is not a type spelling; bind it as a normal
    # expression so a diagnostic surfaces the misuse.
    ret bind_expr(rc, eid);
}

# binds the two operands of a type comparison (`$type_of(...) == TypeName`,
# #1472). each operand binds through `bind_type_operand`
# ---
# rc:  resolver state for the module being resolved
# bin: the comparison's binary payload
# ret: ok(true), or a binding error
fun bind_type_comparison(rc: *ResolveContext, bin: *expr.ExprBinary) R.Result[bool, str] {
    val rl: R.Result[bool, str] = bind_type_operand(rc, bin.lhs);
    if (R.is_err[bool, str](rl)) { ret rl; }
    ret bind_type_operand(rc, bin.rhs);
}

# binds one type-comparison operand. a `$type_of(e)` operand binds only its inner
# value `e` (the `$`-rooted comptime-ident callee is a builtin, bound nowhere); a
# type-name operand binds as a type spelling so its resolved symbol is recorded
# for sema to recover the named type
# ---
# rc:      resolver state for the module being resolved
# operand: the operand expression
# ret:     ok(true), or a binding error
fun bind_type_operand(rc: *ResolveContext, operand: id.ExprId) R.Result[bool, str] {
    if (comptime.is_type_of_call(rc.a, rc.source, operand)) {
        val arg: id.ExprId = comptime.type_of_arg(rc.a, operand);
        if (arg == id.EXPR_NIL) { ret R.ok[bool, str](true); }
        ret bind_expr(rc, arg);
    }
    # an `f.type` field-descriptor type (#1473): bind only the object (the `$each`
    # loop variable); `.type` is a descriptor projection, not a record field.
    if (is_field_type_operand(rc, operand)) {
        val n_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, operand);
        if (O.is_none[*expr.Expr](n_opt)) { ret R.ok[bool, str](true); }
        ret bind_expr(rc, O.unwrap[*expr.Expr](n_opt).data.member.object);
    }
    ret bind_intrinsic_type_arg(rc, operand);
}

# whether `eid` is an `f.type` operand whose object resolves, in the current
# scope, to a `$each` comptime loop variable (a field descriptor). this keys the
# `f.type` type-comparison recognition on the loop variable, so a real record
# field named `type` (`s.type`) is never treated as a descriptor projection
# ---
# rc:  resolver state for the module being resolved
# eid: the candidate `f.type` expression
# ret: true when `eid` is a `$each` field descriptor's `.type`
fun is_field_type_operand(rc: *ResolveContext, eid: id.ExprId) bool {
    if (!comptime.is_field_type_member(rc.a, rc.source, eid)) { ret false; }
    ret member_object_is_field_loopvar(rc, eid);
}

# whether member expression `eid`'s object resolves, in the current scope, to a
# `$each` field-descriptor loop variable (a SYM_VAL bearing SYM_FLAG_COMPTIME).
# shared by the `.type` type-comparison recognition and the broader
# field-descriptor gate deferral, so a real record field access (`s.type`) is never
# mistaken for a descriptor projection.
# ---
# rc:  resolver state for the module being resolved
# eid: a member expression (its object is the candidate loop variable)
# ret: true when the object names a `$each` loop variable
fun member_object_is_field_loopvar(rc: *ResolveContext, eid: id.ExprId) bool {
    val n_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, eid);
    if (O.is_none[*expr.Expr](n_opt)) { ret false; }
    val obj: id.ExprId = O.unwrap[*expr.Expr](n_opt).data.member.object;
    val o_opt: O.Option[*expr.Expr] = ast.get_expr(rc.a, obj);
    if (O.is_none[*expr.Expr](o_opt)) { ret false; }
    val oe: *expr.Expr = O.unwrap[*expr.Expr](o_opt);
    if (oe.kind != expr.EXPR_KIND_IDENT) { ret false; }
    val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, oe.span);
    if (R.is_err[intern.StrId, str](r)) { ret false; }
    val sid: SymbolId = scope_lookup_chain(rc, rc.current_scope, R.unwrap_ok[intern.StrId, str](r));
    if (sid == SYMBOL_NIL) { ret false; }
    val sym: *Symbol = ?rc.symbols[sid];
    ret sym.kind == SYM_VAL && (sym.flags & SYM_FLAG_COMPTIME) != 0;
}

# whether `eid` is a `<loopvar>.name` / `.type` / `.offset` projection off a `$each`
# field descriptor. a `$if` gate reading one cannot fold during resolve (the loop
# variable is bound only per iteration, at the `$each` unroll), so its chain binds
# every arm and defers arm selection there - mirroring the type-comparison defer.
# ---
# rc:  resolver state for the module being resolved
# eid: the candidate projection expression
# ret: true when `eid` is a field-descriptor projection over a `$each` loop variable
fun is_field_descriptor_operand(rc: *ResolveContext, eid: id.ExprId) bool {
    if (!comptime.is_field_descriptor_member(rc.a, rc.source, eid)) { ret false; }
    ret member_object_is_field_loopvar(rc, eid);
}

# interns a static literal in the session interner, returning its StrId or
# STR_NIL on allocation failure (a STR_NIL never matches a real span name)
# ---
# rc:   resolver state for the module being resolved
# text: the literal text to intern
# ret:  the interned StrId, or STR_NIL on failure
fun interned_literal(rc: *ResolveContext, text: str) intern.StrId {
    val r: R.Result[intern.StrId, str] = intern.intern(?rc.s.interner, text);
    if (R.is_err[intern.StrId, str](r)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](r);
}

# resolve the names inside one syntactic type node
# ---
# rc:  resolver state for the module being resolved
# tid: the type node to bind
# ret: ok(true), or a binding error
fun bind_type(rc: *ResolveContext, tid: id.TypeId) R.Result[bool, str] {
    if (tid == id.TYPE_NIL) { ret R.ok[bool, str](true); }
    val t_opt: O.Option[*atype.Type] = ast.get_type(rc.a, tid);
    if (O.is_none[*atype.Type](t_opt)) { ret R.err[bool, str]("TypeId out of range"); }
    val t: *atype.Type = O.unwrap[*atype.Type](t_opt);

    if (t.kind == atype.TYPE_KIND_NAMED) {
        val sid: SymbolId = resolve_type_path(rc, ?t.data.named, t.span);
        if (rc.type_resolved != nil) { rc.type_resolved[tid] = sid; }
        var ai: u32 = 0;
        for (ai < t.data.named.args_len) {
            val arg_id: id.TypeId = rc.a.type_ids[t.data.named.args_start + ai];
            val r: R.Result[bool, str] = bind_type(rc, arg_id);
            if (R.is_err[bool, str](r)) { ret r; }
            ai = ai + 1;
        }
        ret R.ok[bool, str](true);
    }
    if (t.kind == atype.TYPE_KIND_PTR) {
        ret bind_type(rc, t.data.ptr.pointee);
    }
    if (t.kind == atype.TYPE_KIND_SECRET) {
        ret bind_type(rc, t.data.secret.inner);
    }
    if (t.kind == atype.TYPE_KIND_ARRAY) {
        val re: R.Result[bool, str] = bind_expr(rc, t.data.array.length);
        if (R.is_err[bool, str](re)) { ret re; }
        ret bind_type(rc, t.data.array.element);
    }
    if (t.kind == atype.TYPE_KIND_FUN) {
        var pi: u32 = 0;
        for (pi < t.data.fun_.params_len) {
            val pt: id.TypeId = rc.a.type_ids[t.data.fun_.params_start + pi];
            val r: R.Result[bool, str] = bind_type(rc, pt);
            if (R.is_err[bool, str](r)) { ret r; }
            pi = pi + 1;
        }
        ret bind_type(rc, t.data.fun_.ret_type);
    }
    if (t.kind == atype.TYPE_KIND_REC || t.kind == atype.TYPE_KIND_UNI) {
        var fields_start: u32 = 0;
        var fields_len:   u32 = 0;
        if (t.kind == atype.TYPE_KIND_REC) {
            fields_start = t.data.rec_.fields_start;
            fields_len   = t.data.rec_.fields_len;
        }
        or {
            fields_start = t.data.uni_.fields_start;
            fields_len   = t.data.uni_.fields_len;
        }
        var fi: u32 = 0;
        for (fi < fields_len) {
            val tn: *decl.TypedName = ?rc.a.typed_names[fields_start + fi];
            val r: R.Result[bool, str] = bind_type(rc, tn.ty);
            if (R.is_err[bool, str](r)) { ret r; }
            fi = fi + 1;
        }
        ret R.ok[bool, str](true);
    }
    ret R.ok[bool, str](true);
}

# walks a TYPE_KIND_NAMED path. single-segment names look up in the local
# scope chain. multi-segment names start with an in-scope SYM_USE alias and
# index into that alias's target module's pub symbols
# ---
# rc:    resolver state for the module being resolved
# named: the named-type payload
# full:  the full path span, for diagnostics
# ret:   the resolved SymbolId, or SYMBOL_NIL
fun resolve_type_path(rc: *ResolveContext, named: *atype.TypeNamed, full: token.Span) SymbolId {
    val path: token.Span = named.name;
    if (path.len == 0) { ret SYMBOL_NIL; }

    var seg_start: usize = path.offset;
    val end:       usize = path.offset + path.len;
    var seg_end:   usize = seg_start;

    var current_module: session.ModuleId = session.MODULE_NIL;
    var current_sym:    SymbolId      = SYMBOL_NIL;
    var first:          bool          = true;

    for (seg_start < end) {
        seg_end = seg_start;
        for (seg_end < end && rc.source[seg_end] != '.') {
            seg_end = seg_end + 1;
        }
        var seg_span: token.Span;
        seg_span.offset = seg_start;
        seg_span.len    = seg_end - seg_start;

        val r: R.Result[intern.StrId, str] = intern.intern_span(?rc.s.interner, rc.source, seg_span);
        if (R.is_err[intern.StrId, str](r)) { ret SYMBOL_NIL; }
        val seg_name: intern.StrId = R.unwrap_ok[intern.StrId, str](r);

        if (first) {
            # a single-segment name that spells a primitive type resolves to
            # the primitive, taking priority over any value-scope symbol of the
            # same name (mirrors cmach's string-based primitive resolution).
            val is_single: bool = seg_end >= end;
            if (is_single) { current_sym = prim_symbol_for(rc, seg_name); }
            if (current_sym == SYMBOL_NIL) {
                current_sym = scope_lookup_chain(rc, rc.current_scope, seg_name);
            }
            first = false;
        }
        or {
            current_sym = lookup_in_module(rc, current_module, seg_name);
        }

        if (current_sym == SYMBOL_NIL) {
            # a single-segment path names the type directly, so embed the name and
            # offer a suggestion; a qualified `mod.Type` miss reports on the whole
            # path without a (cross-module) suggestion.
            if (seg_start == path.offset && seg_end >= end) {
                val re: R.Result[bool, str] = report_named(rc, full, "unresolved type name `", seg_name, "`");
                if (R.is_ok[bool, str](re)) { attach_suggestion(rc, seg_name); }
            }
            or {
                report_named(rc, full, "unresolved type name `", seg_name, "`");
            }
            ret SYMBOL_NIL;
        }

        if (seg_end >= end) { brk; }

        val sym: *Symbol = ?rc.symbols[current_sym];
        if (sym.kind == SYM_USE) {
            current_module = sym.slot::session.ModuleId;
        }
        or {
            diagnostic.error(?rc.s.diags, rc.a.file_id, full, "expected a module alias before `.`");
            ret SYMBOL_NIL;
        }

        seg_start = seg_end + 1;
    }

    ret current_sym;
}

# looks up `name` among the pub symbols exported by ModuleId `m`. returns
# a SYM_IMPORTED symbol, reusing an existing one when an earlier use-site
# already imported the same (origin, decl) pair via `imported_cache`
# ---
# rc:   resolver state for the module being resolved
# m:    the module to search
# name: interned symbol name
# ret:  the imported SymbolId, or SYMBOL_NIL
fun lookup_in_module(rc: *ResolveContext, m: session.ModuleId, name: intern.StrId) SymbolId {
    val mx: *ModuleExports = find_module_exports_by_module(rc, m);
    if (mx == nil) { ret SYMBOL_NIL; }
    val ps: *PublicSymbol = find_export(mx, name);
    if (ps == nil) { ret SYMBOL_NIL; }
    val sid_r: R.Result[SymbolId, str] = imported_symbol_for(rc, ps);
    if (R.is_err[SymbolId, str](sid_r)) { ret SYMBOL_NIL; }
    ret R.unwrap_ok[SymbolId, str](sid_r);
}

# rewrites every non-nil SymbolId in a resolved-reference array through the
# `remap` permutation produced by build_result's pub-front partition, so the
# references index the reordered symbol array. SYMBOL_NIL and out-of-range
# ids are left untouched
# ---
# refs:    the reference array to rewrite
# len:     number of references
# remap:   old to new index permutation
# sym_len: number of symbols
fun remap_symbol_refs(refs: *SymbolId, len: u32, remap: *u32, sym_len: u32) {
    if (refs == nil) { ret; }
    var i: u32 = 0;
    for (i < len) {
        val sid: SymbolId = refs[i];
        if (sid != SYMBOL_NIL && sid::u32 < sym_len) {
            refs[i] = remap[sid::u32]::SymbolId;
        }
        i = i + 1;
    }
}

# partition pub symbols to the front and assemble the owned ResolveResult
#
# consumes `rc`: its side tables are moved into the result or torn down.
# ---
# rc:  the context to finalize
# ret: the populated ResolveResult, or an allocation error
fun build_result(rc: *ResolveContext) R.Result[ResolveResult, str] {
    var pub_count: u32 = 0;
    var i: u32 = 0;
    for (i < rc.sym_len) {
        if ((rc.symbols[i].flags & SYM_FLAG_PUB) != 0) {
            pub_count = pub_count + 1;
        }
        i = i + 1;
    }

    val r_syms: R.Result[*Symbol, str] = A.allocate[Symbol](rc.s.alloc, rc.sym_len::usize);
    if (R.is_err[*Symbol, str](r_syms)) {
        dnit_context(rc);
        ret R.err[ResolveResult, str](R.unwrap_err[*Symbol, str](r_syms));
    }
    val out_syms: *Symbol = R.unwrap_ok[*Symbol, str](r_syms);

    # partition pub symbols to the front; `remap[old] = new` records the
    # index permutation so the resolved-reference arrays (which hold
    # pre-partition SymbolIds) can be rewritten to the new positions.
    var remap: *u32 = nil;
    if (rc.sym_len > 0) {
        val r_remap: R.Result[*u32, str] = A.allocate[u32](rc.s.alloc, rc.sym_len::usize);
        if (R.is_err[*u32, str](r_remap)) {
            A.deallocate[Symbol](rc.s.alloc, out_syms, rc.sym_len::usize);
            dnit_context(rc);
            ret R.err[ResolveResult, str](R.unwrap_err[*u32, str](r_remap));
        }
        remap = R.unwrap_ok[*u32, str](r_remap);
    }

    var pi: u32 = 0;
    var ni: u32 = pub_count;
    var k:  u32 = 0;
    for (k < rc.sym_len) {
        if ((rc.symbols[k].flags & SYM_FLAG_PUB) != 0) {
            out_syms[pi] = rc.symbols[k];
            remap[k]     = pi;
            pi = pi + 1;
        }
        or {
            out_syms[ni] = rc.symbols[k];
            remap[k]     = ni;
            ni = ni + 1;
        }
        k = k + 1;
    }

    remap_symbol_refs(rc.expr_resolved, rc.a.expr_len::u32, remap, rc.sym_len);
    remap_symbol_refs(rc.type_resolved, rc.a.type_len::u32, remap, rc.sym_len);
    remap_symbol_refs(rc.decl_symbol,   rc.a.decl_len::u32, remap, rc.sym_len);

    if (remap != nil) { A.deallocate[u32](rc.s.alloc, remap, rc.sym_len::usize); }

    # snapshot each symbol's ModuleId-valued fields in build-stable space, so a
    # ResolveResult reused in a later build can be remapped into that build's
    # ModuleId numbering (#1582). origin is captured for every symbol; the SYM_USE
    # target in `slot` is captured too (other kinds' slot is a build-independent
    # index and needs no snapshot).
    var si: u32 = 0;
    for (si < rc.sym_len) {
        val sym: *Symbol = ?out_syms[si];
        sym.origin_stable = stable_of_module(rc.s, sym.origin);
        if (sym.kind == SYM_USE) {
            sym.slot_stable = stable_of_module(rc.s, sym.slot::session.ModuleId);
        }
        or {
            sym.slot_stable = session.STABLE_MODULE_NIL;
        }
        si = si + 1;
    }

    # index every parameter by (owning decl, ordinal) over the final symbol
    # array, so lowering resolves a parameter symbol in O(1) rather than scanning
    # the whole universe per parameter.
    var param_index: map.Map[u64, SymbolId] = map.init[u64, SymbolId](rc.s.alloc, map.hash_u64, map.eq_u64);
    var pk: u32 = 0;
    for (pk < rc.sym_len) {
        if (out_syms[pk].kind == SYM_PARAM) {
            val key: u64 = (out_syms[pk].decl::u64 << 32) | out_syms[pk].slot::u64;
            val ins: R.Result[bool, str] = map.insert[u64, SymbolId](?param_index, key, pk);
            if (R.is_err[bool, str](ins)) {
                map.dnit[u64, SymbolId](?param_index);
                A.deallocate[Symbol](rc.s.alloc, out_syms, rc.sym_len::usize);
                dnit_context(rc);
                ret R.err[ResolveResult, str](R.unwrap_err[bool, str](ins));
            }
        }
        pk = pk + 1;
    }

    # fingerprint the evaluated values of this module's pub module-level comptime
    # constants, so the export firewall re-resolves importers when a const value an
    # importer's `$if` reads changes (the value lives in the ctx, not the symbols).
    var fp_len: u32 = 0;
    val fp_r: R.Result[*u8, str] = pub_const_fp_build(rc, out_syms, pub_count, ?fp_len);
    if (R.is_err[*u8, str](fp_r)) {
        map.dnit[u64, SymbolId](?param_index);
        A.deallocate[Symbol](rc.s.alloc, out_syms, rc.sym_len::usize);
        dnit_context(rc);
        ret R.err[ResolveResult, str](R.unwrap_err[*u8, str](fp_r));
    }

    var out: ResolveResult;
    out.alloc         = rc.s.alloc;
    out.symbols       = out_syms;
    out.symbol_count  = rc.sym_len;
    out.pub_count     = pub_count;
    out.expr_resolved = rc.expr_resolved;
    out.type_resolved = rc.type_resolved;
    out.decl_symbol   = rc.decl_symbol;
    out.expr_count    = rc.a.expr_len::u32;
    out.type_count    = rc.a.type_len::u32;
    out.decl_count    = rc.a.decl_len::u32;
    out.param_index   = param_index;
    out.pub_const_fp     = R.unwrap_ok[*u8, str](fp_r);
    out.pub_const_fp_len = fp_len;

    rc.expr_resolved = nil;
    rc.type_resolved = nil;
    rc.decl_symbol   = nil;

    dnit_context(rc);
    ret R.ok[ResolveResult, str](out);
}

# bytes one pub comptime constant contributes to the value
# fingerprint - name(u32) + CTValue kind(u8) + int_unsigned(u8) + payload bits(u64)
val PUB_CONST_FP_ENTRY: u32 = 14;

# the 8 payload bytes of a CTValue as a canonical u64, set per kind
# so the fingerprint is deterministic (a bool writes 0/1, never the union's stale
# upper bytes; a float's bit pattern travels verbatim through the i64 view)
# ---
# v:   the comptime value
# ret: its 8 payload bytes as a canonical u64
fun ct_value_bits(v: *comptime.CTValue) u64 {
    if (v.kind == comptime.CT_KIND_BOOL) {
        if (v.data.b) { ret 1; }
        ret 0;
    }
    if (v.kind == comptime.CT_KIND_STR)  { ret v.data.s::u64; }
    if (v.kind == comptime.CT_KIND_TYPE) { ret v.data.t::u64; }
    ret v.data.i::u64;
}

# serialize the evaluated CTValue of every pub module-level
# comptime constant in `syms[0, pub_count)` into a fresh byte blob, in pub-symbol
# order. the values are read from the comptime ctx (bound during load); a constant
# not foldable there records a sentinel kind. *out_len gets the blob length; a
# module with no pub comptime constants yields nil/0
# ---
# rc:        resolver state for the module being resolved
# syms:      the final symbol array
# pub_count: number of pub symbols at the front
# out_len:   set to the blob length in bytes
# ret:       the fingerprint blob (nil when none), or an allocation error
fun pub_const_fp_build(rc: *ResolveContext, syms: *Symbol, pub_count: u32, out_len: *u32) R.Result[*u8, str] {
    @out_len = 0;
    var n: u32 = 0;
    var i: u32 = 0;
    for (i < pub_count) {
        if (syms[i].kind == SYM_VAL && (syms[i].flags & SYM_FLAG_MODULE) != 0) { n = n + 1; }
        i = i + 1;
    }
    if (n == 0) { ret R.ok[*u8, str](nil); }

    val total: u32 = n * PUB_CONST_FP_ENTRY;
    val r: R.Result[*u8, str] = A.allocate[u8](rc.s.alloc, total::usize);
    if (R.is_err[*u8, str](r)) { ret r; }
    val buf: *u8 = R.unwrap_ok[*u8, str](r);

    var off: u32 = 0;
    i = 0;
    for (i < pub_count) {
        val sym: *Symbol = ?syms[i];
        if (sym.kind == SYM_VAL && (sym.flags & SYM_FLAG_MODULE) != 0) {
            fp_put_u32(buf, off, sym.name::u32); off = off + 4;
            val nc: O.Option[*comptime.NamedConst] = comptime.lookup(rc.ctx, sym.name);
            if (O.is_some[*comptime.NamedConst](nc)) {
                val v: *comptime.CTValue = ?O.unwrap[*comptime.NamedConst](nc).value;
                buf[off] = v.kind::u8; off = off + 1;
                if (v.int_unsigned) { buf[off] = 1; } or { buf[off] = 0; }
                off = off + 1;
                fp_put_u64(buf, off, ct_value_bits(v)); off = off + 8;
            }
            or {
                buf[off] = 0xFF; off = off + 1;   # sentinel: not a foldable constant
                buf[off] = 0;    off = off + 1;
                fp_put_u64(buf, off, 0); off = off + 8;
            }
        }
        i = i + 1;
    }

    @out_len = total;
    ret R.ok[*u8, str](buf);
}

# write a little-endian u32 into `buf` at byte offset `off`
# ---
# buf: destination buffer
# off: byte offset
# v:   value to write
fun fp_put_u32(buf: *u8, off: u32, v: u32) {
    buf[off]     = (v & 0xFF)::u8;
    buf[off + 1] = ((v >> 8) & 0xFF)::u8;
    buf[off + 2] = ((v >> 16) & 0xFF)::u8;
    buf[off + 3] = ((v >> 24) & 0xFF)::u8;
}

# write a little-endian u64 into `buf` at byte offset `off`
# ---
# buf: destination buffer
# off: byte offset
# v:   value to write
fun fp_put_u64(buf: *u8, off: u32, v: u64) {
    var j: u32 = 0;
    for (j < 8) {
        buf[off + j] = ((v >> (j * 8)) & 0xFF)::u8;
        j = j + 1;
    }
}
