# public entry to the parser
#
# Constructs a Parser over the lexer's token stream and delegates to the
# grammar files under parser/. The parser is malformed-input tolerant:
# syntax errors are emitted into the supplied diagnostic sink while parsing
# continues, so the caller never sees a fallible return for bad input. An
# allocation failure is the one fatal condition, reported through the boolean
# return.

use std.types.bool.bool;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.doclint;
use mach.lang.fe.lexer;
use mach.lang.fe.parser.decl;
use mach.lang.fe.parser.state;

# parse the token stream into the AST, populating diagnostics as it goes
#
# Syntax errors are recovered from and pushed to `diags` while parsing
# continues. The one unrecoverable condition is an allocation failure,
# signalled by the return so the caller can refuse the now-incomplete AST.
# On a clean parse the docstring lint runs over the AST, so its warnings reach
# every parse caller, the build/check driver and the editor, from this one
# entry point.
# ---
# tokens: lexer output to consume
# out:    AST to append parsed nodes into; its root_module is set on completion
# diags:  diagnostic sink; parse errors are pushed here rather than returned
# ret:    true if a fatal allocation failure occurred during the parse
pub fun parse(tokens: *lexer.TokenStream, out: *ast.Ast, diags: *diagnostic.DiagList) bool {
    var p: state.Parser = state.make(tokens, out, diags);
    decl.parse_module(?p);
    if (!p.fatal) {
        doclint.lint_module(out, tokens.source, diags);
    }
    ret p.fatal;
}
