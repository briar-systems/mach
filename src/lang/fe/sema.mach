# infer and check the types of one module's AST
#
# consumes a ResolveResult plus the parsed Ast and produces a SemaResult -
# parallel arrays mapping every AST node id to its semantic type.TypeId. all
# interned types live in the shared TypeInterner on the session; SemaResult owns
# only the per-Ast id-to-type mappings.
#
# each module is analysed in passes: the three parallel arrays are allocated
# (TYPE_NIL prefill), every syntactic AstType is resolved into the interner
# (resolve_type_ref), the declared type of every decl is computed (infer_decl)
# with signatures before bodies so recursive declarations resolve, and finally
# every decl body and initializer is walked (infer_expr) and validated at
# composing sites via the check/* family.
#
# errors push a SEVERITY_ERROR diagnostic and mark the failing position with
# TYPE_ERROR; sema never halts on the first error.
#
# field tables (the structural view of nominal record/union types) live on the
# per-module SemaContext rather than the shared interner: different modules may
# resolve the same nominal (origin, decl) pair, but each computes its own field
# table during its own pass. the field-table API is pub so the infer / check /
# generics sub-modules can populate and query it.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_region_equals;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.module;
use mach.lang.fe.ast.stmt;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema.check;
use mach.lang.fe.sema.coerce;
use mach.lang.fe.sema.context;
use mach.lang.fe.sema.infer;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.session;
use mach.lang.source;
use mach.lang.type;

# re-export sema's shared state and accessor API (which lives in the context
# leaf to break the orchestrator<->pass import cycle) so external consumers keep
# spelling them as `sema.SemaResult` / `sema.SemaContext` / etc.
fwd context.SemaResult;
fwd context.ModuleSema;
fwd context.SemaDeps;
fwd context.FieldEntry;
fwd context.FieldTable;
fwd context.SemaContext;
fwd context.resolved_type_of;
fwd context.module_sema_for;
fwd context.decl_type_for;
fwd context.symbol_for_expr;
fwd context.symbol_for_type;
fwd context.symbol_by_id;
fwd context.report;
fwd context.field_table_begin;
fwd context.field_table_push;
fwd context.field_table_for;
fwd context.field_lookup;

# run semantic analysis on one module
#
# Allocates the three parallel TypeId arrays, resolves every syntactic type,
# computes every decl's declared type, then walks every decl body inferring and
# checking expressions. Diagnostics are pushed into the session; sema does not
# halt on the first error.
# ---
# s:          shared session (allocator, sources, diagnostics, interners)
# a:          parsed Ast for the module being analysed
# rr:         name-resolution output for the same module
# deps:       typing snapshots of every dependency, populated by the driver
# ctx:        comptime context, required to evaluate array-length expressions
# own_module: project-wide ModuleId of the module being analysed
# ret:        the populated SemaResult, or an allocation error
pub fun sema(
    s:          *session.Session,
    a:          *ast.Ast,
    rr:         *resolve.ResolveResult,
    deps:       *context.SemaDeps,
    ctx:        *comptime.ComptimeCtx,
    own_module: session.ModuleId
) R.Result[context.SemaResult, str] {
    var sc: context.SemaContext;

    val res_init: R.Result[bool, str] = init_context(?sc, s, a, rr, deps, ctx, own_module);
    if (R.is_err[bool, str](res_init)) {
        ret R.err[context.SemaResult, str](R.unwrap_err[bool, str](res_init));
    }

    val res_types: R.Result[bool, str] = resolve_all_types(?sc);
    if (R.is_err[bool, str](res_types)) {
        dnit_context(?sc);
        ret R.err[context.SemaResult, str](R.unwrap_err[bool, str](res_types));
    }

    val res_decls: R.Result[bool, str] = infer_all_decls(?sc);
    if (R.is_err[bool, str](res_decls)) {
        dnit_context(?sc);
        ret R.err[context.SemaResult, str](R.unwrap_err[bool, str](res_decls));
    }

    val res_bodies: R.Result[bool, str] = infer_all_bodies(?sc);
    if (R.is_err[bool, str](res_bodies)) {
        dnit_context(?sc);
        ret R.err[context.SemaResult, str](R.unwrap_err[bool, str](res_bodies));
    }

    ret build_result(?sc);
}

# re-type a `$each a in va` pack-unroll body for one concrete element (#1475)
#
# A pack element's type is fixed only at the call site, so the body cannot be
# typed at the original sema pass. At monomorphization the monomorphizer binds
# the loop variable in the comptime context to the element's CT_KIND_PACK_ELEM
# descriptor (so `infer_ident` types `a` to the element type) and calls this to
# write the body expressions' types into the origin module's shared `expr_type`
# array - exactly the array lowering then reads. Distinct elements and instances
# are typed in turn (the array is overwritten per element; lowering interleaves
# typing and emission), so one shared array suffices. The transient context
# reuses the origin SemaResult's arrays in place rather than allocating, so it
# must not be torn down.
# ---
# s:           the origin module's session
# a:           the origin module's Ast (declares the pack-tailed template)
# rr:          the origin module's name-resolution output
# deps:        typing snapshots spanning every module (see collect_module_deps)
# ctx:         comptime context, with the loop variable already bound
# own_module:  ModuleId of the origin module
# sema_result: the origin module's SemaResult, whose arrays this reuses in place
# fn_ret:      the instance's semantic return type (checks any body `ret`)
# body_start:  index of the first `$each` body statement
# body_len:    number of `$each` body statements
# ret:         true once the body is typed, or the first inference error
pub fun reinfer_pack_each_body(
    s:           *session.Session,
    a:           *ast.Ast,
    rr:          *resolve.ResolveResult,
    deps:        *context.SemaDeps,
    ctx:         *comptime.ComptimeCtx,
    own_module:  session.ModuleId,
    sema_result: *context.SemaResult,
    fn_ret:      type.TypeId,
    body_start:  u32,
    body_len:    u32
) R.Result[bool, str] {
    var sc: context.SemaContext;
    sc.s          = s;
    sc.a          = a;
    sc.rr         = rr;
    sc.deps       = deps;
    sc.ctx        = ctx;
    sc.own_module = own_module;
    sc.source     = source_text_of(s, a);

    sc.expr_type        = sema_result.expr_type;
    sc.type_resolved_ty = sema_result.type_resolved_ty;
    sc.decl_type        = sema_result.decl_type;

    sc.callee_eid       = id.EXPR_NIL;
    sc.in_comptime_gate = false;

    ret infer_stmt_list(?sc, body_start, body_len, fn_ret);
}

# assemble a typing-snapshot set spanning every registered module (#1475)
#
# The original per-module sema pass receives only its actual dependencies, but
# the pack-body re-inference at monomorphization may reach any module the body
# references, so it consults the full set. Each entry borrows a module's
# SemaResult.decl_type array (owned by the session), so the returned SemaDeps
# must be released with `free_module_deps` (which frees only the entries array)
# before the SemaResults are torn down. A module with no registered SemaResult
# yields a decl-type-less entry, against which a lookup returns TYPE_ERROR like a
# miss.
# ---
# s:   the session (its module registries)
# ret: a SemaDeps spanning every module, or an allocation error
pub fun collect_module_deps(s: *session.Session) R.Result[context.SemaDeps, str] {
    var deps: context.SemaDeps;
    deps.entries = nil;
    deps.count   = 0;

    val n: u32 = session.module_count(s);
    if (n == 0) { ret R.ok[context.SemaDeps, str](deps); }

    val res_arr: R.Result[*context.ModuleSema, str] = A.allocate[context.ModuleSema](s.alloc, n::usize);
    if (R.is_err[*context.ModuleSema, str](res_arr)) {
        ret R.err[context.SemaDeps, str](R.unwrap_err[*context.ModuleSema, str](res_arr));
    }
    val arr: *context.ModuleSema = R.unwrap_ok[*context.ModuleSema, str](res_arr);

    var i: u32 = 0;
    for (i < n) {
        var ms: context.ModuleSema;
        ms.path       = session.module_fqn(s, i::session.ModuleId);
        ms.module     = i::session.ModuleId;
        ms.decl_type  = nil;
        ms.decl_count = 0;

        val sp: ptr = session.module_sema_ptr(s, i::session.ModuleId);
        if (sp != nil) {
            val sr: *context.SemaResult = sp::*context.SemaResult;
            ms.decl_type  = sr.decl_type;
            ms.decl_count = sr.decl_count;
        }

        arr[i] = ms;
        i = i + 1;
    }

    deps.entries = arr;
    deps.count   = n;
    ret R.ok[context.SemaDeps, str](deps);
}

# release the entries array a `collect_module_deps` allocated
#
# The borrowed decl_type arrays it points into are owned by the session and are
# not freed here.
# ---
# s:    the session (allocator)
# deps: the SemaDeps to release; its entries are freed and its fields zeroed
pub fun free_module_deps(s: *session.Session, deps: *context.SemaDeps) {
    if (deps.entries != nil && deps.count > 0) {
        A.deallocate[context.ModuleSema](s.alloc, deps.entries, deps.count::usize);
    }
    deps.entries = nil;
    deps.count   = 0;
}

# release the parallel arrays held by a SemaResult and zero its fields
# ---
# r: the result to tear down; nil is a no-op
pub fun dnit_result(r: *context.SemaResult) {
    if (r == nil) { ret; }
    if (r.expr_type != nil && r.expr_count > 0) {
        A.deallocate[type.TypeId](r.alloc, r.expr_type, r.expr_count::usize);
    }
    if (r.type_resolved_ty != nil && r.type_count > 0) {
        A.deallocate[type.TypeId](r.alloc, r.type_resolved_ty, r.type_count::usize);
    }
    if (r.decl_type != nil && r.decl_count > 0) {
        A.deallocate[type.TypeId](r.alloc, r.decl_type, r.decl_count::usize);
    }
    r.expr_type        = nil;
    r.type_resolved_ty = nil;
    r.decl_type        = nil;
    r.expr_count       = 0;
    r.type_count       = 0;
    r.decl_count       = 0;
}

# initialize `sc` for a fresh sema run over one module
#
# Wires the phase inputs onto the context, allocates the three parallel TypeId
# arrays (each prefilled with TYPE_NIL), and seeds the builtin type bindings. On
# any failure the partially built context is torn down before returning.
# ---
# sc:         the context to initialize in place
# s:          shared session
# a:          parsed Ast for the module
# rr:         name-resolution output
# deps:       typing snapshots of dependencies
# ctx:        comptime context
# own_module: ModuleId of the module being analysed
# ret:        true once initialized, or an allocation error
fun init_context(
    sc:         *context.SemaContext,
    s:          *session.Session,
    a:          *ast.Ast,
    rr:         *resolve.ResolveResult,
    deps:       *context.SemaDeps,
    ctx:        *comptime.ComptimeCtx,
    own_module: session.ModuleId
) R.Result[bool, str] {
    sc.s          = s;
    sc.a          = a;
    sc.rr         = rr;
    sc.deps       = deps;
    sc.ctx        = ctx;
    sc.own_module = own_module;
    sc.source     = source_text_of(s, a);

    sc.expr_type        = nil;
    sc.type_resolved_ty = nil;
    sc.decl_type        = nil;

    sc.callee_eid       = id.EXPR_NIL;
    sc.in_comptime_gate = false;

    if (a.expr_len > 0) {
        val res_expr: R.Result[*type.TypeId, str] = typeid_array_alloc(s.alloc, a.expr_len);
        if (R.is_err[*type.TypeId, str](res_expr)) {
            dnit_context(sc);
            ret R.err[bool, str](R.unwrap_err[*type.TypeId, str](res_expr));
        }
        sc.expr_type = R.unwrap_ok[*type.TypeId, str](res_expr);
    }
    if (a.type_len > 0) {
        val res_type: R.Result[*type.TypeId, str] = typeid_array_alloc(s.alloc, a.type_len);
        if (R.is_err[*type.TypeId, str](res_type)) {
            dnit_context(sc);
            ret R.err[bool, str](R.unwrap_err[*type.TypeId, str](res_type));
        }
        sc.type_resolved_ty = R.unwrap_ok[*type.TypeId, str](res_type);
    }
    if (a.decl_len > 0) {
        val res_decl: R.Result[*type.TypeId, str] = typeid_array_alloc(s.alloc, a.decl_len);
        if (R.is_err[*type.TypeId, str](res_decl)) {
            dnit_context(sc);
            ret R.err[bool, str](R.unwrap_err[*type.TypeId, str](res_decl));
        }
        sc.decl_type = R.unwrap_ok[*type.TypeId, str](res_decl);
    }

    val res_seed: R.Result[bool, str] = infer.seed_builtins(sc);
    if (R.is_err[bool, str](res_seed)) {
        dnit_context(sc);
        ret R.err[bool, str](R.unwrap_err[bool, str](res_seed));
    }

    ret R.ok[bool, str](true);
}

# allocate a TypeId array of `len` slots, each prefilled with TYPE_NIL
# ---
# a:   allocator
# len: number of TypeId slots
# ret: the allocated array, or an allocation error
fun typeid_array_alloc(a: *A.Allocator, len: usize) R.Result[*type.TypeId, str] {
    val res_arr: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](a, len);
    if (R.is_err[*type.TypeId, str](res_arr)) { ret res_arr; }
    val arr: *type.TypeId = R.unwrap_ok[*type.TypeId, str](res_arr);

    var i: u32 = 0;
    for (i < len::u32) {
        arr[i] = type.TYPE_NIL;
        i = i + 1;
    }
    ret R.ok[*type.TypeId, str](arr);
}

# the module's source text, used to read identifier spans during inference
#
# The Ast.file_id is registered with the session by the driver before sema runs;
# an absent file yields a nil string and spans become empty lookups.
# ---
# s:   the session (its source registry)
# a:   the module's Ast
# ret: the source text, or nil when the file is not registered
fun source_text_of(s: *session.Session, a: *ast.Ast) str {
    val opt_file: O.Option[*source.SourceFile] = source.get(?s.sources, a.file_id);
    if (O.is_none[*source.SourceFile](opt_file)) { ret nil::str; }
    ret O.unwrap[*source.SourceFile](opt_file).text;
}

# free the three parallel arrays held by `sc` and nil the handles
#
# Sized from the Ast lengths the arrays were allocated against. Safe to call on a
# partially built context: a nil handle is skipped.
# ---
# sc: the context to tear down
fun dnit_context(sc: *context.SemaContext) {
    if (sc.expr_type != nil && sc.a.expr_len > 0) {
        A.deallocate[type.TypeId](sc.s.alloc, sc.expr_type, sc.a.expr_len);
    }
    if (sc.type_resolved_ty != nil && sc.a.type_len > 0) {
        A.deallocate[type.TypeId](sc.s.alloc, sc.type_resolved_ty, sc.a.type_len);
    }
    if (sc.decl_type != nil && sc.a.decl_len > 0) {
        A.deallocate[type.TypeId](sc.s.alloc, sc.decl_type, sc.a.decl_len);
    }
    sc.expr_type        = nil;
    sc.type_resolved_ty = nil;
    sc.decl_type        = nil;
}

# resolve every syntactic AstType into its interned semantic TypeId
#
# Writes type_resolved_ty in source order. A type that fails to resolve becomes
# TYPE_ERROR (set by resolve_type_ref), so this pass never errors itself.
# ---
# sc:  the context
# ret: always ok
fun resolve_all_types(sc: *context.SemaContext) R.Result[bool, str] {
    if (sc.type_resolved_ty == nil) { ret R.ok[bool, str](true); }
    var i: u32 = 0;
    for (i < sc.a.type_len::u32) {
        sc.type_resolved_ty[i] = infer.resolve_type_ref(sc, i);
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# compute the declared type of every top-level decl
# ---
# sc:  the context
# ret: true once every decl's type is recorded, or the first error
fun infer_all_decls(sc: *context.SemaContext) R.Result[bool, str] {
    if (sc.decl_type == nil) { ret R.ok[bool, str](true); }
    val opt_module: O.Option[*module.Module] = ast.get_module(sc.a, sc.a.root_module);
    if (O.is_none[*module.Module](opt_module)) {
        ret R.err[bool, str]("root_module is not set on this Ast");
    }
    val mnode: *module.Module = O.unwrap[*module.Module](opt_module);
    ret infer_decls_in_list(sc, mnode.decls_start, mnode.decls_len);
}

# walk a decl list in source order, computing each binding decl's declared type
#
# Comptime-if arms are flattened: the active arm's decls are walked, inactive
# arms are skipped.
# ---
# sc:    the context
# start: index of the first DeclId in the list
# len:   number of decls in the list
# ret:   true once the list is walked, or the first error
fun infer_decls_in_list(sc: *context.SemaContext, start: u32, len: u32) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val did: id.DeclId = sc.a.decl_ids[start + i];
        val res_decl: R.Result[bool, str] = infer_one_decl(sc, did);
        if (R.is_err[bool, str](res_decl)) { ret res_decl; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# compute and record one decl's declared type, recursing into a comptime-if
# ---
# sc:  the context
# did: the decl to type
# ret: true once recorded, or the first error
fun infer_one_decl(sc: *context.SemaContext, did: id.DeclId) R.Result[bool, str] {
    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(sc.a, did);
    if (O.is_none[*decl.Decl](opt_decl)) { ret R.err[bool, str]("DeclId out of range"); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_decl);

    if (d.kind == decl.DECL_KIND_COMPTIME_IF) {
        ret infer_decls_comptime_if(sc, ?d.data.comptime_if);
    }

    val ty: type.TypeId = infer.infer_decl(sc, did);
    sc.decl_type[did] = ty;
    ret R.ok[bool, str](true);
}

# evaluate a decl-scope comptime-if and recurse into the first active arm
#
# The selected arm's decl list is walked so its declared types are computed in
# the enclosing pass.
# ---
# sc:  the context
# ci:  the comptime-if decl payload
# ret: true once the active arm is walked, or the first error
fun infer_decls_comptime_if(sc: *context.SemaContext, ci: *decl.DeclComptimeIf) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < ci.branches_len) {
        val br: *decl.ComptimeBranch = ?sc.a.comptime_branches[ci.branches_start + i];
        val res_active: R.Result[bool, str] = comptime_branch_active(sc, br);
        if (R.is_err[bool, str](res_active)) { ret res_active; }
        if (R.unwrap_ok[bool, str](res_active)) {
            ret infer_decls_in_list(sc, br.body_start, br.body_len);
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# infer and check every top-level decl body and initializer
# ---
# sc:  the context
# ret: true once every body is walked, or the first error
fun infer_all_bodies(sc: *context.SemaContext) R.Result[bool, str] {
    if (sc.decl_type == nil) { ret R.ok[bool, str](true); }
    val opt_module: O.Option[*module.Module] = ast.get_module(sc.a, sc.a.root_module);
    if (O.is_none[*module.Module](opt_module)) {
        ret R.err[bool, str]("root_module is not set on this Ast");
    }
    val mnode: *module.Module = O.unwrap[*module.Module](opt_module);
    ret infer_bodies_in_list(sc, mnode.decls_start, mnode.decls_len);
}

# walk a decl list in source order, inferring and checking each decl's body
# ---
# sc:    the context
# start: index of the first DeclId in the list
# len:   number of decls in the list
# ret:   true once the list is walked, or the first error
fun infer_bodies_in_list(sc: *context.SemaContext, start: u32, len: u32) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val did: id.DeclId = sc.a.decl_ids[start + i];
        val res_body: R.Result[bool, str] = infer_one_body(sc, did);
        if (R.is_err[bool, str](res_body)) { ret res_body; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# infer and check one decl's body or initializer
#
# Decorator arguments are typed and the decorators validated first, then the
# decl's body (function / test), initializer (val / var), comptime-if, or bare
# comptime directive is handled by kind.
# ---
# sc:  the context
# did: the decl whose body to walk
# ret: true once walked, or the first error
fun infer_one_body(sc: *context.SemaContext, did: id.DeclId) R.Result[bool, str] {
    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(sc.a, did);
    if (O.is_none[*decl.Decl](opt_decl)) { ret R.err[bool, str]("DeclId out of range"); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_decl);

    # a decl's backtick decorator arguments are comptime expressions; infer them
    # so their types resolve (e.g. `#[align($size_of(T))]`) before the middle end
    # folds them.
    infer_decorator_args(sc, d);
    validate_decorators(sc, d);

    if (d.kind == decl.DECL_KIND_COMPTIME_IF) {
        ret infer_bodies_comptime_if(sc, ?d.data.comptime_if);
    }
    if (d.kind == decl.DECL_KIND_FUN) {
        if (d.data.fun_.body != id.STMT_NIL) {
            val ret_ty: type.TypeId = context.resolved_type_of(sc, d.data.fun_.return_type);
            ret infer_stmt(sc, d.data.fun_.body, ret_ty);
        }
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_TEST) {
        if (d.data.test_.body != id.STMT_NIL) {
            # a test body returns an integer process status (`ret 0` / `ret 1`);
            # type it as i32 so those literals coerce and are checked, matching the
            # i32-returning function the middle end lowers each test into.
            val ret_ty: type.TypeId = test_return_type(sc);
            ret infer_stmt(sc, d.data.test_.body, ret_ty);
        }
        ret R.ok[bool, str](true);
    }
    if (d.kind == decl.DECL_KIND_VAL || d.kind == decl.DECL_KIND_VAR) {
        ret infer_binding_init(sc, did, d);
    }
    if (d.kind == decl.DECL_KIND_COMPTIME_ATTR) {
        # a bare comptime directive (`$error(...)`): evaluated here, on the body
        # pass that recurses only into the selected comptime-if arm, so a reached
        # `$error` fails the build (#1511) while a dead arm's directive is skipped.
        eval_comptime_directive(sc, d.data.comptime_attr.target, d.span);
        ret R.ok[bool, str](true);
    }
    ret R.ok[bool, str](true);
}

# infer each of decl `d`'s backtick decorator arguments so their types resolve
#
# A decorator argument is a comptime expression (e.g. `#[align($size_of(T))]`);
# typing it here lets the middle end fold it later.
# ---
# sc: the context
# d:  the decl whose decorators to type
fun infer_decorator_args(sc: *context.SemaContext, d: *decl.Decl) {
    var i: u32 = 0;
    for (i < d.decorators_len) {
        val dec: *decl.Decorator = ?sc.a.decorators[d.decorators_start + i];
        var ii: u32 = 0;
        for (ii < dec.args_len) {
            infer.infer_expr(sc, sc.a.expr_ids[dec.args_start + ii]);
            ii = ii + 1;
        }
        i = i + 1;
    }
}

# validate every backtick decorator on decl `d`
#
# Each must name a directive from the closed set (symbol / section / inline /
# align / library), carry the right argument shape, and apply to a compatible
# declaration. Diagnostics are reported against the offending span; sema does not
# halt.
# ---
# sc: the context
# d:  the decl whose decorators to validate
fun validate_decorators(sc: *context.SemaContext, d: *decl.Decl) {
    var i: u32 = 0;
    for (i < d.decorators_len) {
        validate_one_decorator(sc, d, ?sc.a.decorators[d.decorators_start + i]);
        i = i + 1;
    }
}

# whether decorator `dec`'s directive name equals `name`
# ---
# sc:   the context (its source text)
# dec:  the decorator
# name: the directive name to match
# ret:  true on an exact match
fun decorator_named(sc: *context.SemaContext, dec: *decl.Decorator, name: str) bool {
    ret str_region_equals(sc.source, dec.name.offset, dec.name.len, name);
}

# report unless decorator `dec` carries exactly one string-literal argument
# ---
# sc:        the context
# dec:       the decorator
# count_msg: reported when the argument count is not one
# kind_msg:  reported when the sole argument is not a string literal
fun require_string_arg(sc: *context.SemaContext, dec: *decl.Decorator, count_msg: str, kind_msg: str) {
    if (dec.args_len != 1) {
        context.report(sc, dec.name, count_msg);
        ret;
    }
    val opt_arg: O.Option[*expr.Expr] = ast.get_expr(sc.a, sc.a.expr_ids[dec.args_start]);
    if (O.is_some[*expr.Expr](opt_arg)) {
        val arg: *expr.Expr = O.unwrap[*expr.Expr](opt_arg);
        if (arg.kind != expr.EXPR_KIND_LIT_STR) {
            context.report(sc, arg.span, kind_msg);
        }
    }
}

# whether `kind` is a valid `align` target: a global binding or a rec/uni nominal
#
# A `def` alias is excluded - it is transparent (no layout of its own, emits no
# symbol), so an alignment on it would silently no-op.
# ---
# kind: the decl kind
# ret:  true for val / var / rec / uni
fun is_align_target(kind: decl.DeclKind) bool {
    ret kind == decl.DECL_KIND_VAL || kind == decl.DECL_KIND_VAR ||
        kind == decl.DECL_KIND_REC || kind == decl.DECL_KIND_UNI;
}

# whether `kind` is a global binding (val / var)
#
# These are the targets whose `align` argument the body pass type-checks; a
# rec/uni argument is checked by the decl-pass fold (record_type_align) instead,
# to avoid a double report.
# ---
# kind: the decl kind
# ret:  true for val / var
fun is_global_binding(kind: decl.DeclKind) bool {
    ret kind == decl.DECL_KIND_VAL || kind == decl.DECL_KIND_VAR;
}

# whether `kind` is a function or a global binding (the symbol / section targets)
# ---
# kind: the decl kind
# ret:  true for fun / val / var
fun is_fun_or_global(kind: decl.DeclKind) bool {
    ret kind == decl.DECL_KIND_FUN || kind == decl.DECL_KIND_VAL || kind == decl.DECL_KIND_VAR;
}

# the inferred type of decorator-argument expression `eid`
#
# infer_decorator_args has already typed it; an out-of-range id yields TYPE_ERROR.
# ---
# sc:  the context
# eid: the argument expression id
# ret: the argument's inferred type, or TYPE_ERROR
fun decorator_arg_type(sc: *context.SemaContext, eid: id.ExprId) type.TypeId {
    if (eid == id.EXPR_NIL)          { ret type.TYPE_ERROR; }
    if (eid::usize >= sc.a.expr_len) { ret type.TYPE_ERROR; }
    ret sc.expr_type[eid];
}

# validate one decorator: its argument shape and its applicability to decl `d`
# ---
# sc:  the context
# d:   the decorated decl
# dec: the decorator to validate
fun validate_one_decorator(sc: *context.SemaContext, d: *decl.Decl, dec: *decl.Decorator) {
    if (decorator_named(sc, dec, "symbol")) {
        require_string_arg(sc, dec,
            "`symbol` decorator takes one string argument",
            "`symbol` decorator argument must be a string literal");
        if (!is_fun_or_global(d.kind)) {
            context.report(sc, dec.name, "`symbol` decorator applies only to functions and globals");
        }
        ret;
    }
    if (decorator_named(sc, dec, "library")) {
        require_string_arg(sc, dec,
            "`library` decorator takes one string argument",
            "`library` decorator argument must be a string literal");
        if ((d.flags & decl.DECL_FLAG_EXT) == 0) {
            context.report(sc, dec.name, "`library` decorator applies only to ext imports");
        }
        ret;
    }
    if (decorator_named(sc, dec, "inline")) {
        if (dec.args_len != 0) {
            context.report(sc, dec.name, "`inline` decorator takes no arguments");
        }
        if (d.kind != decl.DECL_KIND_FUN) {
            context.report(sc, dec.name, "`inline` decorator applies only to functions");
        }
        ret;
    }
    if (decorator_named(sc, dec, "align")) {
        if (dec.args_len != 1) {
            context.report(sc, dec.name, "`align` decorator takes one argument");
        } or (is_global_binding(d.kind)) {
            # for a global the value is folded at lowering (type layout available);
            # here only its type is checked. a rec/uni argument is validated wholly
            # by the decl-pass fold (record_type_align) - checking it here too would
            # double-report - so the type check is global-only.
            val arg_eid: id.ExprId = sc.a.expr_ids[dec.args_start];
            if (!type.is_integer(?sc.s.types, decorator_arg_type(sc, arg_eid))) {
                context.report(sc, dec.name, "`align` decorator argument must be an integer comptime expression");
            }
        }
        if (!is_align_target(d.kind)) {
            context.report(sc, dec.name, "`align` decorator applies only to records, unions, and globals");
        }
        ret;
    }
    if (decorator_named(sc, dec, "section")) {
        require_string_arg(sc, dec,
            "`section` decorator takes one string argument",
            "`section` decorator argument must be a string literal");
        if (!is_fun_or_global(d.kind)) {
            context.report(sc, dec.name, "`section` decorator applies only to functions and globals");
        }
        ret;
    }
    context.report(sc, dec.name, "unknown decorator; valid directives are symbol, section, inline, align, library");
}

# the return type a `test` body is checked against: the interned i32 primitive
#
# Falls back to TYPE_ERROR if the primitive is somehow unregistered, which
# suppresses cascading diagnostics.
# ---
# sc:  the context
# ret: the i32 TypeId, or TYPE_ERROR
fun test_return_type(sc: *context.SemaContext) type.TypeId {
    val opt_i32: O.Option[type.TypeId] = type.prim(?sc.s.types, type.TYPE_I32);
    if (O.is_none[type.TypeId](opt_i32)) { ret type.TYPE_ERROR; }
    ret O.unwrap[type.TypeId](opt_i32);
}

# infer a module-scope binding's initializer and check it against its slot type
#
# An unannotated binding's initializer was already inferred - and any error in it
# already reported - by the decl-type pass, which records its type in decl_type
# and expr_type. Re-inferring here would duplicate every diagnostic, so only an
# annotated binding (whose decl pass never walked the initializer) needs this
# body-pass infer-and-check.
# ---
# sc:  the context
# did: the binding decl
# d:   the binding decl record
# ret: always ok
fun infer_binding_init(sc: *context.SemaContext, did: id.DeclId, d: *decl.Decl) R.Result[bool, str] {
    if (d.data.bind.init == id.EXPR_NIL) { ret R.ok[bool, str](true); }
    if (d.data.bind.ty   == id.TYPE_NIL) { ret R.ok[bool, str](true); }

    val actual:   type.TypeId = infer.infer_expr(sc, d.data.bind.init);
    val expected: type.TypeId = sc.decl_type[did];
    if (expected != type.TYPE_NIL && expected != type.TYPE_ERROR && actual != type.TYPE_ERROR) {
        check_binding(sc, expected, d.data.bind.init, actual, d.span);
    }
    ret R.ok[bool, str](true);
}

# evaluate a body-scope comptime-if and recurse into the first active arm
# ---
# sc:  the context
# ci:  the comptime-if decl payload
# ret: true once the active arm is walked, or the first error
fun infer_bodies_comptime_if(sc: *context.SemaContext, ci: *decl.DeclComptimeIf) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < ci.branches_len) {
        val br: *decl.ComptimeBranch = ?sc.a.comptime_branches[ci.branches_start + i];
        val res_active: R.Result[bool, str] = comptime_branch_active(sc, br);
        if (R.is_err[bool, str](res_active)) { ret res_active; }
        if (R.unwrap_ok[bool, str](res_active)) {
            ret infer_bodies_in_list(sc, br.body_start, br.body_len);
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# walk a statement subtree, inferring and checking every expression it contains
#
# `fn_ret` is the enclosing function's resolved return type, threaded through so
# `ret` statements can be validated. STMT_NIL is a no-op. BRK / CNT / ASM / ERROR
# carry no expressions to infer.
# ---
# sc:     the context
# sid:    the statement to walk
# fn_ret: the enclosing function's return type
# ret:    true once walked, or the first error
fun infer_stmt(sc: *context.SemaContext, sid: id.StmtId, fn_ret: type.TypeId) R.Result[bool, str] {
    if (sid == id.STMT_NIL) { ret R.ok[bool, str](true); }
    val opt_stmt: O.Option[*stmt.Stmt] = ast.get_stmt(sc.a, sid);
    if (O.is_none[*stmt.Stmt](opt_stmt)) { ret R.err[bool, str]("StmtId out of range"); }
    val st: *stmt.Stmt = O.unwrap[*stmt.Stmt](opt_stmt);

    if (st.kind == stmt.STMT_KIND_EXPR) {
        infer.infer_expr(sc, st.data.expr.expr);
        ret R.ok[bool, str](true);
    }
    if (st.kind == stmt.STMT_KIND_BLOCK) {
        ret infer_stmt_list(sc, st.data.block.stmts_start, st.data.block.stmts_len, fn_ret);
    }
    if (st.kind == stmt.STMT_KIND_IF) {
        val cond_ty: type.TypeId = infer.infer_expr(sc, st.data.if_.cond);
        if (cond_ty != type.TYPE_ERROR) { check.check_condition(sc, cond_ty, st.span); }
        val res_then: R.Result[bool, str] = infer_stmt(sc, st.data.if_.then_block, fn_ret);
        if (R.is_err[bool, str](res_then)) { ret res_then; }
        ret infer_stmt(sc, st.data.if_.else_block, fn_ret);
    }
    if (st.kind == stmt.STMT_KIND_FOR) {
        if (st.data.for_.cond != id.EXPR_NIL) {
            val cond_ty: type.TypeId = infer.infer_expr(sc, st.data.for_.cond);
            if (cond_ty != type.TYPE_ERROR) { check.check_condition(sc, cond_ty, st.span); }
        }
        ret infer_stmt(sc, st.data.for_.body, fn_ret);
    }
    if (st.kind == stmt.STMT_KIND_RET) {
        check_return_stmt(sc, fn_ret, st.data.ret_.value, st.span);
        ret R.ok[bool, str](true);
    }
    if (st.kind == stmt.STMT_KIND_FIN) {
        ret infer_stmt(sc, st.data.fin_.body, fn_ret);
    }
    if (st.kind == stmt.STMT_KIND_DECL) {
        ret infer_local_decl(sc, st.data.decl.decl);
    }
    if (st.kind == stmt.STMT_KIND_COMPTIME_IF) {
        ret infer_stmt_comptime_if(sc, st.data.comptime_if.branches_start, st.data.comptime_if.branches_len, fn_ret);
    }
    if (st.kind == stmt.STMT_KIND_COMPTIME_EACH) {
        ret infer_stmt_comptime_each(sc, ?st.data.comptime_each, st.span, fn_ret);
    }
    if (st.kind == stmt.STMT_KIND_COMPTIME_ATTR) {
        eval_comptime_directive(sc, st.data.comptime_attr.target, st.span);
        ret R.ok[bool, str](true);
    }
    ret R.ok[bool, str](true);
}

# evaluate a reached comptime directive (`$error("msg")`, #1511)
#
# A `$error` directive fails the build with its folded message. The directive is
# reached only on a live path - a selected comptime arm or an unconditional
# position - so sema's per-arm walk fires it exactly when the surrounding code
# would compile, and never for a pruned dead arm. A non-`$error` target is a
# no-op.
# ---
# sc:     the context
# target: the directive's target expression
# span:   span to report the message against
fun eval_comptime_directive(sc: *context.SemaContext, target: id.ExprId, span: token.Span) {
    if (target == id.EXPR_NIL)                            { ret; }
    if (!comptime.is_error_call(sc.a, sc.source, target)) { ret; }
    val res_msg: R.Result[str, str] = comptime.error_message(sc.ctx, sc.a, sc.source, target, ?sc.s.interner);
    if (R.is_err[str, str](res_msg)) {
        context.report(sc, span, R.unwrap_err[str, str](res_msg));
        ret;
    }
    context.report(sc, span, R.unwrap_ok[str, str](res_msg));
}

# type-check a `$each <ident> in $fields(T) { body }` by unrolling it (#1473)
#
# The body is inferred once per field of T, with the loop variable bound in the
# comptime frame to that field's descriptor, so a `v.[f]` / `f.type` in the body
# is typed against the concrete field of each iteration. This is the sema half of
# the splice the lowerer mirrors; heterogeneous field types are handled because
# each iteration re-types the body.
#
# When T is an unbound generic type parameter the unroll is deferred to
# monomorphization (#1523), mirroring how variadic packs are handled (#1475).
# ---
# sc:     the context
# ce:     the `$each` statement payload
# span:   span of the `$each` for diagnostics
# fn_ret: the enclosing function's return type
# ret:    true once the body is typed (or its check deferred), or the first error
fun infer_stmt_comptime_each(sc: *context.SemaContext, ce: *stmt.StmtComptimeEach, span: token.Span, fn_ret: type.TypeId) R.Result[bool, str] {
    if (!comptime.is_fields_call(sc.a, sc.source, ce.seq)) {
        # a variadic-pack sequence (`$each a in va`, #1474): the element types are
        # fixed per call site, so the body is type-checked per instantiation at
        # monomorphization (#1475), not here. accept the well-formed construct and
        # defer; a non-pack, non-`$fields` sequence is malformed.
        val seq_ty: type.TypeId = infer.infer_expr(sc, ce.seq);
        val opt_seq: O.Option[*type.Type] = type.get(?sc.s.types, seq_ty);
        if (O.is_some[*type.Type](opt_seq) && O.unwrap[*type.Type](opt_seq).kind == type.TYPE_PACK) {
            ret R.ok[bool, str](true);
        }
        if (seq_ty != type.TYPE_ERROR) {
            context.report(sc, span, "a `$each` sequence must be `$fields(T)` or a variadic pack");
        }
        ret R.ok[bool, str](true);
    }

    val owner: type.TypeId = infer.field_seq_owner(sc, ce.seq, span);
    if (owner == type.TYPE_ERROR) { ret R.ok[bool, str](true); }
    # an unbound generic type param: defer the body type-check to monomorphization (#1523)
    if (infer.type_is_generic_param(sc, owner)) { ret R.ok[bool, str](true); }

    val res_name: R.Result[intern.StrId, str] = intern.intern_span(?sc.s.interner, sc.source, ce.var_name);
    if (R.is_err[intern.StrId, str](res_name)) { ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_name)); }
    val fname: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);

    val n: u32 = type.field_count(?sc.s.types, owner);
    var i: u32 = 0;
    for (i < n) {
        val mark: comptime.FrameMark = comptime.frame_open(sc.ctx);
        val res_bind: R.Result[bool, str] = comptime.bind(sc.ctx, fname, comptime.field_value(owner::u32, i));
        if (R.is_err[bool, str](res_bind)) {
            val res_close: R.Result[bool, str] = comptime.frame_close(sc.ctx, mark);
            if (R.is_err[bool, str](res_close)) { ret res_close; }
            ret res_bind;
        }
        val res_body:  R.Result[bool, str] = infer_stmt_list(sc, ce.body_start, ce.body_len, fn_ret);
        val res_close: R.Result[bool, str] = comptime.frame_close(sc.ctx, mark);
        if (R.is_err[bool, str](res_body))  { ret res_body; }
        if (R.is_err[bool, str](res_close)) { ret res_close; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# infer and check every statement in a list slice
# ---
# sc:     the context
# start:  index of the first StmtId
# len:    number of statements
# fn_ret: the enclosing function's return type
# ret:    true once walked, or the first error
fun infer_stmt_list(sc: *context.SemaContext, start: u32, len: u32, fn_ret: type.TypeId) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val sid: id.StmtId = sc.a.stmt_ids[start + i];
        val res_stmt: R.Result[bool, str] = infer_stmt(sc, sid, fn_ret);
        if (R.is_err[bool, str](res_stmt)) { ret res_stmt; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# type-check a statement-level comptime-if chain, deferring arm selection as needed
#
# A non-param-gated type-comparison chain is folded and pruned so only the live
# arm is checked; a param-gated chain (or a type-comparison chain that cannot
# fold yet) type-checks every arm structurally and defers selection to lowering;
# otherwise the active arm is selected here and walked.
# ---
# sc:     the context
# start:  index of the first ComptimeBranch
# len:    number of branches
# fn_ret: the enclosing function's return type
# ret:    true once the selected (or every) arm is walked, or the first error
fun infer_stmt_comptime_if(sc: *context.SemaContext, start: u32, len: u32, fn_ret: type.TypeId) R.Result[bool, str] {
    val param_gated:  bool = stmt_comptime_if_gated_on_param(sc, start, len);
    val has_type_cmp: bool = stmt_comptime_if_has_type_comparison(sc, start, len);

    # a type-comparison chain (`$type_of(x) == T`, #1472) NOT gated on a comptime
    # value parameter folds at monomorphization, where the type resolver is
    # installed and x's concrete type is known: prune the provably-dead arms and
    # type-check ONLY the selected one (#1511), so a clean no-cast skeleton
    # compiles directly. when a gate cannot fold yet - the original sema pass
    # installs no resolver, or x is still an abstract generic param - the prune
    # defers and the all-arms check below runs unchanged.
    if (has_type_cmp && !param_gated) {
        val res_prune: R.Result[bool, str] = prune_type_comparison_chain(sc, start, len, fn_ret);
        if (R.is_err[bool, str](res_prune))    { ret res_prune; }
        if (R.unwrap_ok[bool, str](res_prune)) { ret R.ok[bool, str](true); }
    }

    # a chain gated on a comptime value parameter, or a type-comparison chain that
    # did not fold above, cannot select an arm at sema time - the parameter's
    # value is fixed per call site, and an unresolved type comparison folds only
    # once the resolver is installed at lowering. type-check EVERY arm
    # structurally; arm selection is deferred to per-value monomorphization.
    if (param_gated || has_type_cmp) {
        var i: u32 = 0;
        for (i < len) {
            val arm: *decl.ComptimeBranch = ?sc.a.comptime_branches[start + i];
            if (arm.cond != id.EXPR_NIL) {
                # mark gate context so a `$type_of(...)` type comparison is accepted
                # here (and rejected as a value elsewhere).
                val saved_gate: bool = sc.in_comptime_gate;
                sc.in_comptime_gate = true;
                infer.infer_expr(sc, arm.cond);
                sc.in_comptime_gate = saved_gate;
                # every arm gate of a param-gated chain must itself be comptime-
                # foldable: its free identifiers must all be comptime (comptime
                # params or comptime constants), never a runtime local/param/var.
                # arm selection happens at lowering via the comptime evaluator, so a
                # runtime-gated arm would otherwise abort there with a span-less
                # error. report it here, against the offending gate.
                check_comptime_gate(sc, arm.cond);
            }
            val res_body: R.Result[bool, str] = infer_stmt_list(sc, arm.body_start, arm.body_len, fn_ret);
            if (R.is_err[bool, str](res_body)) { ret res_body; }
            i = i + 1;
        }
        ret R.ok[bool, str](true);
    }

    var i: u32 = 0;
    for (i < len) {
        val br: *decl.ComptimeBranch = ?sc.a.comptime_branches[start + i];
        val res_active: R.Result[bool, str] = comptime_branch_active(sc, br);
        if (R.is_err[bool, str](res_active)) { ret res_active; }
        if (R.unwrap_ok[bool, str](res_active)) {
            ret infer_stmt_list(sc, br.body_start, br.body_len, fn_ret);
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# fold a non-param-gated type-comparison `$if` chain and check only the live arm
#
# Returns true once the chain fully folds - the selected arm (if any) is checked
# and the rest are pruned untyped - and false when a gate cannot fold yet, in
# which case the caller type-checks every arm. Only the live arm is checked, so
# an arm written for one concrete type never fails against another. The chain
# folds during monomorphization (the type resolver installed, x's type concrete);
# in the original sema pass no resolver is installed, so the first gate defers and
# every arm is checked instead.
# ---
# sc:     the context
# start:  index of the first ComptimeBranch
# len:    number of branches
# fn_ret: the enclosing function's return type
# ret:    true once the chain folds (live arm checked), false to defer, or an error
fun prune_type_comparison_chain(sc: *context.SemaContext, start: u32, len: u32, fn_ret: type.TypeId) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        val arm: *decl.ComptimeBranch = ?sc.a.comptime_branches[start + i];
        if (arm.cond == id.EXPR_NIL) {
            # the unconditional final `$or {}` arm: reached only when every prior
            # gate folded false, so it is the selected arm.
            val res_body: R.Result[bool, str] = infer_stmt_list(sc, arm.body_start, arm.body_len, fn_ret);
            if (R.is_err[bool, str](res_body)) { ret res_body; }
            ret R.ok[bool, str](true);
        }

        # type the gate (populating the operand types the resolver reads), then
        # fold it. a gate that does not fold to a bool defers the whole chain.
        val saved_gate: bool = sc.in_comptime_gate;
        sc.in_comptime_gate = true;
        infer.infer_expr(sc, arm.cond);
        sc.in_comptime_gate = saved_gate;

        val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, arm.cond, ?sc.s.interner);
        if (R.is_err[comptime.CTValue, str](res_eval)) { ret R.ok[bool, str](false); }
        val gate_val: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_eval);
        if (gate_val.kind != comptime.CT_KIND_BOOL) { ret R.ok[bool, str](false); }
        if (gate_val.data.b) {
            val res_body: R.Result[bool, str] = infer_stmt_list(sc, arm.body_start, arm.body_len, fn_ret);
            if (R.is_err[bool, str](res_body)) { ret res_body; }
            ret R.ok[bool, str](true);
        }
        # gate folded false: this arm is provably dead - prune it (skip checking).
        i = i + 1;
    }
    # every gated arm folded false with no final `$or {}`: no arm is selected.
    ret R.ok[bool, str](true);
}

# whether any arm gate of a statement-level `$if` chain references a comptime param
#
# Such a gate is unfoldable until the call-site value is known, so all arms are
# type-checked and arm selection is deferred to lowering.
# ---
# sc:    the context
# start: index of the first ComptimeBranch
# len:   number of branches
# ret:   true when at least one gate references a comptime value parameter
fun stmt_comptime_if_gated_on_param(sc: *context.SemaContext, start: u32, len: u32) bool {
    var i: u32 = 0;
    for (i < len) {
        val br: *decl.ComptimeBranch = ?sc.a.comptime_branches[start + i];
        if (br.cond != id.EXPR_NIL && expr_references_comptime_param(sc, br.cond)) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# whether any arm gate of a statement-level `$if` chain is a type comparison
#
# A `$type_of(...) == TypeName` gate (#1472) folds only at lowering, so - like a
# comptime-param gate - its chain defers arm selection.
# ---
# sc:    the context
# start: index of the first ComptimeBranch
# len:   number of branches
# ret:   true when at least one gate contains a type comparison
fun stmt_comptime_if_has_type_comparison(sc: *context.SemaContext, start: u32, len: u32) bool {
    var i: u32 = 0;
    for (i < len) {
        val br: *decl.ComptimeBranch = ?sc.a.comptime_branches[start + i];
        if (br.cond != id.EXPR_NIL && gate_has_type_comparison(sc, br.cond)) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# whether `$if` gate `eid` contains a type comparison at any depth
# ---
# sc:  the context
# eid: the gate expression
# ret: true when a type comparison appears anywhere in the gate
fun gate_has_type_comparison(sc: *context.SemaContext, eid: id.ExprId) bool {
    if (eid == id.EXPR_NIL) { ret false; }
    val opt_expr: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](opt_expr)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](opt_expr);

    if (e.kind == expr.EXPR_KIND_BINARY) {
        if ((e.data.binary.op == expr.BIN_EQ || e.data.binary.op == expr.BIN_NEQ)
            && (comptime.is_type_comparison(sc.a, sc.source, ?e.data.binary)
             || infer.is_field_type_operand(sc, e.data.binary.lhs)
             || infer.is_field_type_operand(sc, e.data.binary.rhs))) {
            ret true;
        }
        ret gate_has_type_comparison(sc, e.data.binary.lhs)
         || gate_has_type_comparison(sc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret gate_has_type_comparison(sc, e.data.unary.operand);
    }
    ret false;
}

# whether any leaf identifier of `eid` resolves to a comptime value parameter
#
# Resolves through the resolve result's already-populated symbol bindings; a leaf
# is a comptime param when it is SYM_PARAM with SYM_FLAG_COMPTIME.
# ---
# sc:  the context
# eid: the expression to walk
# ret: true when a comptime value parameter is referenced
fun expr_references_comptime_param(sc: *context.SemaContext, eid: id.ExprId) bool {
    if (eid == id.EXPR_NIL) { ret false; }
    val opt_expr: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](opt_expr)) { ret false; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](opt_expr);

    if (e.kind == expr.EXPR_KIND_IDENT) {
        val opt_sym: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
        if (O.is_none[*resolve.Symbol](opt_sym)) { ret false; }
        val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
        ret sym.kind == resolve.SYM_PARAM && (sym.flags & resolve.SYM_FLAG_COMPTIME) != 0;
    }
    if (e.kind == expr.EXPR_KIND_BINARY) {
        ret expr_references_comptime_param(sc, e.data.binary.lhs)
         || expr_references_comptime_param(sc, e.data.binary.rhs);
    }
    if (e.kind == expr.EXPR_KIND_UNARY) {
        ret expr_references_comptime_param(sc, e.data.unary.operand);
    }
    ret false;
}

# verify a comptime-param `$if` gate is fully comptime-foldable, reporting if not
#
# Arm selection can be deferred to lowering only if the gate cannot abort there
# with a span-less error, so every leaf must be comptime: a comptime parameter, a
# comptime-foldable constant (checked by actually folding it, not by symbol kind -
# a runtime block-local `val` is SYM_VAL yet not foldable), a literal, or a
# `$mach.*` / module-constant path. A non-foldable subexpression (a runtime value,
# or an unevaluable index / call / cast / deref) is reported against its own span.
# Recurses through every composite expression kind.
# ---
# sc:  the context
# eid: the gate expression to verify
fun check_comptime_gate(sc: *context.SemaContext, eid: id.ExprId) {
    if (eid == id.EXPR_NIL) { ret; }
    val opt_expr: O.Option[*expr.Expr] = ast.get_expr(sc.a, eid);
    if (O.is_none[*expr.Expr](opt_expr)) { ret; }
    val e: *expr.Expr = O.unwrap[*expr.Expr](opt_expr);
    val k: expr.ExprKind = e.kind;

    # composite operators: recurse into operands so a runtime leaf is reported at
    # its own span rather than masked by the parent.
    if (k == expr.EXPR_KIND_BINARY) {
        # a type comparison (`$type_of(...) == TypeName`, #1472) is a well-formed
        # comptime gate; its operands name types (validated by infer) and it folds
        # at lowering, so it is not recursed into as value subexpressions.
        if ((e.data.binary.op == expr.BIN_EQ || e.data.binary.op == expr.BIN_NEQ)
            && (comptime.is_type_comparison(sc.a, sc.source, ?e.data.binary)
             || infer.is_field_type_operand(sc, e.data.binary.lhs)
             || infer.is_field_type_operand(sc, e.data.binary.rhs))) {
            ret;
        }
        check_comptime_gate(sc, e.data.binary.lhs);
        check_comptime_gate(sc, e.data.binary.rhs);
        ret;
    }
    if (k == expr.EXPR_KIND_UNARY) {
        # a deref / address-of is not comptime-evaluable at all; report it.
        if (e.data.unary.op == expr.UN_DEREF || e.data.unary.op == expr.UN_ADDR) {
            context.report(sc, e.span, "comptime `$if` gate is not a compile-time constant");
            ret;
        }
        check_comptime_gate(sc, e.data.unary.operand);
        ret;
    }

    # literals fold directly.
    if (k == expr.EXPR_KIND_LIT_INT || k == expr.EXPR_KIND_LIT_FLOAT
     || k == expr.EXPR_KIND_LIT_CHAR || k == expr.EXPR_KIND_LIT_STR) {
        ret;
    }

    # a bare COMPTIME_IDENT in a gate is a standalone `$ident`: not one of the
    # closed comptime channel shapes (#1249). defer to the evaluator's single
    # rejection rule, surfacing its teaching diagnostic against this span rather
    # than inventing a sema-local message. a rooted path arrives as a MEMBER chain
    # (handled below), never as a bare COMPTIME_IDENT here.
    if (k == expr.EXPR_KIND_COMPTIME_IDENT) {
        val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
        if (R.is_err[comptime.CTValue, str](res_eval)) {
            context.report(sc, e.span, R.unwrap_err[comptime.CTValue, str](res_eval));
        }
        ret;
    }

    if (k == expr.EXPR_KIND_IDENT) {
        val opt_sym: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
        # an unresolved ident may be a language literal (`true`/`false`) the
        # evaluator folds directly; leave it to the evaluator.
        if (O.is_none[*resolve.Symbol](opt_sym)) { ret; }
        val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
        if (sym.kind == resolve.SYM_PARAM) {
            if ((sym.flags & resolve.SYM_FLAG_COMPTIME) == 0) {
                check.report_named(sc, e.span, "comptime `$if` gate cannot reference runtime parameter '", sym.name, "'", "comptime `$if` gate cannot reference a runtime parameter");
            }
            ret;
        }
        # a `val` / imported binding is foldable ONLY if it actually resolves to a
        # comptime constant. a runtime block-local `val n = f();` is SYM_VAL but not
        # foldable - and the comptime env is name-keyed, so folding it would
        # spuriously succeed against a same-named MODULE const it shadows (a real
        # miscompile of the gate). decide on resolution identity first: only a
        # module-scope val (or an import) reaches the fold test; a block-local val
        # is rejected outright regardless of any name collision.
        if (sym.kind == resolve.SYM_VAL || sym.kind == resolve.SYM_IMPORTED) {
            val is_module: bool = sym.kind == resolve.SYM_IMPORTED
                                || (sym.flags & resolve.SYM_FLAG_MODULE) != 0;
            if (!is_module) {
                check.report_named(sc, e.span, "comptime `$if` gate cannot reference runtime value '", sym.name, "'", "comptime `$if` gate cannot reference a runtime value");
                ret;
            }
            val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
            if (R.is_err[comptime.CTValue, str](res_eval) && !check.imported_module_const_sym(sc, sym)) {
                check.report_named(sc, e.span, "comptime `$if` gate cannot reference runtime value '", sym.name, "'", "comptime `$if` gate cannot reference a runtime value");
            }
            ret;
        }
        check.report_named(sc, e.span, "comptime `$if` gate cannot reference runtime value '", sym.name, "'", "comptime `$if` gate cannot reference a runtime value");
        ret;
    }

    # a module-qualified member (`alias.CONST`) folds to the defining module's
    # constant; a member of a runtime value does not. fold to decide.
    if (k == expr.EXPR_KIND_MEMBER) {
        val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, eid, ?sc.s.interner);
        if (R.is_err[comptime.CTValue, str](res_eval)) {
            val opt_sym: O.Option[*resolve.Symbol] = context.symbol_for_expr(sc, eid);
            if (O.is_none[*resolve.Symbol](opt_sym) || !check.imported_module_const_sym(sc, O.unwrap[*resolve.Symbol](opt_sym))) {
                context.report(sc, e.span, "comptime `$if` gate is not a compile-time constant");
            }
        }
        ret;
    }

    # index / call / cast / array-lit / struct-lit: not comptime-evaluable in a
    # gate. report against the whole subexpression.
    context.report(sc, e.span, "comptime `$if` gate is not a compile-time constant");
    ret;
}

# type a local val/var: record its type, infer its initializer, check the match
#
# Records the declared (or inferred) type in decl_type, infers the initializer,
# and checks compatibility when an explicit annotation is present.
# ---
# sc:  the context
# did: the local decl
# ret: true once typed, or the first error
fun infer_local_decl(sc: *context.SemaContext, did: id.DeclId) R.Result[bool, str] {
    if (did == id.DECL_NIL) { ret R.ok[bool, str](true); }
    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(sc.a, did);
    if (O.is_none[*decl.Decl](opt_decl)) { ret R.err[bool, str]("DeclId out of range"); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_decl);
    if (d.kind != decl.DECL_KIND_VAL && d.kind != decl.DECL_KIND_VAR) {
        ret R.ok[bool, str](true);
    }

    val ty: type.TypeId = infer.infer_decl(sc, did);
    if (sc.decl_type != nil) { sc.decl_type[did] = ty; }

    if (d.data.bind.init != id.EXPR_NIL) {
        val actual: type.TypeId = infer.infer_expr(sc, d.data.bind.init);
        if (d.data.bind.ty != id.TYPE_NIL && ty != type.TYPE_NIL
            && ty != type.TYPE_ERROR && actual != type.TYPE_ERROR) {
            check_binding(sc, ty, d.data.bind.init, actual, d.span);
        }
    }
    ret R.ok[bool, str](true);
}

# check an initializer expression against the declared slot type
#
# Attempts a literal coercion first (which rewrites expr_type[eid] on success),
# then delegates to check.check_assignable on the post-coercion type.
# ---
# sc:       the context
# expected: the declared slot type
# eid:      the initializer expression
# actual:   the initializer's inferred type
# span:     span to report a mismatch against
fun check_binding(sc: *context.SemaContext, expected: type.TypeId, eid: id.ExprId, actual: type.TypeId, span: token.Span) {
    var have: type.TypeId = actual;
    val opt_coerced: O.Option[type.TypeId] = coerce.try_coerce_literal(sc, eid, expected);
    if (O.is_some[type.TypeId](opt_coerced)) { have = O.unwrap[type.TypeId](opt_coerced); }
    check.check_assignable(sc, expected, have, span);
}

# check a return statement against the enclosing function's return type
#
# Infers the returned value (if any), applies a literal coercion toward the
# resolved return type, then delegates to check.check_return.
# ---
# sc:       the context
# ret_type: the enclosing function's return type
# value:    the returned expression, or EXPR_NIL for a bare `ret`
# span:     span to report a mismatch against
fun check_return_stmt(sc: *context.SemaContext, ret_type: type.TypeId, value: id.ExprId, span: token.Span) {
    if (value == id.EXPR_NIL) {
        check.check_return(sc, ret_type, type.TYPE_NIL, span);
        ret;
    }
    var value_ty: type.TypeId = infer.infer_expr(sc, value);
    if (ret_type != type.TYPE_NIL && ret_type != type.TYPE_ERROR && value_ty != type.TYPE_ERROR) {
        val opt_coerced: O.Option[type.TypeId] = coerce.try_coerce_literal(sc, value, ret_type);
        if (O.is_some[type.TypeId](opt_coerced)) { value_ty = O.unwrap[type.TypeId](opt_coerced); }
    }
    check.check_return(sc, ret_type, value_ty, span);
}

# evaluate a comptime-branch condition, reporting whether the arm is active
#
# An empty cond (`$or { }`) is the unconditional final arm. An evaluation failure
# or a non-bool result yields false (the arm is inactive) without a diagnostic -
# resolve's matching check runs first and already reported it, so reporting again
# here would duplicate it.
# ---
# sc:  the context
# br:  the comptime branch
# ret: true when the arm is active, false when inactive, or an error
fun comptime_branch_active(sc: *context.SemaContext, br: *decl.ComptimeBranch) R.Result[bool, str] {
    if (br.cond == id.EXPR_NIL) { ret R.ok[bool, str](true); }
    val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(sc.ctx, sc.a, sc.source, br.cond, ?sc.s.interner);
    if (R.is_err[comptime.CTValue, str](res_eval)) {
        ret R.ok[bool, str](false);
    }
    val gate_val: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_eval);
    if (gate_val.kind != comptime.CT_KIND_BOOL) { ret R.ok[bool, str](false); }
    ret R.ok[bool, str](gate_val.data.b);
}

# move the context's arrays into a SemaResult and tear the context down
#
# Ownership of the three parallel arrays passes to the result; the context
# handles are cleared first so dnit_context does not free them. The field tables
# the context once owned now live in the session-global type interner and outlive
# the context.
# ---
# sc:  the context to finalize
# ret: the populated SemaResult
fun build_result(sc: *context.SemaContext) R.Result[context.SemaResult, str] {
    var out: context.SemaResult;
    out.alloc            = sc.s.alloc;
    out.expr_type        = sc.expr_type;
    out.type_resolved_ty = sc.type_resolved_ty;
    out.decl_type        = sc.decl_type;
    out.expr_count       = sc.a.expr_len::u32;
    out.type_count       = sc.a.type_len::u32;
    out.decl_count       = sc.a.decl_len::u32;

    sc.expr_type        = nil;
    sc.type_resolved_ty = nil;
    sc.decl_type        = nil;
    dnit_context(sc);

    ret R.ok[context.SemaResult, str](out);
}
