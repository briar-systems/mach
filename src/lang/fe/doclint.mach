# the docstring component lint
#
# A post-parse pass over a module AST that validates `# <component>:` lines in a
# declaration's docstring against the declaration's documentable items. It fires
# only for `pub` declarations whose docstring carries a `# ---` component block; a
# non-`pub` decl, a decl with no docstring, and a summary-only docstring are all
# silent. A docstring is never required. The validated kinds are `fun`, `rec`, and
# `uni` - the declaration forms that expose documentable items.
#
# Documentation may be partial: an item with no component line is never flagged.
# The lint only validates the lines that ARE written - a component naming no real
# item (misspelled), a component with no description, and documented components in
# the wrong relative order. Completeness is not enforced: an item with no
# component line is never reported.
#
# The lint emits WARNINGs to the session diagnostic list and runs from the
# parser's public entry, so both the build/check path and the editor parse path
# surface it.

use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_empty;
use std.types.string.str_equals;

use A: std.allocator;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.id;
use mach.lang.fe.doc;
use mach.lang.fe.lexer;
use pdecl: mach.lang.fe.parser.decl;
use mach.lang.fe.parser.state;
use mach.lang.fe.token;
use src: mach.lang.source;

# how a documentable item's component name is spelled
def ItemKind: u8;
# a generic type parameter, written `[T]`
val ITEM_GENERIC:  ItemKind = 0;
# a comptime value parameter, written `$name`
val ITEM_COMPTIME: ItemKind = 1;
# a value parameter or field, written by its bare name
val ITEM_PLAIN:    ItemKind = 2;
# a function return value, written `ret`
val ITEM_RET:      ItemKind = 3;

# the warning for a component that names no documentable item of the declaration
val MSG_UNKNOWN: str = "documented component matches no parameter, field, generic, or `ret` of this declaration";
# the warning for a matched component whose description is blank
val MSG_NO_DESC: str = "documented component has no description";
# the warning for documented components that break the items' declaration order
val MSG_ORDER:   str = "documented components are out of declaration order";

# one documentable item of a declaration, in declaration order
# ---
# kind:     how the component name is spelled
# name_off: byte offset of the item's base identifier in source (unused for ret)
# name_len: byte length of the base identifier (unused for ret)
rec Item {
    kind:     ItemKind;
    name_off: usize;
    name_len: usize;
}

# validate every documentable `pub` declaration in `a`, appending a WARNING to
# `diags` for each mismatch
#
# A no-op for decls that are non-`pub`, carry no docstring, or carry a
# summary-only docstring. Walks the flat decl pool, so module-scope,
# comptime-branch, and (never-`pub`) local decls are all covered.
# ---
# a:      the parsed module AST
# source: the module's source text the doc spans point into
# diags:  diagnostic sink the warnings are appended to
pub fun lint_module(a: *ast.Ast, source: str, diags: *diagnostic.DiagList) {
    var i: usize = 0;
    for (i < a.decl_len) {
        lint_decl(a, ?a.decls[i], source, diags);
        i = i + 1;
    }
}

# run the component lint for one declaration when it is in scope: `pub`,
# documentable (fun/rec/uni), and carrying a `# ---` component block
# ---
# a:      the parsed module AST
# d:      the declaration to lint
# source: the module's source text
# diags:  diagnostic sink the warnings are appended to
fun lint_decl(a: *ast.Ast, d: *decl.Decl, source: str, diags: *diagnostic.DiagList) {
    if ((d.flags & decl.DECL_FLAG_PUB) == 0)     { ret; }
    if (d.doc.len == 0)                          { ret; }
    if (!is_documentable(d.kind))                { ret; }
    if (!doc.has_component_block(source, d.doc)) { ret; }
    check_components(a, d, source, diags);
}

# true for the declaration kinds that expose documentable items - functions,
# records, and unions, the kinds whose docstrings carry component lines
# ---
# kind: the declaration kind to test
# ret:  true when the kind exposes documentable items
fun is_documentable(kind: decl.DeclKind) bool {
    ret kind == decl.DECL_KIND_FUN
     || kind == decl.DECL_KIND_REC
     || kind == decl.DECL_KIND_UNI;
}

# the number of documentable items a declaration exposes: its generics plus its
# parameters or fields, plus one for a function's non-nil return
# ---
# d:   the declaration to measure
# ret: the count of documentable items, zero for a non-documentable kind
fun item_count(d: *decl.Decl) usize {
    if (d.kind == decl.DECL_KIND_FUN) {
        val f: *decl.DeclFun = ?d.data.fun_;
        var n: usize = f.generics_len::usize + f.params_len::usize;
        if (f.return_type != id.TYPE_NIL) { n = n + 1; }
        ret n;
    }
    if (d.kind == decl.DECL_KIND_REC) {
        val r: *decl.DeclRec = ?d.data.rec_;
        ret r.generics_len::usize + r.fields_len::usize;
    }
    if (d.kind == decl.DECL_KIND_UNI) {
        val u: *decl.DeclUni = ?d.data.uni_;
        ret u.generics_len::usize + u.fields_len::usize;
    }
    ret 0;
}

# the lint body for a decl already known to be in scope
#
# Builds the declaration's ordered item list, then walks the docstring's
# component lines once, validating each. Partial documentation is allowed: an
# item with no component line is never flagged. A buffer allocation failure
# drops the lint silently - a missing warning never aborts the parse.
#
# Per component line:
#   - matches no item              -> unknown (misspelled)
#   - matches an item, blank value  -> missing description
#   - matches an out-of-order item  -> out of order
#
# The order check runs against only the items that ARE documented: the documented
# components must keep the underlying items' relative order, but gaps between them
# (undocumented items) are permitted, so a doc covering only `ret`, or only some
# parameters, is never flagged for order.
# ---
# a:      the parsed module AST
# d:      the in-scope declaration to check
# source: the module's source text
# diags:  diagnostic sink the warnings are appended to
fun check_components(a: *ast.Ast, d: *decl.Decl, source: str, diags: *diagnostic.DiagList) {
    val count: usize = item_count(d);

    var items: *Item = nil;
    if (count > 0) {
        val res_items: R.Result[*Item, str] = A.allocate[Item](a.a, count);
        if (R.is_err[*Item, str](res_items)) { ret; }
        items = R.unwrap_ok[*Item, str](res_items);
        fill_items(a, d, items);
    }

    var iter:      doc.DocComponentIter = doc.component_iter(source, d.doc);
    var component: doc.DocComponent;
    var prev:      usize = 0;
    var have_prev: bool  = false;

    for (doc.component_next(?iter, ?component)) {
        val idx: usize = match_item(source, items, count, component.name_span);
        if (idx == count) {
            warn(diags, a.file_id, component.name_span, MSG_UNKNOWN);
            cnt;
        }
        if (component.desc_span.len == 0) {
            warn(diags, a.file_id, component.name_span, MSG_NO_DESC);
        }
        if (have_prev && idx < prev) {
            warn(diags, a.file_id, component.name_span, MSG_ORDER);
        }
        prev      = idx;
        have_prev = true;
    }

    if (items != nil) {
        A.deallocate[Item](a.a, items, count);
    }
}

# write the declaration's documentable items into `out` in declaration order: for
# a function its generics, then value parameters, then `ret` when the return type
# is non-nil; for a rec/uni its generics, then fields
# ---
# a:   the parsed module AST (source of the side pools)
# d:   the declaration whose items are written
# out: destination buffer, sized to item_count(d)
fun fill_items(a: *ast.Ast, d: *decl.Decl, out: *Item) {
    var n: usize = 0;

    if (d.kind == decl.DECL_KIND_FUN) {
        val f: *decl.DeclFun = ?d.data.fun_;
        n = put_generics(a, f.generics_start, f.generics_len, out, n);
        n = put_typed_names(a, f.params_start, f.params_len, out, n);
        if (f.return_type != id.TYPE_NIL) {
            out[n].kind     = ITEM_RET;
            out[n].name_off = 0;
            out[n].name_len = 0;
            n = n + 1;
        }
        ret;
    }
    if (d.kind == decl.DECL_KIND_REC) {
        val r: *decl.DeclRec = ?d.data.rec_;
        n = put_generics(a, r.generics_start, r.generics_len, out, n);
        n = put_typed_names(a, r.fields_start, r.fields_len, out, n);
        ret;
    }
    if (d.kind == decl.DECL_KIND_UNI) {
        val u: *decl.DeclUni = ?d.data.uni_;
        n = put_generics(a, u.generics_start, u.generics_len, out, n);
        n = put_typed_names(a, u.fields_start, u.fields_len, out, n);
        ret;
    }
}

# write the generics in `[start, start + len)` as ITEM_GENERIC entries beginning
# at index `n`, returning the new count
# ---
# a:     the parsed module AST (source of generic_names)
# start: index of the first generic name in a.generic_names
# len:   number of generic names to write
# out:   destination buffer
# n:     index at which to begin writing
# ret:   the index just past the last entry written
fun put_generics(a: *ast.Ast, start: u32, len: u32, out: *Item, n: usize) usize {
    var i:   u32   = 0;
    var cur: usize = n;
    for (i < len) {
        val sp: token.Span = a.generic_names[start + i];
        out[cur].kind     = ITEM_GENERIC;
        out[cur].name_off = sp.offset;
        out[cur].name_len = sp.len;
        cur = cur + 1;
        i   = i + 1;
    }
    ret cur;
}

# write the parameters or fields in `[start, start + len)` as ITEM_COMPTIME (a
# `$name` comptime parameter) or ITEM_PLAIN entries beginning at index `n`,
# returning the new count
# ---
# a:     the parsed module AST (source of typed_names)
# start: index of the first typed name in a.typed_names
# len:   number of typed names to write
# out:   destination buffer
# n:     index at which to begin writing
# ret:   the index just past the last entry written
fun put_typed_names(a: *ast.Ast, start: u32, len: u32, out: *Item, n: usize) usize {
    var i:   u32   = 0;
    var cur: usize = n;
    for (i < len) {
        val tn: *decl.TypedName = ?a.typed_names[start + i];
        if (tn.comptime) {
            out[cur].kind = ITEM_COMPTIME;
        }
        or {
            out[cur].kind = ITEM_PLAIN;
        }
        out[cur].name_off = tn.name.offset;
        out[cur].name_len = tn.name.len;
        cur = cur + 1;
        i   = i + 1;
    }
    ret cur;
}

# the index of the item whose component spelling equals the byte content of
# `name` within `source`, or `count` when none matches
# ---
# source: the module's source text
# items:  the declaration's documentable items
# count:  number of items
# name:   span of the component name as written in the docstring
# ret:    the matching item index, or `count` when none matches
fun match_item(source: str, items: *Item, count: usize, name: token.Span) usize {
    var i: usize = 0;
    for (i < count) {
        if (item_name_eq(source, ?items[i], name)) { ret i; }
        i = i + 1;
    }
    ret count;
}

# true when the component span `name` spells item `it`: `[T]` for a generic, `$x`
# for a comptime parameter, `ret` for the return value, the bare identifier
# otherwise
# ---
# source: the module's source text
# it:     the item to test
# name:   span of the component name as written in the docstring
# ret:    true when `name` spells `it`
fun item_name_eq(source: str, it: *Item, name: token.Span) bool {
    if (it.kind == ITEM_RET) {
        ret span_eq_str(source, name, "ret");
    }
    if (it.kind == ITEM_GENERIC) {
        # `[` + base + `]`
        if (name.len != it.name_len + 2)               { ret false; }
        if (source[name.offset] != '[')                { ret false; }
        if (source[name.offset + name.len - 1] != ']') { ret false; }
        ret bytes_eq(source, name.offset + 1, it.name_off, it.name_len);
    }
    if (it.kind == ITEM_COMPTIME) {
        # `$` + base
        if (name.len != it.name_len + 1) { ret false; }
        if (source[name.offset] != '$')  { ret false; }
        ret bytes_eq(source, name.offset + 1, it.name_off, it.name_len);
    }
    # plain identifier
    if (name.len != it.name_len) { ret false; }
    ret bytes_eq(source, name.offset, it.name_off, it.name_len);
}

# true when the `len` bytes at `a_off` equal the `len` bytes at `b_off` within
# `source`
# ---
# source: the text both ranges index into
# a_off:  start of the first range
# b_off:  start of the second range
# len:    number of bytes to compare
# ret:    true when the two ranges are byte-equal
fun bytes_eq(source: str, a_off: usize, b_off: usize, len: usize) bool {
    var i: usize = 0;
    for (i < len) {
        if (source[a_off + i] != source[b_off + i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

# true when `span`'s bytes equal the null-terminated string `s`
# ---
# source: the text `span` indexes into
# span:   the span to compare
# s:      the null-terminated string to compare against
# ret:    true when `span`'s bytes equal `s` exactly
fun span_eq_str(source: str, span: token.Span, s: str) bool {
    var i: usize = 0;
    for (i < span.len) {
        if (s[i] == 0)                       { ret false; }
        if (source[span.offset + i] != s[i]) { ret false; }
        i = i + 1;
    }
    ret s[span.len] == 0;
}

# append a docstring WARNING to the sink, swallowing an allocation failure (a
# dropped lint warning never aborts a parse)
# ---
# diags:   diagnostic sink the warning is appended to
# file_id: file the warning is attributed to
# span:    source span the warning points at
# message: the warning text
fun warn(diags: *diagnostic.DiagList, file_id: src.FileId, span: token.Span, message: str) {
    val res_warn: R.Result[bool, str] = diagnostic.warning(diags, file_id, span, message);
    if (R.is_err[bool, str](res_warn)) { ret; }
}

# lex and parse `source`, run the lint, and return the number of warnings whose
# message equals `msg` (the empty string counts every warning)
#
# Frees all temporaries before returning. A lex or parse setup failure returns a
# sentinel that never equals a real count, failing the asserting test.
# ---
# source: module source text to lint
# msg:    warning text to count, or the empty string to count all warnings
# ret:    the number of matching warnings, or a sentinel on setup failure
fun t_warns(source: str, msg: str) usize {
    var alloc: A.Allocator;
    page.make(?alloc);

    val res_stream: R.Result[lexer.TokenStream, str] = lexer.tokenize(source, ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](res_stream)) { ret 0xFFFF; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](res_stream);

    var a:     ast.Ast             = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p:     state.Parser        = state.make(?stream, ?a, ?diags);
    pdecl.parse_module(?p);

    lint_module(?a, stream.source, ?diags);

    var n: usize = 0;
    var i: usize = 0;
    for (i < diags.len) {
        val d: *diagnostic.Diagnostic = ?diags.items[i];
        if (d.severity == diagnostic.SEVERITY_WARNING) {
            if (str_empty(msg) || str_equals(d.message, msg)) { n = n + 1; }
        }
        i = i + 1;
    }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret n;
}

# a fully correct fun (generics, comptime, params, ret) warns nothing.
test "mach.lang.fe.doclint.lint_module:correct_fun_all_items" {
    val source: str = "# atomic load\n# ---\n# [T]: element type\n# $order: ordering\n# ptr: pointer\n# ret: loaded value\npub fun load[T]($order: i64, ptr: *T) T { ret @ptr; }";
    if (t_warns(source, "") != 0) { ret 1; }
    ret 0;
}

# a misspelled component warns unknown; `z` matches no field, and the real field
# `y` simply going undocumented is fine.
test "mach.lang.fe.doclint.lint_module:misspelled_component_unknown" {
    val source: str = "# a point\n# ---\n# x: horizontal\n# z: misspelled\npub rec Point { x: i64; y: i64; }";
    if (t_warns(source, MSG_UNKNOWN) != 1) { ret 1; }
    if (t_warns(source, "")          != 1) { ret 1; }
    ret 0;
}

# only `x` documented, `y` omitted: partial documentation is allowed, no warning.
test "mach.lang.fe.doclint.lint_module:undocumented_item_allowed" {
    val source: str = "# a point\n# ---\n# x: horizontal\npub rec Point { x: i64; y: i64; }";
    if (t_warns(source, "") != 0) { ret 1; }
    ret 0;
}

# a component line with no description warns.
test "mach.lang.fe.doclint.lint_module:no_description_warns" {
    val source: str = "# a point\n# ---\n# x:\npub rec Point { x: i64; y: i64; }";
    if (t_warns(source, MSG_NO_DESC) != 1) { ret 1; }
    if (t_warns(source, "")          != 1) { ret 1; }
    ret 0;
}

# `ret` then `ptr` reverses the underlying order (ptr precedes ret).
test "mach.lang.fe.doclint.lint_module:out_of_order_warns" {
    val source: str = "# swap order\n# ---\n# ret: result\n# ptr: pointer\npub fun oo(ptr: *i64) i64 { ret @ptr; }";
    if (t_warns(source, MSG_ORDER) != 1) { ret 1; }
    if (t_warns(source, "")        != 1) { ret 1; }
    ret 0;
}

# order judges only the documented items, so gaps between them are not out of
# order.
test "mach.lang.fe.doclint.lint_module:order_ignores_gaps" {
    # b and d documented (a, c skipped) in their real relative order: clean.
    val gapped: str = "# four fields\n# ---\n# b: second\n# d: fourth\npub rec R { a: i64; b: i64; c: i64; d: i64; }";
    if (t_warns(gapped, "") != 0) { ret 1; }

    # documenting only `ret` of a multi-param fun is clean (no order, no missing).
    val ret_only: str = "# adds\n# ---\n# ret: the sum\npub fun add(x: i64, y: i64) i64 { ret x + y; }";
    if (t_warns(ret_only, "") != 0) { ret 1; }
    ret 0;
}

# ret is validated when present and is not an item on a void fun.
test "mach.lang.fe.doclint.lint_module:ret_item_presence" {
    # a non-nil return with ret documented: clean.
    val with_ret: str = "# id\n# ---\n# x: the value\n# ret: the value back\npub fun id(x: i64) i64 { ret x; }";
    if (t_warns(with_ret, "") != 0) { ret 1; }

    # a non-nil return WITHOUT ret documented: allowed (partial docs), no warning.
    val no_ret_doc: str = "# id\n# ---\n# x: the value\npub fun id(x: i64) i64 { ret x; }";
    if (t_warns(no_ret_doc, "") != 0) { ret 1; }

    # a void function: ret is not an item, so documenting only the param is clean.
    val void_fn: str = "# noop\n# ---\n# x: ignored\npub fun noop(x: i64) {}";
    if (t_warns(void_fn, "") != 0) { ret 1; }

    # a void function that documents ret: ret matches no item -> unknown.
    val void_ret: str = "# noop\n# ---\n# x: ignored\n# ret: nothing\npub fun noop(x: i64) {}";
    if (t_warns(void_ret, MSG_UNKNOWN) != 1) { ret 1; }
    if (t_warns(void_ret, "")          != 1) { ret 1; }
    ret 0;
}

# a summary-only docstring (no `# ---`) warns nothing.
test "mach.lang.fe.doclint.lint_module:summary_only_silent" {
    val source: str = "# yield the CPU\npub fun spin(x: i64) {}";
    if (t_warns(source, "") != 0) { ret 1; }
    ret 0;
}

# a decl with no docstring warns nothing.
test "mach.lang.fe.doclint.lint_module:no_docstring_silent" {
    val source: str = "pub fun bare(x: i64, y: i64) {}";
    if (t_warns(source, "") != 0) { ret 1; }
    ret 0;
}

# a non-pub decl with a mismatched block warns nothing.
test "mach.lang.fe.doclint.lint_module:non_pub_silent" {
    val source: str = "# private\n# ---\n# bogus: nope\nfun priv(x: i64) {}";
    if (t_warns(source, "") != 0) { ret 1; }
    ret 0;
}

# the docstring is read above a `#[...]` decorator, not the decorator itself.
test "mach.lang.fe.doclint.lint_module:doc_above_decorator" {
    # the doc sits above the `#[inline]` line; capture skips the decorator, so a
    # correct block warns nothing.
    val ok_source: str = "# the answer\n# ---\n# ret: always 42\n#[inline]\npub fun answer() i64 { ret 42; }";
    if (t_warns(ok_source, "") != 0) { ret 1; }

    # and an unknown component above the decorator is still caught.
    val bad_source: str = "# the answer\n# ---\n# bogus: nope\n#[inline]\npub fun answer() i64 { ret 42; }";
    if (t_warns(bad_source, MSG_UNKNOWN) != 1) { ret 1; }
    if (t_warns(bad_source, "")          != 1) { ret 1; }
    ret 0;
}

# generic and comptime components must use their `[T]` / `$name` forms.
test "mach.lang.fe.doclint.lint_module:generic_comptime_forms" {
    # documenting a generic as the bare `T` (not `[T]`) matches no item -> unknown;
    # the generic going otherwise undocumented is fine.
    val bare_generic: str = "# load\n# ---\n# T: element\n# ptr: pointer\npub fun load[T](ptr: *T) { }";
    if (t_warns(bare_generic, MSG_UNKNOWN) != 1) { ret 1; }
    if (t_warns(bare_generic, "")          != 1) { ret 1; }

    # the correct `[T]` form is clean.
    val ok_generic: str = "# load\n# ---\n# [T]: element\n# ptr: pointer\npub fun load[T](ptr: *T) { }";
    if (t_warns(ok_generic, "") != 0) { ret 1; }
    ret 0;
}
