# mach.lang.fe.ast: the per-module AST container.
#
# owns every node array (modules, exprs, stmts, decls, types) plus typed
# side pools for variable-length payloads (decl_ids, stmt_ids, expr_ids,
# type_ids, typed_names, field_inits, generic_names,
# comptime_branches).

use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.size.usize;
use std.types.string.str;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use token: mach.lang.fe.token;
use src:   mach.lang.source;

use id:     mach.lang.fe.ast.id;
use module: mach.lang.fe.ast.module;
use expr:   mach.lang.fe.ast.expr;
use stmt:   mach.lang.fe.ast.stmt;
use decl:   mach.lang.fe.ast.decl;
use m_type: mach.lang.fe.ast.type;

val INITIAL_NODE_CAP:   usize = 32;
val INITIAL_AUX_CAP:    usize = 16;
val INITIAL_ID_POOL_CAP: usize = 64;

# Ast: the root AST container for one parsed source file.
# ---
# alloc:         allocator used for all owned storage
# file_id:       identifier of the source file this AST was parsed from
# root_module:   ModuleId of the top-level Module, or MODULE_NIL before parsing completes
# modules:       Module array
# module_len:    number of Modules stored
# module_cap:    allocated slots in modules
# exprs:         Expr array
# expr_len:      number of Exprs stored
# expr_cap:      allocated slots in exprs
# stmts:         Stmt array
# stmt_len:      number of Stmts stored
# stmt_cap:      allocated slots in stmts
# decls:         Decl array
# decl_len:      number of Decls stored
# decl_cap:      allocated slots in decls
# types:         Type array
# type_len:      number of Types stored
# type_cap:      allocated slots in types
# typed_names:   shared pool used by DeclFun parameters and DeclRec fields
# typed_name_len: number of TypedNames stored
# typed_name_cap: allocated slots in typed_names
# field_inits:   shared pool used by ExprStructLit
# field_init_len: number of FieldInits stored
# field_init_cap: allocated slots in field_inits
# generic_names:       pool of Spans used by DeclFun and DeclRec generic parameters
# generic_name_len:    number of generic names stored
# generic_name_cap:    allocated slots in generic_names
# comptime_branches:   pool of ComptimeBranch records referenced by DeclComptimeIf and StmtComptimeIf
# comptime_branch_len: number of branches stored
# comptime_branch_cap: allocated slots in comptime_branches
# decl_ids:            typed pool of DeclIds for node-owned decl lists
# decl_id_len:         number of DeclIds stored
# decl_id_cap:         allocated slots in decl_ids
# stmt_ids:            typed pool of StmtIds for node-owned stmt lists
# stmt_id_len:         number of StmtIds stored
# stmt_id_cap:         allocated slots in stmt_ids
# expr_ids:            typed pool of ExprIds for node-owned expr lists
# expr_id_len:         number of ExprIds stored
# expr_id_cap:         allocated slots in expr_ids
# type_ids:            typed pool of TypeIds for node-owned type lists
# type_id_len:         number of TypeIds stored
# type_id_cap:         allocated slots in type_ids
pub rec Ast {
    alloc:       *Allocator;
    file_id:     src.FileId;
    root_module: id.ModuleId;

    modules:    *module.Module;
    module_len: usize;
    module_cap: usize;

    exprs:    *expr.Expr;
    expr_len: usize;
    expr_cap: usize;

    stmts:    *stmt.Stmt;
    stmt_len: usize;
    stmt_cap: usize;

    decls:    *decl.Decl;
    decl_len: usize;
    decl_cap: usize;

    types:    *m_type.Type;
    type_len: usize;
    type_cap: usize;

    typed_names:    *decl.TypedName;
    typed_name_len: usize;
    typed_name_cap: usize;

    field_inits:    *expr.FieldInit;
    field_init_len: usize;
    field_init_cap: usize;

    generic_names:    *token.Span;
    generic_name_len: usize;
    generic_name_cap: usize;

    comptime_branches:    *decl.ComptimeBranch;
    comptime_branch_len:  usize;
    comptime_branch_cap:  usize;

    decl_ids:    *id.DeclId;
    decl_id_len: usize;
    decl_id_cap: usize;

    stmt_ids:    *id.StmtId;
    stmt_id_len: usize;
    stmt_id_cap: usize;

    expr_ids:    *id.ExprId;
    expr_id_len: usize;
    expr_id_cap: usize;

    type_ids:    *id.TypeId;
    type_id_len: usize;
    type_id_cap: usize;
}

# init: constructs an empty Ast backed by the given allocator.
# ---
# alloc:   allocator used for all arrays owned by the Ast
# file_id: identifier of the source file this Ast belongs to
# ret:     a new empty Ast
pub fun init(alloc: *Allocator, file_id: src.FileId) Ast {
    var a: Ast;
    a.alloc       = alloc;
    a.file_id     = file_id;
    a.root_module = id.MODULE_NIL;

    a.modules    = nil;
    a.module_len = 0;
    a.module_cap = 0;

    a.exprs    = nil;
    a.expr_len = 0;
    a.expr_cap = 0;

    a.stmts    = nil;
    a.stmt_len = 0;
    a.stmt_cap = 0;

    a.decls    = nil;
    a.decl_len = 0;
    a.decl_cap = 0;

    a.types    = nil;
    a.type_len = 0;
    a.type_cap = 0;

    a.typed_names    = nil;
    a.typed_name_len = 0;
    a.typed_name_cap = 0;

    a.field_inits    = nil;
    a.field_init_len = 0;
    a.field_init_cap = 0;

    a.generic_names    = nil;
    a.generic_name_len = 0;
    a.generic_name_cap = 0;

    a.comptime_branches   = nil;
    a.comptime_branch_len = 0;
    a.comptime_branch_cap = 0;

    a.decl_ids    = nil;
    a.decl_id_len = 0;
    a.decl_id_cap = 0;

    a.stmt_ids    = nil;
    a.stmt_id_len = 0;
    a.stmt_id_cap = 0;

    a.expr_ids    = nil;
    a.expr_id_len = 0;
    a.expr_id_cap = 0;

    a.type_ids    = nil;
    a.type_id_len = 0;
    a.type_id_cap = 0;

    ret a;
}

# dnit: releases every array held by the Ast and clears its fields.
# ---
# a: the Ast to tear down; all arrays are freed and counts zeroed
pub fun dnit(a: *Ast) {
    if (a == nil) { ret; }

    if (a.modules != nil && a.module_cap > 0) {
        deallocate[module.Module](a.alloc, a.modules, a.module_cap);
    }
    if (a.exprs != nil && a.expr_cap > 0) {
        deallocate[expr.Expr](a.alloc, a.exprs, a.expr_cap);
    }
    if (a.stmts != nil && a.stmt_cap > 0) {
        deallocate[stmt.Stmt](a.alloc, a.stmts, a.stmt_cap);
    }
    if (a.decls != nil && a.decl_cap > 0) {
        deallocate[decl.Decl](a.alloc, a.decls, a.decl_cap);
    }
    if (a.types != nil && a.type_cap > 0) {
        deallocate[m_type.Type](a.alloc, a.types, a.type_cap);
    }
    if (a.typed_names != nil && a.typed_name_cap > 0) {
        deallocate[decl.TypedName](a.alloc, a.typed_names, a.typed_name_cap);
    }
    if (a.field_inits != nil && a.field_init_cap > 0) {
        deallocate[expr.FieldInit](a.alloc, a.field_inits, a.field_init_cap);
    }
    if (a.generic_names != nil && a.generic_name_cap > 0) {
        deallocate[token.Span](a.alloc, a.generic_names, a.generic_name_cap);
    }
    if (a.comptime_branches != nil && a.comptime_branch_cap > 0) {
        deallocate[decl.ComptimeBranch](a.alloc, a.comptime_branches, a.comptime_branch_cap);
    }
    if (a.decl_ids != nil && a.decl_id_cap > 0) {
        deallocate[id.DeclId](a.alloc, a.decl_ids, a.decl_id_cap);
    }
    if (a.stmt_ids != nil && a.stmt_id_cap > 0) {
        deallocate[id.StmtId](a.alloc, a.stmt_ids, a.stmt_id_cap);
    }
    if (a.expr_ids != nil && a.expr_id_cap > 0) {
        deallocate[id.ExprId](a.alloc, a.expr_ids, a.expr_id_cap);
    }
    if (a.type_ids != nil && a.type_id_cap > 0) {
        deallocate[id.TypeId](a.alloc, a.type_ids, a.type_id_cap);
    }

    a.modules    = nil;
    a.module_len = 0;
    a.module_cap = 0;

    a.exprs    = nil;
    a.expr_len = 0;
    a.expr_cap = 0;

    a.stmts    = nil;
    a.stmt_len = 0;
    a.stmt_cap = 0;

    a.decls    = nil;
    a.decl_len = 0;
    a.decl_cap = 0;

    a.types    = nil;
    a.type_len = 0;
    a.type_cap = 0;

    a.typed_names    = nil;
    a.typed_name_len = 0;
    a.typed_name_cap = 0;

    a.field_inits    = nil;
    a.field_init_len = 0;
    a.field_init_cap = 0;

    a.generic_names    = nil;
    a.generic_name_len = 0;
    a.generic_name_cap = 0;

    a.comptime_branches   = nil;
    a.comptime_branch_len = 0;
    a.comptime_branch_cap = 0;

    a.decl_ids    = nil;
    a.decl_id_len = 0;
    a.decl_id_cap = 0;

    a.stmt_ids    = nil;
    a.stmt_id_len = 0;
    a.stmt_id_cap = 0;

    a.expr_ids    = nil;
    a.expr_id_len = 0;
    a.expr_id_cap = 0;

    a.type_ids    = nil;
    a.type_id_len = 0;
    a.type_id_cap = 0;

    a.root_module = id.MODULE_NIL;
}

# add_module: appends a Module to the Ast.
# ---
# a:   target Ast
# m:   module to append
# ret: ModuleId of the newly added node
pub fun add_module(a: *Ast, m: module.Module) Result[id.ModuleId, str] {
    if (a.modules == nil) {
        val r: Result[*module.Module, str] = allocate[module.Module](a.alloc, INITIAL_NODE_CAP);
        if (is_err[*module.Module, str](r)) {
            ret err[id.ModuleId, str](unwrap_err[*module.Module, str](r));
        }
        a.modules    = unwrap_ok[*module.Module, str](r);
        a.module_cap = INITIAL_NODE_CAP;
    }
    or (a.module_len == a.module_cap) {
        val new_cap: usize = a.module_cap * 2;
        val r: Result[*module.Module, str] = reallocate[module.Module](a.alloc, a.modules, a.module_cap, new_cap);
        if (is_err[*module.Module, str](r)) {
            ret err[id.ModuleId, str](unwrap_err[*module.Module, str](r));
        }
        a.modules    = unwrap_ok[*module.Module, str](r);
        a.module_cap = new_cap;
    }
    val new_id: id.ModuleId = a.module_len::u32;
    a.modules[a.module_len] = m;
    a.module_len = a.module_len + 1;
    ret ok[id.ModuleId, str](new_id);
}

# get_module: returns a pointer to the Module with the given ModuleId, or none when id_ is out of range.
# ---
# a:   the Ast
# id_: ModuleId to look up
# ret: some(*Module) into a.modules (invalidated by a later add_module that grows the array), or none
pub fun get_module(a: *Ast, id_: id.ModuleId) Option[*module.Module] {
    if (id_::usize >= a.module_len) { ret none[*module.Module](); }
    ret some[*module.Module](?a.modules[id_]);
}

# add_expr: appends an Expr to the Ast.
# ---
# a:   target Ast
# e:   expression to append
# ret: ExprId of the newly added node
pub fun add_expr(a: *Ast, e: expr.Expr) Result[id.ExprId, str] {
    if (a.exprs == nil) {
        val r: Result[*expr.Expr, str] = allocate[expr.Expr](a.alloc, INITIAL_NODE_CAP);
        if (is_err[*expr.Expr, str](r)) {
            ret err[id.ExprId, str](unwrap_err[*expr.Expr, str](r));
        }
        a.exprs    = unwrap_ok[*expr.Expr, str](r);
        a.expr_cap = INITIAL_NODE_CAP;
    }
    or (a.expr_len == a.expr_cap) {
        val new_cap: usize = a.expr_cap * 2;
        val r: Result[*expr.Expr, str] = reallocate[expr.Expr](a.alloc, a.exprs, a.expr_cap, new_cap);
        if (is_err[*expr.Expr, str](r)) {
            ret err[id.ExprId, str](unwrap_err[*expr.Expr, str](r));
        }
        a.exprs    = unwrap_ok[*expr.Expr, str](r);
        a.expr_cap = new_cap;
    }
    val new_id: id.ExprId = a.expr_len::u32;
    a.exprs[a.expr_len] = e;
    a.expr_len = a.expr_len + 1;
    ret ok[id.ExprId, str](new_id);
}

# get_expr: returns a pointer to the Expr with the given ExprId, or none when id_ is out of range.
# ---
# a:   the Ast
# id_: ExprId to look up
# ret: some(*Expr) into a.exprs (invalidated by a later add_expr that grows the array), or none
pub fun get_expr(a: *Ast, id_: id.ExprId) Option[*expr.Expr] {
    if (id_::usize >= a.expr_len) { ret none[*expr.Expr](); }
    ret some[*expr.Expr](?a.exprs[id_]);
}

# add_stmt: appends a Stmt to the Ast.
# ---
# a:   target Ast
# s:   statement to append
# ret: StmtId of the newly added node
pub fun add_stmt(a: *Ast, s: stmt.Stmt) Result[id.StmtId, str] {
    if (a.stmts == nil) {
        val r: Result[*stmt.Stmt, str] = allocate[stmt.Stmt](a.alloc, INITIAL_NODE_CAP);
        if (is_err[*stmt.Stmt, str](r)) {
            ret err[id.StmtId, str](unwrap_err[*stmt.Stmt, str](r));
        }
        a.stmts    = unwrap_ok[*stmt.Stmt, str](r);
        a.stmt_cap = INITIAL_NODE_CAP;
    }
    or (a.stmt_len == a.stmt_cap) {
        val new_cap: usize = a.stmt_cap * 2;
        val r: Result[*stmt.Stmt, str] = reallocate[stmt.Stmt](a.alloc, a.stmts, a.stmt_cap, new_cap);
        if (is_err[*stmt.Stmt, str](r)) {
            ret err[id.StmtId, str](unwrap_err[*stmt.Stmt, str](r));
        }
        a.stmts    = unwrap_ok[*stmt.Stmt, str](r);
        a.stmt_cap = new_cap;
    }
    val new_id: id.StmtId = a.stmt_len::u32;
    a.stmts[a.stmt_len] = s;
    a.stmt_len = a.stmt_len + 1;
    ret ok[id.StmtId, str](new_id);
}

# get_stmt: returns a pointer to the Stmt with the given StmtId, or none when id_ is out of range.
# ---
# a:   the Ast
# id_: StmtId to look up
# ret: some(*Stmt) into a.stmts (invalidated by a later add_stmt that grows the array), or none
pub fun get_stmt(a: *Ast, id_: id.StmtId) Option[*stmt.Stmt] {
    if (id_::usize >= a.stmt_len) { ret none[*stmt.Stmt](); }
    ret some[*stmt.Stmt](?a.stmts[id_]);
}

# add_decl: appends a Decl to the Ast.
# ---
# a:   target Ast
# d:   declaration to append
# ret: DeclId of the newly added node
pub fun add_decl(a: *Ast, d: decl.Decl) Result[id.DeclId, str] {
    if (a.decls == nil) {
        val r: Result[*decl.Decl, str] = allocate[decl.Decl](a.alloc, INITIAL_NODE_CAP);
        if (is_err[*decl.Decl, str](r)) {
            ret err[id.DeclId, str](unwrap_err[*decl.Decl, str](r));
        }
        a.decls    = unwrap_ok[*decl.Decl, str](r);
        a.decl_cap = INITIAL_NODE_CAP;
    }
    or (a.decl_len == a.decl_cap) {
        val new_cap: usize = a.decl_cap * 2;
        val r: Result[*decl.Decl, str] = reallocate[decl.Decl](a.alloc, a.decls, a.decl_cap, new_cap);
        if (is_err[*decl.Decl, str](r)) {
            ret err[id.DeclId, str](unwrap_err[*decl.Decl, str](r));
        }
        a.decls    = unwrap_ok[*decl.Decl, str](r);
        a.decl_cap = new_cap;
    }
    val new_id: id.DeclId = a.decl_len::u32;
    a.decls[a.decl_len] = d;
    a.decl_len = a.decl_len + 1;
    ret ok[id.DeclId, str](new_id);
}

# get_decl: returns a pointer to the Decl with the given DeclId, or none when id_ is out of range.
# ---
# a:   the Ast
# id_: DeclId to look up
# ret: some(*Decl) into a.decls (invalidated by a later add_decl that grows the array), or none
pub fun get_decl(a: *Ast, id_: id.DeclId) Option[*decl.Decl] {
    if (id_::usize >= a.decl_len) { ret none[*decl.Decl](); }
    ret some[*decl.Decl](?a.decls[id_]);
}

# add_type: appends a Type to the Ast.
# ---
# a:   target Ast
# t:   type to append
# ret: TypeId of the newly added node
pub fun add_type(a: *Ast, t: m_type.Type) Result[id.TypeId, str] {
    if (a.types == nil) {
        val r: Result[*m_type.Type, str] = allocate[m_type.Type](a.alloc, INITIAL_NODE_CAP);
        if (is_err[*m_type.Type, str](r)) {
            ret err[id.TypeId, str](unwrap_err[*m_type.Type, str](r));
        }
        a.types    = unwrap_ok[*m_type.Type, str](r);
        a.type_cap = INITIAL_NODE_CAP;
    }
    or (a.type_len == a.type_cap) {
        val new_cap: usize = a.type_cap * 2;
        val r: Result[*m_type.Type, str] = reallocate[m_type.Type](a.alloc, a.types, a.type_cap, new_cap);
        if (is_err[*m_type.Type, str](r)) {
            ret err[id.TypeId, str](unwrap_err[*m_type.Type, str](r));
        }
        a.types    = unwrap_ok[*m_type.Type, str](r);
        a.type_cap = new_cap;
    }
    val new_id: id.TypeId = a.type_len::u32;
    a.types[a.type_len] = t;
    a.type_len = a.type_len + 1;
    ret ok[id.TypeId, str](new_id);
}

# get_type: returns a pointer to the syntactic Type with the given TypeId, or none when id_ is out of range.
# ---
# a:   the Ast
# id_: TypeId to look up
# ret: some(*Type) into a.types (invalidated by a later add_type that grows the array), or none
pub fun get_type(a: *Ast, id_: id.TypeId) Option[*m_type.Type] {
    if (id_::usize >= a.type_len) { ret none[*m_type.Type](); }
    ret some[*m_type.Type](?a.types[id_]);
}

# add_typed_name: appends a TypedName to the shared pool.
# ---
# a:   target Ast
# tn:  entry to append (parameter or field)
# ret: index into a.typed_names for the new entry
pub fun add_typed_name(a: *Ast, tn: decl.TypedName) Result[u32, str] {
    if (a.typed_names == nil) {
        val r: Result[*decl.TypedName, str] = allocate[decl.TypedName](a.alloc, INITIAL_AUX_CAP);
        if (is_err[*decl.TypedName, str](r)) {
            ret err[u32, str](unwrap_err[*decl.TypedName, str](r));
        }
        a.typed_names    = unwrap_ok[*decl.TypedName, str](r);
        a.typed_name_cap = INITIAL_AUX_CAP;
    }
    or (a.typed_name_len == a.typed_name_cap) {
        val new_cap: usize = a.typed_name_cap * 2;
        val r: Result[*decl.TypedName, str] = reallocate[decl.TypedName](a.alloc, a.typed_names, a.typed_name_cap, new_cap);
        if (is_err[*decl.TypedName, str](r)) {
            ret err[u32, str](unwrap_err[*decl.TypedName, str](r));
        }
        a.typed_names    = unwrap_ok[*decl.TypedName, str](r);
        a.typed_name_cap = new_cap;
    }
    val index: u32 = a.typed_name_len::u32;
    a.typed_names[a.typed_name_len] = tn;
    a.typed_name_len = a.typed_name_len + 1;
    ret ok[u32, str](index);
}

# add_field_init: appends a FieldInit to the shared pool.
# ---
# a:   target Ast
# fi:  field initializer to append
# ret: index into a.field_inits for the new entry
pub fun add_field_init(a: *Ast, fi: expr.FieldInit) Result[u32, str] {
    if (a.field_inits == nil) {
        val r: Result[*expr.FieldInit, str] = allocate[expr.FieldInit](a.alloc, INITIAL_AUX_CAP);
        if (is_err[*expr.FieldInit, str](r)) {
            ret err[u32, str](unwrap_err[*expr.FieldInit, str](r));
        }
        a.field_inits    = unwrap_ok[*expr.FieldInit, str](r);
        a.field_init_cap = INITIAL_AUX_CAP;
    }
    or (a.field_init_len == a.field_init_cap) {
        val new_cap: usize = a.field_init_cap * 2;
        val r: Result[*expr.FieldInit, str] = reallocate[expr.FieldInit](a.alloc, a.field_inits, a.field_init_cap, new_cap);
        if (is_err[*expr.FieldInit, str](r)) {
            ret err[u32, str](unwrap_err[*expr.FieldInit, str](r));
        }
        a.field_inits    = unwrap_ok[*expr.FieldInit, str](r);
        a.field_init_cap = new_cap;
    }
    val index: u32 = a.field_init_len::u32;
    a.field_inits[a.field_init_len] = fi;
    a.field_init_len = a.field_init_len + 1;
    ret ok[u32, str](index);
}

# add_generic_name: appends a generic parameter name to the shared pool.
# ---
# a:    target Ast
# name: span of the generic parameter identifier
# ret:  index into a.generic_names for the new entry
pub fun add_generic_name(a: *Ast, name: token.Span) Result[u32, str] {
    if (a.generic_names == nil) {
        val r: Result[*token.Span, str] = allocate[token.Span](a.alloc, INITIAL_AUX_CAP);
        if (is_err[*token.Span, str](r)) {
            ret err[u32, str](unwrap_err[*token.Span, str](r));
        }
        a.generic_names    = unwrap_ok[*token.Span, str](r);
        a.generic_name_cap = INITIAL_AUX_CAP;
    }
    or (a.generic_name_len == a.generic_name_cap) {
        val new_cap: usize = a.generic_name_cap * 2;
        val r: Result[*token.Span, str] = reallocate[token.Span](a.alloc, a.generic_names, a.generic_name_cap, new_cap);
        if (is_err[*token.Span, str](r)) {
            ret err[u32, str](unwrap_err[*token.Span, str](r));
        }
        a.generic_names    = unwrap_ok[*token.Span, str](r);
        a.generic_name_cap = new_cap;
    }
    val index: u32 = a.generic_name_len::u32;
    a.generic_names[a.generic_name_len] = name;
    a.generic_name_len = a.generic_name_len + 1;
    ret ok[u32, str](index);
}

# add_comptime_branch: appends a ComptimeBranch to the shared pool.
# ---
# a:   target Ast
# br:  branch record to append
# ret: index into a.comptime_branches for the new entry
pub fun add_comptime_branch(a: *Ast, br: decl.ComptimeBranch) Result[u32, str] {
    if (a.comptime_branches == nil) {
        val r: Result[*decl.ComptimeBranch, str] = allocate[decl.ComptimeBranch](a.alloc, INITIAL_AUX_CAP);
        if (is_err[*decl.ComptimeBranch, str](r)) {
            ret err[u32, str](unwrap_err[*decl.ComptimeBranch, str](r));
        }
        a.comptime_branches   = unwrap_ok[*decl.ComptimeBranch, str](r);
        a.comptime_branch_cap = INITIAL_AUX_CAP;
    }
    or (a.comptime_branch_len == a.comptime_branch_cap) {
        val new_cap: usize = a.comptime_branch_cap * 2;
        val r: Result[*decl.ComptimeBranch, str] = reallocate[decl.ComptimeBranch](a.alloc, a.comptime_branches, a.comptime_branch_cap, new_cap);
        if (is_err[*decl.ComptimeBranch, str](r)) {
            ret err[u32, str](unwrap_err[*decl.ComptimeBranch, str](r));
        }
        a.comptime_branches   = unwrap_ok[*decl.ComptimeBranch, str](r);
        a.comptime_branch_cap = new_cap;
    }
    val index: u32 = a.comptime_branch_len::u32;
    a.comptime_branches[a.comptime_branch_len] = br;
    a.comptime_branch_len = a.comptime_branch_len + 1;
    ret ok[u32, str](index);
}

