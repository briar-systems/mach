# the per-module AST container
#
# Owns every node array (modules, exprs, stmts, decls, types) plus typed side
# pools for variable-length payloads (decl_ids, stmt_ids, expr_ids, type_ids,
# typed_names, field_inits, generic_names, comptime_branches).

use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.module;
use mach.lang.fe.ast.stmt;
use mach.lang.fe.ast.type;
use mach.lang.fe.pool;
use mach.lang.fe.token;
use mach.lang.source;

# the root AST container for one parsed source file
# ---
# a:                   allocator used for all owned storage
# file_id:             identifier of the source file this AST was parsed from
# root_module:         ModuleId of the top-level Module, or MODULE_NIL before parsing completes
# modules:             Module array
# module_len:          number of Modules stored
# module_cap:          allocated slots in modules
# exprs:               Expr array
# expr_len:            number of Exprs stored
# expr_cap:            allocated slots in exprs
# stmts:               Stmt array
# stmt_len:            number of Stmts stored
# stmt_cap:            allocated slots in stmts
# decls:               Decl array
# decl_len:            number of Decls stored
# decl_cap:            allocated slots in decls
# types:               Type array
# type_len:            number of Types stored
# type_cap:            allocated slots in types
# typed_names:         shared pool used by DeclFun parameters and DeclRec fields
# typed_name_len:      number of TypedNames stored
# typed_name_cap:      allocated slots in typed_names
# field_inits:         shared pool used by ExprStructLit
# field_init_len:      number of FieldInits stored
# field_init_cap:      allocated slots in field_inits
# generic_names:       pool of Spans used by DeclFun and DeclRec generic parameters
# generic_name_len:    number of generic names stored
# generic_name_cap:    allocated slots in generic_names
# comptime_branches:   pool of ComptimeBranch records referenced by DeclComptimeIf and StmtComptimeIf
# comptime_branch_len: number of branches stored
# comptime_branch_cap: allocated slots in comptime_branches
# decorators:          pool of Decorator records referenced by a Decl's leading backtick clauses
# decorator_len:       number of decorators stored
# decorator_cap:       allocated slots in decorators
# decl_ids:            typed pool of DeclIds for node-owned decl lists
# decl_id_len:         number of DeclIds stored
# decl_id_cap:         allocated slots in decl_ids
# stmt_ids:            typed pool of StmtIds for node-owned stmt lists
# stmt_id_len:         number of StmtIds stored
# stmt_id_cap:         allocated slots in stmt_ids
# expr_ids:            typed pool of ExprIds for node-owned expr lists
# expr_id_len:         number of ExprIds stored
# expr_id_cap:         allocated slots in expr_ids
# type_ids:            typed pool of TypeIds for node-owned type lists
# type_id_len:         number of TypeIds stored
# type_id_cap:         allocated slots in type_ids
pub rec Ast {
    a:           *A.Allocator;
    file_id:     source.FileId;
    root_module: id.ModuleId;

    modules:    *module.Module;
    module_len: usize;
    module_cap: usize;

    exprs:    *expr.Expr;
    expr_len: usize;
    expr_cap: usize;

    stmts:    *stmt.Stmt;
    stmt_len: usize;
    stmt_cap: usize;

    decls:    *decl.Decl;
    decl_len: usize;
    decl_cap: usize;

    types:    *type.Type;
    type_len: usize;
    type_cap: usize;

    typed_names:    *decl.TypedName;
    typed_name_len: usize;
    typed_name_cap: usize;

    field_inits:    *expr.FieldInit;
    field_init_len: usize;
    field_init_cap: usize;

    generic_names:    *token.Span;
    generic_name_len: usize;
    generic_name_cap: usize;

    comptime_branches:    *decl.ComptimeBranch;
    comptime_branch_len:  usize;
    comptime_branch_cap:  usize;

    decorators:    *decl.Decorator;
    decorator_len: usize;
    decorator_cap: usize;

    decl_ids:    *id.DeclId;
    decl_id_len: usize;
    decl_id_cap: usize;

    stmt_ids:    *id.StmtId;
    stmt_id_len: usize;
    stmt_id_cap: usize;

    expr_ids:    *id.ExprId;
    expr_id_len: usize;
    expr_id_cap: usize;

    type_ids:    *id.TypeId;
    type_id_len: usize;
    type_id_cap: usize;
}

# initial capacities for the AST's growable backing arrays
val INITIAL_NODE_CAP:    usize = 32;
val INITIAL_AUX_CAP:     usize = 16;
val INITIAL_ID_POOL_CAP: usize = 64;

# construct an empty Ast backed by the given allocator
# ---
# a:       allocator used for all arrays owned by the Ast
# file_id: identifier of the source file this Ast belongs to
# ret:     a new empty Ast
pub fun init(a: *A.Allocator, file_id: source.FileId) Ast {
    var ast: Ast;
    ast.a           = a;
    ast.file_id     = file_id;
    ast.root_module = id.MODULE_NIL;

    ast.modules    = nil;
    ast.module_len = 0;
    ast.module_cap = 0;

    ast.exprs    = nil;
    ast.expr_len = 0;
    ast.expr_cap = 0;

    ast.stmts    = nil;
    ast.stmt_len = 0;
    ast.stmt_cap = 0;

    ast.decls    = nil;
    ast.decl_len = 0;
    ast.decl_cap = 0;

    ast.types    = nil;
    ast.type_len = 0;
    ast.type_cap = 0;

    ast.typed_names    = nil;
    ast.typed_name_len = 0;
    ast.typed_name_cap = 0;

    ast.field_inits    = nil;
    ast.field_init_len = 0;
    ast.field_init_cap = 0;

    ast.generic_names    = nil;
    ast.generic_name_len = 0;
    ast.generic_name_cap = 0;

    ast.comptime_branches   = nil;
    ast.comptime_branch_len = 0;
    ast.comptime_branch_cap = 0;

    ast.decorators    = nil;
    ast.decorator_len = 0;
    ast.decorator_cap = 0;

    ast.decl_ids    = nil;
    ast.decl_id_len = 0;
    ast.decl_id_cap = 0;

    ast.stmt_ids    = nil;
    ast.stmt_id_len = 0;
    ast.stmt_id_cap = 0;

    ast.expr_ids    = nil;
    ast.expr_id_len = 0;
    ast.expr_id_cap = 0;

    ast.type_ids    = nil;
    ast.type_id_len = 0;
    ast.type_id_cap = 0;

    ret ast;
}

# release every array held by the Ast and clear its fields
# ---
# a: the Ast to tear down; all arrays are freed and counts zeroed
pub fun dnit(a: *Ast) {
    if (a == nil) { ret; }

    if (a.modules != nil && a.module_cap > 0) {
        A.deallocate[module.Module](a.a, a.modules, a.module_cap);
    }
    if (a.exprs != nil && a.expr_cap > 0) {
        A.deallocate[expr.Expr](a.a, a.exprs, a.expr_cap);
    }
    if (a.stmts != nil && a.stmt_cap > 0) {
        A.deallocate[stmt.Stmt](a.a, a.stmts, a.stmt_cap);
    }
    if (a.decls != nil && a.decl_cap > 0) {
        A.deallocate[decl.Decl](a.a, a.decls, a.decl_cap);
    }
    if (a.types != nil && a.type_cap > 0) {
        A.deallocate[type.Type](a.a, a.types, a.type_cap);
    }
    if (a.typed_names != nil && a.typed_name_cap > 0) {
        A.deallocate[decl.TypedName](a.a, a.typed_names, a.typed_name_cap);
    }
    if (a.field_inits != nil && a.field_init_cap > 0) {
        A.deallocate[expr.FieldInit](a.a, a.field_inits, a.field_init_cap);
    }
    if (a.generic_names != nil && a.generic_name_cap > 0) {
        A.deallocate[token.Span](a.a, a.generic_names, a.generic_name_cap);
    }
    if (a.comptime_branches != nil && a.comptime_branch_cap > 0) {
        A.deallocate[decl.ComptimeBranch](a.a, a.comptime_branches, a.comptime_branch_cap);
    }
    if (a.decorators != nil && a.decorator_cap > 0) {
        A.deallocate[decl.Decorator](a.a, a.decorators, a.decorator_cap);
    }
    if (a.decl_ids != nil && a.decl_id_cap > 0) {
        A.deallocate[id.DeclId](a.a, a.decl_ids, a.decl_id_cap);
    }
    if (a.stmt_ids != nil && a.stmt_id_cap > 0) {
        A.deallocate[id.StmtId](a.a, a.stmt_ids, a.stmt_id_cap);
    }
    if (a.expr_ids != nil && a.expr_id_cap > 0) {
        A.deallocate[id.ExprId](a.a, a.expr_ids, a.expr_id_cap);
    }
    if (a.type_ids != nil && a.type_id_cap > 0) {
        A.deallocate[id.TypeId](a.a, a.type_ids, a.type_id_cap);
    }

    a.modules    = nil;
    a.module_len = 0;
    a.module_cap = 0;

    a.exprs    = nil;
    a.expr_len = 0;
    a.expr_cap = 0;

    a.stmts    = nil;
    a.stmt_len = 0;
    a.stmt_cap = 0;

    a.decls    = nil;
    a.decl_len = 0;
    a.decl_cap = 0;

    a.types    = nil;
    a.type_len = 0;
    a.type_cap = 0;

    a.typed_names    = nil;
    a.typed_name_len = 0;
    a.typed_name_cap = 0;

    a.field_inits    = nil;
    a.field_init_len = 0;
    a.field_init_cap = 0;

    a.generic_names    = nil;
    a.generic_name_len = 0;
    a.generic_name_cap = 0;

    a.comptime_branches   = nil;
    a.comptime_branch_len = 0;
    a.comptime_branch_cap = 0;

    a.decorators    = nil;
    a.decorator_len = 0;
    a.decorator_cap = 0;

    a.decl_ids    = nil;
    a.decl_id_len = 0;
    a.decl_id_cap = 0;

    a.stmt_ids    = nil;
    a.stmt_id_len = 0;
    a.stmt_id_cap = 0;

    a.expr_ids    = nil;
    a.expr_id_len = 0;
    a.expr_id_cap = 0;

    a.type_ids    = nil;
    a.type_id_len = 0;
    a.type_id_cap = 0;

    a.root_module = id.MODULE_NIL;
}

# append a Module to the Ast
# ---
# a:   target Ast
# m:   module to append
# ret: ModuleId of the newly added node
pub fun add_module(a: *Ast, m: module.Module) R.Result[id.ModuleId, str] {
    if (a.module_len == a.module_cap) {
        val res_modules: R.Result[*module.Module, str] = pool.grow[module.Module](a.a, a.modules, a.module_cap, INITIAL_NODE_CAP, ?a.module_cap);
        if (R.is_err[*module.Module, str](res_modules)) {
            ret R.err[id.ModuleId, str](R.unwrap_err[*module.Module, str](res_modules));
        }
        a.modules = R.unwrap_ok[*module.Module, str](res_modules);
    }
    val new_id: id.ModuleId = a.module_len::u32;
    a.modules[a.module_len] = m;
    a.module_len = a.module_len + 1;
    ret R.ok[id.ModuleId, str](new_id);
}

# return a pointer to the Module with the given ModuleId, or none when id_ is
# out of range
# ---
# a:   the Ast
# id_: ModuleId to look up
# ret: some(*Module) into a.modules (invalidated by a later add_module that grows the array), or none
pub fun get_module(a: *Ast, id_: id.ModuleId) O.Option[*module.Module] {
    if (id_::usize >= a.module_len) { ret O.none[*module.Module](); }
    ret O.some[*module.Module](?a.modules[id_]);
}

# append an Expr to the Ast
# ---
# a:   target Ast
# e:   expression to append
# ret: ExprId of the newly added node
pub fun add_expr(a: *Ast, e: expr.Expr) R.Result[id.ExprId, str] {
    if (a.expr_len == a.expr_cap) {
        val res_exprs: R.Result[*expr.Expr, str] = pool.grow[expr.Expr](a.a, a.exprs, a.expr_cap, INITIAL_NODE_CAP, ?a.expr_cap);
        if (R.is_err[*expr.Expr, str](res_exprs)) {
            ret R.err[id.ExprId, str](R.unwrap_err[*expr.Expr, str](res_exprs));
        }
        a.exprs = R.unwrap_ok[*expr.Expr, str](res_exprs);
    }
    val new_id: id.ExprId = a.expr_len::u32;
    a.exprs[a.expr_len] = e;
    a.expr_len = a.expr_len + 1;
    ret R.ok[id.ExprId, str](new_id);
}

# return a pointer to the Expr with the given ExprId, or none when id_ is out of
# range
# ---
# a:   the Ast
# id_: ExprId to look up
# ret: some(*Expr) into a.exprs (invalidated by a later add_expr that grows the array), or none
pub fun get_expr(a: *Ast, id_: id.ExprId) O.Option[*expr.Expr] {
    if (id_::usize >= a.expr_len) { ret O.none[*expr.Expr](); }
    ret O.some[*expr.Expr](?a.exprs[id_]);
}

# append a Stmt to the Ast
# ---
# a:   target Ast
# s:   statement to append
# ret: StmtId of the newly added node
pub fun add_stmt(a: *Ast, s: stmt.Stmt) R.Result[id.StmtId, str] {
    if (a.stmt_len == a.stmt_cap) {
        val res_stmts: R.Result[*stmt.Stmt, str] = pool.grow[stmt.Stmt](a.a, a.stmts, a.stmt_cap, INITIAL_NODE_CAP, ?a.stmt_cap);
        if (R.is_err[*stmt.Stmt, str](res_stmts)) {
            ret R.err[id.StmtId, str](R.unwrap_err[*stmt.Stmt, str](res_stmts));
        }
        a.stmts = R.unwrap_ok[*stmt.Stmt, str](res_stmts);
    }
    val new_id: id.StmtId = a.stmt_len::u32;
    a.stmts[a.stmt_len] = s;
    a.stmt_len = a.stmt_len + 1;
    ret R.ok[id.StmtId, str](new_id);
}

# return a pointer to the Stmt with the given StmtId, or none when id_ is out of
# range
# ---
# a:   the Ast
# id_: StmtId to look up
# ret: some(*Stmt) into a.stmts (invalidated by a later add_stmt that grows the array), or none
pub fun get_stmt(a: *Ast, id_: id.StmtId) O.Option[*stmt.Stmt] {
    if (id_::usize >= a.stmt_len) { ret O.none[*stmt.Stmt](); }
    ret O.some[*stmt.Stmt](?a.stmts[id_]);
}

# append a Decl to the Ast
# ---
# a:   target Ast
# d:   declaration to append
# ret: DeclId of the newly added node
pub fun add_decl(a: *Ast, d: decl.Decl) R.Result[id.DeclId, str] {
    if (a.decl_len == a.decl_cap) {
        val res_decls: R.Result[*decl.Decl, str] = pool.grow[decl.Decl](a.a, a.decls, a.decl_cap, INITIAL_NODE_CAP, ?a.decl_cap);
        if (R.is_err[*decl.Decl, str](res_decls)) {
            ret R.err[id.DeclId, str](R.unwrap_err[*decl.Decl, str](res_decls));
        }
        a.decls = R.unwrap_ok[*decl.Decl, str](res_decls);
    }
    val new_id: id.DeclId = a.decl_len::u32;
    a.decls[a.decl_len] = d;
    a.decl_len = a.decl_len + 1;
    ret R.ok[id.DeclId, str](new_id);
}

# return a pointer to the Decl with the given DeclId, or none when id_ is out of
# range
# ---
# a:   the Ast
# id_: DeclId to look up
# ret: some(*Decl) into a.decls (invalidated by a later add_decl that grows the array), or none
pub fun get_decl(a: *Ast, id_: id.DeclId) O.Option[*decl.Decl] {
    if (id_::usize >= a.decl_len) { ret O.none[*decl.Decl](); }
    ret O.some[*decl.Decl](?a.decls[id_]);
}

# append a Type to the Ast
# ---
# a:   target Ast
# t:   type to append
# ret: TypeId of the newly added node
pub fun add_type(a: *Ast, t: type.Type) R.Result[id.TypeId, str] {
    if (a.type_len == a.type_cap) {
        val res_types: R.Result[*type.Type, str] = pool.grow[type.Type](a.a, a.types, a.type_cap, INITIAL_NODE_CAP, ?a.type_cap);
        if (R.is_err[*type.Type, str](res_types)) {
            ret R.err[id.TypeId, str](R.unwrap_err[*type.Type, str](res_types));
        }
        a.types = R.unwrap_ok[*type.Type, str](res_types);
    }
    val new_id: id.TypeId = a.type_len::u32;
    a.types[a.type_len] = t;
    a.type_len = a.type_len + 1;
    ret R.ok[id.TypeId, str](new_id);
}

# return a pointer to the syntactic Type with the given TypeId, or none when
# id_ is out of range
# ---
# a:   the Ast
# id_: TypeId to look up
# ret: some(*Type) into a.types (invalidated by a later add_type that grows the array), or none
pub fun get_type(a: *Ast, id_: id.TypeId) O.Option[*type.Type] {
    if (id_::usize >= a.type_len) { ret O.none[*type.Type](); }
    ret O.some[*type.Type](?a.types[id_]);
}

# append a TypedName to the shared pool
# ---
# a:   target Ast
# tn:  entry to append (parameter or field)
# ret: index into a.typed_names for the new entry
pub fun add_typed_name(a: *Ast, tn: decl.TypedName) R.Result[u32, str] {
    if (a.typed_name_len == a.typed_name_cap) {
        val res_typed_names: R.Result[*decl.TypedName, str] = pool.grow[decl.TypedName](a.a, a.typed_names, a.typed_name_cap, INITIAL_AUX_CAP, ?a.typed_name_cap);
        if (R.is_err[*decl.TypedName, str](res_typed_names)) {
            ret R.err[u32, str](R.unwrap_err[*decl.TypedName, str](res_typed_names));
        }
        a.typed_names = R.unwrap_ok[*decl.TypedName, str](res_typed_names);
    }
    val index: u32 = a.typed_name_len::u32;
    a.typed_names[a.typed_name_len] = tn;
    a.typed_name_len = a.typed_name_len + 1;
    ret R.ok[u32, str](index);
}

# append a FieldInit to the shared pool
# ---
# a:   target Ast
# fi:  field initializer to append
# ret: index into a.field_inits for the new entry
pub fun add_field_init(a: *Ast, fi: expr.FieldInit) R.Result[u32, str] {
    if (a.field_init_len == a.field_init_cap) {
        val res_field_inits: R.Result[*expr.FieldInit, str] = pool.grow[expr.FieldInit](a.a, a.field_inits, a.field_init_cap, INITIAL_AUX_CAP, ?a.field_init_cap);
        if (R.is_err[*expr.FieldInit, str](res_field_inits)) {
            ret R.err[u32, str](R.unwrap_err[*expr.FieldInit, str](res_field_inits));
        }
        a.field_inits = R.unwrap_ok[*expr.FieldInit, str](res_field_inits);
    }
    val index: u32 = a.field_init_len::u32;
    a.field_inits[a.field_init_len] = fi;
    a.field_init_len = a.field_init_len + 1;
    ret R.ok[u32, str](index);
}

# append a generic parameter name to the shared pool
# ---
# a:    target Ast
# name: span of the generic parameter identifier
# ret:  index into a.generic_names for the new entry
pub fun add_generic_name(a: *Ast, name: token.Span) R.Result[u32, str] {
    if (a.generic_name_len == a.generic_name_cap) {
        val res_generic_names: R.Result[*token.Span, str] = pool.grow[token.Span](a.a, a.generic_names, a.generic_name_cap, INITIAL_AUX_CAP, ?a.generic_name_cap);
        if (R.is_err[*token.Span, str](res_generic_names)) {
            ret R.err[u32, str](R.unwrap_err[*token.Span, str](res_generic_names));
        }
        a.generic_names = R.unwrap_ok[*token.Span, str](res_generic_names);
    }
    val index: u32 = a.generic_name_len::u32;
    a.generic_names[a.generic_name_len] = name;
    a.generic_name_len = a.generic_name_len + 1;
    ret R.ok[u32, str](index);
}

# append a ComptimeBranch to the shared pool
# ---
# a:   target Ast
# br:  branch record to append
# ret: index into a.comptime_branches for the new entry
pub fun add_comptime_branch(a: *Ast, br: decl.ComptimeBranch) R.Result[u32, str] {
    if (a.comptime_branch_len == a.comptime_branch_cap) {
        val res_comptime_branches: R.Result[*decl.ComptimeBranch, str] = pool.grow[decl.ComptimeBranch](a.a, a.comptime_branches, a.comptime_branch_cap, INITIAL_AUX_CAP, ?a.comptime_branch_cap);
        if (R.is_err[*decl.ComptimeBranch, str](res_comptime_branches)) {
            ret R.err[u32, str](R.unwrap_err[*decl.ComptimeBranch, str](res_comptime_branches));
        }
        a.comptime_branches = R.unwrap_ok[*decl.ComptimeBranch, str](res_comptime_branches);
    }
    val index: u32 = a.comptime_branch_len::u32;
    a.comptime_branches[a.comptime_branch_len] = br;
    a.comptime_branch_len = a.comptime_branch_len + 1;
    ret R.ok[u32, str](index);
}

# append a Decorator to the shared pool
# ---
# a:   target Ast
# d:   decorator record to append
# ret: index into a.decorators for the new entry
pub fun add_decorator(a: *Ast, d: decl.Decorator) R.Result[u32, str] {
    if (a.decorator_len == a.decorator_cap) {
        val res_decorators: R.Result[*decl.Decorator, str] = pool.grow[decl.Decorator](a.a, a.decorators, a.decorator_cap, INITIAL_AUX_CAP, ?a.decorator_cap);
        if (R.is_err[*decl.Decorator, str](res_decorators)) {
            ret R.err[u32, str](R.unwrap_err[*decl.Decorator, str](res_decorators));
        }
        a.decorators = R.unwrap_ok[*decl.Decorator, str](res_decorators);
    }
    val index: u32 = a.decorator_len::u32;
    a.decorators[a.decorator_len] = d;
    a.decorator_len = a.decorator_len + 1;
    ret R.ok[u32, str](index);
}

# append a DeclId to the decl_ids pool
#
# Backs node-owned DeclId lists such as module decls and comptime-if decl-scope
# branch bodies.
# ---
# a:   target Ast
# id_: DeclId to append
# ret: index into a.decl_ids for the new entry
pub fun add_decl_id(a: *Ast, id_: id.DeclId) R.Result[u32, str] {
    if (a.decl_id_len == a.decl_id_cap) {
        val res_decl_ids: R.Result[*id.DeclId, str] = pool.grow[id.DeclId](a.a, a.decl_ids, a.decl_id_cap, INITIAL_ID_POOL_CAP, ?a.decl_id_cap);
        if (R.is_err[*id.DeclId, str](res_decl_ids)) {
            ret R.err[u32, str](R.unwrap_err[*id.DeclId, str](res_decl_ids));
        }
        a.decl_ids = R.unwrap_ok[*id.DeclId, str](res_decl_ids);
    }
    val index: u32 = a.decl_id_len::u32;
    a.decl_ids[a.decl_id_len] = id_;
    a.decl_id_len = a.decl_id_len + 1;
    ret R.ok[u32, str](index);
}

# append a StmtId to the stmt_ids pool
#
# Backs node-owned StmtId lists such as block bodies and comptime-if stmt-scope
# branch bodies.
# ---
# a:   target Ast
# id_: StmtId to append
# ret: index into a.stmt_ids for the new entry
pub fun add_stmt_id(a: *Ast, id_: id.StmtId) R.Result[u32, str] {
    if (a.stmt_id_len == a.stmt_id_cap) {
        val res_stmt_ids: R.Result[*id.StmtId, str] = pool.grow[id.StmtId](a.a, a.stmt_ids, a.stmt_id_cap, INITIAL_ID_POOL_CAP, ?a.stmt_id_cap);
        if (R.is_err[*id.StmtId, str](res_stmt_ids)) {
            ret R.err[u32, str](R.unwrap_err[*id.StmtId, str](res_stmt_ids));
        }
        a.stmt_ids = R.unwrap_ok[*id.StmtId, str](res_stmt_ids);
    }
    val index: u32 = a.stmt_id_len::u32;
    a.stmt_ids[a.stmt_id_len] = id_;
    a.stmt_id_len = a.stmt_id_len + 1;
    ret R.ok[u32, str](index);
}

# append an ExprId to the expr_ids pool
#
# Backs node-owned ExprId lists such as call arguments and array-literal
# elements.
# ---
# a:   target Ast
# id_: ExprId to append
# ret: index into a.expr_ids for the new entry
pub fun add_expr_id(a: *Ast, id_: id.ExprId) R.Result[u32, str] {
    if (a.expr_id_len == a.expr_id_cap) {
        val res_expr_ids: R.Result[*id.ExprId, str] = pool.grow[id.ExprId](a.a, a.expr_ids, a.expr_id_cap, INITIAL_ID_POOL_CAP, ?a.expr_id_cap);
        if (R.is_err[*id.ExprId, str](res_expr_ids)) {
            ret R.err[u32, str](R.unwrap_err[*id.ExprId, str](res_expr_ids));
        }
        a.expr_ids = R.unwrap_ok[*id.ExprId, str](res_expr_ids);
    }
    val index: u32 = a.expr_id_len::u32;
    a.expr_ids[a.expr_id_len] = id_;
    a.expr_id_len = a.expr_id_len + 1;
    ret R.ok[u32, str](index);
}

# append a TypeId to the type_ids pool
#
# Backs node-owned TypeId lists such as generic argument lists and function
# parameter type lists.
# ---
# a:   target Ast
# id_: TypeId to append
# ret: index into a.type_ids for the new entry
pub fun add_type_id(a: *Ast, id_: id.TypeId) R.Result[u32, str] {
    if (a.type_id_len == a.type_id_cap) {
        val res_type_ids: R.Result[*id.TypeId, str] = pool.grow[id.TypeId](a.a, a.type_ids, a.type_id_cap, INITIAL_ID_POOL_CAP, ?a.type_id_cap);
        if (R.is_err[*id.TypeId, str](res_type_ids)) {
            ret R.err[u32, str](R.unwrap_err[*id.TypeId, str](res_type_ids));
        }
        a.type_ids = R.unwrap_ok[*id.TypeId, str](res_type_ids);
    }
    val index: u32 = a.type_id_len::u32;
    a.type_ids[a.type_id_len] = id_;
    a.type_id_len = a.type_id_len + 1;
    ret R.ok[u32, str](index);
}

# report whether a span covers a byte offset
#
# Treats the span as the half-open range [offset, offset + len). A zero-length
# span covers nothing.
# ---
# span:   the byte range to test
# offset: byte offset into the source text
# ret:    true when offset falls inside the span
pub fun span_contains(span: token.Span, offset: usize) bool {
    if (span.len == 0)        { ret false; }
    if (offset < span.offset) { ret false; }
    ret offset < span.offset + span.len;
}

# the tightest Expr whose span covers `offset`, or EXPR_NIL when no expression
# node contains it
#
# "Tightest" means the smallest-length enclosing span, so a nested expression
# wins over its parent; ties resolve to the later (higher-id) node, which is the
# more deeply nested one under the parser's bottom-up construction order. Drives
# hover / go-to-def by byte position over the resolve side tables.
# ---
# a:      the Ast to scan
# offset: byte offset into the Ast's source file
# ret:    the enclosing ExprId, or id.EXPR_NIL when none covers offset
pub fun offset_to_expr(a: *Ast, offset: usize) id.ExprId {
    var best:     id.ExprId = id.EXPR_NIL;
    var best_len: usize     = 0;
    var i:        usize     = 0;
    for (i < a.expr_len) {
        val sp: token.Span = a.exprs[i].span;
        if (span_contains(sp, offset)) {
            if (best == id.EXPR_NIL || sp.len <= best_len) {
                best = i::id.ExprId;
                best_len = sp.len;
            }
        }
        i = i + 1;
    }
    ret best;
}

# the tightest Stmt whose span covers `offset`, or STMT_NIL when no statement
# node contains it
#
# See offset_to_expr for the tie rule.
# ---
# a:      the Ast to scan
# offset: byte offset into the Ast's source file
# ret:    the enclosing StmtId, or id.STMT_NIL when none covers offset
pub fun offset_to_stmt(a: *Ast, offset: usize) id.StmtId {
    var best:     id.StmtId = id.STMT_NIL;
    var best_len: usize     = 0;
    var i:        usize     = 0;
    for (i < a.stmt_len) {
        val sp: token.Span = a.stmts[i].span;
        if (span_contains(sp, offset)) {
            if (best == id.STMT_NIL || sp.len <= best_len) {
                best = i::id.StmtId;
                best_len = sp.len;
            }
        }
        i = i + 1;
    }
    ret best;
}

# the tightest Decl whose span covers `offset`, or DECL_NIL when no declaration
# node contains it
#
# See offset_to_expr for the tie rule.
# ---
# a:      the Ast to scan
# offset: byte offset into the Ast's source file
# ret:    the enclosing DeclId, or id.DECL_NIL when none covers offset
pub fun offset_to_decl(a: *Ast, offset: usize) id.DeclId {
    var best:     id.DeclId = id.DECL_NIL;
    var best_len: usize     = 0;
    var i:        usize     = 0;
    for (i < a.decl_len) {
        val sp: token.Span = a.decls[i].span;
        if (span_contains(sp, offset)) {
            if (best == id.DECL_NIL || sp.len <= best_len) {
                best = i::id.DeclId;
                best_len = sp.len;
            }
        }
        i = i + 1;
    }
    ret best;
}

# the tightest Type whose span covers `offset`, or TYPE_NIL when no type node
# contains it
#
# See offset_to_expr for the tie rule.
# ---
# a:      the Ast to scan
# offset: byte offset into the Ast's source file
# ret:    the enclosing TypeId, or id.TYPE_NIL when none covers offset
pub fun offset_to_type(a: *Ast, offset: usize) id.TypeId {
    var best:     id.TypeId = id.TYPE_NIL;
    var best_len: usize     = 0;
    var i:        usize     = 0;
    for (i < a.type_len) {
        val sp: token.Span = a.types[i].span;
        if (span_contains(sp, offset)) {
            if (best == id.TYPE_NIL || sp.len <= best_len) {
                best = i::id.TypeId;
                best_len = sp.len;
            }
        }
        i = i + 1;
    }
    ret best;
}

# build a Span from an offset and length, for the offset-lookup tests
# ---
# offset: starting byte offset of the span
# len:    length of the span in bytes
# ret:    a Span covering [offset, offset + len)
fun span_make(offset: usize, len: usize) token.Span {
    var sp: token.Span;
    sp.offset = offset;
    sp.len    = len;
    ret sp;
}

# build an IDENT Expr covering [offset, offset+len), for the tests
# ---
# offset: starting byte offset of the expression span
# len:    length of the expression span in bytes
# ret:    an IDENT Expr with the given span
fun expr_make(offset: usize, len: usize) expr.Expr {
    var e: expr.Expr;
    e.span = span_make(offset, len);
    e.kind = expr.EXPR_KIND_IDENT;
    ret e;
}

# span_contains treats the span as the half-open range [offset, offset + len)
test "mach.lang.fe.ast.span_contains:half_open" {
    val sp: token.Span = span_make(10, 3);
    if (span_contains(sp, 9))              { ret 1; }
    if (!span_contains(sp, 10))            { ret 1; }
    if (!span_contains(sp, 12))            { ret 1; }
    if (span_contains(sp, 13))             { ret 1; }
    if (span_contains(span_make(5, 0), 5)) { ret 1; }
    ret 0;
}

# a nested expression's tighter span wins over its enclosing parent
test "mach.lang.fe.ast.offset_to_expr:tightest_enclosing" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var a: Ast = init(?alloc, 0::source.FileId);

    # outer covers [0,10); inner covers [2,5); both contain offset 3.
    val res_outer: R.Result[id.ExprId, str] = add_expr(?a, expr_make(0, 10));
    if (R.is_err[id.ExprId, str](res_outer)) { dnit(?a); ret 1; }
    val res_inner: R.Result[id.ExprId, str] = add_expr(?a, expr_make(2, 3));
    if (R.is_err[id.ExprId, str](res_inner)) { dnit(?a); ret 1; }
    val inner_id: id.ExprId = R.unwrap_ok[id.ExprId, str](res_inner);
    val outer_id: id.ExprId = R.unwrap_ok[id.ExprId, str](res_outer);

    if (offset_to_expr(?a, 3) != inner_id)     { dnit(?a); ret 1; }
    if (offset_to_expr(?a, 7) != outer_id)     { dnit(?a); ret 1; }
    if (offset_to_expr(?a, 99) != id.EXPR_NIL) { dnit(?a); ret 1; }
    dnit(?a);
    ret 0;
}

# a miss in each offset-lookup family returns that family's nil sentinel
test "mach.lang.fe.ast:offset_miss_returns_nil" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var a: Ast = init(?alloc, 0::source.FileId);

    if (offset_to_expr(?a, 0) != id.EXPR_NIL) { dnit(?a); ret 1; }
    if (offset_to_stmt(?a, 0) != id.STMT_NIL) { dnit(?a); ret 1; }
    if (offset_to_decl(?a, 0) != id.DECL_NIL) { dnit(?a); ret 1; }
    if (offset_to_type(?a, 0) != id.TYPE_NIL) { dnit(?a); ret 1; }
    dnit(?a);
    ret 0;
}
