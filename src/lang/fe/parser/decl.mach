# declarations, statements, and the module-level parse entry point
#
# Decls and stmts are kept together because they are mutually recursive: function
# bodies contain stmts, local `val`/`var` stmts wrap decls, and `$if`
# conditionals appear at both scopes. This module also owns the orchestrators
# parse_module, parse_decl, and parse_stmt.

use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_region_equals;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.module;
use mach.lang.fe.ast.stmt;
use mach.lang.fe.lexer;
use mach.lang.fe.parser.expr;
use mach.lang.fe.parser.iasm;
use mach.lang.fe.parser.state;
use mach.lang.fe.token;
use src: mach.lang.source;

# parse a whole source file as a single Module
#
# Buffers the direct decls so a nested decl list (a comptime branch body parsed
# mid-stream) cannot interleave into this module's contiguous decl-id slice.
# Stores the module at p.ast.root_module before returning.
# ---
# p:   parser state positioned at the first token of the file
# ret: ModuleId of the parsed module
pub fun parse_module(p: *state.Parser) id.ModuleId {
    val start: token.Token = state.current(p);

    var buf: state.ListBuf[id.DeclId] = state.list_buf_init[id.DeclId]();

    for (!state.at_eof(p)) {
        val before: usize = p.pos;
        val d: id.DeclId = parse_decl(p);
        if (d != id.DECL_NIL) {
            state.list_buf_push[id.DeclId](p, ?buf, d);
        }
        # realign on the next real declaration boundary so a malformed decl does
        # not make every following token its own error
        if (p.panic) {
            state.sync_to_decl(p);
        }
        # guarantee forward progress even when recovery leaves us in place
        if (p.pos == before && !state.at_eof(p)) { state.advance(p); }
    }

    val end: token.Token = state.current(p);

    var decls_len:   u32 = 0;
    val decls_start: u32 = state.decl_id_buf_flush(p, ?buf, ?decls_len);

    var m: module.Module;
    m.span        = state.span_of(start.span, end.span);
    m.decls_start = decls_start;
    m.decls_len   = decls_len;

    val mid: id.ModuleId = state.push_module(p, m);
    p.ast.root_module = mid;
    ret mid;
}

# parse a single top-level declaration, including any leading `#[...]` decorators
#
# The doc-comment block and decorator range are back-patched onto the parsed decl
# after dispatch, once the decls pool is stable.
# ---
# p:   parser state positioned at the first token of the declaration
# ret: DeclId of the parsed declaration, or DECL_NIL on failure
pub fun parse_decl(p: *state.Parser) id.DeclId {
    val start: token.Token = state.current(p);

    # the doc-comment block is the comment run abutting the declaration's first
    # leading token (the `#[` opener when decorators are present, else the
    # keyword), captured before the decorators are consumed
    val doc: token.Span = lexer.doc_run_above(p.tokens, start.span.offset);

    var decorators_len:   u32 = 0;
    val decorators_start: u32 = parse_decorators(p, ?decorators_len);

    val did: id.DeclId = parse_decl_dispatch(p, start.span);

    # back-patch the doc span and decorator range; the pointer is taken after the
    # dispatch's own appends complete, so the decls pool is stable
    if (did != id.DECL_NIL) {
        val d: *decl.Decl = O.unwrap[*decl.Decl](ast.get_decl(p.ast, did));
        d.doc              = doc;
        d.decorators_start = decorators_start;
        d.decorators_len   = decorators_len;
    }
    ret did;
}

# dispatch on the leading `$` or keyword to the matching declaration parser,
# reporting an error and yielding an ERROR decl when none matches
# ---
# p:     parser state positioned after any decorators
# start: span of the declaration's first token (a decorator's `#[` when present)
# ret:   DeclId of the parsed declaration, or an ERROR decl's id
fun parse_decl_dispatch(p: *state.Parser, start: token.Span) id.DeclId {
    if (state.at(p, token.KIND_DOLLAR)) { ret parse_comptime_decl(p, start); }

    val flags: u8 = parse_flags(p);

    if (state.at_kw(p, token.KW_USE))  { ret parse_use_decl(p, start, flags); }
    if (state.at_kw(p, token.KW_FWD))  { ret parse_fwd_decl(p, start, flags); }
    if (state.at_kw(p, token.KW_FUN))  { ret parse_fun_decl(p, start, flags); }
    if (state.at_kw(p, token.KW_REC))  { ret parse_rec_uni_decl(p, start, flags, decl.DECL_KIND_REC, "expected record name"); }
    if (state.at_kw(p, token.KW_UNI))  { ret parse_rec_uni_decl(p, start, flags, decl.DECL_KIND_UNI, "expected union name"); }
    if (state.at_kw(p, token.KW_VAL))  { ret parse_bind_decl(p, start, flags, decl.DECL_KIND_VAL); }
    if (state.at_kw(p, token.KW_VAR))  { ret parse_bind_decl(p, start, flags, decl.DECL_KIND_VAR); }
    if (state.at_kw(p, token.KW_DEF))  { ret parse_def_decl(p, start, flags); }
    if (state.at_kw(p, token.KW_TEST)) { ret parse_test_decl(p, start, flags); }

    state.error_at_current(p, "expected a declaration; valid starters: use, fwd, fun, rec, uni, val, var, def, test");
    var err: decl.Decl;
    err.span  = start;
    err.kind  = decl.DECL_KIND_ERROR;
    err.flags = flags;
    ret state.push_decl(p, err);
}

# parse zero or more leading `#[name(args)]` decorator clauses into one contiguous
# block in ast.decorators
#
# Backtick decorators (`` `name` ``) were removed in v2.4.0; a backtick at
# decorator position is diagnosed once and its clause skipped so the following
# declaration still parses with no cascade.
# ---
# p:       parser state
# out_len: receives the number of decorators parsed
# ret:     start index of the block in ast.decorators
fun parse_decorators(p: *state.Parser, out_len: *u32) u32 {
    val start: u32 = p.ast.decorator_len::u32;

    var len:      u32  = 0;
    var reported: bool = false;
    for (state.at(p, token.KIND_ATTR_OPEN) || state.at(p, token.KIND_BACKTICK)) {
        if (state.at(p, token.KIND_BACKTICK)) {
            if (!reported) {
                state.error_at_current(p, "backtick decorators were removed in v2.4.0; use #[name(...)]");
                reported = true;
            }
            skip_backtick_decorator(p);
        }
        or {
            if (!parse_one_decorator(p)) { brk; }
            len = len + 1;
        }
    }
    @out_len = len;
    ret start;
}

# skip a removed backtick decorator clause for recovery after the v2.4.0
# migration diagnostic
#
# Consumes the opening backtick and every token through its closing backtick (or
# to end of file when unterminated), so parsing resumes at the declaration the
# clause meant to attach to.
# ---
# p: parser state positioned at the opening backtick
fun skip_backtick_decorator(p: *state.Parser) {
    state.advance(p);
    for (!state.at(p, token.KIND_BACKTICK) && !state.at_eof(p)) {
        state.advance(p);
    }
    if (state.at(p, token.KIND_BACKTICK)) { state.advance(p); }
}

# parse a single `#[name]` / `#[name(args)]` clause and append it to
# ast.decorators
#
# The directive name and any comptime-expr arguments are validated later in sema.
# ---
# p:   parser state positioned at the opening `#[`
# ret: true on success, false on a malformed clause or allocation failure
fun parse_one_decorator(p: *state.Parser) bool {
    state.advance(p);

    if (!state.at(p, token.KIND_IDENT)) {
        state.error_at_current(p, "expected attribute name after '#['");
        ret false;
    }
    val name: token.Span = state.advance(p).span;

    var args_start: u32 = 0;
    var args_len:   u32 = 0;
    if (state.at(p, token.KIND_LPAREN)) {
        args_start = parse_decorator_args(p, ?args_len);
    }

    state.expect(p, token.KIND_RBRACKET, "expected closing ']' to end attribute");

    var d: decl.Decorator;
    d.name       = name;
    d.args_start = args_start;
    d.args_len   = args_len;

    val res_add: R.Result[u32, str] = ast.add_decorator(p.ast, d);
    if (R.is_err[u32, str](res_add)) {
        state.fatal_oom_at(p, name);
        ret false;
    }
    ret true;
}

# parse `(expr, expr, ...)` decorator arguments as comptime exprs
#
# Each argument is buffered so a nested call argument cannot split the slice, then
# flushed to ast.expr_ids as one contiguous block.
# ---
# p:       parser state positioned at the opening `(`
# out_len: receives the number of arguments parsed
# ret:     start index of the block in ast.expr_ids
fun parse_decorator_args(p: *state.Parser, out_len: *u32) u32 {
    state.advance(p);

    var buf: state.ListBuf[id.ExprId] = state.list_buf_init[id.ExprId]();
    if (!state.at(p, token.KIND_RPAREN)) {
        state.list_buf_push[id.ExprId](p, ?buf, expr.parse_expr(p));
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RPAREN)) { brk; }
            state.list_buf_push[id.ExprId](p, ?buf, expr.parse_expr(p));
        }
    }
    state.expect(p, token.KIND_RPAREN, "expected ')' to close decorator arguments");

    ret state.expr_id_buf_flush(p, ?buf, out_len);
}

# parse a single statement
# ---
# p:   parser state positioned at the first token of the statement
# ret: StmtId of the parsed statement, or STMT_NIL on failure
pub fun parse_stmt(p: *state.Parser) id.StmtId {
    val start: token.Token = state.current(p);

    if (state.at(p, token.KIND_LBRACE))                 { ret parse_block_stmt(p); }
    if (state.at_kw(p, token.KW_IF))                           { ret parse_if_stmt(p, start.span); }
    if (state.at_kw(p, token.KW_FOR))                          { ret parse_for_stmt(p, start.span); }
    if (state.at_kw(p, token.KW_RET))                          { ret parse_ret_stmt(p, start.span); }
    if (at_bare_kw_stmt(p, token.KW_BRK))                      { ret parse_brk_stmt(p, start.span); }
    if (at_bare_kw_stmt(p, token.KW_CNT))                      { ret parse_cnt_stmt(p, start.span); }
    if (state.at_kw(p, token.KW_FIN))                          { ret parse_fin_stmt(p, start.span); }
    if (state.at_kw(p, token.KW_ASM))                          { ret iasm.parse_asm(p); }
    if (state.at_kw(p, token.KW_VAL) || state.at_kw(p, token.KW_VAR)) { ret parse_local_decl_stmt(p, start.span); }

    if (state.at(p, token.KIND_DOLLAR) && peek_is_kw(p, 1, token.KW_IF)) {
        ret parse_comptime_if_stmt(p, start.span);
    }
    if (state.at(p, token.KIND_DOLLAR) && peek_is_kw(p, 1, token.KW_EACH)) {
        ret parse_comptime_each_stmt(p, start.span);
    }
    if (state.at(p, token.KIND_DOLLAR) && peek_is_kw(p, 1, token.KW_ERROR)) {
        ret parse_comptime_directive_stmt(p, start.span);
    }

    ret parse_expr_stmt(p, start.span);
}

# parse a bare statement-scope comptime directive `$intrinsic(args);`
#
# Mirrors the decl-scope parse_comptime_directive_decl. The directive carries no
# value and emits no IR; a reached `$error` fails the build at sema.
# ---
# p:     parser state positioned at the leading `$`
# start: span of the statement's first token
# ret:   StmtId of the directive statement
fun parse_comptime_directive_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    val target: id.ExprId = expr.parse_expr(p);
    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after comptime directive");

    var attr: stmt.StmtComptimeAttr;
    attr.target = target;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end.span);
    node.kind = stmt.STMT_KIND_COMPTIME_ATTR;
    node.data.comptime_attr = attr;
    ret state.push_stmt(p, node);
}

# parse visibility and linkage flags (pub / ext) in any order, zero or more times
# ---
# p:   parser state
# ret: bitfield of DECL_FLAG_* values
fun parse_flags(p: *state.Parser) u8 {
    var flags: u8 = 0;
    for (true) {
        if (state.eat_kw(p, token.KW_PUB)) { flags = flags | decl.DECL_FLAG_PUB; }
        or (state.eat_kw(p, token.KW_EXT)) { flags = flags | decl.DECL_FLAG_EXT; }
        or                          { brk; }
    }
    ret flags;
}

# parse a dotted path identifier sequence
# ---
# p:   parser state; the current token must be an IDENT
# ret: span covering the first ident through the last
fun parse_dotted_path(p: *state.Parser) token.Span {
    val start: token.Span = state.advance(p).span;
    var last:  token.Span = start;
    for (state.at(p, token.KIND_DOT) && state.peek(p, 1).kind == token.KIND_IDENT) {
        state.advance(p);
        last = state.advance(p).span;
    }
    ret state.span_of(start, last);
}

# whether the token at p.pos + offset is an IDENT whose text equals `kw`
# ---
# p:      parser state
# offset: lookahead distance from the current token
# kw:     keyword text to match
# ret:    true when the looked-ahead token is that identifier
fun peek_is_kw(p: *state.Parser, offset: usize, kw: str) bool {
    val t: token.Token = state.peek(p, offset);
    if (t.kind != token.KIND_IDENT) { ret false; }
    ret str_region_equals(p.tokens.source, t.span.offset, t.span.len, kw);
}

# whether the current token is the contextual keyword `kw` in its bare statement
# form -- the keyword immediately followed by `;`
#
# `cnt`/`brk` are the only statement keywords that take no operand, so a non-`;`
# follower (`cnt = x`, `cnt.f`) means the word is an ordinary identifier rather
# than the continue/break keyword. Dispatching on the bare form lets such a name
# parse as an expression statement instead of misparsing as continue/break.
# ---
# p:   parser state
# kw:  the contextual keyword to test
# ret: true when the current token is the bare keyword statement form
fun at_bare_kw_stmt(p: *state.Parser, kw: str) bool {
    if (!state.at_kw(p, kw)) { ret false; }
    ret state.peek(p, 1).kind == token.KIND_SEMI;
}

# consume a token of `kind` and return its span, reporting `msg` and returning an
# empty span on mismatch so the caller can still build a node for recovery
# ---
# p:    parser state
# kind: the token kind the caller requires
# msg:  diagnostic to report when the token is absent
# ret:  the consumed token's span, or an empty span on mismatch
fun parse_required(p: *state.Parser, kind: token.Kind, msg: str) token.Span {
    if (state.at(p, kind)) {
        ret state.advance(p).span;
    }
    state.error_at_current(p, msg);
    ret span_empty();
}

# an empty span (offset 0, length 0), the absent-token marker
# ---
# ret: a zero-length span
fun span_empty() token.Span {
    var sp: token.Span;
    sp.offset = 0;
    sp.len    = 0;
    ret sp;
}

# parse the shared `[alias:] path;` tail of a `use`/`fwd` declaration
#
# The leading keyword is already consumed. `path_msg`/`semi_msg` localize the
# diagnostics to the calling keyword.
# ---
# p:         parser state positioned after the keyword
# path_msg:  diagnostic for a missing path
# semi_msg:  diagnostic for a missing terminating `;`
# alias_out: receives the alias span, or an empty span when absent
# path_out:  receives the dotted path span
# ret:       the token whose span ends the declaration
fun parse_alias_path(p: *state.Parser, path_msg: str, semi_msg: str, alias_out: *token.Span, path_out: *token.Span) token.Token {
    var alias: token.Span = span_empty();
    if (state.at(p, token.KIND_IDENT) && state.peek(p, 1).kind == token.KIND_COLON) {
        alias = state.advance(p).span;
        state.advance(p);
    }

    var path: token.Span = span_empty();
    if (state.at(p, token.KIND_IDENT)) {
        path = parse_dotted_path(p);
    }
    or {
        state.error_at_current(p, path_msg);
    }

    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, semi_msg);

    @alias_out = alias;
    @path_out  = path;
    ret end;
}

# parse `use [alias:] path;`
# ---
# p:     parser state positioned at the `use` keyword
# start: span of the declaration's first token
# flags: visibility/linkage flags parsed ahead of the keyword
# ret:   DeclId of the use declaration
fun parse_use_decl(p: *state.Parser, start: token.Span, flags: u8) id.DeclId {
    state.advance(p);

    var alias: token.Span;
    var path:  token.Span;
    val end: token.Token = parse_alias_path(p,
        "expected module path after 'use'",
        "expected ';' after 'use' declaration", ?alias, ?path);

    var u: decl.DeclUse;
    u.alias = alias;
    u.path  = path;

    var d: decl.Decl;
    d.span  = state.span_of(start, end.span);
    d.kind  = decl.DECL_KIND_USE;
    d.flags = flags;
    d.data.use_ = u;
    ret state.push_decl(p, d);
}

# parse `fwd [alias:] path;`
#
# Mirrors `use` grammar but re-exports publicly, so `fwd` always publishes and
# `pub fwd` is rejected; no visibility flag is carried.
# ---
# p:     parser state positioned at the `fwd` keyword
# start: span of the declaration's first token
# flags: visibility/linkage flags parsed ahead of the keyword
# ret:   DeclId of the fwd declaration
fun parse_fwd_decl(p: *state.Parser, start: token.Span, flags: u8) id.DeclId {
    if ((flags & decl.DECL_FLAG_PUB) != 0) {
        state.error_at(p, start, "'fwd' always publishes; 'pub fwd' is not allowed");
    }

    state.advance(p);

    var alias: token.Span;
    var path:  token.Span;
    val end: token.Token = parse_alias_path(p,
        "expected re-export path after 'fwd'",
        "expected ';' after 'fwd' declaration", ?alias, ?path);

    var fwd_d: decl.DeclFwd;
    fwd_d.alias = alias;
    fwd_d.path  = path;

    var d: decl.Decl;
    d.span  = state.span_of(start, end.span);
    d.kind  = decl.DECL_KIND_FWD;
    d.flags = 0;
    d.data.fwd_ = fwd_d;
    ret state.push_decl(p, d);
}

# parse `fun name[generics]?(params) RetType? body`
#
# The function's DeclId is reserved before its body is parsed: the body appends
# its own inner decls to the shared decl store, so pushing the function last would
# let a body edit shift its id -- and cross-module resolution caches a pub
# function's id (resolve.Symbol.decl, read by sema against the dep's AST).
# Reserving keeps a function's id invariant to its own body, the stability the
# incremental-resolve firewall needs (#1582).
# ---
# p:     parser state positioned at the `fun` keyword
# start: span of the declaration's first token
# flags: visibility/linkage flags parsed ahead of the keyword
# ret:   DeclId of the function declaration, or DECL_NIL on a reservation failure
fun parse_fun_decl(p: *state.Parser, start: token.Span, flags: u8) id.DeclId {
    state.advance(p);

    val name: token.Span = parse_required(p, token.KIND_IDENT, "expected function name");

    val gen_start: u32 = p.ast.generic_name_len::u32;
    val gen_len:   u32 = parse_generic_params(p);

    var params_start: u32 = 0;
    val params_len:   u32 = parse_fun_params(p, ?params_start);

    var ret_type: id.TypeId = id.TYPE_NIL;
    if (!state.at(p, token.KIND_LBRACE) && !state.at(p, token.KIND_SEMI)) {
        ret_type = expr.parse_type(p);
    }

    # reserve the DeclId before parsing the body so the function's id is invariant
    # to its own body's appends
    var placeholder: decl.Decl;
    placeholder.span  = start;
    placeholder.kind  = decl.DECL_KIND_FUN;
    placeholder.flags = flags;
    val did: id.DeclId = state.push_decl(p, placeholder);
    if (did == id.DECL_NIL) { ret id.DECL_NIL; }

    var body: id.StmtId  = id.STMT_NIL;
    var end:  token.Span = name;
    if (state.at(p, token.KIND_LBRACE)) {
        body = parse_block_stmt(p);
        if (body != id.STMT_NIL) {
            end = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, body)).span;
        }
    }
    or {
        val semi: token.Token = state.current(p);
        state.expect(p, token.KIND_SEMI, "expected '{' or ';' after function signature");
        end = semi.span;
    }

    var f: decl.DeclFun;
    f.name           = name;
    f.generics_start = gen_start;
    f.generics_len   = gen_len;
    f.params_start   = params_start;
    f.params_len     = params_len;
    f.return_type    = ret_type;
    f.body           = body;

    var d: decl.Decl;
    d.span      = state.span_of(start, end);
    d.kind      = decl.DECL_KIND_FUN;
    d.flags     = flags;
    d.data.fun_ = f;

    # write the completed decl into the reserved slot; body parsing may have grown
    # (and moved) the decl store, so re-fetch the slot pointer by id
    @O.unwrap[*decl.Decl](ast.get_decl(p.ast, did)) = d;
    ret did;
}

# parse `rec`/`uni Name[generics]? { field: Type; ... }`
#
# Records and unions share an identical grammar and payload shape, so one parser
# fills the kind-appropriate union arm, mirroring how parse_bind_decl serves both
# `val` and `var`.
# ---
# p:        parser state positioned at the `rec`/`uni` keyword
# start:    span of the declaration's first token
# flags:    visibility/linkage flags parsed ahead of the keyword
# kind:     DECL_KIND_REC or DECL_KIND_UNI
# name_msg: diagnostic for a missing type name
# ret:      DeclId of the record or union declaration
fun parse_rec_uni_decl(p: *state.Parser, start: token.Span, flags: u8, kind: decl.DeclKind, name_msg: str) id.DeclId {
    state.advance(p);

    val name: token.Span = parse_required(p, token.KIND_IDENT, name_msg);

    val gen_start: u32 = p.ast.generic_name_len::u32;
    val gen_len:   u32 = parse_generic_params(p);

    var fields_start: u32 = 0;
    val fields_len:   u32 = parse_rec_fields(p, ?fields_start);

    var end_span: token.Span = name;
    if (p.pos > 0) {
        end_span = p.tokens.tokens[p.pos - 1].span;
    }

    var d: decl.Decl;
    d.span  = state.span_of(start, end_span);
    d.kind  = kind;
    d.flags = flags;
    if (kind == decl.DECL_KIND_REC) {
        var r: decl.DeclRec;
        r.name           = name;
        r.generics_start = gen_start;
        r.generics_len   = gen_len;
        r.fields_start   = fields_start;
        r.fields_len     = fields_len;
        d.data.rec_ = r;
    }
    or {
        var u: decl.DeclUni;
        u.name           = name;
        u.generics_start = gen_start;
        u.generics_len   = gen_len;
        u.fields_start   = fields_start;
        u.fields_len     = fields_len;
        d.data.uni_ = u;
    }
    ret state.push_decl(p, d);
}

# parse `val name: Type [= expr];` or `var name: Type [= expr];`
#
# Both bindings require an explicit type annotation (Mach has no type inference);
# `val` additionally requires an initializer, unless it is an `ext` foreign data
# import (storage-less, like the body-less `ext fun`).
# ---
# p:     parser state positioned at the `val`/`var` keyword
# start: span of the declaration's first token
# flags: visibility/linkage flags parsed ahead of the keyword
# kind:  DECL_KIND_VAL or DECL_KIND_VAR
# ret:   DeclId of the binding declaration
fun parse_bind_decl(p: *state.Parser, start: token.Span, flags: u8, kind: decl.DeclKind) id.DeclId {
    state.advance(p);

    val name: token.Span = parse_required(p, token.KIND_IDENT, "expected binding name");

    # the colon-and-type is mandatory at the syntax level (val-var.md)
    var ty: id.TypeId = id.TYPE_NIL;
    if (state.eat(p, token.KIND_COLON)) {
        ty = expr.parse_type(p);
    }
    or {
        state.error_at_current(p, "expected ':' and a type; bindings require an explicit type annotation");
    }

    # `val` requires an initializer; `var` may be default-initialized. an `ext`
    # binding is a storage-less foreign data import (#2026) whose definition lives
    # in another object, so it carries no initializer - the exact mirror of the
    # body-less `ext fun` exemption.
    var init: id.ExprId = id.EXPR_NIL;
    if (state.eat(p, token.KIND_EQ)) {
        init = expr.parse_expr(p);
    }
    or (kind == decl.DECL_KIND_VAL && (flags & decl.DECL_FLAG_EXT) == 0) {
        state.error_at_current(p, "'val' requires an initializer");
    }

    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after binding");

    var b: decl.DeclBind;
    b.name = name;
    b.ty   = ty;
    b.init = init;

    var d: decl.Decl;
    d.span      = state.span_of(start, end.span);
    d.kind      = kind;
    d.flags     = flags;
    d.data.bind = b;
    ret state.push_decl(p, d);
}

# parse `def Name: Type;`
# ---
# p:     parser state positioned at the `def` keyword
# start: span of the declaration's first token
# flags: visibility/linkage flags parsed ahead of the keyword
# ret:   DeclId of the type-alias declaration
fun parse_def_decl(p: *state.Parser, start: token.Span, flags: u8) id.DeclId {
    state.advance(p);

    val name: token.Span = parse_required(p, token.KIND_IDENT, "expected type alias name");

    state.expect(p, token.KIND_COLON, "expected ':' in 'def' declaration");
    val ty: id.TypeId = expr.parse_type(p);

    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after 'def' declaration");

    var def_: decl.DeclDef;
    def_.name = name;
    def_.ty   = ty;

    var d: decl.Decl;
    d.span      = state.span_of(start, end.span);
    d.kind      = decl.DECL_KIND_DEF;
    d.flags     = flags;
    d.data.def_ = def_;
    ret state.push_decl(p, d);
}

# parse `test "label" { body }`
# ---
# p:     parser state positioned at the `test` keyword
# start: span of the declaration's first token
# flags: visibility/linkage flags parsed ahead of the keyword
# ret:   DeclId of the test declaration
fun parse_test_decl(p: *state.Parser, start: token.Span, flags: u8) id.DeclId {
    state.advance(p);

    val label: token.Span = parse_required(p, token.KIND_LIT_STR, "expected a string literal after 'test'");

    var body: id.StmtId  = id.STMT_NIL;
    var end:  token.Span = label;
    if (state.at(p, token.KIND_LBRACE)) {
        body = parse_block_stmt(p);
        if (body != id.STMT_NIL) {
            end = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, body)).span;
        }
    }
    or {
        state.error_at_current(p, "expected '{' to open test body");
    }

    var t: decl.DeclTest;
    t.label = label;
    t.body  = body;

    var d: decl.Decl;
    d.span       = state.span_of(start, end);
    d.kind       = decl.DECL_KIND_TEST;
    d.flags      = flags;
    d.data.test_ = t;
    ret state.push_decl(p, d);
}

# dispatch a leading `$` at decl scope to a comptime-if or a bare comptime
# directive (`$intrinsic(args);`)
# ---
# p:     parser state positioned at the `$`
# start: span of the declaration's first token
# ret:   DeclId of the comptime declaration
fun parse_comptime_decl(p: *state.Parser, start: token.Span) id.DeclId {
    if (peek_is_kw(p, 1, token.KW_IF)) { ret parse_comptime_if_decl(p, start); }
    ret parse_comptime_directive_decl(p, start);
}

# parser for one `$if`/`$or` branch body in the caller's scope
#
# Parses a `{ ... }` body (decls at decl scope, stmts at stmt scope), appends its
# elements to their pool as one contiguous block, writes that block's pool start
# and length through the out-params, and returns the closing `}` span. The two
# implementations differ only in element kind, so parse_comptime_chain is shared.
def ComptimeBodyFn: fun(*state.Parser, *u32, *u32) token.Span;

# parse a `$if (cond) {..} $or (cond) {..} $or {..}` chain, shared by decl and
# stmt scope
#
# The leading `$if` is at the cursor; `parse_body` parses each branch body. The
# branches are buffered so a nested chain inside a body cannot interleave into
# this chain's contiguous slice.
# ---
# p:                  parser state positioned at the `$if`
# start:              span of the chain's first token
# parse_body:         the per-scope branch-body parser
# branches_start_out: receives the branch block's start in ast.comptime_branches
# branches_len_out:   receives the number of branches
# ret:                the chain's end span
fun parse_comptime_chain(p: *state.Parser, start: token.Span, parse_body: ComptimeBodyFn, branches_start_out: *u32, branches_len_out: *u32) token.Span {
    var br_buf: state.ListBuf[decl.ComptimeBranch] = state.list_buf_init[decl.ComptimeBranch]();

    state.advance(p);
    state.advance(p);

    var has_more: bool       = true;
    var first:    bool       = true;
    var end:      token.Span = start;

    for (has_more) {
        var cond: id.ExprId = id.EXPR_NIL;
        if (first) {
            state.expect(p, token.KIND_LPAREN, "expected '(' after '$if'");
            cond = expr.parse_expr(p);
            state.expect(p, token.KIND_RPAREN, "expected ')' after '$if' condition");
            first = false;
        }
        or {
            if (state.eat(p, token.KIND_LPAREN)) {
                cond = expr.parse_expr(p);
                state.expect(p, token.KIND_RPAREN, "expected ')' after '$or' condition");
            }
        }

        var body_start: u32 = 0;
        var body_len:   u32 = 0;
        end = parse_body(p, ?body_start, ?body_len);

        var br: decl.ComptimeBranch;
        br.cond       = cond;
        br.body_start = body_start;
        br.body_len   = body_len;
        state.list_buf_push[decl.ComptimeBranch](p, ?br_buf, br);

        if (state.at(p, token.KIND_DOLLAR) && peek_is_kw(p, 1, token.KW_OR)) {
            state.advance(p);
            state.advance(p);
            has_more = true;
        }
        or {
            has_more = false;
        }
    }

    var branches_len:   u32 = 0;
    val branches_start: u32 = state.comptime_branch_buf_flush(p, ?br_buf, ?branches_len);
    @branches_start_out = branches_start;
    @branches_len_out   = branches_len;
    ret end;
}

# parse a `$if`/`$or` branch body as a decl list (decl scope)
#
# The body's direct decls are buffered so a nested comptime branch body cannot
# interleave into this branch's contiguous slice.
# ---
# p:              parser state positioned at the branch body's `{`
# body_start_out: receives the body block's start in ast.decl_ids
# body_len_out:   receives the number of body decls
# ret:            the closing `}` span
fun parse_comptime_decl_body(p: *state.Parser, body_start_out: *u32, body_len_out: *u32) token.Span {
    var body_buf: state.ListBuf[id.DeclId] = state.list_buf_init[id.DeclId]();

    state.expect(p, token.KIND_LBRACE, "expected '{' to open comptime branch body");
    for (!state.at(p, token.KIND_RBRACE) && !state.at_eof(p)) {
        val d: id.DeclId = parse_decl(p);
        if (d != id.DECL_NIL) {
            state.list_buf_push[id.DeclId](p, ?body_buf, d);
        }
        if (p.panic) {
            state.sync_to(p, token.KIND_SEMI, token.KIND_RBRACE, token.KIND_EOF);
            if (state.at(p, token.KIND_SEMI)) { state.advance(p); }
        }
    }
    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACE, "expected '}' to close comptime branch body");

    var body_len:   u32 = 0;
    val body_start: u32 = state.decl_id_buf_flush(p, ?body_buf, ?body_len);
    @body_start_out = body_start;
    @body_len_out   = body_len;
    ret close.span;
}

# parse a `$if`/`$or` branch body as a stmt list (stmt scope)
#
# The body's statements are buffered so a nested block inside cannot interleave
# into this branch's contiguous slice.
# ---
# p:              parser state positioned at the branch body's `{`
# body_start_out: receives the body block's start in ast.stmt_ids
# body_len_out:   receives the number of body statements
# ret:            the closing `}` span
fun parse_comptime_stmt_body(p: *state.Parser, body_start_out: *u32, body_len_out: *u32) token.Span {
    var body_buf: state.ListBuf[id.StmtId] = state.list_buf_init[id.StmtId]();

    state.expect(p, token.KIND_LBRACE, "expected '{' to open comptime branch body");
    for (!state.at(p, token.KIND_RBRACE) && !state.at_eof(p)) {
        val s: id.StmtId = parse_stmt(p);
        if (s != id.STMT_NIL) {
            state.list_buf_push[id.StmtId](p, ?body_buf, s);
        }
        if (p.panic) {
            state.sync_to(p, token.KIND_SEMI, token.KIND_RBRACE, token.KIND_EOF);
            if (state.at(p, token.KIND_SEMI)) { state.advance(p); }
        }
    }
    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACE, "expected '}' to close comptime branch body");

    var body_len:   u32 = 0;
    val body_start: u32 = state.stmt_id_buf_flush(p, ?body_buf, ?body_len);
    @body_start_out = body_start;
    @body_len_out   = body_len;
    ret close.span;
}

# parse `$if (cond) { decls } $or (cond) { decls } $or { decls }` at decl scope
# ---
# p:     parser state positioned at the `$if`
# start: span of the declaration's first token
# ret:   DeclId of the comptime-if declaration
fun parse_comptime_if_decl(p: *state.Parser, start: token.Span) id.DeclId {
    var branches_start: u32 = 0;
    var branches_len:   u32 = 0;
    val end: token.Span = parse_comptime_chain(p, start, parse_comptime_decl_body, ?branches_start, ?branches_len);

    var ci: decl.DeclComptimeIf;
    ci.branches_start = branches_start;
    ci.branches_len   = branches_len;

    var node: decl.Decl;
    node.span  = state.span_of(start, end);
    node.kind  = decl.DECL_KIND_COMPTIME_IF;
    node.flags = 0;
    node.data.comptime_if = ci;
    ret state.push_decl(p, node);
}

# parse a leading-`$` declaration that is not a `$if`: a bare comptime directive
# `$intrinsic(args);` (e.g. `$error("msg")`)
#
# The legacy attribute-write setter `$sym.attr = value;` was removed in v2.0.0
# (superseded by the `#[symbol(...)]` / `#[library(...)]` decorators); a stray `=`
# after the target is rejected with a migration diagnostic.
# ---
# p:     parser state positioned at the `$`
# start: span of the declaration's first token
# ret:   DeclId of the comptime-directive declaration
fun parse_comptime_directive_decl(p: *state.Parser, start: token.Span) id.DeclId {
    # parse the target above assignment precedence so a stray '=' is not swallowed
    # as an assignment expression (KIND_EQ is the lowest-precedence infix operator)
    val target: id.ExprId = expr.parse_expr_bp(p, 2);

    if (state.at(p, token.KIND_EQ)) {
        state.error_at_current(p, "comptime attribute setters were removed in v2.0.0; use a #[symbol(\"...\")] or #[library(\"...\")] decorator on the declaration");
        # consume the assignment so recovery resumes at the next statement
        state.advance(p);
        expr.parse_expr(p);
    }
    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after comptime directive");

    var attr: decl.DeclComptimeAttr;
    attr.target = target;

    var d: decl.Decl;
    d.span  = state.span_of(start, end.span);
    d.kind  = decl.DECL_KIND_COMPTIME_ATTR;
    d.flags = 0;
    d.data.comptime_attr = attr;
    ret state.push_decl(p, d);
}

# parse `[T, U]` generic parameter names, appending each to ast.generic_names
# ---
# p:   parser state; the current token is the opening `[`, or no bracket at all
# ret: the number of generic parameters parsed
fun parse_generic_params(p: *state.Parser) u32 {
    if (!state.eat(p, token.KIND_LBRACKET)) { ret 0; }

    if (state.at(p, token.KIND_RBRACKET)) {
        state.advance(p);
        ret 0;
    }

    var len: u32 = 0;
    if (parse_generic_param(p)) {
        len = len + 1;
    }
    or {
        state.sync_to(p, token.KIND_RBRACKET, token.KIND_LPAREN, token.KIND_EOF);
        if (state.at(p, token.KIND_RBRACKET)) { state.advance(p); }
        ret len;
    }

    for (state.eat(p, token.KIND_COMMA)) {
        if (state.at(p, token.KIND_RBRACKET)) { brk; }
        if (!parse_generic_param(p))          { brk; }
        len = len + 1;
    }

    state.expect(p, token.KIND_RBRACKET, "expected ']' to close generic parameters");
    ret len;
}

# parse a single generic parameter name and append it to ast.generic_names
# ---
# p:   parser state positioned at the parameter name
# ret: true on success, false on a missing name or allocation failure
fun parse_generic_param(p: *state.Parser) bool {
    if (!state.at(p, token.KIND_IDENT)) {
        state.error_at_current(p, "expected generic parameter name");
        ret false;
    }
    val name: token.Span = state.advance(p).span;
    val res_add: R.Result[u32, str] = ast.add_generic_name(p.ast, name);
    if (R.is_err[u32, str](res_add)) {
        state.fatal_oom_at(p, name);
        ret false;
    }
    ret true;
}

# parse `(name: Type, ...)` function parameters into one contiguous block of
# ast.typed_names
#
# A comptime variadic pack is a named trailing parameter whose type is `...`
# (`va: ...`), parsed as an ordinary typed name. A bare `...` in parameter
# position is the C-style marker removed in v2.0.0, rejected with a migration
# diagnostic. Each parameter is buffered so an inline rec/uni parameter type
# cannot split the list's typed_name slice.
# ---
# p:         parser state positioned at the opening `(`
# out_start: receives the block's start index in ast.typed_names
# ret:       the number of parameters parsed
fun parse_fun_params(p: *state.Parser, out_start: *u32) u32 {
    state.expect(p, token.KIND_LPAREN, "expected '(' to open parameter list");

    var buf: state.ListBuf[decl.TypedName] = state.list_buf_init[decl.TypedName]();
    var len: u32 = 0;

    if (state.at(p, token.KIND_RPAREN)) {
        state.advance(p);
        @out_start = state.typed_name_buf_flush(p, ?buf, ?len);
        ret len;
    }

    if (state.at(p, token.KIND_DOT_DOT_DOT)) {
        state.error_at_current(p, "C-style variadic `...` was removed in v2.0.0; declare a comptime variadic pack as a named parameter `va: ...`");
        state.advance(p);
    }
    or (parse_typed_name(p, ?buf, "expected parameter name")) { }
    or {
        state.sync_to(p, token.KIND_RPAREN, token.KIND_LBRACE, token.KIND_EOF);
        if (state.at(p, token.KIND_RPAREN)) { state.advance(p); }
        @out_start = state.typed_name_buf_flush(p, ?buf, ?len);
        ret len;
    }

    for (state.eat(p, token.KIND_COMMA)) {
        if (state.at(p, token.KIND_RPAREN)) { brk; }
        if (state.at(p, token.KIND_DOT_DOT_DOT)) {
            state.error_at_current(p, "C-style variadic `...` was removed in v2.0.0; declare a comptime variadic pack as a named parameter `va: ...`");
            state.advance(p);
            brk;
        }
        if (!parse_typed_name(p, ?buf, "expected parameter name")) { brk; }
    }

    state.expect(p, token.KIND_RPAREN, "expected ')' to close parameter list");
    @out_start = state.typed_name_buf_flush(p, ?buf, ?len);
    ret len;
}

# parse `{ name: Type; ... }` record/union fields into one contiguous block of
# ast.typed_names
#
# Each field is buffered so an inline rec/uni field type cannot split the list's
# typed_name slice.
# ---
# p:         parser state positioned at the opening `{`
# out_start: receives the block's start index in ast.typed_names
# ret:       the number of fields parsed
fun parse_rec_fields(p: *state.Parser, out_start: *u32) u32 {
    state.expect(p, token.KIND_LBRACE, "expected '{' to open record body");

    var buf: state.ListBuf[decl.TypedName] = state.list_buf_init[decl.TypedName]();
    var len: u32 = 0;

    for (!state.at(p, token.KIND_RBRACE) && !state.at_eof(p)) {
        if (!parse_typed_name(p, ?buf, "expected field name")) {
            state.sync_to(p, token.KIND_SEMI, token.KIND_RBRACE, token.KIND_EOF);
            if (state.at(p, token.KIND_SEMI)) { state.advance(p); }
            cnt;
        }
        state.expect(p, token.KIND_SEMI, "expected ';' after record field");
    }

    state.expect(p, token.KIND_RBRACE, "expected '}' to close record body");
    @out_start = state.typed_name_buf_flush(p, ?buf, ?len);
    ret len;
}

# parse a single `[$]name: Type` entry and buffer it into `buf`
#
# A leading `$` marks the entry as a comptime value parameter (function parameters
# only), recorded on the TypedName. The entry is buffered rather than pushed to
# ast.typed_names directly so an inline rec/uni type cannot split the enclosing
# list's contiguous slice.
# ---
# p:                parser state positioned at the optional `$` or the name
# buf:              the list buffer the entry is pushed into
# missing_name_msg: diagnostic for a missing name
# ret:              true on success, false on a malformed entry
fun parse_typed_name(p: *state.Parser, buf: *state.ListBuf[decl.TypedName], missing_name_msg: str) bool {
    var comptime: bool = false;
    if (state.eat(p, token.KIND_DOLLAR)) {
        comptime = true;
    }

    if (!state.at(p, token.KIND_IDENT)) {
        state.error_at_current(p, missing_name_msg);
        ret false;
    }
    val name: token.Span = state.advance(p).span;
    if (!state.expect(p, token.KIND_COLON, "expected ':' between name and type")) { ret false; }
    val ty: id.TypeId = expr.parse_type(p);

    var tn: decl.TypedName;
    tn.name     = name;
    tn.ty       = ty;
    tn.comptime = comptime;
    state.list_buf_push[decl.TypedName](p, buf, tn);
    ret true;
}

# parse `{ stmt; stmt; ... }`
#
# The statements are buffered: a statement containing a nested block (an inner
# `{}`, or an `if`/`for` body) appends its own statement ids to the shared pool
# mid-parse, so this block is flushed as one contiguous slice afterward.
# ---
# p:   parser state positioned at the opening `{`
# ret: StmtId of the block statement
fun parse_block_stmt(p: *state.Parser) id.StmtId {
    val start: token.Token = state.current(p);
    state.expect(p, token.KIND_LBRACE, "expected '{' to open block");

    var buf: state.ListBuf[id.StmtId] = state.list_buf_init[id.StmtId]();

    for (!state.at(p, token.KIND_RBRACE) && !state.at_eof(p)) {
        val s: id.StmtId = parse_stmt(p);
        if (s != id.STMT_NIL) {
            state.list_buf_push[id.StmtId](p, ?buf, s);
        }
        if (p.panic) {
            state.sync_to(p, token.KIND_SEMI, token.KIND_RBRACE, token.KIND_EOF);
            if (state.at(p, token.KIND_SEMI)) { state.advance(p); }
        }
    }

    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACE, "expected '}' to close block");

    var stmts_len:   u32 = 0;
    val stmts_start: u32 = state.stmt_id_buf_flush(p, ?buf, ?stmts_len);

    var block: stmt.StmtBlock;
    block.stmts_start = stmts_start;
    block.stmts_len   = stmts_len;

    var node: stmt.Stmt;
    node.span = state.span_of(start.span, close.span);
    node.kind = stmt.STMT_KIND_BLOCK;
    node.data.block = block;
    ret state.push_stmt(p, node);
}

# parse `if (cond) { then } [or (cond) { ... }]* [or { ... }]?`
# ---
# p:     parser state positioned at the `if` keyword
# start: span of the statement's first token
# ret:   StmtId of the if statement
fun parse_if_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.advance(p);
    state.expect(p, token.KIND_LPAREN, "expected '(' after 'if'");
    val cond: id.ExprId = expr.parse_expr(p);
    state.expect(p, token.KIND_RPAREN, "expected ')' after 'if' condition");

    var then_block: id.StmtId = id.STMT_NIL;
    if (state.at(p, token.KIND_LBRACE)) {
        then_block = parse_block_stmt(p);
    }
    or {
        state.error_at_current(p, "expected '{' to open 'if' body");
    }

    var else_block: id.StmtId = id.STMT_NIL;
    if (state.at_kw(p, token.KW_OR)) {
        else_block = parse_or_chain(p);
    }

    var if_: stmt.StmtIf;
    if_.cond       = cond;
    if_.then_block = then_block;
    if_.else_block = else_block;

    var end_span: token.Span = start;
    if (else_block != id.STMT_NIL) {
        end_span = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, else_block)).span;
    }
    or (then_block != id.STMT_NIL) {
        end_span = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, then_block)).span;
    }

    var node: stmt.Stmt;
    node.span = state.span_of(start, end_span);
    node.kind = stmt.STMT_KIND_IF;
    node.data.if_ = if_;
    ret state.push_stmt(p, node);
}

# parse one arm of an `or (...) { ... }` / `or { ... }` chain, recursing for
# further arms
# ---
# p:   parser state positioned at the `or` keyword
# ret: StmtId of the arm, modeled as a nested if statement
fun parse_or_chain(p: *state.Parser) id.StmtId {
    val start: token.Token = state.current(p);
    state.advance(p);

    if (state.at(p, token.KIND_LBRACE)) {
        ret parse_block_stmt(p);
    }

    state.expect(p, token.KIND_LPAREN, "expected '(' after 'or'");
    val cond: id.ExprId = expr.parse_expr(p);
    state.expect(p, token.KIND_RPAREN, "expected ')' after 'or' condition");

    var then_block: id.StmtId = id.STMT_NIL;
    if (state.at(p, token.KIND_LBRACE)) {
        then_block = parse_block_stmt(p);
    }
    or {
        state.error_at_current(p, "expected '{' to open 'or' body");
    }

    var else_block: id.StmtId = id.STMT_NIL;
    if (state.at_kw(p, token.KW_OR)) {
        else_block = parse_or_chain(p);
    }

    var if_: stmt.StmtIf;
    if_.cond       = cond;
    if_.then_block = then_block;
    if_.else_block = else_block;

    var end_span: token.Span = start.span;
    if (else_block != id.STMT_NIL) {
        end_span = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, else_block)).span;
    }
    or (then_block != id.STMT_NIL) {
        end_span = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, then_block)).span;
    }

    var node: stmt.Stmt;
    node.span = state.span_of(start.span, end_span);
    node.kind = stmt.STMT_KIND_IF;
    node.data.if_ = if_;
    ret state.push_stmt(p, node);
}

# parse `for [(cond)]? { body }`; an absent condition means an infinite loop
# ---
# p:     parser state positioned at the `for` keyword
# start: span of the statement's first token
# ret:   StmtId of the for statement
fun parse_for_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.advance(p);

    var cond: id.ExprId = id.EXPR_NIL;
    if (state.eat(p, token.KIND_LPAREN)) {
        cond = expr.parse_expr(p);
        state.expect(p, token.KIND_RPAREN, "expected ')' after 'for' condition");
    }

    var body:     id.StmtId  = id.STMT_NIL;
    var end_span: token.Span = start;
    if (state.at(p, token.KIND_LBRACE)) {
        body = parse_block_stmt(p);
        if (body != id.STMT_NIL) {
            end_span = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, body)).span;
        }
    }
    or {
        state.error_at_current(p, "expected '{' to open 'for' body");
    }

    var for_: stmt.StmtFor;
    for_.cond = cond;
    for_.body = body;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end_span);
    node.kind = stmt.STMT_KIND_FOR;
    node.data.for_ = for_;
    ret state.push_stmt(p, node);
}

# parse `ret [expr];`
# ---
# p:     parser state positioned at the `ret` keyword
# start: span of the statement's first token
# ret:   StmtId of the ret statement
fun parse_ret_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.advance(p);

    var value: id.ExprId = id.EXPR_NIL;
    if (!state.at(p, token.KIND_SEMI) && !state.at_eof(p)) {
        value = expr.parse_expr(p);
    }

    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after 'ret'");

    var ret_: stmt.StmtRet;
    ret_.value = value;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end.span);
    node.kind = stmt.STMT_KIND_RET;
    node.data.ret_ = ret_;
    ret state.push_stmt(p, node);
}

# parse `brk;`
# ---
# p:     parser state positioned at the `brk` keyword
# start: span of the statement's first token
# ret:   StmtId of the brk statement
fun parse_brk_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.advance(p);
    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after 'brk'");

    var node: stmt.Stmt;
    node.span = state.span_of(start, end.span);
    node.kind = stmt.STMT_KIND_BRK;
    ret state.push_stmt(p, node);
}

# parse `cnt;`
# ---
# p:     parser state positioned at the `cnt` keyword
# start: span of the statement's first token
# ret:   StmtId of the cnt statement
fun parse_cnt_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.advance(p);
    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after 'cnt'");

    var node: stmt.Stmt;
    node.span = state.span_of(start, end.span);
    node.kind = stmt.STMT_KIND_CNT;
    ret state.push_stmt(p, node);
}

# parse `fin { ... }` -- a deferred block run at scope exit
#
# The body must be a block; the bare single-statement form (`fin stmt;`) is
# rejected so a deferred region is always a visible block.
# ---
# p:     parser state positioned at the `fin` keyword
# start: span of the statement's first token
# ret:   StmtId of the fin statement
fun parse_fin_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.advance(p);

    var body_id: id.StmtId = id.STMT_NIL;
    if (state.at(p, token.KIND_LBRACE)) {
        body_id = parse_block_stmt(p);
    }
    or {
        state.error_at_current(p, "expected '{' to open 'fin' body");
    }

    var end_span: token.Span = start;
    if (body_id != id.STMT_NIL) {
        end_span = O.unwrap[*stmt.Stmt](ast.get_stmt(p.ast, body_id)).span;
    }

    var fin_s: stmt.StmtFin;
    fin_s.body = body_id;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end_span);
    node.kind = stmt.STMT_KIND_FIN;
    node.data.fin_ = fin_s;
    ret state.push_stmt(p, node);
}

# parse a local `val`/`var` declaration used as a statement
# ---
# p:     parser state positioned at the `val`/`var` keyword
# start: span of the statement's first token
# ret:   StmtId of the wrapping decl statement
fun parse_local_decl_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    val d: id.DeclId = parse_decl(p);

    var sd: stmt.StmtDecl;
    sd.decl = d;

    var end_span: token.Span = start;
    if (d != id.DECL_NIL) {
        end_span = O.unwrap[*decl.Decl](ast.get_decl(p.ast, d)).span;
    }

    var node: stmt.Stmt;
    node.span = state.span_of(start, end_span);
    node.kind = stmt.STMT_KIND_DECL;
    node.data.decl = sd;
    ret state.push_stmt(p, node);
}

# parse an expression statement `expr;`
# ---
# p:     parser state positioned at the first token of the expression
# start: span of the statement's first token
# ret:   StmtId of the expression statement
fun parse_expr_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    val expr_id: id.ExprId = expr.parse_expr(p);
    val end: token.Token = state.current(p);
    state.expect(p, token.KIND_SEMI, "expected ';' after expression statement");

    var se: stmt.StmtExpr;
    se.expr = expr_id;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end.span);
    node.kind = stmt.STMT_KIND_EXPR;
    node.data.expr = se;
    ret state.push_stmt(p, node);
}

# parse `$each <ident> in <seq> { body }` at statement scope
#
# The sequence is a comptime expression (e.g. `$fields(T)`); the body is spliced
# once per element with the loop variable bound to that element. The sequence is
# paren-less and immediately followed by the body's `{`, so struct-literal parsing
# is suppressed to keep a bare pack ident (`va`) from consuming the body braces.
# ---
# p:     parser state positioned at the leading `$`
# start: span of the statement's first token
# ret:   StmtId of the $each statement
fun parse_comptime_each_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    state.expect(p, token.KIND_DOLLAR, "expected '$' to open a comptime $each");
    state.eat_kw(p, token.KW_EACH);

    val var_tok: token.Token = state.current(p);
    state.expect(p, token.KIND_IDENT, "expected a loop variable name after '$each'");
    if (!state.eat_kw(p, token.KW_IN)) {
        state.error_at_current(p, "expected 'in' after the $each loop variable");
    }

    val saved_nsl: bool = p.no_struct_lit;
    p.no_struct_lit = true;
    val seq: id.ExprId = expr.parse_expr(p);
    p.no_struct_lit = saved_nsl;

    var body_start: u32 = 0;
    var body_len:   u32 = 0;
    val end: token.Span = parse_comptime_stmt_body(p, ?body_start, ?body_len);

    var ce: stmt.StmtComptimeEach;
    ce.var_name   = var_tok.span;
    ce.seq        = seq;
    ce.body_start = body_start;
    ce.body_len   = body_len;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end);
    node.kind = stmt.STMT_KIND_COMPTIME_EACH;
    node.data.comptime_each = ce;
    ret state.push_stmt(p, node);
}

# parse `$if (cond) { stmts } $or (cond) { stmts } $or { stmts }` at statement
# scope
# ---
# p:     parser state positioned at the `$if`
# start: span of the statement's first token
# ret:   StmtId of the comptime-if statement
fun parse_comptime_if_stmt(p: *state.Parser, start: token.Span) id.StmtId {
    var branches_start: u32 = 0;
    var branches_len:   u32 = 0;
    val end: token.Span = parse_comptime_chain(p, start, parse_comptime_stmt_body, ?branches_start, ?branches_len);

    var ci: stmt.StmtComptimeIf;
    ci.branches_start = branches_start;
    ci.branches_len   = branches_len;

    var node: stmt.Stmt;
    node.span = state.span_of(start, end);
    node.kind = stmt.STMT_KIND_COMPTIME_IF;
    node.data.comptime_if = ci;
    ret state.push_stmt(p, node);
}

# lex and parse `source` as a module, reporting whether any error diagnostic was
# produced
#
# Used by the binding-grammar tests.
# ---
# source: module source text
# ret:    true when parsing produced at least one error diagnostic
fun t_parse_module_has_errors(source: str) bool {
    var alloc: A.Allocator;
    page.make(?alloc);
    val res_tokens: R.Result[lexer.TokenStream, str] = lexer.tokenize(source, ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](res_tokens)) { ret true; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](res_tokens);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p: state.Parser = state.make(?stream, ?a, ?diags);
    parse_module(?p);
    val had: bool = diagnostic.has_errors(?diags);
    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret had;
}

# parse_decl pins a malformed module-scope decl's error span to the offending
# token and still records an error decl
test "mach.lang.fe.parser.decl.parse_decl:error_span_pinned" {
    # (a) bare expression `42;` at module scope: one error whose span covers `42`
    # and an error decl is recorded so the ast is non-empty
    var alloc_a: A.Allocator;
    page.make(?alloc_a);
    val tr_a: R.Result[lexer.TokenStream, str] = lexer.tokenize("42;", ?alloc_a, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr_a)) { ret 1; }
    var stream_a: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr_a);
    var a_a: ast.Ast = ast.init(?alloc_a, 0::src.FileId);
    var diags_a: diagnostic.DiagList = diagnostic.init(?alloc_a);
    var p_a: state.Parser = state.make(?stream_a, ?a_a, ?diags_a);
    parse_module(?p_a);
    var rc: i32 = 0;
    if (diags_a.len != 1)                      { rc = 1; }
    or (diags_a.items[0].loc.span.offset != 0) { rc = 1; }
    or (diags_a.items[0].loc.span.len    != 2) { rc = 1; }
    or (a_a.decl_len < 1)                      { rc = 1; }
    diagnostic.dnit(?diags_a);
    ast.dnit(?a_a);
    lexer.dnit(?stream_a, ?alloc_a);
    if (rc != 0) { ret rc; }

    # `42; fun f() {}` -- one error for `42`, and the fun decl is still captured
    var alloc_b: A.Allocator;
    page.make(?alloc_b);
    val tr_b: R.Result[lexer.TokenStream, str] = lexer.tokenize("42; fun f() {}", ?alloc_b, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr_b)) { ret 1; }
    var stream_b: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr_b);
    var a_b: ast.Ast = ast.init(?alloc_b, 0::src.FileId);
    var diags_b: diagnostic.DiagList = diagnostic.init(?alloc_b);
    var p_b: state.Parser = state.make(?stream_b, ?a_b, ?diags_b);
    parse_module(?p_b);
    if (diags_b.len != 1)                                       { rc = 1; }
    or (a_b.decl_len < 2)                                       { rc = 1; }
    or (a_b.decls[a_b.decl_len - 1].kind != decl.DECL_KIND_FUN) { rc = 1; }
    diagnostic.dnit(?diags_b);
    ast.dnit(?a_b);
    lexer.dnit(?stream_b, ?alloc_b);
    ret rc;
}

# sync_to_decl realigns on the next decl boundary so one malformed decl does not
# cascade into errors on every following token
test "mach.lang.fe.parser.decl.parse_module:sync_realigns_no_cascade" {
    # (b) `42 + 3; fun f() {}` -- one error only (no cascade from `+` or `3`) and
    # the fun decl is the last captured decl
    var alloc_c: A.Allocator;
    page.make(?alloc_c);
    val tr_c: R.Result[lexer.TokenStream, str] = lexer.tokenize("42 + 3; fun f() {}", ?alloc_c, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr_c)) { ret 1; }
    var stream_c: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr_c);
    var a_c: ast.Ast = ast.init(?alloc_c, 0::src.FileId);
    var diags_c: diagnostic.DiagList = diagnostic.init(?alloc_c);
    var p_c: state.Parser = state.make(?stream_c, ?a_c, ?diags_c);
    parse_module(?p_c);
    var rc: i32 = 0;
    if (diags_c.len != 1)                                       { rc = 1; }
    or (a_c.decl_len < 1)                                       { rc = 1; }
    or (a_c.decls[a_c.decl_len - 1].kind != decl.DECL_KIND_FUN) { rc = 1; }
    diagnostic.dnit(?diags_c);
    ast.dnit(?a_c);
    lexer.dnit(?stream_c, ?alloc_c);
    if (rc != 0) { ret rc; }

    # `42; val a: i64 = 1; fun g() {}` -- one error, both subsequent decls captured
    var alloc_d: A.Allocator;
    page.make(?alloc_d);
    val tr_d: R.Result[lexer.TokenStream, str] = lexer.tokenize("42; val a: i64 = 1; fun g() {}", ?alloc_d, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr_d)) { ret 1; }
    var stream_d: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr_d);
    var a_d: ast.Ast = ast.init(?alloc_d, 0::src.FileId);
    var diags_d: diagnostic.DiagList = diagnostic.init(?alloc_d);
    var p_d: state.Parser = state.make(?stream_d, ?a_d, ?diags_d);
    parse_module(?p_d);
    if (diags_d.len != 1) { rc = 1; }
    or (a_d.decl_len < 3) { rc = 1; }
    diagnostic.dnit(?diags_d);
    ast.dnit(?a_d);
    lexer.dnit(?stream_d, ?alloc_d);
    ret rc;
}

# val-var.md: bindings require an explicit type -- neither form may omit it
test "mach.lang.fe.parser.decl.parse_bind_decl:requires_type_annotation" {
    if (!t_parse_module_has_errors("val a = 42;")) { ret 1; }
    if (!t_parse_module_has_errors("var b;"))      { ret 1; }
    ret 0;
}

# a `val` must carry an initializer
test "mach.lang.fe.parser.decl.parse_bind_decl:val_requires_initializer" {
    if (!t_parse_module_has_errors("val c: i64;")) { ret 1; }
    ret 0;
}

# val needs type + init; var needs a type but may default-initialize
test "mach.lang.fe.parser.decl.parse_bind_decl:well_formed" {
    if (t_parse_module_has_errors("val c: i64 = 1; var d: i64;")) { ret 1; }
    ret 0;
}

# `ext val`/`ext var` are storage-less foreign data imports (#2026): both parse
# without an initializer (the `val` exemption mirrors the body-less `ext fun`),
# carry DECL_FLAG_EXT, and the exemption is ext-only - a plain `val` without an
# initializer still errors.
test "mach.lang.fe.parser.decl.parse_bind_decl:ext_data_import" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val tr: R.Result[lexer.TokenStream, str] = lexer.tokenize("ext var g: i32; ext val h: i32;", ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p: state.Parser = state.make(?stream, ?a, ?diags);
    parse_module(?p);

    var rc: i32 = 0;
    if (diagnostic.has_errors(?diags))                { rc = 1; }
    or (a.decl_len < 2)                               { rc = 1; }
    or (a.decls[0].kind != decl.DECL_KIND_VAR)        { rc = 1; }
    or (a.decls[1].kind != decl.DECL_KIND_VAL)        { rc = 1; }
    or ((a.decls[0].flags & decl.DECL_FLAG_EXT) == 0) { rc = 1; }
    or ((a.decls[1].flags & decl.DECL_FLAG_EXT) == 0) { rc = 1; }
    or (a.decls[1].data.bind.init != id.EXPR_NIL)     { rc = 1; }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    if (rc != 0) { ret rc; }

    # the exemption is ext-only: a non-ext `val` without an initializer still errors.
    if (!t_parse_module_has_errors("val x: i32;")) { ret 1; }
    ret 0;
}

# $if/$or chains parse at both decl and stmt scope via the shared skeleton, and a
# malformed chain still reports
test "mach.lang.fe.parser.decl.parse_comptime_chain:decl_and_stmt_scope" {
    # decl-scope chain: `$if`, conditional `$or`, and a bare `$or` else
    if (t_parse_module_has_errors("$if (1) {} $or (2) {} $or {}")) { ret 1; }
    # stmt-scope chain inside a function body
    if (t_parse_module_has_errors("fun f() i64 { $if (1) { ret 1; } $or { ret 0; } }")) { ret 1; }
    # a malformed chain still reports: the `$if` condition needs parentheses
    if (!t_parse_module_has_errors("$if 1 {}")) { ret 1; }
    ret 0;
}

# `cnt`/`brk` are continue/break only in their bare form (`cnt;`/`brk;`); the same
# word followed by `=` is an ordinary identifier, so `cnt = g();` must parse as an
# assignment expression statement rather than misparse as continue (#1458)
test "mach.lang.fe.parser.decl.parse_stmt:bare_kw_as_ident" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val source: str = "fun g() i64 { ret 1; } fun f() i64 { var cnt: i64 = 0; for (true) { cnt = g(); brk; cnt; } ret cnt; }";
    val tr: R.Result[lexer.TokenStream, str] = lexer.tokenize(source, ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p: state.Parser = state.make(?stream, ?a, ?diags);
    parse_module(?p);

    var rc: i32 = 0;
    if (diagnostic.has_errors(?diags)) { rc = 1; }

    var n_cnt:  usize = 0;
    var n_brk:  usize = 0;
    var n_expr: usize = 0;
    var i: usize = 0;
    for (i < a.stmt_len) {
        val k: stmt.StmtKind = a.stmts[i].kind;
        if (k == stmt.STMT_KIND_CNT)  { n_cnt  = n_cnt  + 1; }
        or (k == stmt.STMT_KIND_BRK)  { n_brk  = n_brk  + 1; }
        or (k == stmt.STMT_KIND_EXPR) { n_expr = n_expr + 1; }
        i = i + 1;
    }
    # one bare `cnt;` and one `brk;` survive as keyword statements; `cnt = g();` is
    # the lone expression statement (the assignment)
    if (n_cnt  != 1) { rc = 1; }
    if (n_brk  != 1) { rc = 1; }
    if (n_expr != 1) { rc = 1; }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

# statements.md: `fin` requires a block body; the bare single-statement form
# (`fin stmt;`) is rejected, while `fin { ... }` parses (#1548)
test "mach.lang.fe.parser.decl.parse_fin_stmt:requires_block" {
    # bare single-statement forms are rejected
    if (!t_parse_module_has_errors("fun f() { fin g(); }"))              { ret 1; }
    if (!t_parse_module_has_errors("fun f() i64 { fin ret 0; ret 0; }")) { ret 1; }
    if (!t_parse_module_has_errors("fun f() { var x: i64 = 0; fin x = 1; }")) { ret 1; }
    # the block form parses cleanly
    if (t_parse_module_has_errors("fun f() { fin { } }"))                { ret 1; }
    if (t_parse_module_has_errors("fun f() i64 { var x: i64 = 0; fin { x = x + 1; } ret x; }")) { ret 1; }
    ret 0;
}

# a backtick decorator is rejected and the following decls still parse, with
# nothing attached by the removed clause (#1526)
test "mach.lang.fe.parser.decl.parse_decorators:backtick_rejected_recovers" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val source: str = "`symbol(\"_start\")` fun f() {} fun g() {}";
    val tr: R.Result[lexer.TokenStream, str] = lexer.tokenize(source, ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p: state.Parser = state.make(?stream, ?a, ?diags);
    parse_module(?p);

    var rc: i32 = 0;
    if (!diagnostic.has_errors(?diags))        { rc = 1; }
    or (a.decl_len < 2)                        { rc = 1; }
    or (a.decls[0].kind != decl.DECL_KIND_FUN) { rc = 1; }
    or (a.decls[1].kind != decl.DECL_KIND_FUN) { rc = 1; }
    or (a.decls[0].decorators_len != 0)        { rc = 1; }
    or (a.decls[1].decorators_len != 0)        { rc = 1; }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

# any backtick where a decorator may lead is the removed surface -- diagnose it
# whether the clause is well-formed, unterminated, or empty (#1526)
test "mach.lang.fe.parser.decl.parse_decorators:backtick_position_rejected" {
    if (!t_parse_module_has_errors("`inline` fun f() {}")) { ret 1; }
    if (!t_parse_module_has_errors("`inline fun f() {}"))  { ret 1; }
    if (!t_parse_module_has_errors("`` fun f() {}"))       { ret 1; }
    ret 0;
}

# a rejected backtick clause is skipped without discarding a following valid
# `#[...]`, which must still attach to the decl (#1526)
test "mach.lang.fe.parser.decl.parse_decorators:backtick_skipped_attr_attaches" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val source: str = "`inline` #[symbol(\"_start\")] fun f() {}";
    val tr: R.Result[lexer.TokenStream, str] = lexer.tokenize(source, ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p: state.Parser = state.make(?stream, ?a, ?diags);
    parse_module(?p);

    var rc: i32 = 0;
    if (!diagnostic.has_errors(?diags)) { rc = 1; }
    or (a.decl_len < 1)                 { rc = 1; }
    or (a.decls[0].decorators_len != 1) { rc = 1; }

    if (rc == 0) {
        val d0: decl.Decorator = a.decorators[a.decls[0].decorators_start];
        if (!str_region_equals(p.tokens.source, d0.name.offset, d0.name.len, "symbol")) { rc = 1; }
        if (d0.args_len != 1)                                                           { rc = 1; }
    }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

# leading `#[...]` attributes attach to the following decl and do not bleed across
# to the next one (#1532)
test "mach.lang.fe.parser.decl.parse_decorators:attrs_attach" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val source: str = "#[inline] #[symbol(\"_start\")] fun f() {} fun g() {}";
    val tr: R.Result[lexer.TokenStream, str] = lexer.tokenize(source, ?alloc, 0::src.FileId);
    if (R.is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diagnostic.DiagList = diagnostic.init(?alloc);
    var p: state.Parser = state.make(?stream, ?a, ?diags);
    parse_module(?p);

    var rc: i32 = 0;
    if (diagnostic.has_errors(?diags))         { rc = 1; }
    or (a.decl_len < 2)                        { rc = 1; }
    or (a.decls[0].kind != decl.DECL_KIND_FUN) { rc = 1; }
    or (a.decls[1].kind != decl.DECL_KIND_FUN) { rc = 1; }
    or (a.decls[0].decorators_len != 2)        { rc = 1; }
    or (a.decls[1].decorators_len != 0)        { rc = 1; }

    if (rc == 0) {
        val d0: decl.Decorator = a.decorators[a.decls[0].decorators_start];
        val d1: decl.Decorator = a.decorators[a.decls[0].decorators_start + 1];
        if (!str_region_equals(p.tokens.source, d0.name.offset, d0.name.len, "inline")) { rc = 1; }
        if (d0.args_len != 0)                                                           { rc = 1; }
        if (!str_region_equals(p.tokens.source, d1.name.offset, d1.name.len, "symbol")) { rc = 1; }
        if (d1.args_len != 1)                                                           { rc = 1; }
    }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

# a malformed `#[...]` attribute reports an error rather than silently parsing
test "mach.lang.fe.parser.decl.parse_decorators:malformed_attr_errors" {
    # a directive name with no closing `]` must diagnose
    if (!t_parse_module_has_errors("#[inline fun f() {}")) { ret 1; }
    # `#[]` with no directive name must diagnose
    if (!t_parse_module_has_errors("#[] fun f() {}")) { ret 1; }
    ret 0;
}
