# mach.lang.fe.parser.state: the Parser record plus the shared helpers every other parser file builds on.
#
# provides cursor (current, peek, advance), predicate (at, at_kw, eat,
# eat_kw), error reporting (error_at, error_at_current, expect, sync_to),
# span arithmetic (span_of), and the push_* wrappers that log allocation
# failures and return *_NIL rather than aborting. all sibling files depend
# on this one; nothing here depends back on them.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.string.str;
use std.types.string.str_region_equals;
use std.types.size.usize;
use std.types.result.Result;
use std.types.result.is_err;
use std.types.result.unwrap_ok;

use token:  mach.lang.fe.token;
use lexer:  mach.lang.fe.lexer;
use diag:   mach.lang.diagnostic;
use ast:    mach.lang.fe.ast;
use id:     mach.lang.fe.ast.id;
use expr:   mach.lang.fe.ast.expr;
use stmt:   mach.lang.fe.ast.stmt;
use decl:   mach.lang.fe.ast.decl;
use m_type: mach.lang.fe.ast.type;
use module: mach.lang.fe.ast.module;

# Parser: parser cursor and output sinks; lives for the duration of one parse.
# ---
# tokens: stream produced by the lexer
# pos:    index into tokens.tokens of the current token
# ast:    output AST; nodes are appended here as parsing progresses
# diags:  diagnostic sink for parse errors and recovery messages
# panic:  true while skipping tokens during error recovery; cleared at the next synchronization point
pub rec Parser {
    tokens: *lexer.TokenStream;
    pos:    usize;
    ast:    *ast.Ast;
    diags:  *diag.DiagList;
    panic:  bool;
}

# init: initializes a Parser over the given token stream, filling output into ast and diags.
# ---
# tokens: lexer output to consume
# out:    AST to append parsed nodes into
# diags:  diagnostic sink
# ret:    a fresh Parser positioned at the first token
pub fun init(tokens: *lexer.TokenStream, out: *ast.Ast, diags: *diag.DiagList) Parser {
    var p: Parser;
    p.tokens = tokens;
    p.pos    = 0;
    p.ast    = out;
    p.diags  = diags;
    p.panic  = false;
    ret p;
}

# current: returns the current token without consuming it.
# ---
# p:   parser state
# ret: token at p.pos
pub fun current(p: *Parser) token.Token {
    ret p.tokens.tokens[p.pos];
}

# peek: returns the token at an offset from the current position without consuming it.
# ---
# p:      parser state
# offset: positive offset from the current position
# ret:    token at p.pos + offset, or the trailing EOF if past the end
pub fun peek(p: *Parser, offset: usize) token.Token {
    val idx: usize = p.pos + offset;
    if (idx >= p.tokens.len) {
        ret p.tokens.tokens[p.tokens.len - 1];
    }
    ret p.tokens.tokens[idx];
}

# advance: consumes the current token and returns it.
# ---
# p:   parser state
# ret: the token that was current before the call
pub fun advance(p: *Parser) token.Token {
    val t: token.Token = p.tokens.tokens[p.pos];
    if (t.kind != token.KIND_EOF) {
        p.pos = p.pos + 1;
    }
    ret t;
}

# at: reports whether the current token has the given kind.
# ---
# p:    parser state
# kind: token kind to test against
# ret:  true if current().kind == kind
pub fun at(p: *Parser, kind: token.Kind) bool {
    ret current(p).kind == kind;
}

# eat: consumes the current token if its kind matches, reporting whether it did.
# ---
# p:    parser state
# kind: token kind to match and consume
# ret:  true if the token was consumed
pub fun eat(p: *Parser, kind: token.Kind) bool {
    if (at(p, kind)) {
        advance(p);
        ret true;
    }
    ret false;
}

# at_kw: reports whether the current IDENT token matches the given keyword text.
# ---
# p:   parser state
# kw:  keyword to match against the current IDENT's source text
# ret: true when the current token is an IDENT whose text equals kw
pub fun at_kw(p: *Parser, kw: str) bool {
    if (!at(p, token.KIND_IDENT)) { ret false; }
    val t: token.Token = current(p);
    ret str_region_equals(p.tokens.source, t.span.offset, t.span.len, kw);
}

# eat_kw: consumes the current IDENT token if it matches the given keyword text.
# ---
# p:   parser state
# kw:  keyword to match and consume
# ret: true if the keyword was consumed
pub fun eat_kw(p: *Parser, kw: str) bool {
    if (at_kw(p, kw)) {
        advance(p);
        ret true;
    }
    ret false;
}

# expect: consumes the current token when its kind matches, emitting an error otherwise.
# ---
# p:       parser state
# kind:    expected token kind
# message: diagnostic text used when the expected token is absent
# ret:     true if the expected token was consumed; false after emitting an error
pub fun expect(p: *Parser, kind: token.Kind, message: str) bool {
    if (eat(p, kind)) {
        ret true;
    }
    error_at_current(p, message);
    ret false;
}

# error_at_current: emits an error-severity diagnostic pinned to the current token's span.
# ---
# p:       parser state
# message: diagnostic text to record
pub fun error_at_current(p: *Parser, message: str) {
    if (p.panic) { ret; }
    p.panic = true;
    val t: token.Token = current(p);
    val r: Result[bool, str] = diag.error(p.diags, p.tokens.file_id, t.span, message);
    if (is_err[bool, str](r)) { ret; }
}

# error_at: emits an error-severity diagnostic pinned to the given span.
# ---
# p:       parser state
# span:    span to pin the diagnostic to
# message: diagnostic text to record
pub fun error_at(p: *Parser, span: token.Span, message: str) {
    if (p.panic) { ret; }
    p.panic = true;
    val r: Result[bool, str] = diag.error(p.diags, p.tokens.file_id, span, message);
    if (is_err[bool, str](r)) { ret; }
}

# sync_to: advances until the current token is EOF or matches one of the synchronization kinds, then clears panic.
# ---
# p:  parser state
# k0: first synchronization kind
# k1: second synchronization kind (use KIND_ERROR if only one is needed)
# k2: third synchronization kind (use KIND_ERROR if not needed)
pub fun sync_to(p: *Parser, k0: token.Kind, k1: token.Kind, k2: token.Kind) {
    for (!at(p, token.KIND_EOF)) {
        val k: token.Kind = current(p).kind;
        if (k == k0 || k == k1 || k == k2) {
            p.panic = false;
            ret;
        }
        advance(p);
    }
    p.panic = false;
}

# at_eof: true when the parser has consumed every token up to and including EOF.
# ---
# p:   parser state
# ret: true if no more real tokens remain
pub fun at_eof(p: *Parser) bool {
    ret at(p, token.KIND_EOF);
}

# span_of: joins two spans into the minimal span that covers both.
# ---
# start: span at the beginning of the region
# end:   span at the end of the region
# ret:   span from start.offset to end.offset + end.len
pub fun span_of(start: token.Span, end: token.Span) token.Span {
    var s: token.Span;
    s.offset = start.offset;
    s.len    = (end.offset + end.len) - start.offset;
    ret s;
}

# push_expr: appends an Expr to the AST, reporting an allocation error and returning EXPR_NIL on failure.
# ---
# p:   parser state
# e:   expression to append
# ret: the new ExprId, or EXPR_NIL if storage could not be allocated
pub fun push_expr(p: *Parser, e: expr.Expr) id.ExprId {
    val r: Result[id.ExprId, str] = ast.add_expr(p.ast, e);
    if (is_err[id.ExprId, str](r)) {
        error_at(p, e.span, "out of memory while parsing expression");
        ret id.EXPR_NIL;
    }
    ret unwrap_ok[id.ExprId, str](r);
}

# push_stmt: appends a Stmt to the AST, reporting an allocation error and returning STMT_NIL on failure.
# ---
# p:   parser state
# s:   statement to append
# ret: the new StmtId, or STMT_NIL if storage could not be allocated
pub fun push_stmt(p: *Parser, s: stmt.Stmt) id.StmtId {
    val r: Result[id.StmtId, str] = ast.add_stmt(p.ast, s);
    if (is_err[id.StmtId, str](r)) {
        error_at(p, s.span, "out of memory while parsing statement");
        ret id.STMT_NIL;
    }
    ret unwrap_ok[id.StmtId, str](r);
}

# push_decl: appends a Decl to the AST, reporting an allocation error and returning DECL_NIL on failure.
# ---
# p:   parser state
# d:   declaration to append
# ret: the new DeclId, or DECL_NIL if storage could not be allocated
pub fun push_decl(p: *Parser, d: decl.Decl) id.DeclId {
    val r: Result[id.DeclId, str] = ast.add_decl(p.ast, d);
    if (is_err[id.DeclId, str](r)) {
        error_at(p, d.span, "out of memory while parsing declaration");
        ret id.DECL_NIL;
    }
    ret unwrap_ok[id.DeclId, str](r);
}

# push_type: appends a Type to the AST, reporting an allocation error and returning TYPE_NIL on failure.
# ---
# p:   parser state
# t:   type to append
# ret: the new TypeId, or TYPE_NIL if storage could not be allocated
pub fun push_type(p: *Parser, t: m_type.Type) id.TypeId {
    val r: Result[id.TypeId, str] = ast.add_type(p.ast, t);
    if (is_err[id.TypeId, str](r)) {
        error_at(p, t.span, "out of memory while parsing type");
        ret id.TYPE_NIL;
    }
    ret unwrap_ok[id.TypeId, str](r);
}

# push_module: appends a Module to the AST, reporting an allocation error and returning MODULE_NIL on failure.
# ---
# p:   parser state
# m:   module to append
# ret: the new ModuleId, or MODULE_NIL if storage could not be allocated
pub fun push_module(p: *Parser, m: module.Module) id.ModuleId {
    val r: Result[id.ModuleId, str] = ast.add_module(p.ast, m);
    if (is_err[id.ModuleId, str](r)) {
        error_at(p, m.span, "out of memory while parsing module");
        ret id.MODULE_NIL;
    }
    ret unwrap_ok[id.ModuleId, str](r);
}

# push_decl_id: appends a DeclId to ast.decl_ids, returning 0 on failure (caller must check p.panic).
# ---
# p:   parser state
# id_: DeclId to append
# ret: index into ast.decl_ids, or 0 on allocation failure
pub fun push_decl_id(p: *Parser, id_: id.DeclId) u32 {
    val r: Result[u32, str] = ast.add_decl_id(p.ast, id_);
    if (is_err[u32, str](r)) {
        error_at_current(p, "out of memory while parsing");
        ret 0;
    }
    ret unwrap_ok[u32, str](r);
}

# push_stmt_id: appends a StmtId to ast.stmt_ids, returning 0 on failure (caller must check p.panic).
# ---
# p:   parser state
# id_: StmtId to append
# ret: index into ast.stmt_ids, or 0 on allocation failure
pub fun push_stmt_id(p: *Parser, id_: id.StmtId) u32 {
    val r: Result[u32, str] = ast.add_stmt_id(p.ast, id_);
    if (is_err[u32, str](r)) {
        error_at_current(p, "out of memory while parsing");
        ret 0;
    }
    ret unwrap_ok[u32, str](r);
}

# push_expr_id: appends an ExprId to ast.expr_ids, returning 0 on failure (caller must check p.panic).
# ---
# p:   parser state
# id_: ExprId to append
# ret: index into ast.expr_ids, or 0 on allocation failure
pub fun push_expr_id(p: *Parser, id_: id.ExprId) u32 {
    val r: Result[u32, str] = ast.add_expr_id(p.ast, id_);
    if (is_err[u32, str](r)) {
        error_at_current(p, "out of memory while parsing");
        ret 0;
    }
    ret unwrap_ok[u32, str](r);
}

# push_type_id: appends a TypeId to ast.type_ids, returning 0 on failure (caller must check p.panic).
# ---
# p:   parser state
# id_: TypeId to append
# ret: index into ast.type_ids, or 0 on allocation failure
pub fun push_type_id(p: *Parser, id_: id.TypeId) u32 {
    val r: Result[u32, str] = ast.add_type_id(p.ast, id_);
    if (is_err[u32, str](r)) {
        error_at_current(p, "out of memory while parsing");
        ret 0;
    }
    ret unwrap_ok[u32, str](r);
}
