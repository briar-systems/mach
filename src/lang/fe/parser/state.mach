# mach.lang.fe.parser.state: the Parser record plus the shared helpers every other parser file builds on.
#
# provides cursor (current, peek, advance), predicate (at, at_kw, eat,
# eat_kw), error reporting (error_at, error_at_current, expect, sync_to),
# span arithmetic (span_of), and the push_* wrappers that log allocation
# failures and return *_NIL rather than aborting. all sibling files depend
# on this one; nothing here depends back on them.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.string.str;
use std.types.string.str_region_equals;
use std.types.size.usize;
use std.types.result.Result;
use std.types.result.is_err;
use std.types.result.unwrap_ok;

use std.allocator.deallocate;

use token:  mach.lang.fe.token;
use lexer:  mach.lang.fe.lexer;
use diag:   mach.lang.diagnostic;
use ast:    mach.lang.fe.ast;
use pool:   mach.lang.fe.pool;
use id:     mach.lang.fe.ast.id;
use expr:   mach.lang.fe.ast.expr;
use stmt:   mach.lang.fe.ast.stmt;
use decl:   mach.lang.fe.ast.decl;
use m_type: mach.lang.fe.ast.type;
use module: mach.lang.fe.ast.module;

# Parser: parser cursor and output sinks; lives for the duration of one parse.
# ---
# tokens: stream produced by the lexer
# pos:    index into tokens.tokens of the current token
# ast:    output AST; nodes are appended here as parsing progresses
# diags:  diagnostic sink for parse errors and recovery messages
# panic:  true while skipping tokens during error recovery; cleared at the next synchronization point
# fatal:  sticky flag set by any allocation failure during parsing, independent
#         of panic so an OOM hit mid-recovery is never swallowed; the driver
#         treats a fatal parse as failed rather than consuming a corrupt AST
pub rec Parser {
    tokens: *lexer.TokenStream;
    pos:    usize;
    ast:    *ast.Ast;
    diags:  *diag.DiagList;
    panic:  bool;
    fatal:  bool;
}

# init: initializes a Parser over the given token stream, filling output into ast and diags.
# ---
# tokens: lexer output to consume
# out:    AST to append parsed nodes into
# diags:  diagnostic sink
# ret:    a fresh Parser positioned at the first token
pub fun init(tokens: *lexer.TokenStream, out: *ast.Ast, diags: *diag.DiagList) Parser {
    var p: Parser;
    p.tokens = tokens;
    p.pos    = 0;
    p.ast    = out;
    p.diags  = diags;
    p.panic  = false;
    p.fatal  = false;
    ret p;
}

# current: returns the current token without consuming it.
# ---
# p:   parser state
# ret: token at p.pos
pub fun current(p: *Parser) token.Token {
    ret p.tokens.tokens[p.pos];
}

# peek: returns the token at an offset from the current position without consuming it.
# ---
# p:      parser state
# offset: positive offset from the current position
# ret:    token at p.pos + offset, or the trailing EOF if past the end
pub fun peek(p: *Parser, offset: usize) token.Token {
    val idx: usize = p.pos + offset;
    if (idx >= p.tokens.len) {
        ret p.tokens.tokens[p.tokens.len - 1];
    }
    ret p.tokens.tokens[idx];
}

# advance: consumes the current token and returns it.
# ---
# p:   parser state
# ret: the token that was current before the call
pub fun advance(p: *Parser) token.Token {
    val t: token.Token = p.tokens.tokens[p.pos];
    if (t.kind != token.KIND_EOF) {
        p.pos = p.pos + 1;
    }
    ret t;
}

# at: reports whether the current token has the given kind.
# ---
# p:    parser state
# kind: token kind to test against
# ret:  true if current().kind == kind
pub fun at(p: *Parser, kind: token.Kind) bool {
    ret current(p).kind == kind;
}

# eat: consumes the current token if its kind matches, reporting whether it did.
# ---
# p:    parser state
# kind: token kind to match and consume
# ret:  true if the token was consumed
pub fun eat(p: *Parser, kind: token.Kind) bool {
    if (at(p, kind)) {
        advance(p);
        ret true;
    }
    ret false;
}

# at_kw: reports whether the current IDENT token matches the given keyword text.
# ---
# p:   parser state
# kw:  keyword to match against the current IDENT's source text
# ret: true when the current token is an IDENT whose text equals kw
pub fun at_kw(p: *Parser, kw: str) bool {
    if (!at(p, token.KIND_IDENT)) { ret false; }
    val t: token.Token = current(p);
    ret str_region_equals(p.tokens.source, t.span.offset, t.span.len, kw);
}

# eat_kw: consumes the current IDENT token if it matches the given keyword text.
# ---
# p:   parser state
# kw:  keyword to match and consume
# ret: true if the keyword was consumed
pub fun eat_kw(p: *Parser, kw: str) bool {
    if (at_kw(p, kw)) {
        advance(p);
        ret true;
    }
    ret false;
}

# expect: consumes the current token when its kind matches, emitting an error otherwise.
# ---
# p:       parser state
# kind:    expected token kind
# message: diagnostic text used when the expected token is absent
# ret:     true if the expected token was consumed; false after emitting an error
pub fun expect(p: *Parser, kind: token.Kind, message: str) bool {
    if (eat(p, kind)) {
        ret true;
    }
    error_at_current(p, message);
    ret false;
}

# error_at_current: emits an error-severity diagnostic pinned to the current token's span.
# ---
# p:       parser state
# message: diagnostic text to record
pub fun error_at_current(p: *Parser, message: str) {
    if (p.panic) { ret; }
    p.panic = true;
    val t: token.Token = current(p);
    val r: Result[bool, str] = diag.error(p.diags, p.tokens.file_id, t.span, message);
    if (is_err[bool, str](r)) { ret; }
}

# error_at: emits an error-severity diagnostic pinned to the given span.
# ---
# p:       parser state
# span:    span to pin the diagnostic to
# message: diagnostic text to record
pub fun error_at(p: *Parser, span: token.Span, message: str) {
    if (p.panic) { ret; }
    p.panic = true;
    val r: Result[bool, str] = diag.error(p.diags, p.tokens.file_id, span, message);
    if (is_err[bool, str](r)) { ret; }
}

# fatal_oom_at: records an unrecoverable allocation failure at `span`. an OOM is
# not recoverable by error recovery, so this sets the sticky `fatal` flag and
# emits the diagnostic directly, bypassing the `panic` guard that would otherwise
# swallow an allocation failure hit while already recovering. the driver checks
# `fatal` after the parse and refuses to consume the (now incomplete) AST.
pub fun fatal_oom_at(p: *Parser, span: token.Span) {
    # report the first allocation failure once: the flag is sticky and the driver
    # aborts after parse, so a later failure during teardown needs no new message.
    if (p.fatal) { ret; }
    p.fatal = true;
    val r: Result[bool, str] = diag.error(p.diags, p.tokens.file_id, span, "out of memory while parsing");
    if (is_err[bool, str](r)) { ret; }
}

# fatal_oom: fatal_oom_at pinned to the current token's span.
pub fun fatal_oom(p: *Parser) {
    fatal_oom_at(p, current(p).span);
}

# sync_to: advances until the current token is EOF or matches one of the synchronization kinds, then clears panic.
# ---
# p:  parser state
# k0: first synchronization kind
# k1: second synchronization kind (use KIND_ERROR if only one is needed)
# k2: third synchronization kind (use KIND_ERROR if not needed)
pub fun sync_to(p: *Parser, k0: token.Kind, k1: token.Kind, k2: token.Kind) {
    for (!at(p, token.KIND_EOF)) {
        val k: token.Kind = current(p).kind;
        if (k == k0 || k == k1 || k == k2) {
            p.panic = false;
            ret;
        }
        advance(p);
    }
    p.panic = false;
}

# at_decl_start: true when the current token can begin a top-level
# declaration — a `$` directive, a `pub`/`ext` flag, or one of the decl
# keywords. used to find a genuine declaration boundary during recovery.
pub fun at_decl_start(p: *Parser) bool {
    if (at(p, token.KIND_DOLLAR)) { ret true; }
    if (!at(p, token.KIND_IDENT)) { ret false; }
    ret at_kw(p, "pub") || at_kw(p, "ext")
     || at_kw(p, "use") || at_kw(p, "fwd") || at_kw(p, "fun")
     || at_kw(p, "rec") || at_kw(p, "uni") || at_kw(p, "val")
     || at_kw(p, "var") || at_kw(p, "def") || at_kw(p, "test");
}

# sync_to_decl: advance until the current token begins a top-level
# declaration (`at_decl_start`) or EOF, then clear panic. recovery at module
# or comptime-branch scope uses this so one malformed declaration does not
# turn every following body token into its own "expected a declaration"
# error — the parser realigns on the next real declaration boundary instead.
pub fun sync_to_decl(p: *Parser) {
    advance(p);
    for (!at(p, token.KIND_EOF) && !at_decl_start(p)) {
        advance(p);
    }
    p.panic = false;
}

# at_eof: true when the parser has consumed every token up to and including EOF.
# ---
# p:   parser state
# ret: true if no more real tokens remain
pub fun at_eof(p: *Parser) bool {
    ret at(p, token.KIND_EOF);
}

# span_of: joins two spans into the minimal span that covers both.
# ---
# start: span at the beginning of the region
# end:   span at the end of the region
# ret:   span from start.offset to end.offset + end.len
pub fun span_of(start: token.Span, end: token.Span) token.Span {
    var s: token.Span;
    s.offset = start.offset;
    s.len    = (end.offset + end.len) - start.offset;
    ret s;
}

# push_expr: appends an Expr to the AST, reporting an allocation error and returning EXPR_NIL on failure.
# ---
# p:   parser state
# e:   expression to append
# ret: the new ExprId, or EXPR_NIL if storage could not be allocated
pub fun push_expr(p: *Parser, e: expr.Expr) id.ExprId {
    val r: Result[id.ExprId, str] = ast.add_expr(p.ast, e);
    if (is_err[id.ExprId, str](r)) {
        fatal_oom_at(p, e.span);
        ret id.EXPR_NIL;
    }
    ret unwrap_ok[id.ExprId, str](r);
}

# push_stmt: appends a Stmt to the AST, reporting an allocation error and returning STMT_NIL on failure.
# ---
# p:   parser state
# s:   statement to append
# ret: the new StmtId, or STMT_NIL if storage could not be allocated
pub fun push_stmt(p: *Parser, s: stmt.Stmt) id.StmtId {
    val r: Result[id.StmtId, str] = ast.add_stmt(p.ast, s);
    if (is_err[id.StmtId, str](r)) {
        fatal_oom_at(p, s.span);
        ret id.STMT_NIL;
    }
    ret unwrap_ok[id.StmtId, str](r);
}

# push_decl: appends a Decl to the AST, reporting an allocation error and returning DECL_NIL on failure.
# ---
# p:   parser state
# d:   declaration to append
# ret: the new DeclId, or DECL_NIL if storage could not be allocated
pub fun push_decl(p: *Parser, d: decl.Decl) id.DeclId {
    val r: Result[id.DeclId, str] = ast.add_decl(p.ast, d);
    if (is_err[id.DeclId, str](r)) {
        fatal_oom_at(p, d.span);
        ret id.DECL_NIL;
    }
    ret unwrap_ok[id.DeclId, str](r);
}

# push_type: appends a Type to the AST, reporting an allocation error and returning TYPE_NIL on failure.
# ---
# p:   parser state
# t:   type to append
# ret: the new TypeId, or TYPE_NIL if storage could not be allocated
pub fun push_type(p: *Parser, t: m_type.Type) id.TypeId {
    val r: Result[id.TypeId, str] = ast.add_type(p.ast, t);
    if (is_err[id.TypeId, str](r)) {
        fatal_oom_at(p, t.span);
        ret id.TYPE_NIL;
    }
    ret unwrap_ok[id.TypeId, str](r);
}

# push_module: appends a Module to the AST, reporting an allocation error and returning MODULE_NIL on failure.
# ---
# p:   parser state
# m:   module to append
# ret: the new ModuleId, or MODULE_NIL if storage could not be allocated
pub fun push_module(p: *Parser, m: module.Module) id.ModuleId {
    val r: Result[id.ModuleId, str] = ast.add_module(p.ast, m);
    if (is_err[id.ModuleId, str](r)) {
        fatal_oom_at(p, m.span);
        ret id.MODULE_NIL;
    }
    ret unwrap_ok[id.ModuleId, str](r);
}

# push_decl_id: appends a DeclId to ast.decl_ids; on allocation failure it flags the parse fatal (fatal_oom) and returns 0, which flush ignores since it derives the appended count from the pool.
# ---
# p:   parser state
# id_: DeclId to append
# ret: index into ast.decl_ids, or 0 on allocation failure
pub fun push_decl_id(p: *Parser, id_: id.DeclId) u32 {
    val r: Result[u32, str] = ast.add_decl_id(p.ast, id_);
    if (is_err[u32, str](r)) {
        fatal_oom(p);
        ret 0;
    }
    ret unwrap_ok[u32, str](r);
}

# ListBuf: a temporary, contiguous buffer of elements collected while parsing
# one nested list. the matching `ast.*` pool is shared and append-only, and
# fully parsing one element can append that element's own children to the same
# pool mid-parse; buffering the parent's direct elements here and flushing them
# as one block after every nested parse keeps each node's (start, len) slice
# contiguous and disjoint. each pool keeps its own thin `*_buf_flush` helper
# that appends the buffer to its pool and frees it.
# ---
# data: heap buffer of collected elements
# len:  number of elements buffered
# cap:  allocated slots
pub rec ListBuf[T] {
    data: *T;
    len:  usize;
    cap:  usize;
}

# list_buf_init: start an empty ListBuf.
pub fun list_buf_init[T]() ListBuf[T] {
    var b: ListBuf[T];
    b.data = nil;
    b.len  = 0;
    b.cap  = 0;
    ret b;
}

# list_buf_push: buffer one element, growing on demand (seeded at 8, then
# doubling). on allocation failure it flags the parse fatal and leaves the
# buffer unchanged.
pub fun list_buf_push[T](p: *Parser, b: *ListBuf[T], x: T) {
    if (b.len == b.cap) {
        val r: Result[*T, str] = pool.grow[T](p.ast.alloc, b.data, b.cap, 8, ?b.cap);
        if (is_err[*T, str](r)) { fatal_oom(p); ret; }
        b.data = unwrap_ok[*T, str](r);
    }
    b.data[b.len] = x;
    b.len = b.len + 1;
}

# list_buf_free: release a buffer's storage and reset it to empty. the shared
# tail of every `*_buf_flush`.
pub fun list_buf_free[T](p: *Parser, b: *ListBuf[T]) {
    if (b.data != nil && b.cap > 0) {
        deallocate[T](p.ast.alloc, b.data, b.cap);
    }
    b.data = nil;
    b.len  = 0;
    b.cap  = 0;
}

# decl_id_buf_flush: append the buffered DeclIds to `ast.decl_ids` as one
# contiguous block and free the buffer. returns the pool start index of the
# block (the run's `decls_start`/`body_start`); `*out_len` receives its length.
pub fun decl_id_buf_flush(p: *Parser, b: *ListBuf[id.DeclId], out_len: *u32) u32 {
    val start: u32 = p.ast.decl_id_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        push_decl_id(p, b.data[i]);
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the ids that reached the pool.
    @out_len = (p.ast.decl_id_len::u32) - start;
    list_buf_free[id.DeclId](p, b);
    ret start;
}

# expr_id_buf_flush: append the buffered ExprIds to `ast.expr_ids` as one
# contiguous block and free the buffer. returns the pool start index of the
# block (the list's `args_start`/`elems_start`); `*out_len` receives its length.
pub fun expr_id_buf_flush(p: *Parser, b: *ListBuf[id.ExprId], out_len: *u32) u32 {
    val start: u32 = p.ast.expr_id_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        push_expr_id(p, b.data[i]);
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the ids that reached the pool.
    @out_len = (p.ast.expr_id_len::u32) - start;
    list_buf_free[id.ExprId](p, b);
    ret start;
}

# type_id_buf_flush: append the buffered TypeIds to `ast.type_ids` as one
# contiguous block and free the buffer. returns the pool start index of the
# block (the list's `args_start`/`params_start`); `*out_len` receives its length.
pub fun type_id_buf_flush(p: *Parser, b: *ListBuf[id.TypeId], out_len: *u32) u32 {
    val start: u32 = p.ast.type_id_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        push_type_id(p, b.data[i]);
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the ids that reached the pool.
    @out_len = (p.ast.type_id_len::u32) - start;
    list_buf_free[id.TypeId](p, b);
    ret start;
}

# field_init_buf_flush: append the buffered FieldInits to `ast.field_inits` as
# one contiguous block and free the buffer. returns the pool start index of the
# block (the literal's `fields_start`); `*out_len` receives its length.
pub fun field_init_buf_flush(p: *Parser, b: *ListBuf[expr.FieldInit], out_len: *u32) u32 {
    val start: u32 = p.ast.field_init_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        val r: Result[u32, str] = ast.add_field_init(p.ast, b.data[i]);
        if (is_err[u32, str](r)) { fatal_oom(p); }
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the entries that reached the pool.
    @out_len = (p.ast.field_init_len::u32) - start;
    list_buf_free[expr.FieldInit](p, b);
    ret start;
}

# typed_name_buf_flush: append the buffered TypedNames to `ast.typed_names` as
# one contiguous block and free the buffer. returns the pool start index of the
# block (the list's `params_start`/`fields_start`); `*out_len` receives its length.
pub fun typed_name_buf_flush(p: *Parser, b: *ListBuf[decl.TypedName], out_len: *u32) u32 {
    val start: u32 = p.ast.typed_name_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        val r: Result[u32, str] = ast.add_typed_name(p.ast, b.data[i]);
        if (is_err[u32, str](r)) { fatal_oom(p); }
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the entries that reached the pool.
    @out_len = (p.ast.typed_name_len::u32) - start;
    list_buf_free[decl.TypedName](p, b);
    ret start;
}

# stmt_id_buf_flush: append the buffered StmtIds to `ast.stmt_ids` as one
# contiguous block and free the buffer. returns the pool start index of the
# block (the body's `stmts_start`/`body_start`); `*out_len` receives its length.
pub fun stmt_id_buf_flush(p: *Parser, b: *ListBuf[id.StmtId], out_len: *u32) u32 {
    val start: u32 = p.ast.stmt_id_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        push_stmt_id(p, b.data[i]);
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the ids that reached the pool.
    @out_len = (p.ast.stmt_id_len::u32) - start;
    list_buf_free[id.StmtId](p, b);
    ret start;
}

# comptime_branch_buf_flush: append the buffered ComptimeBranches to
# `ast.comptime_branches` as one contiguous block and free the buffer. returns
# the pool start index of the block (the chain's `branches_start`); `*out_len`
# receives its length.
pub fun comptime_branch_buf_flush(p: *Parser, b: *ListBuf[decl.ComptimeBranch], out_len: *u32) u32 {
    val start: u32 = p.ast.comptime_branch_len::u32;
    var i: usize = 0;
    for (i < b.len) {
        val r: Result[u32, str] = ast.add_comptime_branch(p.ast, b.data[i]);
        if (is_err[u32, str](r)) { fatal_oom(p); }
        i = i + 1;
    }
    # the count actually appended, not b.len: a fatal alloc failure mid-flush
    # leaves the slice covering only the branches that reached the pool.
    @out_len = (p.ast.comptime_branch_len::u32) - start;
    list_buf_free[decl.ComptimeBranch](p, b);
    ret start;
}

# push_stmt_id: appends a StmtId to ast.stmt_ids; on allocation failure it flags the parse fatal (fatal_oom) and returns 0, which flush ignores since it derives the appended count from the pool.
# ---
# p:   parser state
# id_: StmtId to append
# ret: index into ast.stmt_ids, or 0 on allocation failure
pub fun push_stmt_id(p: *Parser, id_: id.StmtId) u32 {
    val r: Result[u32, str] = ast.add_stmt_id(p.ast, id_);
    if (is_err[u32, str](r)) {
        fatal_oom(p);
        ret 0;
    }
    ret unwrap_ok[u32, str](r);
}

# push_expr_id: appends an ExprId to ast.expr_ids; on allocation failure it flags the parse fatal (fatal_oom) and returns 0, which flush ignores since it derives the appended count from the pool.
# ---
