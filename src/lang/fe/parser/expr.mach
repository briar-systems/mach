# expression and type parsing
#
# Expressions use a recursive-descent primary stage feeding a Pratt climber for
# infix operators; types use plain recursive descent. The two grammars share one
# module because they are mutually recursive: types contain expressions (array
# lengths) and expressions contain types (casts, struct- and array-literal
# prefixes, generic arguments).

use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.type;
use mach.lang.fe.comptime;
use mach.lang.fe.lexer;
use mach.lang.fe.parser.state;
use mach.lang.fe.token;
use mach.lang.source;

# parses a full expression at the lowest infix binding power
# ---
# p:   parser state
# ret: ExprId of the parsed expression, or EXPR_NIL on failure
pub fun parse_expr(p: *state.Parser) id.ExprId {
    ret parse_expr_bp(p, 0);
}

# parses an expression whose infix operators bind at precedence >= min_bp
#
# This is the Pratt climber: it reads a prefix atom and its postfix chain, then
# folds in each following infix operator whose precedence clears `min_bp`,
# recursing on the right operand at the operator's right binding power.
# ---
# p:      parser state
# min_bp: minimum binding power the next infix operator must meet to bind
# ret:    ExprId of the parsed expression
pub fun parse_expr_bp(p: *state.Parser, min_bp: u8) id.ExprId {
    var lhs: id.ExprId = parse_prefix(p);
    lhs = parse_postfix(p, lhs);

    for (!state.at_eof(p)) {
        val op_tok: token.Token = state.current(p);
        val op_bp:  u8          = token.infix_precedence(op_tok.kind);
        if (op_bp == 0)     { brk; }
        if (op_bp < min_bp) { brk; }

        state.advance(p);

        var right_bp: u8 = op_bp + 1;
        if (token.is_right_assoc(op_tok.kind)) { right_bp = op_bp; }

        val rhs: id.ExprId = parse_expr_bp(p, right_bp);

        var bin: expr.ExprBinary;
        bin.op  = bin_op_from_kind(p, op_tok.kind);
        bin.lhs = lhs;
        bin.rhs = rhs;

        var node: expr.Expr;
        node.span        = span_of_expr_pair(p, lhs, rhs);
        node.kind        = expr.EXPR_KIND_BINARY;
        node.data.binary = bin;
        lhs = state.push_expr(p, node);
    }

    ret lhs;
}

# parses a type expression
# ---
# p:   parser state
# ret: TypeId of the parsed type, or an error node on failure
pub fun parse_type(p: *state.Parser) id.TypeId {
    val start: token.Token = state.current(p);

    if (state.at(p, token.KIND_CARET))    { ret parse_secret(p, start.span); }
    if (state.at(p, token.KIND_STAR))     { ret parse_ptr(p, start.span); }
    if (state.at(p, token.KIND_LBRACKET)) { ret parse_array(p, start.span); }
    if (state.at_kw(p, "fun"))            { ret parse_fun(p, start.span); }
    if (state.at_kw(p, "rec"))            { ret parse_rec_or_uni(p, start.span, type.TYPE_KIND_REC); }
    if (state.at_kw(p, "uni"))            { ret parse_rec_or_uni(p, start.span, type.TYPE_KIND_UNI); }

    # a `...` in type position is a comptime variadic pack, e.g. the type of a
    # `va: ...` parameter. distinct from a standalone trailing `...` in a
    # parameter list, which the legacy va_list variadic marker consumes before a
    # type is ever parsed.
    if (state.at(p, token.KIND_DOT_DOT_DOT)) {
        state.advance(p);
        var pk: type.Type;
        pk.span = start.span;
        pk.kind = type.TYPE_KIND_PACK;
        ret state.push_type(p, pk);
    }

    if (state.at(p, token.KIND_IDENT)) { ret parse_named(p, start.span); }

    state.error_at_current(p, "expected a type; named, '*T', '[N]T', 'fun(...)', or inline 'rec'/'uni' forms are valid here");
    var t: type.Type;
    t.span = start.span;
    t.kind = type.TYPE_KIND_ERROR;
    ret state.push_type(p, t);
}

# parses a prefix atom: literal, identifier, comptime ident, unary operator,
# parenthesized group, array or struct literal, or an error node on recovery
# ---
# p:   parser state
# ret: ExprId of the parsed prefix
fun parse_prefix(p: *state.Parser) id.ExprId {
    val t: token.Token = state.current(p);

    if (t.kind == token.KIND_LIT_INT)   { ret parse_lit_int(p); }
    if (t.kind == token.KIND_LIT_FLOAT) { ret parse_lit_float(p); }
    if (t.kind == token.KIND_LIT_CHAR)  { ret parse_lit_char(p); }
    if (t.kind == token.KIND_LIT_STR)   { ret parse_lit_str(p); }

    if (t.kind == token.KIND_MINUS)    { ret parse_unary(p, expr.UN_NEG); }
    if (t.kind == token.KIND_BANG)     { ret parse_unary(p, expr.UN_NOT); }
    if (t.kind == token.KIND_TILDE)    { ret parse_unary(p, expr.UN_BIT_NOT); }
    if (t.kind == token.KIND_QUESTION) { ret parse_unary(p, expr.UN_ADDR); }
    if (t.kind == token.KIND_AT)       { ret parse_unary(p, expr.UN_DEREF); }

    if (t.kind == token.KIND_LPAREN)   { ret parse_paren(p); }
    if (t.kind == token.KIND_DOLLAR)   { ret parse_comptime_ident(p); }
    if (t.kind == token.KIND_LBRACKET) { ret parse_array_literal(p); }

    if (t.kind == token.KIND_IDENT) {
        if (state.at_kw(p, "nil"))                           { ret parse_lit_nil(p); }
        if (!p.no_struct_lit && looks_like_typed_literal(p)) { ret parse_typed_literal(p); }
        ret parse_ident(p);
    }

    state.error_at_current(p, "expected an expression; literals, identifiers, '(', and unary operators are valid here");
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_ERROR;
    ret state.push_expr(p, node);
}

# applies the postfix operator chain to a primary expression: call, index,
# member access, field projection, and cast all bind here, left to right
# ---
# p:    parser state
# base: expression the postfix operators apply to
# ret:  ExprId after every postfix operator has been folded in
fun parse_postfix(p: *state.Parser, base: id.ExprId) id.ExprId {
    var lhs: id.ExprId = base;
    for (true) {
        val k: token.Kind = state.current(p).kind;
        if (k == token.KIND_LPAREN) { lhs = parse_call(p, lhs, 0, 0, id.EXPR_NIL); }
        or (k == token.KIND_LBRACKET) {
            val after: usize = scan_bracket_close(p, 0);
            if (after != 0 && state.peek(p, after).kind == token.KIND_LPAREN) {
                lhs = parse_bracket_call(p, lhs);
            }
            or {
                lhs = parse_index(p, lhs);
            }
        }
        or (k == token.KIND_DOT) {
            # `v.[f]` is a field projection; a plain `v.field` is a member.
            if (state.peek(p, 1).kind == token.KIND_LBRACKET) {
                lhs = parse_project(p, lhs);
            }
            or {
                lhs = parse_member(p, lhs);
            }
        }
        or (k == token.KIND_COLON_COLON) { lhs = parse_cast(p, lhs, false); }
        or (k == token.KIND_COLON_TILDE) { lhs = parse_cast(p, lhs, true); }
        or (k == token.KIND_COLON_CARET) { lhs = parse_strip(p, lhs); }
        or {
            brk;
        }
    }
    ret lhs;
}

# scans a balanced bracket region and returns the cursor offset just past its
# matching ']'
#
# Walks from the '[' at offset `bracket_off` to its matching ']' and returns the
# offset of the token immediately after it. A ';' or EOF inside the brackets
# means the region can never be a type list and is reported as 0 (unbalanced for
# this purpose). Shared by parse_bracket_call and looks_like_typed_literal so the
# two scanners cannot drift apart.
# ---
# p:           parser state
# bracket_off: cursor offset of the opening '['
# ret:         cursor offset just past the matching ']', or 0 when unbalanced
fun scan_bracket_close(p: *state.Parser, bracket_off: usize) usize {
    var i:     usize = bracket_off + 1;
    var depth: usize = 1;
    for (depth > 0) {
        val k: token.Kind = state.peek(p, i).kind;
        if (k == token.KIND_EOF || k == token.KIND_SEMI) { ret 0; }
        if (k == token.KIND_LBRACKET)                    { depth = depth + 1; }
        or (k == token.KIND_RBRACKET)                    { depth = depth - 1; }
        i = i + 1;
    }
    ret i;
}

# reports whether `k` can begin an expression (per parse_prefix)
#
# Gates the index-reading probe: a payload that cannot start an expression (a
# bare '*', for instance) is never an index and is left to the type reading.
# ---
# k:   leading token kind to test
# ret: true when a prefix parse could start with `k`
fun token_begins_expr(k: token.Kind) bool {
    ret k == token.KIND_LIT_INT   || k == token.KIND_LIT_FLOAT
     || k == token.KIND_LIT_CHAR  || k == token.KIND_LIT_STR
     || k == token.KIND_IDENT     || k == token.KIND_DOLLAR
     || k == token.KIND_MINUS     || k == token.KIND_BANG
     || k == token.KIND_TILDE     || k == token.KIND_QUESTION
     || k == token.KIND_AT        || k == token.KIND_LPAREN
     || k == token.KIND_LBRACKET;
}

# parses a postfix '[' whose matching ']' is followed by '(' - a generic call
# `callee[T, ..](args)` or an index-then-call `callee[expr](args)`
#
# The type and expression grammars overlap (a bare name is both a type and a
# value reference), so the parser cannot decide locally; it probes the payload
# against both grammars and:
#   - parses cleanly only as a type list   -> a generic call;
#   - parses cleanly only as an expression -> an index (the trailing '(' is read
#     as a separate call by the postfix loop);
#   - parses cleanly as both               -> a provisional call carrying both
#     readings, deferred to resolve, which picks by the callee's resolved kind
#     (a value indexes; a function/type takes type arguments);
#   - parses cleanly as neither            -> falls to parse_index, whose real
#     parse surfaces the diagnostic.
# The '{' typed-literal form is recognized at the prefix stage and never reaches
# here.
# ---
# p:      parser state, cursor on the '['
# callee: expression the bracket applies to
# ret:    ExprId of the resulting call or index expression
fun parse_bracket_call(p: *state.Parser, callee: id.ExprId) id.ExprId {
    val idx_probe: id.ExprId = probe_index_payload(p);
    val ty_ok:     bool      = probe_type_payload(p);

    if (ty_ok && idx_probe != id.EXPR_NIL) {
        ret parse_provisional_call(p, callee, idx_probe);
    }
    if (ty_ok) {
        ret parse_generic_call(p, callee);
    }
    ret parse_index(p, callee);
}

# speculatively reads the current '[...]' payload as a single index expression
#
# The cursor is restored and diagnostics are suppressed (via panic) so the probe
# is side-effect free except for the orphaned AST nodes it appends, which a clean
# result intentionally reuses.
# ---
# p:   parser state, cursor on the '['
# ret: ExprId of the index expression when it parses cleanly, else EXPR_NIL
fun probe_index_payload(p: *state.Parser) id.ExprId {
    if (!token_begins_expr(state.peek(p, 1).kind)) { ret id.EXPR_NIL; }

    val save_pos:   usize = p.pos;
    val save_panic: bool  = p.panic;
    p.panic = true;
    state.advance(p);                        # consume '['
    val before: usize    = p.pos;
    val e:      id.ExprId = parse_expr(p);
    val clean:  bool      = p.pos > before && !p.fatal && state.at(p, token.KIND_RBRACKET);
    p.pos   = save_pos;
    p.panic = save_panic;

    if (clean) { ret e; }
    ret id.EXPR_NIL;
}

# speculatively reads the current '[...]' payload as a generic type-argument list
#
# Like probe_index_payload it restores the cursor and suppresses diagnostics; the
# orphaned type nodes it appends are discarded (the committing parse re-reads the
# list).
# ---
# p:   parser state, cursor on the '['
# ret: true when the payload parses cleanly as a type list up to the ']'
fun probe_type_payload(p: *state.Parser) bool {
    val save_pos:   usize = p.pos;
    val save_panic: bool  = p.panic;
    p.panic = true;
    state.advance(p);                        # consume '['
    var ok: bool = false;
    if (!state.at(p, token.KIND_RBRACKET)) {
        val before: usize = p.pos;
        parse_type(p);
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RBRACKET)) { brk; }
            parse_type(p);
        }
        ok = p.pos > before && !p.fatal && state.at(p, token.KIND_RBRACKET);
    }
    p.pos   = save_pos;
    p.panic = save_panic;
    ret ok;
}

# consumes a '[T, U, ..]' type-argument list and flushes it into the shared
# type_id pool
#
# The cursor is on the '['. A nested generic type argument appends its own child
# type ids to the shared pool mid-parse, so the list is buffered and flushed as
# one contiguous block (see parse_call). Factored out of the generic-call parses
# so both readings build the list identically.
# ---
# p:       parser state, cursor on the '['
# out_len: receives the number of type arguments flushed
# ret:     start index of the flushed type-argument slice
fun parse_type_args(p: *state.Parser, out_len: *u32) u32 {
    state.advance(p);                        # consume '['

    var buf: state.ListBuf[id.TypeId] = state.list_buf_init[id.TypeId]();
    if (!state.at(p, token.KIND_RBRACKET)) {
        state.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RBRACKET)) { brk; }
            state.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        }
    }
    state.expect(p, token.KIND_RBRACKET, "expected ']' to close generic arguments");

    ret state.type_id_buf_flush(p, ?buf, out_len);
}

# parses a generic call `callee[T, U](args)`
#
# Consumes the bracketed type-arg list, then delegates to parse_call for the
# parenthesized arguments, threading the type args onto the produced ExprCall.
# ---
# p:      parser state, cursor on the '['
# callee: expression being called
# ret:    ExprId of the EXPR_KIND_CALL node
fun parse_generic_call(p: *state.Parser, callee: id.ExprId) id.ExprId {
    var type_args_len:   u32 = 0;
    val type_args_start: u32 = parse_type_args(p, ?type_args_len);
    ret parse_call(p, callee, type_args_start, type_args_len, id.EXPR_NIL);
}

# parses a provisional bracket call `callee[x](args)` whose payload read cleanly
# as both a type list and the index expression `idx`
#
# Commits the type-arg reading and, alongside it, wraps `callee[idx]` as the
# alternative index reading (index_callee) so resolve can choose between them by
# the callee's kind. `idx` is the expression the index probe already built from
# the same tokens.
# ---
# p:      parser state, cursor on the '['
# callee: expression being called or indexed
# idx:    index expression the index probe built from the payload
# ret:    ExprId of the EXPR_KIND_CALL node carrying both readings
fun parse_provisional_call(p: *state.Parser, callee: id.ExprId, idx: id.ExprId) id.ExprId {
    var type_args_len:   u32        = 0;
    val type_args_start: u32        = parse_type_args(p, ?type_args_len);
    val index_callee:    id.ExprId  = make_index(p, callee, idx);
    ret parse_call(p, callee, type_args_start, type_args_len, index_callee);
}

# builds an INDEX node `object[index]` without consuming tokens
#
# Records the index-then-call reading of a provisional bracket call. Its span
# runs from the object to the index expression.
# ---
# p:      parser state
# object: indexed expression
# index:  index expression
# ret:    ExprId of the EXPR_KIND_INDEX node
fun make_index(p: *state.Parser, object: id.ExprId, index: id.ExprId) id.ExprId {
    var node_index: expr.ExprIndex;
    node_index.object = object;
    node_index.index  = index;

    val cur:        token.Span = state.current(p).span;
    val start_span: token.Span = expr_span_or(p, object, cur);
    val end_span:   token.Span = expr_span_or(p, index, start_span);

    var node: expr.Expr;
    node.span       = state.span_of(start_span, end_span);
    node.kind       = expr.EXPR_KIND_INDEX;
    node.data.index = node_index;
    ret state.push_expr(p, node);
}

# parses an integer literal, decoding its value from the source span
#
# The token carries only a span, so the value is decoded here; otherwise every
# literal would lower as 0. A malformed literal is reported and recovers as 0.
# ---
# p:   parser state, cursor on the integer literal
# ret: ExprId of the EXPR_KIND_LIT_INT node
fun parse_lit_int(p: *state.Parser) id.ExprId {
    val t: token.Token = state.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_INT;
    val res_int: R.Result[comptime.CTValue, str] = comptime.eval_lit_int(p.tokens.source, t.span);
    if (R.is_err[comptime.CTValue, str](res_int)) {
        state.error_at(p, t.span, R.unwrap_err[comptime.CTValue, str](res_int));
        node.data.lit_int = 0;
    }
    or {
        val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_int);
        node.data.lit_int = cv.data.i::u64;
    }
    ret state.push_expr(p, node);
}

# parses a float literal, decoding its value from the source span
# ---
# p:   parser state, cursor on the float literal
# ret: ExprId of the EXPR_KIND_LIT_FLOAT node
fun parse_lit_float(p: *state.Parser) id.ExprId {
    val t: token.Token = state.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_FLOAT;
    val res_float: R.Result[comptime.CTValue, str] = comptime.eval_lit_float(p.tokens.source, t.span);
    if (R.is_err[comptime.CTValue, str](res_float)) {
        state.error_at(p, t.span, R.unwrap_err[comptime.CTValue, str](res_float));
        node.data.lit_float = 0.0;
    }
    or {
        val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_float);
        node.data.lit_float = cv.data.f;
    }
    ret state.push_expr(p, node);
}

# parses a char literal, decoding its byte value (with escapes) from the span
# ---
# p:   parser state, cursor on the char literal
# ret: ExprId of the EXPR_KIND_LIT_CHAR node
fun parse_lit_char(p: *state.Parser) id.ExprId {
    val t: token.Token = state.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_CHAR;
    val res_char: R.Result[comptime.CTValue, str] = comptime.eval_lit_char(p.tokens.source, t.span);
    if (R.is_err[comptime.CTValue, str](res_char)) {
        state.error_at(p, t.span, R.unwrap_err[comptime.CTValue, str](res_char));
        node.data.lit_char = 0;
    }
    or {
        val cv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_char);
        node.data.lit_char = cv.data.i::u32;
    }
    ret state.push_expr(p, node);
}

# parses a double-quoted string literal (null-terminated *u8)
# ---
# p:   parser state, cursor on the string literal
# ret: ExprId of the EXPR_KIND_LIT_STR node
fun parse_lit_str(p: *state.Parser) id.ExprId {
    val t: token.Token = state.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_STR;
    ret state.push_expr(p, node);
}

# parses the `nil` keyword
# ---
# p:   parser state, cursor on `nil`
# ret: ExprId of the EXPR_KIND_LIT_NIL node
fun parse_lit_nil(p: *state.Parser) id.ExprId {
    val t: token.Token = state.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_NIL;
    ret state.push_expr(p, node);
}

# parses a plain identifier reference
# ---
# p:   parser state, cursor on the identifier
# ret: ExprId of the EXPR_KIND_IDENT node
fun parse_ident(p: *state.Parser) id.ExprId {
    val t: token.Token = state.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_IDENT;
    ret state.push_expr(p, node);
}

# parses a `$ident` comptime identifier
# ---
# p:   parser state, cursor on the `$`
# ret: ExprId of the EXPR_KIND_COMPTIME_IDENT node
fun parse_comptime_ident(p: *state.Parser) id.ExprId {
    val dollar: token.Token = state.advance(p);
    var end: token.Span = dollar.span;
    if (state.at(p, token.KIND_IDENT)) {
        end = state.advance(p).span;
    }
    or {
        state.error_at_current(p, "expected an identifier after '$'");
    }

    var node: expr.Expr;
    node.span = state.span_of(dollar.span, end);
    node.kind = expr.EXPR_KIND_COMPTIME_IDENT;
    ret state.push_expr(p, node);
}

# parses a prefix unary operator and its operand
#
# Postfix chains are applied to the operand so member/call/index bind tighter
# than the unary operator.
# ---
# p:   parser state, cursor on the operator
# op:  unary operator the caller matched
# ret: ExprId of the EXPR_KIND_UNARY node
fun parse_unary(p: *state.Parser, op: expr.UnOp) id.ExprId {
    val start: token.Token = state.advance(p);
    var operand: id.ExprId = parse_prefix(p);
    operand = parse_postfix(p, operand);

    var unary: expr.ExprUnary;
    unary.op      = op;
    unary.operand = operand;

    val end_span: token.Span = expr_span_or(p, operand, start.span);

    var node: expr.Expr;
    node.span       = state.span_of(start.span, end_span);
    node.kind       = expr.EXPR_KIND_UNARY;
    node.data.unary = unary;
    ret state.push_expr(p, node);
}

# parses a parenthesized expression `(expr)`
# ---
# p:   parser state, cursor on '('
# ret: ExprId of the inner expression
fun parse_paren(p: *state.Parser) id.ExprId {
    state.advance(p);
    val inner: id.ExprId = parse_expr(p);
    state.expect(p, token.KIND_RPAREN, "expected ')' after parenthesized expression");
    ret inner;
}

# parses one call argument: an expression optionally suffixed with a `...` spread
#
# The postfix `...` pack spread, e.g. `va...`, forwards a whole comptime variadic
# pack. It is recognized only here, in call-argument position, never globally in
# parse_postfix, so it cannot collide with the legacy standalone `...` parameter
# marker (consumed in a parameter list, never after a call argument). Validity (a
# pack operand, the sole trailing argument of a pack-tailed callee) is checked in
# sema.
# ---
# p:   parser state
# ret: ExprId of the argument, wrapped in an EXPR_KIND_SPREAD node when spread
fun parse_call_arg(p: *state.Parser) id.ExprId {
    val e: id.ExprId = parse_expr(p);
    if (!state.at(p, token.KIND_DOT_DOT_DOT)) { ret e; }
    val dots: token.Token = state.advance(p);

    var sp: expr.ExprSpread;
    sp.inner = e;

    val start_span: token.Span = expr_span_or(p, e, dots.span);

    var node: expr.Expr;
    node.span        = state.span_of(start_span, dots.span);
    node.kind        = expr.EXPR_KIND_SPREAD;
    node.data.spread = sp;
    ret state.push_expr(p, node);
}

# parses a call expression `callee(args)`
#
# type_args_start/type_args_len carry any call-site generic arguments parsed by
# parse_generic_call; both are 0 for a plain call. index_callee is EXPR_NIL
# except for a provisional bracket call, where it carries the index-then-call
# reading for resolve to choose (see ExprCall.index_callee).
# ---
# p:               parser state, cursor on '('
# callee:          expression being called
# type_args_start: start index of the call's generic type-argument slice
# type_args_len:   number of generic type arguments
# index_callee:    index-then-call reading for a provisional call, else EXPR_NIL
# ret:             ExprId of the EXPR_KIND_CALL node
fun parse_call(p: *state.Parser, callee: id.ExprId, type_args_start: u32, type_args_len: u32, index_callee: id.ExprId) id.ExprId {
    state.advance(p);

    # buffer the arguments rather than pushing them to the shared expr_id pool
    # as they are parsed: an argument that is itself a call or array literal
    # appends its own child ids to the same pool mid-parse, which would split
    # this list's (start, len) slice. flushing the buffer as one contiguous
    # block after parsing keeps the slice intact.
    var buf: state.ListBuf[id.ExprId] = state.list_buf_init[id.ExprId]();
    if (!state.at(p, token.KIND_RPAREN)) {
        state.list_buf_push[id.ExprId](p, ?buf, parse_call_arg(p));
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RPAREN)) { brk; }
            state.list_buf_push[id.ExprId](p, ?buf, parse_call_arg(p));
        }
    }

    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RPAREN, "expected ')' to close call arguments");

    var args_len:   u32 = 0;
    val args_start: u32 = state.expr_id_buf_flush(p, ?buf, ?args_len);

    var call: expr.ExprCall;
    call.callee          = callee;
    call.args_start      = args_start;
    call.args_len        = args_len;
    call.type_args_start = type_args_start;
    call.type_args_len   = type_args_len;
    call.index_callee    = index_callee;

    val start_span: token.Span = expr_span_or(p, callee, close.span);

    var node: expr.Expr;
    node.span      = state.span_of(start_span, close.span);
    node.kind      = expr.EXPR_KIND_CALL;
    node.data.call = call;
    ret state.push_expr(p, node);
}

# parses an index expression `obj[idx]`
# ---
# p:      parser state, cursor on '['
# object: indexed expression
# ret:    ExprId of the EXPR_KIND_INDEX node
fun parse_index(p: *state.Parser, object: id.ExprId) id.ExprId {
    state.advance(p);
    val idx: id.ExprId = parse_expr(p);
    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACKET, "expected ']' to close index expression");

    var index: expr.ExprIndex;
    index.object = object;
    index.index  = idx;

    val start_span: token.Span = expr_span_or(p, object, close.span);

    var node: expr.Expr;
    node.span       = state.span_of(start_span, close.span);
    node.kind       = expr.EXPR_KIND_INDEX;
    node.data.index = index;
    ret state.push_expr(p, node);
}

# parses a member access `obj.field`
# ---
# p:      parser state, cursor on '.'
# object: expression whose member is accessed
# ret:    ExprId of the EXPR_KIND_MEMBER node, or an error node on failure
fun parse_member(p: *state.Parser, object: id.ExprId) id.ExprId {
    state.advance(p);
    if (!state.at(p, token.KIND_IDENT)) {
        state.error_at_current(p, "expected field name after '.'");
        var err_node: expr.Expr;
        err_node.span = state.current(p).span;
        err_node.kind = expr.EXPR_KIND_ERROR;
        ret state.push_expr(p, err_node);
    }
    val name_tok: token.Token = state.advance(p);

    var member: expr.ExprMember;
    member.object = object;
    member.name   = name_tok.span;

    val start_span: token.Span = expr_span_or(p, object, name_tok.span);

    var node: expr.Expr;
    node.span        = state.span_of(start_span, name_tok.span);
    node.kind        = expr.EXPR_KIND_MEMBER;
    node.data.member = member;
    ret state.push_expr(p, node);
}

# parses a field projection `v.[f]`
#
# The field operand `f` is a comptime field descriptor (the `$each` loop
# variable). The leading `.` is the current token; `[` immediately follows.
# ---
# p:      parser state, cursor on '.'
# object: expression whose field is projected
# ret:    ExprId of the EXPR_KIND_PROJECT node
fun parse_project(p: *state.Parser, object: id.ExprId) id.ExprId {
    state.expect(p, token.KIND_DOT, "expected '.' before '[' in a field projection");
    state.expect(p, token.KIND_LBRACKET, "expected '[' in a field projection");
    val field: id.ExprId = parse_expr(p);
    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACKET, "expected ']' to close a field projection");

    var proj: expr.ExprProject;
    proj.object = object;
    proj.field  = field;

    val start_span: token.Span = expr_span_or(p, object, close.span);

    var node: expr.Expr;
    node.span         = state.span_of(start_span, close.span);
    node.kind         = expr.EXPR_KIND_PROJECT;
    node.data.project = proj;
    ret state.push_expr(p, node);
}

# parses a cast expression: `value::Type` (value convert) or `value:~Type` (bit
# reinterpret)
# ---
# p:           parser state, cursor on the cast operator
# value:       expression being cast
# reinterpret: true for `:~` (bit reinterpret), false for `::` (value convert)
# ret:         ExprId of the EXPR_KIND_CAST node
fun parse_cast(p: *state.Parser, value: id.ExprId, reinterpret: bool) id.ExprId {
    state.advance(p);
    val ty: id.TypeId = parse_type(p);

    var cast: expr.ExprCast;
    cast.value       = value;
    cast.ty          = ty;
    cast.reinterpret = reinterpret;

    val cur:        token.Span = state.current(p).span;
    val start_span: token.Span = expr_span_or(p, value, cur);
    val end_span:   token.Span = type_span_or(p, ty, start_span);

    var node: expr.Expr;
    node.span      = state.span_of(start_span, end_span);
    node.kind      = expr.EXPR_KIND_CAST;
    node.data.cast = cast;
    ret state.push_expr(p, node);
}

# parses a secret-qualifier strip cast `value:^` or `value:^Type`
#
# `:^` removes the `^` qualifier from the operand's type. the target type is
# optional and, when present, a named type: a following IDENT (which cannot
# continue an expression here) is read as the target, while any other lead
# leaves a bare strip so the postfix/infix machinery still binds `*`/`[` as a
# multiply/index on the stripped value. flow-typing semantics land in #1645; the
# parser only records the node.
# ---
# p:     parser state, cursor on ':^'
# value: expression whose qualifier is stripped
# ret:   ExprId of the EXPR_KIND_STRIP node
fun parse_strip(p: *state.Parser, value: id.ExprId) id.ExprId {
    val op: token.Token = state.current(p);
    state.advance(p);

    var ty: id.TypeId = id.TYPE_NIL;
    if (state.at(p, token.KIND_IDENT)) {
        ty = parse_type(p);
    }

    var strip: expr.ExprStrip;
    strip.value = value;
    strip.ty    = ty;

    val start_span: token.Span = expr_span_or(p, value, op.span);
    var end_span:   token.Span = op.span;
    if (ty != id.TYPE_NIL) { end_span = type_span_or(p, ty, op.span); }

    var node: expr.Expr;
    node.span       = state.span_of(start_span, end_span);
    node.kind       = expr.EXPR_KIND_STRIP;
    node.data.strip = strip;
    ret state.push_expr(p, node);
}

# parses an array literal `[N]T{a, b, c}`
# ---
# p:   parser state, cursor on '['
# ret: ExprId of the EXPR_KIND_ARRAY_LIT node
fun parse_array_literal(p: *state.Parser) id.ExprId {
    val start: token.Token = state.current(p);
    val ty: id.TypeId = parse_type(p);
    state.expect(p, token.KIND_LBRACE, "expected '{' after array type in array literal");

    # buffer the elements: an element that is itself a call or array literal
    # appends its own child ids to the shared expr_id pool mid-parse, so flush
    # the parent's direct elements as one contiguous block afterward (see
    # parse_call).
    var buf: state.ListBuf[id.ExprId] = state.list_buf_init[id.ExprId]();
    if (!state.at(p, token.KIND_RBRACE)) {
        state.list_buf_push[id.ExprId](p, ?buf, parse_expr(p));
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RBRACE)) { brk; }
            state.list_buf_push[id.ExprId](p, ?buf, parse_expr(p));
        }
    }

    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACE, "expected '}' to close array literal");

    var elems_len:   u32 = 0;
    val elems_start: u32 = state.expr_id_buf_flush(p, ?buf, ?elems_len);

    var array: expr.ExprArrayLit;
    array.ty          = ty;
    array.elems_start = elems_start;
    array.elems_len   = elems_len;

    var node: expr.Expr;
    node.span           = state.span_of(start.span, close.span);
    node.kind           = expr.EXPR_KIND_ARRAY_LIT;
    node.data.array_lit = array;
    ret state.push_expr(p, node);
}

# parses a struct literal `Name{field: value, ...}` or `Name[args]{...}`
#
# The type prefix is already recognized by looks_like_typed_literal.
# ---
# p:   parser state, cursor on the type prefix
# ret: ExprId of the EXPR_KIND_STRUCT_LIT node
fun parse_typed_literal(p: *state.Parser) id.ExprId {
    val start_tok: token.Token = state.current(p);
    val ty: id.TypeId = parse_type(p);
    state.expect(p, token.KIND_LBRACE, "expected '{' after type in struct literal");

    # buffer the fields: a field initializer may be a nested struct literal
    # that appends its own FieldInits to the shared pool mid-parse, so flush
    # this literal's fields as one contiguous block afterward (see parse_call).
    var buf: state.ListBuf[expr.FieldInit] = state.list_buf_init[expr.FieldInit]();
    if (!state.at(p, token.KIND_RBRACE)) {
        if (!parse_field_init(p, ?buf)) {
            state.sync_to(p, token.KIND_RBRACE, token.KIND_EOF, token.KIND_EOF);
        }
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RBRACE)) { brk; }
            if (!parse_field_init(p, ?buf)) {
                state.sync_to(p, token.KIND_RBRACE, token.KIND_EOF, token.KIND_EOF);
                brk;
            }
        }
    }

    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACE, "expected '}' to close struct literal");

    var fields_len:   u32 = 0;
    val fields_start: u32 = state.field_init_buf_flush(p, ?buf, ?fields_len);

    var lit: expr.ExprStructLit;
    lit.ty           = ty;
    lit.fields_start = fields_start;
    lit.fields_len   = fields_len;

    var node: expr.Expr;
    node.span            = state.span_of(start_tok.span, close.span);
    node.kind            = expr.EXPR_KIND_STRUCT_LIT;
    node.data.struct_lit = lit;
    ret state.push_expr(p, node);
}

# parses `name: value` and buffers it into `buf`
#
# The field is buffered, not pushed to ast.field_inits directly, so a nested
# struct-literal value cannot split the enclosing literal's field slice.
# ---
# p:   parser state, cursor on the field name
# buf: field-init buffer to append the parsed field to
# ret: true on success, false on syntax error
fun parse_field_init(p: *state.Parser, buf: *state.ListBuf[expr.FieldInit]) bool {
    if (!state.at(p, token.KIND_IDENT)) {
        state.error_at_current(p, "expected field name in struct literal");
        ret false;
    }
    val name: token.Span = state.advance(p).span;
    state.expect(p, token.KIND_COLON, "expected ':' between field name and value");
    val value: id.ExprId = parse_expr(p);

    var fi: expr.FieldInit;
    fi.name  = name;
    fi.value = value;
    state.list_buf_push[expr.FieldInit](p, buf, fi);
    ret true;
}

# reports whether the current token sequence looks like `Name(.Name)*([args])?{`,
# the tell-tale shape of a struct literal's type prefix followed by its body
# ---
# p:   parser state
# ret: true when the lookahead matches a struct-literal type prefix
fun looks_like_typed_literal(p: *state.Parser) bool {
    if (state.current(p).kind != token.KIND_IDENT) { ret false; }

    var i: usize = 1;
    for (state.peek(p, i).kind == token.KIND_DOT && state.peek(p, i + 1).kind == token.KIND_IDENT) {
        i = i + 2;
    }

    if (state.peek(p, i).kind == token.KIND_LBRACKET) {
        val after: usize = scan_bracket_close(p, i);
        if (after == 0) { ret false; }
        i = after;
    }

    ret state.peek(p, i).kind == token.KIND_LBRACE;
}

# maps a token kind to its corresponding BinOp
#
# Paired with token.infix_precedence: the Pratt loop only calls this for kinds
# with nonzero infix precedence, so every operator listed there must be mapped
# here. `=` is the sole assignment mapping; an unmapped kind means the two tables
# have drifted out of sync and is reported rather than silently parsed as an
# assignment.
# ---
# p:    parser state
# kind: token kind of the matched infix operator
# ret:  the BinOp the operator maps to
fun bin_op_from_kind(p: *state.Parser, kind: token.Kind) expr.BinOp {
    if (kind == token.KIND_PLUS)      { ret expr.BIN_ADD; }
    if (kind == token.KIND_MINUS)     { ret expr.BIN_SUB; }
    if (kind == token.KIND_STAR)      { ret expr.BIN_MUL; }
    if (kind == token.KIND_SLASH)     { ret expr.BIN_DIV; }
    if (kind == token.KIND_PERCENT)   { ret expr.BIN_MOD; }
    if (kind == token.KIND_EQ_EQ)     { ret expr.BIN_EQ; }
    if (kind == token.KIND_BANG_EQ)   { ret expr.BIN_NEQ; }
    if (kind == token.KIND_LT)        { ret expr.BIN_LT; }
    if (kind == token.KIND_LT_EQ)     { ret expr.BIN_LEQ; }
    if (kind == token.KIND_GT)        { ret expr.BIN_GT; }
    if (kind == token.KIND_GT_EQ)     { ret expr.BIN_GEQ; }
    if (kind == token.KIND_AMP_AMP)   { ret expr.BIN_AND; }
    if (kind == token.KIND_PIPE_PIPE) { ret expr.BIN_OR; }
    if (kind == token.KIND_AMP)       { ret expr.BIN_BIT_AND; }
    if (kind == token.KIND_PIPE)      { ret expr.BIN_BIT_OR; }
    if (kind == token.KIND_CARET)     { ret expr.BIN_BIT_XOR; }
    if (kind == token.KIND_LT_LT)     { ret expr.BIN_SHL; }
    if (kind == token.KIND_GT_GT)     { ret expr.BIN_SHR; }
    if (kind == token.KIND_EQ)        { ret expr.BIN_ASSIGN; }

    state.fatal_ice_at(p, state.current(p).span, "internal compiler error: infix operator has no binary-operator mapping");
    ret expr.BIN_ASSIGN;
}

# computes the span covering two expressions, falling back to the current token
# for either that is EXPR_NIL
# ---
# p:   parser state
# lhs: left expression
# rhs: right expression
# ret: span from lhs's start to rhs's end
fun span_of_expr_pair(p: *state.Parser, lhs: id.ExprId, rhs: id.ExprId) token.Span {
    val cur: token.Span = state.current(p).span;
    ret state.span_of(expr_span_or(p, lhs, cur), expr_span_or(p, rhs, cur));
}

# span of expression `eid`, or `fallback` when it is EXPR_NIL
# ---
# p:        parser state
# eid:      expression to read the span of
# fallback: span to use when `eid` is EXPR_NIL
# ret:      the expression's span, or `fallback`
fun expr_span_or(p: *state.Parser, eid: id.ExprId, fallback: token.Span) token.Span {
    if (eid == id.EXPR_NIL) { ret fallback; }
    ret O.unwrap[*expr.Expr](ast.get_expr(p.ast, eid)).span;
}

# span of type `tid`, or `fallback` when `tid` is TYPE_NIL
# ---
# p:        parser state
# tid:      type to read the span of
# fallback: span to use when `tid` is TYPE_NIL
# ret:      the type's span, or `fallback`
fun type_span_or(p: *state.Parser, tid: id.TypeId, fallback: token.Span) token.Span {
    if (tid == id.TYPE_NIL) { ret fallback; }
    ret O.unwrap[*type.Type](ast.get_type(p.ast, tid)).span;
}

# parses a named type, including dotted paths and optional generic arguments
# ---
# p:     parser state, cursor on the first path identifier
# start: span of the first identifier token in the path
# ret:   TypeId of the resulting TYPE_KIND_NAMED node
fun parse_named(p: *state.Parser, start: token.Span) id.TypeId {
    var last: token.Span = state.advance(p).span;

    for (state.at(p, token.KIND_DOT) && state.peek(p, 1).kind == token.KIND_IDENT) {
        state.advance(p);
        last = state.advance(p).span;
    }

    val path_span: token.Span = state.span_of(start, last);

    var args_start: u32        = 0;
    var args_len:   u32        = 0;
    var end:        token.Span = last;

    if (state.eat(p, token.KIND_LBRACKET)) {
        # buffer the generic arguments: a nested generic type argument appends
        # its own child type ids to the shared type_id pool mid-parse, so flush
        # this list as one contiguous block afterward (see parse_call).
        var buf: state.ListBuf[id.TypeId] = state.list_buf_init[id.TypeId]();
        if (!state.at(p, token.KIND_RBRACKET)) {
            state.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
            for (state.eat(p, token.KIND_COMMA)) {
                if (state.at(p, token.KIND_RBRACKET)) { brk; }
                state.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
            }
        }
        val close: token.Token = state.current(p);
        state.expect(p, token.KIND_RBRACKET, "expected ']' to close generic arguments");
        end = close.span;
        args_start = state.type_id_buf_flush(p, ?buf, ?args_len);
    }

    var named: type.TypeNamed;
    named.name       = path_span;
    named.args_start = args_start;
    named.args_len   = args_len;

    var t: type.Type;
    t.span       = state.span_of(start, end);
    t.kind       = type.TYPE_KIND_NAMED;
    t.data.named = named;
    ret state.push_type(p, t);
}

# parses a pointer type `*T`
# ---
# p:     parser state, cursor on '*'
# start: span of the leading '*' token
# ret:   TypeId of the resulting TYPE_KIND_PTR node
fun parse_ptr(p: *state.Parser, start: token.Span) id.TypeId {
    state.advance(p);
    val inner: id.TypeId = parse_type(p);

    var ptr: type.TypePtr;
    ptr.pointee = inner;

    val end_span: token.Span = type_span_or(p, inner, start);

    var t: type.Type;
    t.span     = state.span_of(start, end_span);
    t.kind     = type.TYPE_KIND_PTR;
    t.data.ptr = ptr;
    ret state.push_type(p, t);
}

# parses a secret-qualified type `^T`
#
# `^` binds to the type constructor immediately to its right, so the qualifier
# nests with `*` and `[N]` through the recursion (`*^u8`, `^*u8`, `[N]^u8`). the
# infix XOR `^` never reaches here: a type never begins with an infix operator.
# ---
# p:     parser state, cursor on '^'
# start: span of the leading '^' token
# ret:   TypeId of the resulting TYPE_KIND_SECRET node
fun parse_secret(p: *state.Parser, start: token.Span) id.TypeId {
    state.advance(p);
    val inner: id.TypeId = parse_type(p);

    var secret: type.TypeSecret;
    secret.inner = inner;

    val end_span: token.Span = type_span_or(p, inner, start);

    var t: type.Type;
    t.span        = state.span_of(start, end_span);
    t.kind        = type.TYPE_KIND_SECRET;
    t.data.secret = secret;
    ret state.push_type(p, t);
}

# parses a fixed-length array type `[N]T`
# ---
# p:     parser state, cursor on '['
# start: span of the leading '[' token
# ret:   TypeId of the resulting TYPE_KIND_ARRAY node
fun parse_array(p: *state.Parser, start: token.Span) id.TypeId {
    state.advance(p);
    val length: id.ExprId = parse_expr(p);
    state.expect(p, token.KIND_RBRACKET, "expected ']' after array length");

    val element: id.TypeId = parse_type(p);

    var array: type.TypeArray;
    array.length  = length;
    array.element = element;

    val end_span: token.Span = type_span_or(p, element, start);

    var t: type.Type;
    t.span       = state.span_of(start, end_span);
    t.kind       = type.TYPE_KIND_ARRAY;
    t.data.array = array;
    ret state.push_type(p, t);
}

# parses a function type `fun(T, U) R`
# ---
# p:     parser state, cursor on the `fun` keyword
# start: span of the `fun` keyword
# ret:   TypeId of the resulting TYPE_KIND_FUN node
fun parse_fun(p: *state.Parser, start: token.Span) id.TypeId {
    state.advance(p);
    state.expect(p, token.KIND_LPAREN, "expected '(' after 'fun'");

    # buffer the parameter types: a parameter that is itself a generic or
    # function type appends its own child type ids to the shared type_id pool
    # mid-parse. flush this list as one contiguous block before parsing the
    # return type, so its nested ids cannot split the parameter slice (see
    # parse_call).
    var buf: state.ListBuf[id.TypeId] = state.list_buf_init[id.TypeId]();

    # a bare `...` in a function-type parameter list is the legacy C-style
    # variadic marker, removed in v2.0.0.
    if (state.at(p, token.KIND_DOT_DOT_DOT)) {
        state.error_at_current(p, "C-style variadic `...` was removed in v2.0.0");
        state.advance(p);
    }
    or (!state.at(p, token.KIND_RPAREN)) {
        state.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        for (state.eat(p, token.KIND_COMMA)) {
            if (state.at(p, token.KIND_RPAREN)) { brk; }
            if (state.at(p, token.KIND_DOT_DOT_DOT)) {
                state.error_at_current(p, "C-style variadic `...` was removed in v2.0.0");
                state.advance(p);
                brk;
            }
            state.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        }
    }

    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RPAREN, "expected ')' to close function parameters");

    var params_len:   u32 = 0;
    val params_start: u32 = state.type_id_buf_flush(p, ?buf, ?params_len);

    var ret_type: id.TypeId  = id.TYPE_NIL;
    var end_span: token.Span = close.span;
    if (!at_type_boundary(p)) {
        ret_type = parse_type(p);
        end_span = type_span_or(p, ret_type, end_span);
    }

    var fun_: type.TypeFun;
    fun_.params_start = params_start;
    fun_.params_len   = params_len;
    fun_.ret_type     = ret_type;

    var t: type.Type;
    t.span      = state.span_of(start, end_span);
    t.kind      = type.TYPE_KIND_FUN;
    t.data.fun_ = fun_;
    ret state.push_type(p, t);
}

# parses an anonymous record or union type `rec { ... }` / `uni { ... }`
# ---
# p:     parser state, cursor on the `rec` or `uni` keyword
# start: span of the `rec` or `uni` keyword
# kind:  TYPE_KIND_REC or TYPE_KIND_UNI
# ret:   TypeId of the resulting node
fun parse_rec_or_uni(p: *state.Parser, start: token.Span, kind: type.TypeKind) id.TypeId {
    state.advance(p);
    state.expect(p, token.KIND_LBRACE, "expected '{' to open anonymous type body");

    # buffer the fields: a field whose type is itself an inline rec/uni appends
    # its own typed_names to the shared pool mid-parse, so flush this type's
    # fields as one contiguous block afterward (see parse_call).
    var buf: state.ListBuf[decl.TypedName] = state.list_buf_init[decl.TypedName]();

    for (!state.at(p, token.KIND_RBRACE) && !state.at_eof(p)) {
        if (!state.at(p, token.KIND_IDENT)) {
            state.error_at_current(p, "expected a field name in anonymous type body");
            state.sync_to(p, token.KIND_SEMI, token.KIND_RBRACE, token.KIND_EOF);
            if (state.at(p, token.KIND_SEMI)) { state.advance(p); }
            cnt;
        }
        val name: token.Span = state.advance(p).span;
        state.expect(p, token.KIND_COLON, "expected ':' between field name and type");
        val ty: id.TypeId = parse_type(p);

        var tn: decl.TypedName;
        tn.name     = name;
        tn.ty       = ty;
        tn.comptime = false;
        state.list_buf_push[decl.TypedName](p, ?buf, tn);

        state.expect(p, token.KIND_SEMI, "expected ';' after field declaration");
    }

    val close: token.Token = state.current(p);
    state.expect(p, token.KIND_RBRACE, "expected '}' to close anonymous type body");

    var fields_len:   u32 = 0;
    val fields_start: u32 = state.typed_name_buf_flush(p, ?buf, ?fields_len);

    var t: type.Type;
    t.span = state.span_of(start, close.span);
    t.kind = kind;
    if (kind == type.TYPE_KIND_REC) {
        var r: type.TypeRec;
        r.fields_start = fields_start;
        r.fields_len   = fields_len;
        t.data.rec_    = r;
    }
    or {
        var u: type.TypeUni;
        u.fields_start = fields_start;
        u.fields_len   = fields_len;
        t.data.uni_    = u;
    }
    ret state.push_type(p, t);
}

# reports whether the current token cannot begin a type
#
# Used to detect an omitted return type in a `fun(...)` signature.
# ---
# p:   parser state
# ret: true when the current token cannot start a type
fun at_type_boundary(p: *state.Parser) bool {
    val k: token.Kind = state.current(p).kind;
    if (k == token.KIND_LBRACE)   { ret true; }
    if (k == token.KIND_SEMI)     { ret true; }
    if (k == token.KIND_COMMA)    { ret true; }
    if (k == token.KIND_RPAREN)   { ret true; }
    if (k == token.KIND_RBRACKET) { ret true; }
    if (k == token.KIND_EQ)       { ret true; }
    if (k == token.KIND_EOF)      { ret true; }
    ret false;
}

# chained assignment `x = y = 0` parses right-associatively
test "mach.lang.fe.parser.expr.parse_expr:chained_assign_right_assoc" {
    var alloc: A.Allocator;
    page.make(?alloc);

    val res_tokens: R.Result[lexer.TokenStream, str] = lexer.tokenize("x = y = 0", ?alloc, 0::source.FileId);
    if (R.is_err[lexer.TokenStream, str](res_tokens)) { ret 1; }
    var stream: lexer.TokenStream     = R.unwrap_ok[lexer.TokenStream, str](res_tokens);
    var a:      ast.Ast               = ast.init(?alloc, 0::source.FileId);
    var diags:  diagnostic.DiagList   = diagnostic.init(?alloc);
    var p:      state.Parser          = state.make(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = O.unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # top-level node is `x = (y = 0)`: a binary ASSIGN
    if (e.kind != expr.EXPR_KIND_BINARY)     { rc = 1; }
    or (e.data.binary.op != expr.BIN_ASSIGN) { rc = 1; }
    or {
        # RHS must itself be a binary ASSIGN (right-associative grouping)
        val rhs: *expr.Expr = O.unwrap[*expr.Expr](ast.get_expr(?a, e.data.binary.rhs));
        if (rhs.kind != expr.EXPR_KIND_BINARY)     { rc = 1; }
        or (rhs.data.binary.op != expr.BIN_ASSIGN) { rc = 1; }
    }
    if (diagnostic.has_errors(?diags)) { rc = 1; }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

# `expr[i](args)` parses as index-then-call, not a generic call
test "mach.lang.fe.parser.expr.parse_expr:index_then_call" {
    var alloc: A.Allocator;
    page.make(?alloc);

    val res_tokens: R.Result[lexer.TokenStream, str] = lexer.tokenize("t[0]()", ?alloc, 0::source.FileId);
    if (R.is_err[lexer.TokenStream, str](res_tokens)) { ret 1; }
    var stream: lexer.TokenStream     = R.unwrap_ok[lexer.TokenStream, str](res_tokens);
    var a:      ast.Ast               = ast.init(?alloc, 0::source.FileId);
    var diags:  diagnostic.DiagList   = diagnostic.init(?alloc);
    var p:      state.Parser          = state.make(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = O.unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # `t[0]()` is a call whose callee is the index `t[0]`, with no type args
    if (e.kind != expr.EXPR_KIND_CALL)  { rc = 1; }
    or (e.data.call.type_args_len != 0) { rc = 1; }
    or {
        val callee: *expr.Expr = O.unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.callee));
        if (callee.kind != expr.EXPR_KIND_INDEX) { rc = 1; }
    }
    if (diagnostic.has_errors(?diags)) { rc = 1; }

    diagnostic.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

# a true generic call `callee[T](args)` still binds its type args
