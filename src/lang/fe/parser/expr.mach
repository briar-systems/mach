    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = O.unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # outer call applies to the inner provisional bracket call `f[i]()`.
    if (e.kind != expr.EXPR_KIND_CALL)           { rc = 1; }
