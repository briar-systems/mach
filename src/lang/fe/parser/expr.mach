# mach.lang.fe.parser.expr: expression and type parsing.
#
# expressions use a hybrid recursive-descent primary / Pratt climber;
# types use plain recursive descent. the two grammars live in one module
# because they are mutually recursive: types contain expressions (array
# lengths), expressions contain types (casts, struct-literal and
# array-literal prefixes, generic arguments).

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.string.str;
use std.types.size.usize;
use std.types.result.Result;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;
use std.types.option.unwrap;

use token:    mach.lang.fe.token;
use ast:      mach.lang.fe.ast;
use id:       mach.lang.fe.ast.id;
use expr:     mach.lang.fe.ast.expr;
use m_type:   mach.lang.fe.ast.type;
use decl:     mach.lang.fe.ast.decl;
use parser:   mach.lang.fe.parser.state;
use comptime: mach.lang.fe.comptime;

use lexer: mach.lang.fe.lexer;
use diag:  mach.lang.diagnostic;
use src:   mach.lang.source;
use page:  std.allocator.page;
use std.allocator.Allocator;

# parse_expr: parses a full expression at the lowest infix binding power.
# ---
# p:   parser state
# ret: ExprId of the parsed expression, or EXPR_NIL on failure
pub fun parse_expr(p: *parser.Parser) id.ExprId {
    ret parse_expr_bp(p, 0);
}

# parse_expr_bp: parses an expression whose infix operators have precedence >= min_bp (Pratt climber).
# ---
# p:      parser state
# min_bp: minimum binding power required for the next infix operator to bind
# ret:    ExprId of the parsed expression
pub fun parse_expr_bp(p: *parser.Parser, min_bp: u8) id.ExprId {
    var lhs: id.ExprId = parse_prefix(p);
    lhs = parse_postfix(p, lhs);

    for (!parser.at_eof(p)) {
        val op_tok: token.Token = parser.current(p);
        val op_bp:  u8           = token.infix_precedence(op_tok.kind);
        if (op_bp == 0)         { brk; }
        if (op_bp < min_bp)     { brk; }

        parser.advance(p);

        var right_bp: u8 = op_bp + 1;
        if (token.is_right_assoc(op_tok.kind)) { right_bp = op_bp; }

        val rhs: id.ExprId = parse_expr_bp(p, right_bp);

        var bin: expr.ExprBinary;
        bin.op  = bin_op_from_kind(p, op_tok.kind);
        bin.lhs = lhs;
        bin.rhs = rhs;

        var node: expr.Expr;
        node.span = span_of_expr_pair(p, lhs, rhs);
        node.kind = expr.EXPR_KIND_BINARY;
        node.data.binary = bin;
        lhs = parser.push_expr(p, node);
    }

    ret lhs;
}

# parse_type: parses a type expression and returns its TypeId.
# ---
# p:   parser state
# ret: TypeId of the parsed type, or TYPE_NIL on failure
pub fun parse_type(p: *parser.Parser) id.TypeId {
    val start: token.Token = parser.current(p);

    if (parser.at(p, token.KIND_STAR))     { ret parse_ptr(p, start.span); }
    if (parser.at(p, token.KIND_LBRACKET)) { ret parse_array(p, start.span); }
    if (parser.at_kw(p, "fun"))            { ret parse_fun(p, start.span); }
    if (parser.at_kw(p, "rec"))            { ret parse_rec_or_uni(p, start.span, m_type.TYPE_KIND_REC); }
    if (parser.at_kw(p, "uni"))            { ret parse_rec_or_uni(p, start.span, m_type.TYPE_KIND_UNI); }
    if (parser.at(p, token.KIND_IDENT))    { ret parse_named(p, start.span); }

    parser.error_at_current(p, "expected a type; named, '*T', '[N]T', 'fun(...)', or inline 'rec'/'uni' forms are valid here");
    var t: m_type.Type;
    t.span = start.span;
    t.kind = m_type.TYPE_KIND_ERROR;
    ret parser.push_type(p, t);
}

# parses a prefix atom: literal, identifier, comptime ident, unary, paren group, array literal, or error recovery
# ---
# p:   parser state
# ret: ExprId of the parsed prefix
fun parse_prefix(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.current(p);

    if (t.kind == token.KIND_LIT_INT)   { ret parse_lit_int(p); }
    if (t.kind == token.KIND_LIT_FLOAT) { ret parse_lit_float(p); }
    if (t.kind == token.KIND_LIT_CHAR)  { ret parse_lit_char(p); }
    if (t.kind == token.KIND_LIT_STR)   { ret parse_lit_str(p); }

    if (t.kind == token.KIND_MINUS)    { ret parse_unary(p, expr.UN_NEG); }
    if (t.kind == token.KIND_BANG)     { ret parse_unary(p, expr.UN_NOT); }
    if (t.kind == token.KIND_TILDE)    { ret parse_unary(p, expr.UN_BIT_NOT); }
    if (t.kind == token.KIND_QUESTION) { ret parse_unary(p, expr.UN_ADDR); }
    if (t.kind == token.KIND_AT)       { ret parse_unary(p, expr.UN_DEREF); }

    if (t.kind == token.KIND_LPAREN)   { ret parse_paren(p); }
    if (t.kind == token.KIND_DOLLAR)   { ret parse_comptime_ident(p); }
    if (t.kind == token.KIND_LBRACKET) { ret parse_array_literal(p); }

    if (t.kind == token.KIND_IDENT) {
        if (parser.at_kw(p, "nil"))      { ret parse_lit_nil(p); }
        if (looks_like_typed_literal(p)) { ret parse_typed_literal(p); }
        ret parse_ident(p);
    }

    parser.error_at_current(p, "expected an expression; literals, identifiers, '(', and unary operators are valid here");
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_ERROR;
    ret parser.push_expr(p, node);
}

# applies postfix operators to a primary expression: call, index, member access, cast
# ---
# p:    parser state
# base: expression to apply postfix operators to
# ret:  ExprId of the resulting expression after all postfix operators are applied
fun parse_postfix(p: *parser.Parser, base: id.ExprId) id.ExprId {
    var lhs: id.ExprId = base;
    for (true) {
        val k: token.Kind = parser.current(p).kind;
        if      (k == token.KIND_LPAREN)      { lhs = parse_call(p, lhs, 0, 0, id.EXPR_NIL); }
        or      (k == token.KIND_LBRACKET) {
            val after: usize = scan_bracket_close(p, 0);
            if (after != 0 && parser.peek(p, after).kind == token.KIND_LPAREN) {
                lhs = parse_bracket_call(p, lhs);
            }
            or {
                lhs = parse_index(p, lhs);
            }
        }
        or      (k == token.KIND_DOT) {
            # `v.[f]` is a field projection (#1473); a plain `v.field` is a member.
            if (parser.peek(p, 1).kind == token.KIND_LBRACKET) {
                lhs = parse_project(p, lhs);
            }
            or {
                lhs = parse_member(p, lhs);
            }
        }
        or      (k == token.KIND_COLON_COLON) { lhs = parse_cast(p, lhs, false); }
        or      (k == token.KIND_COLON_TILDE) { lhs = parse_cast(p, lhs, true); }
        or                                    { brk; }
    }
    ret lhs;
}

# scans a balanced bracket region for the postfix/prefix disambiguators: starting
# at the '[' whose offset from the cursor is `bracket_off`, it walks to the
# matching ']' and returns the cursor offset of the token immediately after it. a
# ';' or EOF reached inside the brackets means the region can never be a type
# list, reported as 0 (the brackets are unbalanced for that purpose). shared by
# parse_bracket_call and looks_like_typed_literal so the two scanners cannot
# drift apart.
fun scan_bracket_close(p: *parser.Parser, bracket_off: usize) usize {
    var i: usize = bracket_off + 1;
    var depth: usize = 1;
    for (depth > 0) {
        val k: token.Kind = parser.peek(p, i).kind;
        if (k == token.KIND_EOF || k == token.KIND_SEMI) { ret 0; }
        if (k == token.KIND_LBRACKET) { depth = depth + 1; }
        or (k == token.KIND_RBRACKET) { depth = depth - 1; }
        i = i + 1;
    }
    ret i;
}

# true when `k` can begin an expression (per parse_prefix). used to gate the
# index-reading probe: a payload that cannot start an expression (a bare '*',
# for instance) is never an index, so it is left to the type reading.
fun token_begins_expr(k: token.Kind) bool {
    ret k == token.KIND_LIT_INT   || k == token.KIND_LIT_FLOAT
     || k == token.KIND_LIT_CHAR  || k == token.KIND_LIT_STR
     || k == token.KIND_IDENT     || k == token.KIND_DOLLAR
     || k == token.KIND_MINUS     || k == token.KIND_BANG
     || k == token.KIND_TILDE     || k == token.KIND_QUESTION
     || k == token.KIND_AT        || k == token.KIND_LPAREN
     || k == token.KIND_LBRACKET;
}

# parses a postfix '[' whose matching ']' is followed by '(' — a bracket that
# may open a generic call `callee[T, ..](args)` OR be the index of an
# index-then-call `callee[expr](args)`. the type and expression grammars overlap
# (a bare name is both a type and a value reference), so the parser cannot decide
# locally; it probes the payload against both grammars and:
#   - parses cleanly only as a type list   -> a generic call;
#   - parses cleanly only as an expression -> an index (the trailing '(' is read
#     as a separate call by the postfix loop);
#   - parses cleanly as both               -> a provisional call carrying both
#     readings, deferred to resolve, which picks by the callee's resolved kind
#     (a value indexes; a function/type takes type arguments);
#   - parses cleanly as neither            -> falls to parse_index, whose real
#     parse surfaces the diagnostic.
# the '{' typed-literal form is recognized at the prefix stage and never reaches
# here.
fun parse_bracket_call(p: *parser.Parser, callee: id.ExprId) id.ExprId {
    val idx_probe: id.ExprId = probe_index_payload(p);
    val ty_ok:     bool       = probe_type_payload(p);

    if (ty_ok && idx_probe != id.EXPR_NIL) {
        ret parse_provisional_call(p, callee, idx_probe);
    }
    if (ty_ok) {
        ret parse_generic_call(p, callee);
    }
    ret parse_index(p, callee);
}

# speculatively reads the current '[...]' payload as a single index expression,
# returning its ExprId when the payload parses cleanly up to the closing ']' and
# EXPR_NIL otherwise. the cursor is restored and diagnostics are suppressed (via
# panic) so the probe is side-effect free except for the orphaned AST nodes it
# appends, which a clean result intentionally reuses.
fun probe_index_payload(p: *parser.Parser) id.ExprId {
    if (!token_begins_expr(parser.peek(p, 1).kind)) { ret id.EXPR_NIL; }
    val save_pos:   usize = p.pos;
    val save_panic: bool  = p.panic;
    p.panic = true;
    parser.advance(p);                       # consume '['
    val before: usize = p.pos;
    val e: id.ExprId = parse_expr(p);
    val clean: bool = p.pos > before && !p.fatal && parser.at(p, token.KIND_RBRACKET);
    p.pos   = save_pos;
    p.panic = save_panic;
    if (clean) { ret e; }
    ret id.EXPR_NIL;
}

# speculatively reads the current '[...]' payload as a generic type-argument
# list, returning whether it parses cleanly up to the closing ']'. like
# probe_index_payload it restores the cursor and suppresses diagnostics; the
# orphaned type nodes it appends are discarded (the committing parse re-reads
# the list).
fun probe_type_payload(p: *parser.Parser) bool {
    val save_pos:   usize = p.pos;
    val save_panic: bool  = p.panic;
    p.panic = true;
    parser.advance(p);                       # consume '['
    var ok: bool = false;
    if (!parser.at(p, token.KIND_RBRACKET)) {
        val before: usize = p.pos;
        parse_type(p);
        for (parser.eat(p, token.KIND_COMMA)) {
            if (parser.at(p, token.KIND_RBRACKET)) { brk; }
            parse_type(p);
        }
        ok = p.pos > before && !p.fatal && parser.at(p, token.KIND_RBRACKET);
    }
    p.pos   = save_pos;
    p.panic = save_panic;
    ret ok;
}

# consumes a '[T, U, ..]' type-argument list (the cursor is on the '[') and
# flushes it into the shared type_id pool, returning the slice start through
# `out_len`. factored out of the generic-call parses so both readings build the
# list identically.
fun parse_type_args(p: *parser.Parser, out_len: *u32) u32 {
    parser.advance(p);                       # consume '['

    # buffer the type arguments: a nested generic type argument appends its own
    # child type ids to the shared type_id pool mid-parse, so flush the parent's
    # direct args as one contiguous block afterward (see parse_call).
    var buf: parser.ListBuf[id.TypeId] = parser.list_buf_init[id.TypeId]();

    if (!parser.at(p, token.KIND_RBRACKET)) {
        parser.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        for (parser.eat(p, token.KIND_COMMA)) {
            if (parser.at(p, token.KIND_RBRACKET)) { brk; }
            parser.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        }
    }
    parser.expect(p, token.KIND_RBRACKET, "expected ']' to close generic arguments");

    ret parser.type_id_buf_flush(p, ?buf, out_len);
}

# parses a generic call `callee[T, U](args)`: consumes the bracketed type-arg
# list, then delegates to parse_call to read the parenthesized arguments,
# threading the type args onto the produced ExprCall.
fun parse_generic_call(p: *parser.Parser, callee: id.ExprId) id.ExprId {
    var type_args_len: u32 = 0;
    val type_args_start: u32 = parse_type_args(p, ?type_args_len);
    ret parse_call(p, callee, type_args_start, type_args_len, id.EXPR_NIL);
}

# parses a provisional bracket call `callee[x](args)` whose payload read cleanly
# as both a type list and the index expression `idx`. it commits the type-arg
# reading and, alongside it, wraps `callee[idx]` as the alternative index reading
# (index_callee) so resolve can choose between them by the callee's kind. `idx`
# is the expression the index probe already built from the same tokens.
fun parse_provisional_call(p: *parser.Parser, callee: id.ExprId, idx: id.ExprId) id.ExprId {
    var type_args_len: u32 = 0;
    val type_args_start: u32 = parse_type_args(p, ?type_args_len);
    val index_callee: id.ExprId = make_index(p, callee, idx);
    ret parse_call(p, callee, type_args_start, type_args_len, index_callee);
}

# builds an INDEX node `object[index]` without consuming tokens, used to record
# the index-then-call reading of a provisional bracket call. its span runs from
# the object to the index expression.
fun make_index(p: *parser.Parser, object: id.ExprId, index: id.ExprId) id.ExprId {
    var node_index: expr.ExprIndex;
    node_index.object = object;
    node_index.index  = index;

    var start_span: token.Span = parser.current(p).span;
    if (object != id.EXPR_NIL) {
        start_span = unwrap[*expr.Expr](ast.get_expr(p.ast, object)).span;
    }
    var end_span: token.Span = start_span;
    if (index != id.EXPR_NIL) {
        end_span = unwrap[*expr.Expr](ast.get_expr(p.ast, index)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start_span, end_span);
    node.kind = expr.EXPR_KIND_INDEX;
    node.data.index = node_index;
    ret parser.push_expr(p, node);
}

# parses an integer literal, decoding its value from the source span (the token
# only carries a span, so the value must be decoded here — otherwise every
# literal would lower as 0). a malformed literal is reported and recovers as 0.
fun parse_lit_int(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_INT;
    val r: Result[comptime.CTValue, str] = comptime.eval_lit_int(p.tokens.source, t.span);
    if (is_err[comptime.CTValue, str](r)) {
        parser.error_at(p, t.span, unwrap_err[comptime.CTValue, str](r));
        node.data.lit_int = 0;
    }
    or {
        val cv: comptime.CTValue = unwrap_ok[comptime.CTValue, str](r);
        node.data.lit_int = cv.data.i::u64;
    }
    ret parser.push_expr(p, node);
}

# parses a float literal, decoding its value from the source span.
fun parse_lit_float(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_FLOAT;
    val r: Result[comptime.CTValue, str] = comptime.eval_lit_float(p.tokens.source, t.span);
    if (is_err[comptime.CTValue, str](r)) {
        parser.error_at(p, t.span, unwrap_err[comptime.CTValue, str](r));
        node.data.lit_float = 0.0;
    }
    or {
        val cv: comptime.CTValue = unwrap_ok[comptime.CTValue, str](r);
        node.data.lit_float = cv.data.f;
    }
    ret parser.push_expr(p, node);
}

# parses a char literal, decoding its byte value (with escapes) from the span.
fun parse_lit_char(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_CHAR;
    val r: Result[comptime.CTValue, str] = comptime.eval_lit_char(p.tokens.source, t.span);
    if (is_err[comptime.CTValue, str](r)) {
        parser.error_at(p, t.span, unwrap_err[comptime.CTValue, str](r));
        node.data.lit_char = 0;
    }
    or {
        val cv: comptime.CTValue = unwrap_ok[comptime.CTValue, str](r);
        node.data.lit_char = cv.data.i::u32;
    }
    ret parser.push_expr(p, node);
}

# parses a double-quoted string literal (null-terminated *u8)
fun parse_lit_str(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_STR;
    ret parser.push_expr(p, node);
}

# parses the `nil` keyword
fun parse_lit_nil(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_LIT_NIL;
    ret parser.push_expr(p, node);
}

# parses a plain identifier reference
fun parse_ident(p: *parser.Parser) id.ExprId {
    val t: token.Token = parser.advance(p);
    var node: expr.Expr;
    node.span = t.span;
    node.kind = expr.EXPR_KIND_IDENT;
    ret parser.push_expr(p, node);
}

# parses a `$ident` comptime identifier
fun parse_comptime_ident(p: *parser.Parser) id.ExprId {
    val dollar: token.Token = parser.advance(p);
    var end: token.Span = dollar.span;
    if (parser.at(p, token.KIND_IDENT)) {
        end = parser.advance(p).span;
    } or {
        parser.error_at_current(p, "expected an identifier after '$'");
    }
    var node: expr.Expr;
    node.span = parser.span_of(dollar.span, end);
    node.kind = expr.EXPR_KIND_COMPTIME_IDENT;
    ret parser.push_expr(p, node);
}

# parses a prefix unary operator followed by an operand; applies postfix chains so member/call/index bind tighter than the unary
fun parse_unary(p: *parser.Parser, op: expr.UnOp) id.ExprId {
    val start: token.Token = parser.advance(p);
    var operand: id.ExprId = parse_prefix(p);
    operand = parse_postfix(p, operand);

    var unary: expr.ExprUnary;
    unary.op      = op;
    unary.operand = operand;

    var end_span: token.Span = start.span;
    if (operand != id.EXPR_NIL) {
        end_span = unwrap[*expr.Expr](ast.get_expr(p.ast, operand)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start.span, end_span);
    node.kind = expr.EXPR_KIND_UNARY;
    node.data.unary = unary;
    ret parser.push_expr(p, node);
}

# parses a parenthesized expression `(expr)`
fun parse_paren(p: *parser.Parser) id.ExprId {
    parser.advance(p);
    val inner: id.ExprId = parse_expr(p);
    parser.expect(p, token.KIND_RPAREN, "expected ')' after parenthesized expression");
    ret inner;
}

# parses a call expression `callee(args)`. type_args_start/type_args_len carry
# any call-site generic arguments parsed by parse_generic_call; both are 0 for
# a plain call. index_callee is EXPR_NIL except for a provisional bracket call,
# where it carries the index-then-call reading for resolve to choose (see
# ExprCall.index_callee).
fun parse_call(p: *parser.Parser, callee: id.ExprId, type_args_start: u32, type_args_len: u32, index_callee: id.ExprId) id.ExprId {
    parser.advance(p);

    # buffer the arguments rather than pushing them to the shared expr_id pool
    # as they are parsed: an argument that is itself a call or array literal
    # appends its own child ids to the same pool mid-parse, which would split
    # this list's (start, len) slice. flushing the buffer as one contiguous
    # block after parsing keeps the slice intact.
    var buf: parser.ListBuf[id.ExprId] = parser.list_buf_init[id.ExprId]();

    if (!parser.at(p, token.KIND_RPAREN)) {
        parser.list_buf_push[id.ExprId](p, ?buf, parse_expr(p));
        for (parser.eat(p, token.KIND_COMMA)) {
            if (parser.at(p, token.KIND_RPAREN)) { brk; }
            parser.list_buf_push[id.ExprId](p, ?buf, parse_expr(p));
        }
    }

    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RPAREN, "expected ')' to close call arguments");

    var args_len: u32 = 0;
    val args_start: u32 = parser.expr_id_buf_flush(p, ?buf, ?args_len);

    var call: expr.ExprCall;
    call.callee          = callee;
    call.args_start      = args_start;
    call.args_len        = args_len;
    call.type_args_start = type_args_start;
    call.type_args_len   = type_args_len;
    call.index_callee    = index_callee;

    var start_span: token.Span = close.span;
    if (callee != id.EXPR_NIL) {
        start_span = unwrap[*expr.Expr](ast.get_expr(p.ast, callee)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start_span, close.span);
    node.kind = expr.EXPR_KIND_CALL;
    node.data.call = call;
    ret parser.push_expr(p, node);
}

# parses an index expression `obj[idx]`
fun parse_index(p: *parser.Parser, object: id.ExprId) id.ExprId {
    parser.advance(p);
    val idx: id.ExprId = parse_expr(p);
    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RBRACKET, "expected ']' to close index expression");

    var index: expr.ExprIndex;
    index.object = object;
    index.index  = idx;

    var start_span: token.Span = close.span;
    if (object != id.EXPR_NIL) {
        start_span = unwrap[*expr.Expr](ast.get_expr(p.ast, object)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start_span, close.span);
    node.kind = expr.EXPR_KIND_INDEX;
    node.data.index = index;
    ret parser.push_expr(p, node);
}

# parses a member access `obj.field`
fun parse_member(p: *parser.Parser, object: id.ExprId) id.ExprId {
    parser.advance(p);
    if (!parser.at(p, token.KIND_IDENT)) {
        parser.error_at_current(p, "expected field name after '.'");
        var err_node: expr.Expr;
        err_node.span = parser.current(p).span;
        err_node.kind = expr.EXPR_KIND_ERROR;
        ret parser.push_expr(p, err_node);
    }
    val name_tok: token.Token = parser.advance(p);

    var member: expr.ExprMember;
    member.object = object;
    member.name   = name_tok.span;

    var start_span: token.Span = name_tok.span;
    if (object != id.EXPR_NIL) {
        start_span = unwrap[*expr.Expr](ast.get_expr(p.ast, object)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start_span, name_tok.span);
    node.kind = expr.EXPR_KIND_MEMBER;
    node.data.member = member;
    ret parser.push_expr(p, node);
}

# parses a field projection `v.[f]` (#1473): the field operand `f` is a comptime
# field descriptor (the `$each` loop variable). the leading `.` is the current
# token; `[` immediately follows.
fun parse_project(p: *parser.Parser, object: id.ExprId) id.ExprId {
    parser.expect(p, token.KIND_DOT, "expected '.' before '[' in a field projection");
    parser.expect(p, token.KIND_LBRACKET, "expected '[' in a field projection");
    val field: id.ExprId = parse_expr(p);
    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RBRACKET, "expected ']' to close a field projection");

    var proj: expr.ExprProject;
    proj.object = object;
    proj.field  = field;

    var start_span: token.Span = close.span;
    if (object != id.EXPR_NIL) {
        start_span = unwrap[*expr.Expr](ast.get_expr(p.ast, object)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start_span, close.span);
    node.kind = expr.EXPR_KIND_PROJECT;
    node.data.project = proj;
    ret parser.push_expr(p, node);
}

# parses a cast expression: `value::Type` (value convert) or `value:~Type`
# (bit reinterpret). `reinterpret` selects which operator the caller matched.
fun parse_cast(p: *parser.Parser, value: id.ExprId, reinterpret: bool) id.ExprId {
    parser.advance(p);
    val ty: id.TypeId = parse_type(p);

    var cast: expr.ExprCast;
    cast.value       = value;
    cast.ty          = ty;
    cast.reinterpret = reinterpret;

    var start_span: token.Span = parser.current(p).span;
    if (value != id.EXPR_NIL) {
        start_span = unwrap[*expr.Expr](ast.get_expr(p.ast, value)).span;
    }
    var end_span: token.Span = start_span;
    if (ty != id.TYPE_NIL) {
        end_span = unwrap[*m_type.Type](ast.get_type(p.ast, ty)).span;
    }

    var node: expr.Expr;
    node.span = parser.span_of(start_span, end_span);
    node.kind = expr.EXPR_KIND_CAST;
    node.data.cast = cast;
    ret parser.push_expr(p, node);
}

# parses an array literal `[N]T{a, b, c}`
fun parse_array_literal(p: *parser.Parser) id.ExprId {
    val start: token.Token = parser.current(p);
    val ty: id.TypeId = parse_type(p);
    parser.expect(p, token.KIND_LBRACE, "expected '{' after array type in array literal");

    # buffer the elements: an element that is itself a call or array literal
    # appends its own child ids to the shared expr_id pool mid-parse, so flush
    # the parent's direct elements as one contiguous block afterward (see
    # parse_call).
    var buf: parser.ListBuf[id.ExprId] = parser.list_buf_init[id.ExprId]();

    if (!parser.at(p, token.KIND_RBRACE)) {
        parser.list_buf_push[id.ExprId](p, ?buf, parse_expr(p));
        for (parser.eat(p, token.KIND_COMMA)) {
            if (parser.at(p, token.KIND_RBRACE)) { brk; }
            parser.list_buf_push[id.ExprId](p, ?buf, parse_expr(p));
        }
    }

    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RBRACE, "expected '}' to close array literal");

    var elems_len: u32 = 0;
    val elems_start: u32 = parser.expr_id_buf_flush(p, ?buf, ?elems_len);

    var array: expr.ExprArrayLit;
    array.ty          = ty;
    array.elems_start = elems_start;
    array.elems_len   = elems_len;

    var node: expr.Expr;
    node.span = parser.span_of(start.span, close.span);
    node.kind = expr.EXPR_KIND_ARRAY_LIT;
    node.data.array_lit = array;
    ret parser.push_expr(p, node);
}

# parses a struct literal `Name{field: value, ...}` or `Name[args]{...}` (type prefix already recognized by looks_like_typed_literal)
fun parse_typed_literal(p: *parser.Parser) id.ExprId {
    val start_tok: token.Token = parser.current(p);
    val ty: id.TypeId = parse_type(p);
    parser.expect(p, token.KIND_LBRACE, "expected '{' after type in struct literal");

    # buffer the fields: a field initializer may be a nested struct literal
    # that appends its own FieldInits to the shared pool mid-parse, so flush
    # this literal's fields as one contiguous block afterward (see parse_call).
    var buf: parser.ListBuf[expr.FieldInit] = parser.list_buf_init[expr.FieldInit]();

    if (!parser.at(p, token.KIND_RBRACE)) {
        if (!parse_field_init(p, ?buf)) {
            parser.sync_to(p, token.KIND_RBRACE, token.KIND_EOF, token.KIND_EOF);
        }
        for (parser.eat(p, token.KIND_COMMA)) {
            if (parser.at(p, token.KIND_RBRACE)) { brk; }
            if (!parse_field_init(p, ?buf)) {
                parser.sync_to(p, token.KIND_RBRACE, token.KIND_EOF, token.KIND_EOF);
                brk;
            }
        }
    }

    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RBRACE, "expected '}' to close struct literal");

    var fields_len: u32 = 0;
    val fields_start: u32 = parser.field_init_buf_flush(p, ?buf, ?fields_len);

    var lit: expr.ExprStructLit;
    lit.ty           = ty;
    lit.fields_start = fields_start;
    lit.fields_len   = fields_len;

    var node: expr.Expr;
    node.span = parser.span_of(start_tok.span, close.span);
    node.kind = expr.EXPR_KIND_STRUCT_LIT;
    node.data.struct_lit = lit;
    ret parser.push_expr(p, node);
}

# parses `name: value` and buffers it into `buf`; returns false on syntax
# error. the field is buffered (not pushed to ast.field_inits directly) so a
# nested struct-literal value cannot split the enclosing literal's field slice.
fun parse_field_init(p: *parser.Parser, buf: *parser.ListBuf[expr.FieldInit]) bool {
    if (!parser.at(p, token.KIND_IDENT)) {
        parser.error_at_current(p, "expected field name in struct literal");
        ret false;
    }
    val name: token.Span = parser.advance(p).span;
    parser.expect(p, token.KIND_COLON, "expected ':' between field name and value");
    val value: id.ExprId = parse_expr(p);

    var fi: expr.FieldInit;
    fi.name  = name;
    fi.value = value;
    parser.list_buf_push[expr.FieldInit](p, buf, fi);
    ret true;
}

# reports whether the current token sequence looks like `Name(.Name)*([args])?{`,
# the tell-tale shape of a struct literal's type prefix followed by its body
fun looks_like_typed_literal(p: *parser.Parser) bool {
    if (parser.current(p).kind != token.KIND_IDENT) { ret false; }

    var i: usize = 1;

    for (parser.peek(p, i).kind == token.KIND_DOT && parser.peek(p, i + 1).kind == token.KIND_IDENT) {
        i = i + 2;
    }

    if (parser.peek(p, i).kind == token.KIND_LBRACKET) {
        val after: usize = scan_bracket_close(p, i);
        if (after == 0) { ret false; }
        i = after;
    }

    ret parser.peek(p, i).kind == token.KIND_LBRACE;
}

# maps a token kind to its corresponding BinOp. paired with
# token.infix_precedence: the Pratt loop only calls this for kinds with nonzero
# infix precedence, so every operator listed there must be mapped here. `=` is
# the sole assignment mapping; an unmapped kind means the two tables have drifted
# out of sync and is reported rather than silently parsed as an assignment.
fun bin_op_from_kind(p: *parser.Parser, kind: token.Kind) expr.BinOp {
    if (kind == token.KIND_PLUS)      { ret expr.BIN_ADD; }
    if (kind == token.KIND_MINUS)     { ret expr.BIN_SUB; }
    if (kind == token.KIND_STAR)      { ret expr.BIN_MUL; }
    if (kind == token.KIND_SLASH)     { ret expr.BIN_DIV; }
    if (kind == token.KIND_PERCENT)   { ret expr.BIN_MOD; }
    if (kind == token.KIND_EQ_EQ)     { ret expr.BIN_EQ; }
    if (kind == token.KIND_BANG_EQ)   { ret expr.BIN_NEQ; }
    if (kind == token.KIND_LT)        { ret expr.BIN_LT; }
    if (kind == token.KIND_LT_EQ)     { ret expr.BIN_LEQ; }
    if (kind == token.KIND_GT)        { ret expr.BIN_GT; }
    if (kind == token.KIND_GT_EQ)     { ret expr.BIN_GEQ; }
    if (kind == token.KIND_AMP_AMP)   { ret expr.BIN_AND; }
    if (kind == token.KIND_PIPE_PIPE) { ret expr.BIN_OR; }
    if (kind == token.KIND_AMP)       { ret expr.BIN_BIT_AND; }
    if (kind == token.KIND_PIPE)      { ret expr.BIN_BIT_OR; }
    if (kind == token.KIND_CARET)     { ret expr.BIN_BIT_XOR; }
    if (kind == token.KIND_LT_LT)     { ret expr.BIN_SHL; }
    if (kind == token.KIND_GT_GT)     { ret expr.BIN_SHR; }
    if (kind == token.KIND_EQ)        { ret expr.BIN_ASSIGN; }
    parser.fatal_ice_at(p, parser.current(p).span, "internal compiler error: infix operator has no binary-operator mapping");
    ret expr.BIN_ASSIGN;
}

# computes the span covering two expressions by id, falling back to the current token when either is EXPR_NIL
fun span_of_expr_pair(p: *parser.Parser, lhs: id.ExprId, rhs: id.ExprId) token.Span {
    var start: token.Span = parser.current(p).span;
    var end:   token.Span = start;
    if (lhs != id.EXPR_NIL) { start = unwrap[*expr.Expr](ast.get_expr(p.ast, lhs)).span; }
    if (rhs != id.EXPR_NIL) { end   = unwrap[*expr.Expr](ast.get_expr(p.ast, rhs)).span; }
    ret parser.span_of(start, end);
}

# parses a named type, including dotted paths and optional generic arguments
# ---
# p:     parser state
# start: span of the first identifier token in the path
# ret:   TypeId of the resulting TYPE_KIND_NAMED node
fun parse_named(p: *parser.Parser, start: token.Span) id.TypeId {
    var last: token.Span = parser.advance(p).span;

    for (parser.at(p, token.KIND_DOT) && parser.peek(p, 1).kind == token.KIND_IDENT) {
        parser.advance(p);
        last = parser.advance(p).span;
    }

    val path_span: token.Span = parser.span_of(start, last);

    var args_start: u32 = 0;
    var args_len:   u32 = 0;
    var end:        token.Span = last;

    if (parser.eat(p, token.KIND_LBRACKET)) {
        # buffer the generic arguments: a nested generic type argument appends
        # its own child type ids to the shared type_id pool mid-parse, so flush
        # this list as one contiguous block afterward (see parse_call).
        var buf: parser.ListBuf[id.TypeId] = parser.list_buf_init[id.TypeId]();
        if (!parser.at(p, token.KIND_RBRACKET)) {
            parser.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
            for (parser.eat(p, token.KIND_COMMA)) {
                if (parser.at(p, token.KIND_RBRACKET)) { brk; }
                parser.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
            }
        }
        val close: token.Token = parser.current(p);
        parser.expect(p, token.KIND_RBRACKET, "expected ']' to close generic arguments");
        end = close.span;
        args_start = parser.type_id_buf_flush(p, ?buf, ?args_len);
    }

    var named: m_type.TypeNamed;
    named.name       = path_span;
    named.args_start = args_start;
    named.args_len   = args_len;

    var t: m_type.Type;
    t.span       = parser.span_of(start, end);
    t.kind       = m_type.TYPE_KIND_NAMED;
    t.data.named = named;
    ret parser.push_type(p, t);
}

# parses a pointer type `*T`
# ---
# p:     parser state
# start: span of the leading `*` token
# ret:   TypeId of the resulting TYPE_KIND_PTR node
fun parse_ptr(p: *parser.Parser, start: token.Span) id.TypeId {
    parser.advance(p);
    val inner: id.TypeId = parse_type(p);

    var ptr: m_type.TypePtr;
    ptr.pointee = inner;

    var end_span: token.Span = start;
    if (inner != id.TYPE_NIL) {
        end_span = unwrap[*m_type.Type](ast.get_type(p.ast, inner)).span;
    }

    var t: m_type.Type;
    t.span     = parser.span_of(start, end_span);
    t.kind     = m_type.TYPE_KIND_PTR;
    t.data.ptr = ptr;
    ret parser.push_type(p, t);
}

# parses a fixed-length array type `[N]T`
# ---
# p:     parser state
# start: span of the leading `[` token
# ret:   TypeId of the resulting TYPE_KIND_ARRAY node
fun parse_array(p: *parser.Parser, start: token.Span) id.TypeId {
    parser.advance(p);
    val length: id.ExprId = parse_expr(p);
    parser.expect(p, token.KIND_RBRACKET, "expected ']' after array length");

    val element: id.TypeId = parse_type(p);

    var array: m_type.TypeArray;
    array.length  = length;
    array.element = element;

    var end_span: token.Span = start;
    if (element != id.TYPE_NIL) {
        end_span = unwrap[*m_type.Type](ast.get_type(p.ast, element)).span;
    }

    var t: m_type.Type;
    t.span       = parser.span_of(start, end_span);
    t.kind       = m_type.TYPE_KIND_ARRAY;
    t.data.array = array;
    ret parser.push_type(p, t);
}

# parses a function type `fun(T, U) R`
# ---
# p:     parser state
# start: span of the `fun` keyword
# ret:   TypeId of the resulting TYPE_KIND_FUN node
fun parse_fun(p: *parser.Parser, start: token.Span) id.TypeId {
    parser.advance(p);
    parser.expect(p, token.KIND_LPAREN, "expected '(' after 'fun'");

    # buffer the parameter types: a parameter that is itself a generic or
    # function type appends its own child type ids to the shared type_id pool
    # mid-parse. flush this list as one contiguous block before parsing the
    # return type, so its nested ids cannot split the parameter slice (see
    # parse_call).
    var buf: parser.ListBuf[id.TypeId] = parser.list_buf_init[id.TypeId]();
    var variadic: bool = false;

    if (parser.at(p, token.KIND_DOT_DOT_DOT)) {
        parser.advance(p);
        variadic = true;
    }
    or (!parser.at(p, token.KIND_RPAREN)) {
        parser.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        for (parser.eat(p, token.KIND_COMMA)) {
            if (parser.at(p, token.KIND_RPAREN)) { brk; }
            if (parser.at(p, token.KIND_DOT_DOT_DOT)) {
                parser.advance(p);
                variadic = true;
                brk;
            }
            parser.list_buf_push[id.TypeId](p, ?buf, parse_type(p));
        }
    }

    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RPAREN, "expected ')' to close function parameters");

    var params_len: u32 = 0;
    val params_start: u32 = parser.type_id_buf_flush(p, ?buf, ?params_len);

    var ret_type: id.TypeId = id.TYPE_NIL;
    var end_span: token.Span = close.span;

    if (!at_type_boundary(p)) {
        ret_type = parse_type(p);
        if (ret_type != id.TYPE_NIL) {
            end_span = unwrap[*m_type.Type](ast.get_type(p.ast, ret_type)).span;
        }
    }

    var fun_: m_type.TypeFun;
    fun_.params_start = params_start;
    fun_.params_len   = params_len;
    fun_.variadic     = variadic;
    fun_.ret_ty       = ret_type;

    var t: m_type.Type;
    t.span      = parser.span_of(start, end_span);
    t.kind      = m_type.TYPE_KIND_FUN;
    t.data.fun_ = fun_;
    ret parser.push_type(p, t);
}

# parses an anonymous record or union type `rec { ... }` / `uni { ... }`
# ---
# p:     parser state
# start: span of the `rec` or `uni` keyword
# kind:  TYPE_KIND_REC or TYPE_KIND_UNI
# ret:   TypeId of the resulting node
fun parse_rec_or_uni(p: *parser.Parser, start: token.Span, kind: m_type.TypeKind) id.TypeId {
    parser.advance(p);
    parser.expect(p, token.KIND_LBRACE, "expected '{' to open anonymous type body");

    # buffer the fields: a field whose type is itself an inline rec/uni appends
    # its own typed_names to the shared pool mid-parse, so flush this type's
    # fields as one contiguous block afterward (see parse_call).
    var buf: parser.ListBuf[decl.TypedName] = parser.list_buf_init[decl.TypedName]();

    for (!parser.at(p, token.KIND_RBRACE) && !parser.at_eof(p)) {
        if (!parser.at(p, token.KIND_IDENT)) {
            parser.error_at_current(p, "expected a field name in anonymous type body");
            parser.sync_to(p, token.KIND_SEMI, token.KIND_RBRACE, token.KIND_EOF);
            if (parser.at(p, token.KIND_SEMI)) { parser.advance(p); }
            cnt;
        }
        val name: token.Span = parser.advance(p).span;
        parser.expect(p, token.KIND_COLON, "expected ':' between field name and type");
        val ty: id.TypeId = parse_type(p);

        var tn: decl.TypedName;
        tn.name     = name;
        tn.ty       = ty;
        tn.comptime = false;
        parser.list_buf_push[decl.TypedName](p, ?buf, tn);

        parser.expect(p, token.KIND_SEMI, "expected ';' after field declaration");
    }

    val close: token.Token = parser.current(p);
    parser.expect(p, token.KIND_RBRACE, "expected '}' to close anonymous type body");

    var fields_len: u32 = 0;
    val fields_start: u32 = parser.typed_name_buf_flush(p, ?buf, ?fields_len);

    var t: m_type.Type;
    t.span = parser.span_of(start, close.span);
    t.kind = kind;
    if (kind == m_type.TYPE_KIND_REC) {
        var r: m_type.TypeRec;
        r.fields_start = fields_start;
        r.fields_len   = fields_len;
        t.data.rec_    = r;
    } or {
        var u: m_type.TypeUni;
        u.fields_start = fields_start;
        u.fields_len   = fields_len;
        t.data.uni_    = u;
    }
    ret parser.push_type(p, t);
}

# true when the current token cannot begin a type (used to detect an omitted return type in `fun(...)` signatures)
fun at_type_boundary(p: *parser.Parser) bool {
    val k: token.Kind = parser.current(p).kind;
    if (k == token.KIND_LBRACE)   { ret true; }
    if (k == token.KIND_SEMI)     { ret true; }
    if (k == token.KIND_COMMA)    { ret true; }
    if (k == token.KIND_RPAREN)   { ret true; }
    if (k == token.KIND_RBRACKET) { ret true; }
    if (k == token.KIND_EQ)       { ret true; }
    if (k == token.KIND_EOF)      { ret true; }
    ret false;
}

test "parser: chained assignment x = y = 0 parses right-associatively (#1242)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("x = y = 0", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # top-level node is `x = (y = 0)`: a binary ASSIGN
    if (e.kind != expr.EXPR_KIND_BINARY)         { rc = 1; }
    or (e.data.binary.op != expr.BIN_ASSIGN)     { rc = 1; }
    or {
        # RHS must itself be a binary ASSIGN (right-associative grouping)
        val rhs: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.binary.rhs));
        if (rhs.kind != expr.EXPR_KIND_BINARY)   { rc = 1; }
        or (rhs.data.binary.op != expr.BIN_ASSIGN) { rc = 1; }
    }
    if (diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

test "parser: expr[i](args) parses as index-then-call, not a generic call (#1247)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("t[0]()", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # `t[0]()` is a call whose callee is the index `t[0]`, with no type args
    if (e.kind != expr.EXPR_KIND_CALL) { rc = 1; }
    or (e.data.call.type_args_len != 0) { rc = 1; }
    or {
        val callee: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.callee));
        if (callee.kind != expr.EXPR_KIND_INDEX) { rc = 1; }
    }
    if (diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

test "parser: a true generic call callee[T](args) still binds its type args (#1247)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("make[i64]()", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, eid));
    if (e.kind != expr.EXPR_KIND_CALL) { rc = 1; }
    or (e.data.call.type_args_len != 1) { rc = 1; }
    or {
        val callee: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.callee));
        if (callee.kind != expr.EXPR_KIND_IDENT) { rc = 1; }
    }
    if (diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

test "parser: bare-identifier bracket call tbl[i](args) is provisional (#1270)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("tbl[i]()", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # `tbl[i]()`: payload `i` reads as both a type arg and an index expression, so
    # the parser records both readings (type_args plus a pre-built index callee)
    # and defers the choice to resolve.
    if (e.kind != expr.EXPR_KIND_CALL) { rc = 1; }
    or (e.data.call.type_args_len != 1) { rc = 1; }
    or (e.data.call.index_callee == id.EXPR_NIL) { rc = 1; }
    or {
        val callee: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.callee));
        if (callee.kind != expr.EXPR_KIND_IDENT) { rc = 1; }
        or {
            val idx: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.index_callee));
            if (idx.kind != expr.EXPR_KIND_INDEX) { rc = 1; }
            or (idx.data.index.object != e.data.call.callee) { rc = 1; }
        }
    }
    if (diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

test "parser: nested index-then-call m[i][j](args) keeps an index callee (#1270)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("m[i][j]()", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # `m[i]` is a plain index (no trailing call), so the provisional `[j](` sits
    # on an index callee; the bracket call still records its index reading.
    if (e.kind != expr.EXPR_KIND_CALL) { rc = 1; }
    or (e.data.call.index_callee == id.EXPR_NIL) { rc = 1; }
    or {
        val callee: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.callee));
        if (callee.kind != expr.EXPR_KIND_INDEX) { rc = 1; }
    }
    if (diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

test "parser: chained call f[i]()() nests a provisional inner call (#1270)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("f[i]()()", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    val eid: id.ExprId = parse_expr(?p);
    var rc: i32 = 0;
    val e: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, eid));
    # outer call applies to the inner provisional bracket call `f[i]()`.
    if (e.kind != expr.EXPR_KIND_CALL) { rc = 1; }
    or (e.data.call.index_callee != id.EXPR_NIL) { rc = 1; }
    or {
        val inner: *expr.Expr = unwrap[*expr.Expr](ast.get_expr(?a, e.data.call.callee));
        if (inner.kind != expr.EXPR_KIND_CALL) { rc = 1; }
        or (inner.data.call.index_callee == id.EXPR_NIL) { rc = 1; }
    }
    if (diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}

test "parser: a malformed bracket payload t[a b](x) is rejected (#1270)" {
    var alloc: Allocator;
    page.make(?alloc);

    val tr: Result[lexer.TokenStream, str] = lexer.tokenize("t[a b]()", ?alloc, 0::src.FileId);
    if (is_err[lexer.TokenStream, str](tr)) { ret 1; }
    var stream: lexer.TokenStream = unwrap_ok[lexer.TokenStream, str](tr);
    var a: ast.Ast = ast.init(?alloc, 0::src.FileId);
    var diags: diag.DiagList = diag.init(?alloc);
    var p: parser.Parser = parser.init(?stream, ?a, ?diags);

    parse_expr(?p);
    var rc: i32 = 0;
    # a payload that reads cleanly as neither a type list nor an expression is
    # not silently accepted: the committing index parse surfaces a diagnostic.
    if (!diag.has_errors(?diags)) { rc = 1; }

    diag.dnit(?diags);
    ast.dnit(?a);
    lexer.dnit(?stream, ?alloc);
    ret rc;
}
