# mach.lang.fe.parser.asm: inline assembly parsing.
#
# parses the mandatory ISA tag and then collects the raw body text by
# tracking brace depth through the already-lexed token stream. there is
# no operand list: operand direction and the clobber set are inferred
# later from the instruction stream, and local substitution happens
# through `{name}` references in the raw body.

use std.types.size.usize;

use token:  mach.lang.fe.token;
use id:     mach.lang.fe.ast.id;
use stmt:   mach.lang.fe.ast.stmt;
use parser: mach.lang.fe.parser.state;

# parse_asm: parses an `asm <isa> { body }` statement starting at the `asm` keyword.
# ---
# p:   parser state; current token must be the IDENT `asm`
# ret: StmtId of the resulting STMT_KIND_ASM node
pub fun parse_asm(p: *parser.Parser) id.StmtId {
    val start: token.Token = parser.advance(p);

    var isa: token.Span;
    isa.offset = 0;
    isa.len    = 0;

    if (parser.at(p, token.KIND_IDENT)) {
        isa = parser.advance(p).span;
    } or {
        parser.error_at_current(p, "expected ISA tag after 'asm'");
    }

    var body: token.Span;
    body.offset = 0;
    body.len    = 0;
    var end_span: token.Span = start.span;

    if (!parser.at(p, token.KIND_LBRACE)) {
        parser.error_at_current(p, "expected '{' to open inline assembly body");
    } or {
        val lbrace: token.Token = parser.advance(p);
        val body_start: usize = lbrace.span.offset + lbrace.span.len;
        collect_body(p, body_start, ?body, ?end_span);
    }

    var asm_stmt: stmt.StmtAsm;
    asm_stmt.isa  = isa;
    asm_stmt.body = body;

    var node: stmt.Stmt;
    node.span = parser.span_of(start.span, end_span);
    node.kind = stmt.STMT_KIND_ASM;
    node.data.asm_ = asm_stmt;
    ret parser.push_stmt(p, node);
}

# collects the raw body text between the already-consumed `{` and its matching `}` by tracking brace depth through the token stream
# ---
# p:            parser state; current token is the first token inside the body, after `{`
# start_offset: byte offset immediately after the opening `{`
# body:         out-parameter receiving the span covering the raw body text
# end_span:     out-parameter receiving the span of the closing `}`
fun collect_body(p: *parser.Parser, start_offset: usize, body: *token.Span, end_span: *token.Span) {
    var depth:       usize = 1;
    var last_offset: usize = start_offset;

    for (!parser.at_eof(p)) {
        val t: token.Token = parser.current(p);
        if (t.kind == token.KIND_LBRACE) {
            depth = depth + 1;
            last_offset = t.span.offset + t.span.len;
            parser.advance(p);
            cnt;
        }
        if (t.kind == token.KIND_RBRACE) {
            depth = depth - 1;
            if (depth == 0) {
                body.offset = start_offset;
                body.len    = t.span.offset - start_offset;
                end_span.offset = t.span.offset;
                end_span.len    = t.span.len;
                parser.advance(p);
                ret;
            }
            last_offset = t.span.offset + t.span.len;
            parser.advance(p);
            cnt;
        }
        last_offset = t.span.offset + t.span.len;
        parser.advance(p);
    }

    parser.error_at_current(p, "unterminated asm body");
    body.offset     = start_offset;
    body.len        = last_offset - start_offset;
    end_span.offset = last_offset;
    end_span.len    = 0;
}
