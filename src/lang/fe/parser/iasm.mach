# inline assembly parsing
#
# parses the mandatory ISA tag, then collects the raw body text by tracking
# brace depth through the already-lexed token stream. there is no operand
# list: operand direction and the clobber set are inferred later from the
# instruction stream, and local substitution happens through `{name}`
# references in the raw body.

use std.types.size.usize;

use mach.lang.fe.ast.id;
use mach.lang.fe.ast.stmt;
use mach.lang.fe.parser.state;
use mach.lang.fe.token;

# parse an `asm <isa> { body }` statement starting at the `asm` keyword
# ---
# p:   parser state; current token must be the IDENT `asm`
# ret: StmtId of the resulting STMT_KIND_ASM node
pub fun parse_asm(p: *state.Parser) id.StmtId {
    val start: token.Token = state.advance(p);

    var isa: token.Span;
    isa.offset = 0;
    isa.len    = 0;

    if (state.at(p, token.KIND_IDENT)) {
        isa = state.advance(p).span;
    }
    or {
        state.error_at_current(p, "expected ISA tag after 'asm'");
    }

    var body: token.Span;
    body.offset = 0;
    body.len    = 0;
    var end_span: token.Span = start.span;

    if (state.at(p, token.KIND_LBRACE)) {
        val lbrace:     token.Token = state.advance(p);
        val body_start: usize       = lbrace.span.offset + lbrace.span.len;
        collect_body(p, body_start, start.span, ?body, ?end_span);
    }
    or {
        state.error_at_current(p, "expected '{' to open inline assembly body");
    }

    var asm_stmt: stmt.StmtAsm;
    asm_stmt.isa  = isa;
    asm_stmt.body = body;

    var node: stmt.Stmt;
    node.span      = state.span_of(start.span, end_span);
    node.kind      = stmt.STMT_KIND_ASM;
    node.data.asm_ = asm_stmt;
    ret state.push_stmt(p, node);
}

# collect the raw body text between the already-consumed `{` and its matching
# `}` by tracking brace depth through the token stream
# ---
# p:            parser state; current token is the first token inside the body, after `{`
# start_offset: byte offset immediately after the opening `{`
# asm_span:     span of the opening `asm` keyword, used for the unterminated-body diagnostic
# body:         out-parameter receiving the span covering the raw body text
# end_span:     out-parameter receiving the span of the closing `}`
fun collect_body(p: *state.Parser, start_offset: usize, asm_span: token.Span, body: *token.Span, end_span: *token.Span) {
    var depth:       usize = 1;
    var last_offset: usize = start_offset;

    for (!state.at_eof(p)) {
        val t: token.Token = state.current(p);

        if (t.kind == token.KIND_LBRACE) {
            depth = depth + 1;
        }
        or (t.kind == token.KIND_RBRACE) {
            depth = depth - 1;
            if (depth == 0) {
                body.offset     = start_offset;
                body.len        = t.span.offset - start_offset;
                end_span.offset = t.span.offset;
                end_span.len    = t.span.len;
                state.advance(p);
                ret;
            }
        }

        last_offset = t.span.offset + t.span.len;
        state.advance(p);
    }

    # ran out of tokens before the matching `}`: cover everything scanned and
    # pin the diagnostic to the opening `asm` keyword.
    state.error_at(p, asm_span, "unterminated asm body");
    body.offset     = start_offset;
    body.len        = last_offset - start_offset;
    end_span.offset = last_offset;
    end_span.len    = 0;
}
