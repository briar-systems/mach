# structured read of a captured doc-comment block
#
# a doc block is the `#`-comment run the parser attaches to a Decl (see
# documentation.md): a free-prose summary, an optional `# ---` separator, then
# `# <component>: <description>` lines - one per documentable item. this module
# turns a doc span plus its source text into structured spans the docstring lint
# and (later) hover and rename build on. it allocates nothing: every result is a
# byte span back into the source.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;
use std.types.string.str_region_equals;

use mach.lang.fe.token;

# one parsed `# <name>: <description>` component line
# ---
# name_span: byte span of just the `<name>` token (trimmed), for rename
# desc_span: byte span of the description (trimmed), or an empty span when absent
pub rec DocComponent {
    name_span: token.Span;
    desc_span: token.Span;
}

# a forward cursor over a doc block's component lines
# ---
# source: the source text the doc span points into
# off:    byte offset of the next unscanned position within the doc block
# end:    byte offset just past the doc block
pub rec DocComponentIter {
    source: str;
    off:    usize;
    end:    usize;
}

# whether the doc block carries a `# ---` separator, i.e. it has a component
# block rather than being summary-only
#
# The docstring lint only validates decls whose docstring has a component block.
# ---
# source: the source text the doc span points into
# doc:    the doc-block span (empty when the decl has no docstring)
# ret:    true when a `# ---` separator line is present
pub fun has_component_block(source: str, doc: token.Span) bool {
    if (doc.len == 0) { ret false; }
    ret separator_offset(source, doc) != doc.offset + doc.len;
}

# the byte span of the summary - every line before the `# ---` separator, or the
# whole block when summary-only - trimmed of the leading `#` of the first line
# and of trailing whitespace and newlines
#
# An empty span when the doc block is empty or carries no summary text.
# ---
# source: the source text the doc span points into
# doc:    the doc-block span
# ret:    the summary span, or an empty span when absent
pub fun summary_span(source: str, doc: token.Span) token.Span {
    if (doc.len == 0) { ret empty_span(); }

    val sep: usize = separator_offset(source, doc);
    # the summary's content starts after the first line's `#` and whitespace.
    val lo: usize = strip_hash(source, doc.offset, sep);
    var hi: usize = sep;
    # drop a trailing newline and trailing in-line whitespace.
    for (hi > lo && (source[hi - 1] == '\n' || source[hi - 1] == '\r')) { hi = hi - 1; }
    hi = trim_trailing(source, lo, hi);

    if (hi <= lo) { ret empty_span(); }

    var s: token.Span;
    s.offset = lo;
    s.len    = hi - lo;
    ret s;
}

# a cursor positioned at the first component line (the line after the `# ---`
# separator)
#
# When the block has no separator the cursor is empty and `component_next`
# immediately reports done.
# ---
# source: the source text the doc span points into
# doc:    the doc-block span
# ret:    a fresh iterator over the block's component lines
pub fun component_iter(source: str, doc: token.Span) DocComponentIter {
    var it: DocComponentIter;
    it.source = source;
    it.end    = doc.offset + doc.len;

    if (doc.len == 0) {
        it.off = it.end;
        ret it;
    }

    val sep: usize = separator_offset(source, doc);
    if (sep == it.end) {
        it.off = it.end;
        ret it;
    }

    # skip the separator line itself.
    var off: usize = line_end(source, sep, it.end);
    if (off < it.end && source[off] == '\n') { off = off + 1; }
    it.off = off;
    ret it;
}

# advance the iterator to the next component line, writing the parsed component
# through `out` and returning true; return false when the block is exhausted
#
# A component line is `# <name>: <description>` where `<name>` is a single
# whitespace-free token (a parameter or field name, `[T]`, `$name`, or `ret`). a
# `#` line that does not fit that shape - a blank line, a colon-less prose line,
# a multi-word line, or a more deeply indented line - is a continuation of the
# preceding component's description: its bytes extend that component's desc_span
# and it never starts a new component. This matches the wrapped, aligned
# descriptions in the existing corpus.
# ---
# it:  the iterator to advance
# out: receives the parsed component on a true return
# ret: true when a component was produced, false at end of block
pub fun component_next(it: *DocComponentIter, out: *DocComponent) bool {
    var have:    bool       = false;
    var name:    token.Span = empty_span();
    var desc_lo: usize      = 0;
    var desc_hi: usize      = 0;

    for (it.off < it.end) {
        val le:      usize = line_end(it.source, it.off, it.end);
        val content: usize = strip_hash(it.source, it.off, le);

        var name_span: token.Span = empty_span();
        var head_lo:   usize      = 0;
        val starts:    bool       = component_head(it.source, it.off, content, le, ?name_span, ?head_lo);

        if (starts) {
            # a second component head ends the current one: return what we have
            # gathered, leaving the cursor on this line for the next call.
            if (have) { ret emit_component(out, name, desc_lo, desc_hi); }

            have    = true;
            name    = name_span;
            desc_lo = head_lo;
            desc_hi = trim_trailing(it.source, head_lo, le);
        }
        or (have) {
            # a continuation line extends the description; a blank `#` line leaves
            # desc_hi unchanged.
            val hi: usize = trim_trailing(it.source, content, le);
            if (hi > content) { desc_hi = hi; }
        }

        it.off = le;
        if (it.off < it.end && it.source[it.off] == '\n') { it.off = it.off + 1; }
    }

    if (have) { ret emit_component(out, name, desc_lo, desc_hi); }
    ret false;
}

# a zero-length span, the canonical "absent" marker
# ---
# ret: a span with offset and len both zero
fun empty_span() token.Span {
    var s: token.Span;
    s.offset = 0;
    s.len    = 0;
    ret s;
}

# whether byte `c` is in-line whitespace (a space or tab)
# ---
# c:   the byte to test
# ret: true for a space or tab
fun is_space(c: u8) bool {
    ret c == ' ' || c == '\t';
}

# the byte offset of the newline ending the line that starts at `off`, or `end`
# when the line runs to the searchable region's end with no newline
# ---
# source: the source text
# off:    byte offset of the line start
# end:    byte offset just past the searchable region
# ret:    offset of the line's terminating newline, or `end`
fun line_end(source: str, off: usize, end: usize) usize {
    var i: usize = off;
    for (i < end && source[i] != '\n') { i = i + 1; }
    ret i;
}

# advance past a leading `#` and any in-line whitespace on a comment line that
# starts at `off`, returning the offset of the first content byte
#
# The doc run guarantees each line begins with `#`; the guard leaves a `#`-less
# line untouched rather than consuming a content byte.
# ---
# source: the source text
# off:    byte offset of the line start
# end:    byte offset just past the searchable region
# ret:    offset of the first content byte after `#` and whitespace
fun strip_hash(source: str, off: usize, end: usize) usize {
    var i: usize = off;
    if (i < end && source[i] == '#') { i = i + 1; }
    for (i < end && is_space(source[i])) { i = i + 1; }
    ret i;
}

# pull `hi` back past trailing in-line whitespace, down to `lo`
# ---
# source: the source text
# lo:     lower bound the trim will not cross
# hi:     exclusive upper bound to trim back from
# ret:    the new upper bound with trailing space and tab removed
fun trim_trailing(source: str, lo: usize, hi: usize) usize {
    var i: usize = hi;
    for (i > lo && is_space(source[i - 1])) { i = i - 1; }
    ret i;
}

# whether the comment line whose content runs from `content` to `content_end` is
# exactly `---`, the separator that introduces the component block
# ---
# source:      the source text
# content:     byte offset of the line content (past `#` and whitespace)
# content_end: byte offset just past the line content
# ret:         true when the trimmed content is exactly `---`
fun is_separator_line(source: str, content: usize, content_end: usize) bool {
    val hi: usize = trim_trailing(source, content, content_end);
    if (hi - content != 3) { ret false; }
    ret source[content] == '-' && source[content + 1] == '-' && source[content + 2] == '-';
}

# the byte offset of the `#` opening the `# ---` separator line within the doc
# block, or the block end (`doc.offset + doc.len`) when the block has no
# separator
#
# Drives both summary_span and the component iterator.
# ---
# source: the source text the doc span points into
# doc:    the doc-block span
# ret:    offset of the separator's `#`, or the block end when absent
fun separator_offset(source: str, doc: token.Span) usize {
    val end: usize = doc.offset + doc.len;
    var off: usize = doc.offset;
    for (off < end) {
        val le:      usize = line_end(source, off, end);
        val content: usize = strip_hash(source, off, le);
        if (is_separator_line(source, content, le)) { ret off; }
        off = le;
        if (off < end && source[off] == '\n') { off = off + 1; }
    }
    ret end;
}

# whether the line beginning at `off` starts a component, writing the name
# token's span through `name_out` and the description's start offset through
# `desc_lo_out`
#
# A component head must sit at the base indentation (`#` then at most one space)
# with a single non-empty whitespace-free token before a `:`. A deeper
# indentation marks a wrapped continuation line, so a prose line that happens to
# start `word:` under a component is not mistaken for a new component. A blank,
# colon-less, or multi-word line is also not a head.
# ---
# source:      the source text
# off:         byte offset of the line start
# content:     byte offset of the line content (past `#` and whitespace)
# le:          byte offset of the line end
# name_out:    receives the name token's span on a true return
# desc_lo_out: receives the description's start offset on a true return
# ret:         true when the line is a component head
fun component_head(source: str, off: usize, content: usize, le: usize, name_out: *token.Span, desc_lo_out: *usize) bool {
    if (content >= le) { ret false; }

    # the name must sit at the base indent: `#` plus at most one space. anything
    # more deeply indented is a continuation aligned under a description.
    var hash: usize = off;
    if (hash < le && source[hash] == '#') { hash = hash + 1; }
    if (content > hash + 1)               { ret false; }

    var colon: usize = content;
    for (colon < le && source[colon] != ':') { colon = colon + 1; }
    if (colon >= le) { ret false; }

    val name_hi: usize = trim_trailing(source, content, colon);
    if (name_hi <= content) { ret false; }

    # the name token must be a single word: no interior whitespace.
    var i: usize = content;
    for (i < name_hi) {
        if (is_space(source[i])) { ret false; }
        i = i + 1;
    }

    # the description starts after the `:` and any aligning whitespace.
    var lo: usize = colon + 1;
    for (lo < le && is_space(source[lo])) { lo = lo + 1; }

    name_out.offset = content;
    name_out.len    = name_hi - content;
    @desc_lo_out    = lo;
    ret true;
}

# write a finished component - its name span and description range - through
# `out` and report success, the shared tail of component_next
# ---
# out:     receives the assembled component
# name:    the component's name span
# desc_lo: byte offset of the description start
# desc_hi: byte offset just past the description (equal to desc_lo when empty)
# ret:     always true, so a caller can `ret emit_component(...)`
fun emit_component(out: *DocComponent, name: token.Span, desc_lo: usize, desc_hi: usize) bool {
    out.name_span = name;
    if (desc_hi > desc_lo) {
        out.desc_span.offset = desc_lo;
        out.desc_span.len    = desc_hi - desc_lo;
    }
    or {
        out.desc_span = empty_span();
    }
    ret true;
}

# a span covering the whole of `s` (offset 0), for the tests
# ---
# s:   the string to span
# ret: a span from 0 to the string's length
fun t_span(s: str) token.Span {
    var sp: token.Span;
    sp.offset = 0;
    sp.len    = str_len(s);
    ret sp;
}

# whether `span` equals the byte content of `expect` within `source`
# ---
# source: the source text `span` indexes into
# span:   the span to compare
# expect: the expected byte content
# ret:    true when the span's bytes equal `expect`
fun t_eq(source: str, span: token.Span, expect: str) bool {
    ret str_region_equals(source, span.offset, span.len, expect);
}

# a summary-only block has no component block and yields a trimmed summary.
test "mach.lang.fe.doc.summary_span:summary_only" {
    val src: str = "# yield the CPU to other threads";
    val doc: token.Span = t_span(src);

    if (has_component_block(src, doc))                                        { ret 1; }
    if (!t_eq(src, summary_span(src, doc), "yield the CPU to other threads")) { ret 1; }

    var it: DocComponentIter = component_iter(src, doc);
    var c:  DocComponent;
    if (component_next(?it, ?c)) { ret 1; }
    ret 0;
}

# a `# ---` block splits the summary from the ordered component lines.
test "mach.lang.fe.doc.component_next:ordered_components" {
    val src: str = "# read the wall-clock time\n# ---\n# out: pointer to populate\n# ret: 0 on success";
    val doc: token.Span = t_span(src);

    if (!has_component_block(src, doc))                                 { ret 1; }
    if (!t_eq(src, summary_span(src, doc), "read the wall-clock time")) { ret 1; }

    var it: DocComponentIter = component_iter(src, doc);
    var c:  DocComponent;

    if (!component_next(?it, ?c))                       { ret 1; }
    if (!t_eq(src, c.name_span, "out"))                 { ret 1; }
    if (!t_eq(src, c.desc_span, "pointer to populate")) { ret 1; }

    if (!component_next(?it, ?c))                { ret 1; }
    if (!t_eq(src, c.name_span, "ret"))          { ret 1; }
    if (!t_eq(src, c.desc_span, "0 on success")) { ret 1; }

    if (component_next(?it, ?c)) { ret 1; }
    ret 0;
}

# component names keep their syntactic form ([T], $order) and aligned colons trim.
test "mach.lang.fe.doc.component_next:name_forms" {
    val src: str = "# atomic load\n# ---\n# [T]:    element type\n# $order: memory ordering\n# ptr:    pointer to load from";
    val doc: token.Span = t_span(src);

    var it: DocComponentIter = component_iter(src, doc);
    var c:  DocComponent;

    if (!component_next(?it, ?c))                { ret 1; }
    if (!t_eq(src, c.name_span, "[T]"))          { ret 1; }
    if (!t_eq(src, c.desc_span, "element type")) { ret 1; }

    if (!component_next(?it, ?c))          { ret 1; }
    if (!t_eq(src, c.name_span, "$order")) { ret 1; }

    if (!component_next(?it, ?c))       { ret 1; }
    if (!t_eq(src, c.name_span, "ptr")) { ret 1; }
    ret 0;
}

# the colon-less `#` line under `a:` has no head, so it is a continuation of
# `a`'s description, not a new component. only two components are produced.
test "mach.lang.fe.doc.component_next:wrapped_continuation" {
    val src: str = "# wrapped\n# ---\n# a: a long description that\n#    wraps onto a second line\n# b: short";
    val doc: token.Span = t_span(src);

    var it: DocComponentIter = component_iter(src, doc);
    var c:  DocComponent;

    if (!component_next(?it, ?c))     { ret 1; }
    if (!t_eq(src, c.name_span, "a")) { ret 1; }
    # the description span reaches the end of the continuation line.
    if (!t_eq(src, c.desc_span, "a long description that\n#    wraps onto a second line")) { ret 1; }

    if (!component_next(?it, ?c))     { ret 1; }
    if (!t_eq(src, c.name_span, "b")) { ret 1; }

    if (component_next(?it, ?c)) { ret 1; }
    ret 0;
}

# `a`'s description wraps onto an indented line that itself starts `facts:`. the
# deep indent (more than one space after `#`) marks it a continuation, so only
# `a` and `b` are real components and `facts` is not mistaken for one.
test "mach.lang.fe.doc.component_next:deep_indent_continuation" {
    val src: str = "# wrapped\n# ---\n# a: leading text\n#       facts: still part of a\n# b: short";
    val doc: token.Span = t_span(src);

    var it: DocComponentIter = component_iter(src, doc);
    var c:  DocComponent;

    if (!component_next(?it, ?c))     { ret 1; }
    if (!t_eq(src, c.name_span, "a")) { ret 1; }

    if (!component_next(?it, ?c))     { ret 1; }
    if (!t_eq(src, c.name_span, "b")) { ret 1; }

    if (component_next(?it, ?c)) { ret 1; }
    ret 0;
}

# an empty doc span has no summary, no component block, and no components.
test "mach.lang.fe.doc:empty_block" {
    val src: str = "";
    var doc: token.Span;
    doc.offset = 0;
    doc.len    = 0;

    if (has_component_block(src, doc))   { ret 1; }
    if (summary_span(src, doc).len != 0) { ret 1; }

    var it: DocComponentIter = component_iter(src, doc);
    var c:  DocComponent;
    if (component_next(?it, ?c)) { ret 1; }
    ret 0;
}
