# the structured result of the build layer: its error currency and its artifacts
#
# The orchestration layer speaks two channels. Located diagnostics go to the
# session sink; every function that can fail returns `R.Result[T, Fail]`. `Fail`
# ties the two together: a failure already filed on the sink carries `reported`,
# so the single render step prints nothing further for it, while an unreported
# failure carries the message to print. `BuildOutcome` is the success side - the
# artifacts a plan produced, plus the exit derivation inputs. Nothing below the
# render layer prints; nothing below the engine derives an exit code.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.string.str;

use std.collections.vector.Vector;

# the orchestration layer's single error currency
#
# `reported` marks a failure already filed on the diagnostic sink as a located
# diagnostic; the renderer prints nothing further for it. `internal`
# distinguishes compiler faults from user errors for exit-code derivation.
# ---
# reported: the failure was already filed as a located diagnostic on the sink
# message:  the text to print for an unreported failure; empty when reported
# internal: a compiler fault (exit 2) rather than a user error (exit 1)
pub rec Fail {
    reported: bool;
    message:  str;
    internal: bool;
}

# an unreported user error carrying `message` for the renderer to print (exit 1)
# ---
# message: the text to print after the `error: ` prefix
# ret:     a Fail the render step prints and derives exit code 1 from
pub fun user(message: str) Fail {
    var f: Fail;
    f.reported = false;
    f.message  = message;
    f.internal = false;
    ret f;
}

# an unreported internal compiler fault carrying `message` for the renderer (exit 2)
# ---
# message: the text to print after the `error: ` prefix
# ret:     a Fail the render step prints and derives exit code 2 from
pub fun internal(message: str) Fail {
    var f: Fail;
    f.reported = false;
    f.message  = message;
    f.internal = true;
    ret f;
}

# a failure already filed as a located diagnostic on the session sink
#
# The diagnostic flush is the user-facing message, so the renderer prints
# nothing further; the exit code is a user error (1).
# ---
# ret: a Fail the render step prints nothing for and derives exit code 1 from
pub fun reported() Fail {
    var f: Fail;
    f.reported = true;
    f.message  = "";
    f.internal = false;
    ret f;
}

# one produced artifact's kind, discriminating the `Artifact` payload
pub def ArtifactKind: u8;
pub val ART_BINARY:  ArtifactKind = 0;
pub val ART_OBJECTS: ArtifactKind = 1;
pub val ART_ARCHIVE: ArtifactKind = 2;
pub val ART_SHARED:  ArtifactKind = 3;
pub val ART_TESTS:   ArtifactKind = 4;

# one produced artifact: its kind and its path on disk
# ---
# kind: the artifact kind (binary, objects, archive, shared object, tests)
# path: the produced artifact's path
pub rec Artifact {
    kind: ArtifactKind;
    path: str;
}

# one built test - its reporting metadata and its dispatch coordinates
#
# All owned strings come from the build allocator, so they outlive the session
# teardown inside `build_tests` and stay valid until the caller frees that
# allocator (after it has run every test).
# ---
# module: owned fully-qualified name of the declaring module, the runner's
#         per-module roll-up key (collection order keeps a module's tests adjacent)
# label:  owned printable test name (the `test "..."` literal's inner text)
# file:   owned source file path of the declaring module
# line:   1-based source line of the `test` keyword
# exe:    owned absolute path to the shared dispatcher executable (the same
#         path on every artifact of a build); nil in `--list` mode
# idx:    the test's dispatch index - the dispatcher runs it for `<exe> <idx>`
pub rec TestArtifact {
    module: *u8;
    label:  *u8;
    file:   *u8;
    line:   u32;
    exe:    *u8;
    idx:    u32;
}

# the structured result of executing a plan
#
# `ok` and `internal` are the exit derivation inputs the render step reads (ok
# -> 0, user error -> 1, internal fault -> 2). `artifacts` lists what the build
# produced; `tests` and `tests_skipped` are populated only for test goals.
# ---
# ok:            the plan executed with no failure
# internal:      a failure was a compiler fault rather than a user error
# artifacts:     the produced artifacts, one per built unit output
# tests:         the built test artifacts; empty for non-test goals
# tests_skipped: target-gated own-src modules excluded from collection (#1873)
pub rec BuildOutcome {
    ok:            bool;
    internal:      bool;
    artifacts:     Vector[Artifact];
    tests:         Vector[TestArtifact];
    tests_skipped: u32;
}

# the render seam: engine-side moments the CLI's render layer turns into text
#
# The engine emits through the nil-safe free functions below at the moment
# each event lands, so a consumer renders failures and diagnostics interleaved
# with the build exactly where they occur; the engine itself never prints.
# Every fn pointer must be populated on a live sink; a nil sink is silent.
# ---
# ctx:      opaque consumer state handed to each callback
# fn_unit:  a plan unit is starting (artifact selector, target selector,
#           whether an artifact is named)
# fn_note:  the one-shot scalarization note (#2016): the summed vector-op count
# fn_fail:  a failure, at the moment it is final
# fn_diags: flush a unit session's located diagnostics; the session is handed
#           as an opaque pointer (cast back to *session.Session)
pub rec Render {
    ctx:      ptr;
    fn_unit:  fun(ptr, str, str, bool);
    fn_note:  fun(ptr, u32);
    fn_fail:  fun(ptr, *Fail);
    fn_diags: fun(ptr, ptr);
}

# emit a unit-start event; a nil sink is a no-op
# ---
# rd:           the sink, or nil
# artifact:     the unit's artifact selector
# target:       the unit's target selector (empty for the manifest default)
# has_artifact: an artifact is named
pub fun render_unit(rd: *Render, artifact: str, target: str, has_artifact: bool) {
    if (rd == nil) { ret; }
    rd.fn_unit(rd.ctx, artifact, target, has_artifact);
}

# emit the scalarization-note event; a nil sink is a no-op
# ---
# rd:    the sink, or nil
# total: the summed scalarized vector-operation count (non-zero)
pub fun render_note(rd: *Render, total: u32) {
    if (rd == nil) { ret; }
    rd.fn_note(rd.ctx, total);
}

# emit a failure event; a nil sink is a no-op
# ---
# rd: the sink, or nil
# f:  the failure that just became final
pub fun render_fail(rd: *Render, f: *Fail) {
    if (rd == nil) { ret; }
    rd.fn_fail(rd.ctx, f);
}

# emit a diagnostics-flush event for a unit session; a nil sink is a no-op
# ---
# rd: the sink, or nil
# s:  the unit's session as an opaque pointer
pub fun render_diags(rd: *Render, s: ptr) {
    if (rd == nil) { ret; }
    rd.fn_diags(rd.ctx, s);
}
