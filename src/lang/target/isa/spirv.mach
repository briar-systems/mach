# SPIR-V instruction set: the word-stream module builder
#
# Owns the SPIR-V binary constants (magic, version, the subset of core opcodes,
# capabilities, storage classes, decorations) and the low-level `Builder` that
# assembles a valid SPIR-V module as a stream of 32-bit words. SPIR-V is not a
# linear machine code: it is a typed, SSA-flavoured word stream organised into
# ordered logical sections (capabilities, memory model, decorations, types and
# constants, then function bodies), with every result bound to a numeric id. The
# `Builder` allocates ids and appends instructions into the per-section word
# vectors; `serialize` frames the header and concatenates the sections into the
# final little-endian byte image.
#
# This is the target-specific "opcode space" analogue of `isa.x64`: it holds only
# the SPIR-V-shaped facts. The `IsaVTable` is built by the sibling `register`
# module, the MIR-to-module translation lives in `emit`, and the type / constant
# deduplication in `types`. It imports no back-end module, so it stays a leaf the
# emitter and the object-format writer can both name.

use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

# the SPIR-V module magic number, the first header word of every module
pub val SPV_MAGIC: u32 = 0x07230203;

# the SPIR-V 1.6 version word (major 1, minor 6 in the middle two bytes)
pub val SPV_VERSION_1_6: u32 = 0x00010600;

# the generator magic stamped into the header; 0 is the reserved "unknown tool"
# value, which every validator accepts
pub val SPV_GENERATOR: u32 = 0;

# the core SPIR-V opcodes the emitter produces. each is the low 16 bits of an
# instruction's first word; the high 16 bits carry the instruction's total word
# count (`inst_word`)
pub val OP_NAME:                u32 = 5;
pub val OP_MEMORY_MODEL:        u32 = 14;
pub val OP_CAPABILITY:          u32 = 17;
pub val OP_TYPE_VOID:           u32 = 19;
pub val OP_TYPE_BOOL:           u32 = 20;
pub val OP_TYPE_INT:            u32 = 21;
pub val OP_TYPE_FLOAT:          u32 = 22;
pub val OP_TYPE_VECTOR:         u32 = 23;
pub val OP_TYPE_POINTER:        u32 = 32;
pub val OP_TYPE_FUNCTION:       u32 = 33;
pub val OP_CONSTANT_TRUE:       u32 = 41;
pub val OP_CONSTANT_FALSE:      u32 = 42;
pub val OP_CONSTANT:            u32 = 43;
pub val OP_FUNCTION:            u32 = 54;
pub val OP_FUNCTION_PARAMETER:  u32 = 55;
pub val OP_FUNCTION_END:        u32 = 56;
pub val OP_FUNCTION_CALL:       u32 = 57;
pub val OP_VARIABLE:            u32 = 59;
pub val OP_LOAD:                u32 = 61;
pub val OP_STORE:               u32 = 62;
pub val OP_DECORATE:            u32 = 71;
pub val OP_CONVERT_F_TO_U:      u32 = 109;
pub val OP_CONVERT_F_TO_S:      u32 = 110;
pub val OP_CONVERT_S_TO_F:      u32 = 111;
pub val OP_CONVERT_U_TO_F:      u32 = 112;
pub val OP_U_CONVERT:           u32 = 113;
pub val OP_S_CONVERT:           u32 = 114;
pub val OP_F_CONVERT:           u32 = 115;
pub val OP_BITCAST:             u32 = 124;
pub val OP_S_NEGATE:            u32 = 126;
pub val OP_F_NEGATE:            u32 = 127;
pub val OP_I_ADD:               u32 = 128;
pub val OP_F_ADD:               u32 = 129;
pub val OP_I_SUB:               u32 = 130;
pub val OP_F_SUB:               u32 = 131;
pub val OP_I_MUL:               u32 = 132;
pub val OP_F_MUL:               u32 = 133;
pub val OP_U_DIV:               u32 = 134;
pub val OP_S_DIV:               u32 = 135;
pub val OP_F_DIV:               u32 = 136;
pub val OP_U_MOD:               u32 = 137;
pub val OP_S_REM:               u32 = 138;
pub val OP_F_REM:               u32 = 140;
pub val OP_I_EQUAL:             u32 = 170;
pub val OP_I_NOT_EQUAL:         u32 = 171;
pub val OP_U_LESS_THAN:         u32 = 176;
pub val OP_S_LESS_THAN:         u32 = 177;
pub val OP_U_LESS_THAN_EQUAL:   u32 = 178;
pub val OP_S_LESS_THAN_EQUAL:   u32 = 179;
pub val OP_F_ORD_EQUAL:         u32 = 180;
pub val OP_F_ORD_NOT_EQUAL:     u32 = 182;
pub val OP_F_ORD_LESS_THAN:     u32 = 184;
pub val OP_F_ORD_LESS_THAN_EQUAL: u32 = 188;
pub val OP_SHIFT_RIGHT_LOGICAL:    u32 = 194;
pub val OP_SHIFT_RIGHT_ARITHMETIC: u32 = 195;
pub val OP_SHIFT_LEFT_LOGICAL:     u32 = 196;
pub val OP_BITWISE_OR:          u32 = 197;
pub val OP_BITWISE_XOR:         u32 = 198;
pub val OP_BITWISE_AND:         u32 = 199;
pub val OP_NOT:                 u32 = 200;
pub val OP_LOOP_MERGE:          u32 = 246;
pub val OP_SELECTION_MERGE:     u32 = 247;
pub val OP_LABEL:               u32 = 248;
pub val OP_BRANCH:              u32 = 249;
pub val OP_BRANCH_CONDITIONAL:  u32 = 250;
pub val OP_RETURN:              u32 = 253;
pub val OP_RETURN_VALUE:        u32 = 254;
pub val OP_UNREACHABLE:         u32 = 255;

# capability operands (OpCapability). Shader gives the structured-control-flow and
# logical-addressing feature set; Linkage lets the module export functions with no
# entry point, so a compiled mach function is a library export rather than a
# graphics / compute shader stage
pub val CAP_SHADER:  u32 = 1;
pub val CAP_LINKAGE: u32 = 5;

# addressing model operand of OpMemoryModel: Logical (no physical pointers - the
# only model a Shader/Linkage module without the Addresses capability may use)
pub val ADDRESSING_LOGICAL: u32 = 0;

# memory model operand of OpMemoryModel: GLSL450 (the general-purpose model a
# Shader module pairs with the logical addressing model)
pub val MEMORY_GLSL450: u32 = 1;

# storage class operand of OpTypePointer / OpVariable: Function (a value with
# automatic storage local to one function invocation - the class every MIR vreg's
# backing variable lives in)
pub val STORAGE_FUNCTION: u32 = 7;

# decoration operand of OpDecorate: LinkageAttributes (names an exported / imported
# symbol and its linkage), the decoration that publishes a function under the
# Linkage capability
pub val DECOR_LINKAGE_ATTRIBUTES: u32 = 41;

# linkage-type operand trailing a LinkageAttributes decoration: Export makes the
# decorated function visible to a consumer of the module
pub val LINKAGE_EXPORT: u32 = 0;

# function-control operand of OpFunction: None (no inline / pure / const hints)
pub val FUNCTION_CONTROL_NONE: u32 = 0;

# loop-control operand of OpLoopMerge: None (no unroll / dont-unroll hints)
pub val LOOP_CONTROL_NONE: u32 = 0;

# selection-control operand of OpSelectionMerge: None (no flatten hints)
pub val SELECTION_CONTROL_NONE: u32 = 0;

# the assembler of a SPIR-V module as ordered word-stream sections
#
# Ids are allocated from a single monotone counter shared across every section, so
# `next_id` is also the module's id bound. Instructions are appended into the
# section their logical position requires; `serialize` frames the header and
# concatenates them in SPIR-V's mandated order. `err` latches an allocation
# failure the way `isa.InstBuf.err` does, so a batch of appends is checked once.
# ---
# alloc:        allocator backing every section vector and the serialized image
# next_id:      the next id to hand out; equals the id bound at serialize time
# caps:         OpCapability instructions
# memory_model: the single OpMemoryModel instruction
# decorations:  OpDecorate / OpName instructions
# types_consts: OpType* / OpConstant* / global OpTypePointer instructions
# functions:    OpFunction ... OpFunctionEnd bodies, in emission order
# err:          latched true when an append hit an allocation error
pub rec Builder {
    alloc:        *A.Allocator;
    next_id:      u32;
    caps:         Vec;
    memory_model: Vec;
    decorations:  Vec;
    types_consts: Vec;
    functions:    Vec;
    err:          bool;
}

# a growable word buffer, one SPIR-V logical section's contents
#
# A hand-rolled `u32` vector rather than the generic `std` vector so this leaf
# depends on nothing but the allocator; growth doubles the capacity from a small
# seed.
# ---
# words: the backing word array (owned)
# len:   number of words stored
# cap:   allocated capacity in words
pub rec Vec {
    words: *u32;
    len:   u32;
    cap:   u32;
}

# seed capacity for a section vector's first growth
val VEC_INIT_CAP: u32 = 32;

# construct an empty word buffer; allocates nothing until the first append
# ---
# ret: an empty Vec
fun vec_init() Vec {
    var v: Vec;
    v.words = nil;
    v.len   = 0;
    v.cap   = 0;
    ret v;
}

# append one word, growing the buffer if needed; sets `b.err` on allocation failure
# ---
# b:   the builder whose allocator backs the buffer and whose err latches failure
# v:   the section buffer to append to
# w:   the word to append
fun vec_push(b: *Builder, v: *Vec, w: u32) {
    if (b.err) { ret; }
    if (v.len >= v.cap) {
        var new_cap: u32 = VEC_INIT_CAP;
        if (v.cap > 0) { new_cap = v.cap * 2; }
        if (v.words == nil) {
            val ra: R.Result[*u32, str] = A.allocate[u32](b.alloc, new_cap::usize);
            if (R.is_err[*u32, str](ra)) { b.err = true; ret; }
            v.words = R.unwrap_ok[*u32, str](ra);
        }
        or {
            val rr: R.Result[*u32, str] = A.reallocate[u32](b.alloc, v.words, v.cap::usize, new_cap::usize);
            if (R.is_err[*u32, str](rr)) { b.err = true; ret; }
            v.words = R.unwrap_ok[*u32, str](rr);
        }
        v.cap = new_cap;
    }
    v.words[v.len] = w;
    v.len = v.len + 1;
}

# release a section buffer's backing storage
# ---
# b: the builder whose allocator owns the buffer
# v: the buffer to free
fun vec_dnit(b: *Builder, v: *Vec) {
    if (v.words != nil && v.cap > 0) {
        A.deallocate[u32](b.alloc, v.words, v.cap::usize);
    }
    v.words = nil;
    v.len   = 0;
    v.cap   = 0;
}

# construct a fresh module builder with every section empty and id allocation
# starting at 1 (id 0 is reserved / never valid in SPIR-V)
# ---
# alloc: allocator backing every section and the serialized image
# ret:   an initialized Builder
pub fun builder_init(alloc: *A.Allocator) Builder {
    var b: Builder;
    b.alloc        = alloc;
    b.next_id      = 1;
    b.caps         = vec_init();
    b.memory_model = vec_init();
    b.decorations  = vec_init();
    b.types_consts = vec_init();
    b.functions    = vec_init();
    b.err          = false;
    ret b;
}

# release every section buffer a builder owns; safe on a partially built builder
# ---
# b: the builder to tear down
pub fun builder_dnit(b: *Builder) {
    vec_dnit(b, ?b.caps);
    vec_dnit(b, ?b.memory_model);
    vec_dnit(b, ?b.decorations);
    vec_dnit(b, ?b.types_consts);
    vec_dnit(b, ?b.functions);
}

# allocate a fresh SPIR-V result id
# ---
# b:   the builder
# ret: the new id (never 0)
pub fun alloc_id(b: *Builder) u32 {
    val id: u32 = b.next_id;
    b.next_id = b.next_id + 1;
    ret id;
}

# the first word of an instruction: the total word count in the high half, the
# opcode in the low half
# ---
# opcode: the SPIR-V opcode
# words:  the instruction's total word count (including this word)
# ret:    the packed first word
pub fun inst_word(opcode: u32, words: u32) u32 {
    ret (words << 16) | (opcode & 0xFFFF);
}

# append a complete instruction to a section: the opcode plus `n` pre-built operand
# words. the caller assembles the operands (ids, literals, packed strings) into
# `ops`; this frames the word count
# ---
# b:      the builder (its allocator backs the section, its err latches failure)
# v:      the section buffer to append to
# opcode: the SPIR-V opcode
# ops:    the operand words, or nil when `n` is 0
# n:      number of operand words
pub fun inst(b: *Builder, v: *Vec, opcode: u32, ops: *u32, n: u32) {
    vec_push(b, v, inst_word(opcode, n + 1));
    var i: u32 = 0;
    for (i < n) {
        vec_push(b, v, ops[i]);
        i = i + 1;
    }
}

# the number of words a SPIR-V literal string occupies: its bytes plus a NUL
# terminator, rounded up to a whole word
# ---
# s:   the string
# ret: the word count
pub fun string_words(s: str) u32 {
    val bytes: u32 = str_len(s)::u32 + 1;
    ret (bytes + 3) / 4;
}

# pack a literal string into consecutive operand words (4 bytes per word,
# little-endian, NUL-terminated, zero-padded to a whole word)
# ---
# s:   the string to pack
# out: destination word array, at least `string_words(s)` wide
# ret: the number of words written
pub fun pack_string(s: str, out: *u32) u32 {
    val n: usize = str_len(s);
    val words: u32 = string_words(s);
    var wi: u32 = 0;
    for (wi < words) {
        var w: u32 = 0;
        var byte: u32 = 0;
        for (byte < 4) {
            val idx: usize = (wi * 4 + byte)::usize;
            var b: u32 = 0;
            if (idx < n) { b = s[idx]::u32; }
            w = w | (b << (byte * 8));
            byte = byte + 1;
        }
        out[wi] = w;
        wi = wi + 1;
    }
    ret words;
}

# frame the header and concatenate the sections into the final module byte image
#
# The word bound is the current `next_id` (one past the highest id handed out).
# Sections are emitted in SPIR-V's required order: capabilities, memory model,
# decorations, types / constants, then function bodies. Every word is serialized
# little-endian. The returned buffer is allocated from the builder's allocator and
# owned by the caller.
# ---
# b:       the fully populated builder
# out_len: receives the byte length of the image
# ret:     the owned little-endian byte image, or an error string
pub fun serialize(b: *Builder, out_len: *u32) R.Result[*u8, str] {
    if (b.err) { ret R.err[*u8, str]("spirv: module builder hit an allocation error"); }

    val total_words: u32 = 5 + b.caps.len + b.memory_model.len + b.decorations.len
                         + b.types_consts.len + b.functions.len;
    val total_bytes: u32 = total_words * 4;

    val rb: R.Result[*u8, str] = A.allocate[u8](b.alloc, total_bytes::usize);
    if (R.is_err[*u8, str](rb)) { ret rb; }
    val buf: *u8 = R.unwrap_ok[*u8, str](rb);

    var pos: u32 = 0;
    pos = put_word(buf, pos, SPV_MAGIC);
    pos = put_word(buf, pos, SPV_VERSION_1_6);
    pos = put_word(buf, pos, SPV_GENERATOR);
    pos = put_word(buf, pos, b.next_id);
    pos = put_word(buf, pos, 0);  # schema, reserved 0

    pos = put_section(buf, pos, ?b.caps);
    pos = put_section(buf, pos, ?b.memory_model);
    pos = put_section(buf, pos, ?b.decorations);
    pos = put_section(buf, pos, ?b.types_consts);
    pos = put_section(buf, pos, ?b.functions);

    @out_len = total_bytes;
    ret R.ok[*u8, str](buf);
}

# write one little-endian word at byte offset `pos`, returning the next offset
# ---
# buf: destination byte buffer
# pos: byte offset to write at
# w:   the word to write
# ret: the offset past the written word
fun put_word(buf: *u8, pos: u32, w: u32) u32 {
    buf[pos]     = (w & 0xFF)::u8;
    buf[pos + 1] = ((w >> 8) & 0xFF)::u8;
    buf[pos + 2] = ((w >> 16) & 0xFF)::u8;
    buf[pos + 3] = ((w >> 24) & 0xFF)::u8;
    ret pos + 4;
}

# serialize a whole section's words at byte offset `pos`, returning the next offset
# ---
# buf: destination byte buffer
# pos: byte offset to write at
# v:   the section buffer to serialize
# ret: the offset past the section
fun put_section(buf: *u8, pos: u32, v: *Vec) u32 {
    var p: u32 = pos;
    var i: u32 = 0;
    for (i < v.len) {
        p = put_word(buf, p, v.words[i]);
        i = i + 1;
    }
    ret p;
}

test "mach.lang.target.isa.spirv.inst_word:pack" {
    # OpIAdd (128) as a 5-word instruction packs the count in the high half.
    if (inst_word(OP_I_ADD, 5) != 0x00050080) { ret 1; }
    # OpCapability (17) as a 2-word instruction.
    if (inst_word(OP_CAPABILITY, 2) != 0x00020011) { ret 1; }
    ret 0;
}

test "mach.lang.target.isa.spirv.pack_string:linkage_name" {
    # "add" packs into one word, little-endian, NUL-terminated: 'a'|'d'<<8|'d'<<16.
    if (string_words("add") != 1) { ret 1; }
    var w: [4]u32;
    if (pack_string("add", ?w[0]) != 1) { ret 1; }
    if (w[0] != 0x00646461) { ret 1; }

    # a 4-char name needs two words (the NUL forces a second word).
    if (string_words("main") != 2) { ret 1; }
    ret 0;
}

test "mach.lang.target.isa.spirv.serialize:header_and_bound" {
    var alloc: A.Allocator;
    if (O.is_some[str](page.make(?alloc))) { ret 1; }

    var b: Builder = builder_init(?alloc);

    # two capabilities and a memory model, nothing else.
    var caps: [1]u32;
    caps[0] = CAP_SHADER;
    inst(?b, ?b.caps, OP_CAPABILITY, ?caps[0], 1);
    caps[0] = CAP_LINKAGE;
    inst(?b, ?b.caps, OP_CAPABILITY, ?caps[0], 1);
    var mm: [2]u32;
    mm[0] = ADDRESSING_LOGICAL;
    mm[1] = MEMORY_GLSL450;
    inst(?b, ?b.memory_model, OP_MEMORY_MODEL, ?mm[0], 2);

    # allocate three ids so the bound is 4.
    alloc_id(?b); alloc_id(?b); alloc_id(?b);

    var len: u32 = 0;
    val rs: R.Result[*u8, str] = serialize(?b, ?len);
    builder_dnit(?b);
    if (R.is_err[*u8, str](rs)) { ret 1; }
    val buf: *u8 = R.unwrap_ok[*u8, str](rs);

    # header: magic, version 1.6, bound 4 at word 3.
    if (read_word(buf, 0) != SPV_MAGIC)        { A.deallocate[u8](?alloc, buf, len::usize); ret 1; }
    if (read_word(buf, 4) != SPV_VERSION_1_6)  { A.deallocate[u8](?alloc, buf, len::usize); ret 1; }
    if (read_word(buf, 12) != 4)               { A.deallocate[u8](?alloc, buf, len::usize); ret 1; }
    # first instruction after the 5-word header: OpCapability Shader.
    if (read_word(buf, 20) != 0x00020011)      { A.deallocate[u8](?alloc, buf, len::usize); ret 1; }
    if (read_word(buf, 24) != CAP_SHADER)      { A.deallocate[u8](?alloc, buf, len::usize); ret 1; }

    A.deallocate[u8](?alloc, buf, len::usize);
    ret 0;
}

# read one little-endian word at byte offset `pos`; a test helper mirroring
# `put_word`
# ---
# buf: source byte buffer
# pos: byte offset to read from
# ret: the decoded word
fun read_word(buf: *u8, pos: u32) u32 {
    ret buf[pos]::u32 | (buf[pos + 1]::u32 << 8) | (buf[pos + 2]::u32 << 16) | (buf[pos + 3]::u32 << 24);
}
