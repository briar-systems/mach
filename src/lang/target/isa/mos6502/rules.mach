# MOS 6502 instruction-selection rule pack
#
# The 6502 contribution to the shared rule engine (`be.codegen.rules`). By the time
# selection runs, `be.codegen.legalize` has rewritten every wider-than-8-bit scalar
# into native byte operations, so this pack only ever sees 1-byte ops - and because
# the 6502 is an accumulator machine (no register-to-register arithmetic), almost
# every operation survives selection as its generic opcode and the encoder
# materializes the load-A / operate / store-A byte sequence. The pack is therefore
# small and boring: it retags the moves and control-flow terminators to concrete
# 6502 opcodes and passes everything else through. That smallness is the 8-bit
# target succeeding - the width legalization did the hard work upstream.
#
# The encoder (`mos6502.encode`) is the total authority on what the 6502 can
# realize: an operation the hardware lacks (a byte multiply, any divide, a
# floating-point op) reaches the encoder as a passed-through generic opcode and is
# rejected there with a loud, specific diagnostic, mirroring how the legalizer
# rejects the wide forms of the same operations.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use R: std.types.result;

use mach.lang.be.codegen.mir;
use mach.lang.be.codegen.rules;
use mach.lang.target.isa.mos6502;
use target: mach.lang.target.resolved;

# the concrete signature the erased `isa.IsaVTable.select` pointer is cast back to,
# matching the shared `be.codegen.isel.SelectFn`
# ---
# a:   backing allocator (threaded for the shared SelectFn contract)
# tgt: resolved compilation target (must be mos6502)
# f:   the MIR function to select instructions for; mutated in place
# ret: ok(true) on success, or an error naming the failure
pub def SelectFn: fun(*A.Allocator, *target.Target, *mir.MirFunction) R.Result[bool, str];

# the number of rules in the pack: one per reachable generic opcode plus the six
# fused compare-and-branch survivors. the coverage test pins it so a rule added to
# the table and this count cannot drift apart
pub val RULE_COUNT: usize = 51;

# the number of post-selection plain register-copy opcodes
pub val COPY_OPCODE_COUNT: usize = 2;

# the number of comparison opcodes the engine's compare-and-branch fusion combines
pub val FUSED_CC_COUNT: usize = 6;

# the pack's rule table, ordered by match priority
#
# Retags the moves and control-flow terminators to concrete 6502 opcodes; passes
# every other reachable generic opcode through for the encoder to materialize (or
# to reject when the hardware cannot realize it).
pub val RULES: [RULE_COUNT]rules.Rule = [RULE_COUNT]rules.Rule{
    # moves and control flow retag to concrete 6502 opcodes.
    rules.Rule{ op: mir.MIR_MOV,         gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_RETAG, to: mos6502.MOV::u32, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_BR,          gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_RETAG, to: mos6502.JMP::u32, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_RET,         gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_RETAG, to: mos6502.RTS::u32, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_UNREACHABLE, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_RETAG, to: mos6502.BRK::u32, expand: nil, expansion_length: 0 },

    # the integer ALU / logic ops pass through: the encoder materializes each as a
    # load-A / operate / store-A byte sequence. the hardware-absent forms (multiply,
    # divide, remainder) also pass through and are rejected at encode time.
    rules.Rule{ op: mir.MIR_ADD,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SUB,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_MUL,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_DIV_S, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_DIV_U, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_REM_S, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_REM_U, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_NEG,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_AND,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_OR,    gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_XOR,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SHL,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SHR_S, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SHR_U, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_NOT,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },

    # the comparisons and the conditional branch pass through; the encoder
    # materializes the CMP + Bxx byte sequence. the pack declares all six conditions
    # fusable, so a single-consumer `CMP ; CBR` pair collapses ahead of selection
    # into a `MIR_SEL_CBR_*` survivor (below); a compare whose boolean is consumed
    # elsewhere stays a plain compare the encoder lowers to a 0/1 result.
    rules.Rule{ op: mir.MIR_CMP_EQ,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CMP_NE,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CMP_LT_S, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CMP_LT_U, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CMP_LE_S, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CMP_LE_U, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CBR,      gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },

    # the fused compare-and-branch survivors the engine's combine produces; the
    # encoder materializes the native `LDA ; CMP ; B!cc ; JMP then ; JMP else`
    # sequence. scalar-gated: the combine never fuses a vector lane.
    rules.Rule{ op: mir.MIR_SEL_CBR_EQ,   gate: rules.GATE_SCALAR, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SEL_CBR_NE,   gate: rules.GATE_SCALAR, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SEL_CBR_LT_S, gate: rules.GATE_SCALAR, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SEL_CBR_LT_U, gate: rules.GATE_SCALAR, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SEL_CBR_LE_S, gate: rules.GATE_SCALAR, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SEL_CBR_LE_U, gate: rules.GATE_SCALAR, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },

    # the width conversions pass through: after legalization these are byte moves or
    # zero / sign fills the encoder emits (or rejects for the float forms).
    rules.Rule{ op: mir.MIR_TRUNC,    gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SEXT,     gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_ZEXT,     gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_FP_TRUNC, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_FP_EXT,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_FP_TO_SI, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_FP_TO_UI, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_SI_TO_FP, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_UI_TO_FP, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_BITCAST,  gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },

    # memory and address ops pass through to the encoder's zero-page / absolute /
    # frame-relative addressing.
    rules.Rule{ op: mir.MIR_ALLOCA, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_LOAD,   gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_STORE,  gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_GEP,    gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },

    # call / phi pseudos pass through; MIR_CALL is the caller-saved clobber barrier
    # the shared allocator keys on.
    rules.Rule{ op: mir.MIR_CALL,     gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_ARG,      gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_CALL_RES, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
    rules.Rule{ op: mir.MIR_PHI,      gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },

    # inline assembly passes through; the encoder emits the body bytes directly.
    rules.Rule{ op: mir.MIR_ASM, gate: rules.GATE_ANY, guard: nil, kind: rules.RULE_PASS, to: 0, expand: nil, expansion_length: 0 },
};

# the post-selection plain register-copy opcodes: the concrete 6502 move and the
# generic `mir.MIR_MOV` the reload / store moves regalloc splices after selection
pub val COPY_OPCODES: [COPY_OPCODE_COUNT]u32 = [COPY_OPCODE_COUNT]u32{
    mos6502.MOV::u32,
    mir.MIR_MOV,
};

# the comparison opcodes the engine's compare-and-branch fusion combines with a
# consuming conditional branch: all six scalar conditions, so a `CMP ; CBR` pair
# collapses to one native compare-and-branch the encoder materializes directly
pub val FUSED_CCS: [FUSED_CC_COUNT]u32 = [FUSED_CC_COUNT]u32{
    mir.MIR_CMP_EQ,
    mir.MIR_CMP_NE,
    mir.MIR_CMP_LT_S,
    mir.MIR_CMP_LT_U,
    mir.MIR_CMP_LE_S,
    mir.MIR_CMP_LE_U,
};

# the pack handed to the shared engine
#
# Retags the moves and control-flow terminators to concrete 6502 opcodes; passes
# every other reachable generic opcode through for the encoder to materialize (or
# to reject when the hardware cannot realize it).
pub val PACK: rules.RulePack = rules.RulePack{
    name:               "mos6502",
    rules:              ?RULES[0],
    rule_count:         RULE_COUNT::u32,
    copy_opcodes:       ?COPY_OPCODES[0],
    copy_opcode_count:  COPY_OPCODE_COUNT::u32,
    fused_cbr_ccs:      ?FUSED_CCS[0],
    fused_cbr_cc_count: FUSED_CC_COUNT::u32,
};

# select concrete 6502 instructions for one MIR function
#
# The 6502 implementation behind the ISA vtable's `select` slot; a one-line binding
# of the pack to the shared engine.
# ---
# a:   backing allocator (unused in practice; no 6502 rule expands)
# tgt: resolved compilation target (must be mos6502)
# f:   the MIR function to select instructions for; mutated in place
# ret: ok(true) on success, or an error naming the failure
pub fun select(a: *A.Allocator, tgt: *target.Target, f: *mir.MirFunction) R.Result[bool, str] {
    ret rules.select(?PACK, a, tgt, f);
}

# classify a post-selection opcode as a 6502 plain register move
# ---
# opcode: the concrete post-selection opcode to classify
# ret:    true when the opcode is a plain register-move form
pub fun is_reg_move(opcode: u32) bool {
    ret rules.is_reg_move(?PACK, opcode);
}

# every generic opcode that can reach selection terminates in a rule, and the pack
# pins its exact storage length so an appended rule and the storage size cannot
# drift apart
test "mach.lang.target.isa.mos6502.rules:generic_opcode_coverage" {
    val pack: *rules.RulePack = ?PACK;
    if (pack.rule_count != 51)        { ret 1; }
    if (pack.fused_cbr_cc_count != 6) { ret 1; }

    var reachable: [mir.SELECTION_REACHABLE_COUNT]u32;
    mir.selection_reachable(?reachable[0]);
    var eliminated: [mir.SELECTION_ELIMINATED_COUNT]u32;
    mir.selection_eliminated(?eliminated[0]);
    var fused: [mir.SELECTION_FUSED_COUNT]u32;
    mir.selection_fused(?fused[0]);

    var ops: [3]mir.MirOperand;
    ops[0] = mir.op_preg(11);
    ops[1] = mir.op_preg(12);
    ops[2] = mir.op_preg(13);
    var probe: mir.MirInstr;
    probe.operands      = ?ops[0];
    probe.operand_count = 3;
    probe.width         = 1;
    probe.vec_lane      = mir.VEC_LANE_NONE;

    var f: mir.MirFunction;

    var i: u32 = 0;
    for (i < mir.SELECTION_REACHABLE_COUNT) {
        probe.opcode = reachable[i];
        if (rules.find_rule(pack, ?f, ?probe) == nil) { ret 1; }
        i = i + 1;
    }
    i = 0;
    for (i < mir.SELECTION_ELIMINATED_COUNT) {
        probe.opcode = eliminated[i];
        if (rules.find_rule(pack, ?f, ?probe) != nil) { ret 1; }
        i = i + 1;
    }
    # the fused survivors the combine produces must be admitted.
    i = 0;
    for (i < mir.SELECTION_FUSED_COUNT) {
        probe.opcode = fused[i];
        if (rules.find_rule(pack, ?f, ?probe) == nil) { ret 1; }
        i = i + 1;
    }
    ret 0;
}

# the copy-hygiene classifier admits the concrete 6502 move and the generic
# MIR_MOV regalloc splices, and rejects a non-move opcode
test "mach.lang.target.isa.mos6502.rules:is_reg_move" {
    if (!is_reg_move(mos6502.MOV::u32)) { ret 1; }
    if (!is_reg_move(mir.MIR_MOV))      { ret 1; }
    if (is_reg_move(mos6502.JMP::u32))  { ret 1; }
    ret 0;
}
