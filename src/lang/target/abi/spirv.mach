# the SPIR-V identity calling convention
#
# SPIR-V has no registers and no stack: a function's parameters are logical
# `OpFunctionParameter`s and a call is a logical `OpFunctionCall`. But the shared
# MIR lowering runs the ABI back-half unconditionally, classifying every parameter,
# argument, and return through the target's ABI vtable and emitting physical-
# register pre-coloring moves. This convention makes that pre-coloring trivially
# reconstructable: parameter / argument `i` is placed in "register" `i` and the
# return in register 0, so a pre-coloring `MIR_MOV pv <- preg(i)` names logical
# position `i` directly. The SPIR-V emitter reads the position off the register
# index and never needs a real register file.
#
# Nothing here models a real machine: the register banks are nominal (the SPIR-V
# back half runs no register allocation), aggregates and varargs are out of the
# SPIR-V milestone, and the emitter raises a precise diagnostic if one is reached.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.string.str;

use R: std.types.result;

use mach.lang.target.abi;
use mach.lang.target.isa;

# process-global storage for the SPIR-V ABI vtable. written once by `register` and
# borrowed by the vtable installed into the ABI registry; lives for the process
# lifetime.
var spirv_abi_vtable: abi.AbiVTable;

# the number of nominal argument registers the identity convention exposes
val ARG_REG_COUNT: i32 = 16;

# classify one argument: logical position `i` goes in "register" `i`
#
# The identity placement - a single general-purpose slot whose register id is the
# argument's own position - so the pre-coloring move the shared lowering emits
# names the logical position directly. The float / aggregate / vector inputs are
# ignored: the SPIR-V emitter types values from the IR signature and MIR facts, not
# from a register bank, and diagnoses anything past the scalar milestone.
# ---
# index: zero-based logical argument position
# ret:   a single-register slot in register `index`
fun classify_arg(index: i32, size: u64, align: u64, is_float: bool, fp_eightbytes: u8,
                 is_aggregate: bool, is_vector: bool, is_ext: bool, gp_used: i32, fp_used: i32,
                 hfa_members: u8, hfa_elem: u8, agg: abi.AggLayout) abi.ParamSlot {
    var sz: u64 = size;
    if (sz > 8) { sz = 8; }  # a wider value rides one nominal slot; the emitter caps scope
    ret abi.make_slot(abi.CLASS_GP, index, -1, 0, sz);
}

# classify the return value: register 0
# ---
# ret: a single-register slot in register 0
fun classify_return(size: u64, align: u64, is_float: bool, fp_eightbytes: u8,
                    is_aggregate: bool, is_vector: bool, hfa_members: u8, hfa_elem: u8,
                    agg: abi.AggLayout) abi.ParamSlot {
    var sz: u64 = size;
    if (sz > 8) { sz = 8; }
    ret abi.make_slot(abi.CLASS_GP, 0, -1, 0, sz);
}

# classify a single value for an indirect (untyped) call: position from `gp_used`
# ---
# ret: a single-register slot in the next free register position
fun classify_value(size: u64, align: u64, is_float: bool, fp_eightbytes: u8,
                   is_aggregate: bool, gp_used: i32, fp_used: i32, hfa_members: u8, hfa_elem: u8) abi.ParamSlot {
    var sz: u64 = size;
    if (sz > 8) { sz = 8; }
    ret abi.make_slot(abi.CLASS_GP, gp_used, -1, 0, sz);
}

# fill the nominal argument register bank (ids 0..ARG_REG_COUNT-1)
# ---
# out: destination register array (at least ARG_REG_COUNT wide)
# ret: the number of registers written
fun arg_regs(out: *isa.Register) i32 {
    var i: i32 = 0;
    for (i < ARG_REG_COUNT) {
        out[i].id   = i;
        out[i].size = 8;
        i = i + 1;
    }
    ret ARG_REG_COUNT;
}

# fill the callee-saved bank: empty (a SPIR-V call clobbers nothing that matters -
# there is no register allocation)
# ---
# out: destination register array (unused)
# ret: 0
fun callee_saved(out: *isa.Register) i32 {
    ret 0;
}

# build and install the SPIR-V ABI vtable
#
# Wires the identity classifiers and the nominal argument register bank. Every
# convention scalar (stack alignment, red zone, shadow space) is 0: no machine
# stack exists. Idempotent: the registry entry is write-once. Must run at compiler
# startup before `target.select` requests a spirv target.
# ---
# reg: the ABI registry to install the vtable into
# ret: true on success
pub fun register(reg: *abi.AbiRegistry) R.Result[bool, str] {
    spirv_abi_vtable.id           = abi.ABI_UNKNOWN;
    spirv_abi_vtable.name         = "spirv";
    spirv_abi_vtable.arch_id      = isa.ARCH_SPIRV;
    spirv_abi_vtable.classify     = classify_value::*u8;
    spirv_abi_vtable.arg_passing  = classify_arg::*u8;
    spirv_abi_vtable.ret_passing  = classify_return::*u8;
    spirv_abi_vtable.gp_arg_regs  = arg_regs::*u8;
    spirv_abi_vtable.fp_arg_regs  = arg_regs::*u8;
    spirv_abi_vtable.callee_saved = callee_saved::*u8;
    spirv_abi_vtable.stack_align  = 0;
    spirv_abi_vtable.red_zone     = 0;
    spirv_abi_vtable.shadow_space = 0;
    spirv_abi_vtable.indirect_result_reg         = 0;
    spirv_abi_vtable.indirect_result_in_argfile  = false;
    spirv_abi_vtable.consumes_agg_layout         = false;
    spirv_abi_vtable.fp_callee_saved_full_vector = true;
    spirv_abi_vtable.va_model                    = nil;

    abi.register(reg, ?spirv_abi_vtable);
    ret R.ok[bool, str](true);
}
