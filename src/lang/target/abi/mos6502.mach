# MOS 6502 calling convention
#
# A minimal internal convention for the 8-bit target, registered like the other
# ABIs and declaring `covers_isa` for mos6502 only. Because the 6502 has no
# register wide enough for a pointer and only a small zero-page value file, the
# convention is deliberately simple:
#
#   - a BYTE scalar argument (size <= 1) rides one of the first few zero-page value
#     registers; further byte arguments and every wider / aggregate / floating value
#     spill to the software stack (CLASS_STACK), read by the callee at `[fp+off]`.
#   - a BYTE scalar return rides the first value register; a wider or aggregate
#     return is returned through a caller-provided hidden pointer (CLASS_SRET).
#   - every register is caller-saved: the callee preserves nothing, so no
#     callee-saved set is declared and a call clobbers the whole value file.
#
# The register-per-scalar shape fits BYTE values cleanly (the common case after
# width legalization splits wider scalars into byte lanes within a function). A
# wide scalar crossing a call boundary is the documented frontier: it takes the
# memory path here rather than a paired-register placement the backend does not yet
# model.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.string.str;

use R: std.types.result;

use mach.lang.target.abi;
use mach.lang.target.isa;
use mach.lang.target.isa.mos6502;

# the number of zero-page value registers used to pass byte scalar arguments before
# the convention spills to the software stack
val ARG_REG_COUNT: i32 = 4;

# the process-global 6502 ABI vtable, written once by `register`
var mos6502_abi_vtable: abi.AbiVTable;

# whether a value is a single byte passed in a value register (not float, not an
# aggregate, one byte wide)
fun is_byte_scalar(size: u64, is_float: bool, is_aggregate: bool) bool {
    ret !is_float && !is_aggregate && size <= 1;
}

# classify one value into a placement decision
# ---
# size / align / is_float / fp_eightbytes / is_aggregate: the value's shape
# gp_used / fp_used: registers already consumed
# hfa_members / hfa_elem: HFA descriptor (unused on the 6502)
# ret: the placement decision
fun classify(size: u64, align: u64, is_float: bool, fp_eightbytes: u8, is_aggregate: bool,
             gp_used: i32, fp_used: i32, hfa_members: u8, hfa_elem: u8) abi.ParamSlot {
    if (is_byte_scalar(size, is_float, is_aggregate) && gp_used < ARG_REG_COUNT) {
        ret abi.make_slot(abi.CLASS_GP, mos6502.FIRST_VALUE_REG + gp_used, -1, 0, size);
    }
    ret abi.make_slot(abi.CLASS_STACK, -1, -1, 0, size);
}

# assign the register or stack slot for one argument
# ---
# see abi.ArgPassingFn for the parameter contract; the 6502 ignores the vector /
# ext / HFA descriptors
# ret: the placement decision
fun arg_passing(index: i32, size: u64, align: u64, is_float: bool, fp_eightbytes: u8,
                is_aggregate: bool, is_vector: bool, is_ext: bool, gp_used: i32, fp_used: i32,
                hfa_members: u8, hfa_elem: u8, agg: abi.AggLayout) abi.ParamSlot {
    if (is_byte_scalar(size, is_float, is_aggregate) && gp_used < ARG_REG_COUNT) {
        ret abi.make_slot(abi.CLASS_GP, mos6502.FIRST_VALUE_REG + gp_used, -1, 0, size);
    }
    ret abi.make_slot(abi.CLASS_STACK, -1, -1, 0, size);
}

# assign the register or hidden-pointer slot for a return value
# ---
# see abi.RetPassingFn for the parameter contract
# ret: the placement decision
fun ret_passing(size: u64, align: u64, is_float: bool, fp_eightbytes: u8, is_aggregate: bool,
                is_vector: bool, hfa_members: u8, hfa_elem: u8, agg: abi.AggLayout) abi.ParamSlot {
    if (is_byte_scalar(size, is_float, is_aggregate)) {
        ret abi.make_slot(abi.CLASS_GP, mos6502.FIRST_VALUE_REG, -1, 0, size);
    }
    # a wider or aggregate return goes through a caller-provided hidden pointer.
    ret abi.make_slot(abi.CLASS_SRET, mos6502.PTR_LO, -1, 0, size);
}

# fill the byte-argument register bank in canonical order and return its count
# ---
# out: caller-owned buffer receiving the register descriptors
# ret: the number of registers written
fun gp_arg_regs(out: *isa.Register) i32 {
    var i: i32 = 0;
    for (i < ARG_REG_COUNT) {
        out[i].id   = mos6502.FIRST_VALUE_REG + i;
        out[i].size = 1;
        i = i + 1;
    }
    ret ARG_REG_COUNT;
}

# the 6502 has no floating-point register bank
fun fp_arg_regs(out: *isa.Register) i32 { ret 0; }

# the 6502 convention is caller-saved throughout: no callee-saved registers
fun callee_saved(out: *isa.Register) i32 { ret 0; }

# the call-side variadic model: the 6502 encodes no vector count and duplicates no
# tail float
fun va_model() abi.VaModel {
    var m: abi.VaModel;
    m.kind             = abi.VA_MODEL_REG_SAVE;
    m.float_dup_gp     = false;
    m.vector_count_reg = -1;
    ret m;
}

# build and install the 6502 ABI vtable
#
# Declares the convention over mos6502 only, with byte-argument registers, an
# entirely caller-saved register file (no callee-saved set), and no stack
# alignment / red zone / shadow space (the software stack is byte-granular).
# Idempotent; must run at startup before `target.select` requests a 6502 target.
# ---
# reg: the ABI registry to install the vtable into
# ret: true on success
pub fun register(reg: *abi.AbiRegistry) R.Result[bool, str] {
    mos6502_abi_vtable.id      = abi.ABI_UNKNOWN;
    mos6502_abi_vtable.name    = "mos6502";
    mos6502_abi_vtable.arch_id = isa.ARCH_MOS6502;

    mos6502_abi_vtable.classify     = classify::*u8;
    mos6502_abi_vtable.arg_passing  = arg_passing::*u8;
    mos6502_abi_vtable.ret_passing  = ret_passing::*u8;
    mos6502_abi_vtable.gp_arg_regs  = gp_arg_regs::*u8;
    mos6502_abi_vtable.fp_arg_regs  = fp_arg_regs::*u8;
    mos6502_abi_vtable.callee_saved = callee_saved::*u8;
    mos6502_abi_vtable.va_model     = va_model::*u8;

    mos6502_abi_vtable.stack_align  = 1;
    mos6502_abi_vtable.red_zone     = 0;
    mos6502_abi_vtable.shadow_space = 0;
    # the hidden sret pointer rides the encoder pointer pair; it is not part of the
    # byte-argument file, so the GP argument cursor starts at 0.
    mos6502_abi_vtable.indirect_result_reg        = mos6502.PTR_LO;
    mos6502_abi_vtable.indirect_result_in_argfile = false;
    mos6502_abi_vtable.consumes_agg_layout        = false;
    # no callee-saved FP register exists, so the full-vector-preservation fact is moot.
    mos6502_abi_vtable.fp_callee_saved_full_vector = true;

    abi.register(reg, ?mos6502_abi_vtable);
    ret R.ok[bool, str](true);
}

# the convention declares itself over mos6502 only and classifies a byte scalar
# into the first value register, spilling a wider value to the stack
test "mach.lang.target.abi.mos6502.register:classifies_byte_and_wide" {
    var reg: abi.AbiRegistry = abi.registry_init();
    if (R.is_err[bool, str](register(?reg))) { ret 1; }
    if (!abi.covers_isa(?mos6502_abi_vtable, isa.ARCH_MOS6502)) { ret 1; }
    if (abi.covers_isa(?mos6502_abi_vtable, isa.ARCH_X86_64))   { ret 1; }

    # a byte argument rides the first value register.
    val a0: abi.ParamSlot = arg_passing(0, 1, 1, false, 0, false, false, false, 0, 0, 0, 0, abi.agg_none());
    if (a0.class != abi.CLASS_GP)                 { ret 1; }
    if (a0.reg != mos6502.FIRST_VALUE_REG)        { ret 1; }

    # a two-byte argument takes the stack path (the wide-value frontier).
    val a1: abi.ParamSlot = arg_passing(0, 2, 1, false, 0, false, false, false, 0, 0, 0, 0, abi.agg_none());
    if (a1.class != abi.CLASS_STACK) { ret 1; }

    # a byte return rides the first value register.
    val r0: abi.ParamSlot = ret_passing(1, 1, false, 0, false, false, 0, 0, abi.agg_none());
    if (r0.class != abi.CLASS_GP)          { ret 1; }
    if (r0.reg != mos6502.FIRST_VALUE_REG) { ret 1; }
    ret 0;
}
