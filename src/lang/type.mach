# semantic type universe shared across sema, middle-end, and backend
#
# `TypeInterner` lives on the session next to `intern.Interner`. It owns every
# `Type` record produced during sema and hands out stable `TypeId` handles;
# equality of two `TypeId`s is identity equality.
#
# Primitive types (`u8`..`f64`, `ptr`) are pre-allocated by `init` and exposed
# via `prim(kind)`. Compound types are interned by their canonical form: pointer
# types by base, array types by `(base, count)`, nominal types (`rec`/`uni`) by
# `(origin, decl)`, generic parameters by `(owner, index)`, function types by a
# content hash of their signature, and instances by `(origin, decl, args)`.
# Structural equality of function types is also available via
# `type_equals_signatures`.

use std.allocator.page;
use std.collections.map;
use std.crypto.hash.fnv1a;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast.id;
use mach.lang.intern;
use mach.lang.module;

pub def TypeId:     u32;
# sentinel TypeId for the absence of a type - a function with no declared
# return (void), a bare `ret;`, or a type not yet resolved
pub val TYPE_NIL:   TypeId = 0xFFFFFFFF;
# sentinel TypeId for a type that failed to resolve; sema propagates it to
# degrade gracefully and suppress cascading diagnostics
pub val TYPE_ERROR: TypeId = 0xFFFFFFFE;

# discriminator for Type.data
pub def TypeKind: u8;

# primitive type kinds. these have no payload
pub val TYPE_U8:    TypeKind = 0;   # unsigned 8-bit integer
pub val TYPE_U16:   TypeKind = 1;   # unsigned 16-bit integer
pub val TYPE_U32:   TypeKind = 2;   # unsigned 32-bit integer
pub val TYPE_U64:   TypeKind = 3;   # unsigned 64-bit integer
pub val TYPE_I8:    TypeKind = 4;   # signed 8-bit integer
pub val TYPE_I16:   TypeKind = 5;   # signed 16-bit integer
pub val TYPE_I32:   TypeKind = 6;   # signed 32-bit integer
pub val TYPE_I64:   TypeKind = 7;   # signed 64-bit integer
pub val TYPE_F32:   TypeKind = 8;   # 32-bit floating point
pub val TYPE_F64:   TypeKind = 9;   # 64-bit floating point
pub val TYPE_PTR:   TypeKind = 10;  # raw pointer (untyped, opaque, address-shaped)
pub val PRIM_COUNT: u32      = 11;  # number of primitive types

# compound and nominal type kinds. these have a Type.data payload
pub val TYPE_POINTER:       TypeKind = 11;  # pointer-to-T type payload
pub val TYPE_ARRAY:         TypeKind = 12;  # fixed-size array type payload
pub val TYPE_FUN:           TypeKind = 13;  # function type payload
pub val TYPE_REC:           TypeKind = 14;  # nominal record type payload
pub val TYPE_UNI:           TypeKind = 15;  # nominal union type payload
pub val TYPE_GENERIC_PARAM: TypeKind = 16;  # generic parameter placeholder type payload
pub val TYPE_INSTANCE:      TypeKind = 17;  # concrete instantiation of a generic declaration payload

# a comptime variadic pack. the type of a `va: ...` parameter. a
# payload-free singleton. the pack's element types are fixed per call site and
# supplied by monomorphization, never carried on the type itself
pub val TYPE_PACK: TypeKind = 18;

# the `^T` secret qualifier (#1645): the top of the two-point secrecy lattice
# (public is the bottom). wraps an inner type to mark its data secret for the
# constant-time guarantee. secrecy has no runtime representation - a `^T` lowers
# to the same machine shape as `T`; it constrains only sema's flow typing
pub val TYPE_SECRET: TypeKind = 19;

# scalar class of a primitive TypeKind, the discriminator of PrimDesc
pub def PrimClass: u8;

# not a primitive scalar (a compound, nominal, or sentinel kind)
pub val PRIM_CLASS_NONE:  PrimClass = 0;
# an integer primitive (u8..i64); signedness lives in PrimDesc.signed
pub val PRIM_CLASS_INT:   PrimClass = 1;
# a floating-point primitive (f32, f64)
pub val PRIM_CLASS_FLOAT: PrimClass = 2;
# the raw `ptr` primitive; its width is target-defined, so bits is 0 here
pub val PRIM_CLASS_PTR:   PrimClass = 3;

# the (class, signedness, bit width) of a primitive TypeKind
#
# The single source of truth every site that classifies a primitive by its
# scalar class, signedness, or width derives from, replacing the per-site
# `(sign, bits, class)` if-ladders. A non-primitive kind yields PRIM_CLASS_NONE
# with signed false and bits 0.
# ---
# class:  PRIM_CLASS_INT / FLOAT / PTR, or PRIM_CLASS_NONE for a non-primitive
# signed: true for the signed integers (i8..i64), false otherwise
# bits:   scalar width in bits (8/16/32/64 for int, 32/64 for float, 0 for ptr)
pub rec PrimDesc {
    class:  PrimClass;
    signed: bool;
    bits:   u32;
}

# the PrimDesc for a TypeKind
#
# The one if-ladder mapping a primitive kind to its scalar facts; every other
# classifier reads this rather than restating the per-kind constants. A
# non-primitive kind maps to PRIM_CLASS_NONE.
# ---
# kind: the TypeKind to describe
# ret:  the kind's PrimDesc (PRIM_CLASS_NONE for a non-primitive kind)
pub fun prim_desc(kind: TypeKind) PrimDesc {
    var d: PrimDesc;
    d.class  = PRIM_CLASS_NONE;
    d.signed = false;
    d.bits   = 0;

    if (kind == TYPE_U8)  { d.class = PRIM_CLASS_INT;   d.signed = false; d.bits = 8;  }
    or (kind == TYPE_U16) { d.class = PRIM_CLASS_INT;   d.signed = false; d.bits = 16; }
    or (kind == TYPE_U32) { d.class = PRIM_CLASS_INT;   d.signed = false; d.bits = 32; }
    or (kind == TYPE_U64) { d.class = PRIM_CLASS_INT;   d.signed = false; d.bits = 64; }
    or (kind == TYPE_I8)  { d.class = PRIM_CLASS_INT;   d.signed = true;  d.bits = 8;  }
    or (kind == TYPE_I16) { d.class = PRIM_CLASS_INT;   d.signed = true;  d.bits = 16; }
    or (kind == TYPE_I32) { d.class = PRIM_CLASS_INT;   d.signed = true;  d.bits = 32; }
    or (kind == TYPE_I64) { d.class = PRIM_CLASS_INT;   d.signed = true;  d.bits = 64; }
    or (kind == TYPE_F32) { d.class = PRIM_CLASS_FLOAT; d.signed = false; d.bits = 32; }
    or (kind == TYPE_F64) { d.class = PRIM_CLASS_FLOAT; d.signed = false; d.bits = 64; }
    or (kind == TYPE_PTR) { d.class = PRIM_CLASS_PTR;   d.signed = false; d.bits = 0;  }

    ret d;
}

# pointer-to-T type payload
# ---
# base: pointee TypeId
pub rec TypePointer {
    base: TypeId;
}

# secret-qualifier `^T` payload (#1645)
#
# Carries the inner type the qualifier wraps. `^^T` never forms: intern_secret
# collapses a doubled qualifier, keeping the lattice two-point.
# ---
# base: the inner (public-spelled) TypeId the qualifier wraps
pub rec TypeSecret {
    base: TypeId;
}

# fixed-size array type payload
# ---
# base:  element TypeId
# count: element count
pub rec TypeArray {
    base:  TypeId;
    count: u32;
}

# function type payload
# ---
# ret_type:     return type
# params_start: index into ti.params for the first parameter type
# params_len:   number of fixed parameter types
pub rec TypeFun {
    ret_type:     TypeId;
    params_start: u32;
    params_len:   u32;
}

# nominal (rec / uni / def) reference payload
#
# Two nominal types are identical iff they refer to the same declaration site.
# ---
# name:   interned identifier (for diagnostics - not load-bearing for identity)
# origin: ModuleId of the declaring module
# decl:   DeclId of the declaration in `origin`'s Ast
pub rec TypeNominal {
    name:   intern.StrId;
    origin: module.ModuleId;
    decl:   id.DeclId;
}

# placeholder type for a generic parameter as written in a declaration
# ---
# name:  interned identifier (for diagnostics)
# owner: DeclId of the enclosing generic decl (in its module's Ast)
# index: ordinal among the owner's generic parameters
pub rec TypeGenericParam {
    name:  intern.StrId;
    owner: id.DeclId;
    index: u32;
}

# concrete instantiation of a generic declaration
#
# Two instances are identical if (target_origin, target_decl) match and the
# args sequences are element-wise equal.
# ---
# target_origin: module that declared the generic
# target_decl:   declaration in target_origin's Ast
# args_start:    index into TypeInterner.params
# args_len:      number of concrete argument types
pub rec TypeInstance {
    target_origin: module.ModuleId;
    target_decl:   id.DeclId;
    args_start:    u32;
    args_len:      u32;
}

# tagged union of all type kinds
# ---
# kind: which TYPE_* variant is active
# data: kind-specific payload; primitives use no payload
pub rec Type {
    kind: TypeKind;
    data: uni {
        pointer:       TypePointer;
        secret:        TypeSecret;
        array:         TypeArray;
        fn:            TypeFun;
        nominal:       TypeNominal;
        generic_param: TypeGenericParam;
        instance:      TypeInstance;
    };
}

# one field of a nominal record/union or generic instance
#
# Recorded in the session-global field store.
# ---
# name: interned field identifier
# ty:   interned semantic type of the field
pub rec FieldEntry {
    name: intern.StrId;
    ty:   TypeId;
}

# the structural field list for one nominal or instance TypeId
#
# Fields live in a contiguous slice of the interner's field pool.
# ---
# ty:           the TypeId this table describes
# fields_start: index of the first field in the field pool
# fields_len:   number of fields
# epoch:        the build epoch this table was (re)built in. a nominal keeps its
#               TypeId across rebuilds, but its field TYPES can change (an importer
#               on a long-lived session must see the current layout), so a builder
#               rebuilds a table whose epoch predates the current one rather than
#               reusing the stale layout - while a within-build rebuild request for
#               an up-to-date table is a no-op (dedup of repeated anon references). a
#               fresh-session build (the CLI) only ever sees epoch 0 (#1583)
pub rec FieldTable {
    ty:           TypeId;
    fields_start: u32;
    fields_len:   u32;
    epoch:        u32;
}

# session-shared interner for the type universe
# ---
# a:               allocator backing all owned arrays
# types:           universe of Type records indexed by TypeId
# type_len:        number of types stored
# type_cap:        allocated slots in types
# params:          pool of TypeIds referenced by TypeFun
# params_len:      number of TypeIds stored
# params_cap:      allocated slots in params
# dedup:           Type to TypeId map; populated for kinds with self-contained payloads
# prims:           pre-allocated TypeIds for each primitive TypeKind, indexed by kind
# field_tables:    one FieldTable per nominal / instance TypeId that has a field layout; built once and shared session-wide so any module can resolve a cross-module record's fields
# field_table_len: number of field tables stored
# field_table_cap: allocated slots in field_tables
# field_pool:      contiguous FieldEntry storage backing field_tables
# field_pool_len:  number of FieldEntries stored
# field_pool_cap:  allocated slots in field_pool
# field_epoch:     the current build epoch, bumped once per sema pass by the driver
#                  (field_epoch_bump). a field-table builder stamps it onto each
#                  table and rebuilds any table whose epoch is older, so a record's
#                  field-type change on a long-lived session refreshes the cached
#                  layout instead of leaving it stale (#1583)
pub rec TypeInterner {
    a: *A.Allocator;

    types:    *Type;
    type_len: u32;
    type_cap: u32;

    params:     *TypeId;
    params_len: u32;
    params_cap: u32;

    dedup: map.Map[Type, TypeId];

    # TYPE_FUN bypasses `dedup` (its params live in the side pool).
    # A content hash of (ret, params) to TypeId deduplicates structurally
    # equal function types, collapsing the per-generic-call TYPE_FUN explosion.
    # A hash collision degrades to a fresh append (the prior non-deduped default),
    # never to a wrong identity, since the candidate is verified against the
    # mapped type before reuse.
    fun_index: map.Map[u64, TypeId];

    # TYPE_INSTANCE bypasses `dedup` (its args live in the side pool, which the
    # context-free dedup hash cannot read), so instance TypeIds are tracked in
    # their own list and deduped by scanning it - O(instances), not O(type_len).
    instances:     *TypeId;
    instances_len: u32;
    instances_cap: u32;

    prims: [PRIM_COUNT]TypeId;

    field_tables:    *FieldTable;
    field_table_len: u32;
    field_table_cap: u32;

    # nominal / instance TypeId -> its index in field_tables, so a field-table
    # lookup is O(1) rather than a linear scan of every registered table.
    field_index: map.Map[TypeId, u32];

    field_pool:     *FieldEntry;
    field_pool_len: u32;
    field_pool_cap: u32;

    field_epoch: u32;
}

# initial capacities for the interner's growable backing arrays
val INITIAL_TYPE_CAP:        u32 = 64;
val INITIAL_PARAMS_CAP:      u32 = 32;
val INITIAL_INSTANCE_CAP:    u32 = 16;
val INITIAL_FIELD_TABLE_CAP: u32 = 16;
val INITIAL_FIELD_POOL_CAP:  u32 = 64;

# construct an empty interner with primitives pre-allocated
# ---
# ti:  pointer to the interner to populate
# a:   allocator used for all owned storage
# ret: none on success (`ti` populated), or some(error) on allocation failure
pub fun init(ti: *TypeInterner, a: *A.Allocator) O.Option[str] {
    ti.a = a;

    ti.types    = nil;
    ti.type_len = 0;
    ti.type_cap = 0;

    ti.params     = nil;
    ti.params_len = 0;
    ti.params_cap = 0;

    ti.instances     = nil;
    ti.instances_len = 0;
    ti.instances_cap = 0;

    ti.field_tables    = nil;
    ti.field_table_len = 0;
    ti.field_table_cap = 0;

    ti.field_pool     = nil;
    ti.field_pool_len = 0;
    ti.field_pool_cap = 0;

    ti.field_epoch = 0;

    ti.dedup       = map.init[Type, TypeId](a, hash_type, eq_type);
    ti.fun_index   = map.init[u64, TypeId](a, map.hash_u64, map.eq_u64);
    ti.field_index = map.init[TypeId, u32](a, map.hash_u32, map.eq_u32);

    val res_types: R.Result[*Type, str] = A.allocate[Type](a, INITIAL_TYPE_CAP::usize);
    if (R.is_err[*Type, str](res_types)) {
        dnit(ti);
        ret O.some[str](R.unwrap_err[*Type, str](res_types));
    }
    ti.types    = R.unwrap_ok[*Type, str](res_types);
    ti.type_cap = INITIAL_TYPE_CAP;

    val res_params: R.Result[*TypeId, str] = A.allocate[TypeId](a, INITIAL_PARAMS_CAP::usize);
    if (R.is_err[*TypeId, str](res_params)) {
        dnit(ti);
        ret O.some[str](R.unwrap_err[*TypeId, str](res_params));
    }
    ti.params     = R.unwrap_ok[*TypeId, str](res_params);
    ti.params_cap = INITIAL_PARAMS_CAP;

    # seed the primitives in kind order. prim(kind) indexes the resulting
    # prims[] table to recover a primitive's TypeId, so nothing depends on a
    # primitive's TypeId equaling its kind ordinal.
    var i: u32 = 0;
    for (i < PRIM_COUNT) {
        var t: Type;
        t.kind = i::TypeKind;

        val res_append: R.Result[TypeId, str] = append_type(ti, t);
        if (R.is_err[TypeId, str](res_append)) {
            dnit(ti);
            ret O.some[str](R.unwrap_err[TypeId, str](res_append));
        }
        val tid: TypeId = R.unwrap_ok[TypeId, str](res_append);
        ti.prims[i] = tid;

        # record the primitive in the dedup map so a later intern of the same
        # primitive returns this TypeId. redundant for primitives, but it keeps
        # one code path for every kind.
        val res_insert: R.Result[bool, str] = map.insert[Type, TypeId](?ti.dedup, t, tid);
        if (R.is_err[bool, str](res_insert)) {
            dnit(ti);
            ret O.some[str](R.unwrap_err[bool, str](res_insert));
        }

        i = i + 1;
    }

    ret O.none[str]();
}

# tear down a TypeInterner, freeing every owned array and map and zeroing it
# back to a clean slate
# ---
# ti: the interner to tear down
pub fun dnit(ti: *TypeInterner) {
    if (ti == nil) { ret; }

    if (ti.types != nil && ti.type_cap > 0) {
        A.deallocate[Type](ti.a, ti.types, ti.type_cap::usize);
    }
    if (ti.params != nil && ti.params_cap > 0) {
        A.deallocate[TypeId](ti.a, ti.params, ti.params_cap::usize);
    }
    if (ti.instances != nil && ti.instances_cap > 0) {
        A.deallocate[TypeId](ti.a, ti.instances, ti.instances_cap::usize);
    }
    if (ti.field_tables != nil && ti.field_table_cap > 0) {
        A.deallocate[FieldTable](ti.a, ti.field_tables, ti.field_table_cap::usize);
    }
    if (ti.field_pool != nil && ti.field_pool_cap > 0) {
        A.deallocate[FieldEntry](ti.a, ti.field_pool, ti.field_pool_cap::usize);
    }

    map.dnit[Type, TypeId](?ti.dedup);
    map.dnit[u64, TypeId](?ti.fun_index);
    map.dnit[TypeId, u32](?ti.field_index);

    ti.types    = nil;
    ti.type_len = 0;
    ti.type_cap = 0;

    ti.params     = nil;
    ti.params_len = 0;
    ti.params_cap = 0;

    ti.instances     = nil;
    ti.instances_len = 0;
    ti.instances_cap = 0;

    ti.field_tables    = nil;
    ti.field_table_len = 0;
    ti.field_table_cap = 0;

    ti.field_pool     = nil;
    ti.field_pool_len = 0;
    ti.field_pool_cap = 0;

    ti.field_epoch = 0;
}

# return a pointer to the Type for a given TypeId, or none when tid is out of
# range
# ---
# ti:  the interner
# tid: TypeId returned by a previous intern call
# ret: some(*Type) into ti.types (invalidated by a later intern that grows the array), or none
pub fun get(ti: *TypeInterner, tid: TypeId) O.Option[*Type] {
    if (tid >= ti.type_len) { ret O.none[*Type](); }
    ret O.some[*Type](?ti.types[tid]);
}

# return the TypeId at `index` in the parameter pool, or none when index is
# out of range
# ---
# ti:    the interner
# index: pool index (typically `fun.params_start + i`)
# ret:   some(TypeId) at the given pool slot, or none
pub fun get_param(ti: *TypeInterner, index: u32) O.Option[TypeId] {
    if (index >= ti.params_len) { ret O.none[TypeId](); }
    ret O.some[TypeId](ti.params[index]);
}

# return the TypeId for a primitive TypeKind
# ---
# ti:   the interner
# kind: a primitive kind (TYPE_U8 .. TYPE_PTR)
# ret:  some(TypeId) for a primitive kind, none when kind is not a primitive
pub fun prim(ti: *TypeInterner, kind: TypeKind) O.Option[TypeId] {
    if (kind >= PRIM_COUNT) { ret O.none[TypeId](); }
    ret O.some[TypeId](ti.prims[kind]);
}

# whether `tid` is an integer primitive (u8..i64)
#
# Reads the kind through the interner, so, unlike a bare `tid == TYPE_U8`
# ordinal test, it never depends on a primitive's TypeId equaling its kind
# ordinal. The single shared predicate for sema's infer / check / coerce passes.
# A secret `^T` is classified by its inner type, so secret integers participate
# in arithmetic exactly as public ones (the join and gates are layered on top).
# ---
# ti:  the interner
# tid: the TypeId to classify
# ret: true for u8..u64 and i8..i64
pub fun is_integer(ti: *TypeInterner, tid: TypeId) bool {
    val opt_type: O.Option[*Type] = get(ti, strip_secret(ti, tid));
    if (O.is_none[*Type](opt_type)) { ret false; }
    ret prim_desc(O.unwrap[*Type](opt_type).kind).class == PRIM_CLASS_INT;
}

# whether `tid` is an integer or float primitive (u8..f64)
#
# A secret `^T` is classified by its inner type.
# ---
# ti:  the interner
# tid: the TypeId to classify
# ret: true for any integer or float primitive
pub fun is_numeric(ti: *TypeInterner, tid: TypeId) bool {
    val opt_type: O.Option[*Type] = get(ti, strip_secret(ti, tid));
    if (O.is_none[*Type](opt_type)) { ret false; }
    val c: PrimClass = prim_desc(O.unwrap[*Type](opt_type).kind).class;
    ret c == PRIM_CLASS_INT || c == PRIM_CLASS_FLOAT;
}

# whether `tid` is a float primitive (f32 or f64)
#
# A secret `^T` is classified by its inner type.
# ---
# ti:  the interner
# tid: the TypeId to classify
# ret: true for f32 or f64
pub fun is_float(ti: *TypeInterner, tid: TypeId) bool {
    val opt_type: O.Option[*Type] = get(ti, strip_secret(ti, tid));
    if (O.is_none[*Type](opt_type)) { ret false; }
    ret prim_desc(O.unwrap[*Type](opt_type).kind).class == PRIM_CLASS_FLOAT;
}

# whether `tid` is address-shaped - a raw `ptr`, a typed `*T`, or a function
# (a code address)
#
# Used to relate `nil` and reinterpret casts against pointer and function
# operands. A secret `^T` is classified by its inner type.
# ---
# ti:  the interner
# tid: the TypeId to classify
# ret: true for TYPE_PTR / TYPE_POINTER / TYPE_FUN
pub fun is_pointer_like(ti: *TypeInterner, tid: TypeId) bool {
    val opt_type: O.Option[*Type] = get(ti, strip_secret(ti, tid));
    if (O.is_none[*Type](opt_type)) { ret false; }
    val k: TypeKind = O.unwrap[*Type](opt_type).kind;
    ret k == TYPE_PTR || k == TYPE_POINTER || k == TYPE_FUN;
}

# whether `tid` is a secret-qualified type `^T`
# ---
# ti:  the interner
# tid: the TypeId to classify
# ret: true when `tid`'s kind is TYPE_SECRET
pub fun is_secret(ti: *TypeInterner, tid: TypeId) bool {
    val opt_type: O.Option[*Type] = get(ti, tid);
    if (O.is_none[*Type](opt_type)) { ret false; }
    ret O.unwrap[*Type](opt_type).kind == TYPE_SECRET;
}

# peel one secret qualifier from `tid`, returning the inner type
#
# A non-secret type is returned unchanged. `^^T` never forms (intern_secret
# collapses it), so a single peel is exhaustive.
# ---
# ti:  the interner
# tid: the TypeId to strip
# ret: the inner type when `tid` is `^T`, else `tid` unchanged
pub fun strip_secret(ti: *TypeInterner, tid: TypeId) TypeId {
    val opt_type: O.Option[*Type] = get(ti, tid);
    if (O.is_none[*Type](opt_type)) { ret tid; }
    val t: *Type = O.unwrap[*Type](opt_type);
    if (t.kind != TYPE_SECRET) { ret tid; }
    ret t.data.secret.base;
}

# whether `tid` carries secret data anywhere along its pointer / array / secret
# spine - the predicate the welded-storage rules use to keep secret memory off
# the untyped `ptr`
#
# Follows `^` (true immediately), a typed pointer's pointee, and an array's
# element. A nominal rec/uni is a leaf here (its secret fields are welded at the
# field level), so the walk is over a finite spine and always terminates.
# ---
# ti:  the interner
# tid: the TypeId to inspect
# ret: true when a secret qualifier appears along the spine
pub fun carries_secret(ti: *TypeInterner, tid: TypeId) bool {
    val opt_type: O.Option[*Type] = get(ti, tid);
    if (O.is_none[*Type](opt_type)) { ret false; }
    val t: *Type = O.unwrap[*Type](opt_type);
    if (t.kind == TYPE_SECRET)  { ret true; }
    if (t.kind == TYPE_POINTER) { ret carries_secret(ti, t.data.pointer.base); }
    if (t.kind == TYPE_ARRAY)   { ret carries_secret(ti, t.data.array.base); }
    ret false;
}

# whether two types place the secret qualifier identically along their spines
#
# `::` and `:~` may neither add nor drop `^`, so a cast's operand and target must
# match secret-for-secret at the top level and through every pointer / array
# step. Differing inner leaf types (e.g. `^u32` vs `^u64`) still match - only the
# `^` placement is compared, not the underlying shapes the cast itself converts.
# ---
# ti:  the interner
# a:   the first TypeId
# b:   the second TypeId
# ret: true when both carry the same secret-qualifier placement along the spine
pub fun secrecy_structure_equal(ti: *TypeInterner, a: TypeId, b: TypeId) bool {
    val a_secret: bool = is_secret(ti, a);
    val b_secret: bool = is_secret(ti, b);
    if (a_secret != b_secret) { ret false; }

    val sa: TypeId = strip_secret(ti, a);
    val sb: TypeId = strip_secret(ti, b);

    val oa: O.Option[*Type] = get(ti, sa);
    val ob: O.Option[*Type] = get(ti, sb);
    if (O.is_none[*Type](oa) || O.is_none[*Type](ob)) { ret true; }
    val ta: *Type = O.unwrap[*Type](oa);
    val tb: *Type = O.unwrap[*Type](ob);

    if (ta.kind == TYPE_POINTER && tb.kind == TYPE_POINTER) {
        ret secrecy_structure_equal(ti, ta.data.pointer.base, tb.data.pointer.base);
    }
    if (ta.kind == TYPE_ARRAY && tb.kind == TYPE_ARRAY) {
        ret secrecy_structure_equal(ti, ta.data.array.base, tb.data.array.base);
    }
    ret true;
}

# intern a pointer-to type
#
# Returns an existing TypeId when the same base has been interned before.
# ---
# ti:   the interner
# base: pointee TypeId
# ret:  TypeId for *base, or an allocation error
pub fun intern_pointer(ti: *TypeInterner, base: TypeId) R.Result[TypeId, str] {
    var t: Type;
    t.kind              = TYPE_POINTER;
    t.data.pointer.base = base;
    ret intern_dedup(ti, t);
}

# intern a secret-qualified type `^base` (#1645)
#
# A doubled qualifier collapses (`^^T` interns to `^T`) so the secrecy lattice
# stays two-point, and a poisoned base poisons the qualifier. Returns an existing
# TypeId when the same base has been wrapped before.
# ---
# ti:   the interner
# base: the inner TypeId to wrap
# ret:  TypeId for `^base`, or an allocation error
pub fun intern_secret(ti: *TypeInterner, base: TypeId) R.Result[TypeId, str] {
    if (base == TYPE_ERROR) { ret R.ok[TypeId, str](TYPE_ERROR); }
    if (is_secret(ti, base)) { ret R.ok[TypeId, str](base); }
    var t: Type;
    t.kind             = TYPE_SECRET;
    t.data.secret.base = base;
    ret intern_dedup(ti, t);
}

# intern a fixed-size array type
#
# Returns an existing TypeId when the same (base, count) pair has been
# interned before.
# ---
# ti:    the interner
# base:  element TypeId
# count: element count
# ret:   TypeId for [count]base, or an allocation error
pub fun intern_array(ti: *TypeInterner, base: TypeId, count: u32) R.Result[TypeId, str] {
    var t: Type;
    t.kind             = TYPE_ARRAY;
    t.data.array.base  = base;
    t.data.array.count = count;
    ret intern_dedup(ti, t);
}

# intern the comptime variadic pack type, a payload-free singleton
# ---
# ti:  the interner
# ret: the TypeId for a `...` pack, or an allocation error
pub fun intern_pack(ti: *TypeInterner) R.Result[TypeId, str] {
    var t: Type;
    t.kind = TYPE_PACK;
    ret intern_dedup(ti, t);
}

# intern a nominal type (rec / uni)
#
# Two nominal types intern to the same TypeId iff their (origin, decl) pairs
# match.
# ---
# ti:     the interner
# name:   interned identifier (diagnostic only)
# origin: declaring module
# decl:   declaration in origin's Ast
# kind:   TYPE_REC or TYPE_UNI
# ret:    TypeId for the nominal type, or an allocation error
pub fun intern_nominal(ti: *TypeInterner, name: intern.StrId, origin: module.ModuleId, decl: id.DeclId, kind: TypeKind) R.Result[TypeId, str] {
    var t: Type;
    t.kind                = kind;
    t.data.nominal.name   = name;
    t.data.nominal.origin = origin;
    t.data.nominal.decl   = decl;
    ret intern_dedup(ti, t);
}

# intern a generic parameter placeholder
#
# Two generic params intern to the same TypeId iff they share an (owner,
# index) pair.
# ---
# ti:    the interner
# name:  interned identifier (diagnostic only)
# owner: enclosing generic DeclId
# index: ordinal among the owner's generic parameters
# ret:   TypeId for the generic param, or an allocation error
pub fun intern_generic_param(ti: *TypeInterner, name: intern.StrId, owner: id.DeclId, index: u32) R.Result[TypeId, str] {
    var t: Type;
    t.kind                     = TYPE_GENERIC_PARAM;
    t.data.generic_param.name  = name;
    t.data.generic_param.owner = owner;
    t.data.generic_param.index = index;
    ret intern_dedup(ti, t);
}

# intern a function type, deduplicating structurally equal signatures through
# a content-hash index so a generic call's repeated substitute_fun does not
# grow the universe without bound
#
# On a hash hit the candidate is verified against the mapped type before
# reuse, so a collision degrades to a fresh append (the historical non-deduped
# default), never to a wrong identity. Structural equivalence is also available
# via `type_equals_signatures`.
# ---
# ti:       the interner
# ret_type: return type
# params:   pointer to a contiguous array of fixed parameter TypeIds
# count:    number of fixed parameter types
# ret:      the (deduped) TypeId for the function, or an allocation error
pub fun intern_function(ti: *TypeInterner, ret_type: TypeId, params: *TypeId, count: u32) R.Result[TypeId, str] {
    val h: u64 = hash_fun(ret_type, params, count);

    val res_get: R.Result[*TypeId, str] = map.get[u64, TypeId](?ti.fun_index, ?h);
    if (R.is_ok[*TypeId, str](res_get)) {
        val existing: TypeId = @R.unwrap_ok[*TypeId, str](res_get);
        if (fun_matches(ti, existing, ret_type, params, count)) {
            ret R.ok[TypeId, str](existing);
        }
    }

    val res_start: R.Result[u32, str] = params_append(ti, params, count);
    if (R.is_err[u32, str](res_start)) {
        ret R.err[TypeId, str](R.unwrap_err[u32, str](res_start));
    }
    val start: u32 = R.unwrap_ok[u32, str](res_start);

    var t: Type;
    t.kind                 = TYPE_FUN;
    t.data.fn.ret_type     = ret_type;
    t.data.fn.params_start = start;
    t.data.fn.params_len   = count;

    val res_append: R.Result[TypeId, str] = append_type(ti, t);
    if (R.is_err[TypeId, str](res_append)) {
        ret res_append;
    }
    val tid: TypeId = R.unwrap_ok[TypeId, str](res_append);

    # last-writer-wins on a hash collision: the most recently interned signature
    # for this hash is the one reused next, so equal signatures still collapse.
    val res_insert: R.Result[bool, str] = map.insert[u64, TypeId](?ti.fun_index, h, tid);
    if (R.is_err[bool, str](res_insert)) {
        ret R.err[TypeId, str](R.unwrap_err[bool, str](res_insert));
    }

    ret R.ok[TypeId, str](tid);
}

# intern a generic instantiation `(target_origin, target_decl)<args>`
#
# Scans the instance list for a match before appending; on miss, copies args
# into the params pool, appends a fresh TypeInstance record, and records it in
# the instance list. TYPE_INSTANCE bypasses the dedup map (its args live in the
# side pool, which the context-free dedup hash cannot read), so dedup walks the
# instance list resulting in O(instances), not O(type_len).
# ---
# ti:            the interner
# target_origin: module that declared the generic
# target_decl:   declaration in target_origin's Ast
# args:          pointer to a contiguous array of concrete arg types
# count:         number of argument types
# ret:           the (deduped) TypeId for the instance, or an allocation error
pub fun intern_instance(ti: *TypeInterner, target_origin: module.ModuleId, target_decl: id.DeclId, args: *TypeId, count: u32) R.Result[TypeId, str] {
    var i: u32 = 0;
    for (i < ti.instances_len) {
        val tid:  TypeId = ti.instances[i];
        val cand: *Type  = ?ti.types[tid];
        if (cand.data.instance.target_origin == target_origin
            && cand.data.instance.target_decl == target_decl
            && cand.data.instance.args_len == count) {
            var args_match: bool = true;
            var ii:         u32  = 0;
            for (ii < count) {
                if (ti.params[cand.data.instance.args_start + ii] != args[ii]) {
                    args_match = false;
                    brk;
                }
                ii = ii + 1;
            }
            if (args_match) { ret R.ok[TypeId, str](tid); }
        }
        i = i + 1;
    }

    val res_start: R.Result[u32, str] = params_append(ti, args, count);
    if (R.is_err[u32, str](res_start)) {
        ret R.err[TypeId, str](R.unwrap_err[u32, str](res_start));
    }
    val start: u32 = R.unwrap_ok[u32, str](res_start);

    var t: Type;
    t.kind                        = TYPE_INSTANCE;
    t.data.instance.target_origin = target_origin;
    t.data.instance.target_decl   = target_decl;
    t.data.instance.args_start    = start;
    t.data.instance.args_len      = count;

    val res_append: R.Result[TypeId, str] = append_type(ti, t);
    if (R.is_err[TypeId, str](res_append)) {
        ret res_append;
    }
    val tid: TypeId = R.unwrap_ok[TypeId, str](res_append);

    val res_track: R.Result[bool, str] = track_instance(ti, tid);
    if (R.is_err[bool, str](res_track)) {
        ret R.err[TypeId, str](R.unwrap_err[bool, str](res_track));
    }

    ret R.ok[TypeId, str](tid);
}

# structural equivalence for two function types
#
# Used by sema where function-type identity is insufficient (signatures can
# match without being the same interned TypeId).
# ---
# ti:  the interner
# a:   first TypeId; must be TYPE_FUN
# b:   second TypeId; must be TYPE_FUN
# ret: true when both have matching return type and parameter sequence
pub fun type_equals_signatures(ti: *TypeInterner, a: TypeId, b: TypeId) bool {
    if (a == b)                               { ret true; }
    if (a >= ti.type_len || b >= ti.type_len) { ret false; }

    val ta: *Type = ?ti.types[a];
    val tb: *Type = ?ti.types[b];
    if (ta.kind != TYPE_FUN || tb.kind != TYPE_FUN)     { ret false; }
    if (ta.data.fn.ret_type != tb.data.fn.ret_type)     { ret false; }
    if (ta.data.fn.params_len != tb.data.fn.params_len) { ret false; }

    var i: u32 = 0;
    for (i < ta.data.fn.params_len) {
        if (ti.params[ta.data.fn.params_start + i] != ti.params[tb.data.fn.params_start + i]) {
            ret false;
        }
        i = i + 1;
    }
    ret true;
}

# advance the current build epoch, invalidating every field table built in a
# prior epoch so the next builder rebuilds it with the current layout
#
# The driver calls this once per sema pass; a fresh session never calls it (its
# single build runs at epoch 0). (#1583)
# ---
# ti: the interner
pub fun field_epoch_bump(ti: *TypeInterner) {
    ti.field_epoch = ti.field_epoch + 1;
}

# the current build epoch a field-table builder stamps onto a table and compares
# an existing table's epoch against to decide rebuild vs reuse
# ---
# ti:  the interner
# ret: the current epoch
pub fun field_epoch(ti: *TypeInterner) u32 {
    ret ti.field_epoch;
}

# begin a field table for TypeId `ty`, returning its index; fields are appended
# with field_table_push
#
# Reuses `ty`'s existing table slot when present (a rebuild at a newer epoch -
# the old field-pool slice is abandoned), otherwise appends a fresh slot. The
# table is stamped with the current epoch.
# ---
# ti:  the interner
# ty:  the TypeId the table describes
# ret: the table's index, or an allocation error
pub fun field_table_begin(ti: *TypeInterner, ty: TypeId) R.Result[u32, str] {
    # rebuild in place: reuse the existing slot so a re-layout does not grow the
    # table array (the abandoned field-pool slice is the rebuild's only residue).
    val res_get: R.Result[*u32, str] = map.get[TypeId, u32](?ti.field_index, ?ty);
    if (R.is_ok[*u32, str](res_get)) {
        val reuse_idx: u32 = @R.unwrap_ok[*u32, str](res_get);
        ti.field_tables[reuse_idx].fields_start = ti.field_pool_len;
        ti.field_tables[reuse_idx].fields_len   = 0;
        ti.field_tables[reuse_idx].epoch        = ti.field_epoch;
        ret R.ok[u32, str](reuse_idx);
    }

    if (ti.field_table_len == ti.field_table_cap) {
        var new_cap: u32 = ti.field_table_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_FIELD_TABLE_CAP; }

        if (ti.field_tables == nil) {
            val res_a_tables: R.Result[*FieldTable, str] = A.allocate[FieldTable](ti.a, new_cap::usize);
            if (R.is_err[*FieldTable, str](res_a_tables)) {
                ret R.err[u32, str](R.unwrap_err[*FieldTable, str](res_a_tables));
            }
            ti.field_tables = R.unwrap_ok[*FieldTable, str](res_a_tables);
        }
        or {
            val res_ra_tables: R.Result[*FieldTable, str] = A.reallocate[FieldTable](ti.a, ti.field_tables, ti.field_table_cap::usize, new_cap::usize);
            if (R.is_err[*FieldTable, str](res_ra_tables)) {
                ret R.err[u32, str](R.unwrap_err[*FieldTable, str](res_ra_tables));
            }
            ti.field_tables = R.unwrap_ok[*FieldTable, str](res_ra_tables);
        }

        ti.field_table_cap = new_cap;
    }

    val idx:        u32                 = ti.field_table_len;
    val res_insert: R.Result[bool, str] = map.insert[TypeId, u32](?ti.field_index, ty, idx);
    if (R.is_err[bool, str](res_insert)) {
        ret R.err[u32, str](R.unwrap_err[bool, str](res_insert));
    }

    var ft: FieldTable;
    ft.ty           = ty;
    ft.fields_start = ti.field_pool_len;
    ft.fields_len   = 0;
    ft.epoch        = ti.field_epoch;
    ti.field_tables[idx] = ft;
    ti.field_table_len   = ti.field_table_len + 1;

    ret R.ok[u32, str](idx);
}

# ensure the field pool has room for `additional` more FieldEntries, growing it
# if not
#
# A table is built by pushing its fields one at a time; reserving the whole run
# up front means the pushes that follow cannot grow the pool, so they cannot fail
# partway and leave a half-built table registered at the current epoch (which a
# later builder would reuse as if complete). Call this before field_table_begin.
# ---
# ti:         the interner
# additional: number of FieldEntry slots the next table will push
# ret:        true once the pool has room, or an allocation error
pub fun field_table_reserve(ti: *TypeInterner, additional: u32) R.Result[bool, str] {
    if (ti.field_pool_len + additional <= ti.field_pool_cap) {
        ret R.ok[bool, str](true);
    }

    var new_cap: u32 = ti.field_pool_cap;
    if (new_cap == 0) { new_cap = INITIAL_FIELD_POOL_CAP; }
    for (ti.field_pool_len + additional > new_cap) {
        new_cap = new_cap * 2;
    }

    if (ti.field_pool == nil) {
        val res_a_pool: R.Result[*FieldEntry, str] = A.allocate[FieldEntry](ti.a, new_cap::usize);
        if (R.is_err[*FieldEntry, str](res_a_pool)) {
            ret R.err[bool, str](R.unwrap_err[*FieldEntry, str](res_a_pool));
        }
        ti.field_pool = R.unwrap_ok[*FieldEntry, str](res_a_pool);
    }
    or {
        val res_ra_pool: R.Result[*FieldEntry, str] = A.reallocate[FieldEntry](ti.a, ti.field_pool, ti.field_pool_cap::usize, new_cap::usize);
        if (R.is_err[*FieldEntry, str](res_ra_pool)) {
            ret R.err[bool, str](R.unwrap_err[*FieldEntry, str](res_ra_pool));
        }
        ti.field_pool = R.unwrap_ok[*FieldEntry, str](res_ra_pool);
    }

    ti.field_pool_cap = new_cap;
    ret R.ok[bool, str](true);
}

# append one `(name, ty)` field to the table at `table_idx`, growing the
# shared field pool as needed
#
# Fields must be pushed contiguously, before any other table is begun.
# ---
# ti:        the interner
# table_idx: index returned by field_table_begin
# name:      interned field identifier
# ty:        interned semantic type of the field
# ret:       true on success, or an allocation error
pub fun field_table_push(ti: *TypeInterner, table_idx: u32, name: intern.StrId, ty: TypeId) R.Result[bool, str] {
    if (ti.field_pool_len == ti.field_pool_cap) {
        var new_cap: u32 = ti.field_pool_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_FIELD_POOL_CAP; }

        if (ti.field_pool == nil) {
            val res_a_pool: R.Result[*FieldEntry, str] = A.allocate[FieldEntry](ti.a, new_cap::usize);
            if (R.is_err[*FieldEntry, str](res_a_pool)) {
                ret R.err[bool, str](R.unwrap_err[*FieldEntry, str](res_a_pool));
            }
            ti.field_pool = R.unwrap_ok[*FieldEntry, str](res_a_pool);
        }
        or {
            val res_ra_pool: R.Result[*FieldEntry, str] = A.reallocate[FieldEntry](ti.a, ti.field_pool, ti.field_pool_cap::usize, new_cap::usize);
            if (R.is_err[*FieldEntry, str](res_ra_pool)) {
                ret R.err[bool, str](R.unwrap_err[*FieldEntry, str](res_ra_pool));
            }
            ti.field_pool = R.unwrap_ok[*FieldEntry, str](res_ra_pool);
        }

        ti.field_pool_cap = new_cap;
    }

    var fe: FieldEntry;
    fe.name = name;
    fe.ty   = ty;
    ti.field_pool[ti.field_pool_len]      = fe;
    ti.field_pool_len                     = ti.field_pool_len + 1;
    ti.field_tables[table_idx].fields_len = ti.field_tables[table_idx].fields_len + 1;

    ret R.ok[bool, str](true);
}

# the field table describing nominal or instance TypeId `ty`, or none when
# none has been registered yet
# ---
# ti:  the interner
# ty:  the TypeId to look up
# ret: some(*FieldTable) when present, none otherwise
pub fun field_table_for(ti: *TypeInterner, ty: TypeId) O.Option[*FieldTable] {
    val res_get: R.Result[*u32, str] = map.get[TypeId, u32](?ti.field_index, ?ty);
    if (R.is_err[*u32, str](res_get)) {
        ret O.none[*FieldTable]();
    }
    ret O.some[*FieldTable](?ti.field_tables[@R.unwrap_ok[*u32, str](res_get)]);
}

# the number of fields registered for TypeId `ty`, or 0 when no table exists
# ---
# ti:  the interner
# ty:  the TypeId to inspect
# ret: the field count
pub fun field_count(ti: *TypeInterner, ty: TypeId) u32 {
    val opt_ft: O.Option[*FieldTable] = field_table_for(ti, ty);
    if (O.is_none[*FieldTable](opt_ft)) { ret 0; }
    ret O.unwrap[*FieldTable](opt_ft).fields_len;
}

# the `(name, ty)` entry at ordinal `ix` of TypeId `ty`'s table, or none when
# out of range or no table exists
# ---
# ti:  the interner
# ty:  the TypeId to inspect
# ix:  the field ordinal
# ret: some(*FieldEntry) on success, none otherwise
pub fun field_at(ti: *TypeInterner, ty: TypeId, ix: u32) O.Option[*FieldEntry] {
    val opt_ft: O.Option[*FieldTable] = field_table_for(ti, ty);
    if (O.is_none[*FieldTable](opt_ft)) {
        ret O.none[*FieldEntry]();
    }

    val ft: *FieldTable = O.unwrap[*FieldTable](opt_ft);
    if (ix >= ft.fields_len) {
        ret O.none[*FieldEntry]();
    }

    ret O.some[*FieldEntry](?ti.field_pool[ft.fields_start + ix]);
}

# the FieldEntry at ordinal `ix` of an already-fetched table, read straight
# from the field pool - O(1) with no table re-resolution
#
# The caller holds `ft` and guarantees `ix < ft.fields_len`.
# ---
# ti:  the interner
# ft:  a field table previously returned by field_table_for / field_table_begin
# ix:  the field ordinal, in range [0, ft.fields_len)
# ret: a borrowed pointer to the field entry
pub fun field_entry_at(ti: *TypeInterner, ft: *FieldTable, ix: u32) *FieldEntry {
    ret ?ti.field_pool[ft.fields_start + ix];
}

# return the existing TypeId for `t` via the dedup map, or append it and
# record the mapping
# ---
# ti:  the interner
# t:   the Type to intern (a dedup-eligible kind, not TYPE_FUN / TYPE_INSTANCE)
# ret: the existing or freshly appended TypeId, or an allocation error
fun intern_dedup(ti: *TypeInterner, t: Type) R.Result[TypeId, str] {
    val res_get: R.Result[*TypeId, str] = map.get[Type, TypeId](?ti.dedup, ?t);
    if (R.is_ok[*TypeId, str](res_get)) {
        ret R.ok[TypeId, str](@R.unwrap_ok[*TypeId, str](res_get));
    }

    val res_append: R.Result[TypeId, str] = append_type(ti, t);
    if (R.is_err[TypeId, str](res_append)) {
        ret res_append;
    }
    val tid: TypeId = R.unwrap_ok[TypeId, str](res_append);

    val res_insert: R.Result[bool, str] = map.insert[Type, TypeId](?ti.dedup, t, tid);
    if (R.is_err[bool, str](res_insert)) {
        ret R.err[TypeId, str](R.unwrap_err[bool, str](res_insert));
    }

    ret R.ok[TypeId, str](tid);
}

# append `t` to the universe (growing it as needed) and return its fresh
# TypeId
# ---
# ti:  the interner
# t:   the Type to append
# ret: the fresh TypeId, or an allocation error
fun append_type(ti: *TypeInterner, t: Type) R.Result[TypeId, str] {
    if (ti.type_len == ti.type_cap) {
        val new_cap: u32 = ti.type_cap * 2;
        val res_ra_types: R.Result[*Type, str] = A.reallocate[Type](ti.a, ti.types, ti.type_cap::usize, new_cap::usize);
        if (R.is_err[*Type, str](res_ra_types)) {
            ret R.err[TypeId, str](R.unwrap_err[*Type, str](res_ra_types));
        }
        ti.types    = R.unwrap_ok[*Type, str](res_ra_types);
        ti.type_cap = new_cap;
    }

    val tid: TypeId = ti.type_len;
    ti.types[ti.type_len] = t;
    ti.type_len = ti.type_len + 1;

    ret R.ok[TypeId, str](tid);
}

# ensure the parameter pool has room for `need` more TypeIds, growing it if
# not
# ---
# ti:   the interner
# need: number of additional TypeId slots required
# ret:  true once the pool has room, or an allocation error
fun reserve_params(ti: *TypeInterner, need: u32) R.Result[bool, str] {
    if (ti.params_len + need <= ti.params_cap) {
        ret R.ok[bool, str](true);
    }

    var new_cap: u32 = ti.params_cap;
    if (new_cap == 0) { new_cap = INITIAL_PARAMS_CAP; }
    for (ti.params_len + need > new_cap) {
        new_cap = new_cap * 2;
    }

    val res_ra_params: R.Result[*TypeId, str] = A.reallocate[TypeId](ti.a, ti.params, ti.params_cap::usize, new_cap::usize);
    if (R.is_err[*TypeId, str](res_ra_params)) {
        ret R.err[bool, str](R.unwrap_err[*TypeId, str](res_ra_params));
    }
    ti.params     = R.unwrap_ok[*TypeId, str](res_ra_params);
    ti.params_cap = new_cap;

    ret R.ok[bool, str](true);
}

# copy `len` TypeIds from `src` into the parameter pool, growing it as needed,
# and return the pool index where the copied run begins
#
# Shared by intern_function and intern_instance, whose side-pool slices are
# built identically. `src` may be nil when `len` is 0.
# ---
# ti:  the interner
# src: pointer to the TypeIds to copy
# len: number of TypeIds to copy
# ret: the start index of the run in ti.params, or an allocation error
fun params_append(ti: *TypeInterner, src: *TypeId, len: u32) R.Result[u32, str] {
    val start: u32 = ti.params_len;

    val res_reserve: R.Result[bool, str] = reserve_params(ti, len);
    if (R.is_err[bool, str](res_reserve)) {
        ret R.err[u32, str](R.unwrap_err[bool, str](res_reserve));
    }

    var i: u32 = 0;
    for (i < len) {
        ti.params[start + i] = src[i];
        i = i + 1;
    }
    ti.params_len = start + len;

    ret R.ok[u32, str](start);
}

# FNV-1a content hash over a function signature (ret, params), matching the
# identity `fun_matches` verifies
# ---
# ret_type: return type
# params:   pointer to a contiguous array of fixed parameter TypeIds
# count:    number of fixed parameter types
# ret:      the signature's content hash
fun hash_fun(ret_type: TypeId, params: *TypeId, count: u32) u64 {
    var h: u64 = fnv1a.FNV_INIT;
    h = fnv1a.step_u8(h, TYPE_FUN::u8);
    h = fnv1a.step_u32(h, ret_type::u32);
    h = fnv1a.step_u32(h, count);

    var i: u32 = 0;
    for (i < count) {
        h = fnv1a.step_u32(h, params[i]::u32);
        i = i + 1;
    }
    ret h;
}

# whether the interned TYPE_FUN at `tid` has exactly the given signature
# (ret, params slice)
# ---
# ti:       the interner
# tid:      TypeId of the candidate (verified to be TYPE_FUN)
# ret_type: return type to match
# params:   pointer to a contiguous array of fixed parameter TypeIds
# count:    number of fixed parameter types
# ret:      true when `tid` is a TYPE_FUN with exactly this signature
fun fun_matches(ti: *TypeInterner, tid: TypeId, ret_type: TypeId, params: *TypeId, count: u32) bool {
    if (tid >= ti.type_len) { ret false; }

    val t: *Type = ?ti.types[tid];
    if (t.kind != TYPE_FUN)             { ret false; }
    if (t.data.fn.ret_type != ret_type) { ret false; }
    if (t.data.fn.params_len != count)  { ret false; }

    var i: u32 = 0;
    for (i < count) {
        if (ti.params[t.data.fn.params_start + i] != params[i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

# append `tid` to the instance list, growing it as needed
# ---
# ti:  the interner
# tid: the instance TypeId to track
# ret: true on success, or an allocation error
fun track_instance(ti: *TypeInterner, tid: TypeId) R.Result[bool, str] {
    if (ti.instances_len == ti.instances_cap) {
        var new_cap: u32 = ti.instances_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_INSTANCE_CAP; }

        if (ti.instances == nil) {
            val res_a_instances: R.Result[*TypeId, str] = A.allocate[TypeId](ti.a, new_cap::usize);
            if (R.is_err[*TypeId, str](res_a_instances)) {
                ret R.err[bool, str](R.unwrap_err[*TypeId, str](res_a_instances));
            }
            ti.instances = R.unwrap_ok[*TypeId, str](res_a_instances);
        }
        or {
            val res_ra_instances: R.Result[*TypeId, str] = A.reallocate[TypeId](ti.a, ti.instances, ti.instances_cap::usize, new_cap::usize);
            if (R.is_err[*TypeId, str](res_ra_instances)) {
                ret R.err[bool, str](R.unwrap_err[*TypeId, str](res_ra_instances));
            }
            ti.instances = R.unwrap_ok[*TypeId, str](res_ra_instances);
        }

        ti.instances_cap = new_cap;
    }

    ti.instances[ti.instances_len] = tid;
    ti.instances_len = ti.instances_len + 1;

    ret R.ok[bool, str](true);
}

# structural FNV-1a hash over Type's identity-bearing fields
#
# Function types bypass dedup, so this never hashes one.
# ---
# p:   pointer to the Type to hash (as `ptr`, per the dedup map's hash signature)
# ret: the structural hash
fun hash_type(p: ptr) u64 {
    val t: *Type = p::*Type;

    var h: u64 = fnv1a.FNV_INIT;
    h = fnv1a.step_u8(h, t.kind::u8);
    if (t.kind == TYPE_POINTER) {
        h = fnv1a.step_u32(h, t.data.pointer.base::u32);
    }
    or (t.kind == TYPE_SECRET) {
        h = fnv1a.step_u32(h, t.data.secret.base::u32);
    }
    or (t.kind == TYPE_ARRAY) {
        h = fnv1a.step_u32(h, t.data.array.base::u32);
        h = fnv1a.step_u32(h, t.data.array.count);
    }
    or (t.kind == TYPE_REC || t.kind == TYPE_UNI) {
        h = fnv1a.step_u32(h, t.data.nominal.origin::u32);
        h = fnv1a.step_u32(h, t.data.nominal.decl::u32);
    }
    or (t.kind == TYPE_GENERIC_PARAM) {
        h = fnv1a.step_u32(h, t.data.generic_param.owner::u32);
        h = fnv1a.step_u32(h, t.data.generic_param.index);
    }
    ret h;
}

# structural equality over two Types' identity-bearing fields; primitives
# compare by kind alone
# ---
# pa:  pointer to the first Type (as `ptr`, per the dedup map's eq signature)
# pb:  pointer to the second Type
# ret: true when both Types share the same identity-bearing fields
fun eq_type(pa: ptr, pb: ptr) bool {
    val a: *Type = pa::*Type;
    val b: *Type = pb::*Type;
    if (a.kind != b.kind) { ret false; }

    if (a.kind == TYPE_POINTER) {
        ret a.data.pointer.base == b.data.pointer.base;
    }
    if (a.kind == TYPE_SECRET) {
        ret a.data.secret.base == b.data.secret.base;
    }
    if (a.kind == TYPE_ARRAY) {
        ret a.data.array.base == b.data.array.base
            && a.data.array.count == b.data.array.count;
    }
    if (a.kind == TYPE_REC || a.kind == TYPE_UNI) {
        ret a.data.nominal.origin == b.data.nominal.origin
            && a.data.nominal.decl == b.data.nominal.decl;
    }
    if (a.kind == TYPE_GENERIC_PARAM) {
        ret a.data.generic_param.owner == b.data.generic_param.owner
            && a.data.generic_param.index == b.data.generic_param.index;
    }

    # primitives and TYPE_ERROR are equal by kind alone
    ret true;
}

# intern_function returns one TypeId for identical signatures and distinct ids
# when a parameter type differs
test "mach.lang.type.intern_function:identical_signatures" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var ti: TypeInterner;
    if (O.is_some[str](init(?ti, ?alloc))) { ret 1; }

    val u8_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U8));

    # same signature interned twice -> same TypeId
    val r1: R.Result[TypeId, str] = intern_function(?ti, u8_id, nil, 0);
    val r2: R.Result[TypeId, str] = intern_function(?ti, u8_id, nil, 0);
    if (R.is_err[TypeId, str](r1))                                    { dnit(?ti); ret 1; }
    if (R.is_err[TypeId, str](r2))                                    { dnit(?ti); ret 1; }
    if (R.unwrap_ok[TypeId, str](r1) != R.unwrap_ok[TypeId, str](r2)) { dnit(?ti); ret 1; }

    # fun(u32)->u8 and fun(u64)->u8 differ because the param types differ
    val u32_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U32));
    val u64_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U64));
    var p32: [1]TypeId;
    p32[0] = u32_id;
    var p64: [1]TypeId;
    p64[0] = u64_id;
    val r4: R.Result[TypeId, str] = intern_function(?ti, u8_id, ?p32[0], 1);
    val r5: R.Result[TypeId, str] = intern_function(?ti, u8_id, ?p64[0], 1);
    if (R.is_err[TypeId, str](r4))                                    { dnit(?ti); ret 1; }
    if (R.is_err[TypeId, str](r5))                                    { dnit(?ti); ret 1; }
    if (R.unwrap_ok[TypeId, str](r4) == R.unwrap_ok[TypeId, str](r5)) { dnit(?ti); ret 1; }

    dnit(?ti);
    ret 0;
}

# intern_instance dedups on (origin, decl, args) and distinguishes a differing
# arg type and a differing arg count
test "mach.lang.type.intern_instance:dedup_by_origin_decl_args" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var ti: TypeInterner;
    if (O.is_some[str](init(?ti, ?alloc))) { ret 1; }

    val u32_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U32));
    val u8_id:  TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U8));

    var a1: [1]TypeId;
    a1[0] = u32_id;

    # same (origin, decl, args) interned twice -> same TypeId
    val r1: R.Result[TypeId, str] = intern_instance(?ti, 1::module.ModuleId, 0::id.DeclId, ?a1[0], 1);
    val r2: R.Result[TypeId, str] = intern_instance(?ti, 1::module.ModuleId, 0::id.DeclId, ?a1[0], 1);
    if (R.is_err[TypeId, str](r1))                                    { dnit(?ti); ret 1; }
    if (R.is_err[TypeId, str](r2))                                    { dnit(?ti); ret 1; }
    if (R.unwrap_ok[TypeId, str](r1) != R.unwrap_ok[TypeId, str](r2)) { dnit(?ti); ret 1; }

    # different arg type -> different TypeId
    var a1u8: [1]TypeId;
    a1u8[0] = u8_id;
    val r3: R.Result[TypeId, str] = intern_instance(?ti, 1::module.ModuleId, 0::id.DeclId, ?a1u8[0], 1);
    if (R.is_err[TypeId, str](r3))                                    { dnit(?ti); ret 1; }
    if (R.unwrap_ok[TypeId, str](r1) == R.unwrap_ok[TypeId, str](r3)) { dnit(?ti); ret 1; }

    # different arg count -> different TypeId
    var a2: [2]TypeId;
    a2[0] = u32_id;
    a2[1] = u8_id;
    val r4: R.Result[TypeId, str] = intern_instance(?ti, 1::module.ModuleId, 0::id.DeclId, ?a2[0], 2);
    if (R.is_err[TypeId, str](r4))                                    { dnit(?ti); ret 1; }
    if (R.unwrap_ok[TypeId, str](r1) == R.unwrap_ok[TypeId, str](r4)) { dnit(?ti); ret 1; }

    dnit(?ti);
    ret 0;
}

# type_equals_signatures sees identical signatures as equal, a differing param
# type as unequal, and a sentinel TypeId as unequal
test "mach.lang.type.type_equals_signatures:param_and_nil_boundaries" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var ti: TypeInterner;
    if (O.is_some[str](init(?ti, ?alloc))) { ret 1; }

    val i32_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_I32));
    val i64_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_I64));

    var pi32: [1]TypeId;
    pi32[0] = i32_id;
    var pi64: [1]TypeId;
    pi64[0] = i64_id;

    # fun(i32)->void interned twice -> same TypeId via dedup
    val ra: R.Result[TypeId, str] = intern_function(?ti, TYPE_NIL, ?pi32[0], 1);
    val rc: R.Result[TypeId, str] = intern_function(?ti, TYPE_NIL, ?pi32[0], 1);
    val rd: R.Result[TypeId, str] = intern_function(?ti, TYPE_NIL, ?pi64[0], 1);
    if (R.is_err[TypeId, str](ra)) { dnit(?ti); ret 1; }
    if (R.is_err[TypeId, str](rc)) { dnit(?ti); ret 1; }
    if (R.is_err[TypeId, str](rd)) { dnit(?ti); ret 1; }

    val tid_a: TypeId = R.unwrap_ok[TypeId, str](ra);
    val tid_c: TypeId = R.unwrap_ok[TypeId, str](rc);
    val tid_d: TypeId = R.unwrap_ok[TypeId, str](rd);

    # a vs c: identical signatures -> equal (deduped to same TypeId)
    if (!type_equals_signatures(?ti, tid_a, tid_c))   { dnit(?ti); ret 1; }
    # a vs d: differ on param type -> not equal
    if (type_equals_signatures(?ti, tid_a, tid_d))    { dnit(?ti); ret 1; }
    # a vs TYPE_NIL sentinel: not equal (non-FUN or out-of-range)
    if (type_equals_signatures(?ti, tid_a, TYPE_NIL)) { dnit(?ti); ret 1; }

    dnit(?ti);
    ret 0;
}

# is_integer / is_numeric / is_float pin their kind boundaries against a
# comptime pack, a pointer, and an array
test "mach.lang.type:numeric_predicate_boundaries" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var ti: TypeInterner;
    if (O.is_some[str](init(?ti, ?alloc))) { ret 1; }

    val ptr_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_PTR));
    val u8_id:  TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U8));
    val i64_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_I64));
    val f32_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_F32));

    val pack_r: R.Result[TypeId, str] = intern_pack(?ti);
    if (R.is_err[TypeId, str](pack_r)) { dnit(?ti); ret 1; }
    val pack_id: TypeId = R.unwrap_ok[TypeId, str](pack_r);

    val arr_r: R.Result[TypeId, str] = intern_array(?ti, u8_id, 4);
    if (R.is_err[TypeId, str](arr_r)) { dnit(?ti); ret 1; }
    val arr_id: TypeId = R.unwrap_ok[TypeId, str](arr_r);

    # a comptime pack is neither integer, numeric, nor float
    if (is_integer(?ti, pack_id)) { dnit(?ti); ret 1; }
    if (is_numeric(?ti, pack_id)) { dnit(?ti); ret 1; }
    if (is_float(?ti, pack_id))   { dnit(?ti); ret 1; }
    # ptr is not an integer
    if (is_integer(?ti, ptr_id))  { dnit(?ti); ret 1; }
    # u8 and i64 are integers
    if (!is_integer(?ti, u8_id))  { dnit(?ti); ret 1; }
    if (!is_integer(?ti, i64_id)) { dnit(?ti); ret 1; }
    # f32 is a float
    if (!is_float(?ti, f32_id))   { dnit(?ti); ret 1; }
    # array is not an integer
    if (is_integer(?ti, arr_id))  { dnit(?ti); ret 1; }

    dnit(?ti);
    ret 0;
}

# intern_secret dedups, collapses a doubled qualifier, and threads the secret
# qualifier through the classifier / spine predicates (#1645)
test "mach.lang.type.intern_secret:dedup_collapse_and_predicates" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var ti: TypeInterner;
    if (O.is_some[str](init(?ti, ?alloc))) { ret 1; }

    val u32_id: TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U32));

    # `^u32` interned twice -> one TypeId, distinct from `u32`
    val s1: R.Result[TypeId, str] = intern_secret(?ti, u32_id);
    val s2: R.Result[TypeId, str] = intern_secret(?ti, u32_id);
    if (R.is_err[TypeId, str](s1) || R.is_err[TypeId, str](s2)) { dnit(?ti); ret 1; }
    val sec_u32: TypeId = R.unwrap_ok[TypeId, str](s1);
    if (sec_u32 != R.unwrap_ok[TypeId, str](s2)) { dnit(?ti); ret 1; }
    if (sec_u32 == u32_id)                       { dnit(?ti); ret 1; }

    # `^^u32` collapses to `^u32` - the lattice is two-point
    val s3: R.Result[TypeId, str] = intern_secret(?ti, sec_u32);
    if (R.is_err[TypeId, str](s3))                  { dnit(?ti); ret 1; }
    if (R.unwrap_ok[TypeId, str](s3) != sec_u32)    { dnit(?ti); ret 1; }

    # is_secret / strip_secret round-trip
    if (!is_secret(?ti, sec_u32))                 { dnit(?ti); ret 1; }
    if (is_secret(?ti, u32_id))                   { dnit(?ti); ret 1; }
    if (strip_secret(?ti, sec_u32) != u32_id)     { dnit(?ti); ret 1; }
    if (strip_secret(?ti, u32_id) != u32_id)      { dnit(?ti); ret 1; }

    # a secret integer is still an integer for arithmetic classification
    if (!is_integer(?ti, sec_u32))                { dnit(?ti); ret 1; }
    if (!is_numeric(?ti, sec_u32))                { dnit(?ti); ret 1; }

    # `*^u32` carries secret along its spine; `*u32` does not
    val pp_sec: R.Result[TypeId, str] = intern_pointer(?ti, sec_u32);
    val pp_pub: R.Result[TypeId, str] = intern_pointer(?ti, u32_id);
    if (R.is_err[TypeId, str](pp_sec) || R.is_err[TypeId, str](pp_pub)) { dnit(?ti); ret 1; }
    val ptr_sec: TypeId = R.unwrap_ok[TypeId, str](pp_sec);
    val ptr_pub: TypeId = R.unwrap_ok[TypeId, str](pp_pub);
    if (!carries_secret(?ti, ptr_sec))            { dnit(?ti); ret 1; }
    if (carries_secret(?ti, ptr_pub))             { dnit(?ti); ret 1; }
    if (!carries_secret(?ti, sec_u32))            { dnit(?ti); ret 1; }

    # secrecy_structure_equal: `*^u32` differs from `*u32`, matches itself, and
    # `^u32` vs `^u64` (same placement, differing leaves) is equal
    val u64_id:  TypeId = O.unwrap[TypeId](prim(?ti, TYPE_U64));
    val sec_u64: R.Result[TypeId, str] = intern_secret(?ti, u64_id);
    if (R.is_err[TypeId, str](sec_u64)) { dnit(?ti); ret 1; }
    if (secrecy_structure_equal(?ti, ptr_sec, ptr_pub))                       { dnit(?ti); ret 1; }
    if (!secrecy_structure_equal(?ti, ptr_sec, ptr_sec))                      { dnit(?ti); ret 1; }
    if (!secrecy_structure_equal(?ti, sec_u32, R.unwrap_ok[TypeId, str](sec_u64))) { dnit(?ti); ret 1; }
    if (secrecy_structure_equal(?ti, sec_u32, u32_id))                       { dnit(?ti); ret 1; }

    dnit(?ti);
    ret 0;
}
