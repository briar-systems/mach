    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # a `def` alias has no layout of its own and emits no symbol, so an `align` on
    # it would silently no-op; it is rejected as an invalid target instead.
    val res_fid: R.Result[source.FileId, str] = open(?es, "da.mach", "#[align(8)] def D: u64;\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                                                                                 { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "`align` decorator applies only to records, unions, and globals")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a `va: ...` pack declares; `va.len` and `$each a in va` typecheck (#1474)
test "mach.lang.editor.sema:variadic_pack_declares" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # a named trailing pack parameter; `va.len` is the comptime element count and
    # `$each a in va` iterates it (element body deferred to monomorphization).
    val res_fid: R.Result[source.FileId, str] = open(?es, "pk.mach",
        "fun take(va: ...) i64 { var n: i64 = va.len::i64; $each a in va { } ret n; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                           { dnit(?es); session.dnit(?s); ret 1; }
    if (diagnostic.has_errors(R.unwrap_ok[*diagnostic.DiagList, str](res_diags))) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

