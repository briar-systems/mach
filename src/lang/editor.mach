    if (diag_count(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "incompatible operand types") != 1) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# mixed-signedness integer comparison is accepted (#1248)
test "mach.lang.editor.sema:mixed_sign_int_compare" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # i32 vs u64 compares mathematical values; sema must accept it without a
    # type-mismatch, the lowering handles the value-correct sequence.
    val res_fid: R.Result[source.FileId, str] = open(?es, "mix.mach",
        "fun main() i64 { var a: i32 = 0; var b: u64 = 0; val c: u8 = a < b; ret c::i64; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                               { dnit(?es); session.dnit(?s); ret 1; }
    if (diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "type mismatch")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# mixed-width float comparison is accepted (#1248)
