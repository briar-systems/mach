}

# calling a non-function renders the callee type (#1046)
test "mach.lang.editor.sema:call_non_function" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # `x` is an i64, not a function; calling it reports the callee's rendered
    # type rather than a bare "callee is not a function".
    val res_fid: R.Result[source.FileId, str] = open(?es, "nc.mach",
        "fun main() i64 { var x: i64 = 0; ret x(); }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                                                        { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "not callable: `i64` is not a function")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# pointer reinterpret legality follows the target pointer width (#1248)
test "mach.lang.editor.sema:reinterpret_pointer_width" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # a `*u8` reinterpreted to u32 is legal exactly when a pointer is 4 bytes;
    # byte_size must read the width from the target, not a hardcoded 8.
    val res_fid: R.Result[source.FileId, str] = open(?es, "pw.mach",
        "fun main() i64 { var p: *u8; var x: u32; x = p:~u32; ret 0; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags_4: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 4);
    if (R.is_err[*diagnostic.DiagList, str](res_diags_4))                                 { dnit(?es); session.dnit(?s); ret 1; }
    if (diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags_4), "bit reinterpret")) { dnit(?es); session.dnit(?s); ret 1; }

    val res_diags_8: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags_8))                                  { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags_8), "bit reinterpret")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a buffer's comptime ctx is seeded from the host target, not a placeholder (#1249)
test "mach.lang.editor.open:ctx_seeded_from_host" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    val res_fid: R.Result[source.FileId, str] = open(?es, "buf.mach", "fun f() {}\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val b: *Buffer = slot_live(?es, fid);
    if (b == nil) { dnit(?es); session.dnit(?s); ret 1; }
    # the ctx target params reflect the running compiler's host, not the old
    # os=0 / arch=0 / ptr=8 placeholder that made the LSP read target-gated code
    # as a freestanding/unknown target.
    if (b.ctx.target_os_id != target.host_os_id())          { dnit(?es); session.dnit(?s); ret 1; }
    if (b.ctx.target_arch_id != target.host_arch_id())      { dnit(?es); session.dnit(?s); ret 1; }
    if (b.ctx.pointer_width != target.host_pointer_width()) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# repeated resolve resets diagnostics instead of accumulating them (#1249)
test "mach.lang.editor.resolve:repeated_resets_diags" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # an unbound `undef` makes every resolve emit a diagnostic; the count must
    # stay stable across repeated calls rather than doubling.
    val res_fid: R.Result[source.FileId, str] = open(?es, "buf.mach", "fun f() i64 { ret undef; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_resolve_1: R.Result[*res.ResolveResult, str] = resolve(?es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve_1)) { dnit(?es); session.dnit(?s); ret 1; }
    val len_1: usize = es.s.diags.len;
    if (len_1 == 0) { dnit(?es); session.dnit(?s); ret 1; }

    val res_resolve_2: R.Result[*res.ResolveResult, str] = resolve(?es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve_2)) { dnit(?es); session.dnit(?s); ret 1; }
    val len_2: usize = es.s.diags.len;

    # without the reset-on-entry, the second resolve appends a duplicate set.
    if (len_2 != len_1) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a runtime local shadowing a module const is rejected in a $if gate, not folded (#1249)
test "mach.lang.editor.resolve:local_shadows_comptime_const" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # `N` is a module comptime const; the runtime local `N` shadows it. the
    # comptime env is name-keyed, so the gate fold silently succeeds against the
    # module const 4 while the resolver bound the ident to the local - resolve
    # must reject the gate on resolution identity instead of miscompiling it.
    val res_fid: R.Result[source.FileId, str] = open(?es, "shadow.mach",
        "pub val N: i64 = 4;\nfun g(x: i64) i64 {\n    val N: i64 = x;\n    $if (N > 2) { ret 1; }\n    ret 0;\n}\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_resolve: R.Result[*res.ResolveResult, str] = resolve(?es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve))        { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(?es.s.diags, "shadows a comptime constant")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a runtime parameter shadowing a module const is rejected in a $if gate (#1249)
test "mach.lang.editor.resolve:param_shadows_comptime_const" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # same miscompile through a runtime (non-`$`) parameter named after the
    # module const: the fold would silently use the const, not the parameter.
    val res_fid: R.Result[source.FileId, str] = open(?es, "pshadow.mach",
        "pub val N: i64 = 4;\nfun g(N: i64) i64 {\n    $if (N > 2) { ret 1; }\n    ret 0;\n}\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_resolve: R.Result[*res.ResolveResult, str] = resolve(?es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve))        { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(?es.s.diags, "shadows a comptime constant")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a standalone bare $ident gate is rejected with the teaching diagnostic (#1249)
test "mach.lang.editor.resolve:bare_dollar_ident_gate_rejected" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # a lone `$mode` is none of the closed comptime channel shapes: a comptime
    # parameter is referenced without `$`, and comptime paths are rooted. the
    # gate must be rejected with the single teaching diagnostic owned by eval,
    # not folded nor reported with a path-root message.
    val res_fid: R.Result[source.FileId, str] = open(?es, "bareident.mach",
        "fun g() i64 {\n    $if ($mode) { ret 1; }\n    ret 0;\n}\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_resolve: R.Result[*res.ResolveResult, str] = resolve(?es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve))                       { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(?es.s.diags, "comptime parameters are referenced without")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# nil coerces to fun types in every position (#1369)
test "mach.lang.editor.sema:nil_coerces_to_fun" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # nil is the null address and takes any pointer-like type, function types
    # included. it must coerce uniformly into a fun-typed global (bare and
    # `nil::F`), a local, a record field, an argument, and a return slot, and an
    # `== nil` comparison must still type. none of these may report a mismatch.
    val res_fid: R.Result[source.FileId, str] = open(?es, "nilfun.mach",
        "def F: fun(u32);\npub var gq: fun(u32) = nil;\npub var gr: F = nil::F;\nrec T { cb: fun(); k: F; }\nfun take(c: fun(u32)) u8 { if (c == nil) { ret 1; } ret 0; }\nfun give() fun(u32) { ret nil; }\nfun givec() F { ret nil::F; }\nfun main() i64 { var lq: fun(u32) = nil; var lr: F = nil::F; var t: T = T{ cb: nil, k: nil::F }; if (gq != nil) { ret 1; } if (lr != nil) { ret 2; } if (t.k != nil) { ret 3; } ret take(lq)::i64; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                               { dnit(?es); session.dnit(?s); ret 1; }
    if (diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "type mismatch")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# nil into a non-pointer binding is still rejected (#1369)
test "mach.lang.editor.sema:nil_into_non_pointer_rejected" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # the coercion admits only pointer-like targets; nil into an integer slot is
    # still a mismatch, so widening nil to a non-address type stays an error.
    val res_fid: R.Result[source.FileId, str] = open(?es, "nilint.mach",
        "fun main() i64 { var bad: u32 = nil; ret 0; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                                { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "type mismatch")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}
