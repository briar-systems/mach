    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "`align` decorator applies only to records, unions, and globals")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a section decorator on a function or global is accepted; on a type is rejected (#1476)
test "mach.lang.editor.sema:section_decorator_target" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # `section` applies to functions and globals (placed, no error); a `def` type
    # is not a symbol-bearing decl, so a section on it is reported.
    val res_fid: R.Result[source.FileId, str] = open(?es, "se.mach",
        "#[section(\".s\")] pub var g: u64 = 0;\n#[section(\".s\")] fun f() i64 { ret 0; }\n#[section(\".s\")] def D: u64;\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags)) { dnit(?es); session.dnit(?s); ret 1; }
    val list: *diagnostic.DiagList = R.unwrap_ok[*diagnostic.DiagList, str](res_diags);
    if (!diag_has(list, "`section` decorator applies only to functions and globals")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a negative align on a type is reported, not silently dropped (#1490)
test "mach.lang.editor.sema:negative_align_reported" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # `#[align(-8)]` on a record folds to a negative integer-typed constant - the
    # body-pass validator can't catch it (it's integer-typed), so the decl-pass
    # fold must report it rather than `ret` silently.
    val res_fid: R.Result[source.FileId, str] = open(?es, "na.mach", "#[align(-8)] rec R { a: u8; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                                                                { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "`align` value must be a non-zero power of two")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# align on a def alias is rejected, not silently ignored (#1490)
test "mach.lang.editor.sema:align_on_def_alias_rejected" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
