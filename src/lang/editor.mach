# the compiler-as-library query surface for editor tooling
#
# the single entry an editor (LSP server, plugin) binds to. an editor holds
# dirty, possibly-broken in-memory buffers and wants best-effort analysis of one
# buffer at a time, without a full `driver.build_project`. register a buffer's
# text directly, then ask for its tokens, its parsed `ast.Ast`, its
# `res.ResolveResult` side tables, its semantic expression types, or its
# diagnostics. each phase tolerates a malformed buffer and returns a usable
# partial result rather than bailing at the first error.
#
# an `EditorSession` borrows a caller-owned `session.Session` (whose `SourceMap`
# holds the buffer text and whose `DiagList` collects diagnostics) and owns one
# `*ast.Ast`, one `*res.ResolveResult`, and an optional `*context.SemaResult`
# per registered buffer, keyed by `source.FileId`. teardown frees those; the
# borrowed session is left untouched.
#
# a buffer is resolved in isolation against an empty dependency set, so local
# names bind while cross-module references resolve to SYMBOL_NIL. its comptime
# context is seeded from the host target, so `$if` predicates evaluate against
# the running compiler rather than an unknown placeholder.
#
# this surface drives the front-end phases directly rather than routing through
# `query.QueryDb.get`. routing these entries through `get` lands with the LSP
# query integration without changing this module's signatures.

use std.allocator.page;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_contains;
use std.types.string.str_index_of;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.id;
use mach.lang.fe.comptime;
use mach.lang.fe.lexer;
use mach.lang.fe.parser;
use res: mach.lang.fe.resolve;
use mach.lang.fe.sema;
use mach.lang.fe.sema.context;
use mach.lang.intern;
use mach.lang.session;
use mach.lang.source;
use mach.lang.target;
use mach.lang.type;

# the per-buffer analysis state an EditorSession owns for one registered file
# ---
# file_id: FileId the buffer is registered under
# in_use:  whether this slot holds a live buffer (slots are indexed by FileId)
# a:       owned parsed Ast, or nil before the first parse
# rr:      owned ResolveResult side tables, or nil before the first resolve
# sr:      owned SemaResult expression-type side tables, or nil until `analyze`;
#          derived from `rr`, so dropping `rr` drops it
# ctx:     comptime context resolve evaluates against; a dnit-safe value at all times
pub rec Buffer {
    file_id: source.FileId;
    in_use:  bool;
    a:       *ast.Ast;
    rr:      *res.ResolveResult;
    sr:      *context.SemaResult;
    ctx:     comptime.ComptimeCtx;
}

# the editor-facing facade over a borrowed compiler session
# ---
# s:       borrowed session; owns the SourceMap (buffer text) and DiagList
# alloc:   allocator for the buffer registry and per-buffer analysis
# buffers: Buffer registry indexed by FileId
# buf_len: number of slots in `buffers`
pub rec EditorSession {
    s:       *session.Session;
    alloc:   *A.Allocator;
    buffers: *Buffer;
    buf_len: u32;
}

# seed slot count for the buffer registry on its first growth
val BUFFERS_SEED: u32 = 8;

# construct an editor session over a caller-owned compiler session
#
# The session must outlive the editor session; the editor borrows its SourceMap
# and DiagList and never tears them down.
# ---
# s:   the compiler session whose SourceMap and DiagList back this editor
# ret: a new empty EditorSession
pub fun init(s: *session.Session) EditorSession {
    var es: EditorSession;
    es.s       = s;
    es.alloc   = s.alloc;
    es.buffers = nil;
    es.buf_len = 0;
    ret es;
}

# release every owned Ast, ResolveResult, and comptime context, plus the buffer
# registry; the borrowed session is left untouched
# ---
# es: the editor session to tear down
pub fun dnit(es: *EditorSession) {
    if (es == nil) { ret; }
    if (es.buffers != nil && es.buf_len > 0) {
        var i: u32 = 0;
        for (i < es.buf_len) {
            buffer_free(es, ?es.buffers[i]);
            i = i + 1;
        }
        A.deallocate[Buffer](es.alloc, es.buffers, es.buf_len::usize);
    }
    es.buffers = nil;
    es.buf_len = 0;
}

# register an unsaved buffer's text and return its FileId
#
# The text is copied into the session's SourceMap and a fresh analysis slot is
# reserved. The buffer is not yet parsed.
# ---
# es:   the editor session
# path: a display path for the buffer (the LSP document URI, or any label)
# text: the buffer's full source text; copied into the session
# ret:  the FileId the buffer is registered under, or an allocation error
pub fun open(es: *EditorSession, path: str, text: str) R.Result[source.FileId, str] {
    val res_fid: R.Result[source.FileId, str] = session.load_source(es.s, path, text);
    if (R.is_err[source.FileId, str](res_fid)) { ret res_fid; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_slot: R.Result[*Buffer, str] = slot_ensure(es, fid);
    if (R.is_err[*Buffer, str](res_slot)) {
        ret R.err[source.FileId, str](R.unwrap_err[*Buffer, str](res_slot));
    }
    ret R.ok[source.FileId, str](fid);
}

# replace the text of an open buffer, dropping its cached analysis
#
# The SourceMap text is rebuilt and the next parse / resolve recomputes against
# it. An unknown or out-of-range id is a no-op returning false.
# ---
# es:   the editor session
# fid:  FileId of the buffer to replace
# text: the buffer's new full source text
# ret:  true when the buffer was updated, false when fid is unknown, or an allocation error
pub fun update(es: *EditorSession, fid: source.FileId, text: str) R.Result[bool, str] {
    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret R.ok[bool, str](false); }

    val res_update: R.Result[bool, str] = source.update(?es.s.sources, ?es.s.queries, fid, text);
    if (R.is_err[bool, str](res_update))     { ret res_update; }
    if (!R.unwrap_ok[bool, str](res_update)) { ret R.ok[bool, str](false); }

    analysis_drop(es, b);
    ret R.ok[bool, str](true);
}

# lex an open buffer, surfacing lex errors as diagnostics
#
# Returns the owning TokenStream; the caller frees it with `lexer.dnit`.
# Malformed input is recorded, never aborted. Resets the session DiagList so the
# result reflects only this buffer's lex pass.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: the owning TokenStream, or an error when fid is unknown / on allocation failure
pub fun tokenize(es: *EditorSession, fid: source.FileId) R.Result[lexer.TokenStream, str] {
    diags_reset(es);
    ret tokenize_inner(es, fid);
}

# tokenize and parse an open buffer best-effort, returning its Ast
#
# Lex and parse errors land on the session DiagList; the AST is a usable partial
# tree even for a broken buffer. The returned Ast is owned by the editor and
# cached for this buffer; repeated calls reparse and replace it.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the buffer's parsed Ast, or an error when fid is unknown / on allocation failure
pub fun parse(es: *EditorSession, fid: source.FileId) R.Result[*ast.Ast, str] {
    diags_reset(es);
    ret parse_inner(es, fid);
}

# name-resolve an open buffer best-effort, returning its ResolveResult tables
#
# Parses first if needed. The buffer is resolved in isolation against an empty
# dependency set, so cross-module references resolve to SYMBOL_NIL while local
# names bind. Name errors land on the session DiagList. The returned
# ResolveResult is owned by the editor and cached.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the buffer's ResolveResult, or an error when fid is unknown / on allocation failure
pub fun resolve(es: *EditorSession, fid: source.FileId) R.Result[*res.ResolveResult, str] {
    diags_reset(es);

    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret R.err[*res.ResolveResult, str]("editor: buffer not open"); }

    if (b.a == nil) {
        val res_parse: R.Result[*ast.Ast, str] = parse_inner(es, fid);
        if (R.is_err[*ast.Ast, str](res_parse)) {
            ret R.err[*res.ResolveResult, str](R.unwrap_err[*ast.Ast, str](res_parse));
        }
    }

    var deps: res.ResolveDeps;
    deps.entries = nil;
    deps.count   = 0;
    ret buffer_resolve(es, b, ?deps);
}

# analyze an open buffer and return the session DiagList of reported diagnostics
#
# Runs tokenize -> emit-lex-errors -> parse, so the list reflects the buffer's
# syntactic diagnostics. The DiagList is borrowed from the session and reset on
# entry so the result reflects only this buffer's current analysis.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the session DiagList, or an error when fid is unknown / on allocation failure
pub fun diagnostics(es: *EditorSession, fid: source.FileId) R.Result[*diagnostic.DiagList, str] {
    diags_reset(es);

    val res_parse: R.Result[*ast.Ast, str] = parse_inner(es, fid);
    if (R.is_err[*ast.Ast, str](res_parse)) {
        ret R.err[*diagnostic.DiagList, str](R.unwrap_err[*ast.Ast, str](res_parse));
    }
    ret R.ok[*diagnostic.DiagList, str](?es.s.diags);
}

# the buffer's cached parsed Ast, or nil when it has not been parsed
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the cached Ast, or nil
pub fun ast_of(es: *EditorSession, fid: source.FileId) *ast.Ast {
    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret nil; }
    ret b.a;
}

# the buffer's cached ResolveResult, or nil when it has not been resolved
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the cached ResolveResult, or nil
pub fun resolve_of(es: *EditorSession, fid: source.FileId) *res.ResolveResult {
    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret nil; }
    ret b.rr;
}

# parse, resolve, and run full semantic analysis over one open buffer in
# isolation, caching and returning its SemaResult expression-type side tables
#
# Opt-in: the cheap `resolve` path never runs sema, so a non-type-aware consumer
# pays nothing. An editor that needs an expression's resolved type calls this
# once, then maps a cursor `ExprId` / `DeclId` to its `TypeId` with `expr_type_of`
# / `decl_type_of` and walks the session type interner's field tables
# (`type.field_table_for`) for member completion and value go-to-def. The buffer
# is analysed against an empty dependency set, mirroring `resolve`, so
# cross-module references type as TYPE_ERROR while local expressions type fully.
#
# The cached SemaResult is owned by the editor and invalidated whenever the
# buffer is reparsed, updated, or re-resolved (it is derived from the
# ResolveResult). Diagnostics accumulate on the session DiagList, reset by the
# resolve on entry.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the buffer's cached SemaResult, or an error
pub fun analyze(es: *EditorSession, fid: source.FileId) R.Result[*context.SemaResult, str] {
    val res_resolve: R.Result[*res.ResolveResult, str] = resolve(es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve)) {
        ret R.err[*context.SemaResult, str](R.unwrap_err[*res.ResolveResult, str](res_resolve));
    }
    val rr: *res.ResolveResult = R.unwrap_ok[*res.ResolveResult, str](res_resolve);

    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret R.err[*context.SemaResult, str]("editor: buffer not open"); }

    # sema's generic machinery reads a declaration's origin AST through the
    # session registry, so the buffer's own module must be registered first.
    val res_register: R.Result[bool, str] = session.register_module_ast(es.s, fid::session.ModuleId, b.a);
    if (R.is_err[bool, str](res_register)) {
        ret R.err[*context.SemaResult, str](R.unwrap_err[bool, str](res_register));
    }

    var deps: context.SemaDeps;
    deps.entries = nil;
    deps.count   = 0;

    val res_sema: R.Result[context.SemaResult, str] = sema.sema(es.s, b.a, rr, ?deps, ?b.ctx, fid::session.ModuleId);
    if (R.is_err[context.SemaResult, str](res_sema)) {
        ret R.err[*context.SemaResult, str](R.unwrap_err[context.SemaResult, str](res_sema));
    }

    # the resolve above already invalidated any prior SemaResult via rr_drop, so
    # b.sr is nil here; heap the fresh result and cache it.
    val sr_slot: R.Result[*context.SemaResult, str] = A.allocate[context.SemaResult](es.alloc, 1);
    if (R.is_err[*context.SemaResult, str](sr_slot)) {
        var sr_owned: context.SemaResult = R.unwrap_ok[context.SemaResult, str](res_sema);
        sema.dnit_result(?sr_owned);
        ret sr_slot;
    }
    val sr: *context.SemaResult = R.unwrap_ok[*context.SemaResult, str](sr_slot);
    @sr = R.unwrap_ok[context.SemaResult, str](res_sema);
    b.sr = sr;
    ret R.ok[*context.SemaResult, str](sr);
}

# the buffer's cached SemaResult, or nil when it has not been analyzed
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the cached SemaResult, or nil
pub fun sema_of(es: *EditorSession, fid: source.FileId) *context.SemaResult {
    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret nil; }
    ret b.sr;
}

# the semantic type inferred for an expression in an analyzed buffer
#
# Maps an `ExprId` (e.g. from `ast.offset_to_expr` at the cursor) to its `TypeId`,
# the bridge an editor walks to the type interner's field tables for member
# completion and value go-to-def. Yields TYPE_NIL for the nil id and TYPE_ERROR
# when the buffer is unanalyzed or the id is out of range.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# eid: the expression id to type
# ret: the expression's semantic TypeId, TYPE_NIL, or TYPE_ERROR
pub fun expr_type_of(es: *EditorSession, fid: source.FileId, eid: id.ExprId) type.TypeId {
    if (eid == id.EXPR_NIL) { ret type.TYPE_NIL; }
    val b: *Buffer = slot_live(es, fid);
    if (b == nil || b.sr == nil || b.sr.expr_type == nil) { ret type.TYPE_ERROR; }
    if (eid >= b.sr.expr_count) { ret type.TYPE_ERROR; }
    ret b.sr.expr_type[eid];
}

# the declared (or inferred) type of a binding declaration in an analyzed buffer
#
# Maps a `DeclId` (e.g. from `ast.offset_to_decl`) to its `TypeId`. Yields
# TYPE_NIL for the nil id and TYPE_ERROR when the buffer is unanalyzed or the id
# is out of range.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# did: the declaration id to type
# ret: the declaration's semantic TypeId, TYPE_NIL, or TYPE_ERROR
pub fun decl_type_of(es: *EditorSession, fid: source.FileId, did: id.DeclId) type.TypeId {
    if (did == id.DECL_NIL) { ret type.TYPE_NIL; }
    val b: *Buffer = slot_live(es, fid);
    if (b == nil || b.sr == nil || b.sr.decl_type == nil) { ret type.TYPE_ERROR; }
    if (did >= b.sr.decl_count) { ret type.TYPE_ERROR; }
    ret b.sr.decl_type[did];
}

# the interned semantic type a syntactic AstType resolved to in an analyzed buffer
#
# Maps a syntactic `ast.id.TypeId` (e.g. from `ast.offset_to_type`) to the
# semantic `TypeId` sema resolved it to. Yields TYPE_NIL for the nil id and
# TYPE_ERROR when the buffer is unanalyzed or the id is out of range.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# tid: the syntactic AstType id to resolve
# ret: the resolved semantic TypeId, TYPE_NIL, or TYPE_ERROR
pub fun resolved_type_of(es: *EditorSession, fid: source.FileId, tid: id.TypeId) type.TypeId {
    if (tid == id.TYPE_NIL) { ret type.TYPE_NIL; }
    val b: *Buffer = slot_live(es, fid);
    if (b == nil || b.sr == nil || b.sr.type_resolved_ty == nil) { ret type.TYPE_ERROR; }
    if (tid >= b.sr.type_count) { ret type.TYPE_ERROR; }
    ret b.sr.type_resolved_ty[tid];
}

# replace the borrowed session DiagList with a fresh empty one
#
# The single owner of the editor's diagnostic-reset policy: every public
# analysis entry resets on the way in, and the `*_inner` workers never touch the
# lifecycle, so repeated calls cannot accumulate duplicates.
# ---
# es: the editor session
fun diags_reset(es: *EditorSession) {
    diagnostic.dnit(?es.s.diags);
    es.s.diags = diagnostic.init(es.alloc);
}

# the lex pass without the diagnostic reset, shared by `tokenize` and `parse_inner`
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: the owning TokenStream, or an error when fid is unknown / on allocation failure
fun tokenize_inner(es: *EditorSession, fid: source.FileId) R.Result[lexer.TokenStream, str] {
    val opt_file: O.Option[*source.SourceFile] = source.get(?es.s.sources, fid);
    if (O.is_none[*source.SourceFile](opt_file)) {
        ret R.err[lexer.TokenStream, str]("editor: buffer not open");
    }
    val file: *source.SourceFile = O.unwrap[*source.SourceFile](opt_file);

    val res_tokens: R.Result[lexer.TokenStream, str] = lexer.tokenize(file.text, es.alloc, fid);
    if (R.is_err[lexer.TokenStream, str](res_tokens)) { ret res_tokens; }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](res_tokens);

    val res_emit: R.Result[bool, str] = lexer.emit_diagnostics(?stream, ?es.s.diags);
    if (R.is_err[bool, str](res_emit)) {
        lexer.dnit(?stream, es.alloc);
        ret R.err[lexer.TokenStream, str](R.unwrap_err[bool, str](res_emit));
    }
    ret R.ok[lexer.TokenStream, str](stream);
}

# the tokenize + parse pass without the diagnostic reset, shared by the public
# `parse`, `resolve`, and `diagnostics` entries
# ---
# es:  the editor session
# fid: FileId of an open buffer
# ret: a borrowed pointer to the buffer's parsed Ast, or an error
fun parse_inner(es: *EditorSession, fid: source.FileId) R.Result[*ast.Ast, str] {
    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret R.err[*ast.Ast, str]("editor: buffer not open"); }

    val res_tokens: R.Result[lexer.TokenStream, str] = tokenize_inner(es, fid);
    if (R.is_err[lexer.TokenStream, str](res_tokens)) {
        ret R.err[*ast.Ast, str](R.unwrap_err[lexer.TokenStream, str](res_tokens));
    }
    var stream: lexer.TokenStream = R.unwrap_ok[lexer.TokenStream, str](res_tokens);

    analysis_drop(es, b);

    val res_ast: R.Result[*ast.Ast, str] = ast_alloc(es, fid);
    if (R.is_err[*ast.Ast, str](res_ast)) {
        lexer.dnit(?stream, es.alloc);
        ret res_ast;
    }
    val a: *ast.Ast = R.unwrap_ok[*ast.Ast, str](res_ast);

    parser.parse(?stream, a, ?es.s.diags);
    lexer.dnit(?stream, es.alloc);

    b.a = a;
    ret R.ok[*ast.Ast, str](a);
}

# re-resolve a parsed buffer against `deps`, replacing its cached ResolveResult,
# and return a borrowed pointer to the new side tables
#
# The comptime context is reseeded from the host target first. The buffer must
# already hold a parsed Ast. Shared by the public `resolve` (empty deps) and the
# test-only `t_resolve_deps` (explicit deps).
# ---
# es:   the editor session
# b:    the buffer to resolve; its `a` must be non-nil
# deps: the dependency set to resolve against
# ret:  a borrowed pointer to the cached ResolveResult, or an error
fun buffer_resolve(es: *EditorSession, b: *Buffer, deps: *res.ResolveDeps) R.Result[*res.ResolveResult, str] {
    rr_drop(es, b);
    ctx_seed(es, b);

    val res_resolve: R.Result[res.ResolveResult, str] = res.resolve(es.s, b.a, deps, ?b.ctx, b.file_id::session.ModuleId);
    if (R.is_err[res.ResolveResult, str](res_resolve)) {
        ret R.err[*res.ResolveResult, str](R.unwrap_err[res.ResolveResult, str](res_resolve));
    }

    val res_slot: R.Result[*res.ResolveResult, str] = A.allocate[res.ResolveResult](es.alloc, 1);
    if (R.is_err[*res.ResolveResult, str](res_slot)) {
        var rr_owned: res.ResolveResult = R.unwrap_ok[res.ResolveResult, str](res_resolve);
        res.dnit_result(?rr_owned);
        ret res_slot;
    }
    val rr: *res.ResolveResult = R.unwrap_ok[*res.ResolveResult, str](res_slot);
    @rr = R.unwrap_ok[res.ResolveResult, str](res_resolve);
    b.rr = rr;
    ret R.ok[*res.ResolveResult, str](rr);
}

# the Buffer slot for a FileId, or nil when the id is out of the registry's range
# ---
# es:  the editor session
# fid: candidate FileId
# ret: a borrowed pointer to the slot, or nil
fun slot_get(es: *EditorSession, fid: source.FileId) *Buffer {
    if (es.buffers == nil || fid::u32 >= es.buf_len) { ret nil; }
    ret ?es.buffers[fid::u32];
}

# the live Buffer for a FileId, or nil when the id is out of range or its slot is free
# ---
# es:  the editor session
# fid: candidate FileId
# ret: a borrowed pointer to the open buffer, or nil
fun slot_live(es: *EditorSession, fid: source.FileId) *Buffer {
    val b: *Buffer = slot_get(es, fid);
    if (b == nil || !b.in_use) { ret nil; }
    ret b;
}

# grow the registry to cover `fid`, mark its slot in use, and return it
#
# New slots between the old length and `fid` are left free, each holding a
# dnit-safe host-seeded comptime context. Reopening a live slot drops its prior
# analysis first.
# ---
# es:  the editor session
# fid: FileId to reserve a slot for
# ret: a borrowed pointer to the now-live slot, or an allocation error
fun slot_ensure(es: *EditorSession, fid: source.FileId) R.Result[*Buffer, str] {
    val needed: u32 = fid::u32 + 1;
    if (needed > es.buf_len) {
        var new_len: u32 = es.buf_len;
        if (new_len == 0) { new_len = BUFFERS_SEED; }
        for (new_len < needed) { new_len = new_len * 2; }

        if (es.buffers == nil) {
            val res_alloc: R.Result[*Buffer, str] = A.allocate[Buffer](es.alloc, new_len::usize);
            if (R.is_err[*Buffer, str](res_alloc)) { ret res_alloc; }
            es.buffers = R.unwrap_ok[*Buffer, str](res_alloc);
        }
        or {
            val res_realloc: R.Result[*Buffer, str] = A.reallocate[Buffer](es.alloc, es.buffers, es.buf_len::usize, new_len::usize);
            if (R.is_err[*Buffer, str](res_realloc)) { ret res_realloc; }
            es.buffers = R.unwrap_ok[*Buffer, str](res_realloc);
        }

        var i: u32 = es.buf_len;
        for (i < new_len) {
            val nb: *Buffer = ?es.buffers[i];
            nb.file_id = i::source.FileId;
            nb.in_use  = false;
            nb.a       = nil;
            nb.rr      = nil;
            nb.sr      = nil;
            nb.ctx     = host_ctx(es);
            i = i + 1;
        }
        es.buf_len = new_len;
    }

    val b: *Buffer = ?es.buffers[fid::u32];
    if (b.in_use) {
        analysis_drop(es, b);
    }
    b.file_id = fid;
    b.in_use  = true;
    ret R.ok[*Buffer, str](b);
}

# heap a fresh empty Ast for the buffer so the editor can hand back a stable
# pointer and free it on teardown
# ---
# es:  the editor session
# fid: FileId the Ast is parsed under
# ret: a borrowed pointer to the new Ast, or an allocation error
fun ast_alloc(es: *EditorSession, fid: source.FileId) R.Result[*ast.Ast, str] {
    val res_alloc: R.Result[*ast.Ast, str] = A.allocate[ast.Ast](es.alloc, 1);
    if (R.is_err[*ast.Ast, str](res_alloc)) { ret res_alloc; }
    val a: *ast.Ast = R.unwrap_ok[*ast.Ast, str](res_alloc);
    @a = ast.init(es.alloc, fid);
    ret R.ok[*ast.Ast, str](a);
}

# a fresh comptime context seeded from the host target
#
# The os, arch, abi, and pointer width this compiler binary was built for. The
# editor resolves a buffer with no project-selected target, so `$if` predicates
# evaluate against the running compiler rather than an unknown placeholder.
# ---
# es:  the editor session
# ret: a host-seeded ComptimeCtx
fun host_ctx(es: *EditorSession) comptime.ComptimeCtx {
    ret comptime.init(
        es.alloc,
        target.host_os_id(),
        target.host_arch_id(),
        target.host_abi_id(),
        comptime.MODE_DEBUG,
        0,
        target.host_pointer_width(),
        intern.STR_NIL,
        intern.STR_NIL
    );
}

# reseed a buffer's comptime context from the host target, dnit-ing any prior one
# ---
# es: the editor session
# b:  the buffer whose context is reset
fun ctx_seed(es: *EditorSession, b: *Buffer) {
    comptime.dnit(?b.ctx);
    b.ctx = host_ctx(es);
}

# free a buffer's cached SemaResult and nil the field
# ---
# es: the editor session
# b:  the buffer whose SemaResult is released
fun sema_drop(es: *EditorSession, b: *Buffer) {
    if (b.sr == nil) { ret; }
    sema.dnit_result(b.sr);
    A.deallocate[context.SemaResult](es.alloc, b.sr, 1);
    b.sr = nil;
}

# free a buffer's cached ResolveResult and the SemaResult derived from it, niling
# both fields
#
# The SemaResult's expression-type tables are computed atop the ResolveResult, so
# any path that replaces `rr` (a re-resolve, a reparse) must invalidate `sr` too.
# ---
# es: the editor session
# b:  the buffer whose ResolveResult is released
fun rr_drop(es: *EditorSession, b: *Buffer) {
    sema_drop(es, b);
    if (b.rr == nil) { ret; }
    res.dnit_result(b.rr);
    A.deallocate[res.ResolveResult](es.alloc, b.rr, 1);
    b.rr = nil;
}

# free a buffer's cached Ast, ResolveResult, and comptime context, leaving the
# slot in use with empty analysis
# ---
# es: the editor session
# b:  the buffer whose analysis is released
fun analysis_drop(es: *EditorSession, b: *Buffer) {
    rr_drop(es, b);
    if (b.a != nil) {
        ast.dnit(b.a);
        A.deallocate[ast.Ast](es.alloc, b.a, 1);
        b.a = nil;
    }
    comptime.dnit(?b.ctx);
}

# fully release a registry slot, including its analysis, marking it free
# ---
# es: the editor session
# b:  the buffer slot to release
fun buffer_free(es: *EditorSession, b: *Buffer) {
    if (!b.in_use) { ret; }
    analysis_drop(es, b);
    b.in_use = false;
}

# build a Session over a page allocator for the editor tests
# ---
# a:   uninitialized allocator to back the session
# ret: an initialized Session, or an allocation error
fun t_session(a: *A.Allocator) R.Result[session.Session, str] {
    page.make(a);
    ret session.init(a);
}

# true when any diagnostic on `list` has a message containing `sub`
# ---
# list: the diagnostic list to scan
# sub:  substring to search each message for
# ret:  true on the first match, false when none match
fun diag_has(list: *diagnostic.DiagList, sub: str) bool {
    var i: usize = 0;
    for (i < list.len) {
        if (str_contains(list.items[i].message, sub)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# true when any diagnostic on `list` carries a note containing `sub`
# ---
# list: the diagnostic list to scan
# sub:  substring to search each note for
# ret:  true on the first match, false when none match
fun diag_note_has(list: *diagnostic.DiagList, sub: str) bool {
    var i: usize = 0;
    for (i < list.len) {
        if (list.items[i].note != nil && str_contains(list.items[i].note, sub)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# true when any diagnostic on `list` carries a help line containing `sub`
# ---
# list: the diagnostic list to scan
# sub:  substring to search each help line for
# ret:  true on the first match, false when none match
fun diag_help_has(list: *diagnostic.DiagList, sub: str) bool {
    var i: usize = 0;
    for (i < list.len) {
        if (list.items[i].help != nil && str_contains(list.items[i].help, sub)) { ret true; }
        i = i + 1;
    }
    ret false;
}

# true when any diagnostic on `list` carries a secondary location whose label
# contains `sub`
# ---
# list: the diagnostic list to scan
# sub:  substring to search each secondary-location label for
# ret:  true on the first match, false when none match
fun diag_related_has(list: *diagnostic.DiagList, sub: str) bool {
    var i: usize = 0;
    for (i < list.len) {
        var r: usize = 0;
        for (r < list.items[i].related_len) {
            val rel: *diagnostic.Related = ?list.items[i].related[r];
            if (rel.label != nil && str_contains(rel.label, sub)) { ret true; }
            r = r + 1;
        }
        i = i + 1;
    }
    ret false;
}

# the number of diagnostics on `list` whose message contains `sub`
# ---
# list: the diagnostic list to scan
# sub:  substring to match against each message
# ret:  the count of matching diagnostics
fun diag_count(list: *diagnostic.DiagList, sub: str) u32 {
    var hits: u32   = 0;
    var i:    usize = 0;
    for (i < list.len) {
        if (str_contains(list.items[i].message, sub)) { hits = hits + 1; }
        i = i + 1;
    }
    ret hits;
}

# parse, resolve, and run full semantic analysis over one open buffer in
# isolation, with the comptime pointer width forced to `pw`
#
# Every diagnostic lands on the session DiagList, which is reset before sema runs
# and returned. Test-only: drives the front-end the way the build does for a
# single self-contained module.
# ---
# es:  the editor session
# fid: FileId of an open buffer
# pw:  pointer width to force on the buffer's comptime context
# ret: a borrowed pointer to the session DiagList, or an error
fun t_run_sema(es: *EditorSession, fid: source.FileId, pw: u32) R.Result[*diagnostic.DiagList, str] {
    val res_resolve: R.Result[*res.ResolveResult, str] = resolve(es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve)) {
        ret R.err[*diagnostic.DiagList, str](R.unwrap_err[*res.ResolveResult, str](res_resolve));
    }
    val rr: *res.ResolveResult = R.unwrap_ok[*res.ResolveResult, str](res_resolve);

    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret R.err[*diagnostic.DiagList, str]("editor: buffer not open"); }
    b.ctx.pointer_width = pw;

    # sema's generic machinery reads a declaration's origin AST through the
    # session registry, so the buffer's own module must be registered first.
    val res_register: R.Result[bool, str] = session.register_module_ast(es.s, fid::session.ModuleId, b.a);
    if (R.is_err[bool, str](res_register)) {
        ret R.err[*diagnostic.DiagList, str](R.unwrap_err[bool, str](res_register));
    }

    diags_reset(es);

    var deps: context.SemaDeps;
    deps.entries = nil;
    deps.count   = 0;

    val res_sema: R.Result[context.SemaResult, str] = sema.sema(es.s, b.a, rr, ?deps, ?b.ctx, fid::session.ModuleId);
    if (R.is_err[context.SemaResult, str](res_sema)) {
        ret R.err[*diagnostic.DiagList, str](R.unwrap_err[context.SemaResult, str](res_sema));
    }
    var sema_result: context.SemaResult = R.unwrap_ok[context.SemaResult, str](res_sema);
    sema.dnit_result(?sema_result);

    ret R.ok[*diagnostic.DiagList, str](?es.s.diags);
}

# name-resolve an open buffer against an explicit dependency set, caching and
# returning the ResolveResult
#
# Test-only, for cross-module scenarios; the editor's own `resolve` always uses
# an empty dependency set.
# ---
# es:   the editor session
# fid:  FileId of an open buffer
# deps: the dependency set to resolve against
# ret:  a borrowed pointer to the cached ResolveResult, or an error
fun t_resolve_deps(es: *EditorSession, fid: source.FileId, deps: *res.ResolveDeps) R.Result[*res.ResolveResult, str] {
    val b: *Buffer = slot_live(es, fid);
    if (b == nil) { ret R.err[*res.ResolveResult, str]("editor: buffer not open"); }
    if (b.a == nil) {
        val res_parse: R.Result[*ast.Ast, str] = parse(es, fid);
        if (R.is_err[*ast.Ast, str](res_parse)) {
            ret R.err[*res.ResolveResult, str](R.unwrap_err[*ast.Ast, str](res_parse));
        }
    }
    ret buffer_resolve(es, b, deps);
}

# snapshot an already-resolved buffer's pub surface as a ModuleExports keyed by
# `fqn`, mirroring the driver's build_module_exports
#
# Test-only; the returned `symbols` array is owned by the caller.
# ---
# es:  the editor session
# fid: FileId of a resolved buffer
# fqn: fully-qualified module name to key the exports under
# ret: the ModuleExports snapshot, or an error
fun t_exports(es: *EditorSession, fid: source.FileId, fqn: str) R.Result[res.ModuleExports, str] {
    val b: *Buffer = slot_get(es, fid);
    if (b == nil || b.rr == nil) { ret R.err[res.ModuleExports, str]("editor: buffer not resolved"); }

    val res_fqn: R.Result[intern.StrId, str] = intern.intern(?es.s.interner, fqn);
    if (R.is_err[intern.StrId, str](res_fqn)) {
        ret R.err[res.ModuleExports, str](R.unwrap_err[intern.StrId, str](res_fqn));
    }

    var mx: res.ModuleExports;
    mx.path    = R.unwrap_ok[intern.StrId, str](res_fqn);
    mx.module  = fid::session.ModuleId;
    mx.symbols = nil;
    mx.count   = 0;

    val pub_len: u32 = b.rr.pub_count;
    if (pub_len == 0) { ret R.ok[res.ModuleExports, str](mx); }

    val res_syms: R.Result[*res.PublicSymbol, str] = A.allocate[res.PublicSymbol](es.alloc, pub_len::usize);
    if (R.is_err[*res.PublicSymbol, str](res_syms)) {
        ret R.err[res.ModuleExports, str](R.unwrap_err[*res.PublicSymbol, str](res_syms));
    }
    val syms: *res.PublicSymbol = R.unwrap_ok[*res.PublicSymbol, str](res_syms);

    var i: u32 = 0;
    for (i < pub_len) {
        val sym: *res.Symbol = ?b.rr.symbols[i];
        var ps: res.PublicSymbol;
        ps.kind   = sym.kind;
        ps.name   = sym.name;
        ps.decl   = sym.decl;
        ps.slot   = sym.slot;
        ps.origin = sym.origin;
        syms[i] = ps;
        i = i + 1;
    }
    mx.symbols = syms;
    mx.count   = pub_len;
    ret R.ok[res.ModuleExports, str](mx);
}

# a clean single-file buffer parses to a non-empty AST and reports no diagnostics
test "mach.lang.editor.parse:clean_buffer" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    val res_fid: R.Result[source.FileId, str] = open(?es, "buf.mach", "fun f(a: i64) i64 { ret a; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_ast: R.Result[*ast.Ast, str] = parse(?es, fid);
    if (R.is_err[*ast.Ast, str](res_ast)) { dnit(?es); session.dnit(?s); ret 1; }
    val a: *ast.Ast = R.unwrap_ok[*ast.Ast, str](res_ast);
    if (a.decl_len == 0) { dnit(?es); session.dnit(?s); ret 1; }

    val res_diags: R.Result[*diagnostic.DiagList, str] = diagnostics(?es, fid);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                           { dnit(?es); session.dnit(?s); ret 1; }
    if (diagnostic.has_errors(R.unwrap_ok[*diagnostic.DiagList, str](res_diags))) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a broken buffer yields a partial AST plus diagnostics and never bails
test "mach.lang.editor.diagnostics:partial_on_broken_buffer" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # a missing ')' plus a stray backtick: the parser recovers and the lexer
    # records the bad char, so we expect both error diagnostics AND a usable
    # partial AST that still contains the broken function decl.
    val res_fid: R.Result[source.FileId, str] = open(?es, "broken.mach", "fun g(a: i64 { ret a ` ; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = diagnostics(?es, fid);
    if (R.is_err[*diagnostic.DiagList, str](res_diags)) { dnit(?es); session.dnit(?s); ret 1; }
    val list: *diagnostic.DiagList = R.unwrap_ok[*diagnostic.DiagList, str](res_diags);
    if (!diagnostic.has_errors(list)) { dnit(?es); session.dnit(?s); ret 1; }

    val a: *ast.Ast = ast_of(?es, fid);
    if (a == nil)        { dnit(?es); session.dnit(?s); ret 1; }
    if (a.decl_len == 0) { dnit(?es); session.dnit(?s); ret 1; }

    # offset 2 falls on the `fun g` declaration; the partial tree still answers an
    # offset -> id query.
    if (ast.offset_to_decl(a, 2) == id.DECL_NIL) { dnit(?es); session.dnit(?s); ret 1; }

    # resolve still produces usable side tables over the broken buffer.
    val res_resolve: R.Result[*res.ResolveResult, str] = resolve(?es, fid);
    if (R.is_err[*res.ResolveResult, str](res_resolve)) { dnit(?es); session.dnit(?s); ret 1; }
    val rrp: *res.ResolveResult = R.unwrap_ok[*res.ResolveResult, str](res_resolve);
    if (rrp.decl_count != a.decl_len::u32) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# update drops cached analysis and reparses against the new text
test "mach.lang.editor.update:drops_cached_analysis" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    val res_fid: R.Result[source.FileId, str] = open(?es, "buf.mach", "fun a() {}\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_parse_1: R.Result[*ast.Ast, str] = parse(?es, fid);
    if (R.is_err[*ast.Ast, str](res_parse_1)) { dnit(?es); session.dnit(?s); ret 1; }
    val decls_1: usize = R.unwrap_ok[*ast.Ast, str](res_parse_1).decl_len;

    val res_update: R.Result[bool, str] = update(?es, fid, "fun a() {}\nfun b() {}\n");
    if (R.is_err[bool, str](res_update))     { dnit(?es); session.dnit(?s); ret 1; }
    if (!R.unwrap_ok[bool, str](res_update)) { dnit(?es); session.dnit(?s); ret 1; }
    # the cached AST is dropped on update.
    if (ast_of(?es, fid) != nil) { dnit(?es); session.dnit(?s); ret 1; }

    val res_parse_2: R.Result[*ast.Ast, str] = parse(?es, fid);
    if (R.is_err[*ast.Ast, str](res_parse_2))                        { dnit(?es); session.dnit(?s); ret 1; }
    if (R.unwrap_ok[*ast.Ast, str](res_parse_2).decl_len <= decls_1) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a re-exported module alias resolves through to a downstream consumer (#1248)
test "mach.lang.editor.resolve:reexported_module_alias" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # inner exports a type `Thing`; surface re-exports the inner module as alias
    # `al`; consumer imports `t.surface.al` and names `al.Thing` in type
    # position. before the fix the surface's SYM_USE slot was dropped through the
    # export pipeline, so the consumer imported `al` as a plain symbol and the
    # type path reported `expected a module alias before .`.
    val res_inner: R.Result[source.FileId, str] = open(?es, "inner.mach", "pub rec Thing { x: i64; }\n");
    if (R.is_err[source.FileId, str](res_inner)) { dnit(?es); session.dnit(?s); ret 1; }
    val inner: source.FileId = R.unwrap_ok[source.FileId, str](res_inner);

    var empty: res.ResolveDeps;
    empty.entries = nil;
    empty.count   = 0;
    if (R.is_err[*res.ResolveResult, str](t_resolve_deps(?es, inner, ?empty))) { dnit(?es); session.dnit(?s); ret 1; }
    val res_ex_inner: R.Result[res.ModuleExports, str] = t_exports(?es, inner, "t.inner");
    if (R.is_err[res.ModuleExports, str](res_ex_inner)) { dnit(?es); session.dnit(?s); ret 1; }
    var ex_inner: res.ModuleExports = R.unwrap_ok[res.ModuleExports, str](res_ex_inner);

    val res_surface: R.Result[source.FileId, str] = open(?es, "surface.mach", "fwd al: t.inner;\n");
    if (R.is_err[source.FileId, str](res_surface)) { dnit(?es); session.dnit(?s); ret 1; }
    val surface: source.FileId = R.unwrap_ok[source.FileId, str](res_surface);

    var sdeps: res.ResolveDeps;
    sdeps.entries = ?ex_inner;
    sdeps.count   = 1;
    if (R.is_err[*res.ResolveResult, str](t_resolve_deps(?es, surface, ?sdeps))) { dnit(?es); session.dnit(?s); ret 1; }
    val res_ex_surface: R.Result[res.ModuleExports, str] = t_exports(?es, surface, "t.surface");
    if (R.is_err[res.ModuleExports, str](res_ex_surface)) { dnit(?es); session.dnit(?s); ret 1; }
    var ex_surface: res.ModuleExports = R.unwrap_ok[res.ModuleExports, str](res_ex_surface);

    val res_consumer: R.Result[source.FileId, str] = open(?es, "consumer.mach",
        "use al: t.surface.al;\nfun take(p: al.Thing) i64 { ret p.x; }\n");
    if (R.is_err[source.FileId, str](res_consumer)) { dnit(?es); session.dnit(?s); ret 1; }
    val consumer: source.FileId = R.unwrap_ok[source.FileId, str](res_consumer);

    var cdeps_arr: [2]res.ModuleExports;
    cdeps_arr[0] = ex_surface;
    cdeps_arr[1] = ex_inner;
    var cdeps: res.ResolveDeps;
    cdeps.entries = ?cdeps_arr[0];
    cdeps.count   = 2;

    diags_reset(?es);
    if (R.is_err[*res.ResolveResult, str](t_resolve_deps(?es, consumer, ?cdeps))) { dnit(?es); session.dnit(?s); ret 1; }

    val is_clean: bool = !diagnostic.has_errors(?es.s.diags);
    A.deallocate[res.PublicSymbol](es.alloc, ex_inner.symbols, ex_inner.count::usize);
    A.deallocate[res.PublicSymbol](es.alloc, ex_surface.symbols, ex_surface.count::usize);
    if (!is_clean) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# the retained SemaResult bridges a cursor ExprId to its TypeId and the type
# interner's field tables, and is invalidated when the buffer changes (#1501)
test "mach.lang.editor.analyze:expr_type_bridges_to_field_table" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    val src: str = "rec P { x: i64; y: i64; }\nfun f(p: P) i64 { ret p.x; }\n";
    val res_fid: R.Result[source.FileId, str] = open(?es, "p.mach", src);
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_an: R.Result[*context.SemaResult, str] = analyze(?es, fid);
    if (R.is_err[*context.SemaResult, str](res_an)) { dnit(?es); session.dnit(?s); ret 1; }

    val a: *ast.Ast = ast_of(?es, fid);
    if (a == nil) { dnit(?es); session.dnit(?s); ret 1; }

    # locate the receiver `p` and the member `x` in `ret p.x` by source offset
    val res_idx: R.Result[usize, str] = str_index_of(src, "p.x");
    if (R.is_err[usize, str](res_idx)) { dnit(?es); session.dnit(?s); ret 1; }
    val off_p: usize = R.unwrap_ok[usize, str](res_idx);

    # the receiver ident `p` types as the nominal `P`
    val eid_p: id.ExprId = ast.offset_to_expr(a, off_p);
    if (eid_p == id.EXPR_NIL) { dnit(?es); session.dnit(?s); ret 1; }
    val ty_p: type.TypeId = expr_type_of(?es, fid, eid_p);
    if (ty_p == type.TYPE_ERROR || ty_p == type.TYPE_NIL) { dnit(?es); session.dnit(?s); ret 1; }

    # P carries a two-field table the editor enumerates for member completion
    if (O.is_none[*type.FieldTable](type.field_table_for(?s.types, ty_p))) { dnit(?es); session.dnit(?s); ret 1; }
    if (type.field_count(?s.types, ty_p) != 2)                             { dnit(?es); session.dnit(?s); ret 1; }

    # field `x` and the member access `p.x` both type as i64
    val i64_opt: O.Option[type.TypeId] = type.prim(?s.types, type.TYPE_I64);
    if (O.is_none[type.TypeId](i64_opt)) { dnit(?es); session.dnit(?s); ret 1; }
    val i64_id: type.TypeId = O.unwrap[type.TypeId](i64_opt);

    val f0_opt: O.Option[*type.FieldEntry] = type.field_at(?s.types, ty_p, 0);
    if (O.is_none[*type.FieldEntry](f0_opt)) { dnit(?es); session.dnit(?s); ret 1; }
    val f0: *type.FieldEntry = O.unwrap[*type.FieldEntry](f0_opt);
    if (f0.ty != i64_id) { dnit(?es); session.dnit(?s); ret 1; }

    val eid_px: id.ExprId = ast.offset_to_expr(a, off_p + 2);
    if (eid_px == id.EXPR_NIL)                  { dnit(?es); session.dnit(?s); ret 1; }
    if (expr_type_of(?es, fid, eid_px) != i64_id) { dnit(?es); session.dnit(?s); ret 1; }

    # editing the buffer drops the cached SemaResult (it derives from the resolve)
    val res_up: R.Result[bool, str] = update(?es, fid, "fun g() i64 { ret 0; }\n");
    if (R.is_err[bool, str](res_up)) { dnit(?es); session.dnit(?s); ret 1; }
    if (sema_of(?es, fid) != nil)    { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a generic parameter nested two anonymous-aggregate levels deep is substituted (#1248)
test "mach.lang.editor.sema:nested_generic_param_substituted" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    val res_fid: R.Result[source.FileId, str] = open(?es, "box.mach",
        "rec Box[T] { outer: rec { inner: rec { v: T; }; }; }\nfun main() i64 { var b: Box[u32]; b.outer.inner.v = 5; ret 0; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags)) { dnit(?es); session.dnit(?s); ret 1; }
    # before the fix the placeholder T leaked into Box[u32], so the concrete
    # assignment reported `expected T, found i64`. it must now type clean.
    if (diagnostic.has_errors(R.unwrap_ok[*diagnostic.DiagList, str](res_diags))) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# an array length above the u32 range is rejected, not truncated (#1248)
test "mach.lang.editor.sema:array_length_overflow_rejected" {
    var alloc: A.Allocator;
    val res_session: R.Result[session.Session, str] = t_session(?alloc);
    if (R.is_err[session.Session, str](res_session)) { ret 1; }
    var s: session.Session = R.unwrap_ok[session.Session, str](res_session);
    var es: EditorSession = init(?s);

    # 0x100000001 truncates to 1 in u32; before the fix the array silently
    # interned as [1]u8 with no diagnostic. it must now be rejected outright.
    val res_fid: R.Result[source.FileId, str] = open(?es, "arr.mach",
        "fun main() i64 { var a: [0x100000001]u8; ret 0; }\n");
    if (R.is_err[source.FileId, str](res_fid)) { dnit(?es); session.dnit(?s); ret 1; }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_diags: R.Result[*diagnostic.DiagList, str] = t_run_sema(?es, fid, 8);
    if (R.is_err[*diagnostic.DiagList, str](res_diags))                                       { dnit(?es); session.dnit(?s); ret 1; }
    if (!diag_has(R.unwrap_ok[*diagnostic.DiagList, str](res_diags), "array length exceeds")) { dnit(?es); session.dnit(?s); ret 1; }

    dnit(?es);
    session.dnit(?s);
    ret 0;
}

# a module-scope unannotated val reports an initializer error exactly once (#1248)
test "mach.lang.editor.sema:unannotated_val_error_once" {
