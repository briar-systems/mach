# mach.lang.me.ir.id: index-handle types for the IR data model
#
# `BlockId` and `InstructionId` are `u32` handles into a `Function`'s block and
# instruction arrays, valid for that function's lifetime. This is the leaf of
# the `me.ir` data model: it depends on nothing else in `me.ir`, which lets both
# `value` and `instruction` name block and instruction handles without forming
# an import cycle (`value` operands name instructions; instructions live in
# blocks). `ir.mach` re-exports these so downstream code can spell them as
# `ir.BlockId` / `ir.InstructionId`.

# handle into a Function's block array
pub def BlockId:   u32;
# sentinel BlockId for the absence of a block; never a valid index
pub val BLOCK_NIL: BlockId = 0xFFFFFFFF;

# handle into a Function's instruction array
pub def InstructionId: u32;
# sentinel InstructionId for the absence of an instruction; never a valid index
pub val INSTR_NIL:     InstructionId = 0xFFFFFFFF;
