# mach.lang.me.ir.id: IR index-handle types.
#
# `BlockId` and `InstructionId` are `u32` handles into a `Function`'s block
# and instruction arrays. This is the leaf module
# of the IR data model: it depends on nothing else in `me.ir`, which lets
# both `value` and `instruction` reference instruction/block handles without
# forming an import cycle (`value` operands name instructions; instructions
# live in blocks). `ir.mach` re-exports these so downstream code can spell
# them as `ir.BlockId` / `ir.InstructionId`.

# handle into a `Function`'s block array; valid for that function's lifetime.
pub def BlockId: u32;

# handle into a `Function`'s instruction array; valid for that function's lifetime.
pub def InstructionId: u32;

# sentinel "no block"; never a valid index. NEVER treat as a default.
pub val BLOCK_NIL: BlockId = 0xFFFFFFFF;

# sentinel "no instruction"; never a valid index. NEVER treat as a default.
pub val INSTR_NIL: InstructionId = 0xFFFFFFFF;
