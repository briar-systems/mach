# mach.lang.me.ir.value: SSA values, the operands of every IR instruction
#
# A `Value` is a tagged reference, never a storage location. It either names a
# prior definition (an instruction result or a function parameter), a global or
# function symbol, or carries a compile-time constant inline. Every value records
# its IR type so consumers and the verifier can type-check operands without
# chasing def-use chains.
#
# Values are small and copied by value throughout the IR; the constructors below
# stamp out the common shapes. `is_constant` distinguishes the inline constant
# kinds from references for constant-folding and DCE.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;

use mach.lang.intern;
use mach.lang.me.ir.id;
use ir_type: mach.lang.me.ir.type;

# discriminator for Value.data
pub def ValueKind: u8;

# result of an instruction; `data.instr` names the defining InstructionId
pub val VAL_INSTR:       ValueKind = 0;
# a function parameter; `data.param_ix` is the zero-based parameter index
pub val VAL_PARAM:       ValueKind = 1;
# an inline integer constant; `data.int_lit` holds the bit pattern
pub val VAL_CONST_INT:   ValueKind = 2;
# an inline floating-point constant; `data.float_lit` holds the value
pub val VAL_CONST_FLOAT: ValueKind = 3;
# a null pointer constant; no payload
pub val VAL_CONST_NULL:  ValueKind = 4;
# an inline byte blob (e.g. a string literal); `data.bytes` borrows the bytes
pub val VAL_CONST_BYTES: ValueKind = 5;
# a reference to a module global; `data.global_ix` indexes Module.globals
pub val VAL_GLOBAL:      ValueKind = 6;
# a reference to a function symbol; `data.fn_ix` indexes Module.functions
pub val VAL_FN:          ValueKind = 7;
# a pre-serialized aggregate constant (struct/array/str initializer);
# `data.agg` holds the laid-out blob plus a relocation side-table naming the
# pointer leaves (string / address-of-global) the linker must patch
pub val VAL_CONST_AGG:   ValueKind = 8;

# a borrowed byte blob for VAL_CONST_BYTES constants
# ---
# ptr: pointer to the bytes (not owned by the Value)
# len: number of bytes
pub rec ValueBytes {
    ptr: *u8;
    len: u32;
}

# one pointer leaf in an aggregate constant that the linker must patch
#
# The blob byte `offset` holds a pointer slot to be filled with the address of
# `symbol` plus `addend`. Used for `str` / address-of-global / function-pointer
# leaves whose value is a symbol address not known until link time.
# ---
# offset: byte offset of the pointer slot within the aggregate blob
# symbol: interned name of the target symbol (e.g. an anonymous rodata global)
# addend: constant added to the resolved symbol address
# is_fn:  true when `symbol` names a function (so a cross-module extern stub for
#         it is typed STT_FUNC, not STT_OBJECT)
pub rec AggReloc {
    offset: u32;
    symbol: intern.StrId;
    addend: i64;
    is_fn:  bool;
}

# a pre-serialized aggregate constant for VAL_CONST_AGG
#
# The laid-out little-endian blob plus a relocation side-table for its pointer
# leaves. The blob and side-table are owned by the IR module's allocator
# (materialised once during lowering, never copied) and freed by
# `ir.dnit_module`; a VAL_CONST_AGG appears only as a global's initializer
# (never as an instruction operand), so the module teardown frees each blob
# exactly once via a global walk.
# ---
# bytes:       the laid-out aggregate blob (sized to the aggregate's IR type)
# len:         number of bytes in the blob (also its allocation size)
# relocs:      side-table of pointer leaves to patch (nil when reloc_cap is 0)
# reloc_count: number of live side-table entries
# reloc_cap:   allocated entry capacity of `relocs` (the true allocation size,
#              which the layout pass grows past `reloc_count`); teardown frees
#              `reloc_cap` entries
pub rec ValueAgg {
    bytes:       *u8;
    len:         u32;
    relocs:      *AggReloc;
    reloc_count: u32;
    reloc_cap:   u32;
}

# an SSA value: a typed, tagged operand reference
# ---
# kind:   which ValueKind variant is active
# ty:     IR type of the value
# secret: the constant-time secrecy taint (#1646). true when this value carries
#         secret data - the top of the two-point secrecy lattice the front end
#         proved. the IR type universe erases the `^` qualifier (a `^T` shares
#         `T`'s machine shape), so this bit is where the taint lives once types are
#         lowered; it threads to MIR and the final instructions so the back end and
#         the #1648 validator can enforce that a secret never steers control flow,
#         addresses memory, or feeds a variable-latency op. set per use by the
#         lowerer from sema's flow typing (a `:^` downgrade yields a public value),
#         and monotonically inherited across every RAUW so it cannot die before the
#         bottom. false for every value in a program that uses no secret.
# data:   kind-specific payload
pub rec Value {
    kind:   ValueKind;
    ty:     ir_type.IrTypeId;
    secret: bool;
    data: uni {
        instr:     id.InstructionId;
        param_ix:  u32;
        int_lit:   u64;
        float_lit: f64;
        bytes:     ValueBytes;
        global_ix: u32;
        fn_ix:     u32;
        agg:       ValueAgg;
    };
}

# construct a value naming an instruction result
# ---
# instr: InstructionId of the defining instruction
# ty:    IR type of the result
# ret:   a VAL_INSTR value
pub fun instr(instr: id.InstructionId, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_INSTR;
    v.secret = false;
    v.ty   = ty;
    v.data.instr = instr;
    ret v;
}

# construct a value naming a function parameter
# ---
# index: zero-based parameter index
# ty:    IR type of the parameter
# ret:   a VAL_PARAM value
pub fun param(index: u32, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_PARAM;
    v.secret = false;
    v.ty   = ty;
    v.data.param_ix = index;
    ret v;
}

# construct an inline integer constant
# ---
# bits: integer bit pattern
# ty:   IR integer type
# ret:  a VAL_CONST_INT value
pub fun const_int(bits: u64, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_CONST_INT;
    v.secret = false;
    v.ty   = ty;
    v.data.int_lit = bits;
    ret v;
}

# construct an inline floating-point constant
# ---
# value: floating-point value
# ty:    IR float type
# ret:   a VAL_CONST_FLOAT value
pub fun const_float(value: f64, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_CONST_FLOAT;
    v.secret = false;
    v.ty   = ty;
    v.data.float_lit = value;
    ret v;
}

# construct a null pointer constant
# ---
# ty:  IR pointer type
# ret: a VAL_CONST_NULL value
pub fun const_null(ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_CONST_NULL;
    v.secret = false;
    v.ty   = ty;
    # no payload; zero the union so the inert value is deterministic
    v.data.int_lit = 0;
    ret v;
}

# construct an inline byte-blob constant; the bytes are borrowed, not copied
# ---
# ptr: pointer to the bytes
# len: number of bytes
# ty:  IR type of the blob (typically a pointer or array)
# ret: a VAL_CONST_BYTES value
pub fun const_bytes(ptr: *u8, len: u32, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_CONST_BYTES;
    v.secret = false;
    v.ty   = ty;
    v.data.bytes.ptr = ptr;
    v.data.bytes.len = len;
    ret v;
}

# construct a reference to a module global
# ---
# index: index into Module.globals
# ty:    IR type of the reference (a pointer to the global)
# ret:   a VAL_GLOBAL value
pub fun global(index: u32, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_GLOBAL;
    v.secret = false;
    v.ty   = ty;
    v.data.global_ix = index;
    ret v;
}

# construct a reference to a function symbol
# ---
# index: index into Module.functions
# ty:    IR type of the reference (a function or pointer type)
# ret:   a VAL_FN value
pub fun fn(index: u32, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_FN;
    v.secret = false;
    v.ty   = ty;
    v.data.fn_ix = index;
    ret v;
}

# construct a pre-serialized aggregate constant; the blob and relocation
# side-table are borrowed (owned by the module allocator), not copied
# ---
# bytes:       the laid-out aggregate blob
# len:         number of bytes in the blob
# relocs:      pointer-leaf side-table (nil when reloc_cap is 0)
# reloc_count: number of live side-table entries
# reloc_cap:   allocated entry capacity of `relocs` (its allocation size)
# ty:          IR type of the aggregate
# ret:         a VAL_CONST_AGG value
pub fun const_agg(bytes: *u8, len: u32, relocs: *AggReloc, reloc_count: u32, reloc_cap: u32, ty: ir_type.IrTypeId) Value {
    var v: Value;
    v.kind = VAL_CONST_AGG;
    v.secret = false;
    v.ty   = ty;
    v.data.agg.bytes       = bytes;
    v.data.agg.len         = len;
    v.data.agg.relocs      = relocs;
    v.data.agg.reloc_count = reloc_count;
    v.data.agg.reloc_cap   = reloc_cap;
    ret v;
}

# return a copy of `v` carrying IR type `ty`, preserving its kind and payload
#
# Used to tag an aggregate rvalue's storage pointer with the aggregate type so a
# store / return / argument copy of it classifies as an aggregate (a sized
# memcpy) rather than a scalar pointer move.
# ---
# v:   the value to re-tag
# ty:  the IR type to carry
# ret: a copy of `v` with `.ty = ty`
pub fun retype(v: Value, ty: ir_type.IrTypeId) Value {
    var copy: Value = v;
    copy.ty = ty;
    ret copy;
}

# true when the value carries a compile-time constant inline (integer, float,
# null, byte blob, or aggregate); false for instruction / parameter / global /
# function references
# ---
# v:   the value to test
# ret: true for the VAL_CONST_* kinds
pub fun is_constant(v: Value) bool {
    if (v.kind == VAL_CONST_INT)   { ret true; }
    if (v.kind == VAL_CONST_FLOAT) { ret true; }
    if (v.kind == VAL_CONST_NULL)  { ret true; }
    if (v.kind == VAL_CONST_BYTES) { ret true; }
    if (v.kind == VAL_CONST_AGG)   { ret true; }
    ret false;
}
