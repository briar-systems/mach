# textual IR dump for debugging and golden tests
#
# Renders a `Module` in a fixed, human-readable format. The output is not a
# reloadable language; `me.lower` is the only way to materialize IR. Output
# goes to any `std.io.writer.Writer`, so callers choose buffer / fd / discard
# sinks.
#
# Format:
#   module "<fqn>" {
#     val @<name>: <ty> = <value>
#
#     fn @<name>(<params>): <ret> {
#       block bb0:
#         %0 = add i32 %a: i32, %b: i32
#         cbr %1, bb1, bb2
#       block bb1:
#         ...
#     }
#   }
#
# Block labels are `bb<id>`; instruction results are `%<instr_id>`; function
# parameters render as `%p<index>`; globals and functions as `@<name>`; phis
# as `phi <ty> [bb0 %0: i32, bb1 %3: i32, ...]`. Per-instruction modifier flags
# render as opcode suffixes (`add.nsw`, `load.volatile`).
#
# Every value operand at a use site carries its own IR type as a `<value>: <ty>`
# suffix, so a mis-typed operand (an aggregate passed as a bare pointer) is
# visible without chasing def-use chains. An extern declaration renders its
# signature's parameter types (`fn @<name>(<ty>, <ty>): <ret> extern`); it has no
# materialized parameter values to name `%p<index>`.

use std.format;
use std.io.writer;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use O: std.types.option;
use R: std.types.result;

use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.ir.id;
use mach.lang.me.ir.instruction;
use mach.lang.me.ir.type;
use mach.lang.me.ir.value;

# write a module: its name, its globals, then its functions
# ---
# out:      destination writer
# m:        the module to render
# interner: interner for recovering names backing FQNs and symbols
# ret:      ok(true) on success, or the first write / format error
pub fun print_module(out: *writer.Writer, m: *ir.Module, interner: *intern.Interner) R.Result[bool, str] {
    val res_open: R.Result[bool, str] = emit_str(out, "module \"");
    if (R.is_err[bool, str](res_open)) { ret res_open; }
    val res_name: R.Result[bool, str] = emit_name(out, interner, m.name);
    if (R.is_err[bool, str](res_name)) { ret res_name; }
    val res_brace: R.Result[bool, str] = emit_str(out, "\" {\n");
    if (R.is_err[bool, str](res_brace)) { ret res_brace; }

    var i: u32 = 0;
    for (i < m.global_len) {
        val res_global: R.Result[bool, str] = print_global(out, m, ?m.globals[i], interner);
        if (R.is_err[bool, str](res_global)) { ret res_global; }
        i = i + 1;
    }
    if (m.global_len > 0) {
        val res_gap: R.Result[bool, str] = emit_str(out, "\n");
        if (R.is_err[bool, str](res_gap)) { ret res_gap; }
    }

    i = 0;
    for (i < m.function_len) {
        val res_fn: R.Result[bool, str] = print_function(out, m, ?m.functions[i], interner);
        if (R.is_err[bool, str](res_fn)) { ret res_fn; }
        if (i + 1 < m.function_len) {
            val res_gap: R.Result[bool, str] = emit_str(out, "\n");
            if (R.is_err[bool, str](res_gap)) { ret res_gap; }
        }
        i = i + 1;
    }

    ret emit_str(out, "}\n");
}

# write one global declaration line
# ---
# out:      destination writer
# m:        the owning module (for the IR type table)
# g:        the global to render
# interner: interner for recovering the global's name
# ret:      ok(true) on success, or a write error
pub fun print_global(out: *writer.Writer, m: *ir.Module, g: *ir.Global, interner: *intern.Interner) R.Result[bool, str] {
    var head: str = "  val @";
    if (g.is_mut) { head = "  var @"; }
    val res_head: R.Result[bool, str] = emit_str(out, head);
    if (R.is_err[bool, str](res_head)) { ret res_head; }
    val res_name: R.Result[bool, str] = emit_name(out, interner, g.name);
    if (R.is_err[bool, str](res_name)) { ret res_name; }
    val res_colon: R.Result[bool, str] = emit_str(out, ": ");
    if (R.is_err[bool, str](res_colon)) { ret res_colon; }
    val res_ty: R.Result[bool, str] = print_type(out, m, g.ty);
    if (R.is_err[bool, str](res_ty)) { ret res_ty; }
    val res_eq: R.Result[bool, str] = emit_str(out, " = ");
    if (R.is_err[bool, str](res_eq)) { ret res_eq; }
    val res_val: R.Result[bool, str] = print_value(out, m, ?g.init, interner);
    if (R.is_err[bool, str](res_val)) { ret res_val; }
    ret emit_str(out, "\n");
}

# write one function: its signature header, then each block
# ---
# out:      destination writer
# m:        the owning module (for the IR type table)
# fn:       the function to render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
pub fun print_function(out: *writer.Writer, m: *ir.Module, fn: *ir.Function, interner: *intern.Interner) R.Result[bool, str] {
    val res_head: R.Result[bool, str] = emit_str(out, "  fn @");
    if (R.is_err[bool, str](res_head)) { ret res_head; }
    val res_name: R.Result[bool, str] = emit_name(out, interner, fn.name);
    if (R.is_err[bool, str](res_name)) { ret res_name; }
    val res_open: R.Result[bool, str] = emit_str(out, "(");
    if (R.is_err[bool, str](res_open)) { ret res_open; }

    if ((fn.flags & ir.FN_FLAG_EXTERN) != 0) {
        # an extern decl carries a signature but no materialized VAL_PARAM values;
        # render the parameter types from the signature so the dump shows the real
        # arity and types instead of an empty `()`.
        val res_sig: R.Result[bool, str] = print_signature_params(out, m, fn.sig);
        if (R.is_err[bool, str](res_sig)) { ret res_sig; }
    }
    or {
        var i: u32 = 0;
        for (i < fn.param_count) {
            if (i > 0) {
                val res_sep: R.Result[bool, str] = emit_str(out, ", ");
                if (R.is_err[bool, str](res_sep)) { ret res_sep; }
            }
            val res_marker: R.Result[bool, str] = emit_str(out, "%p");
            if (R.is_err[bool, str](res_marker)) { ret res_marker; }
            val res_index: R.Result[bool, str] = emit_u64(out, i::u64);
            if (R.is_err[bool, str](res_index)) { ret res_index; }
            val res_colon: R.Result[bool, str] = emit_str(out, ": ");
            if (R.is_err[bool, str](res_colon)) { ret res_colon; }
            val res_ty: R.Result[bool, str] = print_type(out, m, fn.params[i].ty);
            if (R.is_err[bool, str](res_ty)) { ret res_ty; }
            i = i + 1;
        }
    }

    val res_close: R.Result[bool, str] = emit_str(out, "): ");
    if (R.is_err[bool, str](res_close)) { ret res_close; }
    val res_ret: R.Result[bool, str] = print_signature_ret(out, m, fn.sig);
    if (R.is_err[bool, str](res_ret)) { ret res_ret; }

    if ((fn.flags & ir.FN_FLAG_EXTERN) != 0) {
        ret emit_str(out, " extern\n");
    }

    val res_brace: R.Result[bool, str] = emit_str(out, " {\n");
    if (R.is_err[bool, str](res_brace)) { ret res_brace; }

    var i: u32 = 0;
    for (i < fn.block_count) {
        val res_block: R.Result[bool, str] = print_block(out, m, fn, ?fn.blocks[i], interner);
        if (R.is_err[bool, str](res_block)) { ret res_block; }
        i = i + 1;
    }

    ret emit_str(out, "  }\n");
}

# write one block: its label, phis, body instructions, then terminator
# ---
# out:      destination writer
# m:        the owning module (for the IR type table)
# fn:       the owning function (for the instruction pool)
# blk:      the block to render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
pub fun print_block(out: *writer.Writer, m: *ir.Module, fn: *ir.Function, blk: *ir.Block, interner: *intern.Interner) R.Result[bool, str] {
    val res_label: R.Result[bool, str] = emit_str(out, "    block bb");
    if (R.is_err[bool, str](res_label)) { ret res_label; }
    val res_id: R.Result[bool, str] = emit_u64(out, blk.id::u64);
    if (R.is_err[bool, str](res_id)) { ret res_id; }
    val res_colon: R.Result[bool, str] = emit_str(out, ":\n");
    if (R.is_err[bool, str](res_colon)) { ret res_colon; }

    var i: u32 = 0;
    for (i < blk.phi_count) {
        val res_phi: R.Result[bool, str] = print_instruction_id(out, m, fn, blk.phis[i], interner);
        if (R.is_err[bool, str](res_phi)) { ret res_phi; }
        i = i + 1;
    }

    i = 0;
    for (i < blk.instr_count) {
        val res_instr: R.Result[bool, str] = print_instruction_id(out, m, fn, blk.instructions[i], interner);
        if (R.is_err[bool, str](res_instr)) { ret res_instr; }
        i = i + 1;
    }

    if (blk.terminator != id.INSTR_NIL) {
        ret print_instruction_id(out, m, fn, blk.terminator, interner);
    }
    ret R.ok[bool, str](true);
}

# write one instruction line: the optional result binding, opcode and flag
# suffixes, result type, and operands rendered per the opcode's convention
# ---
# out:      destination writer
# m:        the owning module (for the IR type table)
# fn:       the owning function (for operand resolution)
# ins:      the instruction to render
# iid:      the instruction's id (names the result `%iid`)
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
pub fun print_instruction(out: *writer.Writer, m: *ir.Module, fn: *ir.Function, ins: *instruction.Instruction, iid: id.InstructionId, interner: *intern.Interner) R.Result[bool, str] {
    val res_indent: R.Result[bool, str] = emit_str(out, "      ");
    if (R.is_err[bool, str](res_indent)) { ret res_indent; }

    val has_result: bool = produces_value(ins.kind);
    if (has_result) {
        val res_marker: R.Result[bool, str] = emit_str(out, "%");
        if (R.is_err[bool, str](res_marker)) { ret res_marker; }
        val res_id: R.Result[bool, str] = emit_u64(out, iid::u64);
        if (R.is_err[bool, str](res_id)) { ret res_id; }
        val res_eq: R.Result[bool, str] = emit_str(out, " = ");
        if (R.is_err[bool, str](res_eq)) { ret res_eq; }
    }

    val res_op: R.Result[bool, str] = emit_str(out, opcode_name(ins.kind));
    if (R.is_err[bool, str](res_op)) { ret res_op; }
    val res_flags: R.Result[bool, str] = print_flag_suffixes(out, ins.flags);
    if (R.is_err[bool, str](res_flags)) { ret res_flags; }

    if (has_result) {
        val res_space: R.Result[bool, str] = emit_str(out, " ");
        if (R.is_err[bool, str](res_space)) { ret res_space; }
        # an alloca's result type is the uninformative IR pointer; show the
        # allocated element type (aux_ty) instead, which is what it names.
        var result_ty: type.IrTypeId = ins.ty;
        if (ins.kind == instruction.OP_ALLOCA) { result_ty = ins.aux_ty; }
        val res_ty: R.Result[bool, str] = print_type(out, m, result_ty);
        if (R.is_err[bool, str](res_ty)) { ret res_ty; }
    }

    if (ins.kind == instruction.OP_PHI) {
        val res_phi: R.Result[bool, str] = print_phi_operands(out, m, fn, ins, interner);
        if (R.is_err[bool, str](res_phi)) { ret res_phi; }
    }
    or {
        val res_operands: R.Result[bool, str] = print_operands(out, m, fn, ins, interner);
        if (R.is_err[bool, str](res_operands)) { ret res_operands; }
    }

    if (ins.kind == instruction.OP_DBG_VALUE) {
        val res_dbg: R.Result[bool, str] = print_dbg_expr(out, fn, iid);
        if (R.is_err[bool, str](res_dbg)) { ret res_dbg; }
    }

    ret emit_str(out, "\n");
}

# append an OP_DBG_VALUE's debug-location expression as ` ; +k, -j` in applied order,
# or nothing for the identity expression. the operand itself is rendered by the
# shared operand path, so a VAL_CONST_NULL operand already reads as the optimized-out
# sentinel
# ---
# out: destination writer
# fn:  the owning function (for the expression pool)
# iid: the OP_DBG_VALUE instruction id
# ret: ok(true) on success, or a write error
fun print_dbg_expr(out: *writer.Writer, fn: *ir.Function, iid: id.InstructionId) R.Result[bool, str] {
    val eid: ir.DbgExprId = ir.dbg_expr_id(fn, iid);
    val opt: O.Option[*ir.DbgExpr] = ir.dbg_expr_get(fn, eid);
    if (O.is_none[*ir.DbgExpr](opt)) { ret R.ok[bool, str](true); }
    val dex: *ir.DbgExpr = O.unwrap[*ir.DbgExpr](opt);

    val res_sep: R.Result[bool, str] = emit_str(out, " ; ");
    if (R.is_err[bool, str](res_sep)) { ret res_sep; }

    var i: u32 = 0;
    for (i < dex.op_count) {
        if (i > 0) {
            val res_comma: R.Result[bool, str] = emit_str(out, ", ");
            if (R.is_err[bool, str](res_comma)) { ret res_comma; }
        }
        var sign: str = "+";
        if (dex.ops[i].op == ir.DBG_OP_MINUS_CONST) { sign = "-"; }
        val res_sign: R.Result[bool, str] = emit_str(out, sign);
        if (R.is_err[bool, str](res_sign)) { ret res_sign; }
        val res_num: R.Result[bool, str] = emit_u64(out, dex.ops[i].arg);
        if (R.is_err[bool, str](res_num)) { ret res_num; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# render one Value operand reference inline
# ---
# out:      destination writer
# m:        the owning module (for global / function name lookup)
# v:        the value to render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
pub fun print_value(out: *writer.Writer, m: *ir.Module, v: *value.Value, interner: *intern.Interner) R.Result[bool, str] {
    if (v.kind == value.VAL_INSTR) {
        val res_marker: R.Result[bool, str] = emit_str(out, "%");
        if (R.is_err[bool, str](res_marker)) { ret res_marker; }
        ret emit_u64(out, v.data.instr::u64);
    }
    if (v.kind == value.VAL_PARAM) {
        val res_marker: R.Result[bool, str] = emit_str(out, "%p");
        if (R.is_err[bool, str](res_marker)) { ret res_marker; }
        ret emit_u64(out, v.data.param_ix::u64);
    }
    if (v.kind == value.VAL_CONST_INT) {
        ret emit_u64(out, v.data.int_lit);
    }
    if (v.kind == value.VAL_CONST_FLOAT) {
        # std has no float formatter; print the truncated integer magnitude
        # tagged `f` so the dump stays readable (it is not reloadable anyway).
        val res_tag: R.Result[bool, str] = emit_str(out, "f");
        if (R.is_err[bool, str](res_tag)) { ret res_tag; }
        val f: f64 = v.data.float_lit;
        if (f < 0.0) {
            val res_sign: R.Result[bool, str] = emit_str(out, "-");
            if (R.is_err[bool, str](res_sign)) { ret res_sign; }
            ret emit_u64(out, (0.0 - f)::u64);
        }
        ret emit_u64(out, f::u64);
    }
    if (v.kind == value.VAL_CONST_NULL) {
        ret emit_str(out, "null");
    }
    if (v.kind == value.VAL_CONST_BYTES) {
        val res_open: R.Result[bool, str] = emit_str(out, "bytes[");
        if (R.is_err[bool, str](res_open)) { ret res_open; }
        val res_len: R.Result[bool, str] = emit_u64(out, v.data.bytes.len::u64);
        if (R.is_err[bool, str](res_len)) { ret res_len; }
        ret emit_str(out, "]");
    }
    if (v.kind == value.VAL_GLOBAL) {
        val res_sigil: R.Result[bool, str] = emit_str(out, "@");
        if (R.is_err[bool, str](res_sigil)) { ret res_sigil; }
        if (v.data.global_ix < m.global_len) {
            ret emit_name(out, interner, m.globals[v.data.global_ix].name);
        }
        ret emit_u64(out, v.data.global_ix::u64);
    }
    if (v.kind == value.VAL_FN) {
        val res_sigil: R.Result[bool, str] = emit_str(out, "@");
        if (R.is_err[bool, str](res_sigil)) { ret res_sigil; }
        if (v.data.fn_ix < m.function_len) {
            ret emit_name(out, interner, m.functions[v.data.fn_ix].name);
        }
        ret emit_u64(out, v.data.fn_ix::u64);
    }
    if (v.kind == value.VAL_CONST_AGG) {
        val res_open: R.Result[bool, str] = emit_str(out, "agg[");
        if (R.is_err[bool, str](res_open)) { ret res_open; }
        val res_len: R.Result[bool, str] = emit_u64(out, v.data.agg.len::u64);
        if (R.is_err[bool, str](res_len)) { ret res_len; }
        ret emit_str(out, "]");
    }
    ret emit_str(out, "<?value>");
}

# render an IR type compactly: `void`, `i<bits>`, `f<bits>`, `ptr`, `[N]elem`,
# `{f0, f1, ...}`, `uni{...}`, or `fn(...) -> ret`
# ---
# out: destination writer
# m:   the owning module (for the IR type table)
# tid: the type to render
# ret: ok(true) on success, or a write error
pub fun print_type(out: *writer.Writer, m: *ir.Module, tid: type.IrTypeId) R.Result[bool, str] {
    val opt_type: O.Option[*type.IrType] = type.get(?m.types, tid);
    if (O.is_none[*type.IrType](opt_type)) {
        ret emit_str(out, "<?type>");
    }
    val t: *type.IrType = O.unwrap[*type.IrType](opt_type);

    if (t.kind == type.IRT_VOID) { ret emit_str(out, "void"); }
    if (t.kind == type.IRT_INT) {
        val res_tag: R.Result[bool, str] = emit_str(out, "i");
        if (R.is_err[bool, str](res_tag)) { ret res_tag; }
        ret emit_u64(out, t.data.bits::u64);
    }
    if (t.kind == type.IRT_FLOAT) {
        val res_tag: R.Result[bool, str] = emit_str(out, "f");
        if (R.is_err[bool, str](res_tag)) { ret res_tag; }
        ret emit_u64(out, t.data.bits::u64);
    }
    if (t.kind == type.IRT_PTR) { ret emit_str(out, "ptr"); }
    if (t.kind == type.IRT_ARRAY) {
        val res_open: R.Result[bool, str] = emit_str(out, "[");
        if (R.is_err[bool, str](res_open)) { ret res_open; }
        val res_len: R.Result[bool, str] = emit_u64(out, type.array_count(?m.types, tid)::u64);
        if (R.is_err[bool, str](res_len)) { ret res_len; }
        val res_close: R.Result[bool, str] = emit_str(out, "]");
        if (R.is_err[bool, str](res_close)) { ret res_close; }
        ret print_type(out, m, t.data.array_.element);
    }
    if (t.kind == type.IRT_VECTOR) {
        # `<element>x<lanes>`, e.g. f32x4
        val res_elem: R.Result[bool, str] = print_type(out, m, t.data.vector_.element);
        if (R.is_err[bool, str](res_elem)) { ret res_elem; }
        val res_x: R.Result[bool, str] = emit_str(out, "x");
        if (R.is_err[bool, str](res_x)) { ret res_x; }
        ret emit_u64(out, t.data.vector_.lanes::u64);
    }
    if (t.kind == type.IRT_STRUCT || t.kind == type.IRT_UNION) {
        var open: str = "{";
        if (t.kind == type.IRT_UNION) { open = "uni{"; }
        val res_open: R.Result[bool, str] = emit_str(out, open);
        if (R.is_err[bool, str](res_open)) { ret res_open; }
        var i: u32 = 0;
        for (i < t.data.struct_.field_count) {
            if (i > 0) {
                val res_sep: R.Result[bool, str] = emit_str(out, ", ");
                if (R.is_err[bool, str](res_sep)) { ret res_sep; }
            }
            val res_field: R.Result[bool, str] = print_type(out, m, t.data.struct_.fields[i]);
            if (R.is_err[bool, str](res_field)) { ret res_field; }
            i = i + 1;
        }
        ret emit_str(out, "}");
    }
    if (t.kind == type.IRT_FN) {
        val res_open: R.Result[bool, str] = emit_str(out, "fn(");
        if (R.is_err[bool, str](res_open)) { ret res_open; }
        var i: u32 = 0;
        for (i < t.data.fn.param_count) {
            if (i > 0) {
                val res_sep: R.Result[bool, str] = emit_str(out, ", ");
                if (R.is_err[bool, str](res_sep)) { ret res_sep; }
            }
            val res_param: R.Result[bool, str] = print_type(out, m, t.data.fn.params[i]);
            if (R.is_err[bool, str](res_param)) { ret res_param; }
            i = i + 1;
        }
        val res_arrow: R.Result[bool, str] = emit_str(out, ") -> ");
        if (R.is_err[bool, str](res_arrow)) { ret res_arrow; }
        ret print_type(out, m, t.data.fn.ret_type);
    }
    ret emit_str(out, "<?type>");
}

# render one instruction referenced by id in a block's list
#
# Resolves the id through `ir.instruction_get`, the single access point. An
# out-of-range or nil id (the malformed IR this printer exists to debug)
# renders a `<dangling %N>` line instead of an out-of-bounds pool read.
# ---
# out:      destination writer
# m:        the owning module (for the IR type table)
# fn:       the owning function (for the instruction pool)
# iid:      the instruction id to resolve and render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
fun print_instruction_id(out: *writer.Writer, m: *ir.Module, fn: *ir.Function, iid: id.InstructionId, interner: *intern.Interner) R.Result[bool, str] {
    val opt_ins: O.Option[*instruction.Instruction] = ir.instruction_get(fn, iid);
    if (O.is_some[*instruction.Instruction](opt_ins)) {
        ret print_instruction(out, m, fn, O.unwrap[*instruction.Instruction](opt_ins), iid, interner);
    }
    val res_open: R.Result[bool, str] = emit_str(out, "      <dangling %");
    if (R.is_err[bool, str](res_open)) { ret res_open; }
    val res_id: R.Result[bool, str] = emit_u64(out, iid::u64);
    if (R.is_err[bool, str](res_id)) { ret res_id; }
    ret emit_str(out, ">\n");
}

# render an instruction's flat operand list as ` op0, op1, ...`
#
# Branch targets (const_int block ids) render as `bb<n>`. Nothing is written
# for an operand-less instruction.
# ---
# out:      destination writer
# m:        the owning module (for global / function name lookup)
# fn:       the owning function (for operand resolution)
# ins:      the instruction whose operands to render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
fun print_operands(out: *writer.Writer, m: *ir.Module, fn: *ir.Function, ins: *instruction.Instruction, interner: *intern.Interner) R.Result[bool, str] {
    if (ins.operand_count == 0) { ret R.ok[bool, str](true); }

    var i: u32 = 0;
    for (i < ins.operand_count) {
        if (i == 0) {
            val res_space: R.Result[bool, str] = emit_str(out, " ");
            if (R.is_err[bool, str](res_space)) { ret res_space; }
        }
        or {
            val res_sep: R.Result[bool, str] = emit_str(out, ", ");
            if (R.is_err[bool, str](res_sep)) { ret res_sep; }
        }
        val op: *value.Value = ?ins.operands[i];
        # for BR every operand is a target; for CBR operands 1 and 2 are targets.
        val is_target: bool = ins.kind == instruction.OP_BR || (ins.kind == instruction.OP_CBR && i >= 1);
        if (is_target && op.kind == value.VAL_CONST_INT) {
            val res_bb: R.Result[bool, str] = emit_str(out, "bb");
            if (R.is_err[bool, str](res_bb)) { ret res_bb; }
            val res_id: R.Result[bool, str] = emit_u64(out, op.data.int_lit);
            if (R.is_err[bool, str](res_id)) { ret res_id; }
        }
        or {
            val res_op: R.Result[bool, str] = print_operand(out, m, op, interner);
            if (R.is_err[bool, str](res_op)) { ret res_op; }
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# render one value operand followed by its IR type as `<value>: <ty>`
#
# The per-operand type is what makes a mis-typed operand visible in a dump (an
# aggregate passed as a bare pointer, a wrong-width integer): the Value carries
# its own `ty`, independent of the referenced definition's result type. Used at
# every value use site (flat operand lists, phi incomings).
# ---
# out:      destination writer
# m:        the owning module (for global / function name lookup and the type table)
# v:        the operand value to render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
fun print_operand(out: *writer.Writer, m: *ir.Module, v: *value.Value, interner: *intern.Interner) R.Result[bool, str] {
    val res_val: R.Result[bool, str] = print_value(out, m, v, interner);
    if (R.is_err[bool, str](res_val)) { ret res_val; }
    val res_colon: R.Result[bool, str] = emit_str(out, ": ");
    if (R.is_err[bool, str](res_colon)) { ret res_colon; }
    ret print_type(out, m, v.ty);
}

# render a phi's `[bbN %v, bbM %w, ...]` incoming list
#
# Operands alternate block-id (const_int) and value.
# ---
# out:      destination writer
# m:        the owning module (for global / function name lookup)
# fn:       the owning function (for operand resolution)
# ins:      the phi instruction whose incoming list to render
# interner: interner for recovering names
# ret:      ok(true) on success, or a write error
fun print_phi_operands(out: *writer.Writer, m: *ir.Module, fn: *ir.Function, ins: *instruction.Instruction, interner: *intern.Interner) R.Result[bool, str] {
    val res_open: R.Result[bool, str] = emit_str(out, " [");
    if (R.is_err[bool, str](res_open)) { ret res_open; }

    var i: u32 = 0;
    for (i + 1 < ins.operand_count) {
        if (i > 0) {
            val res_sep: R.Result[bool, str] = emit_str(out, ", ");
            if (R.is_err[bool, str](res_sep)) { ret res_sep; }
        }
        val blk_op: *value.Value = ?ins.operands[i];
        val res_bb: R.Result[bool, str] = emit_str(out, "bb");
        if (R.is_err[bool, str](res_bb)) { ret res_bb; }
        val res_id: R.Result[bool, str] = emit_u64(out, blk_op.data.int_lit);
        if (R.is_err[bool, str](res_id)) { ret res_id; }
        val res_space: R.Result[bool, str] = emit_str(out, " ");
        if (R.is_err[bool, str](res_space)) { ret res_space; }
        val res_val: R.Result[bool, str] = print_operand(out, m, ?ins.operands[i + 1], interner);
        if (R.is_err[bool, str](res_val)) { ret res_val; }
        i = i + 2;
    }
    ret emit_str(out, "]");
}

# render a function signature's parameter types from its IRT_FN type id as a bare
# comma list `T0, T1, ...`
#
# Used for an extern declaration, which carries a signature but no materialized
# VAL_PARAM values to name `%pN`. Writes nothing for a missing or non-function
# type id (malformed IR) or a zero-parameter signature.
# ---
# out: destination writer
# m:   the owning module (for the IR type table)
# sig: the function's signature type id
# ret: ok(true) on success, or a write error
fun print_signature_params(out: *writer.Writer, m: *ir.Module, sig: type.IrTypeId) R.Result[bool, str] {
    val opt_type: O.Option[*type.IrType] = type.get(?m.types, sig);
    if (O.is_none[*type.IrType](opt_type)) { ret R.ok[bool, str](true); }
    val t: *type.IrType = O.unwrap[*type.IrType](opt_type);
    if (t.kind != type.IRT_FN) { ret R.ok[bool, str](true); }

    var i: u32 = 0;
    for (i < t.data.fn.param_count) {
        if (i > 0) {
            val res_sep: R.Result[bool, str] = emit_str(out, ", ");
            if (R.is_err[bool, str](res_sep)) { ret res_sep; }
        }
        val res_ty: R.Result[bool, str] = print_type(out, m, t.data.fn.params[i]);
        if (R.is_err[bool, str](res_ty)) { ret res_ty; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# render a function signature's return type from its IRT_FN type id
#
# Falls back to `void` for a missing or non-function type id, which only
# arises for malformed IR.
# ---
# out: destination writer
# m:   the owning module (for the IR type table)
# sig: the function's signature type id
# ret: ok(true) on success, or a write error
fun print_signature_ret(out: *writer.Writer, m: *ir.Module, sig: type.IrTypeId) R.Result[bool, str] {
    val opt_type: O.Option[*type.IrType] = type.get(?m.types, sig);
    if (O.is_some[*type.IrType](opt_type)) {
        val t: *type.IrType = O.unwrap[*type.IrType](opt_type);
        if (t.kind == type.IRT_FN) {
            ret print_type(out, m, t.data.fn.ret_type);
        }
    }
    ret emit_str(out, "void");
}

# append `.nsw` / `.nuw` / `.exact` / `.volatile` for each set modifier flag
# ---
# out:   destination writer
# flags: the instruction's modifier flag bits
# ret:   ok(true) on success, or a write error
fun print_flag_suffixes(out: *writer.Writer, flags: u16) R.Result[bool, str] {
    if ((flags & instruction.INSTR_FLAG_NSW) != 0) {
        val res: R.Result[bool, str] = emit_str(out, ".nsw");
        if (R.is_err[bool, str](res)) { ret res; }
    }
    if ((flags & instruction.INSTR_FLAG_NUW) != 0) {
        val res: R.Result[bool, str] = emit_str(out, ".nuw");
        if (R.is_err[bool, str](res)) { ret res; }
    }
    if ((flags & instruction.INSTR_FLAG_EXACT) != 0) {
        val res: R.Result[bool, str] = emit_str(out, ".exact");
        if (R.is_err[bool, str](res)) { ret res; }
    }
    if ((flags & instruction.INSTR_FLAG_VOLATILE) != 0) {
        val res: R.Result[bool, str] = emit_str(out, ".volatile");
        if (R.is_err[bool, str](res)) { ret res; }
    }
    ret R.ok[bool, str](true);
}

# whether an opcode defines an SSA result worth naming `%n`
#
# Terminators, stores, memzero, and inline asm produce no value.
# ---
# k:   the opcode to classify
# ret: true when the opcode yields a named SSA result
fun produces_value(k: instruction.InstrKind) bool {
    if (instruction.is_terminator(k)) { ret false; }
    if (k == instruction.OP_STORE)     { ret false; }
    if (k == instruction.OP_MEMZERO)   { ret false; }
    if (k == instruction.OP_ASM)       { ret false; }
    if (k == instruction.OP_DBG_VALUE) { ret false; }
    ret true;
}

# return a short mnemonic for an opcode
#
# An unknown opcode is a missing dispatch entry, not valid IR; it renders the
# loud `<?op>` sentinel so a dump never silently mislabels a new opcode.
# ---
# k:   the opcode
# ret: the mnemonic string
fun opcode_name(k: instruction.InstrKind) str {
    if (k == instruction.OP_ADD)         { ret "add"; }
    if (k == instruction.OP_SUB)         { ret "sub"; }
    if (k == instruction.OP_MUL)         { ret "mul"; }
    if (k == instruction.OP_DIV_S)       { ret "div_s"; }
    if (k == instruction.OP_DIV_U)       { ret "div_u"; }
    if (k == instruction.OP_REM_S)       { ret "rem_s"; }
    if (k == instruction.OP_REM_U)       { ret "rem_u"; }
    if (k == instruction.OP_NEG)         { ret "neg"; }
    if (k == instruction.OP_AND)         { ret "and"; }
    if (k == instruction.OP_OR)          { ret "or"; }
    if (k == instruction.OP_XOR)         { ret "xor"; }
    if (k == instruction.OP_SHL)         { ret "shl"; }
    if (k == instruction.OP_SHR_S)       { ret "shr_s"; }
    if (k == instruction.OP_SHR_U)       { ret "shr_u"; }
    if (k == instruction.OP_NOT)         { ret "not"; }
    if (k == instruction.OP_CMP_EQ)      { ret "cmp_eq"; }
    if (k == instruction.OP_CMP_NE)      { ret "cmp_ne"; }
    if (k == instruction.OP_CMP_LT_S)    { ret "cmp_lt_s"; }
    if (k == instruction.OP_CMP_LT_U)    { ret "cmp_lt_u"; }
    if (k == instruction.OP_CMP_LE_S)    { ret "cmp_le_s"; }
    if (k == instruction.OP_CMP_LE_U)    { ret "cmp_le_u"; }
    if (k == instruction.OP_TRUNC)       { ret "trunc"; }
    if (k == instruction.OP_SEXT)        { ret "sext"; }
    if (k == instruction.OP_ZEXT)        { ret "zext"; }
    if (k == instruction.OP_FP_TRUNC)    { ret "fp_trunc"; }
    if (k == instruction.OP_FP_EXT)      { ret "fp_ext"; }
    if (k == instruction.OP_FP_TO_SI)    { ret "fp_to_si"; }
    if (k == instruction.OP_FP_TO_UI)    { ret "fp_to_ui"; }
    if (k == instruction.OP_SI_TO_FP)    { ret "si_to_fp"; }
    if (k == instruction.OP_UI_TO_FP)    { ret "ui_to_fp"; }
    if (k == instruction.OP_BITCAST)     { ret "bitcast"; }
    if (k == instruction.OP_DECLASSIFY)  { ret "declassify"; }
    if (k == instruction.OP_ALLOCA)      { ret "alloca"; }
    if (k == instruction.OP_LOAD)        { ret "load"; }
    if (k == instruction.OP_STORE)       { ret "store"; }
    if (k == instruction.OP_MEMZERO)     { ret "memzero"; }
    if (k == instruction.OP_DBG_VALUE)   { ret "dbg_value"; }
    if (k == instruction.OP_GEP)         { ret "gep"; }
    if (k == instruction.OP_EXTRACT)     { ret "extract"; }
    if (k == instruction.OP_INSERT)      { ret "insert"; }
    if (k == instruction.OP_PHI)         { ret "phi"; }
    if (k == instruction.OP_CALL)        { ret "call"; }
    if (k == instruction.OP_BR)          { ret "br"; }
    if (k == instruction.OP_CBR)         { ret "cbr"; }
    if (k == instruction.OP_RET)         { ret "ret"; }
    if (k == instruction.OP_UNREACHABLE) { ret "unreachable"; }
    if (k == instruction.OP_ASM)         { ret "asm"; }
    ret "<?op>";
}

# write a string, collapsing the written byte count to ok(true)
# ---
# out: destination writer
# s:   the string to write
# ret: ok(true) on success, or the write error
fun emit_str(out: *writer.Writer, s: str) R.Result[bool, str] {
    val res: R.Result[usize, str] = format.write_str(out, s);
    if (R.is_err[usize, str](res)) { ret R.err[bool, str](R.unwrap_err[usize, str](res)); }
    ret R.ok[bool, str](true);
}

# write an unsigned integer in decimal
# ---
# out: destination writer
# n:   the value to write
# ret: ok(true) on success, or the write error
fun emit_u64(out: *writer.Writer, n: u64) R.Result[bool, str] {
    val res: R.Result[usize, str] = format.write_u64(out, n);
    if (R.is_err[usize, str](res)) { ret R.err[bool, str](R.unwrap_err[usize, str](res)); }
    ret R.ok[bool, str](true);
}

# write an interned name, or `<?name>` when the id does not resolve
# ---
# out:      destination writer
# interner: interner holding the name
# name_id:  the interned string id to resolve
# ret:      ok(true) on success, or the write error
fun emit_name(out: *writer.Writer, interner: *intern.Interner, name_id: intern.StrId) R.Result[bool, str] {
    val opt_name: O.Option[str] = intern.lookup(interner, name_id);
    if (O.is_some[str](opt_name)) {
        ret emit_str(out, O.unwrap[str](opt_name));
    }
    ret emit_str(out, "<?name>");
}
