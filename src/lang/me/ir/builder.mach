# lhs: left operand
# rhs: right operand
# ret: a value naming the product, or an error
pub fun emit_mul(b: *Builder, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    ret emit_binary(b, instruction.OP_MUL, lhs, rhs);
}

