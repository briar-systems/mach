# operand: value to reinterpret
# to:      destination type (same size as the operand's type)
# ret:     a value of type `to`, or an error
pub fun emit_bitcast(b: *Builder, operand: value.Value, to: type.IrTypeId) R.Result[value.Value, str] {
    ret emit_unary(b, instruction.OP_BITCAST, operand, to);
}

# emit a stack allocation
#
# The result is a pointer to `count` contiguous slots of `ty`; `count` is a
# runtime value (use a const_int of 1 for a single slot). The result type and
# the result Value are both the untyped IR pointer; the allocated element type
# (which sizes the stack slot, since the pointer carries none) rides on
# `aux_ty`, the same convention GEP / MEMZERO / CALL use for a type their
# result slot cannot itself carry.
# ---
# b:     the builder
# ty:    the element type being allocated
# count: number of elements to allocate
# ret:   a pointer value naming the allocation, or an error
pub fun emit_alloca(b: *Builder, ty: type.IrTypeId, count: value.Value) R.Result[value.Value, str] {
    val res_ptr: R.Result[type.IrTypeId, str] = ptr_type(b);
    if (R.is_err[type.IrTypeId, str](res_ptr)) {
        ret R.err[value.Value, str](R.unwrap_err[type.IrTypeId, str](res_ptr));
    }
    val ptr_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_ptr);

    var ops: [1]value.Value;
    ops[0] = count;
    val res_iid: R.Result[id.InstructionId, str] = emit_raw(b, instruction.OP_ALLOCA, ptr_ty, ?ops[0], 1);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[value.Value, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);
    b.fn.instrs[iid].aux_ty = ty;
    ret R.ok[value.Value, str](value.instr(iid, ptr_ty));
}

# emit a load of type `ty` from a pointer
# ---
# b:   the builder
# ptr: pointer to load from
# ty:  type of the loaded value
# ret: a value of type `ty`, or an error
pub fun emit_load(b: *Builder, ptr: value.Value, ty: type.IrTypeId) R.Result[value.Value, str] {
    var ops: [1]value.Value;
    ops[0] = ptr;
    ret emit_value_instr(b, instruction.OP_LOAD, ty, ?ops[0], 1);
}

# emit a store of `value_arg` to `ptr`, producing no value (void instruction)
#
# Operand order is [value, ptr] per the opcode convention.
# ---
# b:         the builder
# value_arg: value to store
# ptr:       destination pointer
# ret:       ok(true) on success, or an error
pub fun emit_store(b: *Builder, value_arg: value.Value, ptr: value.Value) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    var ops: [2]value.Value;
    ops[0] = value_arg;
    ops[1] = ptr;
    val res_iid: R.Result[id.InstructionId, str] = emit_raw(b, instruction.OP_STORE, void_ty, ?ops[0], 2);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    # a store of a secret value writes secret storage; mark the store so a future
    # dead-store-elimination pass and the #1648 validator can identify it and keep a
    # zeroizing write to secret storage alive (#1646). a zeroizing store of a public
    # zero into secret storage is not caught here (its destination pointee, not its
    # value, is secret) - that refinement needs the lvalue's semantic type at the
    # store site and rides with the validator work.
    if (value_arg.secret) {
        val siid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);
        if (siid::u32 < b.fn.instr_len) { b.fn.instrs[siid::u32].secret = true; }
    }
    ret R.ok[bool, str](true);
}

# emit a zero-fill of the aggregate at `ptr`, producing no value (void
# instruction)
#
# `pointee_ty` is the aggregate type whose `byte_size` the back end zeroes,
# recorded on the instruction (`aux_ty`) since the pointer operand is untyped
# (IRT_PTR). `aux_ty` is not verified, so the caller must pass a resolvable
# aggregate type; lower_decl_stmt passes the slot type. Used to zero-initialize
# an aggregate local that has no initializer -- a scalar local uses a plain
# typed zero store instead so mem2reg can still promote it.
# ---
# b:          the builder
# ptr:        destination pointer (the aggregate's storage address)
# pointee_ty: the aggregate type to zero (sizes the fill)
# ret:        ok(true) on success, or an error
pub fun emit_memzero(b: *Builder, ptr: value.Value, pointee_ty: type.IrTypeId) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    var ops: [1]value.Value;
    ops[0] = ptr;
    val res_iid: R.Result[id.InstructionId, str] = emit_raw(b, instruction.OP_MEMZERO, void_ty, ?ops[0], 1);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);
    b.fn.instrs[iid].aux_ty = pointee_ty;
    ret R.ok[bool, str](true);
}

# emit an address computation: `base` adjusted by the given indices
#
# The result is a pointer. Operand order is [base, idx0, idx1, ...]. The index
# walk follows the standard getelementptr model: index 0 strides over the source
# pointee `src_ty` (the type one element of `base` denotes), and each subsequent
# index descends one level into the aggregate reached so far. `src_ty` is
# recorded on the instruction (`aux_ty`) because the base pointer is untyped, so
# without it the back end could not turn the indices into byte offsets.
# ---
# b:           the builder
# base:        base pointer
# src_ty:      source pointee type the index walk starts from
# indices:     pointer to an array of index values
# index_count: number of indices
# ret:         a pointer value naming the computed address, or an error
pub fun emit_gep(b: *Builder, base: value.Value, src_ty: type.IrTypeId, indices: *value.Value, index_count: u32) R.Result[value.Value, str] {
    val res_ptr: R.Result[type.IrTypeId, str] = ptr_type(b);
    if (R.is_err[type.IrTypeId, str](res_ptr)) {
        ret R.err[value.Value, str](R.unwrap_err[type.IrTypeId, str](res_ptr));
    }
    val ptr_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_ptr);

    val total: u32 = index_count + 1;
    val res_ops: R.Result[*value.Value, str] = A.allocate[value.Value](b.m.alloc, total::usize);
    if (R.is_err[*value.Value, str](res_ops)) {
        ret R.err[value.Value, str](R.unwrap_err[*value.Value, str](res_ops));
    }
    val ops: *value.Value = R.unwrap_ok[*value.Value, str](res_ops);
    ops[0] = base;
    var i: u32 = 0;
    for (i < index_count) {
        ops[1 + i] = indices[i];
        i = i + 1;
    }

    val res_iid: R.Result[id.InstructionId, str] = emit_raw_owned(b, instruction.OP_GEP, ptr_ty, ops, total);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[value.Value, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);
    b.fn.instrs[iid].aux_ty = src_ty;
    ret R.ok[value.Value, str](value.instr(iid, ptr_ty));
}

# emit an aggregate element extraction
#
# The element type is supplied since the aggregate's element layout is opaque
# to the builder.
# ---
# b:     the builder
# agg:   aggregate value
# index: element index value
# ty:    type of the extracted element
# ret:   a value of type `ty`, or an error
pub fun emit_extract(b: *Builder, agg: value.Value, index: value.Value, ty: type.IrTypeId) R.Result[value.Value, str] {
    var ops: [2]value.Value;
    ops[0] = agg;
    ops[1] = index;
    ret emit_value_instr(b, instruction.OP_EXTRACT, ty, ?ops[0], 2);
}

# emit an aggregate element insertion, producing a new aggregate value of the
# same type as the input aggregate
# ---
# b:       the builder
# agg:     aggregate value
# index:   element index value
# element: value to insert
# ret:     a new aggregate value, or an error
pub fun emit_insert(b: *Builder, agg: value.Value, index: value.Value, element: value.Value) R.Result[value.Value, str] {
    var ops: [3]value.Value;
    ops[0] = agg;
    ops[1] = index;
    ops[2] = element;
    ret emit_value_instr(b, instruction.OP_INSERT, agg.ty, ?ops[0], 3);
}

# emit a phi node of type `ty` into the current block's phi list with no
# incoming edges yet
#
# Populate it with `phi_add_incoming`. Phis logically execute at block entry,
# before the body.
# ---
# b:   the builder
# ty:  result type of the phi
# ret: a value naming the phi result, or an error
pub fun emit_phi(b: *Builder, ty: type.IrTypeId) R.Result[value.Value, str] {
    if (b.fn == nil)                 { ret R.err[value.Value, str]("builder: emit_phi with no current function"); }
    if (b.block >= b.fn.block_count) { ret R.err[value.Value, str]("builder: emit_phi with invalid block cursor"); }

    val res_iid: R.Result[id.InstructionId, str] = pool_append(b, instruction.OP_PHI, ty, nil, 0);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[value.Value, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);

    val blk: *ir.Block = ?b.fn.blocks[b.block];
    val res_phi: R.Result[bool, str] = ir.block_append_phi(b.m, blk, iid);
    if (R.is_err[bool, str](res_phi)) {
        ret R.err[value.Value, str](R.unwrap_err[bool, str](res_phi));
    }
    ret R.ok[value.Value, str](value.instr(iid, ty));
}

# append one incoming `(source, value_arg)` edge to a phi instruction
#
# The operand layout is [block0, val0, block1, val1, ...]; the predecessor
# block id rides in the value slot it pairs with, encoded as a const_int.
# Growth goes through the single capacity-maintaining ir.phi_append_incoming.
# ---
# b:         the builder
# phi:       the phi value returned by emit_phi
# source:    predecessor block contributing `value_arg`
# value_arg: the value flowing in from `source`
# ret:       ok(true) on success, or an error
pub fun phi_add_incoming(b: *Builder, phi: value.Value, source: id.BlockId, value_arg: value.Value) R.Result[bool, str] {
    if (b.fn == nil) {
        ret R.err[bool, str]("builder: phi_add_incoming with no current function");
    }
    if (phi.kind != value.VAL_INSTR) {
        ret R.err[bool, str]("builder: phi_add_incoming on a non-instruction value");
    }

    val iid: id.InstructionId = phi.data.instr;
    if (iid >= b.fn.instr_len) {
        ret R.err[bool, str]("builder: phi_add_incoming with stale phi id");
    }
    val ins: *instruction.Instruction = ?b.fn.instrs[iid];
    if (ins.kind != instruction.OP_PHI) {
        ret R.err[bool, str]("builder: phi_add_incoming on a non-phi instruction");
    }

    ret ir.phi_append_incoming(b.m, ins, source, value_arg);
}

# emit a call to `callee` with the given arguments
#
# The result type is the callee function type's return type, supplied by the
# caller as `ret_type` (IRT_VOID for a void call still yields a Value carrying
# the void type). Operand order is [callee, arg0, arg1, ...].
# ---
# b:         the builder
# callee:    function value (VAL_FN or a function-pointer value)
# args:      pointer to an array of argument values
# arg_count: number of arguments
# ret_type:  the call's result type
# ret:       a value naming the call result, or an error
pub fun emit_call(b: *Builder, callee: value.Value, args: *value.Value, arg_count: u32, ret_type: type.IrTypeId) R.Result[value.Value, str] {
    val total: u32 = arg_count + 1;
    val res_ops: R.Result[*value.Value, str] = A.allocate[value.Value](b.m.alloc, total::usize);
    if (R.is_err[*value.Value, str](res_ops)) {
        ret R.err[value.Value, str](R.unwrap_err[*value.Value, str](res_ops));
    }
    val ops: *value.Value = R.unwrap_ok[*value.Value, str](res_ops);
    ops[0] = callee;
    var i: u32 = 0;
    for (i < arg_count) {
        ops[1 + i] = args[i];
        i = i + 1;
    }

    val res_iid: R.Result[id.InstructionId, str] = emit_raw_owned(b, instruction.OP_CALL, ret_type, ops, total);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[value.Value, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);

    # stamp the callee's declared IRT_FN signature onto the call (aux_ty) so the
    # back end classifies the ABI from the declared signature, not from per-arg
    # operand types that can diverge. a direct call reads the callee function's
    # `sig`; an indirect (function-pointer) call's callee value already carries
    # the IRT_FN as its type.
    var sig: type.IrTypeId = callee.ty;
    if (callee.kind == value.VAL_FN && callee.data.fn_ix < b.m.function_len) {
        sig = b.m.functions[callee.data.fn_ix].sig;
    }
    b.fn.instrs[iid].aux_ty = sig;
    ret R.ok[value.Value, str](value.instr(iid, ret_type));
}

# emit an unconditional branch to `target`, terminating the current block and
# recording the edge in `target.preds`
# ---
# b:      the builder
# target: successor block
# ret:    ok(true) on success, or an error (e.g. block already terminated)
pub fun emit_br(b: *Builder, target: id.BlockId) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    val res_ptr: R.Result[type.IrTypeId, str] = ptr_type(b);
    if (R.is_err[type.IrTypeId, str](res_ptr)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_ptr));
    }
    val block_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_ptr);

    var ops: [1]value.Value;
    ops[0] = value.const_int(target::u64, block_ty);
    val res_iid: R.Result[id.InstructionId, str] = emit_terminator(b, instruction.OP_BR, void_ty, ?ops[0], 1);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    ret add_pred(b, target);
}

# emit a conditional branch: if `cond` is nonzero go to `then_b`, else `else_b`
#
# Terminates the current block and records both edges. Operand order is
# [cond, then, else].
# ---
# b:      the builder
# cond:   8-bit condition value
# then_b: taken successor
# else_b: untaken successor
# ret:    ok(true) on success, or an error
pub fun emit_cbr(b: *Builder, cond: value.Value, then_b: id.BlockId, else_b: id.BlockId) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    val res_ptr: R.Result[type.IrTypeId, str] = ptr_type(b);
    if (R.is_err[type.IrTypeId, str](res_ptr)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_ptr));
    }
    val block_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_ptr);

    var ops: [3]value.Value;
    ops[0] = cond;
    ops[1] = value.const_int(then_b::u64, block_ty);
    ops[2] = value.const_int(else_b::u64, block_ty);
    val res_iid: R.Result[id.InstructionId, str] = emit_terminator(b, instruction.OP_CBR, void_ty, ?ops[0], 3);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }

    val res_then: R.Result[bool, str] = add_pred(b, then_b);
    if (R.is_err[bool, str](res_then)) {
        ret res_then;
    }
    ret add_pred(b, else_b);
}

# emit a value-returning ret, terminating the current block
# ---
# b:         the builder
# value_arg: the value to return
# ret:       ok(true) on success, or an error
pub fun emit_ret(b: *Builder, value_arg: value.Value) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    var ops: [1]value.Value;
    ops[0] = value_arg;
    val res_iid: R.Result[id.InstructionId, str] = emit_terminator(b, instruction.OP_RET, void_ty, ?ops[0], 1);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    ret R.ok[bool, str](true);
}

# emit a void ret (no return value), terminating the current block
# ---
# b:   the builder
# ret: ok(true) on success, or an error
pub fun emit_ret_void(b: *Builder) R.Result[bool, str] {
    ret emit_void_terminator(b, instruction.OP_RET);
}

# emit an unreachable terminator, ending the current block
#
# Used after a noreturn call or as a fallthrough trap.
# ---
# b:   the builder
# ret: ok(true) on success, or an error
pub fun emit_unreachable(b: *Builder) R.Result[bool, str] {
    ret emit_void_terminator(b, instruction.OP_UNREACHABLE);
}

# emit an inline-asm instruction with the given operand values
#
# The asm body and operand descriptors are registered separately in
# `Function.asm_blocks` by the caller, keyed on the returned instruction id.
# Produces a void result. Operands are the values fed into the asm block, in
# source order.
# ---
# b:             the builder
# operands:      pointer to an array of input operand values
# operand_count: number of input operands
# ret:           the new OP_ASM instruction id (key into Function.asm_blocks), or an error
pub fun emit_asm(b: *Builder, operands: *value.Value, operand_count: u32) R.Result[id.InstructionId, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[id.InstructionId, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    if (operand_count == 0) {
        ret emit_raw(b, instruction.OP_ASM, void_ty, nil, 0);
    }

    val res_ops: R.Result[*value.Value, str] = A.allocate[value.Value](b.m.alloc, operand_count::usize);
    if (R.is_err[*value.Value, str](res_ops)) {
        ret R.err[id.InstructionId, str](R.unwrap_err[*value.Value, str](res_ops));
    }
    val ops: *value.Value = R.unwrap_ok[*value.Value, str](res_ops);
    var i: u32 = 0;
    for (i < operand_count) {
        ops[i] = operands[i];
        i = i + 1;
    }
    ret emit_raw_owned(b, instruction.OP_ASM, void_ty, ops, operand_count);
}

# emit an OP_DBG_VALUE binding the source variable (name, ty, scope) to `val`, its
# current SSA value; produces no value
#
# Records the variable identity in the current function's dbg_vars side table,
# keyed by the new instruction's id. The frontend emits this only under `-g`; it
# is pure debug metadata the back end skips, so it never affects emitted code. Its
# `val` operand is rewritten by RAUW like any other, so the debug value follows the
# SSA value it tracks across the optimizer.
# ---
# b:     the builder
# val:   the SSA value the variable currently holds
# name:  interned source variable name
# ty:    the variable's IR type
# scope: lexical scope id the variable is declared in
# ret:   ok(true) on success, or an error
pub fun emit_dbg_value(b: *Builder, val: value.Value, name: intern.StrId, ty: type.IrTypeId,
                       ty_sem: semtype.TypeId, is_param: bool, scope: u32) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    var ops: [1]value.Value;
    ops[0] = val;
    val res_iid: R.Result[id.InstructionId, str] = emit_raw(b, instruction.OP_DBG_VALUE, void_ty, ?ops[0], 1);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);

    var dv: ir.DbgVar;
    dv.name     = name;
    dv.ty       = ty;
    dv.ty_sem   = ty_sem;
    dv.is_param = is_param;
    dv.scope    = scope;
    ret map.insert[id.InstructionId, ir.DbgVar](?b.fn.dbg_vars, iid, dv);
}

# shared body for two-operand binary ops; result type follows lhs
# ---
# b:   the builder
# k:   the binary opcode to emit
# lhs: left operand
# rhs: right operand
# ret: a value naming the result, or an error
fun emit_binary(b: *Builder, k: instruction.InstrKind, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    var ops: [2]value.Value;
    ops[0] = lhs;
    ops[1] = rhs;
    ret emit_value_instr(b, k, lhs.ty, ?ops[0], 2);
}

# shared body for single-operand ops with an explicit result type
# ---
# b:       the builder
# k:       the unary opcode to emit
# operand: the sole operand
# ty:      the result type
# ret:     a value of type `ty`, or an error
fun emit_unary(b: *Builder, k: instruction.InstrKind, operand: value.Value, ty: type.IrTypeId) R.Result[value.Value, str] {
    var ops: [1]value.Value;
    ops[0] = operand;
    ret emit_value_instr(b, k, ty, ?ops[0], 1);
}

# shared body for comparisons; result is an interned 8-bit integer
# ---
# b:   the builder
# k:   the comparison opcode to emit
# lhs: left operand
# rhs: right operand
# ret: an 8-bit boolean value, or an error
fun emit_compare(b: *Builder, k: instruction.InstrKind, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    val res_bool: R.Result[type.IrTypeId, str] = type.intern_int(?b.m.types, 8);
    if (R.is_err[type.IrTypeId, str](res_bool)) {
        ret R.err[value.Value, str](R.unwrap_err[type.IrTypeId, str](res_bool));
    }
    val bool_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_bool);

    var ops: [2]value.Value;
    ops[0] = lhs;
    ops[1] = rhs;
    ret emit_value_instr(b, k, bool_ty, ?ops[0], 2);
}

# emit a comparison with an explicit result type, for a lane-wise vector compare
# whose result is the same-shape unsigned mask vector rather than an 8-bit
# boolean (#1965). reuses the OP_CMP_* opcodes; only the result type differs
# ---
# b:         the builder
# k:         the comparison opcode to emit
# lhs:       left operand
# rhs:       right operand
# result_ty: the mask vector result type
# ret:       a value of type `result_ty`, or an error
pub fun emit_vcompare(b: *Builder, k: instruction.InstrKind, lhs: value.Value, rhs: value.Value, result_ty: type.IrTypeId) R.Result[value.Value, str] {
    var ops: [2]value.Value;
    ops[0] = lhs;
    ops[1] = rhs;
    ret emit_value_instr(b, k, result_ty, ?ops[0], 2);
}

# shared body for a void terminator that carries no operands (ret-void,
# unreachable)
# ---
# b:   the builder
# k:   the terminator opcode to emit
# ret: ok(true) on success, or an error
fun emit_void_terminator(b: *Builder, k: instruction.InstrKind) R.Result[bool, str] {
    val res_void: R.Result[type.IrTypeId, str] = void_type(b);
    if (R.is_err[type.IrTypeId, str](res_void)) {
        ret R.err[bool, str](R.unwrap_err[type.IrTypeId, str](res_void));
    }
    val void_ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_void);

    val res_iid: R.Result[id.InstructionId, str] = emit_terminator(b, k, void_ty, nil, 0);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[bool, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    ret R.ok[bool, str](true);
}

# append a value-producing instruction whose operands live in a caller stack
# buffer (copied into owned storage), returning the result Value
# ---
# b:             the builder
# k:             the opcode to emit
# ty:            the result type
# ops:           pointer to the caller's stack operand buffer
# operand_count: number of operands in `ops`
# ret:           a value of type `ty`, or an error
fun emit_value_instr(b: *Builder, k: instruction.InstrKind, ty: type.IrTypeId, ops: *value.Value, operand_count: u32) R.Result[value.Value, str] {
    val res_iid: R.Result[id.InstructionId, str] = emit_raw(b, k, ty, ops, operand_count);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        ret R.err[value.Value, str](R.unwrap_err[id.InstructionId, str](res_iid));
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);
    ret R.ok[value.Value, str](value.instr(iid, ty));
}

# copy `operand_count` operands from a stack buffer into owned storage, append a
# new instruction to the pool, and link it into the current block's body
# ---
# b:             the builder
# k:             the opcode to emit
# ty:            the result type
# ops:           pointer to the caller's stack operand buffer
# operand_count: number of operands in `ops`
# ret:           the new instruction's id, or an error
fun emit_raw(b: *Builder, k: instruction.InstrKind, ty: type.IrTypeId, ops: *value.Value, operand_count: u32) R.Result[id.InstructionId, str] {
    if (operand_count == 0) {
        ret emit_raw_owned(b, k, ty, nil, 0);
    }
    val res_ops: R.Result[*value.Value, str] = A.allocate[value.Value](b.m.alloc, operand_count::usize);
    if (R.is_err[*value.Value, str](res_ops)) {
        ret R.err[id.InstructionId, str](R.unwrap_err[*value.Value, str](res_ops));
    }
    val owned: *value.Value = R.unwrap_ok[*value.Value, str](res_ops);
    var i: u32 = 0;
    for (i < operand_count) {
        owned[i] = ops[i];
        i = i + 1;
    }
    ret emit_raw_owned(b, k, ty, owned, operand_count);
}

# append a non-terminator instruction taking ownership of `owned` operands,
# linking it into the current block's body list
#
# On a guard or pool-append failure the operand array is released so the caller
# never leaks it. Once the pool entry exists, the operands belong to it and a
# later block-link failure leaves them for dnit_function to reclaim.
# ---
# b:             the builder
# k:             the opcode to emit
# ty:            the result type
# owned:         owned operand array (or nil for none), adopted on success
# operand_count: number of operands in `owned`
# ret:           the new instruction's id, or an error
fun emit_raw_owned(b: *Builder, k: instruction.InstrKind, ty: type.IrTypeId, owned: *value.Value, operand_count: u32) R.Result[id.InstructionId, str] {
    if (b.fn == nil) {
        dealloc_ops(b, owned, operand_count);
        ret R.err[id.InstructionId, str]("builder: emit with no current function");
    }
    if (b.block >= b.fn.block_count) {
        dealloc_ops(b, owned, operand_count);
        ret R.err[id.InstructionId, str]("builder: emit with invalid block cursor");
    }
    val blk: *ir.Block = ?b.fn.blocks[b.block];
    if (blk.terminator != id.INSTR_NIL) {
        dealloc_ops(b, owned, operand_count);
        ret R.err[id.InstructionId, str]("builder: emit into an already-terminated block");
    }

    val res_iid: R.Result[id.InstructionId, str] = pool_append(b, k, ty, owned, operand_count);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        dealloc_ops(b, owned, operand_count);
        ret res_iid;
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);

    # the operand array is now owned by the pool entry; a block-link failure
    # leaves the instruction (with its operands) in the pool for dnit_function
    # to reclaim -- do not free here.
    val res_link: R.Result[bool, str] = ir.block_append_instr(b.m, blk, iid);
    if (R.is_err[bool, str](res_link)) {
        ret R.err[id.InstructionId, str](R.unwrap_err[bool, str](res_link));
    }
    ret R.ok[id.InstructionId, str](iid);
}

# append a terminator instruction, recording it in `Block.terminator` rather
# than the body list
#
# Operands are copied from a stack buffer into owned storage. Rejects a second
# terminator. Successor pred-list updates are the caller's job.
# ---
# b:             the builder
# k:             the terminator opcode to emit
# ty:            the result type
# stack_ops:     pointer to the caller's stack operand buffer (or nil for none)
# operand_count: number of operands in `stack_ops`
# ret:           the new terminator's id, or an error
fun emit_terminator(b: *Builder, k: instruction.InstrKind, ty: type.IrTypeId, stack_ops: *value.Value, operand_count: u32) R.Result[id.InstructionId, str] {
    if (b.fn == nil)                 { ret R.err[id.InstructionId, str]("builder: terminator with no current function"); }
    if (b.block >= b.fn.block_count) { ret R.err[id.InstructionId, str]("builder: terminator with invalid block cursor"); }
    val blk: *ir.Block = ?b.fn.blocks[b.block];
    if (blk.terminator != id.INSTR_NIL) {
        ret R.err[id.InstructionId, str]("builder: block already has a terminator");
    }

    var owned: *value.Value = nil;
    if (operand_count > 0) {
        val res_ops: R.Result[*value.Value, str] = A.allocate[value.Value](b.m.alloc, operand_count::usize);
        if (R.is_err[*value.Value, str](res_ops)) {
            ret R.err[id.InstructionId, str](R.unwrap_err[*value.Value, str](res_ops));
        }
        owned = R.unwrap_ok[*value.Value, str](res_ops);
        var i: u32 = 0;
        for (i < operand_count) {
            owned[i] = stack_ops[i];
            i = i + 1;
        }
    }

    val res_iid: R.Result[id.InstructionId, str] = pool_append(b, k, ty, owned, operand_count);
    if (R.is_err[id.InstructionId, str](res_iid)) {
        dealloc_ops(b, owned, operand_count);
        ret res_iid;
    }
    val iid: id.InstructionId = R.unwrap_ok[id.InstructionId, str](res_iid);
    blk.terminator = iid;
    ret R.ok[id.InstructionId, str](iid);
}

# build a fresh Instruction record (owned operands) and append it to the pool
# through the single ir.instruction_add primitive
# ---
# b:             the builder
# k:             the opcode to record
# ty:            the result type
# operands:      owned operand array (or nil for none), sized to operand_count
# operand_count: number of operands in `operands`
# ret:           the new instruction's id, or an error
fun pool_append(b: *Builder, k: instruction.InstrKind, ty: type.IrTypeId, operands: *value.Value, operand_count: u32) R.Result[id.InstructionId, str] {
    var ins: instruction.Instruction;
    ins.kind          = k;
    ins.ty            = ty;
    ins.operands      = operands;
    ins.operand_count = operand_count;
    ins.operand_cap   = operand_count;          # `operands` is allocated to exactly this many here
    ins.flags         = 0;
    ins.aux_ty        = type.IRT_NIL;
    ins.loc           = b.loc;                   # stamp the current debug-location cursor
    ins.secret        = false;                   # public until the lowerer stamps taint (#1646)
    ret ir.instruction_add(b.m, b.fn, ins);
}

# record the current block as a predecessor of `target` via the single
# ir.block_append_pred primitive
#
# Validates the target is in range first -- branching to a nonexistent block is
# a builder bug.
# ---
# b:      the builder
# target: the successor block gaining the current block as a predecessor
# ret:    ok(true) on success, or an error
fun add_pred(b: *Builder, target: id.BlockId) R.Result[bool, str] {
    if (target >= b.fn.block_count) {
        ret R.err[bool, str]("builder: branch to out-of-range block");
    }
    ret ir.block_append_pred(b.m, ?b.fn.blocks[target], b.block);
}

# free an owned operand array; a no-op for the nil / empty array
# ---
# b:             the builder
# ops:           the operand array to release
# operand_count: number of operands the array was allocated for
fun dealloc_ops(b: *Builder, ops: *value.Value, operand_count: u32) {
    if (ops != nil && operand_count > 0) {
        A.deallocate[value.Value](b.m.alloc, ops, operand_count::usize);
    }
}

# intern and return the module's void IR type
# ---
# b:   the builder
# ret: the void IrTypeId, or an error
fun void_type(b: *Builder) R.Result[type.IrTypeId, str] {
    ret type.intern_void(?b.m.types);
}

# intern and return the module's pointer IR type
#
# Used for block-target and computed-address operands.
# ---
# b:   the builder
# ret: the pointer IrTypeId, or an error
fun ptr_type(b: *Builder) R.Result[type.IrTypeId, str] {
    ret type.intern_ptr(?b.m.types);
}

# pool_append stamps the builder's current debug-location cursor onto every
# emitted instruction, and set_function resets the cursor so a fresh function
# begins unlocated (FILE_NIL) rather than inheriting the previous one's location
test "mach.lang.me.ir.builder.pool_append:stamps_loc_cursor" {
    var alloc: A.Allocator;
    page.make(?alloc);

    val res_m: R.Result[ir.Module, str] = ir.init(?alloc, intern.STR_NIL);
    if (R.is_err[ir.Module, str](res_m)) { ret 1; }
    var m: ir.Module = R.unwrap_ok[ir.Module, str](res_m);

    val res_i64: R.Result[type.IrTypeId, str] = type.intern_int(?m.types, 64);
    if (R.is_err[type.IrTypeId, str](res_i64)) { ret 1; }
    val i64t: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_i64);

    val res_fn: R.Result[u32, str] = ir.function_add(?m, intern.STR_NIL, type.IRT_NIL, 0);
    if (R.is_err[u32, str](res_fn)) { ret 1; }
    val fn: *ir.Function = ?m.functions[R.unwrap_ok[u32, str](res_fn)];

    var b: Builder = init(?m);
    set_function(?b, fn);
    val res_blk: R.Result[id.BlockId, str] = new_block(?b);
    if (R.is_err[id.BlockId, str](res_blk)) { ret 1; }
    set_block(?b, R.unwrap_ok[id.BlockId, str](res_blk));

    # an instruction emitted under a set cursor carries that exact location
    set_loc(?b, source.loc(7, 42));
    val res_add: R.Result[value.Value, str] = emit_add(?b, value.const_int(1, i64t), value.const_int(2, i64t));
    if (R.is_err[value.Value, str](res_add)) { ret 1; }
    val add_id: id.InstructionId = R.unwrap_ok[value.Value, str](res_add).data.instr;
    if (fn.instrs[add_id::u32].loc.file != 7)    { ret 1; }
    if (fn.instrs[add_id::u32].loc.offset != 42) { ret 1; }

    # set_function resets the cursor: a new function starts unlocated
    val res_fn2: R.Result[u32, str] = ir.function_add(?m, intern.STR_NIL, type.IRT_NIL, 0);
    if (R.is_err[u32, str](res_fn2)) { ret 1; }
    val fn2: *ir.Function = ?m.functions[R.unwrap_ok[u32, str](res_fn2)];
    set_function(?b, fn2);
    if (source.loc_is_valid(current_loc(?b))) { ret 1; }

    ir.dnit(?m);
    ret 0;
}

# emit_dbg_value records the source variable in dbg_vars and binds it to a value
# operand, and RAUW (mutate.replace_uses) rewrites that operand like any other, so
# a debug value follows the SSA value it tracks
test "mach.lang.me.ir.builder.emit_dbg_value:records_and_rauw_moves" {
    var alloc: A.Allocator;
    page.make(?alloc);

    val res_m: R.Result[ir.Module, str] = ir.init(?alloc, intern.STR_NIL);
    if (R.is_err[ir.Module, str](res_m)) { ret 1; }
    var m: ir.Module = R.unwrap_ok[ir.Module, str](res_m);

    val res_i64: R.Result[type.IrTypeId, str] = type.intern_int(?m.types, 64);
    if (R.is_err[type.IrTypeId, str](res_i64)) { ret 1; }
    val i64t: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](res_i64);

    val res_fn: R.Result[u32, str] = ir.function_add(?m, intern.STR_NIL, type.IRT_NIL, 0);
    if (R.is_err[u32, str](res_fn)) { ret 1; }
    val fn: *ir.Function = ?m.functions[R.unwrap_ok[u32, str](res_fn)];

    var b: Builder = init(?m);
    set_function(?b, fn);
    val res_blk: R.Result[id.BlockId, str] = new_block(?b);
    if (R.is_err[id.BlockId, str](res_blk)) { ret 1; }
    set_block(?b, R.unwrap_ok[id.BlockId, str](res_blk));

    # a value to track, then a debug value binding a variable to it
    val res_add: R.Result[value.Value, str] = emit_add(?b, value.const_int(1, i64t), value.const_int(2, i64t));
    if (R.is_err[value.Value, str](res_add)) { ret 1; }
    val v: value.Value = R.unwrap_ok[value.Value, str](res_add);
    val v_id: id.InstructionId = v.data.instr;

    if (R.is_err[bool, str](emit_dbg_value(?b, v, intern.STR_NIL, i64t, semtype.TYPE_NIL, false, 0))) { ret 1; }

    # the OP_DBG_VALUE is the last-appended instruction; its operand is v
    val dbg_id: u32 = fn.instr_len - 1;
    val dbg: *instruction.Instruction = ?fn.instrs[dbg_id];
    if (dbg.kind != instruction.OP_DBG_VALUE)    { ret 1; }
    if (dbg.operand_count != 1)                  { ret 1; }
    if (dbg.operands[0].kind != value.VAL_INSTR) { ret 1; }
    if (dbg.operands[0].data.instr != v_id)      { ret 1; }

    # the variable identity is recorded in dbg_vars
    var key: id.InstructionId = dbg_id::id.InstructionId;
    if (R.is_err[*ir.DbgVar, str](map.get[id.InstructionId, ir.DbgVar](?fn.dbg_vars, ?key))) { ret 1; }

    # RAUW replaces v with param 0; the debug value's operand moves with it
    mutate.replace_uses(fn, v_id, value.param(0, i64t));
    val dbg2: *instruction.Instruction = ?fn.instrs[dbg_id];
    if (dbg2.operands[0].kind != value.VAL_PARAM) { ret 1; }
    if (dbg2.operands[0].data.param_ix != 0)      { ret 1; }

    ir.dnit(?m);
    ret 0;
}
