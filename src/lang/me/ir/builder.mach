# mach.lang.me.ir.builder: IR construction helper.
#
# A `Builder` carries an insertion cursor (the
# current module, function, and block) and exposes one emitter per
# `InstrKind`. Each emitter appends a fresh `Instruction` to the function's
# instruction pool, links its id into the current block, and hands back a
# `Value` naming the result (or `ok(true)` for void-producing emitters).
#
# Storage model: instructions live in a flat per-`Function` pool
# (`Function.instrs`); an `InstructionId` is an index into that pool, so
# `Value.data.instr` and `Block.instructions` are stable handles for the
# function's lifetime. The builder owns the growth of the pool, of each
# block's instruction / phi / pred arrays, and of every instruction's operand
# array.
#
# Terminator emitters (`emit_br` / `emit_cbr` / `emit_ret` /
# `emit_unreachable`) additionally record the control-flow edge by appending
# the current block to each successor's predecessor list. A block accepts
# exactly one terminator; a second terminator emission is rejected with an
# error rather than silently overwriting the first.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.allocate;
use std.allocator.reallocate;
use std.allocator.deallocate;

use ir:      mach.lang.me.ir;
use instr:   mach.lang.me.ir.instruction;
use value:   mach.lang.me.ir.value;
use ir_type: mach.lang.me.ir.type;
use id:      mach.lang.me.ir.id;

val INITIAL_INSTR_CAP:      u32 = 64;
val INITIAL_BLOCK_BODY_CAP: u32 = 8;
val INITIAL_PHI_CAP:        u32 = 4;
val INITIAL_PRED_CAP:       u32 = 4;
val INITIAL_BLOCK_CAP:      u32 = 4;

# an insertion cursor over an IR module.
# ---
# m:     the module being built (owns the instruction pool growth via fn)
# fn:    the function currently being emitted into (nil until set_function)
# block: the block id new instructions land in (BLOCK_NIL until set_block)
pub rec Builder {
    m:     *ir.Module;
    fn:    *ir.Function;
    block: id.BlockId;
}

# constructs a builder positioned on a module with no current function. the
# caller must `set_function` and `set_block` before emitting.
# ---
# m:   the module to build into
# ret: a Builder with fn = nil and a BLOCK_NIL block cursor
pub fun init(m: *ir.Module) Builder {
    var b: Builder;
    b.m     = m;
    b.fn    = nil;
    b.block = id.BLOCK_NIL;
    ret b;
}

# moves the cursor to a function; clears the block cursor.
# ---
# b:  the builder
# fn: the function to emit into
pub fun set_function(b: *Builder, fn: *ir.Function) {
    b.fn    = fn;
    b.block = id.BLOCK_NIL;
}

# moves the cursor to a block within the current function.
# ---
# b:   the builder
# blk: the block instructions will be appended to
pub fun set_block(b: *Builder, blk: id.BlockId) {
    b.block = blk;
}

# allocates a fresh empty block in the current function and returns its id.
# does not move the cursor. the new block has no instructions, no phis, no
# predecessors, and an INSTR_NIL terminator.
# ---
# b:   the builder (must have a current function)
# ret: the new block's id, or an allocation / state error
pub fun new_block(b: *Builder) Result[id.BlockId, str] {
    if (b.fn == nil) { ret err[id.BlockId, str]("builder: new_block with no current function"); }
    val fn: *ir.Function = b.fn;

    if (fn.block_count == fn.block_cap) {
        val gr: Result[bool, str] = grow_blocks(b);
        if (is_err[bool, str](gr)) { ret err[id.BlockId, str](unwrap_err[bool, str](gr)); }
    }

    val bid: id.BlockId = fn.block_count;
    var blk: ir.Block;
    blk.id           = bid;
    blk.instructions = nil;
    blk.instr_count  = 0;
    blk.instr_cap    = 0;
    blk.phis         = nil;
    blk.phi_count    = 0;
    blk.phi_cap      = 0;
    blk.terminator   = id.INSTR_NIL;
    blk.preds        = nil;
    blk.pred_count   = 0;
    blk.pred_cap     = 0;
    fn.blocks[bid]   = blk;
    fn.block_count   = bid + 1;
    ret ok[id.BlockId, str](bid);
}

# emits an integer addition `lhs + rhs`.
# ---
# b:   the builder
# lhs: left operand
# rhs: right operand
# ret: a value naming the sum, or an error
pub fun emit_add(b: *Builder, lhs: value.Value, rhs: value.Value) Result[value.Value, str] {
    ret emit_binary(b, instr.OP_ADD, lhs, rhs);
}

# emits an integer subtraction `lhs - rhs`.
# ---
# b:   the builder
# lhs: left operand
# rhs: right operand
# ret: a value naming the difference, or an error
pub fun emit_sub(b: *Builder, lhs: value.Value, rhs: value.Value) Result[value.Value, str] {
    ret emit_binary(b, instr.OP_SUB, lhs, rhs);
}

