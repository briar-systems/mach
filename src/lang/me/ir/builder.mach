# IR construction cursor
#
# A `Builder` carries an insertion cursor (the current module, function, and
# block) and exposes one emitter per `InstrKind`. Each emitter appends a fresh
# `Instruction` to the function's instruction pool, links its id into the
# current block, and hands back a `Value` naming the result (or `ok(true)` for
# void-producing emitters).
#
# Storage model: instructions live in a flat per-`Function` pool
# (`Function.instrs`); an `InstructionId` is an index into that pool, so
# `Value.data.instr` and `Block.instructions` are stable handles for the
# function's lifetime. All storage growth -- the pool, each block's
# instruction / phi / pred arrays, and every instruction's operand array --
# goes through the `ir.mach` primitives (`block_add`, `instruction_add`,
# `block_append_*`, `phi_append_incoming`), so the capacity invariants live in
# exactly one place.
#
# Terminator emitters (`emit_br` / `emit_cbr` / `emit_ret` / `emit_unreachable`)
# additionally record the control-flow edge by appending the current block to
# each successor's predecessor list. A block accepts exactly one terminator; a
# second terminator emission is rejected with an error rather than silently
# overwriting the first.

use std.allocator.page;
use std.collections.map;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use R: std.types.result;

use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.ir.id;
use mach.lang.me.ir.instruction;
use mach.lang.me.ir.mutate;
use mach.lang.me.ir.type;
use mach.lang.me.ir.value;
use mach.lang.source;

use semtype: mach.lang.type;

# an insertion cursor over an IR module
# ---
# m:     the module being built (owns instruction-pool growth via its functions)
# fn:    the function currently being emitted into (nil until set_function)
# block: the block new instructions land in (BLOCK_NIL until set_block)
# loc:   current debug-location cursor stamped onto every emitted instruction;
#        FILE_NIL until set_loc, and reset to FILE_NIL on each set_function so a
#        new function's prologue never inherits a stale location
pub rec Builder {
    m:     *ir.Module;
    fn:    *ir.Function;
    block: id.BlockId;
    loc:   source.SrcLoc;
}

# construct a builder positioned on a module with no current function
#
# The caller must `set_function` and `set_block` before emitting.
# ---
# m:   the module to build into
# ret: a Builder with fn = nil, a BLOCK_NIL block cursor, and an empty loc cursor
pub fun init(m: *ir.Module) Builder {
    var b: Builder;
    b.m     = m;
    b.fn    = nil;
    b.block = id.BLOCK_NIL;
    b.loc   = source.loc_nil();
    ret b;
}

# move the cursor to a function, clearing the block and location cursors
# ---
# b:  the builder
# fn: the function to emit into
pub fun set_function(b: *Builder, fn: *ir.Function) {
    b.fn    = fn;
    b.block = id.BLOCK_NIL;
    b.loc   = source.loc_nil();
}

# set the current debug-location cursor stamped onto subsequently emitted
# instructions; the frontend updates it per statement / expression
# ---
# b:   the builder
# loc: the source location to stamp
pub fun set_loc(b: *Builder, loc: source.SrcLoc) {
    b.loc = loc;
}

# read the current debug-location cursor, so a caller can save and later restore
# it around a nested lowering
# ---
# b:   the builder
# ret: the current location cursor
pub fun current_loc(b: *Builder) source.SrcLoc {
    ret b.loc;
}

# move the cursor to a block within the current function
# ---
# b:   the builder
# blk: the block instructions will be appended to
pub fun set_block(b: *Builder, blk: id.BlockId) {
    b.block = blk;
}

# allocate a fresh empty block in the current function and return its id
#
# Does not move the cursor. The new block has no instructions, no phis, no
# predecessors, and an INSTR_NIL terminator.
# ---
# b:   the builder (must have a current function)
# ret: the new block's id, or an allocation / state error
pub fun new_block(b: *Builder) R.Result[id.BlockId, str] {
    if (b.fn == nil) {
        ret R.err[id.BlockId, str]("builder: new_block with no current function");
    }
    ret ir.block_add(b.m, b.fn);
}

# emit an integer addition `lhs + rhs`
# ---
# b:   the builder
# lhs: left operand
# rhs: right operand
# ret: a value naming the sum, or an error
pub fun emit_add(b: *Builder, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    ret emit_binary(b, instruction.OP_ADD, lhs, rhs);
}

# emit an integer subtraction `lhs - rhs`
# ---
# b:   the builder
# lhs: left operand
# rhs: right operand
# ret: a value naming the difference, or an error
pub fun emit_sub(b: *Builder, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    ret emit_binary(b, instruction.OP_SUB, lhs, rhs);
}

# emit an integer multiplication `lhs * rhs`
