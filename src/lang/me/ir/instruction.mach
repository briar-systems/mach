# mach.lang.me.ir.instruction: the IR instruction set.
#
# An `Instruction` is an opcode plus a flat list of
# `Value` operands, a result type, the block it lives in, and a flag word.
# Instructions are SSA: a non-void instruction defines exactly one value,
# referenced elsewhere by an `InstructionId` wrapped in a `VAL_INSTR` Value.
#
# Operand conventions per opcode (the list is positional):
#   STORE  = [value, ptr]
#   GEP    = [base, idx0, idx1, ...]
#   PHI    = [block0, val0, block1, val1, ...]   (block ids ride in val slots)
#   CALL   = [callee, arg0, arg1, ...]
#   CBR    = [cond, then, else]                  (then/else are block targets)
#   BR     = [target]
#   RET    = [value] or []                       (empty for void return)
#
# Signedness modelling: there is no 1-bit type and no separate signed integer
# type. Division/remainder/shift/compare carry their signedness in the opcode
# (DIV_S vs DIV_U, CMP_LT_S vs CMP_LT_U, ...). Comparisons produce an 8-bit
# IRT_INT result.
#
# Variadic intrinsics are dedicated opcodes (`OP_VA_START`/`OP_VA_ARG`/
# `OP_VA_END`), each taking a single va_list-pointer operand, expanded by the
# backend during MIR lowering using the active ABI's register-save layout.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;

use value:   mach.lang.me.ir.value;
use ir_type: mach.lang.me.ir.type;

# the opcode of an instruction; selects operand interpretation and result type.
pub def InstrKind: u8;

# integer addition; operands [lhs, rhs].
pub val OP_ADD:         InstrKind = 0;
# integer subtraction; operands [lhs, rhs].
pub val OP_SUB:         InstrKind = 1;
# integer multiplication; operands [lhs, rhs].
pub val OP_MUL:         InstrKind = 2;
# signed integer division; operands [lhs, rhs].
pub val OP_DIV_S:       InstrKind = 3;
# unsigned integer division; operands [lhs, rhs].
pub val OP_DIV_U:       InstrKind = 4;
# signed remainder; operands [lhs, rhs].
pub val OP_REM_S:       InstrKind = 5;
# unsigned remainder; operands [lhs, rhs].
pub val OP_REM_U:       InstrKind = 6;
# integer negation; operands [operand].
pub val OP_NEG:         InstrKind = 7;

# bitwise and; operands [lhs, rhs].
pub val OP_AND:         InstrKind = 8;
# bitwise or; operands [lhs, rhs].
pub val OP_OR:          InstrKind = 9;
# bitwise xor; operands [lhs, rhs].
pub val OP_XOR:         InstrKind = 10;
# shift left; operands [lhs, rhs].
pub val OP_SHL:         InstrKind = 11;
# arithmetic (sign-preserving) shift right; operands [lhs, rhs].
pub val OP_SHR_S:       InstrKind = 12;
# logical (zero-filling) shift right; operands [lhs, rhs].
pub val OP_SHR_U:       InstrKind = 13;
# bitwise not; operands [operand].
pub val OP_NOT:         InstrKind = 14;

# equality comparison; operands [lhs, rhs]; result is an 8-bit IRT_INT.
pub val OP_CMP_EQ:      InstrKind = 15;
# inequality comparison; operands [lhs, rhs]; result is an 8-bit IRT_INT.
pub val OP_CMP_NE:      InstrKind = 16;
# signed less-than; operands [lhs, rhs]; result is an 8-bit IRT_INT.
pub val OP_CMP_LT_S:    InstrKind = 17;
# unsigned less-than; operands [lhs, rhs]; result is an 8-bit IRT_INT.
pub val OP_CMP_LT_U:    InstrKind = 18;
# signed less-or-equal; operands [lhs, rhs]; result is an 8-bit IRT_INT.
pub val OP_CMP_LE_S:    InstrKind = 19;
# unsigned less-or-equal; operands [lhs, rhs]; result is an 8-bit IRT_INT.
pub val OP_CMP_LE_U:    InstrKind = 20;

# integer truncation to a narrower width; operands [operand].
pub val OP_TRUNC:       InstrKind = 21;
# integer sign extension to a wider width; operands [operand].
pub val OP_SEXT:        InstrKind = 22;
# integer zero extension to a wider width; operands [operand].
pub val OP_ZEXT:        InstrKind = 23;
# float truncation (f64 to f32); operands [operand].
pub val OP_FP_TRUNC:    InstrKind = 24;
# float extension (f32 to f64); operands [operand].
pub val OP_FP_EXT:      InstrKind = 25;
# float to signed integer; operands [operand].
pub val OP_FP_TO_SI:    InstrKind = 26;
# float to unsigned integer; operands [operand].
pub val OP_FP_TO_UI:    InstrKind = 27;
# signed integer to float; operands [operand].
pub val OP_SI_TO_FP:    InstrKind = 28;
# unsigned integer to float; operands [operand].
pub val OP_UI_TO_FP:    InstrKind = 29;
# same-size bit reinterpretation; operands [operand].
pub val OP_BITCAST:     InstrKind = 30;

# stack allocation; operands [count]; result is a pointer to the slot.
pub val OP_ALLOCA:      InstrKind = 31;
# load from a pointer; operands [ptr]; result is the loaded value.
pub val OP_LOAD:        InstrKind = 32;
# store to a pointer; operands [value, ptr]; produces no value.
pub val OP_STORE:       InstrKind = 33;
# address computation; operands [base, idx0, ...]; result is a pointer.
pub val OP_GEP:         InstrKind = 34;

# extract an element from an aggregate; operands [agg, index].
pub val OP_EXTRACT:     InstrKind = 35;
# insert an element into an aggregate; operands [agg, index, element].
pub val OP_INSERT:      InstrKind = 36;

# SSA join; operands [block0, val0, ...].
pub val OP_PHI:         InstrKind = 37;
# call; operands [callee, arg0, ...].
pub val OP_CALL:        InstrKind = 38;
# unconditional branch; operands [target].
pub val OP_BR:          InstrKind = 39;
# conditional branch; operands [cond, then, else].
pub val OP_CBR:         InstrKind = 40;
# return; operands [value] or [].
pub val OP_RET:         InstrKind = 41;
# trap / unreachable terminator; no operands.
pub val OP_UNREACHABLE: InstrKind = 42;

# inline assembly; the body and operands live in Function.asm_blocks keyed by id.
pub val OP_ASM:         InstrKind = 43;

# zero-fill a memory region; operand [ptr]; produces no value. `aux_ty` carries
# the pointee type whose `byte_size` is the number of bytes zeroed (used to
# zero-initialize an aggregate local that has no initializer). a scalar local
# is zeroed with an ordinary typed OP_STORE of a zero constant instead, so this
# opcode is reserved for record / union / array slots.
pub val OP_MEMZERO:     InstrKind = 44;

# initialize a `va_list`; operand [ap_ptr]; produces no value. the backend
# expands it to the SysV register-save-area setup (gp_offset / fp_offset,
# reg_save_area, overflow_arg_area). `ap_ptr` points at the va_list storage.
pub val OP_VA_START:    InstrKind = 45;
# fetch the next variadic argument; operand [ap_ptr]; result is the value of the
# instruction's result type. the backend pulls the argument from the register-
# save area or the overflow area per the active ABI and advances the cursor.
pub val OP_VA_ARG:      InstrKind = 46;
# finalize a `va_list`; operand [ap_ptr]; produces no value. a no-op on SysV.
pub val OP_VA_END:      InstrKind = 47;

# no-signed-wrap: the result is poison if signed overflow occurs.
pub val INSTR_FLAG_NSW:      u16 = 0x01;
# no-unsigned-wrap: the result is poison if unsigned overflow occurs.
pub val INSTR_FLAG_NUW:      u16 = 0x02;
# exact: a division/shift is known to be exact (no remainder / no truncation).
pub val INSTR_FLAG_EXACT:    u16 = 0x04;
# volatile: a load/store must not be elided or reordered (kept by DCE).
pub val INSTR_FLAG_VOLATILE: u16 = 0x08;

# one SSA instruction.
# ---
# kind:          the opcode
# ty:            result IR type (IRT_VOID for terminators and stores)
# operands:      pointer to a contiguous array of operand Values (owned)
# operand_count: number of live operands; the prefix of `operands` in use. a pass
#                may shrink this in place (a CBR folded to a BR, a phi compacted to
#                its surviving incomings) without reallocating, so it is NOT the
#                allocation size — see `operand_cap`.
# operand_cap:   allocated element capacity of `operands` (the true allocation
#                size). teardown frees `operand_cap` values, so the free size never
#                depends on a count a pass may have shrunk. any code that allocates
#                or grows `operands` must set this to the allocation size; a pass
#                that only shrinks `operand_count` leaves it untouched.
#                note: an instruction does NOT record its owning block — block
#                membership lives solely in the Block lists (the liveness source
#                of truth); a consumer needing placement derives it from them.
# flags:         bitwise-or of INSTR_FLAG_* modifiers
# aux_ty:        opcode-specific auxiliary type, used by the opcodes whose base
#                pointer / result slot cannot itself carry the type the back end
#                needs. for OP_GEP it is the source pointee the index walk starts
#                from (the untyped IRT_PTR base supplies no element/field sizes).
#                for OP_MEMZERO it is the aggregate pointee whose `byte_size` is
#                the number of bytes zeroed. for OP_CALL it is the callee's
#                IRT_FN signature, stamped so the back end classifies the ABI
#                from the declaration rather than from per-arg operand types.
#                IRT_NIL for every other opcode. OP_ALLOCA is the one exception
#                that instead overloads `ty` to carry its allocated element type
#                (its result Value is the IRT_PTR); see emit_alloca.
pub rec Instruction {
    kind:          InstrKind;
    ty:            ir_type.IrTypeId;
    operands:      *value.Value;
    operand_count: u32;
    operand_cap:   u32;
    flags:         u16;
    aux_ty:        ir_type.IrTypeId;
}

# true when the opcode ends a block (BR/CBR/RET/UNREACHABLE). every block
# must end in exactly one terminator.
# ---
# k:   an opcode
# ret: true if k is a block terminator
pub fun is_terminator(k: InstrKind) bool {
    if (k == OP_BR)          { ret true; }
    if (k == OP_CBR)         { ret true; }
    if (k == OP_RET)         { ret true; }
    if (k == OP_UNREACHABLE) { ret true; }
    ret false;
}

# true when the opcode has no side effects and depends only on its operands,
# so it may be freely eliminated when unused or hoisted. Memory writes,
# loads, calls, control flow, alloca, and inline asm are NOT pure. Used by
# dce and mem2reg. Note: volatility lives on the instruction's flags, so a
# caller treating OP_LOAD must still honour INSTR_FLAG_VOLATILE.
# ---
# k:   an opcode
# ret: true if k is a pure (side-effect-free, value-producing) operation
pub fun is_pure(k: InstrKind) bool {
    if (is_terminator(k)) { ret false; }
    if (k == OP_STORE)    { ret false; }
    if (k == OP_MEMZERO)  { ret false; }
    if (k == OP_LOAD)     { ret false; }
    if (k == OP_CALL)     { ret false; }
    if (k == OP_ALLOCA)   { ret false; }
    if (k == OP_ASM)      { ret false; }
    if (k == OP_PHI)      { ret false; }
    # the variadic intrinsics mutate the va_list cursor / save area; they must
    # not be eliminated or reordered.
    if (k == OP_VA_START) { ret false; }
    if (k == OP_VA_ARG)   { ret false; }
    if (k == OP_VA_END)   { ret false; }
    ret true;
}
