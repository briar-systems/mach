    if (t_count(?env, true, false, VC_DOMINANCE) < 1) { ret 1; }
    ret 0;
}

# a dead cycle whose blocks each have a predecessor but no entry path is flagged
# unreachable; a pred-count test would wrongly accept it.
test "mach.lang.me.ir.verify.check_reachability:dead_cycle" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    val b1: id.BlockId = t_block(?env);
    val b2: id.BlockId = t_block(?env);
    if (b2 != 2) { ret 1; }

    builder.set_block(?env.bld, b0);
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld))) { ret 1; }
    builder.set_block(?env.bld, b1);
    if (R.is_err[bool, str](builder.emit_br(?env.bld, b2))) { ret 1; }
    builder.set_block(?env.bld, b2);
    if (R.is_err[bool, str](builder.emit_br(?env.bld, b1))) { ret 1; }

    if (t_count(?env, true, false, VC_REACHABILITY) < 2) { ret 1; }
    ret 0;
}

# a terminator id past the end of the instruction pool is flagged, not read out
# of bounds.
test "mach.lang.me.ir.verify.check_block_lists:dangling_terminator" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    if (b0 != 0) { ret 1; }
    builder.set_block(?env.bld, b0);
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld))) { ret 1; }

    # point the terminator slot at an id past the end of the pool.
    env.m.functions[0].blocks[0].terminator = env.m.functions[0].instr_len + 100;
    if (t_count(?env, false, false, VC_DANGLING_ID) < 1) { ret 1; }
    ret 0;
}

# a right-length but wrong-member pred list is caught by the multiset compare; a
# count-only test would pass it.
test "mach.lang.me.ir.verify.check_pred_consistency:wrong_member" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    val b1: id.BlockId = t_block(?env);
    val b2: id.BlockId = t_block(?env);
    val b3: id.BlockId = t_block(?env);
    if (b3 != 3) { ret 1; }

    builder.set_block(?env.bld, b0);
    if (R.is_err[bool, str](builder.emit_cbr(?env.bld, t_ci(?env, 1), b1, b2))) { ret 1; }
    builder.set_block(?env.bld, b1);
    if (R.is_err[bool, str](builder.emit_br(?env.bld, b3))) { ret 1; }
    builder.set_block(?env.bld, b2);
    if (R.is_err[bool, str](builder.emit_br(?env.bld, b3))) { ret 1; }
    builder.set_block(?env.bld, b3);
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld))) { ret 1; }

    # block 3's preds are {1, 2}; rewrite to {1, 1} - same length, wrong members.
    env.m.functions[0].blocks[3].preds[1] = 1::id.BlockId;
    if (t_count(?env, false, false, VC_PRED_CONSISTENT) < 1) { ret 1; }
    ret 0;
}

# repr rejects a non-address-producing add result reinterpreted as a struct
# operand; the always-on (repr=false) run does not.
test "mach.lang.me.ir.verify.agg_value_is_address_producing:add_result" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }

    val sr: R.Result[type.IrTypeId, str] = type.intern_struct(?env.m.types, ?env.i64ty, 1, 0);
    if (R.is_err[type.IrTypeId, str](sr)) { ret 1; }
    val stty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](sr);

    val b0: id.BlockId = t_block(?env);
    if (b0 != 0) { ret 1; }
    builder.set_block(?env.bld, b0);

    # alloca a struct slot - the store needs an address-typed destination.
    val ar: R.Result[value.Value, str] = builder.emit_alloca(?env.bld, stty, t_ci(?env, 1));
    if (R.is_err[value.Value, str](ar)) { ret 1; }
    val aptr: value.Value = R.unwrap_ok[value.Value, str](ar);

    # add(c0, c0): a pure arithmetic result, not address-producing.
    val c0: value.Value = t_ci(?env, 0);
    val addv: R.Result[value.Value, str] = builder.emit_add(?env.bld, c0, c0);
    if (R.is_err[value.Value, str](addv)) { ret 1; }
    val add_val: value.Value = R.unwrap_ok[value.Value, str](addv);

    # retype the add result to the struct type: VAL_INSTR with ty=stty from OP_ADD.
    val struct_add: value.Value = value.retype(add_val, stty);

    if (R.is_err[bool, str](builder.emit_store(?env.bld, struct_add, aptr))) { ret 1; }
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld)))                { ret 1; }

    if (t_count(?env, false, true, VC_AGG_ADDRESS) < 1)   { ret 1; }
    if (t_count(?env, false, false, VC_AGG_ADDRESS) != 0) { ret 1; }
    ret 0;
}

# rebuild_preds reproduces both edges of a cbr whose arms target the same block,
# so the rebuilt pred multiset stays consistent.
test "mach.lang.me.ir.verify.check_pred_consistency:same_target_cbr" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    val b1: id.BlockId = t_block(?env);
    if (b1 != 1) { ret 1; }

    builder.set_block(?env.bld, b0);
    # both arms of the cbr target b1: two incoming edges from b0.
    if (R.is_err[bool, str](builder.emit_cbr(?env.bld, t_ci(?env, 1), b1, b1))) { ret 1; }
    builder.set_block(?env.bld, b1);
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld))) { ret 1; }

    if (R.is_err[bool, str](ir.preds_rebuild(?env.m, ?env.m.functions[0]))) { ret 1; }
    if (t_count(?env, false, false, VC_PRED_CONSISTENT) != 0)               { ret 1; }
    if (env.m.functions[0].blocks[1].pred_count != 2)                       { ret 1; }
    ret 0;
}

# repr rejects an add whose two operands carry mismatched widths; the always-on
# run does not.
test "mach.lang.me.ir.verify.check_type_agree:binary_mismatch" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    if (b0 != 0) { ret 1; }
    val i32r: R.Result[type.IrTypeId, str] = type.intern_int(?env.m.types, 32);
    if (R.is_err[type.IrTypeId, str](i32r)) { ret 1; }
    val i32ty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](i32r);

    builder.set_block(?env.bld, b0);
    # add of an i64 and an i32 operand: the builder copies the result type from
    # lhs without checking the operands agree.
    if (R.is_err[value.Value, str](builder.emit_add(?env.bld, t_ci(?env, 0), value.const_int(0, i32ty)))) { ret 1; }
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld)))                                             { ret 1; }

    if (t_count(?env, false, true, VC_TYPE_AGREE) < 1)   { ret 1; }
    if (t_count(?env, false, false, VC_TYPE_AGREE) != 0) { ret 1; }
    ret 0;
}

# repr rejects a store whose destination operand is an integer, not an address.
test "mach.lang.me.ir.verify.check_type_agree:store_non_pointer" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    if (b0 != 0) { ret 1; }
    builder.set_block(?env.bld, b0);
    if (R.is_err[bool, str](builder.emit_store(?env.bld, t_ci(?env, 1), t_ci(?env, 0)))) { ret 1; }
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld)))                            { ret 1; }

    if (t_count(?env, false, true, VC_TYPE_AGREE) < 1) { ret 1; }
    ret 0;
}

# repr flags an alloca whose element type (carried in aux_ty) was corrupted to an
# out-of-range, non-sentinel id.
test "mach.lang.me.ir.verify.check_aux_resolve:alloca_element" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val b0: id.BlockId = t_block(?env);
    if (b0 != 0) { ret 1; }
    builder.set_block(?env.bld, b0);
    val ar: R.Result[value.Value, str] = builder.emit_alloca(?env.bld, env.i64ty, t_ci(?env, 1));
    if (R.is_err[value.Value, str](ar)) { ret 1; }
    val av: value.Value = R.unwrap_ok[value.Value, str](ar);
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld))) { ret 1; }

    # well-formed: the element type resolves.
    if (t_count(?env, false, true, VC_TYPE_RESOLVE) != 0) { ret 1; }
    # corrupt the element type to an out-of-range, non-sentinel id.
    val aid: id.InstructionId = av.data.instr;
    env.m.functions[0].instrs[aid].aux_ty = 0xFFFF::type.IrTypeId;
    if (t_count(?env, false, true, VC_TYPE_RESOLVE) < 1) { ret 1; }
    ret 0;
}

# repr accepts an aggregate-typed phi that merges two arms' return-storage
# pointers and is then consumed as an aggregate operand.
test "mach.lang.me.ir.verify.agg_value_is_address_producing:return_phi" {
    var env: TEnv;
    if (!t_env(?env)) { ret 1; }
    val agr: R.Result[type.IrTypeId, str] = type.intern_array(?env.m.types, env.i64ty, 4);
    if (R.is_err[type.IrTypeId, str](agr)) { ret 1; }
    val aggty: type.IrTypeId = R.unwrap_ok[type.IrTypeId, str](agr);

    val b0: id.BlockId = t_block(?env);
    val b1: id.BlockId = t_block(?env);
    val b2: id.BlockId = t_block(?env);
    val b3: id.BlockId = t_block(?env);
    if (b0 != 0 || b1 != 1 || b2 != 2 || b3 != 3) { ret 1; }

    # entry: a slot to store into, then a two-way branch into the diamond arms.
    builder.set_block(?env.bld, b0);
    val a0r: R.Result[value.Value, str] = builder.emit_alloca(?env.bld, aggty, t_ci(?env, 1));
    if (R.is_err[value.Value, str](a0r)) { ret 1; }
    val a0: value.Value = R.unwrap_ok[value.Value, str](a0r);
    if (R.is_err[bool, str](builder.emit_cbr(?env.bld, t_ci(?env, 1), b1, b2))) { ret 1; }

    # each arm allocates aggregate return storage and branches to the join.
    builder.set_block(?env.bld, b1);
    val a1r: R.Result[value.Value, str] = builder.emit_alloca(?env.bld, aggty, t_ci(?env, 1));
    if (R.is_err[value.Value, str](a1r)) { ret 1; }
    val a1: value.Value = R.unwrap_ok[value.Value, str](a1r);
    if (R.is_err[bool, str](builder.emit_br(?env.bld, b3))) { ret 1; }

    builder.set_block(?env.bld, b2);
    val a2r: R.Result[value.Value, str] = builder.emit_alloca(?env.bld, aggty, t_ci(?env, 1));
    if (R.is_err[value.Value, str](a2r)) { ret 1; }
    val a2: value.Value = R.unwrap_ok[value.Value, str](a2r);
    if (R.is_err[bool, str](builder.emit_br(?env.bld, b3))) { ret 1; }

    # join: an aggregate-typed phi merges the two arms' storage pointers, then it
    # is consumed as an aggregate operand.
    builder.set_block(?env.bld, b3);
    val pr: R.Result[value.Value, str] = builder.emit_phi(?env.bld, aggty);
    if (R.is_err[value.Value, str](pr)) { ret 1; }
    val phi: value.Value = R.unwrap_ok[value.Value, str](pr);
    if (R.is_err[bool, str](builder.phi_add_incoming(?env.bld, phi, b1, value.retype(a1, aggty)))) { ret 1; }
    if (R.is_err[bool, str](builder.phi_add_incoming(?env.bld, phi, b2, value.retype(a2, aggty)))) { ret 1; }
    if (R.is_err[bool, str](builder.emit_store(?env.bld, value.retype(phi, aggty), a0)))           { ret 1; }
    if (R.is_err[bool, str](builder.emit_ret_void(?env.bld)))                                      { ret 1; }

    if (t_count(?env, false, true, VC_AGG_ADDRESS) != 0) { ret 1; }
    ret 0;
}
