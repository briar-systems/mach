# mach.lang.me.lower.context: per-module lowering state and accessor API.
#
# `LowerContext` (and the loop / fin / locals machinery hung off it) is the
# state the decl / stmt / expr lowering passes thread and mutate. it lives in
# this leaf — apart from the `lower` orchestrator that drives the passes — so
# the passes can take a `*LowerContext` without importing the orchestrator,
# which would close an import cycle.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.is_none;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use map: std.collections.map;
use maphash: std.collections.map;

use sess:     mach.lang.session;
use src:      mach.lang.source;
use target:   mach.lang.target.resolved;
use abi:      mach.lang.target.abi;
use ty:       mach.lang.type;
use intern:   mach.lang.intern;

use ast:      mach.lang.fe.ast;
use aid:      mach.lang.fe.ast.id;
use adecl:    mach.lang.fe.ast.decl;
use resolve:  mach.lang.fe.resolve;
use sema:     mach.lang.fe.sema;
use generics: mach.lang.fe.sema.generics;
use comptime: mach.lang.fe.comptime;

use ir:       mach.lang.me.ir;
use ir_type:  mach.lang.me.ir.type;
use value:    mach.lang.me.ir.value;
use builder:  mach.lang.me.ir.builder;


# initial capacity for the loop and fin working stacks on a LowerContext.
val INITIAL_STACK_CAP: u32 = 8;

# upper bound on the number of distinct comptime value-parameter instances one
# module may emit. a recursive comptime-param function called with a changing
# value (`f($n - 1)`) would otherwise instantiate without end; hitting this cap
# is reported as an error rather than exhausting memory.
pub val MAX_VALUE_INSTANCES: u32 = 4096;

# REPORTED: the sentinel error a lowering routine returns after it has already
# filed a structured diagnostic at the offending span. the driver recognizes it
# and suppresses the raw `error: <string>` reprint, leaving the located
# diagnostic (flushed from the session sink) as the single user-facing message.
pub val REPORTED: str = "lower:reported";

# one entry on the loop stack: the header and exit blocks of an active
# loop. `cnt` branches to `header`, `brk` branches to `exit`.
# ---
# header: block a `cnt` (or back-edge) branches to
# exit:   block a `brk` branches to
pub rec LoopFrame {
    header: ir.BlockId;
    exit:   ir.BlockId;
}

# one collected generic instance awaiting body emission: a concrete
# `(generic_decl, origin, type-args)` triple plus the mangled symbol name the
# instance is emitted under. the worklist dedups by `name`, so an instance is
# emitted once per object no matter how many call sites reference it.
# ---
# decl:     DeclId of the generic function in `origin`'s AST
# origin:   ModuleId that declares the generic
# args:     owned copy of the concrete type-argument sequence (by ordinal)
# arg_len:  number of type arguments
# name:     instance linkage name (mangled, with the type-args suffix)
pub rec Instance {
    decl:    aid.DeclId;
    origin:  sess.ModuleId;
    args:    *ty.TypeId;
    arg_len: u32;
    name:    intern.StrId;
}

# one collected comptime value-parameter instance awaiting body emission: a
# `(decl, origin, comptime-value sequence)` triple plus the mangled symbol name
# the instance is emitted under. mirrors `Instance` but keys on folded comptime
# VALUES (CTValues) rather than type arguments, so a function with one or more
# `$`-parameters is monomorphized once per distinct argument-value sequence. the
# worklist dedups by `name`.
# ---
# decl:    DeclId of the comptime-param function in `origin`'s AST
# origin:  ModuleId that declares the function
# vals:    owned copy of the folded comptime-value sequence (by comptime ordinal)
# val_len: number of comptime values
# names:   owned copy of the bare comptime-param identifiers (by comptime ordinal),
#          paired positionally with `vals` for binding into the comptime context
# name:    instance linkage name (mangled, with the value-args suffix)
pub rec ValueInstance {
    decl:    aid.DeclId;
    origin:  sess.ModuleId;
    vals:    *comptime.CTValue;
    val_len: u32;
    names:   *intern.StrId;
    name:    intern.StrId;
}

# per-module lowering state, threaded through every decl / stmt / expr.
# the leading fields are the phase inputs and the IR being built; the
# trailing fields are the working state for the function currently being
# lowered (reset by `begin_function`).
# ---
# s:           shared session (allocator, interner, type universe)
# tgt:         selected target — drives IR type sizing
# a:           parsed AST being lowered
# fqn:         FQN of the module being lowered; the mangler qualifies every
#              definition's symbol name with it
# own_module:  ModuleId of the module being lowered; keys its export-name
#              overrides and matches a self-reference's origin
# sema_result: typing output parallel to the AST
# rr:          name-resolution output parallel to the AST
# ctx:         comptime context supplying folded global initialisers
# m:           the IR module being built
# builder:     insertion cursor into `m`
# locals:      source SymbolId -> the Value naming its current storage
#              (an alloca pointer for address-taken / mutable locals)
# local_names: source local name -> its storage Value, last-binding-wins;
#              the inline-asm lowerer resolves `{name}` references against it
# fn_index:    index into m.functions of the function being lowered
# ret_ty:      IR return type of the function being lowered
# loops:       active loop stack (innermost last) for brk / cnt
# loop_len:    number of active loop frames
# loop_cap:    allocated capacity of the loop stack
# fins:        deferred `fin` body StmtIds (innermost last)
# fin_len:     number of pending fin entries
# fin_cap:     allocated capacity of the fin stack
# subst:       active generic substitution (concrete type-args by param ordinal)
#              while lowering a monomorphized instance body, nil otherwise;
#              `lower_type` consults it to resolve `TYPE_GENERIC_PARAM`s
# subst_len:   number of substitution arguments
# insts:       per-module worklist of generic instances collected at call sites,
#              drained to fixpoint after the module's decls are lowered (each
#              instance emits one concrete weak body)
# inst_len:    number of worklist entries
# inst_cap:    allocated capacity of the worklist
# inst_drained: persistent cursor into `insts`: entries below it are already
#              emitted, so a re-entrant drain (e.g. type instances enqueued while
#              value instances lower) emits each generic body exactly once
# vinsts:      per-module worklist of comptime value-parameter instances collected
#              at call sites, drained to fixpoint after the type-instance worklist;
#              each emits one concrete weak body with its `$param->CTValue` bindings
#              active so the comptime evaluator selects each `$if` arm
# vinst_len:   number of value-instance worklist entries
# vinst_cap:   allocated capacity of the value-instance worklist
pub rec LowerContext {
    s:           *sess.Session;
    tgt:         *target.Target;
    a:           *ast.Ast;
    fqn:         intern.StrId;
    own_module:  sess.ModuleId;
    sema_result: *sema.SemaResult;
    rr:          *resolve.ResolveResult;
    ctx:         *comptime.ComptimeCtx;
    m:           *ir.Module;
    builder:     builder.Builder;
    locals:      map.Map[resolve.SymbolId, value.Value];
    local_names: map.Map[intern.StrId, value.Value];

    fn_index:    u32;
    ret_ty:      ir_type.IrTypeId;

    loops:       *LoopFrame;
    loop_len:    u32;
    loop_cap:    u32;

    fins:        *aid.StmtId;
    fin_len:     u32;
    fin_cap:     u32;

    subst:       *ty.TypeId;
    subst_len:   u32;

    insts:       *Instance;
    inst_len:    u32;
    inst_cap:    u32;
    inst_drained: u32;

    vinsts:      *ValueInstance;
    vinst_len:   u32;
    vinst_cap:   u32;
}


# initialises a LowerContext: wires the phase inputs, points the builder
# at the module, builds the locals map, and allocates the loop / fin
# working stacks.
# ---
# lc:          context to populate
# s:           shared session
# tgt:         selected target
# a:           parsed AST
# fqn:         FQN of the module being lowered (for symbol mangling)
# own_module:  ModuleId of the module being lowered
# sema_result: typing output
# rr:          name resolution
# ctx:         comptime context
# m:           IR module being built
# ret:         true on success, or an allocation error
pub fun init_context(
    lc:          *LowerContext,
    s:           *sess.Session,
    tgt:         *target.Target,
    a:           *ast.Ast,
    fqn:         intern.StrId,
    own_module:  sess.ModuleId,
    sema_result: *sema.SemaResult,
    rr:          *resolve.ResolveResult,
    ctx:         *comptime.ComptimeCtx,
    m:           *ir.Module
) Result[bool, str] {
    lc.s           = s;
    lc.tgt         = tgt;
    lc.a           = a;
    lc.fqn         = fqn;
    lc.own_module  = own_module;
    lc.sema_result = sema_result;
    lc.rr          = rr;
    lc.ctx         = ctx;
    lc.m           = m;
    lc.builder     = builder.init(m);

    # install the `alias.CONST` member resolver so comptime.eval can fold module-
    # qualified constant paths in this module's initialisers and gates. data is
    # the LowerContext itself, read live so the value-instance drains' module
    # swaps stay correct.
    comptime.set_member_resolver(ctx, resolve_module_member_const::*u8, lc::ptr);
    lc.locals      = map.init[resolve.SymbolId, value.Value](s.alloc, maphash.hash_u32, maphash.eq_u32);
    lc.local_names = map.init[intern.StrId, value.Value](s.alloc, maphash.hash_u32, maphash.eq_u32);

    lc.fn_index = 0;
    lc.ret_ty   = ir_type.IRT_NIL;

    val lr: Result[*LoopFrame, str] = allocate[LoopFrame](s.alloc, INITIAL_STACK_CAP::usize);
    if (is_err[*LoopFrame, str](lr)) {
        map.dnit[intern.StrId, value.Value](?lc.local_names);
        map.dnit[resolve.SymbolId, value.Value](?lc.locals);
        ret err[bool, str](unwrap_err[*LoopFrame, str](lr));
    }
    lc.loops    = unwrap_ok[*LoopFrame, str](lr);
    lc.loop_len = 0;
    lc.loop_cap = INITIAL_STACK_CAP;

    val fr: Result[*aid.StmtId, str] = allocate[aid.StmtId](s.alloc, INITIAL_STACK_CAP::usize);
    if (is_err[*aid.StmtId, str](fr)) {
        deallocate[LoopFrame](s.alloc, lc.loops, lc.loop_cap::usize);
        map.dnit[intern.StrId, value.Value](?lc.local_names);
        map.dnit[resolve.SymbolId, value.Value](?lc.locals);
        ret err[bool, str](unwrap_err[*aid.StmtId, str](fr));
    }
    lc.fins    = unwrap_ok[*aid.StmtId, str](fr);
    lc.fin_len = 0;
    lc.fin_cap = INITIAL_STACK_CAP;

    lc.subst     = nil;
    lc.subst_len = 0;
    lc.insts     = nil;
    lc.inst_len  = 0;
    lc.inst_cap  = 0;
    lc.inst_drained = 0;
    lc.vinsts    = nil;
    lc.vinst_len = 0;
    lc.vinst_cap = 0;

    ret ok[bool, str](true);
}

# releases the working storage held by a LowerContext (the locals map and
# the loop / fin stacks) and clears the member resolver init_context installed
# on the comptime ctx, so the borrowed ctx never keeps a dangling LowerContext
# pointer past this module's lowering. does not otherwise touch the borrowed
# phase inputs or the module.
# ---
# lc: context to tear down
pub fun dnit_context(lc: *LowerContext) {
    if (lc == nil) { ret; }
    if (lc.ctx != nil) { comptime.set_member_resolver(lc.ctx, nil, nil); }
    map.dnit[intern.StrId, value.Value](?lc.local_names);
    map.dnit[resolve.SymbolId, value.Value](?lc.locals);
    if (lc.loops != nil && lc.loop_cap > 0) {
        deallocate[LoopFrame](lc.s.alloc, lc.loops, lc.loop_cap::usize);
    }
    if (lc.fins != nil && lc.fin_cap > 0) {
        deallocate[aid.StmtId](lc.s.alloc, lc.fins, lc.fin_cap::usize);
    }
    if (lc.insts != nil && lc.inst_cap > 0) {
        var ii: u32 = 0;
        for (ii < lc.inst_len) {
            if (lc.insts[ii].args != nil && lc.insts[ii].arg_len > 0) {
                deallocate[ty.TypeId](lc.s.alloc, lc.insts[ii].args, lc.insts[ii].arg_len::usize);
            }
            ii = ii + 1;
        }
        deallocate[Instance](lc.s.alloc, lc.insts, lc.inst_cap::usize);
    }
    if (lc.vinsts != nil && lc.vinst_cap > 0) {
        var vi: u32 = 0;
        for (vi < lc.vinst_len) {
            if (lc.vinsts[vi].vals != nil && lc.vinsts[vi].val_len > 0) {
                deallocate[comptime.CTValue](lc.s.alloc, lc.vinsts[vi].vals, lc.vinsts[vi].val_len::usize);
            }
            if (lc.vinsts[vi].names != nil && lc.vinsts[vi].val_len > 0) {
                deallocate[intern.StrId](lc.s.alloc, lc.vinsts[vi].names, lc.vinsts[vi].val_len::usize);
            }
            vi = vi + 1;
        }
        deallocate[ValueInstance](lc.s.alloc, lc.vinsts, lc.vinst_cap::usize);
    }
    lc.loops    = nil;
    lc.loop_len = 0;
    lc.loop_cap = 0;
    lc.fins     = nil;
    lc.fin_len  = 0;
    lc.fin_cap  = 0;
    lc.insts    = nil;
    lc.inst_len = 0;
    lc.inst_cap = 0;
    lc.inst_drained = 0;
    lc.vinsts    = nil;
    lc.vinst_len = 0;
    lc.vinst_cap = 0;
}

# resolve_module_member_const: the `alias.CONST` member resolver lowering
# installs on every ComptimeCtx it evaluates against (a comptime.ModuleMemberFn).
# given a module-qualified member expression, it reads the active module's name
# resolution for the member's resolved symbol; when that symbol is a constant
# imported from another module, it returns the constant's pre-folded comptime
# value from the declaring module's ComptimeCtx. it returns none — leaving
# comptime.eval to reject the path with a loud error — whenever the member
# resolves to anything else (a function, a `var`, a non-constant `val`, or an
# unexported / unknown member): the declaring module's ctx holds exactly its
# transitively-constant module-level vals, so a lookup miss there is the scope
# guard for everything that is not a constant. `data` is the *LowerContext
# driving the evaluation; reading its `rr` / `s` live keeps the resolver correct
# across the value-instance drains that swap the active module.
# ---
# data: the *LowerContext, erased to a ptr by the installer
# eid:  the MEMBER expression id, valid in the active module's ast
# ret:  some(value) when the member names a module-level constant, else none
pub fun resolve_module_member_const(data: ptr, eid: aid.ExprId) Result[Option[comptime.CTValue], str] {
    val lc: *LowerContext = data::*LowerContext;
    if (lc == nil) { ret ok[Option[comptime.CTValue], str](none[comptime.CTValue]()); }
    val rr: *resolve.ResolveResult = lc.rr;
    if (rr == nil || rr.expr_resolved == nil || eid::u32 >= rr.expr_count) {
        ret ok[Option[comptime.CTValue], str](none[comptime.CTValue]());
    }
    val sid: resolve.SymbolId = rr.expr_resolved[eid];
    if (sid == resolve.SYMBOL_NIL || sid::u32 >= rr.symbol_count) {
        ret ok[Option[comptime.CTValue], str](none[comptime.CTValue]());
    }
    val sym: *resolve.Symbol = ?rr.symbols[sid];
    if (sym.kind != resolve.SYM_IMPORTED) {
        ret ok[Option[comptime.CTValue], str](none[comptime.CTValue]());
    }
    val octx: *comptime.ComptimeCtx = (sess.module_comptime_ptr(lc.s, sym.origin))::*comptime.ComptimeCtx;
    if (octx == nil) { ret ok[Option[comptime.CTValue], str](none[comptime.CTValue]()); }
    val nc: Option[*comptime.NamedConst] = comptime.lookup(octx, sym.name);
    if (is_none[*comptime.NamedConst](nc)) {
        ret ok[Option[comptime.CTValue], str](none[comptime.CTValue]());
    }
    ret ok[Option[comptime.CTValue], str](some[comptime.CTValue](unwrap[*comptime.NamedConst](nc).value));
}

# resets the per-function working state before lowering a new function:
# clears the locals map and the loop / fin stacks, and records the new
# function index and IR return type. the builder cursor is set by the
# caller (`lower.decl.lower_fun`) once the entry block exists.
# ---
# lc:       the context
# fn_index: index of the function in m.functions
# ret_ty:   the function's IR return type
pub fun begin_function(lc: *LowerContext, fn_index: u32, ret_ty: ir_type.IrTypeId) {
    map.clear[resolve.SymbolId, value.Value](?lc.locals);
    map.clear[intern.StrId, value.Value](?lc.local_names);
    lc.loop_len = 0;
    lc.fin_len  = 0;
    lc.fn_index = fn_index;
    lc.ret_ty   = ret_ty;
}

# binds a source SymbolId to the IR Value that names its storage. for
# locals this is the alloca-slot pointer; for parameters seeded before the
# body it may be a VAL_PARAM. overwrites any prior binding.
#
# the binding is also recorded by source name in `local_names` (last-binding-
# wins) so the inline-asm lowerer can resolve a `{name}` reference to its
# storage Value, mirroring cmach's name-keyed local table.
# ---
# lc:  the context
# sym: source symbol id
# v:   the Value to bind
# ret: true on success, or an allocation error from the map
pub fun bind_local(lc: *LowerContext, sym: resolve.SymbolId, v: value.Value) Result[bool, str] {
    val r: Result[bool, str] = map.insert[resolve.SymbolId, value.Value](?lc.locals, sym, v);
    if (is_err[bool, str](r)) { ret r; }

    val so: Option[*resolve.Symbol] = symbol_of(lc, sym);
    if (is_some[*resolve.Symbol](so)) {
        val name: intern.StrId = unwrap[*resolve.Symbol](so).name;
        if (name != intern.STR_NIL) {
            ret map.insert[intern.StrId, value.Value](?lc.local_names, name, v);
        }
    }
    ret ok[bool, str](true);
}

# looks up the storage Value bound to a source local by interned name, or none
# when no local with that name is in scope. the inline-asm lowerer uses this to
# resolve `{name}` references in an asm body to the local's alloca slot.
# ---
# lc:   the context
# name: interned source local name
# ret:  some(Value) when a local of that name is bound, none otherwise
pub fun lookup_local_name(lc: *LowerContext, name: intern.StrId) Option[value.Value] {
    var key: intern.StrId = name;
    val r: Result[*value.Value, str] = map.get[intern.StrId, value.Value](?lc.local_names, ?key);
    if (is_ok[*value.Value, str](r)) {
        ret some[value.Value](@unwrap_ok[*value.Value, str](r));
    }
    ret none[value.Value]();
}

# looks up the Value bound to a source SymbolId, or none when the symbol
# has no local binding (a global or function reference).
# ---
# lc:  the context
# sym: source symbol id
# ret: some(Value) when bound, none otherwise
pub fun lookup_local(lc: *LowerContext, sym: resolve.SymbolId) Option[value.Value] {
    val r: Result[*value.Value, str] = map.get[resolve.SymbolId, value.Value](?lc.locals, ?sym);
    if (is_ok[*value.Value, str](r)) {
        ret some[value.Value](@unwrap_ok[*value.Value, str](r));
    }
    ret none[value.Value]();
}

# pushes a loop frame, recording the header and exit blocks the innermost
# `cnt` / `brk` branch to. grows the loop stack on overflow.
# ---
# lc:     the context
# header: block `cnt` branches to
# exit:   block `brk` branches to
# ret:    true on success, or an allocation error
pub fun push_loop(lc: *LowerContext, header: ir.BlockId, exit: ir.BlockId) Result[bool, str] {
    if (lc.loop_len == lc.loop_cap) {
        val new_cap: u32 = lc.loop_cap * 2;
        val r: Result[*LoopFrame, str] = reallocate[LoopFrame](lc.s.alloc, lc.loops, lc.loop_cap::usize, new_cap::usize);
        if (is_err[*LoopFrame, str](r)) { ret err[bool, str](unwrap_err[*LoopFrame, str](r)); }
        lc.loops    = unwrap_ok[*LoopFrame, str](r);
        lc.loop_cap = new_cap;
    }
    var f: LoopFrame;
    f.header = header;
    f.exit   = exit;
    lc.loops[lc.loop_len] = f;
    lc.loop_len = lc.loop_len + 1;
    ret ok[bool, str](true);
}

# pops the innermost loop frame. no-op when the stack is empty.
# ---
# lc: the context
pub fun pop_loop(lc: *LowerContext) {
    if (lc.loop_len > 0) { lc.loop_len = lc.loop_len - 1; }
}

# returns a pointer to the innermost active loop frame, or nil outside any
# loop. a pointer (rather than a by-value `Option[LoopFrame]`) keeps the two
# block ids stable through the call boundary.
# ---
# lc:  the context
# ret: pointer to the innermost LoopFrame, or nil outside any loop
pub fun current_loop(lc: *LowerContext) *LoopFrame {
    if (lc.loop_len == 0) { ret nil; }
    ret ?lc.loops[lc.loop_len - 1];
}

# enqueue_instance: record a generic instance `(decl, origin, args)` on the
# per-module worklist under its mangled `name`, deduped by name (already-queued
# or already-emitted instances are skipped). takes an OWNED copy of `args` so the
# caller's buffer can be reused / freed; the copy is released when the context is
# torn down. an instance whose body is already a defined function in the module
# (emitted by an earlier drain) is not re-queued. returns true once the instance
# is present (queued now or before), or an allocation error.
# ---
# lc:      the context
# decl:    DeclId of the generic function in `origin`'s AST
# origin:  ModuleId declaring the generic
# args:    concrete type-argument sequence (copied)
# arg_len: number of type arguments
# name:    instance linkage name
# ret:     true on success, or an allocation error
pub fun enqueue_instance(lc: *LowerContext, decl: aid.DeclId, origin: sess.ModuleId,
                         args: *ty.TypeId, arg_len: u32, name: intern.StrId) Result[bool, str] {
    var i: u32 = 0;
    for (i < lc.inst_len) {
        if (lc.insts[i].name == name) { ret ok[bool, str](true); }
        i = i + 1;
    }

    if (lc.inst_len == lc.inst_cap) {
        var new_cap: u32 = lc.inst_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_STACK_CAP; }
        if (lc.insts == nil) {
            val r: Result[*Instance, str] = allocate[Instance](lc.s.alloc, new_cap::usize);
            if (is_err[*Instance, str](r)) { ret err[bool, str](unwrap_err[*Instance, str](r)); }
            lc.insts = unwrap_ok[*Instance, str](r);
        } or {
            val r: Result[*Instance, str] = reallocate[Instance](lc.s.alloc, lc.insts, lc.inst_cap::usize, new_cap::usize);
            if (is_err[*Instance, str](r)) { ret err[bool, str](unwrap_err[*Instance, str](r)); }
            lc.insts = unwrap_ok[*Instance, str](r);
        }
        lc.inst_cap = new_cap;
    }

    var copy: *ty.TypeId = nil;
    if (arg_len > 0) {
        val r: Result[*ty.TypeId, str] = allocate[ty.TypeId](lc.s.alloc, arg_len::usize);
        if (is_err[*ty.TypeId, str](r)) { ret err[bool, str](unwrap_err[*ty.TypeId, str](r)); }
        copy = unwrap_ok[*ty.TypeId, str](r);
        var j: u32 = 0;
        for (j < arg_len) { copy[j] = args[j]; j = j + 1; }
    }

    var inst: Instance;
    inst.decl    = decl;
    inst.origin  = origin;
    inst.args    = copy;
    inst.arg_len = arg_len;
    inst.name    = name;
    lc.insts[lc.inst_len] = inst;
    lc.inst_len = lc.inst_len + 1;
    ret ok[bool, str](true);
}

# enqueue_value_instance: record a comptime value-parameter instance
# `(decl, origin, vals, names)` on the per-module worklist under its mangled
# `name`, deduped by name (identical to `enqueue_instance` — a linear scan, no
# map/hash, so determinism is preserved). takes OWNED copies of `vals` and
# `names` so the caller's buffers can be reused / freed; the copies are released
# when the context is torn down. exceeding MAX_VALUE_INSTANCES distinct instances
# is reported as an error (a recursive comptime-param function called with a
# changing value would otherwise instantiate without end).
# ---
# lc:      the context
# decl:    DeclId of the comptime-param function in `origin`'s AST
# origin:  ModuleId declaring the function
# vals:    folded comptime-value sequence (copied), by comptime ordinal
# names:   bare comptime-param identifiers (copied), by comptime ordinal
# val_len: number of comptime values / names
# name:    instance linkage name
# ret:     true on success, or an allocation / cap error
pub fun enqueue_value_instance(lc: *LowerContext, decl: aid.DeclId, origin: sess.ModuleId,
                               vals: *comptime.CTValue, names: *intern.StrId, val_len: u32,
                               name: intern.StrId) Result[bool, str] {
    var i: u32 = 0;
    for (i < lc.vinst_len) {
        if (lc.vinsts[i].name == name) { ret ok[bool, str](true); }
        i = i + 1;
    }

    if (lc.vinst_len >= MAX_VALUE_INSTANCES) {
        ret err[bool, str]("comptime value-parameter instantiation limit exceeded (likely unbounded comptime recursion)");
    }

    if (lc.vinst_len == lc.vinst_cap) {
        var new_cap: u32 = lc.vinst_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_STACK_CAP; }
        if (lc.vinsts == nil) {
            val r: Result[*ValueInstance, str] = allocate[ValueInstance](lc.s.alloc, new_cap::usize);
            if (is_err[*ValueInstance, str](r)) { ret err[bool, str](unwrap_err[*ValueInstance, str](r)); }
            lc.vinsts = unwrap_ok[*ValueInstance, str](r);
        } or {
            val r: Result[*ValueInstance, str] = reallocate[ValueInstance](lc.s.alloc, lc.vinsts, lc.vinst_cap::usize, new_cap::usize);
            if (is_err[*ValueInstance, str](r)) { ret err[bool, str](unwrap_err[*ValueInstance, str](r)); }
            lc.vinsts = unwrap_ok[*ValueInstance, str](r);
        }
        lc.vinst_cap = new_cap;
    }

    var vcopy: *comptime.CTValue = nil;
    var ncopy: *intern.StrId = nil;
    if (val_len > 0) {
        val vr: Result[*comptime.CTValue, str] = allocate[comptime.CTValue](lc.s.alloc, val_len::usize);
        if (is_err[*comptime.CTValue, str](vr)) { ret err[bool, str](unwrap_err[*comptime.CTValue, str](vr)); }
        vcopy = unwrap_ok[*comptime.CTValue, str](vr);
        val nr: Result[*intern.StrId, str] = allocate[intern.StrId](lc.s.alloc, val_len::usize);
        if (is_err[*intern.StrId, str](nr)) {
            deallocate[comptime.CTValue](lc.s.alloc, vcopy, val_len::usize);
            ret err[bool, str](unwrap_err[*intern.StrId, str](nr));
        }
        ncopy = unwrap_ok[*intern.StrId, str](nr);
        var j: u32 = 0;
        for (j < val_len) { vcopy[j] = vals[j]; ncopy[j] = names[j]; j = j + 1; }
    }

    var inst: ValueInstance;
    inst.decl    = decl;
    inst.origin  = origin;
    inst.vals    = vcopy;
    inst.val_len = val_len;
    inst.names   = ncopy;
    inst.name    = name;
    lc.vinsts[lc.vinst_len] = inst;
    lc.vinst_len = lc.vinst_len + 1;
    ret ok[bool, str](true);
}

# pushes a deferred `fin` body. the body StmtId is replayed (lowered
# inline) before every reachable terminator that closes the enclosing
# scope. grows the fin stack on overflow.
# ---
# lc:   the context
# body: StmtId of the fin body
# ret:  true on success, or an allocation error
pub fun push_fin(lc: *LowerContext, body: aid.StmtId) Result[bool, str] {
    if (lc.fin_len == lc.fin_cap) {
        val new_cap: u32 = lc.fin_cap * 2;
        val r: Result[*aid.StmtId, str] = reallocate[aid.StmtId](lc.s.alloc, lc.fins, lc.fin_cap::usize, new_cap::usize);
        if (is_err[*aid.StmtId, str](r)) { ret err[bool, str](unwrap_err[*aid.StmtId, str](r)); }
        lc.fins    = unwrap_ok[*aid.StmtId, str](r);
        lc.fin_cap = new_cap;
    }
    lc.fins[lc.fin_len] = body;
    lc.fin_len = lc.fin_len + 1;
    ret ok[bool, str](true);
}

# returns the number of pending fin bodies.
# ---
# lc:  the context
# ret: count of deferred fin entries
pub fun fin_count(lc: *LowerContext) u32 {
    ret lc.fin_len;
}

# returns the fin body StmtId at stack index `i` (0 = outermost).
# ---
# lc: the context
# i:  stack index in [0, fin_count)
# ret: the StmtId, or STMT_NIL when out of range
pub fun fin_at(lc: *LowerContext, i: u32) aid.StmtId {
    if (i >= lc.fin_len) { ret aid.STMT_NIL; }
    ret lc.fins[i];
}

# lowers a semantic `type.TypeId` into the module's IR type universe.
# generics, instances, and aliases are assumed resolved by sema; this maps
# the concrete machine shapes. unknown / error types lower to void so that
# lowering never aborts on a poisoned upstream type (dce / the verifier
# surface the real problem).
# ---
# lc:  the context
# tid: semantic TypeId
# ret: the corresponding IrTypeId, or an allocation error
pub fun lower_type(lc: *LowerContext, tid: ty.TypeId) Result[ir_type.IrTypeId, str] {
    if (tid == ty.TYPE_NIL) {
        ret ir_type.intern_void(?lc.m.types);
    }

    # while lowering a monomorphized instance body, resolve any generic parameter
    # in `tid` (a bare `T`, `*T`, `[N]T`, a nested `Result[T,E]`, etc.) to its
    # concrete type-argument before mapping the machine shape, so storage sizing
    # and field layout match the instance instead of falling through to the
    # pointer-width erasure below.
    var rtid: ty.TypeId = tid;
    if (lc.subst != nil && lc.subst_len > 0) {
        rtid = generics.substitute(lc.s, tid, lc.subst, lc.subst_len);
    }

    # ensure a generic instance's substituted field table exists before lowering
    # it, regardless of whether the current body substitutes params. a non-generic
    # function that names a concrete instance (e.g. returning `Option[str]`) never
    # substitutes, so without this its instance lowers against an unpopulated field
    # store and collapses to an undersized struct. a no-op for non-instances and
    # already-tabled instances.
    generics.ensure_fields(lc.s, rtid);

    val t_opt: Option[*ty.Type] = ty.get(?lc.s.types, rtid);
    if (is_none[*ty.Type](t_opt)) {
        ret ir_type.intern_void(?lc.m.types);
    }
    val t: *ty.Type = unwrap[*ty.Type](t_opt);
    val k: ty.TypeKind = t.kind;

    if (k == ty.TYPE_U8 || k == ty.TYPE_I8)   { ret ir_type.intern_int(?lc.m.types, 8); }
    if (k == ty.TYPE_U16 || k == ty.TYPE_I16) { ret ir_type.intern_int(?lc.m.types, 16); }
    if (k == ty.TYPE_U32 || k == ty.TYPE_I32) { ret ir_type.intern_int(?lc.m.types, 32); }
    if (k == ty.TYPE_U64 || k == ty.TYPE_I64) { ret ir_type.intern_int(?lc.m.types, 64); }
    if (k == ty.TYPE_F32)                     { ret ir_type.intern_float(?lc.m.types, 32); }
    if (k == ty.TYPE_F64)                     { ret ir_type.intern_float(?lc.m.types, 64); }
    if (k == ty.TYPE_PTR)                     { ret ir_type.intern_ptr(?lc.m.types); }
    if (k == ty.TYPE_POINTER)                 { ret ir_type.intern_ptr(?lc.m.types); }

    # `va_list` lowers per the target ABI's variadic save model: the register-save
    # model (SysV) uses the four-field `__va_list_tag` struct, the home-area model
    # (win64) a single pointer. dispatching here keeps `$size_of(va_list)`, C-interop
    # struct layouts, and the scalar-vs-aggregate value path correct on every target.
    if (k == ty.TYPE_VA_LIST) {
        ret lower_va_list(lc);
    }

    if (k == ty.TYPE_ARRAY) {
        val er: Result[ir_type.IrTypeId, str] = lower_type(lc, t.data.array.base);
        if (is_err[ir_type.IrTypeId, str](er)) { ret er; }
        ret ir_type.intern_array(?lc.m.types, unwrap_ok[ir_type.IrTypeId, str](er), t.data.array.count);
    }

    # records, unions, and generic instances all lower to an IR struct of their
    # field layout, read from the session-global field store. a generic instance
    # carries a substituted field table (built by `generics.instantiate`), so it
    # lowers to the same concrete shape as a non-generic record — field access
    # within a generic body GEPs through it correctly.
    if (k == ty.TYPE_REC || k == ty.TYPE_UNI || k == ty.TYPE_INSTANCE) {
        ret lower_nominal(lc, rtid, k == ty.TYPE_UNI);
    }

    if (k == ty.TYPE_FUN) {
        ret lower_function_type(lc, t);
    }

    # generic params / errors that survived to here lower to a pointer-width
    # opaque slot so storage sizing still works.
    ret ir_type.intern_ptr(?lc.m.types);
}

# lowers a nominal (rec / uni) semantic type to an IR struct of its lowered
# field types, read from the session-global field store keyed by TypeId. the
# store is the canonical field layout (built once by sema and shared across
# phases and modules), so it resolves anonymous records — whose identity is
# structural, not tied to a single AST declaration — as well as named records
# referenced from another module. a type with no field table lowers to an
# empty struct, keeping lowering total.
fun lower_nominal(lc: *LowerContext, tid: ty.TypeId, is_union: bool) Result[ir_type.IrTypeId, str] {
    # an `align(...)` decorator on the record/union, folded by sema and keyed by
    # this nominal TypeId; 0 leaves the natural alignment.
    var nom_align: u32 = 0;
    val ta: Option[u32] = sess.type_align(lc.s, tid::u32);
    if (is_some[u32](ta)) { nom_align = unwrap[u32](ta); }

    val fields_len: u32 = ty.field_count(?lc.s.types, tid);
    if (fields_len == 0) {
        ret ir_type.intern_struct(?lc.m.types, nil, 0, nom_align);
    }

    val buf_r: Result[*ir_type.IrTypeId, str] = allocate[ir_type.IrTypeId](lc.s.alloc, fields_len::usize);
    if (is_err[*ir_type.IrTypeId, str](buf_r)) {
        ret err[ir_type.IrTypeId, str](unwrap_err[*ir_type.IrTypeId, str](buf_r));
    }
    val buf: *ir_type.IrTypeId = unwrap_ok[*ir_type.IrTypeId, str](buf_r);

    var i: u32 = 0;
    for (i < fields_len) {
        val fe_opt: Option[*ty.FieldEntry] = ty.field_at(?lc.s.types, tid, i);
        var fty: ir_type.IrTypeId = ir_type.IRT_NIL;
        if (is_some[*ty.FieldEntry](fe_opt)) {
            val sem: ty.TypeId = unwrap[*ty.FieldEntry](fe_opt).ty;
            val fr: Result[ir_type.IrTypeId, str] = lower_type(lc, sem);
            if (is_err[ir_type.IrTypeId, str](fr)) {
                deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
                ret fr;
            }
            fty = unwrap_ok[ir_type.IrTypeId, str](fr);
        } or {
            val vr: Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?lc.m.types);
            if (is_err[ir_type.IrTypeId, str](vr)) {
                deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
                ret vr;
            }
            fty = unwrap_ok[ir_type.IrTypeId, str](vr);
        }
        buf[i] = fty;
        i = i + 1;
    }

    var sr: Result[ir_type.IrTypeId, str];
    if (is_union) {
        sr = ir_type.intern_union(?lc.m.types, buf, fields_len, nom_align);
    }
    or {
        sr = ir_type.intern_struct(?lc.m.types, buf, fields_len, nom_align);
    }
    deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
    ret sr;
}

# lowers the builtin `va_list` type per the target ABI's variadic save model. the
# register-save model (SysV) lowers it to the AMD64 `__va_list_tag` IR struct
# { i32 gp_offset, i32 fp_offset, ptr overflow_arg_area, ptr reg_save_area }, whose
# field order and types match the model's VA_* field offsets so the backend's
# va_start / va_arg expansion GEPs the right offsets. the home-area model (win64)
# lowers it to a single pointer — the cursor `va_start` seeds and `va_arg` walks —
# so `$size_of(va_list)` is 8 (not 24) and a C-interop struct embedding it lays out
# correctly. the model is read from the selected target's ABI vtable.
fun lower_va_list(lc: *LowerContext) Result[ir_type.IrTypeId, str] {
    val model: abi.VaModelFn = lc.tgt.abi.va_model::abi.VaModelFn;
    val m: abi.VaModel = model();
    if (m.kind == abi.VA_MODEL_HOME) {
        ret ir_type.intern_ptr(?lc.m.types);
    }
    var buf: [4]ir_type.IrTypeId;
    val i32r: Result[ir_type.IrTypeId, str] = ir_type.intern_int(?lc.m.types, 32);
    if (is_err[ir_type.IrTypeId, str](i32r)) { ret i32r; }
    val i32t: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](i32r);
    val ptrr: Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?lc.m.types);
    if (is_err[ir_type.IrTypeId, str](ptrr)) { ret ptrr; }
    val ptrt: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](ptrr);
    buf[0] = i32t;
    buf[1] = i32t;
    buf[2] = ptrt;
    buf[3] = ptrt;
    ret ir_type.intern_struct(?lc.m.types, ?buf[0], 4, 0);
}

# lowers a TYPE_FUN semantic type into an IRT_FN, propagating the semantic
# `variadic` flag so the back end recognizes variadic definitions (the
# register-save prologue) and variadic calls (the tail-argument ABI walk).
# parameter types come from the type interner's param pool.
fun lower_function_type(lc: *LowerContext, t: *ty.Type) Result[ir_type.IrTypeId, str] {
    val variadic: bool = t.data.fn.variadic;
    val ret_r: Result[ir_type.IrTypeId, str] = lower_type(lc, t.data.fn.ret_ty);
    if (is_err[ir_type.IrTypeId, str](ret_r)) { ret ret_r; }
    val ir_ret: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](ret_r);

    val count: u32 = t.data.fn.params_len;
    if (count == 0) {
        ret ir_type.intern_fn(?lc.m.types, ir_ret, nil, 0, variadic);
    }

    val buf_r: Result[*ir_type.IrTypeId, str] = allocate[ir_type.IrTypeId](lc.s.alloc, count::usize);
    if (is_err[*ir_type.IrTypeId, str](buf_r)) {
        ret err[ir_type.IrTypeId, str](unwrap_err[*ir_type.IrTypeId, str](buf_r));
    }
    val buf: *ir_type.IrTypeId = unwrap_ok[*ir_type.IrTypeId, str](buf_r);

    var i: u32 = 0;
    for (i < count) {
        val po: Option[ty.TypeId] = ty.get_param(?lc.s.types, t.data.fn.params_start + i);
        var p_sem: ty.TypeId = ty.TYPE_NIL;
        if (is_some[ty.TypeId](po)) { p_sem = unwrap[ty.TypeId](po); }
        val pr: Result[ir_type.IrTypeId, str] = lower_type(lc, p_sem);
        if (is_err[ir_type.IrTypeId, str](pr)) {
            deallocate[ir_type.IrTypeId](lc.s.alloc, buf, count::usize);
            ret pr;
        }
        buf[i] = unwrap_ok[ir_type.IrTypeId, str](pr);
        i = i + 1;
    }

    val fr: Result[ir_type.IrTypeId, str] = ir_type.intern_fn(?lc.m.types, ir_ret, buf, count, variadic);
    deallocate[ir_type.IrTypeId](lc.s.alloc, buf, count::usize);
    ret fr;
}

# returns the semantic type of an expression from the sema result, or
# TYPE_NIL when the id is out of range.
# ---
# lc:  the context
# eid: AST ExprId
# ret: the expression's interned semantic TypeId (TYPE_NIL if unknown)
pub fun expr_type_of(lc: *LowerContext, eid: aid.ExprId) ty.TypeId {
    if (eid == aid.EXPR_NIL) { ret ty.TYPE_NIL; }
    if (eid::usize >= lc.a.expr_len) { ret ty.TYPE_NIL; }
    ret lc.sema_result.expr_type[eid];
}

# returns the interned semantic type a syntactic AstType resolved to, or
# TYPE_NIL when the id is out of range.
# ---
# lc:  the context
# tid: AST TypeId
# ret: the interned semantic TypeId (TYPE_NIL if unknown)
pub fun type_resolved_of(lc: *LowerContext, tid: aid.TypeId) ty.TypeId {
    if (tid == aid.TYPE_NIL) { ret ty.TYPE_NIL; }
    if (tid::usize >= lc.a.type_len) { ret ty.TYPE_NIL; }
    ret lc.sema_result.type_resolved_ty[tid];
}

# returns the declared / inferred semantic type of a decl, or TYPE_NIL.
# ---
# lc:  the context
# did: AST DeclId
# ret: the decl's interned semantic TypeId (TYPE_NIL if unknown)
pub fun decl_type_of(lc: *LowerContext, did: aid.DeclId) ty.TypeId {
    if (did == aid.DECL_NIL) { ret ty.TYPE_NIL; }
    if (did::usize >= lc.a.decl_len) { ret ty.TYPE_NIL; }
    ret lc.sema_result.decl_type[did];
}

# returns the resolved SymbolId for an expression reference, or SYMBOL_NIL.
# ---
# lc:  the context
# eid: AST ExprId (typically an IDENT)
# ret: the bound SymbolId, or SYMBOL_NIL
pub fun expr_symbol_of(lc: *LowerContext, eid: aid.ExprId) resolve.SymbolId {
    if (eid == aid.EXPR_NIL) { ret resolve.SYMBOL_NIL; }
    if (eid::usize >= lc.rr.expr_count) { ret resolve.SYMBOL_NIL; }
    ret lc.rr.expr_resolved[eid];
}

# returns the module's source text from the session source map. an unregistered
# file id yields the empty string — never reached for a well-formed pipeline,
# since resolve already required the file to be registered.
# ---
# lc:  the context
# ret: the module's source text, or the empty string
pub fun module_source(lc: *LowerContext) str {
    val sf: Option[*src.SourceFile] = src.get(?lc.s.sources, lc.a.file_id);
    if (is_none[*src.SourceFile](sf)) { ret ""; }
    ret unwrap[*src.SourceFile](sf).text;
}

# returns a pointer to a resolved Symbol by id, or none when out of range.
# ---
# lc:  the context
# sid: SymbolId into the resolve result
# ret: some(*Symbol) or none
pub fun symbol_of(lc: *LowerContext, sid: resolve.SymbolId) Option[*resolve.Symbol] {
    if (sid == resolve.SYMBOL_NIL) { ret none[*resolve.Symbol](); }
    if (sid >= lc.rr.symbol_count) { ret none[*resolve.Symbol](); }
    ret some[*resolve.Symbol](?lc.rr.symbols[sid]);
}

# ensure_extern_function: returns the index of the module function named
# `name`, creating a signature-only `FN_FLAG_EXTERN` declaration when none
# exists. a cross-module function reference resolves through this so the
# back end emits a name-based call relocation against the imported symbol
# (the linker binds it to the defining module's object).
# ---
# lc:   the context
# name: interned function symbol name
# sig:  the function's IR type
# ret:  the function index, or an allocation error
pub fun ensure_extern_function(lc: *LowerContext, name: intern.StrId, sig: ir_type.IrTypeId) Result[u32, str] {
    val m: *ir.Module = lc.m;
    val existing: Option[u32] = ir.lookup_function(m, name);
    if (is_some[u32](existing)) { ret ok[u32, str](unwrap[u32](existing)); }

    if (m.function_len == m.function_cap) {
        val new_cap: u32 = grow_cap(m.function_cap);
        val r: Result[*ir.Function, str] = reallocate[ir.Function](m.alloc, m.functions, m.function_cap::usize, new_cap::usize);
        if (is_err[*ir.Function, str](r)) { ret err[u32, str](unwrap_err[*ir.Function, str](r)); }
        m.functions    = unwrap_ok[*ir.Function, str](r);
        m.function_cap = new_cap;
    }

    val idx: u32 = m.function_len;
    var f: ir.Function;
    f.name        = name;
    f.sig         = sig;
    f.params      = nil;
    f.param_count = 0;
    f.blocks      = nil;
    f.block_count = 0;
    f.block_cap   = 0;
    f.instrs      = nil;
    f.instr_len   = 0;
    f.instr_cap   = 0;
    f.flags       = ir.FN_FLAG_EXTERN;
    f.label       = intern.STR_NIL;
    f.asm_blocks  = map.init[ir.InstructionId, ir.IrAsm](m.alloc, maphash.hash_u32, maphash.eq_u32);

    m.functions[idx] = f;
    m.function_len   = m.function_len + 1;
    val reg: Result[bool, str] = ir.register_function(m, name, idx);
    if (is_err[bool, str](reg)) { ret err[u32, str](unwrap_err[bool, str](reg)); }

    # appending may have reallocated `m.functions`, invalidating the builder's
    # raw pointer to the function currently being lowered. re-point it at the
    # live array so subsequent emits land in the right function.
    if (lc.builder.fn != nil && lc.fn_index < m.function_len) {
        lc.builder.fn = ?m.functions[lc.fn_index];
    }
    ret ok[u32, str](idx);
}

# grow_cap: doubling growth for the function array, seeding an empty one.
fun grow_cap(cap: u32) u32 {
    if (cap == 0) { ret 4; }
    ret cap * 2;
}

# ensure_extern_global: returns the index of the module global named `name`,
# creating a storage-less `is_extern` declaration when none exists. a reference
# to a `val`/`var` defined in another module resolves through this so the back
# end emits a name-based relocation the linker binds to the defining object.
# ---
# lc:   the context
# name: interned global symbol name
# ty:   the global's IR storage type
# ret:  the global index, or an allocation error
pub fun ensure_extern_global(lc: *LowerContext, name: intern.StrId, ty: ir_type.IrTypeId) Result[u32, str] {
    val m: *ir.Module = lc.m;
    val existing: Option[u32] = ir.lookup_global(m, name);
    if (is_some[u32](existing)) { ret ok[u32, str](unwrap[u32](existing)); }

    if (m.global_len == m.global_cap) {
        val new_cap: u32 = grow_cap(m.global_cap);
        val r: Result[*ir.Global, str] = reallocate[ir.Global](m.alloc, m.globals, m.global_cap::usize, new_cap::usize);
        if (is_err[*ir.Global, str](r)) { ret err[u32, str](unwrap_err[*ir.Global, str](r)); }
        m.globals    = unwrap_ok[*ir.Global, str](r);
        m.global_cap = new_cap;
    }

    val idx: u32 = m.global_len;
    var g: ir.Global;
    g.name      = name;
    g.ty        = ty;
    g.init      = value.const_int(0, ty);
    g.is_mut    = true;
    g.is_pub    = false;
    g.is_extern = true;
    g.is_local  = false;
    g.align     = 0;
    g.section   = intern.STR_NIL;
    m.globals[idx] = g;
    m.global_len   = m.global_len + 1;
    val reg: Result[bool, str] = ir.register_global(m, name, idx);
    if (is_err[bool, str](reg)) { ret err[u32, str](unwrap_err[bool, str](reg)); }
    ret ok[u32, str](idx);
}

# add_rodata_bytes: materialise a byte-blob constant (`init`, a VAL_CONST_BYTES)
# as an anonymous read-only data global and return a VAL_GLOBAL pointer to it.
# string literals and other inline byte blobs flow through here so the back end
# emits them to `.rodata` and resolves uses to the global's address rather than
# carrying raw bytes into instruction operands.
# ---
# lc:   the context
# init: the VAL_CONST_BYTES value to store
# pty:  the IR pointer type the resulting global value carries
# ret:  a VAL_GLOBAL pointer to the new global, or an error
pub fun add_rodata_bytes(lc: *LowerContext, init: value.Value, pty: ir_type.IrTypeId) Result[value.Value, str] {
    val m: *ir.Module = lc.m;
    val name_r: Result[intern.StrId, str] = anon_global_name(lc, m.global_len);
    if (is_err[intern.StrId, str](name_r)) { ret err[value.Value, str](unwrap_err[intern.StrId, str](name_r)); }

    if (m.global_len == m.global_cap) {
        val new_cap: u32 = grow_cap(m.global_cap);
        val r: Result[*ir.Global, str] = reallocate[ir.Global](m.alloc, m.globals, m.global_cap::usize, new_cap::usize);
        if (is_err[*ir.Global, str](r)) { ret err[value.Value, str](unwrap_err[*ir.Global, str](r)); }
        m.globals    = unwrap_ok[*ir.Global, str](r);
        m.global_cap = new_cap;
    }

    val idx: u32 = m.global_len;
    var g: ir.Global;
    g.name      = unwrap_ok[intern.StrId, str](name_r);
    g.ty        = init.ty;
    g.init      = init;
    g.is_mut    = false;
    g.is_pub    = false;
    g.is_extern = false;
    g.is_local  = true;
    g.align     = 0;
    g.section   = intern.STR_NIL;
    m.globals[idx] = g;
    m.global_len   = m.global_len + 1;

    ret ok[value.Value, str](value.global_value(idx, pty));
}

# anon_global_name: interns a unique anonymous data-global name `.Lc.<n>` for
# slot `n`, distinct from any user symbol (the `.L` prefix is the conventional
# local-label form) and unique because `n` is the global's index.
fun anon_global_name(lc: *LowerContext, n: u32) Result[intern.StrId, str] {
    var buf: [16]u8;
    buf[0] = '.';
    buf[1] = 'L';
    buf[2] = 'c';
    buf[3] = '.';
    var len: usize = 4;
    var d: u32 = 0;
    for (d < 8) {
        val shift: u32 = (7 - d) * 4;
        val nib: u32 = (n >> shift) & 0xF;
        var c: u8 = nib::u8 + 0x30;
        if (nib > 9) { c = nib::u8 - 10 + 0x61; }
        buf[len] = c;
        len = len + 1;
        d = d + 1;
    }
    ret intern.intern_bytes(?lc.s.interner, (?buf[0])::str, len);
}
