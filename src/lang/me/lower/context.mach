# per-module lowering state and the accessor API the lowering passes thread.
#
# `LowerContext` (and the loop / fin / locals machinery hung off it) is the
# state the decl / stmt / expr lowering passes thread and mutate. it lives in
# this leaf -- apart from the `lower` orchestrator that drives the passes -- so
# the passes can take a `*LowerContext` without importing the orchestrator,
# which would close an import cycle.

use std.collections.map;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast;
use mach.lang.fe.ast.id;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema;
use mach.lang.fe.sema.generics;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.ir.builder;
use ir_type: mach.lang.me.ir.type;
use mach.lang.me.ir.value;
use mach.lang.session;
use mach.lang.source;
use target:  mach.lang.target.resolved;
use mach.lang.type;


# initial capacity for the loop and fin working stacks on a LowerContext
val INITIAL_STACK_CAP: u32 = 8;

# upper bound on the number of distinct comptime value-parameter instances one
# module may emit. a recursive comptime-param function called with a changing
# value (`f($n - 1)`) would otherwise instantiate without end; hitting this cap
# is reported as an error rather than exhausting memory.
pub val MAX_VALUE_INSTANCES: u32 = 4096;

# sentinel error a lowering routine returns after it has already filed a
# structured diagnostic at the offending span. the driver recognizes it and
# suppresses the raw `error: <string>` reprint, leaving the located diagnostic
# (flushed from the session sink) as the single user-facing message.
pub val REPORTED: str = "lower:reported";

# one entry on the loop stack: the header and exit blocks of an active loop.
# `cnt` branches to `header`, `brk` branches to `exit`.
# ---
# header: block a `cnt` (or back-edge) branches to
# exit:   block a `brk` branches to
pub rec LoopFrame {
    header: ir.BlockId;
    exit:   ir.BlockId;
}

# one collected generic instance awaiting body emission: a concrete
# `(generic_decl, origin, type-args)` triple plus the mangled symbol name the
# instance is emitted under. the worklist dedups by `name`, so an instance is
# emitted once per object no matter how many call sites reference it.
# ---
# decl:    DeclId of the generic function in `origin`'s AST
# origin:  ModuleId that declares the generic
# args:    owned copy of the concrete type-argument sequence (by ordinal)
# arg_len: number of type arguments
# name:    instance linkage name (mangled, with the type-args suffix)
pub rec Instance {
    decl:    id.DeclId;
    origin:  session.ModuleId;
    args:    *type.TypeId;
    arg_len: u32;
    name:    intern.StrId;
}

# one collected comptime value-parameter instance awaiting body emission: a
# `(decl, origin, comptime-value sequence)` triple plus the mangled symbol name
# the instance is emitted under. mirrors `Instance` but keys on folded comptime
# VALUES (CTValues) rather than type arguments, so a function with one or more
# `$`-parameters is monomorphized once per distinct argument-value sequence. the
# worklist dedups by `name`.
# ---
# decl:    DeclId of the comptime-param function in `origin`'s AST
# origin:  ModuleId that declares the function
# vals:    owned copy of the folded comptime-value sequence (by comptime
#          ordinal)
# val_len: number of comptime values
# names:   owned copy of the bare comptime-param identifiers (by comptime
#          ordinal), paired positionally with `vals` for binding into the
#          comptime context
# name:    instance linkage name (mangled, with the value-args suffix)
pub rec ValueInstance {
    decl:    id.DeclId;
    origin:  session.ModuleId;
    vals:    *comptime.CTValue;
    val_len: u32;
    names:   *intern.StrId;
    name:    intern.StrId;
}

# one collected comptime variadic-pack instance awaiting body emission: a
# `(decl, origin, pack element type-list)` triple plus the mangled symbol name
# the instance is emitted under. mirrors `Instance` but keys on the concrete
# TYPES the pack absorbs at a call site, so a pack-tailed function is
# monomorphized once per distinct trailing arg-type sequence. the worklist
# dedups by `name`.
# ---
# decl:     DeclId of the pack-tailed function in `origin`'s AST
# origin:   ModuleId that declares the function
# types:    owned copy of the pack element type-list (by pack ordinal)
# type_len: number of pack element types
# name:     instance linkage name (mangled, with the type-list suffix)
pub rec PackInstance {
    decl:     id.DeclId;
    origin:   session.ModuleId;
    types:    *type.TypeId;
    type_len: u32;
    name:     intern.StrId;
}

# per-module lowering state, threaded through every decl / stmt / expr.
#
# The leading fields are the phase inputs and the IR being built; the trailing
# fields are the working state for the function currently being lowered (reset
# by `begin_function`).
# ---
# s:             shared session (allocator, interner, type universe)
# tgt:           selected target -- drives IR type sizing
# a:             parsed AST being lowered
# fqn:           FQN of the module being lowered; the mangler qualifies every
#                definition's symbol with it
# own_module:    ModuleId of the module being lowered; keys its export-name
#                overrides and matches a self-reference's origin
# sema_result:   typing output parallel to the AST
# rr:            name-resolution output parallel to the AST
# ctx:           comptime context supplying folded global initialisers
# m:             the IR module being built
# builder:       insertion cursor into `m`
# locals:        source SymbolId -> the Value naming its current storage (an
#                alloca pointer for address-taken / mutable locals)
# local_names:   source local name -> its storage Value, last-binding-wins; the
#                inline-asm lowerer resolves `{name}` references against it
#
# fn_index:      index into m.functions of the function being lowered
# ret_type:      IR return type of the function being lowered
# fn_ret_sem:    semantic return type of the function being lowered, with
#                generic substitution applied inside a monomorphized instance
#                body; used by deferred `$each $fields(T)` body re-inference
#
# loops:         active loop stack (innermost last) for brk / cnt
# loop_len:      number of active loop frames
# loop_cap:      allocated capacity of the loop stack
#
# fins:          deferred `fin` body StmtIds (innermost last)
# fin_len:       number of pending fin entries
# fin_cap:       allocated capacity of the fin stack
#
# subst:         active generic substitution (concrete type-args by param
#                ordinal) while lowering a monomorphized instance body, nil
#                otherwise; lower_type consults it to resolve
#                TYPE_GENERIC_PARAMs
# subst_len:     number of substitution arguments
#
# insts:         per-module worklist of generic instances collected at call
#                sites, drained to fixpoint after the module's decls are lowered
# inst_len:      number of worklist entries
# inst_cap:      allocated capacity of the worklist
# inst_drained:  persistent cursor into `insts`: entries below it are already
#                emitted, so a re-entrant drain emits each generic body exactly
#                once
#
# vinsts:        per-module worklist of comptime value-parameter instances,
#                drained after the type-instance worklist; each binds its
#                `$param -> CTValue` while lowering
# vinst_len:     number of value-instance worklist entries
# vinst_cap:     allocated capacity of the value-instance worklist
# vinst_drained: persistent cursor into `vinsts` (see inst_drained)
#
# pinsts:        per-module worklist of comptime variadic-pack instances,
#                drained alongside the type / value worklists; each expands the
#                pack to N params typed by its element type-list
# pinst_len:     number of pack-instance worklist entries
# pinst_cap:     allocated capacity of the pack-instance worklist
# pinst_drained: persistent cursor into `pinsts` (see inst_drained)
#
# pack_slots:    while lowering a pack instance body, the N expanded pack-
#                parameter alloca slots (by pack ordinal); nil outside a pack
#                instance
# pack_types:    the N concrete pack element semantic types (by pack ordinal),
#                parallel to pack_slots; nil outside a pack instance
# pack_len:      number of expanded pack parameters (0 outside a pack instance)
# pack_ret_type: the pack instance's semantic return type, supplied to per-
#                element body re-inference so a body `ret` checks against it
pub rec LowerContext {
    s:           *session.Session;
    tgt:         *target.Target;
    a:           *ast.Ast;
    fqn:         intern.StrId;
    own_module:  session.ModuleId;
    sema_result: *sema.SemaResult;
    rr:          *resolve.ResolveResult;
    ctx:         *comptime.ComptimeCtx;
    m:           *ir.Module;
    builder:     builder.Builder;
    locals:      map.Map[resolve.SymbolId, value.Value];
    local_names: map.Map[intern.StrId, value.Value];

    fn_index:   u32;
    ret_type:   ir_type.IrTypeId;
    fn_ret_sem: type.TypeId;

    loops:    *LoopFrame;
    loop_len: u32;
    loop_cap: u32;

    fins:    *id.StmtId;
    fin_len: u32;
    fin_cap: u32;

    subst:     *type.TypeId;
    subst_len: u32;

    insts:        *Instance;
    inst_len:     u32;
    inst_cap:     u32;
    inst_drained: u32;

    vinsts:        *ValueInstance;
    vinst_len:     u32;
    vinst_cap:     u32;
    vinst_drained: u32;

    pinsts:        *PackInstance;
    pinst_len:     u32;
    pinst_cap:     u32;
    pinst_drained: u32;

    pack_slots:    *value.Value;
    pack_types:    *type.TypeId;
    pack_len:      u32;
    pack_ret_type: type.TypeId;
}


# initialise a LowerContext: wire the phase inputs, point the builder at the
# module, install the comptime resolvers, build the locals maps, and allocate
# the loop / fin working stacks.
# ---
# lc:          context to populate
# s:           shared session
# tgt:         selected target
# a:           parsed AST
# fqn:         FQN of the module being lowered (for symbol mangling)
# own_module:  ModuleId of the module being lowered
# sema_result: typing output
# rr:          name resolution
# ctx:         comptime context
# m:           IR module being built
# ret:         true on success, or an allocation error
pub fun init_context(
    lc:          *LowerContext,
    s:           *session.Session,
    tgt:         *target.Target,
    a:           *ast.Ast,
    fqn:         intern.StrId,
    own_module:  session.ModuleId,
    sema_result: *sema.SemaResult,
    rr:          *resolve.ResolveResult,
    ctx:         *comptime.ComptimeCtx,
    m:           *ir.Module
) R.Result[bool, str] {
    lc.s           = s;
    lc.tgt         = tgt;
    lc.a           = a;
    lc.fqn         = fqn;
    lc.own_module  = own_module;
    lc.sema_result = sema_result;
    lc.rr          = rr;
    lc.ctx         = ctx;
    lc.m           = m;
    lc.builder     = builder.init(m);

    # install the `alias.CONST` member resolver so comptime.eval can fold module-
    # qualified constant paths in this module's initialisers and gates. data is
    # the LowerContext itself, read live so the value-instance drains' module
    # swaps stay correct.
    comptime.set_member_resolver(ctx, resolve_module_member_const::*u8, lc::ptr);
    # install the type-comparison operand resolver so comptime.eval can fold
    # `$type_of(...)` type gates in this module's bodies.
    comptime.set_type_resolver(ctx, resolve_type_comparison_operand::*u8, lc::ptr);
    # install the field-descriptor member resolver so `f.name` / `f.type` /
    # `f.offset` fold inside `$each` bodies.
    comptime.set_field_resolver(ctx, resolve_field_member::*u8, lc::ptr);

    lc.locals      = map.init[resolve.SymbolId, value.Value](s.alloc, map.hash_u32, map.eq_u32);
    lc.local_names = map.init[intern.StrId, value.Value](s.alloc, map.hash_u32, map.eq_u32);

    lc.fn_index   = 0;
    lc.ret_type   = ir_type.IRT_NIL;
    lc.fn_ret_sem = type.TYPE_NIL;

    val res_loops: R.Result[*LoopFrame, str] = A.allocate[LoopFrame](s.alloc, INITIAL_STACK_CAP::usize);
    if (R.is_err[*LoopFrame, str](res_loops)) {
        map.dnit[intern.StrId, value.Value](?lc.local_names);
        map.dnit[resolve.SymbolId, value.Value](?lc.locals);
        ret R.err[bool, str](R.unwrap_err[*LoopFrame, str](res_loops));
    }
    lc.loops    = R.unwrap_ok[*LoopFrame, str](res_loops);
    lc.loop_len = 0;
    lc.loop_cap = INITIAL_STACK_CAP;

    val res_fins: R.Result[*id.StmtId, str] = A.allocate[id.StmtId](s.alloc, INITIAL_STACK_CAP::usize);
    if (R.is_err[*id.StmtId, str](res_fins)) {
        A.deallocate[LoopFrame](s.alloc, lc.loops, lc.loop_cap::usize);
        map.dnit[intern.StrId, value.Value](?lc.local_names);
        map.dnit[resolve.SymbolId, value.Value](?lc.locals);
        ret R.err[bool, str](R.unwrap_err[*id.StmtId, str](res_fins));
    }
    lc.fins    = R.unwrap_ok[*id.StmtId, str](res_fins);
    lc.fin_len = 0;
    lc.fin_cap = INITIAL_STACK_CAP;

    lc.subst     = nil;
    lc.subst_len = 0;

    lc.insts        = nil;
    lc.inst_len     = 0;
    lc.inst_cap     = 0;
    lc.inst_drained = 0;

    lc.vinsts        = nil;
    lc.vinst_len     = 0;
    lc.vinst_cap     = 0;
    lc.vinst_drained = 0;

    lc.pinsts        = nil;
    lc.pinst_len     = 0;
    lc.pinst_cap     = 0;
    lc.pinst_drained = 0;

    lc.pack_slots    = nil;
    lc.pack_types    = nil;
    lc.pack_len      = 0;
    lc.pack_ret_type = type.TYPE_NIL;

    ret R.ok[bool, str](true);
}

# release the working storage held by a LowerContext (the locals maps, the loop
# and fin stacks, and the three instance worklists) and clear the comptime
# resolvers init_context installed, so the borrowed ctx never keeps a dangling
# LowerContext pointer past this module's lowering. does not otherwise touch the
# borrowed phase inputs or the module.
# ---
# lc: context to tear down
pub fun dnit_context(lc: *LowerContext) {
    if (lc == nil) { ret; }
    if (lc.ctx != nil) {
        comptime.set_member_resolver(lc.ctx, nil, nil);
        comptime.set_type_resolver(lc.ctx, nil, nil);
        comptime.set_field_resolver(lc.ctx, nil, nil);
    }
    map.dnit[intern.StrId, value.Value](?lc.local_names);
    map.dnit[resolve.SymbolId, value.Value](?lc.locals);

    if (lc.loops != nil && lc.loop_cap > 0) {
        A.deallocate[LoopFrame](lc.s.alloc, lc.loops, lc.loop_cap::usize);
    }
    if (lc.fins != nil && lc.fin_cap > 0) {
        A.deallocate[id.StmtId](lc.s.alloc, lc.fins, lc.fin_cap::usize);
    }
    if (lc.insts != nil && lc.inst_cap > 0) {
        var i: u32 = 0;
        for (i < lc.inst_len) {
            if (lc.insts[i].args != nil && lc.insts[i].arg_len > 0) {
                A.deallocate[type.TypeId](lc.s.alloc, lc.insts[i].args, lc.insts[i].arg_len::usize);
            }
            i = i + 1;
        }
        A.deallocate[Instance](lc.s.alloc, lc.insts, lc.inst_cap::usize);
    }
    if (lc.vinsts != nil && lc.vinst_cap > 0) {
        var i: u32 = 0;
        for (i < lc.vinst_len) {
            if (lc.vinsts[i].vals != nil && lc.vinsts[i].val_len > 0) {
                A.deallocate[comptime.CTValue](lc.s.alloc, lc.vinsts[i].vals, lc.vinsts[i].val_len::usize);
            }
            if (lc.vinsts[i].names != nil && lc.vinsts[i].val_len > 0) {
                A.deallocate[intern.StrId](lc.s.alloc, lc.vinsts[i].names, lc.vinsts[i].val_len::usize);
            }
            i = i + 1;
        }
        A.deallocate[ValueInstance](lc.s.alloc, lc.vinsts, lc.vinst_cap::usize);
    }
    if (lc.pinsts != nil && lc.pinst_cap > 0) {
        var i: u32 = 0;
        for (i < lc.pinst_len) {
            if (lc.pinsts[i].types != nil && lc.pinsts[i].type_len > 0) {
                A.deallocate[type.TypeId](lc.s.alloc, lc.pinsts[i].types, lc.pinsts[i].type_len::usize);
            }
            i = i + 1;
        }
        A.deallocate[PackInstance](lc.s.alloc, lc.pinsts, lc.pinst_cap::usize);
    }

    lc.loops    = nil;
    lc.loop_len = 0;
    lc.loop_cap = 0;
    lc.fins     = nil;
    lc.fin_len  = 0;
    lc.fin_cap  = 0;

    lc.insts        = nil;
    lc.inst_len     = 0;
    lc.inst_cap     = 0;
    lc.inst_drained = 0;

    lc.vinsts        = nil;
    lc.vinst_len     = 0;
    lc.vinst_cap     = 0;
    lc.vinst_drained = 0;

    lc.pinsts        = nil;
    lc.pinst_len     = 0;
    lc.pinst_cap     = 0;
    lc.pinst_drained = 0;

    lc.pack_slots    = nil;
    lc.pack_types    = nil;
    lc.pack_len      = 0;
    lc.pack_ret_type = type.TYPE_NIL;
}

# the `alias.CONST` member resolver lowering installs on every ComptimeCtx it
# evaluates against (a comptime.ModuleMemberFn).
#
# Given a module-qualified member expression, it reads the active module's name
# resolution for the member's resolved symbol; when that symbol is a constant
# imported from another module, it returns the constant's pre-folded comptime
# value from the declaring module's ComptimeCtx. It returns none -- leaving
# comptime.eval to reject the path with a loud error -- whenever the member
# resolves to anything else (a function, a `var`, a non-constant `val`, or an
# unexported / unknown member): the declaring module's ctx holds exactly its
# transitively-constant module-level vals, so a lookup miss there is the scope
# guard for everything that is not a constant. `data` is the *LowerContext
# driving the evaluation; reading its `rr` / `s` live keeps the resolver correct
# across the value-instance drains that swap the active module.
# ---
# data: the *LowerContext, erased to a ptr by the installer
# eid:  the MEMBER expression id, valid in the active module's ast
# ret:  some(value) when the member names a module-level constant, else none
pub fun resolve_module_member_const(data: ptr, eid: id.ExprId) R.Result[O.Option[comptime.CTValue], str] {
    val lc: *LowerContext = data::*LowerContext;
    if (lc == nil) { ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]()); }
    val rr: *resolve.ResolveResult = lc.rr;
    if (rr == nil || rr.expr_resolved == nil || eid::u32 >= rr.expr_count) {
        ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]());
    }
    val sid: resolve.SymbolId = rr.expr_resolved[eid];
    if (sid == resolve.SYMBOL_NIL || sid::u32 >= rr.symbol_count) {
        ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]());
    }
    val sym: *resolve.Symbol = ?rr.symbols[sid];
    if (sym.kind != resolve.SYM_IMPORTED) {
        ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]());
    }
    val octx: *comptime.ComptimeCtx = (session.module_comptime_ptr(lc.s, sym.origin))::*comptime.ComptimeCtx;
    if (octx == nil) { ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]()); }
    val nc: O.Option[*comptime.NamedConst] = comptime.lookup(octx, sym.name);
    if (O.is_none[*comptime.NamedConst](nc)) {
        ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]());
    }
    ret R.ok[O.Option[comptime.CTValue], str](O.some[comptime.CTValue](O.unwrap[*comptime.NamedConst](nc).value));
}

# the type-comparison operand resolver lowering installs on every ComptimeCtx it
# evaluates against (a comptime.TypeIdentFn).
#
# Given the value expression of a type-comparison operand -- a `$type_of(...)`'s
# inner value, or a type-name spelling -- it returns the operand's interned
# semantic TypeId as an opaque type-identity token, so a `$type_of(x) == i64`
# gate folds to an identity compare. None when the expression carries no
# resolved type (an untyped or erroneous operand), leaving comptime.eval to
# defer / error. `data` is the *LowerContext driving the evaluation; reading its
# `sema_result` live keeps the resolver correct across the value-instance drains
# that swap the active module.
# ---
# data: the *LowerContext, erased to a ptr by the installer
# eid:  the operand value expression id, valid in the active module's ast
# ret:  some(type-id token) when the operand has a resolved type, else none
pub fun resolve_type_comparison_operand(data: ptr, eid: id.ExprId) R.Result[O.Option[u32], str] {
    val lc: *LowerContext = data::*LowerContext;
    if (lc == nil) { ret R.ok[O.Option[u32], str](O.none[u32]()); }
    val t: type.TypeId = expr_type_of(lc, eid);
    if (t == type.TYPE_NIL || t == type.TYPE_ERROR) { ret R.ok[O.Option[u32], str](O.none[u32]()); }
    ret R.ok[O.Option[u32], str](O.some[u32](t::u32));
}

# the field-descriptor member resolver lowering installs on every ComptimeCtx it
# evaluates against (a comptime.FieldMemberFn).
#
# Given the owning record's sema TypeId, a field ordinal, and a FIELD_SEL_*
# selector, it projects the field's `.name` (str), `.type` (a sema TypeId
# token), or `.offset` (its byte offset in the target layout, the same authority
# `$offset_of` reads). None when the ordinal is out of range.
# ---
# data:  the *LowerContext, erased to a ptr by the installer
# owner: the owning record's sema TypeId
# index: the field ordinal
# sel:   a comptime.FIELD_SEL_* selector
# ret:   some(value) for the projected attribute, else none
pub fun resolve_field_member(data: ptr, owner: u32, index: u32, sel: u8) R.Result[O.Option[comptime.CTValue], str] {
    val lc: *LowerContext = data::*LowerContext;
    if (lc == nil) { ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]()); }
    val owner_ty: type.TypeId = owner::type.TypeId;
    val fa: O.Option[*type.FieldEntry] = type.field_at(?lc.s.types, owner_ty, index);
    if (O.is_none[*type.FieldEntry](fa)) { ret R.ok[O.Option[comptime.CTValue], str](O.none[comptime.CTValue]()); }
    val fe: *type.FieldEntry = O.unwrap[*type.FieldEntry](fa);

    if (sel == comptime.FIELD_SEL_NAME) {
        ret R.ok[O.Option[comptime.CTValue], str](O.some[comptime.CTValue](comptime.ct_str(fe.name)));
    }
    if (sel == comptime.FIELD_SEL_TYPE) {
        ret R.ok[O.Option[comptime.CTValue], str](O.some[comptime.CTValue](comptime.ct_type(fe.ty::u32)));
    }

    # offset: the field's byte offset in the target layout (IR authority).
    val res_ir: R.Result[ir_type.IrTypeId, str] = lower_type(lc, owner_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[O.Option[comptime.CTValue], str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    val ir_id: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);
    val off: u32 = ir_type.byte_offset(?lc.m.types, ir_id, index, lc.tgt);
    ret R.ok[O.Option[comptime.CTValue], str](O.some[comptime.CTValue](comptime.ct_uint(off::u64)));
}

# reset the per-function working state before lowering a new function: clear the
# locals maps and the loop / fin stacks, and record the new function index and
# IR return type. the builder cursor is set by the caller (`lower.decl.lower_fun`)
# once the entry block exists.
# ---
# lc:       the context
# fn_index: index of the function in m.functions
# ret_type: the function's IR return type
pub fun begin_function(lc: *LowerContext, fn_index: u32, ret_type: ir_type.IrTypeId) {
    map.clear[resolve.SymbolId, value.Value](?lc.locals);
    map.clear[intern.StrId, value.Value](?lc.local_names);
    lc.loop_len   = 0;
    lc.fin_len    = 0;
    lc.fn_index   = fn_index;
    lc.ret_type   = ret_type;
    lc.fn_ret_sem = type.TYPE_NIL;

    # pack-instance body state defaults off; lower_pack_instance sets it after
    # this reset, and an ordinary function (or a generic / value instance) never
    # reads it.
    lc.pack_slots    = nil;
    lc.pack_types    = nil;
    lc.pack_len      = 0;
    lc.pack_ret_type = type.TYPE_NIL;
}

# bind a source SymbolId to the IR Value that names its storage. for locals this
# is the alloca-slot pointer; for parameters seeded before the body it may be a
# VAL_PARAM. overwrites any prior binding.
#
# The binding is also recorded by source name in `local_names` (last-binding-
# wins) so the inline-asm lowerer can resolve a `{name}` reference to its storage
# Value, mirroring cmach's name-keyed local table.
# ---
# lc:  the context
# sym: source symbol id
# v:   the Value to bind
# ret: true on success, or an allocation error from the map
pub fun bind_local(lc: *LowerContext, sym: resolve.SymbolId, v: value.Value) R.Result[bool, str] {
    val res_bind: R.Result[bool, str] = map.insert[resolve.SymbolId, value.Value](?lc.locals, sym, v);
    if (R.is_err[bool, str](res_bind)) { ret res_bind; }

    val opt_sym: O.Option[*resolve.Symbol] = symbol_of(lc, sym);
    if (O.is_some[*resolve.Symbol](opt_sym)) {
        val name: intern.StrId = O.unwrap[*resolve.Symbol](opt_sym).name;
        if (name != intern.STR_NIL) {
            ret map.insert[intern.StrId, value.Value](?lc.local_names, name, v);
        }
    }
    ret R.ok[bool, str](true);
}

# look up the storage Value bound to a source local by interned name, or none
# when no local with that name is in scope. the inline-asm lowerer uses this to
# resolve `{name}` references in an asm body to the local's alloca slot.
# ---
# lc:   the context
# name: interned source local name
# ret:  some(Value) when a local of that name is bound, none otherwise
pub fun lookup_local_name(lc: *LowerContext, name: intern.StrId) O.Option[value.Value] {
    var key: intern.StrId = name;
    val res_get: R.Result[*value.Value, str] = map.get[intern.StrId, value.Value](?lc.local_names, ?key);
    if (R.is_ok[*value.Value, str](res_get)) {
        ret O.some[value.Value](@R.unwrap_ok[*value.Value, str](res_get));
    }
    ret O.none[value.Value]();
}

# look up the Value bound to a source SymbolId, or none when the symbol has no
# local binding (a global or function reference).
# ---
# lc:  the context
# sym: source symbol id
# ret: some(Value) when bound, none otherwise
pub fun lookup_local(lc: *LowerContext, sym: resolve.SymbolId) O.Option[value.Value] {
    val res_get: R.Result[*value.Value, str] = map.get[resolve.SymbolId, value.Value](?lc.locals, ?sym);
    if (R.is_ok[*value.Value, str](res_get)) {
        ret O.some[value.Value](@R.unwrap_ok[*value.Value, str](res_get));
    }
    ret O.none[value.Value]();
}

# push a loop frame, recording the header and exit blocks the innermost `cnt` /
# `brk` branch to. grows the loop stack on overflow.
# ---
# lc:     the context
# header: block `cnt` branches to
# exit:   block `brk` branches to
# ret:    true on success, or an allocation error
pub fun push_loop(lc: *LowerContext, header: ir.BlockId, exit: ir.BlockId) R.Result[bool, str] {
    if (lc.loop_len == lc.loop_cap) {
        val new_cap: u32 = lc.loop_cap * 2;
        val res_grow: R.Result[*LoopFrame, str] = A.reallocate[LoopFrame](lc.s.alloc, lc.loops, lc.loop_cap::usize, new_cap::usize);
        if (R.is_err[*LoopFrame, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*LoopFrame, str](res_grow)); }
        lc.loops    = R.unwrap_ok[*LoopFrame, str](res_grow);
        lc.loop_cap = new_cap;
    }
    var f: LoopFrame;
    f.header = header;
    f.exit   = exit;
    lc.loops[lc.loop_len] = f;
    lc.loop_len = lc.loop_len + 1;
    ret R.ok[bool, str](true);
}

# pop the innermost loop frame. no-op when the stack is empty.
# ---
# lc: the context
pub fun pop_loop(lc: *LowerContext) {
    if (lc.loop_len > 0) { lc.loop_len = lc.loop_len - 1; }
}

# return a pointer to the innermost active loop frame, or nil outside any loop.
# a pointer (rather than a by-value `Option[LoopFrame]`) keeps the two block ids
# stable through the call boundary.
# ---
# lc:  the context
# ret: pointer to the innermost LoopFrame, or nil outside any loop
pub fun current_loop(lc: *LowerContext) *LoopFrame {
    if (lc.loop_len == 0) { ret nil; }
    ret ?lc.loops[lc.loop_len - 1];
}

# record a generic instance `(decl, origin, args)` on the per-module worklist
# under its mangled `name`, deduped by name (a linear scan, no map/hash, so
# determinism is preserved). takes an OWNED copy of `args` so the caller's buffer
# can be reused / freed; the copy is released when the context is torn down. an
# already-queued or already-emitted instance is skipped.
# ---
# lc:      the context
# decl:    DeclId of the generic function in `origin`'s AST
# origin:  ModuleId declaring the generic
# args:    concrete type-argument sequence (copied)
# arg_len: number of type arguments
# name:    instance linkage name
# ret:     true on success, or an allocation error
pub fun enqueue_instance(lc: *LowerContext, decl: id.DeclId, origin: session.ModuleId,
                         args: *type.TypeId, arg_len: u32, name: intern.StrId) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < lc.inst_len) {
        if (lc.insts[i].name == name) { ret R.ok[bool, str](true); }
        i = i + 1;
    }

    if (lc.inst_len == lc.inst_cap) {
        var new_cap: u32 = lc.inst_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_STACK_CAP; }
        if (lc.insts == nil) {
            val res_grow: R.Result[*Instance, str] = A.allocate[Instance](lc.s.alloc, new_cap::usize);
            if (R.is_err[*Instance, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*Instance, str](res_grow)); }
            lc.insts = R.unwrap_ok[*Instance, str](res_grow);
        }
        or {
            val res_grow: R.Result[*Instance, str] = A.reallocate[Instance](lc.s.alloc, lc.insts, lc.inst_cap::usize, new_cap::usize);
            if (R.is_err[*Instance, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*Instance, str](res_grow)); }
            lc.insts = R.unwrap_ok[*Instance, str](res_grow);
        }
        lc.inst_cap = new_cap;
    }

    var args_copy: *type.TypeId = nil;
    if (arg_len > 0) {
        val res_copy: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](lc.s.alloc, arg_len::usize);
        if (R.is_err[*type.TypeId, str](res_copy)) { ret R.err[bool, str](R.unwrap_err[*type.TypeId, str](res_copy)); }
        args_copy = R.unwrap_ok[*type.TypeId, str](res_copy);
        var j: u32 = 0;
        for (j < arg_len) { args_copy[j] = args[j]; j = j + 1; }
    }

    var inst: Instance;
    inst.decl    = decl;
    inst.origin  = origin;
    inst.args    = args_copy;
    inst.arg_len = arg_len;
    inst.name    = name;
    lc.insts[lc.inst_len] = inst;
    lc.inst_len = lc.inst_len + 1;
    ret R.ok[bool, str](true);
}

# record a comptime value-parameter instance `(decl, origin, vals, names)` on the
# per-module worklist under its mangled `name`, deduped by name (a linear scan,
# as `enqueue_instance`). takes OWNED copies of `vals` and `names` so the
# caller's buffers can be reused / freed; the copies are released when the
# context is torn down. exceeding MAX_VALUE_INSTANCES distinct instances is
# reported as an error (a recursive comptime-param function called with a
# changing value would otherwise instantiate without end).
# ---
# lc:      the context
# decl:    DeclId of the comptime-param function in `origin`'s AST
# origin:  ModuleId declaring the function
# vals:    folded comptime-value sequence (copied), by comptime ordinal
# names:   bare comptime-param identifiers (copied), by comptime ordinal
# val_len: number of comptime values / names
# name:    instance linkage name
# ret:     true on success, or an allocation / cap error
pub fun enqueue_value_instance(lc: *LowerContext, decl: id.DeclId, origin: session.ModuleId,
                               vals: *comptime.CTValue, names: *intern.StrId, val_len: u32,
                               name: intern.StrId) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < lc.vinst_len) {
        if (lc.vinsts[i].name == name) { ret R.ok[bool, str](true); }
        i = i + 1;
    }

    if (lc.vinst_len >= MAX_VALUE_INSTANCES) {
        ret R.err[bool, str]("comptime value-parameter instantiation limit exceeded (likely unbounded comptime recursion)");
    }

    if (lc.vinst_len == lc.vinst_cap) {
        var new_cap: u32 = lc.vinst_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_STACK_CAP; }
        if (lc.vinsts == nil) {
            val res_grow: R.Result[*ValueInstance, str] = A.allocate[ValueInstance](lc.s.alloc, new_cap::usize);
            if (R.is_err[*ValueInstance, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*ValueInstance, str](res_grow)); }
            lc.vinsts = R.unwrap_ok[*ValueInstance, str](res_grow);
        }
        or {
            val res_grow: R.Result[*ValueInstance, str] = A.reallocate[ValueInstance](lc.s.alloc, lc.vinsts, lc.vinst_cap::usize, new_cap::usize);
            if (R.is_err[*ValueInstance, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*ValueInstance, str](res_grow)); }
            lc.vinsts = R.unwrap_ok[*ValueInstance, str](res_grow);
        }
        lc.vinst_cap = new_cap;
    }

    var vals_copy: *comptime.CTValue = nil;
    var names_copy: *intern.StrId = nil;
    if (val_len > 0) {
        val res_vals: R.Result[*comptime.CTValue, str] = A.allocate[comptime.CTValue](lc.s.alloc, val_len::usize);
        if (R.is_err[*comptime.CTValue, str](res_vals)) { ret R.err[bool, str](R.unwrap_err[*comptime.CTValue, str](res_vals)); }
        vals_copy = R.unwrap_ok[*comptime.CTValue, str](res_vals);
        val res_names: R.Result[*intern.StrId, str] = A.allocate[intern.StrId](lc.s.alloc, val_len::usize);
        if (R.is_err[*intern.StrId, str](res_names)) {
            A.deallocate[comptime.CTValue](lc.s.alloc, vals_copy, val_len::usize);
            ret R.err[bool, str](R.unwrap_err[*intern.StrId, str](res_names));
        }
        names_copy = R.unwrap_ok[*intern.StrId, str](res_names);
        var j: u32 = 0;
        for (j < val_len) { vals_copy[j] = vals[j]; names_copy[j] = names[j]; j = j + 1; }
    }

    var inst: ValueInstance;
    inst.decl    = decl;
    inst.origin  = origin;
    inst.vals    = vals_copy;
    inst.val_len = val_len;
    inst.names   = names_copy;
    inst.name    = name;
    lc.vinsts[lc.vinst_len] = inst;
    lc.vinst_len = lc.vinst_len + 1;
    ret R.ok[bool, str](true);
}

# record a comptime variadic-pack instance `(decl, origin, type-list)` on the
# per-module worklist under its mangled `name`, deduped by name (a linear scan,
# as `enqueue_instance`). takes an OWNED copy of `types` so the caller's buffer
# can be reused / freed; the copy is released when the context is torn down.
# ---
# lc:       the context
# decl:     DeclId of the pack-tailed function in `origin`'s AST
# origin:   ModuleId declaring the function
# types:    pack element type-list (copied), by pack ordinal
# type_len: number of pack element types
# name:     instance linkage name
# ret:      true on success, or an allocation error
pub fun enqueue_pack_instance(lc: *LowerContext, decl: id.DeclId, origin: session.ModuleId,
                              types: *type.TypeId, type_len: u32, name: intern.StrId) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < lc.pinst_len) {
        if (lc.pinsts[i].name == name) { ret R.ok[bool, str](true); }
        i = i + 1;
    }

    if (lc.pinst_len == lc.pinst_cap) {
        var new_cap: u32 = lc.pinst_cap * 2;
        if (new_cap == 0) { new_cap = INITIAL_STACK_CAP; }
        if (lc.pinsts == nil) {
            val res_grow: R.Result[*PackInstance, str] = A.allocate[PackInstance](lc.s.alloc, new_cap::usize);
            if (R.is_err[*PackInstance, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*PackInstance, str](res_grow)); }
            lc.pinsts = R.unwrap_ok[*PackInstance, str](res_grow);
        }
        or {
            val res_grow: R.Result[*PackInstance, str] = A.reallocate[PackInstance](lc.s.alloc, lc.pinsts, lc.pinst_cap::usize, new_cap::usize);
            if (R.is_err[*PackInstance, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*PackInstance, str](res_grow)); }
            lc.pinsts = R.unwrap_ok[*PackInstance, str](res_grow);
        }
        lc.pinst_cap = new_cap;
    }

    var types_copy: *type.TypeId = nil;
    if (type_len > 0) {
        val res_copy: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](lc.s.alloc, type_len::usize);
        if (R.is_err[*type.TypeId, str](res_copy)) { ret R.err[bool, str](R.unwrap_err[*type.TypeId, str](res_copy)); }
        types_copy = R.unwrap_ok[*type.TypeId, str](res_copy);
        var j: u32 = 0;
        for (j < type_len) { types_copy[j] = types[j]; j = j + 1; }
    }

    var inst: PackInstance;
    inst.decl     = decl;
    inst.origin   = origin;
    inst.types    = types_copy;
    inst.type_len = type_len;
    inst.name     = name;
    lc.pinsts[lc.pinst_len] = inst;
    lc.pinst_len = lc.pinst_len + 1;
    ret R.ok[bool, str](true);
}

# push a deferred `fin` body. the body StmtId is replayed (lowered inline) before
# every reachable terminator that closes the enclosing scope. grows the fin stack
# on overflow.
# ---
# lc:   the context
# body: StmtId of the fin body
# ret:  true on success, or an allocation error
pub fun push_fin(lc: *LowerContext, body: id.StmtId) R.Result[bool, str] {
    if (lc.fin_len == lc.fin_cap) {
        val new_cap: u32 = lc.fin_cap * 2;
        val res_grow: R.Result[*id.StmtId, str] = A.reallocate[id.StmtId](lc.s.alloc, lc.fins, lc.fin_cap::usize, new_cap::usize);
        if (R.is_err[*id.StmtId, str](res_grow)) { ret R.err[bool, str](R.unwrap_err[*id.StmtId, str](res_grow)); }
        lc.fins    = R.unwrap_ok[*id.StmtId, str](res_grow);
        lc.fin_cap = new_cap;
    }
    lc.fins[lc.fin_len] = body;
    lc.fin_len = lc.fin_len + 1;
    ret R.ok[bool, str](true);
}

# return the number of pending fin bodies.
# ---
# lc:  the context
# ret: count of deferred fin entries
pub fun fin_count(lc: *LowerContext) u32 {
    ret lc.fin_len;
}

# return the fin body StmtId at stack index `i` (0 = outermost), or STMT_NIL when
# out of range.
# ---
# lc:  the context
# i:   stack index in [0, fin_count)
# ret: the StmtId, or STMT_NIL when out of range
pub fun fin_at(lc: *LowerContext, i: u32) id.StmtId {
    if (i >= lc.fin_len) { ret id.STMT_NIL; }
    ret lc.fins[i];
}

# lower a semantic `type.TypeId` into the module's IR type universe.
#
# Generics, instances, and aliases are assumed resolved by sema; this maps the
# concrete machine shapes. Unknown / error types lower to void so that lowering
# never aborts on a poisoned upstream type (dce / the verifier surface the real
# problem).
# ---
# lc:  the context
# tid: semantic TypeId
# ret: the corresponding IrTypeId, or an allocation error
pub fun lower_type(lc: *LowerContext, tid: type.TypeId) R.Result[ir_type.IrTypeId, str] {
    if (tid == type.TYPE_NIL) {
        ret ir_type.intern_void(?lc.m.types);
    }

    # while lowering a monomorphized instance body, resolve any generic parameter
    # in `tid` (a bare `T`, `*T`, `[N]T`, a nested `Result[T,E]`, etc.) to its
    # concrete type-argument before mapping the machine shape, so storage sizing
    # and field layout match the instance instead of falling through to the
    # pointer-width erasure below.
    var rtid: type.TypeId = tid;
    if (lc.subst != nil && lc.subst_len > 0) {
        rtid = generics.substitute(lc.s, tid, lc.subst, lc.subst_len);
    }

    # ensure a generic instance's substituted field table exists before lowering
    # it, regardless of whether the current body substitutes params. a non-generic
    # function that names a concrete instance (e.g. returning `Option[str]`) never
    # substitutes, so without this its instance lowers against an unpopulated field
    # store and collapses to an undersized struct. a no-op for non-instances and
    # already-tabled instances.
    generics.ensure_fields(lc.s, rtid);

    val t_opt: O.Option[*type.Type] = type.get(?lc.s.types, rtid);
    if (O.is_none[*type.Type](t_opt)) {
        ret ir_type.intern_void(?lc.m.types);
    }
    val t: *type.Type = O.unwrap[*type.Type](t_opt);
    val k: type.TypeKind = t.kind;

    # secrecy has no runtime representation (#1645): `^T` lowers to exactly `T`'s
    # machine shape. the secret-taint-to-MIR contract that propagates it through
    # codegen for the constant-time guarantee lands separately (#1646).
    if (k == type.TYPE_SECRET) { ret lower_type(lc, t.data.secret.base); }

    val d: type.PrimDesc = type.prim_desc(k);
    if (d.class == type.PRIM_CLASS_INT)   { ret ir_type.intern_int(?lc.m.types, d.bits); }
    if (d.class == type.PRIM_CLASS_FLOAT) { ret ir_type.intern_float(?lc.m.types, d.bits); }
    if (d.class == type.PRIM_CLASS_PTR)   { ret ir_type.intern_ptr(?lc.m.types); }
    if (k == type.TYPE_POINTER)           { ret ir_type.intern_ptr(?lc.m.types); }

    if (k == type.TYPE_ARRAY) {
        val res_base: R.Result[ir_type.IrTypeId, str] = lower_type(lc, t.data.array.base);
        if (R.is_err[ir_type.IrTypeId, str](res_base)) { ret res_base; }
        ret ir_type.intern_array(?lc.m.types, R.unwrap_ok[ir_type.IrTypeId, str](res_base), t.data.array.count);
    }

    # records, unions, and generic instances all lower to an IR struct of their
    # field layout, read from the session-global field store. a generic instance
    # carries a substituted field table (built by `generics.instantiate`), so it
    # lowers to the same concrete shape as a non-generic record -- field access
    # within a generic body GEPs through it correctly.
    if (k == type.TYPE_REC || k == type.TYPE_UNI || k == type.TYPE_INSTANCE) {
        ret lower_nominal(lc, rtid, k == type.TYPE_UNI);
    }

    if (k == type.TYPE_FUN) {
        ret lower_function_type(lc, t);
    }

    # generic params / errors that survived to here lower to a pointer-width
    # opaque slot so storage sizing still works.
    ret ir_type.intern_ptr(?lc.m.types);
}

# lower a nominal (rec / uni) semantic type to an IR struct of its lowered field
# types, read from the session-global field store keyed by TypeId. the store is
# the canonical field layout (built once by sema and shared across phases and
# modules), so it resolves anonymous records -- whose identity is structural, not
# tied to a single AST declaration -- as well as named records referenced from
# another module. a type with no field table lowers to an empty struct, keeping
# lowering total.
# ---
# lc:       the context
# tid:      the nominal semantic TypeId
# is_union: lower to an IR union rather than a struct
# ret:      the IrTypeId, or an allocation error
fun lower_nominal(lc: *LowerContext, tid: type.TypeId, is_union: bool) R.Result[ir_type.IrTypeId, str] {
    # an `#[align(...)]` decorator on the record/union, folded by sema and keyed
    # by this nominal TypeId; 0 leaves the natural alignment.
    var nom_align: u32 = 0;
    val ta: O.Option[u32] = session.type_align(lc.s, tid::u32);
    if (O.is_some[u32](ta)) { nom_align = O.unwrap[u32](ta); }

    val fields_len: u32 = type.field_count(?lc.s.types, tid);
    if (fields_len == 0) {
        ret ir_type.intern_struct(?lc.m.types, nil, 0, nom_align);
    }

    val res_buf: R.Result[*ir_type.IrTypeId, str] = A.allocate[ir_type.IrTypeId](lc.s.alloc, fields_len::usize);
    if (R.is_err[*ir_type.IrTypeId, str](res_buf)) {
        ret R.err[ir_type.IrTypeId, str](R.unwrap_err[*ir_type.IrTypeId, str](res_buf));
    }
    val buf: *ir_type.IrTypeId = R.unwrap_ok[*ir_type.IrTypeId, str](res_buf);

    var i: u32 = 0;
    for (i < fields_len) {
        val fe_opt: O.Option[*type.FieldEntry] = type.field_at(?lc.s.types, tid, i);
        if (O.is_none[*type.FieldEntry](fe_opt)) {
            # field_count promised fields_len entries, so an in-range miss is a
            # corrupt field table, not a layout we can guess. fail rather than
            # substitute a pointer-width slot and silently mis-size the type.
            A.deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
            ret R.err[ir_type.IrTypeId, str]("field table for nominal type is missing an in-range field");
        }

        val sem: type.TypeId = O.unwrap[*type.FieldEntry](fe_opt).ty;
        val res_field: R.Result[ir_type.IrTypeId, str] = lower_type(lc, sem);
        if (R.is_err[ir_type.IrTypeId, str](res_field)) {
            A.deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
            ret res_field;
        }
        buf[i] = R.unwrap_ok[ir_type.IrTypeId, str](res_field);
        i = i + 1;
    }

    var res_struct: R.Result[ir_type.IrTypeId, str];
    if (is_union) {
        res_struct = ir_type.intern_union(?lc.m.types, buf, fields_len, nom_align);
    }
    or {
        res_struct = ir_type.intern_struct(?lc.m.types, buf, fields_len, nom_align);
    }
    A.deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
    ret res_struct;
}

# lower a TYPE_FUN semantic type into an IRT_FN. parameter types come from the
# type interner's param pool.
# ---
# lc: the context
# t:  the function Type to lower
# ret: the IRT_FN IrTypeId, or an allocation error
fun lower_function_type(lc: *LowerContext, t: *type.Type) R.Result[ir_type.IrTypeId, str] {
    val res_ret: R.Result[ir_type.IrTypeId, str] = lower_type(lc, t.data.fn.ret_type);
    if (R.is_err[ir_type.IrTypeId, str](res_ret)) { ret res_ret; }
    val ir_ret: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ret);

    val params_len: u32 = t.data.fn.params_len;
    if (params_len == 0) {
        ret ir_type.intern_fn(?lc.m.types, ir_ret, nil, 0);
    }

    val res_buf: R.Result[*ir_type.IrTypeId, str] = A.allocate[ir_type.IrTypeId](lc.s.alloc, params_len::usize);
    if (R.is_err[*ir_type.IrTypeId, str](res_buf)) {
        ret R.err[ir_type.IrTypeId, str](R.unwrap_err[*ir_type.IrTypeId, str](res_buf));
    }
    val buf: *ir_type.IrTypeId = R.unwrap_ok[*ir_type.IrTypeId, str](res_buf);

    var i: u32 = 0;
    for (i < params_len) {
        val po: O.Option[type.TypeId] = type.get_param(?lc.s.types, t.data.fn.params_start + i);
        var p_sem: type.TypeId = type.TYPE_NIL;
        if (O.is_some[type.TypeId](po)) { p_sem = O.unwrap[type.TypeId](po); }
        val res_param: R.Result[ir_type.IrTypeId, str] = lower_type(lc, p_sem);
        if (R.is_err[ir_type.IrTypeId, str](res_param)) {
            A.deallocate[ir_type.IrTypeId](lc.s.alloc, buf, params_len::usize);
            ret res_param;
        }
        buf[i] = R.unwrap_ok[ir_type.IrTypeId, str](res_param);
        i = i + 1;
    }

    val res_fn: R.Result[ir_type.IrTypeId, str] = ir_type.intern_fn(?lc.m.types, ir_ret, buf, params_len);
    A.deallocate[ir_type.IrTypeId](lc.s.alloc, buf, params_len::usize);
    ret res_fn;
}

# return the semantic type of an expression from the sema result, or TYPE_NIL
# when the id is out of range.
# ---
# lc:  the context
# eid: AST ExprId
# ret: the expression's interned semantic TypeId (TYPE_NIL if unknown)
pub fun expr_type_of(lc: *LowerContext, eid: id.ExprId) type.TypeId {
    if (eid == id.EXPR_NIL)          { ret type.TYPE_NIL; }
    if (eid::usize >= lc.a.expr_len) { ret type.TYPE_NIL; }
    ret lc.sema_result.expr_type[eid];
}

# apply the active generic substitution to `tid`, returning the concrete sema
# TypeId. when no substitution is active (not inside a monomorphized generic
# instance body), `tid` is returned unchanged. used to resolve a deferred
# `$fields(T)` type argument to its concrete record type.
# ---
# lc:  the context
# tid: semantic TypeId
# ret: the substituted TypeId, or `tid` when no substitution is active
pub fun substitute_type(lc: *LowerContext, tid: type.TypeId) type.TypeId {
    if (lc.subst == nil || lc.subst_len == 0) { ret tid; }
    ret generics.substitute(lc.s, tid, lc.subst, lc.subst_len);
}

# return the interned semantic type a syntactic AstType resolved to, or TYPE_NIL
# when the id is out of range.
# ---
# lc:  the context
# tid: AST TypeId
# ret: the interned semantic TypeId (TYPE_NIL if unknown)
pub fun type_resolved_of(lc: *LowerContext, tid: id.TypeId) type.TypeId {
    if (tid == id.TYPE_NIL)          { ret type.TYPE_NIL; }
    if (tid::usize >= lc.a.type_len) { ret type.TYPE_NIL; }
    ret lc.sema_result.type_resolved_ty[tid];
}

# return the declared / inferred semantic type of a decl, or TYPE_NIL.
# ---
# lc:  the context
# did: AST DeclId
# ret: the decl's interned semantic TypeId (TYPE_NIL if unknown)
pub fun decl_type_of(lc: *LowerContext, did: id.DeclId) type.TypeId {
    if (did == id.DECL_NIL)          { ret type.TYPE_NIL; }
    if (did::usize >= lc.a.decl_len) { ret type.TYPE_NIL; }
    ret lc.sema_result.decl_type[did];
}

# return the semantic return type of a function decl, with any generic
# substitution applied. used by `lower_instance` to populate `fn_ret_sem` so
# deferred `$each $fields(T)` body re-inference can check `ret`.
# ---
# lc:  the context (subst/subst_len active when inside a generic instance body)
# did: DeclId of the function declaration
# ret: the substituted sema return TypeId, or TYPE_NIL when unavailable
pub fun decl_ret_sem(lc: *LowerContext, did: id.DeclId) type.TypeId {
    val fn_ty: type.TypeId = decl_type_of(lc, did);
    val to: O.Option[*type.Type] = type.get(?lc.s.types, fn_ty);
    if (O.is_none[*type.Type](to)) { ret type.TYPE_NIL; }
    val t: *type.Type = O.unwrap[*type.Type](to);
    if (t.kind != type.TYPE_FUN) { ret type.TYPE_NIL; }
    var ret_type: type.TypeId = t.data.fn.ret_type;
    if (lc.subst != nil && lc.subst_len > 0) {
        ret_type = generics.substitute(lc.s, ret_type, lc.subst, lc.subst_len);
    }
    ret ret_type;
}

# return the resolved SymbolId for an expression reference, or SYMBOL_NIL.
# ---
# lc:  the context
# eid: AST ExprId (typically an IDENT)
# ret: the bound SymbolId, or SYMBOL_NIL
pub fun expr_symbol_of(lc: *LowerContext, eid: id.ExprId) resolve.SymbolId {
    if (eid == id.EXPR_NIL)             { ret resolve.SYMBOL_NIL; }
    if (eid::usize >= lc.rr.expr_count) { ret resolve.SYMBOL_NIL; }
    ret lc.rr.expr_resolved[eid];
}

# return the module's source text from the session source map. an unregistered
# file id yields the empty string -- never reached for a well-formed pipeline,
# since resolve already required the file to be registered.
# ---
# lc:  the context
# ret: the module's source text, or the empty string
pub fun module_source(lc: *LowerContext) str {
    val sf: O.Option[*source.SourceFile] = source.get(?lc.s.sources, lc.a.file_id);
    if (O.is_none[*source.SourceFile](sf)) { ret ""; }
    ret O.unwrap[*source.SourceFile](sf).text;
}

# emit an OP_DBG_VALUE binding the source variable named by `name_span` (type
# `ty`) to `val_v`, its current value
#
# Interns the variable's source name and records the debug value in the current
# function. Scope is the function body (0) for now; the location-emitter tiers
# build the scope tree. Callers gate this on `lc.s.debug`; shared by the decl,
# parameter, and reassignment birth sites.
# ---
# lc:        the lowering context
# name_span: source span of the variable's identifier
# ty:        the variable's IR type
# ty_sem:    the variable's semantic type (keeps signedness the IR type erases)
# is_param:  true for a formal parameter, false for a local
# val_v:     the value the variable currently holds
# ret:       true on success, or an error
pub fun emit_dbg_birth(lc: *LowerContext, name_span: token.Span, ty: ir_type.IrTypeId,
                       ty_sem: type.TypeId, is_param: bool, val_v: value.Value) R.Result[bool, str] {
    val res_name: R.Result[intern.StrId, str] = intern.intern_span(?lc.s.interner, module_source(lc), name_span);
    if (R.is_err[intern.StrId, str](res_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_name));
    }
    val name: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);
    ret builder.emit_dbg_value(?lc.builder, val_v, name, ty, ty_sem, is_param, 0);
}

# return a pointer to a resolved Symbol by id, or none when out of range.
# ---
# lc:  the context
# sid: SymbolId into the resolve result
# ret: some(*Symbol) or none
pub fun symbol_of(lc: *LowerContext, sid: resolve.SymbolId) O.Option[*resolve.Symbol] {
    if (sid == resolve.SYMBOL_NIL) { ret O.none[*resolve.Symbol](); }
    if (sid >= lc.rr.symbol_count) { ret O.none[*resolve.Symbol](); }
    ret O.some[*resolve.Symbol](?lc.rr.symbols[sid]);
}

# return the index of the module function named `name`, creating a signature-only
# `FN_FLAG_EXTERN` declaration when none exists. a cross-module function
# reference resolves through this so the back end emits a name-based call
# relocation against the imported symbol (the linker binds it to the defining
# module's object).
# ---
# lc:   the context
# name: interned function symbol name
# sig:  the function's IR type
# ret:  the function index, or an allocation error
pub fun ensure_extern_function(lc: *LowerContext, name: intern.StrId, sig: ir_type.IrTypeId) R.Result[u32, str] {
    val m: *ir.Module = lc.m;
    val existing: O.Option[u32] = ir.function_lookup(m, name);
    if (O.is_some[u32](existing)) { ret R.ok[u32, str](O.unwrap[u32](existing)); }

    if (m.function_len == m.function_cap) {
        val new_cap: u32 = grow_cap(m.function_cap);
        val res_grow: R.Result[*ir.Function, str] = A.reallocate[ir.Function](m.alloc, m.functions, m.function_cap::usize, new_cap::usize);
        if (R.is_err[*ir.Function, str](res_grow)) { ret R.err[u32, str](R.unwrap_err[*ir.Function, str](res_grow)); }
        m.functions    = R.unwrap_ok[*ir.Function, str](res_grow);
        m.function_cap = new_cap;
    }

    val idx: u32 = m.function_len;
    var f: ir.Function;
    f.name        = name;
    f.sig         = sig;
    f.params      = nil;
    f.param_count = 0;
    f.blocks      = nil;
    f.block_count = 0;
    f.block_cap   = 0;
    f.instrs      = nil;
    f.instr_len   = 0;
    f.instr_cap   = 0;
    f.flags       = ir.FN_FLAG_EXTERN;
    f.label       = intern.STR_NIL;
    f.line        = 0;
    f.section     = intern.STR_NIL;
    f.disp        = intern.STR_NIL;
    f.ret_sem     = type.TYPE_NIL;
    f.asm_blocks  = map.init[ir.InstructionId, ir.IrAsm](m.alloc, map.hash_u32, map.eq_u32);
    f.dbg_vars    = map.init[ir.InstructionId, ir.DbgVar](m.alloc, map.hash_u32, map.eq_u32);
    f.dbg_exprs    = nil;
    f.dbg_expr_len = 0;
    f.dbg_expr_cap = 0;
    f.dbg_expr_ids = map.init[ir.InstructionId, ir.DbgExprId](m.alloc, map.hash_u32, map.eq_u32);

    m.functions[idx] = f;
    m.function_len   = m.function_len + 1;
    val res_reg: R.Result[bool, str] = ir.function_register(m, name, idx);
    if (R.is_err[bool, str](res_reg)) { ret R.err[u32, str](R.unwrap_err[bool, str](res_reg)); }

    # appending may have reallocated `m.functions`, invalidating the builder's
    # raw pointer to the function currently being lowered. re-point it at the
    # live array so subsequent emits land in the right function.
    if (lc.builder.fn != nil && lc.fn_index < m.function_len) {
        lc.builder.fn = ?m.functions[lc.fn_index];
    }
    ret R.ok[u32, str](idx);
}

# return the index of the module global named `name`, creating a storage-less
# `is_extern` declaration when none exists. a reference to a `val`/`var` defined
# in another module resolves through this so the back end emits a name-based
# relocation the linker binds to the defining object.
# ---
# lc:   the context
# name: interned global symbol name
# ty:   the global's IR storage type
# ret:  the global index, or an allocation error
pub fun ensure_extern_global(lc: *LowerContext, name: intern.StrId, ty: ir_type.IrTypeId) R.Result[u32, str] {
    val m: *ir.Module = lc.m;
    val existing: O.Option[u32] = ir.global_lookup(m, name);
    if (O.is_some[u32](existing)) { ret R.ok[u32, str](O.unwrap[u32](existing)); }

    if (m.global_len == m.global_cap) {
        val new_cap: u32 = grow_cap(m.global_cap);
        val res_grow: R.Result[*ir.Global, str] = A.reallocate[ir.Global](m.alloc, m.globals, m.global_cap::usize, new_cap::usize);
        if (R.is_err[*ir.Global, str](res_grow)) { ret R.err[u32, str](R.unwrap_err[*ir.Global, str](res_grow)); }
        m.globals    = R.unwrap_ok[*ir.Global, str](res_grow);
        m.global_cap = new_cap;
    }

    val idx: u32 = m.global_len;
    var g: ir.Global;
    g.name      = name;
    g.ty        = ty;
    g.init      = value.const_int(0, ty);
    g.is_mut    = true;
    g.is_pub    = false;
    g.is_extern = true;
    g.is_local  = false;
    g.align     = 0;
    g.section   = intern.STR_NIL;
    m.globals[idx] = g;
    m.global_len   = m.global_len + 1;
    val res_reg: R.Result[bool, str] = ir.global_register(m, name, idx);
    if (R.is_err[bool, str](res_reg)) { ret R.err[u32, str](R.unwrap_err[bool, str](res_reg)); }
    ret R.ok[u32, str](idx);
}

# materialise a byte-blob constant (`init`, a VAL_CONST_BYTES) as an anonymous
# read-only data global and return a VAL_GLOBAL pointer to it. string literals
# and other inline byte blobs flow through here so the back end emits them to
# `.rodata` and resolves uses to the global's address rather than carrying raw
# bytes into instruction operands.
# ---
# lc:   the context
# init: the VAL_CONST_BYTES value to store
# pty:  the IR pointer type the resulting global value carries
# ret:  a VAL_GLOBAL pointer to the new global, or an error
pub fun add_rodata_bytes(lc: *LowerContext, init: value.Value, pty: ir_type.IrTypeId) R.Result[value.Value, str] {
    val m: *ir.Module = lc.m;
    val res_name: R.Result[intern.StrId, str] = anon_global_name(lc, m.global_len);
    if (R.is_err[intern.StrId, str](res_name)) { ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_name)); }

    if (m.global_len == m.global_cap) {
        val new_cap: u32 = grow_cap(m.global_cap);
        val res_grow: R.Result[*ir.Global, str] = A.reallocate[ir.Global](m.alloc, m.globals, m.global_cap::usize, new_cap::usize);
        if (R.is_err[*ir.Global, str](res_grow)) { ret R.err[value.Value, str](R.unwrap_err[*ir.Global, str](res_grow)); }
        m.globals    = R.unwrap_ok[*ir.Global, str](res_grow);
        m.global_cap = new_cap;
    }

    val idx: u32 = m.global_len;
    var g: ir.Global;
    g.name      = R.unwrap_ok[intern.StrId, str](res_name);
    g.ty        = init.ty;
    g.init      = init;
    g.is_mut    = false;
    g.is_pub    = false;
    g.is_extern = false;
    g.is_local  = true;
    g.align     = 0;
    g.section   = intern.STR_NIL;
    m.globals[idx] = g;
    m.global_len   = m.global_len + 1;

    ret R.ok[value.Value, str](value.global(idx, pty));
}

# intern a unique anonymous data-global name `.Lc.<n>` for slot `n`, distinct
# from any user symbol (the `.L` prefix is the conventional local-label form) and
# unique because `n` is the global's index.
# ---
# lc:  the context
# n:   the global's index
# ret: the interned name, or an allocation error
fun anon_global_name(lc: *LowerContext, n: u32) R.Result[intern.StrId, str] {
    var buf: [16]u8;
    buf[0] = '.';
    buf[1] = 'L';
    buf[2] = 'c';
    buf[3] = '.';
    var len: usize = 4;
    var d: u32 = 0;
    for (d < 8) {
        val shift: u32 = (7 - d) * 4;
        val nib: u32 = (n >> shift) & 0xF;
        var c: u8 = nib::u8 + 0x30;
        if (nib > 9) { c = nib::u8 - 10 + 0x61; }
        buf[len] = c;
        len = len + 1;
        d = d + 1;
    }
    ret intern.intern_bytes(?lc.s.interner, (?buf[0])::str, len);
}

# doubling growth for the function / global arrays, seeding an empty one.
# ---
# cap: current capacity
# ret: the next capacity (4 when seeding from empty)
fun grow_cap(cap: u32) u32 {
    if (cap == 0) { ret 4; }
    ret cap * 2;
}
