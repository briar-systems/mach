# mach.lang.me.lower.testrunner: synthesizes one standalone entry per `test`.
#
# `mach test` builds every `test "..."` block into its own small executable: the
# test function plus the project's transitive code, with a synthesized `main`
# that calls just that one test and returns its `i32` result as the process exit
# status (`0` = pass, non-zero = fail). the per-test executables are run as
# separate processes by the `mach test` command, so a crashing test reports a
# signal and the run continues.
#
# this module does two jobs for that build:
#   - `collect` gathers every `FN_FLAG_TEST` function across the lowered module
#     set into a `Test` list (linkage name, printable label, source line, and the
#     index of the module it was declared in, for `file:line` reporting).
#   - `synthesize_entry` builds, for one collected test, a tiny IR module whose
#     `main` is `ret <test>();` — a signature-only extern for the test symbol plus
#     a two-instruction body. it carries no OS interaction of its own, so it works
#     for any target with or without a standard library.
# `neutralize_project_main` turns the project's own `main` into a body-less extern
# so each test executable's sole program entry is the synthesized one.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.is_none;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use map:     std.collections.map;
use maphash: std.collections.map;

use intern: mach.lang.intern;
use sess:   mach.lang.session;

use ir:      mach.lang.me.ir;
use ir_type: mach.lang.me.ir.type;
use irid:    mach.lang.me.ir.id;
use value:   mach.lang.me.ir.value;
use builder: mach.lang.me.ir.builder;

# Test: one collected `test` declaration.
# ---
# linkage: interned linkage name — the symbol the synthesized `main` calls
# label:   interned printable label (the literal's inner text), reported by `mach test`
# line:    1-based source line of the `test` keyword, reported as `file:line`
# mod_idx: index of the IR module the test was collected from, so the runner can
#          resolve the declaring source file for reporting
pub rec Test {
    linkage: intern.StrId;
    label:   intern.StrId;
    line:    u32;
    mod_idx: u32;
}

# Collected: the owned `Test` list `collect` produces. `cap` is the allocated
# length (>= count) so `free` releases it exactly.
# ---
# tests: owned array of collected tests, in module then declaration order
# count: number of populated entries
# cap:   allocated length of `tests`
pub rec Collected {
    tests: *Test;
    count: u32;
    cap:   u32;
}

# collect: gather every `FN_FLAG_TEST` function across `modules[0..count)` into an
# owned `Test` list, in module then declaration order. an empty build yields an
# empty `Collected` (nil array, zero count).
pub fun collect(s: *sess.Session, modules: *ir.Module, count: u32) Result[Collected, str] {
    var c: Collected;
    c.tests = nil;
    c.count = 0;
    c.cap   = 0;

    var mi: u32 = 0;
    for (mi < count) {
        val mod: *ir.Module = ?modules[mi];
        var fi: u32 = 0;
        for (fi < mod.function_len) {
            val fn: *ir.Function = ?mod.functions[fi];
            if ((fn.flags & ir.FN_FLAG_TEST) != 0) {
                var t: Test;
                t.linkage = fn.name;
                t.label   = fn.label;
                t.line    = fn.line;
                t.mod_idx = mi;
                val ar: Result[bool, str] = push_test(s, ?c, t);
                if (is_err[bool, str](ar)) { free(s, ?c); ret err[Collected, str](unwrap_err[bool, str](ar)); }
            }
            fi = fi + 1;
        }
        mi = mi + 1;
    }
    ret ok[Collected, str](c);
}

# free: release a `Collected` list's backing array.
pub fun free(s: *sess.Session, c: *Collected) {
    if (c.tests != nil && c.cap > 0) { deallocate[Test](s.alloc, c.tests, c.cap::usize); }
    c.tests = nil;
    c.count = 0;
    c.cap   = 0;
}

# push_test: append one `Test`, doubling the backing array when full.
fun push_test(s: *sess.Session, c: *Collected, t: Test) Result[bool, str] {
    if (c.count == c.cap) {
        var new_cap: u32 = c.cap * 2;
        if (new_cap < 8) { new_cap = 8; }
        if (c.tests == nil) {
            val r: Result[*Test, str] = allocate[Test](s.alloc, new_cap::usize);
            if (is_err[*Test, str](r)) { ret err[bool, str](unwrap_err[*Test, str](r)); }
            c.tests = unwrap_ok[*Test, str](r);
        }
        or {
            val r: Result[*Test, str] = reallocate[Test](s.alloc, c.tests, c.cap::usize, new_cap::usize);
            if (is_err[*Test, str](r)) { ret err[bool, str](unwrap_err[*Test, str](r)); }
            c.tests = unwrap_ok[*Test, str](r);
        }
        c.cap = new_cap;
    }
    c.tests[c.count] = t;
    c.count = c.count + 1;
    ret ok[bool, str](true);
}

# neutralize_project_main: turn any function whose linkage name is literally
# `main` into a body-less extern so each test executable's sole program entry is
# the synthesized per-test `main`. the dropped blocks are reclaimed by the
# module's own dnit; a test build never references the project's `main`, so the
# extern emits nothing. called between lowering and codegen in a test build.
pub fun neutralize_project_main(s: *sess.Session, modules: *ir.Module, count: u32) Result[bool, str] {
    val main_r: Result[intern.StrId, str] = intern.intern(?s.interner, "main");
    if (is_err[intern.StrId, str](main_r)) { ret err[bool, str](unwrap_err[intern.StrId, str](main_r)); }
    val main_id: intern.StrId = unwrap_ok[intern.StrId, str](main_r);

    var mi: u32 = 0;
    for (mi < count) {
        val mod: *ir.Module = ?modules[mi];
        var fi: u32 = 0;
        for (fi < mod.function_len) {
            val fn: *ir.Function = ?mod.functions[fi];
            if (fn.name == main_id && (fn.flags & ir.FN_FLAG_EXTERN) == 0) {
                fn.flags       = fn.flags | ir.FN_FLAG_EXTERN;
                fn.block_count = 0;
            }
            fi = fi + 1;
        }
        mi = mi + 1;
    }
    ret ok[bool, str](true);
}

# synthesize_entry: build a fresh IR module whose `main` calls the single test
# named by `linkage` and returns its `i32` result as the process exit status. the
# module declares the test symbol as a signature-only `i32()` extern (the linker
# binds it to the test's defining object) and emits `main` as `ret <test>();`.
# the caller optimises and codegens it, then links it with the project's per-module
# objects into one standalone test executable. the returned module is owned by the
# caller (`ir.dnit_module`).
pub fun synthesize_entry(s: *sess.Session, linkage: intern.StrId) Result[ir.Module, str] {
    val name_r: Result[intern.StrId, str] = intern.intern(?s.interner, "__mach_test_entry");
    if (is_err[intern.StrId, str](name_r)) { ret err[ir.Module, str](unwrap_err[intern.StrId, str](name_r)); }

    val mod_r: Result[ir.Module, str] = ir.init_module(s.alloc, unwrap_ok[intern.StrId, str](name_r));
    if (is_err[ir.Module, str](mod_r)) { ret err[ir.Module, str](unwrap_err[ir.Module, str](mod_r)); }
    var m: ir.Module = unwrap_ok[ir.Module, str](mod_r);

    val br: Result[bool, str] = build_entry(s, ?m, linkage);
    if (is_err[bool, str](br)) { ir.dnit_module(?m); ret err[ir.Module, str](unwrap_err[bool, str](br)); }
    ret ok[ir.Module, str](m);
}

# build_entry: emit the test symbol's extern and the `main(){ret <test>();}` body.
fun build_entry(s: *sess.Session, m: *ir.Module, linkage: intern.StrId) Result[bool, str] {
    val i32_r: Result[ir_type.IrTypeId, str] = ir_type.intern_int(?m.types, 32);
    if (is_err[ir_type.IrTypeId, str](i32_r)) { ret err[bool, str](unwrap_err[ir_type.IrTypeId, str](i32_r)); }
    val i32: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](i32_r);

    val sig_r: Result[ir_type.IrTypeId, str] = ir_type.intern_fn(?m.types, i32, nil, 0, false);
    if (is_err[ir_type.IrTypeId, str](sig_r)) { ret err[bool, str](unwrap_err[ir_type.IrTypeId, str](sig_r)); }
    val sig: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](sig_r);

    # the test symbol, declared signature-only so the call resolves across objects.
    val ext_r: Result[u32, str] = append_function(m, linkage, sig, ir.FN_FLAG_EXTERN);
    if (is_err[u32, str](ext_r)) { ret err[bool, str](unwrap_err[u32, str](ext_r)); }
    val callee: value.Value = value.fn_value(unwrap_ok[u32, str](ext_r), sig);

    # `main`: exempt from mangling (the OS entry calls the literal `main`); a
    # synthesized module is not run through the export registry, so the name is
    # emitted verbatim. its body is a single call to the test and a return of the
    # i32 result, which the process exit status carries (0 = pass).
    val main_r: Result[intern.StrId, str] = intern.intern(?s.interner, "main");
    if (is_err[intern.StrId, str](main_r)) { ret err[bool, str](unwrap_err[intern.StrId, str](main_r)); }
    val main_idx_r: Result[u32, str] = append_function(m, unwrap_ok[intern.StrId, str](main_r), sig, ir.FN_FLAG_PUB);
    if (is_err[u32, str](main_idx_r)) { ret err[bool, str](unwrap_err[u32, str](main_idx_r)); }
    val main_idx: u32 = unwrap_ok[u32, str](main_idx_r);

    var b: builder.Builder = builder.init(m);
    builder.set_function(?b, ?m.functions[main_idx]);
    val eb_r: Result[irid.BlockId, str] = builder.new_block(?b);
    if (is_err[irid.BlockId, str](eb_r)) { ret err[bool, str](unwrap_err[irid.BlockId, str](eb_r)); }
    builder.set_block(?b, unwrap_ok[irid.BlockId, str](eb_r));

    val call_r: Result[value.Value, str] = builder.emit_call(?b, callee, nil, 0, i32);
    if (is_err[value.Value, str](call_r)) { ret err[bool, str](unwrap_err[value.Value, str](call_r)); }
    ret builder.emit_ret(?b, unwrap_ok[value.Value, str](call_r));
}

# append_function: grow the function array if needed and append a Function with
# the given linkage, returning its index. mirrors decl.append_function against a
# bare module.
fun append_function(m: *ir.Module, name: intern.StrId, sig: ir_type.IrTypeId, flags: u32) Result[u32, str] {
    if (m.function_len == m.function_cap) {
        val new_cap: u32 = m.function_cap * 2;
        val r: Result[*ir.Function, str] = reallocate[ir.Function](m.alloc, m.functions, m.function_cap::usize, new_cap::usize);
        if (is_err[*ir.Function, str](r)) { ret err[u32, str](unwrap_err[*ir.Function, str](r)); }
        m.functions    = unwrap_ok[*ir.Function, str](r);
        m.function_cap = new_cap;
    }
    val idx: u32 = m.function_len;
    var f: ir.Function;
    f.name        = name;
    f.sig         = sig;
    f.params      = nil;
    f.param_count = 0;
    f.blocks      = nil;
    f.block_count = 0;
    f.block_cap   = 0;
    f.instrs      = nil;
    f.instr_len   = 0;
    f.instr_cap   = 0;
    f.flags       = flags;
    f.label       = intern.STR_NIL;
    f.line        = 0;
    f.asm_blocks  = map.init[irid.InstructionId, ir.IrAsm](m.alloc, maphash.hash_u32, maphash.eq_u32);
    m.functions[idx] = f;
    m.function_len   = m.function_len + 1;
    val reg: Result[bool, str] = ir.register_function(m, name, idx);
    if (is_err[bool, str](reg)) { ret err[u32, str](unwrap_err[bool, str](reg)); }
    ret ok[u32, str](idx);
}
