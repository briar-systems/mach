# per-expression lowering from the AST into the middle-end IR
#
# Produces an IR Value for every expression. Rvalue and lvalue positions are
# disambiguated by call site: lower_rvalue returns the loaded value an
# expression denotes; lower_lvalue returns a pointer to the storage an
# assignable expression names.
#
# Locals are alloca slots seeded in the lowering context, so an IDENT rvalue is
# a load of its slot and an IDENT lvalue is the slot pointer itself. mem2reg
# later collapses the slots into SSA values, so the redundant load/store traffic
# emitted here costs nothing in the final code.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.StrView;
use std.types.string.str;
use std.types.string.str_len;
use std.types.string.view;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.expr;
use mach.lang.fe.ast.id;
use atype: mach.lang.fe.ast.type;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema.generics;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.ir.builder;
use ir_type: mach.lang.me.ir.type;
use mach.lang.me.ir.value;
use mach.lang.me.lower.context;
use mach.lang.me.lower.mangle;
use mach.lang.session;
use mach.lang.source;
use mach.lang.type;

# lower an expression to its rvalue: the loaded value it denotes
#
# Dispatches on the expression's ExprKind.
# ---
# ctx: per-module lowering context
# eid: the expression to lower
# ret: the resulting Value, or an error
pub fun lower_rvalue(ctx: *context.LowerContext, eid: id.ExprId) R.Result[value.Value, str] {
    val opt_e: O.Option[*expr.Expr] = ast.get_expr(ctx.a, eid);
    if (O.is_none[*expr.Expr](opt_e)) {
        ret R.err[value.Value, str]("lower: expression id out of range");
    }
    val e: *expr.Expr    = O.unwrap[*expr.Expr](opt_e);
    val k: expr.ExprKind = e.kind;

    if (k == expr.EXPR_KIND_LIT_INT)        { ret lower_lit_int(ctx, eid, e); }
    if (k == expr.EXPR_KIND_LIT_FLOAT)      { ret lower_lit_float(ctx, eid, e); }
    if (k == expr.EXPR_KIND_LIT_CHAR)       { ret lower_lit_char(ctx, e); }
    if (k == expr.EXPR_KIND_LIT_STR)        { ret lower_lit_str(ctx, e); }
    if (k == expr.EXPR_KIND_LIT_NIL)        { ret lower_lit_nil(ctx, eid); }
    if (k == expr.EXPR_KIND_IDENT)          { ret lower_ident_rvalue(ctx, eid); }
    if (k == expr.EXPR_KIND_MEMBER)         { ret lower_member_rvalue(ctx, eid, e); }
    if (k == expr.EXPR_KIND_PROJECT)        { ret lower_project_rvalue(ctx, eid, e); }
    if (k == expr.EXPR_KIND_INDEX)          { ret lower_index_rvalue(ctx, eid, e); }
    if (k == expr.EXPR_KIND_CALL)           { ret lower_call(ctx, eid, e); }
    if (k == expr.EXPR_KIND_BINARY)         { ret lower_binary(ctx, eid, e); }
    if (k == expr.EXPR_KIND_UNARY)          { ret lower_unary(ctx, eid, e); }
    if (k == expr.EXPR_KIND_CAST)           { ret lower_cast(ctx, eid, e); }
    if (k == expr.EXPR_KIND_STRIP)          { ret lower_strip(ctx, e); }
    if (k == expr.EXPR_KIND_COMPTIME_IDENT) { ret lower_comptime_path(ctx, eid); }
    if (k == expr.EXPR_KIND_ARRAY_LIT)      { ret lower_array_lit(ctx, eid, e); }
    if (k == expr.EXPR_KIND_STRUCT_LIT)     { ret lower_struct_lit(ctx, eid, e); }

    ret R.err[value.Value, str]("lower: unsupported expression kind in rvalue position");
}

# lower an assignable expression to its lvalue: a pointer to the storage it names
#
# Valid only for the location-denoting expression forms; sema rejects others
# before lowering.
# ---
# ctx: per-module lowering context
# eid: the expression to lower
# ret: a pointer Value, or an error
pub fun lower_lvalue(ctx: *context.LowerContext, eid: id.ExprId) R.Result[value.Value, str] {
    val opt_e: O.Option[*expr.Expr] = ast.get_expr(ctx.a, eid);
    if (O.is_none[*expr.Expr](opt_e)) {
        ret R.err[value.Value, str]("lower: lvalue id out of range");
    }
    val e: *expr.Expr    = O.unwrap[*expr.Expr](opt_e);
    val k: expr.ExprKind = e.kind;

    if (k == expr.EXPR_KIND_IDENT)   { ret lower_ident_lvalue(ctx, eid); }
    if (k == expr.EXPR_KIND_MEMBER)  { ret lower_member_lvalue(ctx, eid, e); }
    if (k == expr.EXPR_KIND_PROJECT) { ret lower_project_lvalue(ctx, eid, e); }
    if (k == expr.EXPR_KIND_INDEX)   { ret lower_index_lvalue(ctx, eid, e); }
    if (k == expr.EXPR_KIND_UNARY) {
        # `@p` as an lvalue is the rvalue of p (already a pointer)
        if (e.data.unary.op == expr.UN_DEREF) {
            ret lower_rvalue(ctx, e.data.unary.operand);
        }
    }

    # a by-value aggregate returned from a call is materialized into storage (its
    # sret slot); by the aggregate convention its rvalue IS that storage pointer,
    # which is exactly the lvalue a field/index access or address-of wants. a
    # scalar call result has no storage and is not an lvalue (it falls through).
    if (k == expr.EXPR_KIND_CALL) {
        val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
        if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
        if (is_aggregate_ir(ctx, R.unwrap_ok[ir_type.IrTypeId, str](res_ir))) {
            ret lower_rvalue(ctx, eid);
        }
    }

    ret R.err[value.Value, str]("lower: expression is not an lvalue");
}

# lower an integer literal to a constant at the expression's IR type
# ---
# ctx: per-module lowering context
# eid: the literal expression
# e:   the resolved literal node
# ret: the constant Value, or an error
fun lower_lit_int(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret R.ok[value.Value, str](value.const_int(e.data.lit_int, R.unwrap_ok[ir_type.IrTypeId, str](res_ir)));
}

# lower a float literal to a constant at the expression's IR type
# ---
# ctx: per-module lowering context
# eid: the literal expression
# e:   the resolved literal node
# ret: the constant Value, or an error
fun lower_lit_float(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret R.ok[value.Value, str](value.const_float(e.data.lit_float, R.unwrap_ok[ir_type.IrTypeId, str](res_ir)));
}

# lower a character literal to an 8-bit integer constant
# ---
# ctx: per-module lowering context
# e:   the resolved literal node
# ret: the constant Value, or an error
fun lower_lit_char(ctx: *context.LowerContext, e: *expr.Expr) R.Result[value.Value, str] {
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type.intern_int(?ctx.m.types, 8);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret R.ok[value.Value, str](value.const_int(e.data.lit_char::u64, R.unwrap_ok[ir_type.IrTypeId, str](res_ir)));
}

# lower a string literal to a pointer into an anonymous read-only data global
#
# The literal lowers to a VAL_CONST_BYTES naming the literal's decoded content
# bytes; the back end materialises a read-only data global and resolves the
# Value to a *u8 pointer to it. Escape sequences (\n \t \r \\ \' \" \0 \xHH) are
# decoded into the materialised bytes, matching the documented string-literal
# semantics and comptime.eval's eval_lit_str. The decoded content is interned
# (giving a stable byte sequence) and the Value borrows the interned bytes.
# ---
# ctx: per-module lowering context
# e:   the resolved string-literal node
# ret: a *u8 pointer Value into the rodata global, or an error
pub fun lower_lit_str(ctx: *context.LowerContext, e: *expr.Expr) R.Result[value.Value, str] {
    val res_ptr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?ctx.m.types);
    if (R.is_err[ir_type.IrTypeId, str](res_ptr)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ptr)); }
    val pty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ptr);

    # the literal's inner content view, with the surrounding quotes stripped.
    val txt: str = context.module_source(ctx);
    var inner: StrView = view(nil, 0);
    if (e.span.len >= 2::usize) {
        inner = view(?txt[e.span.offset + 1::usize], e.span.len - 2::usize);
    }

    val res_sid: R.Result[intern.StrId, str] = intern_str_lit(ctx, inner);
    if (R.is_err[intern.StrId, str](res_sid)) { ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_sid)); }
    val opt_bytes: O.Option[str] = intern.lookup(?ctx.s.interner, R.unwrap_ok[intern.StrId, str](res_sid));
    if (O.is_none[str](opt_bytes)) { ret R.err[value.Value, str]("lower: string literal lookup failed"); }
    val bytes: str = O.unwrap[str](opt_bytes);

    # materialise the literal as an anonymous `.rodata` global and yield a
    # pointer to it; a raw byte blob must not reach the back end as an operand.
    # the blob length includes the trailing '\0' (the interned bytes are
    # null-terminated): a `str` is a thin `*char` walked to its terminator, so the
    # terminator must be part of the emitted data rather than left to depend on a
    # section's alignment padding; which an empty literal (0 content bytes) has
    # none of, and a literal whose length is a multiple of the alignment loses.
    val blob: value.Value = value.const_bytes(bytes::*u8, (str_len(bytes) + 1::usize)::u32, pty);
    ret context.add_rodata_bytes(ctx, blob, pty);
}

# intern a string literal's inner content, decoding escape sequences when present
#
# With no escapes the raw view is interned directly; otherwise the decoded bytes
# are materialised into a temporary buffer (decoded length never exceeds the
# source length) and interned, then the buffer is released.
# ---
# ctx:   per-module lowering context
# inner: the literal's content view, quotes already stripped
# ret:   the interned StrId of the decoded content, or an error
fun intern_str_lit(ctx: *context.LowerContext, inner: StrView) R.Result[intern.StrId, str] {
    if (inner.len == 0 || !lit_has_escape(inner)) {
        ret intern.intern_bytes(?ctx.s.interner, inner.data::str, inner.len);
    }

    val res_buf: R.Result[*u8, str] = A.allocate[u8](ctx.s.alloc, inner.len);
    if (R.is_err[*u8, str](res_buf)) { ret R.err[intern.StrId, str](R.unwrap_err[*u8, str](res_buf)); }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);

    var read:  usize = 0;
    var write: usize = 0;
    for (read < inner.len) {
        val c: u8 = inner.data[read];
        if (c != '\\') {
            buf[write] = c;
            read  = read + 1;
            write = write + 1;
            cnt;
        }
        var consumed: usize = 0;
        val res_esc: R.Result[u8, str] = lit_decode_escape((?inner.data[read])::*u8, inner.len - read, ?consumed);
        if (R.is_err[u8, str](res_esc)) {
            A.deallocate[u8](ctx.s.alloc, buf, inner.len);
            ret R.err[intern.StrId, str](R.unwrap_err[u8, str](res_esc));
        }
        buf[write] = R.unwrap_ok[u8, str](res_esc);
        read  = read + consumed;
        write = write + 1;
    }

    val res_id: R.Result[intern.StrId, str] = intern.intern_bytes(?ctx.s.interner, buf::str, write);
    A.deallocate[u8](ctx.s.alloc, buf, inner.len);
    ret res_id;
}

# whether a string view contains a backslash (an escape sequence)
# ---
# s:   the string view to scan
# ret: true when `s` holds at least one backslash
fun lit_has_escape(s: StrView) bool {
    var i: usize = 0;
    for (i < s.len) {
        if (s.data[i] == '\\') { ret true; }
        i = i + 1;
    }
    ret false;
}

# decode one escape sequence starting at the leading backslash
#
# Mirrors comptime.eval's decode_escape: \n \t \r \\ \' \" \0 \xHH.
# ---
# p:            pointer at the leading backslash
# len:          bytes available from `p` to the end of the content
# out_consumed: written with the number of input bytes the escape consumed
# ret:          the decoded byte, or an error for a malformed escape
fun lit_decode_escape(p: *u8, len: usize, out_consumed: *usize) R.Result[u8, str] {
    if (len < 2) { ret R.err[u8, str]("lower: incomplete escape sequence in string literal"); }
    val c: u8 = p[1];

    if (c == 'n')  { @out_consumed = 2; ret R.ok[u8, str](10); }
    if (c == 't')  { @out_consumed = 2; ret R.ok[u8, str](9); }
    if (c == 'r')  { @out_consumed = 2; ret R.ok[u8, str](13); }
    if (c == '\\') { @out_consumed = 2; ret R.ok[u8, str](92); }
    if (c == '\'') { @out_consumed = 2; ret R.ok[u8, str](39); }
    if (c == '"')  { @out_consumed = 2; ret R.ok[u8, str](34); }
    if (c == '0')  { @out_consumed = 2; ret R.ok[u8, str](0); }
    if (c == 'x') {
        if (len < 4) { ret R.err[u8, str]("lower: incomplete \\x escape in string literal"); }
        val hi: i64 = lit_hex_digit(p[2]);
        val lo: i64 = lit_hex_digit(p[3]);
        if (hi < 0 || lo < 0) { ret R.err[u8, str]("lower: invalid \\x escape in string literal"); }
        @out_consumed = 4;
        ret R.ok[u8, str]((hi * 16 + lo)::u8);
    }
    ret R.err[u8, str]("lower: unknown escape sequence in string literal");
}

# map a hex digit byte to its value 0..15, or -1 when not a hex digit
# ---
# c:   the candidate digit byte
# ret: the digit value 0..15, or -1 when `c` is not a hex digit
fun lit_hex_digit(c: u8) i64 {
    if (c >= '0' && c <= '9') { ret (c - '0')::i64; }
    if (c >= 'a' && c <= 'f') { ret (c - 'a')::i64 + 10; }
    if (c >= 'A' && c <= 'F') { ret (c - 'A')::i64 + 10; }
    ret -1;
}

# lower a `nil` literal to a null constant at the expression's IR type
# ---
# ctx: per-module lowering context
# eid: the literal expression
# ret: the null constant Value, or an error
fun lower_lit_nil(ctx: *context.LowerContext, eid: id.ExprId) R.Result[value.Value, str] {
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret R.ok[value.Value, str](value.const_null(R.unwrap_ok[ir_type.IrTypeId, str](res_ir)));
}

# lower an identifier in rvalue position
#
# A load from its alloca slot when the symbol is a local / parameter slot, the
# bound VAL_PARAM Value when it is a bare parameter, or a function / global
# reference otherwise. An aggregate-typed local is left as its slot pointer (not
# loaded): an aggregate rvalue is its storage address, which the back end
# consumes for two-register / by-reference argument passing and aggregate
# returns (loads happen at scalar use sites).
# ---
# ctx: per-module lowering context
# eid: the identifier expression
# ret: the resulting Value, or an error
fun lower_ident_rvalue(ctx: *context.LowerContext, eid: id.ExprId) R.Result[value.Value, str] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, eid);

    # a comptime value parameter has no runtime storage in the monomorphized body;
    # its value was bound into the comptime context by the value-instance drain,
    # so a reference folds to that constant.
    val opt_cv: O.Option[comptime.CTValue] = comptime_param_value(ctx, sid);
    if (O.is_some[comptime.CTValue](opt_cv)) {
        ret const_value_of(ctx, eid, O.unwrap[comptime.CTValue](opt_cv));
    }

    # a `$each a in va` pack loop variable (#1475): bound in the comptime context
    # to a pack-element descriptor; its rvalue is a load from the matching expanded
    # parameter slot recorded on the context by lower_pack_instance.
    val opt_ord: O.Option[u32] = pack_elem_ordinal(ctx, sid);
    if (O.is_some[u32](opt_ord)) {
        ret load_pack_elem(ctx, eid, O.unwrap[u32](opt_ord));
    }

    val opt_local: O.Option[value.Value] = context.lookup_local(ctx, sid);
    if (O.is_some[value.Value](opt_local)) {
        val slot: value.Value = O.unwrap[value.Value](opt_local);
        # a bare parameter is already an SSA value, not a slot to load.
        if (slot.kind == value.VAL_PARAM) {
            ret R.ok[value.Value, str](slot);
        }
        val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
        if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
        ret rvalue_at(ctx, slot, R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
    }
    ret symbol_reference(ctx, eid, sid);
}

# the expanded-parameter ordinal of a `$each a in va` pack loop variable (#1475)
#
# The loop variable is a comptime-flagged SYM_VAL with no declaration, bound by
# the unroll to a CT_KIND_PACK_ELEM descriptor whose `.index` is the element's
# ordinal among the instance's expanded pack parameters.
# ---
# ctx: per-module lowering context
# sid: the symbol to inspect
# ret: some(ordinal) for a pack loop variable, none otherwise
fun pack_elem_ordinal(ctx: *context.LowerContext, sid: resolve.SymbolId) O.Option[u32] {
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret O.none[u32](); }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    if (sym.kind != resolve.SYM_VAL || (sym.flags & resolve.SYM_FLAG_COMPTIME) == 0) { ret O.none[u32](); }
    if (sym.decl != id.DECL_NIL)                                                     { ret O.none[u32](); }
    val opt_nc: O.Option[*comptime.NamedConst] = comptime.lookup(ctx.ctx, sym.name);
    if (O.is_none[*comptime.NamedConst](opt_nc)) { ret O.none[u32](); }
    val cval: comptime.CTValue = O.unwrap[*comptime.NamedConst](opt_nc).value;
    if (cval.kind != comptime.CT_KIND_PACK_ELEM) { ret O.none[u32](); }
    ret O.some[u32](cval.data.pelem.index);
}

# the rvalue of a pack element at a given ordinal
#
# A load from the expanded parameter slot lower_pack_instance recorded on the
# context. An aggregate element flows by its storage address tagged with the
# aggregate IR type, mirroring an ordinary local rvalue.
# ---
# ctx: per-module lowering context
# eid: the pack loop-variable expression (supplies the element's IR type)
# ord: the element's ordinal among the expanded pack parameters
# ret: the element's rvalue, or an error
fun load_pack_elem(ctx: *context.LowerContext, eid: id.ExprId, ord: u32) R.Result[value.Value, str] {
    if (ctx.pack_slots == nil || ord >= ctx.pack_len) {
        ret R.err[value.Value, str]("lower: pack element ordinal out of range");
    }
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret rvalue_at(ctx, ctx.pack_slots[ord], R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
}

# whether `eid` is a `va...` pack spread expression (#1474/#1475)
# ---
# ctx: per-module lowering context
# eid: the expression to test
# ret: true for a spread expression
fun is_spread_expr(ctx: *context.LowerContext, eid: id.ExprId) bool {
    val opt_e: O.Option[*expr.Expr] = ast.get_expr(ctx.a, eid);
    if (O.is_none[*expr.Expr](opt_e)) { ret false; }
    ret O.unwrap[*expr.Expr](opt_e).kind == expr.EXPR_KIND_SPREAD;
}

# whether a call expression has any `va...` spread argument
# ---
# ctx: per-module lowering context
# e:   the resolved call node
# ret: true when at least one argument is a spread
fun call_has_spread(ctx: *context.LowerContext, e: *expr.Expr) bool {
    var i: u32 = 0;
    for (i < e.data.call.args_len) {
        val pool_ix: u32 = e.data.call.args_start + i;
        if (pool_ix::usize >= ctx.a.expr_id_len)          { ret false; }
        if (is_spread_expr(ctx, ctx.a.expr_ids[pool_ix])) { ret true; }
        i = i + 1;
    }
    ret false;
}

# the rvalue of a whole pack slot, typed from `ctx.pack_types` rather than a sema type
#
# Used when splicing the whole pack into a `va...` forward. Aggregates flow by
# storage address tagged with the aggregate IR type, mirroring load_pack_elem.
# ---
# ctx:     per-module lowering context
# slot_ix: index of the pack slot
# ret:     the slot's rvalue, or an error
fun load_pack_slot(ctx: *context.LowerContext, slot_ix: u32) R.Result[value.Value, str] {
    if (ctx.pack_slots == nil || slot_ix >= ctx.pack_len) {
        ret R.err[value.Value, str]("lower: pack slot index out of range");
    }
    val res_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, ctx.pack_types[slot_ix]);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret rvalue_at(ctx, ctx.pack_slots[slot_ix], R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
}

# the folded comptime value of a comptime value parameter, when it is one
#
# A SYM_PARAM with SYM_FLAG_COMPTIME bound in the comptime context by a
# value-instance drain folds here. None for any other symbol, or when not in a
# value-instance body. Used to fold a `$param` reference to a constant instead of
# a slot load.
# ---
# ctx: per-module lowering context
# sid: the symbol to inspect
# ret: some(value) for a bound comptime value parameter, none otherwise
fun comptime_param_value(ctx: *context.LowerContext, sid: resolve.SymbolId) O.Option[comptime.CTValue] {
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret O.none[comptime.CTValue](); }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    if (sym.kind != resolve.SYM_PARAM || (sym.flags & resolve.SYM_FLAG_COMPTIME) == 0) {
        ret O.none[comptime.CTValue]();
    }
    val opt_nc: O.Option[*comptime.NamedConst] = comptime.lookup(ctx.ctx, sym.name);
    if (O.is_none[*comptime.NamedConst](opt_nc)) { ret O.none[comptime.CTValue](); }
    ret O.some[comptime.CTValue](O.unwrap[*comptime.NamedConst](opt_nc).value);
}

# the back-end symbol name a reference to module-level symbol `sym` resolves to
#
# Mangled against the defining module's FQN (keyed by sym.origin) and honouring
# the defining decl's export override (an `ext fun` or `#[symbol(...)]` literal
# stays literal), so it byte-matches the name lower_fun / lower_global emitted
# for the definition: the definition mangles against its own FQN through the same
# chokepoint with the same bare name and override. A self-reference
# (origin == own_module) agrees trivially.
# ---
# ctx: per-module lowering context
# sym: the referenced module-level symbol
# ret: the referent's linkage name, or an error
fun reference_linkage_name(ctx: *context.LowerContext, sym: *resolve.Symbol) R.Result[intern.StrId, str] {
    val fqn: intern.StrId = session.module_fqn(ctx.s, sym.origin);
    var export: O.Option[intern.StrId] = O.none[intern.StrId]();
    if (sym.decl != id.DECL_NIL) {
        export = session.export_name(ctx.s, sym.origin, sym.decl::u32);
    }
    ret mangle.linkage_name(ctx.s, fqn, sym.name, export);
}

# the linkage name an identifier (or module-qualified member) resolves to
#
# Defined when the expression names a function or a `val`/`var` binding (kinds
# SYM_FUN / SYM_VAL / SYM_VAR / SYM_IMPORTED); the symbol whose address a constant
# aggregate initializer's `?G` / function-pointer leaf relocates against. None for
# a parameter, type, or otherwise non-addressable reference, so the folder falls
# back rather than emitting a bad relocation. It does not by itself distinguish a
# module-level binding from a block-local `val`/`var` of the same kind; the sole
# caller folds global-scope initializers, where no local is in scope, so a
# returned name always denotes a module-level symbol.
# ---
# ctx: per-module lowering context
# eid: the expression naming the symbol
# ret: some(linkage name) for a fn/binding symbol, else none
pub fun symbol_linkage_name(ctx: *context.LowerContext, eid: id.ExprId) O.Option[intern.StrId] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, eid);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret O.none[intern.StrId](); }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);

    val is_addressable: bool = sym.kind == resolve.SYM_FUN
        || sym.kind == resolve.SYM_VAL
        || sym.kind == resolve.SYM_VAR
        || sym.kind == resolve.SYM_IMPORTED;
    if (!is_addressable) { ret O.none[intern.StrId](); }

    val res_ln: R.Result[intern.StrId, str] = reference_linkage_name(ctx, sym);
    if (R.is_err[intern.StrId, str](res_ln)) { ret O.none[intern.StrId](); }
    ret O.some[intern.StrId](R.unwrap_ok[intern.StrId, str](res_ln));
}

# form an rvalue for an identifier that names a module-level symbol
#
# A function reference (VAL_FN) for functions, otherwise the global's storage
# rvalue (a load, or the storage address for an aggregate global).
# ---
# ctx: per-module lowering context
# eid: the identifier expression (supplies the referent's IR type)
# sid: the resolved symbol
# ret: the symbol's rvalue, or an error
fun symbol_reference(ctx: *context.LowerContext, eid: id.ExprId, sid: resolve.SymbolId) R.Result[value.Value, str] {
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) {
        ret report_expr(ctx, eid, "unresolved identifier");
    }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);

    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    val vty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);

    # the back-end symbol name of the referent, mangled against its defining
    # module (or kept literal when exempted) so it matches the definition.
    val res_ln: R.Result[intern.StrId, str] = reference_linkage_name(ctx, sym);
    if (R.is_err[intern.StrId, str](res_ln)) { ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_ln)); }
    val link: intern.StrId = R.unwrap_ok[intern.StrId, str](res_ln);

    # a function reference: a local function resolves to its module index; a
    # function imported from another module (kind SYM_IMPORTED, naming a function
    # decl) resolves through a signature-only extern declaration so the back end
    # emits a name-based call relocation the linker binds to the defining object.
    # a `val`/`var` binding whose type is a function pointer is NOT a function
    # reference; it falls through to the global-load path below, so a call
    # through it loads the stored pointer and dispatches indirectly.
    if (names_function(ctx, sym)) {
        ret fn_reference(ctx, link, vty);
    }

    # global val / var: a load from the global's storage pointer, except for
    # an aggregate global whose rvalue is its storage address (the back end
    # loads halves / passes the pointer at use sites; see lower_ident_rvalue).
    val opt_gi: O.Option[u32] = find_global(ctx, link);
    if (O.is_some[u32](opt_gi)) {
        ret emit_global_rvalue(ctx, O.unwrap[u32](opt_gi), vty);
    }

    # a comptime-const val that lives in another module has no global in this
    # module's IR (its storage was never emitted here). such a constant; e.g.
    # the stdlib `val true: bool = 1;` imported by name; folds to its value,
    # read from the module's comptime context where the load walk registered it.
    val opt_nc: O.Option[*comptime.NamedConst] = comptime.lookup(ctx.ctx, sym.name);
    if (O.is_some[*comptime.NamedConst](opt_nc)) {
        ret const_value_of(ctx, eid, O.unwrap[*comptime.NamedConst](opt_nc).value);
    }

    # a runtime global `val`/`var` defined in another module (imach emits one
    # object per module, so its storage lives only in the defining module's IR).
    # declare a storage-less extern global here and load through it; the back end
    # emits a name-based relocation the linker binds to the defining object -
    # mirroring the extern-function path above.
    val res_xg: R.Result[u32, str] = context.ensure_extern_global(ctx, link, vty);
    if (R.is_err[u32, str](res_xg)) { ret R.err[value.Value, str](R.unwrap_err[u32, str](res_xg)); }
    ret emit_global_rvalue(ctx, R.unwrap_ok[u32, str](res_xg), vty);
}

# whether the identifier's semantic type is a function type
#
# A reference to a function-typed expression is a function-pointer reference
# (resolved to a local or extern function rather than a global load).
# ---
# ctx: per-module lowering context
# eid: the identifier expression
# ret: true when the expression's type is TYPE_FUN
pub fun references_function(ctx: *context.LowerContext, eid: id.ExprId) bool {
    val tid: type.TypeId = context.expr_type_of(ctx, eid);
    val opt_t: O.Option[*type.Type] = type.get(?ctx.s.types, tid);
    if (O.is_none[*type.Type](opt_t)) { ret false; }
    ret O.unwrap[*type.Type](opt_t).kind == type.TYPE_FUN;
}

# whether a symbol names a function DECLARATION
#
# A reference to such a symbol is the function's code symbol (a direct call /
# PC32-relative reference), rather than a `val`/`var` binding whose type merely
# happens to be a function pointer (storage holding a pointer; a load, then an
# indirect call). The discriminator is the referent's nature, not its type: a
# SYM_FUN is a function; a SYM_VAL / SYM_VAR is always a binding; an imported
# symbol resolves by reading the origin decl's kind from its module AST. Used by
# call / rvalue lowering; references_function (type-based) cannot tell `f` from a
# `val P: fun(...)... = f` binding.
# ---
# ctx: per-module lowering context
# sym: the symbol to classify
# ret: true when `sym` names a function declaration
fun names_function(ctx: *context.LowerContext, sym: *resolve.Symbol) bool {
    if (sym.kind == resolve.SYM_FUN) { ret true; }
    if (sym.kind == resolve.SYM_VAL || sym.kind == resolve.SYM_VAR
        || sym.kind == resolve.SYM_PARAM) { ret false; }
    if (sym.kind != resolve.SYM_IMPORTED) { ret false; }
    # an imported symbol carries only SYM_IMPORTED; recover whether it names a
    # function by reading its origin decl's kind from the defining module's AST.
    val origin_ast: *ast.Ast = session.module_ast(ctx.s, sym.origin);
    if (origin_ast == nil) { ret false; }
    val opt_d: O.Option[*decl.Decl] = ast.get_decl(origin_ast, sym.decl);
    if (O.is_none[*decl.Decl](opt_d)) { ret false; }
    ret O.unwrap[*decl.Decl](opt_d).kind == decl.DECL_KIND_FUN;
}

# the storage pointer of a module-level binding
#
# A global defined in this module resolves to its module index; a runtime global
# val/var defined in another module declares a storage-less extern global here
# and yields its storage pointer (the back end emits a name-based relocation the
# linker binds to the defining object). Shared by the ident and
# module-qualified-member lvalue paths.
# ---
# ctx: per-module lowering context
# eid: the binding expression (supplies the value type that sizes an extern)
# sid: the resolved symbol
# ret: the binding's storage pointer, or an error
fun symbol_lvalue(ctx: *context.LowerContext, eid: id.ExprId, sid: resolve.SymbolId) R.Result[value.Value, str] {
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) {
        ret report_expr(ctx, eid, "unresolved identifier");
    }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);

    val res_ln: R.Result[intern.StrId, str] = reference_linkage_name(ctx, sym);
    if (R.is_err[intern.StrId, str](res_ln)) { ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_ln)); }
    val link: intern.StrId = R.unwrap_ok[intern.StrId, str](res_ln);

    val opt_gi: O.Option[u32] = find_global(ctx, link);
    if (O.is_some[u32](opt_gi)) {
        ret global_pointer(ctx, O.unwrap[u32](opt_gi));
    }

    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    val vty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);
    val res_xg: R.Result[u32, str] = context.ensure_extern_global(ctx, link, vty);
    if (R.is_err[u32, str](res_xg)) { ret R.err[value.Value, str](R.unwrap_err[u32, str](res_xg)); }
    ret global_pointer(ctx, R.unwrap_ok[u32, str](res_xg));
}

# lower an identifier in lvalue position
#
# The alloca slot pointer for a local, or the global storage pointer for a
# module-level binding.
# ---
# ctx: per-module lowering context
# eid: the identifier expression
# ret: the storage pointer, or an error
fun lower_ident_lvalue(ctx: *context.LowerContext, eid: id.ExprId) R.Result[value.Value, str] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, eid);

    # a comptime value parameter has no storage (it folds to a constant), so it is
    # not addressable. sema already rejects `?$param`; guard the lower path too so
    # a fabricated extern global can never be emitted for it.
    val opt_cv: O.Option[comptime.CTValue] = comptime_param_value(ctx, sid);
    if (O.is_some[comptime.CTValue](opt_cv)) {
        ret R.err[value.Value, str]("lower: cannot take the address of a comptime parameter");
    }

    # a `$each a in va` pack loop variable (#1475): bound to a CT_KIND_PACK_ELEM
    # descriptor, so it is neither a comptime value-param nor a real local. its
    # lvalue is the expanded parameter slot lower_pack_instance recorded on the
    # context - the storage address field access (`a.x`) and `?a` take. mirrors
    # the pack branch in lower_ident_rvalue.
    val opt_ord: O.Option[u32] = pack_elem_ordinal(ctx, sid);
    if (O.is_some[u32](opt_ord)) {
        val ord: u32 = O.unwrap[u32](opt_ord);
        if (ctx.pack_slots == nil || ord >= ctx.pack_len) {
            ret R.err[value.Value, str]("lower: pack element ordinal out of range");
        }
        ret R.ok[value.Value, str](ctx.pack_slots[ord]);
    }

    val opt_local: O.Option[value.Value] = context.lookup_local(ctx, sid);
    if (O.is_some[value.Value](opt_local)) {
        ret R.ok[value.Value, str](O.unwrap[value.Value](opt_local));
    }
    ret symbol_lvalue(ctx, eid, sid);
}

# fold a `$each` field-descriptor member (`f.offset`, #1473) to a constant
#
# None when the object is not a field descriptor (an ordinary field access). A
# CT_KIND_STR member (a field name) is materialized as an anonymous rodata string
# and yields a pointer to it, exactly like a string literal.
# ---
# ctx: per-module lowering context
# eid: the member expression
# e:   the resolved member node
# ret: some(folded constant or error) for a field-descriptor member, none otherwise
fun try_lower_field_member(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) O.Option[R.Result[value.Value, str]] {
    val src_text: str = context.module_source(ctx);
    val res_obj: R.Result[comptime.CTValue, str] = comptime.eval(ctx.ctx, ctx.a, src_text, e.data.member.object, ?ctx.s.interner);
    if (R.is_err[comptime.CTValue, str](res_obj))                                   { ret O.none[R.Result[value.Value, str]](); }
    if (R.unwrap_ok[comptime.CTValue, str](res_obj).kind != comptime.CT_KIND_FIELD) { ret O.none[R.Result[value.Value, str]](); }

    val res_member: R.Result[comptime.CTValue, str] = comptime.eval(ctx.ctx, ctx.a, src_text, eid, ?ctx.s.interner);
    if (R.is_err[comptime.CTValue, str](res_member)) { ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[comptime.CTValue, str](res_member))); }
    val v: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_member);
    if (v.kind == comptime.CT_KIND_INT) {
        val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
        if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir))); }
        ret O.some[R.Result[value.Value, str]](R.ok[value.Value, str](value.const_int(v.data.i:~u64, R.unwrap_ok[ir_type.IrTypeId, str](res_ir))));
    }
    if (v.kind == comptime.CT_KIND_STR) {
        val res_ptr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?ctx.m.types);
        if (R.is_err[ir_type.IrTypeId, str](res_ptr)) { ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ptr))); }
        val pty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ptr);
        val opt_bytes: O.Option[str] = intern.lookup(?ctx.s.interner, v.data.s);
        if (O.is_none[str](opt_bytes)) { ret O.some[R.Result[value.Value, str]](R.err[value.Value, str]("lower: field name lookup failed")); }
        val bytes: str = O.unwrap[str](opt_bytes);
        val blob: value.Value = value.const_bytes(bytes::*u8, (str_len(bytes) + 1::usize)::u32, pty);
        ret O.some[R.Result[value.Value, str]](context.add_rodata_bytes(ctx, blob, pty));
    }
    ret O.some[R.Result[value.Value, str]](R.err[value.Value, str]("lower: unsupported field descriptor member in value position"));
}

# fold `va.len` to the current pack instance's element count (#1475)
#
# None when the member's receiver is not a comptime variadic pack (an ordinary
# record/module member). The count is a compile-time constant fixed by the call
# site (ctx.pack_len), emitted at the member expression's lowered type (sema types
# `va.len` as u64).
# ---
# ctx: per-module lowering context
# eid: the member expression
# e:   the resolved member node
# ret: some(folded count or error) for a pack receiver, none otherwise
fun try_lower_pack_len(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) O.Option[R.Result[value.Value, str]] {
    val obj_ty: type.TypeId = context.expr_type_of(ctx, e.data.member.object);
    val opt_t: O.Option[*type.Type] = type.get(?ctx.s.types, obj_ty);
    if (O.is_none[*type.Type](opt_t))                       { ret O.none[R.Result[value.Value, str]](); }
    if (O.unwrap[*type.Type](opt_t).kind != type.TYPE_PACK) { ret O.none[R.Result[value.Value, str]](); }

    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) {
        ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)));
    }
    val ity: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);
    ret O.some[R.Result[value.Value, str]](R.ok[value.Value, str](value.const_int(ctx.pack_len::u64, ity)));
}

# lower a member access in rvalue position
#
# Folds the comptime special cases first (`va.len`, a `$each` field-descriptor
# member, a module-qualified reference, a `$mach.*` path), then falls back to a
# load of the field pointer - except for an aggregate field, whose rvalue is its
# storage address (see lower_ident_rvalue).
# ---
# ctx: per-module lowering context
# eid: the member expression
# e:   the resolved member node
# ret: the member's rvalue, or an error
fun lower_member_rvalue(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    # `va.len` on a comptime variadic pack (#1475): folds to the instance's element
    # count, a compile-time constant fixed by the call site. sema already validated
    # that `.len` is the pack's only member, so a pack receiver here is `.len`.
    val opt_pack_len: O.Option[R.Result[value.Value, str]] = try_lower_pack_len(ctx, eid, e);
    if (O.is_some[R.Result[value.Value, str]](opt_pack_len)) { ret O.unwrap[R.Result[value.Value, str]](opt_pack_len); }

    # a `$each` field-descriptor member (`f.offset`) folds to a constant (#1473).
    val opt_field: O.Option[R.Result[value.Value, str]] = try_lower_field_member(ctx, eid, e);
    if (O.is_some[R.Result[value.Value, str]](opt_field)) { ret O.unwrap[R.Result[value.Value, str]](opt_field); }

    # a module-qualified reference (`alias.name`, where `alias` is a `use`
    # binding) is recorded by resolve as a symbol on the member expression
    # itself; it denotes the imported value, not a field of a record. lower it
    # as a plain symbol reference (cross-module const / global / function).
    val qsid: resolve.SymbolId = context.expr_symbol_of(ctx, eid);
    if (qsid != resolve.SYMBOL_NIL) {
        ret symbol_reference(ctx, eid, qsid);
    }

    # a `$mach.*` member chain (rooted at a `$` comptime ident) is a comptime
    # path, not a field access; fold it to the constant the evaluator produces.
    if (comptime.is_comptime_path(ctx.a, eid)) {
        ret lower_comptime_path(ctx, eid);
    }

    val res_ptr: R.Result[value.Value, str] = lower_member_lvalue(ctx, eid, e);
    if (R.is_err[value.Value, str](res_ptr)) { ret res_ptr; }
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret rvalue_at(ctx, R.unwrap_ok[value.Value, str](res_ptr), R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
}

# lower a member access in lvalue position to the field pointer
#
# A gep against the base with the field index. The receiver may be the record's
# own storage (`s.field`) or a pointer to it (`p.field` with `p: *S`, auto-deref);
# the field index is resolved against the record type, not the pointer. A
# module-qualified reference (`alias.name`) instead yields the imported binding's
# storage pointer.
# ---
# ctx: per-module lowering context
# eid: the member expression
# e:   the resolved member node
# ret: the field pointer Value, or an error
fun lower_member_lvalue(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val qsid: resolve.SymbolId = context.expr_symbol_of(ctx, eid);
    if (qsid != resolve.SYMBOL_NIL) {
        ret symbol_lvalue(ctx, eid, qsid);
    }

    var rec_ty: type.TypeId;
    val res_base: R.Result[value.Value, str] = member_receiver(ctx, eid, e.data.member.object,
        "field access on untyped pointer; cast to a typed pointer (*T) first", ?rec_ty);
    if (R.is_err[value.Value, str](res_base)) { ret res_base; }

    val field_ix: u32 = field_index_in_type(ctx, rec_ty, e.data.member.name);
    ret field_gep(ctx, R.unwrap_ok[value.Value, str](res_base), rec_ty, field_ix);
}

# the field ordinal a `v.[f]` projection names
#
# Read from the comptime FIELD descriptor its field operand evaluates to (bound
# by an enclosing `$each`). Errors when the operand is not a field descriptor.
# ---
# ctx:       per-module lowering context
# field_eid: the projection's field operand
# ret:       the field ordinal, or an error
fun project_field_index(ctx: *context.LowerContext, field_eid: id.ExprId) R.Result[u32, str] {
    val res_field: R.Result[comptime.CTValue, str] =
        comptime.eval(ctx.ctx, ctx.a, context.module_source(ctx), field_eid, ?ctx.s.interner);
    if (R.is_err[comptime.CTValue, str](res_field)) { ret R.err[u32, str](R.unwrap_err[comptime.CTValue, str](res_field)); }
    val fv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_field);
    if (fv.kind != comptime.CT_KIND_FIELD) {
        ret R.err[u32, str]("lower: `v.[f]` field operand is not a comptime field descriptor");
    }
    ret R.ok[u32, str](fv.data.fld.index);
}

# lower a `v.[f]` projection in rvalue position
#
# A load from the projected field pointer, except for an aggregate field whose
# rvalue is its storage address (mirrors lower_member_rvalue).
# ---
# ctx: per-module lowering context
# eid: the projection expression
# e:   the resolved projection node
# ret: the projection's rvalue, or an error
fun lower_project_rvalue(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val res_ptr: R.Result[value.Value, str] = lower_project_lvalue(ctx, eid, e);
    if (R.is_err[value.Value, str](res_ptr)) { ret res_ptr; }
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret rvalue_at(ctx, R.unwrap_ok[value.Value, str](res_ptr), R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
}

# lower a `v.[f]` projection in lvalue position to the field pointer
#
# Like a member access, but the field index comes from the comptime field
# descriptor rather than a name. A pointer receiver auto-derefs; a value receiver
# uses its own storage.
# ---
# ctx: per-module lowering context
# eid: the projection expression
# e:   the resolved projection node
# ret: the field pointer Value, or an error
fun lower_project_lvalue(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val res_fix: R.Result[u32, str] = project_field_index(ctx, e.data.project.field);
    if (R.is_err[u32, str](res_fix)) { ret R.err[value.Value, str](R.unwrap_err[u32, str](res_fix)); }
    val field_ix: u32 = R.unwrap_ok[u32, str](res_fix);

    var rec_ty: type.TypeId;
    val res_base: R.Result[value.Value, str] = member_receiver(ctx, eid, e.data.project.object,
        "field projection on untyped pointer; cast to a typed pointer (*T) first", ?rec_ty);
    if (R.is_err[value.Value, str](res_base)) { ret res_base; }

    ret field_gep(ctx, R.unwrap_ok[value.Value, str](res_base), rec_ty, field_ix);
}

# lower an index access in rvalue position
#
# A load from the element pointer, except for an aggregate element whose rvalue is
# its storage address (see lower_ident_rvalue).
# ---
# ctx: per-module lowering context
# eid: the index expression
# e:   the resolved index node
# ret: the element's rvalue, or an error
fun lower_index_rvalue(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val res_ptr: R.Result[value.Value, str] = lower_index_lvalue(ctx, eid, e);
    if (R.is_err[value.Value, str](res_ptr)) { ret res_ptr; }
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    ret rvalue_at(ctx, R.unwrap_ok[value.Value, str](res_ptr), R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
}

# lower an index access in lvalue position to the element pointer
#
# A gep against the base (an array slot pointer or a raw pointer rvalue) with the
# index value. A pointer base `*T` deref'd by one index strides over the element T
# directly (`[ix]`, gep source type T); an array base `[N]T` addresses an element
# through the canonical `[0, ix]` aggregate walk (gep source type `[N]T`), so the
# index scales by the element size, not the whole-array size.
# ---
# ctx: per-module lowering context
# eid: the index expression
# e:   the resolved index node
# ret: the element pointer Value, or an error
fun lower_index_lvalue(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val obj_ty: type.TypeId = context.expr_type_of(ctx, e.data.index.object);
    val is_ptr: bool        = is_pointer_type(ctx, obj_ty);

    # a pointer base is consumed by its rvalue; an array base by its lvalue (its
    # own storage), mirroring the member-receiver split.
    var base: value.Value;
    if (is_ptr) {
        val res_base: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.index.object);
        if (R.is_err[value.Value, str](res_base)) { ret res_base; }
        base = R.unwrap_ok[value.Value, str](res_base);
    } or {
        val res_base: R.Result[value.Value, str] = lower_lvalue(ctx, e.data.index.object);
        if (R.is_err[value.Value, str](res_base)) { ret res_base; }
        base = R.unwrap_ok[value.Value, str](res_base);
    }

    val res_ix: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.index.index);
    if (R.is_err[value.Value, str](res_ix)) { ret res_ix; }
    var ix: value.Value = R.unwrap_ok[value.Value, str](res_ix);

    # a gep index is machine-word arithmetic: the back end scales the full index
    # register, so a sub-word index (e.g. a u8) must be widened to 64 bits first -
    # otherwise its undefined high register bits corrupt the scaled offset.
    val res_widen: R.Result[value.Value, str] = widen_index(ctx, ix, context.expr_type_of(ctx, e.data.index.index));
    if (R.is_err[value.Value, str](res_widen)) { ret res_widen; }
    ix = R.unwrap_ok[value.Value, str](res_widen);

    if (is_ptr) {
        # `*T[ix]` strides over the pointee element type T. a raw untyped `ptr` has
        # no element type to size the stride, so indexing one is not lowerable.
        val opt_pt: O.Option[*type.Type] = type.get(?ctx.s.types, obj_ty);
        if (O.is_none[*type.Type](opt_pt)) { ret R.err[value.Value, str]("lower: index base has no pointer type"); }
        val pt: *type.Type = O.unwrap[*type.Type](opt_pt);
        if (pt.kind != type.TYPE_POINTER) {
            ret report_expr(ctx, eid, "index on untyped pointer; use a typed pointer (*T) to index");
        }
        val res_elem_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, pt.data.pointer.base);
        if (R.is_err[ir_type.IrTypeId, str](res_elem_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_elem_ir)); }
        var idx1: [1]value.Value;
        idx1[0] = ix;
        ret builder.emit_gep(?ctx.builder, base, R.unwrap_ok[ir_type.IrTypeId, str](res_elem_ir), ?idx1[0], 1);
    }

    # `[N]T[ix]` addresses element ix through the aggregate walk on the array type.
    val res_arr_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, obj_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_arr_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_arr_ir)); }
    val arr_ir: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_arr_ir);

    val res_xty: R.Result[ir_type.IrTypeId, str] = index_type(ctx);
    if (R.is_err[ir_type.IrTypeId, str](res_xty)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_xty)); }
    val xty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_xty);

    var idx: [2]value.Value;
    idx[0] = value.const_int(0, xty);
    idx[1] = ix;
    ret builder.emit_gep(?ctx.builder, base, arr_ir, ?idx[0], 2);
}

# intern a static literal in the session interner
#
# Returns STR_NIL on allocation failure (a STR_NIL never matches a real span
# name), so a caller comparing against it degrades to "no match" rather than to
# an error path.
# ---
# ctx:  per-module lowering context
# text: the literal text to intern
# ret:  the interned StrId, or STR_NIL on allocation failure
fun interned_literal(ctx: *context.LowerContext, text: str) intern.StrId {
    val res_str: R.Result[intern.StrId, str] = intern.intern(?ctx.s.interner, text);
    if (R.is_err[intern.StrId, str](res_str)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](res_str);
}

# fold a comptime value intrinsic call to an integer constant
#
# Handles `$size_of(T)`, `$align_of(T)`, and `$offset_of(T, field)`, mirroring
# cmach's sema-time fold. None when the callee is not such an intrinsic, leaving
# the caller to lower a normal call. The constant takes the call's IR result type
# (u64), set by sema. Sizes / offsets come from the target-aware IR layout, the
# same authority the backend uses for alloca and gep.
# ---
# ctx: per-module lowering context
# eid: the call expression (supplies the u64 result type)
# e:   the resolved call node
# ret: some(folded constant or error) for an intrinsic call, none otherwise
pub fun try_lower_comptime_intrinsic(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) O.Option[R.Result[value.Value, str]] {
    val opt_ce: O.Option[*expr.Expr] = ast.get_expr(ctx.a, e.data.call.callee);
    if (O.is_none[*expr.Expr](opt_ce)) { ret O.none[R.Result[value.Value, str]](); }
    val ce: *expr.Expr = O.unwrap[*expr.Expr](opt_ce);
    if (ce.kind != expr.EXPR_KIND_COMPTIME_IDENT) { ret O.none[R.Result[value.Value, str]](); }

    val ns: token.Span = comptime.comptime_ident_name(ce.span);
    if (ns.len == 0) { ret O.none[R.Result[value.Value, str]](); }
    val res_name: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, context.module_source(ctx), ns);
    if (R.is_err[intern.StrId, str](res_name)) {
        ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_name)));
    }
    val name: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);
    val is_size:   bool = name == interned_literal(ctx, "size_of");
    val is_align:  bool = name == interned_literal(ctx, "align_of");
    val is_offset: bool = name == interned_literal(ctx, "offset_of");
    if (!is_size && !is_align && !is_offset) { ret O.none[R.Result[value.Value, str]](); }

    # bound the argument pool slice this call reads: arg0 (and, for offset_of,
    # arg1) must lie within the expr-id pool. sema validates intrinsic arities, so
    # this only guards the indexing; `args_start + args_len <= pool` makes every
    # ordinal in [args_start, args_start + args_len) addressable, and the per-
    # intrinsic arity requires the ordinals actually read to be present.
    var arity: u32 = 1;
    if (is_offset) { arity = 2; }
    if (e.data.call.args_len < arity ||
        e.data.call.args_start::usize + e.data.call.args_len::usize > ctx.a.expr_id_len) {
        ret O.some[R.Result[value.Value, str]](R.err[value.Value, str]("lower: comptime intrinsic argument index out of range"));
    }
    val arg0_eid: id.ExprId   = ctx.a.expr_ids[e.data.call.args_start];
    val op_ty:    type.TypeId = context.expr_type_of(ctx, arg0_eid);
    val res_op_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, op_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_op_ir)) {
        ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_op_ir)));
    }
    val op_ir: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_op_ir);

    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) {
        ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)));
    }
    val rt: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);

    var n: u32 = 0;
    if (is_size)  { n = ir_type.byte_size(?ctx.m.types, op_ir, ctx.tgt); }
    if (is_align) { n = ir_type.byte_align(?ctx.m.types, op_ir, ctx.tgt); }
    if (is_offset) {
        val f_eid: id.ExprId = ctx.a.expr_ids[e.data.call.args_start + 1];
        val opt_f: O.Option[*expr.Expr] = ast.get_expr(ctx.a, f_eid);
        if (O.is_none[*expr.Expr](opt_f)) {
            ret O.some[R.Result[value.Value, str]](R.err[value.Value, str]("lower: offset_of field argument out of range"));
        }
        val field_ix: u32 = field_index_in_type(ctx, op_ty, O.unwrap[*expr.Expr](opt_f).span);
        n = ir_type.byte_offset(?ctx.m.types, op_ir, field_ix, ctx.tgt);
    }

    ret O.some[R.Result[value.Value, str]](R.ok[value.Value, str](value.const_int(n::u64, rt)));
}

# fold a constant scalar cast expression (`<const>::T`) to a constant Value
#
# Handles chains like `(-11)::i32::u32`. A cast of a constant operand is itself a
# constant the frontend comptime.eval rejects (it has no type resolution to model
# width / sign); this folds it here via the same trunc/extend/convert semantics
# lower_cast emits, so a global initialiser `val X: T = <const>::U` becomes a real
# constant instead of the zero placeholder a read-only global can never receive.
# None when the expression is not a cast or its operand is not a foldable scalar
# constant.
# ---
# ctx: per-module lowering context
# eid: the cast expression
# e:   the resolved cast node
# ret: some(folded constant or error) for a foldable cast, none otherwise
pub fun try_lower_comptime_cast(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) O.Option[R.Result[value.Value, str]] {
    if (e.kind != expr.EXPR_KIND_CAST) { ret O.none[R.Result[value.Value, str]](); }
    val opt_folded: O.Option[R.Result[comptime.CTValue, str]] = fold_const_scalar(ctx, eid);
    if (O.is_none[R.Result[comptime.CTValue, str]](opt_folded)) { ret O.none[R.Result[value.Value, str]](); }
    val res_cv: R.Result[comptime.CTValue, str] = O.unwrap[R.Result[comptime.CTValue, str]](opt_folded);
    if (R.is_err[comptime.CTValue, str](res_cv)) {
        ret O.some[R.Result[value.Value, str]](R.err[value.Value, str](R.unwrap_err[comptime.CTValue, str](res_cv)));
    }
    ret O.some[R.Result[value.Value, str]](const_value_of(ctx, eid, R.unwrap_ok[comptime.CTValue, str](res_cv)));
}

# fold a constant scalar expression to its comptime value
#
# A non-cast leaf is delegated to comptime.eval; a cast recurses on its operand
# and applies the same value-conversion lower_cast lowers (int trunc/extend by
# width and signedness, int<->float convert, float trunc/extend, and `:~`
# reinterpret). None when the expression is not a foldable scalar constant.
# ---
# ctx: per-module lowering context
# eid: the expression to fold
# ret: some(folded value or error) for a foldable scalar, none otherwise
fun fold_const_scalar(ctx: *context.LowerContext, eid: id.ExprId) O.Option[R.Result[comptime.CTValue, str]] {
    val opt_e: O.Option[*expr.Expr] = ast.get_expr(ctx.a, eid);
    if (O.is_none[*expr.Expr](opt_e)) { ret O.none[R.Result[comptime.CTValue, str]](); }
    val e: *expr.Expr = O.unwrap[*expr.Expr](opt_e);

    if (e.kind != expr.EXPR_KIND_CAST) {
        val res_eval: R.Result[comptime.CTValue, str] =
            comptime.eval(ctx.ctx, ctx.a, context.module_source(ctx), eid, ?ctx.s.interner);
        if (R.is_err[comptime.CTValue, str](res_eval)) { ret O.none[R.Result[comptime.CTValue, str]](); }
        ret O.some[R.Result[comptime.CTValue, str]](R.ok[comptime.CTValue, str](R.unwrap_ok[comptime.CTValue, str](res_eval)));
    }

    val opt_op: O.Option[R.Result[comptime.CTValue, str]] = fold_const_scalar(ctx, e.data.cast.value);
    if (O.is_none[R.Result[comptime.CTValue, str]](opt_op)) { ret O.none[R.Result[comptime.CTValue, str]](); }
    val res_op: R.Result[comptime.CTValue, str] = O.unwrap[R.Result[comptime.CTValue, str]](opt_op);
    if (R.is_err[comptime.CTValue, str](res_op)) { ret O.some[R.Result[comptime.CTValue, str]](res_op); }
    val opv: comptime.CTValue = R.unwrap_ok[comptime.CTValue, str](res_op);

    val from_ty: type.TypeId = context.expr_type_of(ctx, e.data.cast.value);
    val to_ty:   type.TypeId = context.type_resolved_of(ctx, e.data.cast.ty);
    ret O.some[R.Result[comptime.CTValue, str]](convert_const_scalar(ctx, opv, from_ty, to_ty, e.data.cast.reinterpret));
}

# apply a `::` value conversion (or `:~` reinterpret) to a folded scalar constant
#
# Matches lower_cast's instruction selection: integer truncate / sign- / zero-
# extend by the destination width, int<->float convert, and float truncate /
# extend. The folded integer is held in an i64 already canonicalised to its source
# type's representation, so a conversion to an integer target is exactly "take the
# low to_bits bits, then sign- or zero-extend to 64 by the target's signedness".
# ---
# ctx:         per-module lowering context
# v:           the folded source constant
# from_ty:     the operand's semantic type
# to_ty:       the cast's target semantic type
# reinterpret: true for a `:~` bit-reinterpret, false for a `::` value convert
# ret:         the converted constant, or an error
fun convert_const_scalar(
    ctx:         *context.LowerContext,
    v:           comptime.CTValue,
    from_ty:     type.TypeId,
    to_ty:       type.TypeId,
    reinterpret: bool
) R.Result[comptime.CTValue, str] {
    val from_float: bool = is_float_type(ctx, from_ty);
    val to_float:   bool = is_float_type(ctx, to_ty);
    val to_signed:  bool = is_signed_type(ctx, to_ty);
    val to_bits:    u32  = scalar_bits(ctx, to_ty);

    # `:~` reinterprets the raw bits; the value is sema-validated as equal size,
    # so the comptime payload already carries those bits unchanged.
    if (reinterpret) { ret R.ok[comptime.CTValue, str](v); }

    if (from_float && to_float) { ret float_ct(v.data.f); }
    if (from_float && !to_float) {
        # float -> int truncates toward zero into the target representation.
        ret int_ct(rerepresent_int(v.data.f::i64, to_bits, to_signed));
    }
    if (!from_float && to_float) {
        # int -> float yields the integer's real value as an f64.
        ret float_ct(v.data.i::f64);
    }

    ret int_ct(rerepresent_int(v.data.i, to_bits, to_signed));
}

# canonicalise an integer to a `to_bits`-wide target's representation in an i64
#
# Takes the low to_bits bits then sign- or zero-extends to 64. A to_bits of 0 (a
# non-scalar or pointer-width target) or >= 64 leaves the value unchanged.
# ---
# x:         the source integer
# to_bits:   the target width in bits
# to_signed: true to sign-extend, false to zero-extend
# ret:       the canonicalised integer
fun rerepresent_int(x: i64, to_bits: u32, to_signed: bool) i64 {
    if (to_bits == 0 || to_bits >= 64) { ret x; }
    val shift:  u64 = (64 - to_bits)::u64;
    val masked: u64 = (x::u64 << shift) >> shift;
    if (!to_signed) { ret masked::i64; }
    # arithmetic right shift sign-extends from the target's high bit.
    ret (masked::i64 << shift) >> shift;
}

# wrap an integer in a CT_KIND_INT comptime value
# ---
# i:   the integer payload
# ret: the wrapped comptime value
fun int_ct(i: i64) R.Result[comptime.CTValue, str] {
    var v: comptime.CTValue;
    v.kind   = comptime.CT_KIND_INT;
    v.data.i = i;
    ret R.ok[comptime.CTValue, str](v);
}

# wrap a float in a CT_KIND_FLOAT comptime value
# ---
# f:   the float payload
# ret: the wrapped comptime value
fun float_ct(f: f64) R.Result[comptime.CTValue, str] {
    var v: comptime.CTValue;
    v.kind   = comptime.CT_KIND_FLOAT;
    v.data.f = f;
    ret R.ok[comptime.CTValue, str](v);
}

# lower a call: the callee rvalue, then each argument rvalue, then an OP_CALL
#
# ABI classification (which args ride in registers vs the stack) is deferred to
# isel against the target ABI; lowering emits the flat operand list the contract
# specifies. The call's IR result type is the lowered semantic type of the call
# expression (IRT_VOID for a void call). A comptime value intrinsic callee is
# folded to a constant before normal call lowering. A comptime value-parameter
# argument is dropped from the runtime operand list (it is folded into the
# instance); a `va...` spread argument expands to the current pack's concrete
# slots.
# ---
# ctx: per-module lowering context
# eid: the call expression
# e:   the resolved call node
# ret: the call's result Value, or an error
fun lower_call(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val opt_intr: O.Option[R.Result[value.Value, str]] = try_lower_comptime_intrinsic(ctx, eid, e);
    if (O.is_some[R.Result[value.Value, str]](opt_intr)) { ret O.unwrap[R.Result[value.Value, str]](opt_intr); }

    val res_callee: R.Result[value.Value, str] = lower_callee(ctx, eid, e);
    if (R.is_err[value.Value, str](res_callee)) { ret res_callee; }
    val callee: value.Value = R.unwrap_ok[value.Value, str](res_callee);

    # a comptime value parameter is fixed at the call site (folded into the
    # instance), so its argument is dropped from the runtime OP_CALL: only the
    # runtime ordinals are passed, matching the stripped instance signature.
    val opt_cf: O.Option[*decl.DeclFun] = callee_decl_fun(ctx, e.data.call.callee);
    var has_ct:  bool          = false;
    var cf_decl: *decl.DeclFun = nil;
    var cf_ast:  *ast.Ast      = nil;
    if (O.is_some[*decl.DeclFun](opt_cf)) {
        cf_decl = O.unwrap[*decl.DeclFun](opt_cf);
        if (decl_fun_has_comptime_param(ctx, e.data.call.callee, cf_decl)) {
            has_ct = true;
            cf_ast = callee_ast(ctx, e.data.call.callee);
        }
    }

    val argc:       u32  = e.data.call.args_len;
    val has_spread: bool = call_has_spread(ctx, e);
    var rtc:        u32  = argc;
    if (has_ct)     { rtc = runtime_arg_count(ctx, cf_ast, cf_decl, argc); }
    # a va... spread replaces one spread arg with ctx.pack_len concrete slot args.
    if (has_spread) { rtc = (argc - 1) + ctx.pack_len; }

    var args: *value.Value = nil;
    if (rtc > 0) {
        val res_args: R.Result[*value.Value, str] = A.allocate[value.Value](ctx.s.alloc, rtc::usize);
        if (R.is_err[*value.Value, str](res_args)) { ret R.err[value.Value, str](R.unwrap_err[*value.Value, str](res_args)); }
        args = R.unwrap_ok[*value.Value, str](res_args);

        var dst: u32 = 0;
        var i:   u32 = 0;
        for (i < argc) {
            if (has_ct && arg_is_comptime(ctx, cf_ast, cf_decl, i)) { i = i + 1; cnt; }
            val pool_ix: u32 = e.data.call.args_start + i;
            if (pool_ix::usize >= ctx.a.expr_id_len) {
                A.deallocate[value.Value](ctx.s.alloc, args, rtc::usize);
                ret R.err[value.Value, str]("lower: call argument index out of range");
            }
            val arg_eid: id.ExprId = ctx.a.expr_ids[pool_ix];
            # va... spread: splice the current pack's N concrete slots into the arg list.
            if (has_spread && is_spread_expr(ctx, arg_eid)) {
                var ii: u32 = 0;
                for (ii < ctx.pack_len) {
                    val res_slot: R.Result[value.Value, str] = load_pack_slot(ctx, ii);
                    if (R.is_err[value.Value, str](res_slot)) {
                        A.deallocate[value.Value](ctx.s.alloc, args, rtc::usize);
                        ret res_slot;
                    }
                    args[dst] = R.unwrap_ok[value.Value, str](res_slot);
                    dst = dst + 1;
                    ii  = ii + 1;
                }
                i = i + 1;
                cnt;
            }
            val res_arg: R.Result[value.Value, str] = lower_rvalue(ctx, arg_eid);
            if (R.is_err[value.Value, str](res_arg)) {
                A.deallocate[value.Value](ctx.s.alloc, args, rtc::usize);
                ret res_arg;
            }
            args[dst] = R.unwrap_ok[value.Value, str](res_arg);
            dst = dst + 1;
            i   = i + 1;
        }
    }
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) {
        if (args != nil) { A.deallocate[value.Value](ctx.s.alloc, args, rtc::usize); }
        ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir));
    }
    val rt: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);

    val res_call: R.Result[value.Value, str] = builder.emit_call(?ctx.builder, callee, args, rtc, rt);
    if (args != nil) { A.deallocate[value.Value](ctx.s.alloc, args, rtc::usize); }
    ret res_call;
}

# the number of runtime arguments at a comptime-param call site
#
# The call's argument count minus the comptime ordinals (folded into the
# instance, not passed at runtime).
# ---
# ctx:  per-module lowering context
# a:    the callee's origin AST
# f:    the callee's DeclFun
# argc: the call's total argument count
# ret:  the runtime argument count
fun runtime_arg_count(ctx: *context.LowerContext, a: *ast.Ast, f: *decl.DeclFun, argc: u32) u32 {
    if (a == nil) { ret argc; }
    var len: u32 = 0;
    var i:   u32 = 0;
    for (i < argc) {
        if (!arg_is_comptime(ctx, a, f, i)) { len = len + 1; }
        i = i + 1;
    }
    ret len;
}

# whether the argument at a given call-ordinal binds a comptime parameter
#
# Read from the callee's origin DeclFun typed_names. Ordinals beyond the declared
# params (variadic tail) are runtime.
# ---
# ctx: per-module lowering context
# a:   the callee's origin AST
# f:   the callee's DeclFun
# ord: the call argument ordinal
# ret: true when the bound parameter is comptime
fun arg_is_comptime(ctx: *context.LowerContext, a: *ast.Ast, f: *decl.DeclFun, ord: u32) bool {
    if (a == nil)            { ret false; }
    if (ord >= f.params_len) { ret false; }
    ret a.typed_names[f.params_start + ord].comptime;
}

# lower a call's callee to a function-reference value
#
# A call to a function with comptime value parameters resolves to a per-value
# monomorphized instance; a pack-tailed callee resolves to a per-type-list
# instance; a call carrying explicit type arguments (`callee[T, ...](...)`) names
# a generic and resolves to its per-type instance; a plain call delegates to the
# normal rvalue lowering of the callee.
# ---
# ctx: per-module lowering context
# eid: the call expression
# e:   the resolved call node
# ret: a function-reference Value, or an error
fun lower_callee(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val opt_cf: O.Option[*decl.DeclFun] = callee_decl_fun(ctx, e.data.call.callee);
    if (O.is_some[*decl.DeclFun](opt_cf)) {
        val f: *decl.DeclFun = O.unwrap[*decl.DeclFun](opt_cf);
        if (decl_fun_has_comptime_param(ctx, e.data.call.callee, f)) {
            # a callee that is BOTH generic (`[T]`) and comptime-param (`$mode`)
            # needs a combined type+value instance, which is unsupported. sema
            # already rejects such a call with a clean diagnostic and the driver
            # aborts before lowering, so reaching here is a coherence violation:
            # neither lower_value_callee (which ignores the type args, producing a
            # wrong symbol) nor lower_generic_callee (which lowers against the
            # comptime-stripped signature) is correct, so hard-error instead.
            if (f.generics_len > 0) {
                ret R.err[value.Value, str]("lower: comptime value parameters on a generic function are not supported");
            }
            ret lower_value_callee(ctx, eid, e, f);
        }
        # a pack-tailed callee (`va: ...`) resolves to a per-type-list monomorphized
        # instance (#1475), keyed by the trailing arguments' concrete types.
        if (decl_fun_has_pack_param(ctx, e.data.call.callee, f)) {
            ret lower_pack_callee(ctx, eid, e, f);
        }
    }
    if (e.data.call.type_args_len == 0) {
        ret lower_rvalue(ctx, e.data.call.callee);
    }
    ret lower_generic_callee(ctx, eid, e);
}

# the callee's origin DeclFun
#
# Read from its origin module's AST for a cross-module callee. None when the
# callee does not name a function declaration.
# ---
# ctx:    per-module lowering context
# callee: the callee expression
# ret:    some(DeclFun) for a function callee, none otherwise
fun callee_decl_fun(ctx: *context.LowerContext, callee: id.ExprId) O.Option[*decl.DeclFun] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, callee);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret O.none[*decl.DeclFun](); }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    if (sym.kind != resolve.SYM_FUN && sym.kind != resolve.SYM_IMPORTED) { ret O.none[*decl.DeclFun](); }
    if (sym.decl == id.DECL_NIL)                                         { ret O.none[*decl.DeclFun](); }

    var origin_ast: *ast.Ast = ctx.a;
    if (sym.origin != ctx.own_module) {
        origin_ast = session.module_ast(ctx.s, sym.origin);
        if (origin_ast == nil) { ret O.none[*decl.DeclFun](); }
    }
    val opt_d: O.Option[*decl.Decl] = ast.get_decl(origin_ast, sym.decl);
    if (O.is_none[*decl.Decl](opt_d)) { ret O.none[*decl.DeclFun](); }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_d);
    if (d.kind != decl.DECL_KIND_FUN) { ret O.none[*decl.DeclFun](); }
    ret O.some[*decl.DeclFun](?d.data.fun_);
}

# whether the callee's DeclFun declares any comptime value parameter
#
# Reads the comptime flags from the callee's origin AST.
# ---
# ctx:    per-module lowering context
# callee: the callee expression
# f:      the callee's DeclFun
# ret:    true when at least one parameter is comptime
fun decl_fun_has_comptime_param(ctx: *context.LowerContext, callee: id.ExprId, f: *decl.DeclFun) bool {
    val origin_ast: *ast.Ast = callee_ast(ctx, callee);
    if (origin_ast == nil) { ret false; }
    var i: u32 = 0;
    for (i < f.params_len) {
        if (origin_ast.typed_names[f.params_start + i].comptime) { ret true; }
        i = i + 1;
    }
    ret false;
}

# whether the callee's DeclFun ends in a comptime variadic-pack parameter
#
# Detects a trailing `va: ...` (#1475) syntactically from the callee's origin AST
# - the trailing parameter's AstType is a TYPE_KIND_PACK. Done without sema
# (mirrors the comptime-flag check) so it works for a cross-module callee whose
# resolved types live in another module.
# ---
# ctx:    per-module lowering context
# callee: the callee expression
# f:      the callee's DeclFun
# ret:    true when the trailing parameter is a comptime variadic pack
fun decl_fun_has_pack_param(ctx: *context.LowerContext, callee: id.ExprId, f: *decl.DeclFun) bool {
    val origin_ast: *ast.Ast = callee_ast(ctx, callee);
    if (origin_ast == nil) { ret false; }
    if (f.params_len == 0) { ret false; }
    val tn: *decl.TypedName = ?origin_ast.typed_names[f.params_start + (f.params_len - 1)];
    val opt_t: O.Option[*atype.Type] = ast.get_type(origin_ast, tn.ty);
    if (O.is_none[*atype.Type](opt_t)) { ret false; }
    ret O.unwrap[*atype.Type](opt_t).kind == atype.TYPE_KIND_PACK;
}

# the AST the callee is declared in
#
# The caller's own AST for a local callee, the origin module's AST for a
# cross-module one, or nil when unresolvable.
# ---
# ctx:    per-module lowering context
# callee: the callee expression
# ret:    the declaring AST, or nil
fun callee_ast(ctx: *context.LowerContext, callee: id.ExprId) *ast.Ast {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, callee);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret nil; }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    if (sym.origin == ctx.own_module) { ret ctx.a; }
    ret session.module_ast(ctx.s, sym.origin);
}

# resolve a comptime value-parameter call to its monomorphized instance
#
# Folds each comptime-ordinal argument to a CTValue (the same fold `$if` uses)
# against the caller's comptime context, computes the instance's mangled linkage
# name (with the values encoded into the disjoint `K...E` suffix), enqueues the
# instance for body emission, and returns a function reference to it. A
# non-constant argument at a `$`-parameter is a hard error pointing at the
# argument.
# ---
# ctx: per-module lowering context
# eid: the call expression
# e:   the resolved call node
# f:   the callee's DeclFun
# ret: a function reference to the instance, or an error
fun lower_value_callee(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr, f: *decl.DeclFun) R.Result[value.Value, str] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, e.data.call.callee);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) {
        ret R.err[value.Value, str]("lower: unresolved comptime-param call target");
    }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    val origin_ast: *ast.Ast = callee_ast(ctx, e.data.call.callee);
    if (origin_ast == nil) { ret R.err[value.Value, str]("lower: comptime-param callee AST unavailable"); }

    # count comptime parameters to size the value / name buffers.
    var ct_len: u32 = 0;
    var i:      u32 = 0;
    for (i < f.params_len) {
        if (origin_ast.typed_names[f.params_start + i].comptime) { ct_len = ct_len + 1; }
        i = i + 1;
    }
    if (ct_len == 0) { ret R.err[value.Value, str]("lower: comptime-param call has no comptime parameters"); }

    val res_vals: R.Result[*comptime.CTValue, str] = A.allocate[comptime.CTValue](ctx.s.alloc, ct_len::usize);
    if (R.is_err[*comptime.CTValue, str](res_vals)) { ret R.err[value.Value, str](R.unwrap_err[*comptime.CTValue, str](res_vals)); }
    val vals: *comptime.CTValue = R.unwrap_ok[*comptime.CTValue, str](res_vals);
    val res_names: R.Result[*intern.StrId, str] = A.allocate[intern.StrId](ctx.s.alloc, ct_len::usize);
    if (R.is_err[*intern.StrId, str](res_names)) {
        A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
        ret R.err[value.Value, str](R.unwrap_err[*intern.StrId, str](res_names));
    }
    val names: *intern.StrId = R.unwrap_ok[*intern.StrId, str](res_names);

    # fold each comptime-ordinal argument and record its bare parameter name.
    var dst: u32 = 0;
    var ii:  u32 = 0;
    for (ii < f.params_len) {
        val tn: *decl.TypedName = ?origin_ast.typed_names[f.params_start + ii];
        if (tn.comptime) {
            if (ii >= e.data.call.args_len) {
                A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
                A.deallocate[intern.StrId](ctx.s.alloc, names, ct_len::usize);
                ret R.err[value.Value, str]("lower: comptime-param call argument index out of range");
            }
            val arg_eid: id.ExprId = ctx.a.expr_ids[e.data.call.args_start + ii];
            val opt_fv: O.Option[comptime.CTValue] = fold_comptime_arg(ctx, arg_eid);
            if (O.is_none[comptime.CTValue](opt_fv)) {
                val arg_span: token.Span = expr_span_of(ctx, arg_eid);
                diagnostic.error(?ctx.s.diags, ctx.a.file_id, arg_span, "comptime argument is not a compile-time constant");
                A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
                A.deallocate[intern.StrId](ctx.s.alloc, names, ct_len::usize);
                ret R.err[value.Value, str](context.REPORTED);
            }
            vals[dst] = O.unwrap[comptime.CTValue](opt_fv);

            # the bare parameter identifier, interned against the session, paired
            # positionally with the value so the drain binds `$param -> CTValue`.
            # the origin module's source must be registered (a resolvable callee's
            # module is loaded); a missing one is a coherence violation, not a no-op,
            # so hard-error rather than slicing a nil source in intern_span.
            val opt_src: O.Option[*source.SourceFile] = source.get(?ctx.s.sources, origin_ast.file_id);
            if (O.is_none[*source.SourceFile](opt_src)) {
                A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
                A.deallocate[intern.StrId](ctx.s.alloc, names, ct_len::usize);
                ret R.err[value.Value, str]("lower: comptime-param callee origin module source unavailable");
            }
            val origin_text: str = O.unwrap[*source.SourceFile](opt_src).text;
            val res_name: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, origin_text, tn.name);
            if (R.is_err[intern.StrId, str](res_name)) {
                A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
                A.deallocate[intern.StrId](ctx.s.alloc, names, ct_len::usize);
                ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_name));
            }
            names[dst] = R.unwrap_ok[intern.StrId, str](res_name);
            dst = dst + 1;
        }
        ii = ii + 1;
    }

    # the instance is owned by the function's origin module; mangle against that
    # module's FQN so the definition (emitted by the drain) and every reference
    # agree byte-for-byte.
    val fqn: intern.StrId = session.module_fqn(ctx.s, sym.origin);
    val res_link: R.Result[intern.StrId, str] = mangle.value_instance_name(ctx.s, fqn, sym.name, vals, ct_len);
    if (R.is_err[intern.StrId, str](res_link)) {
        A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
        A.deallocate[intern.StrId](ctx.s.alloc, names, ct_len::usize);
        ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_link));
    }
    val link: intern.StrId = R.unwrap_ok[intern.StrId, str](res_link);

    val res_enq: R.Result[bool, str] = context.enqueue_value_instance(ctx, sym.decl, sym.origin, vals, names, ct_len, link);
    A.deallocate[comptime.CTValue](ctx.s.alloc, vals, ct_len::usize);
    A.deallocate[intern.StrId](ctx.s.alloc, names, ct_len::usize);
    if (R.is_err[bool, str](res_enq)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_enq)); }

    val res_ptr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?ctx.m.types);
    if (R.is_err[ir_type.IrTypeId, str](res_ptr)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ptr)); }
    ret fn_reference(ctx, link, R.unwrap_ok[ir_type.IrTypeId, str](res_ptr));
}

# fold a comptime call argument to a CTValue
#
# Tries the comptime evaluator against the caller's context first (handles
# literals, `$mach.*`, and bare-name constants registered in the caller's
# context). On failure, resolves a cross-module constant reference; a
# module-qualified member `alias.CONST` (or a bare import) binds to an imported
# symbol whose (origin, name) names a `pub val` in the defining module; its folded
# value is read from that module's comptime context. None when the argument is not
# a compile-time constant.
# ---
# ctx: per-module lowering context
# eid: the argument expression
# ret: some(folded value) for a compile-time constant, none otherwise
fun fold_comptime_arg(ctx: *context.LowerContext, eid: id.ExprId) O.Option[comptime.CTValue] {
    val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(ctx.ctx, ctx.a, context.module_source(ctx), eid, ?ctx.s.interner);
    if (R.is_ok[comptime.CTValue, str](res_eval)) {
        ret O.some[comptime.CTValue](R.unwrap_ok[comptime.CTValue, str](res_eval));
    }

    # a cross-module constant: resolve the arg's symbol and read its value from
    # the DEFINING module's comptime context.
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, eid);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) { ret O.none[comptime.CTValue](); }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);
    if (sym.kind != resolve.SYM_VAL && sym.kind != resolve.SYM_IMPORTED) { ret O.none[comptime.CTValue](); }

    # the defining module's comptime context holds the folded value under the bare
    # symbol name. the caller's own context is the same when origin == own module.
    var dctx: *comptime.ComptimeCtx = ctx.ctx;
    if (sym.origin != ctx.own_module) {
        dctx = (session.module_comptime_ptr(ctx.s, sym.origin))::*comptime.ComptimeCtx;
        if (dctx == nil) { ret O.none[comptime.CTValue](); }
    }
    val opt_nc: O.Option[*comptime.NamedConst] = comptime.lookup(dctx, sym.name);
    if (O.is_none[*comptime.NamedConst](opt_nc)) { ret O.none[comptime.CTValue](); }
    ret O.some[comptime.CTValue](O.unwrap[*comptime.NamedConst](opt_nc).value);
}

# the source span of an argument expression
#
# Used to point a diagnostic at a non-constant comptime argument.
# ---
# ctx: per-module lowering context
# eid: the argument expression
# ret: the expression's span, or a zero span when out of range
fun expr_span_of(ctx: *context.LowerContext, eid: id.ExprId) token.Span {
    val opt_e: O.Option[*expr.Expr] = ast.get_expr(ctx.a, eid);
    if (O.is_some[*expr.Expr](opt_e)) { ret O.unwrap[*expr.Expr](opt_e).span; }
    var s: token.Span;
    s.offset = 0;
    s.len    = 0;
    ret s;
}

# file a located error at an expression's span and return the REPORTED sentinel
#
# Lets lowering surface a single file:line:col diagnostic instead of a span-less
# propagated string.
# ---
# ctx:     per-module lowering context
# eid:     the expression to locate the error at
# message: the diagnostic text
# ret:     always an error carrying the REPORTED sentinel
fun report_expr(ctx: *context.LowerContext, eid: id.ExprId, message: str) R.Result[value.Value, str] {
    diagnostic.error(?ctx.s.diags, ctx.a.file_id, expr_span_of(ctx, eid), message);
    ret R.err[value.Value, str](context.REPORTED);
}

# resolve a generic call to its monomorphized instance
#
# Reads the call-site type arguments (substituting any that are themselves generic
# params bound in the enclosing instance body, so a transitive `allocate[T]` ->
# `reallocate[T]` resolves T to the concrete arg), computes the instance's mangled
# linkage name, enqueues the instance for body emission, and returns a function
# reference to it. The instance lives in the generic's origin module; the back end
# emits a name-based call the linker binds to the (weak, deduped) instance body.
# ---
# ctx: per-module lowering context
# eid: the call expression
# e:   the resolved call node
# ret: a function reference to the instance, or an error
fun lower_generic_callee(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, e.data.call.callee);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) {
        ret R.err[value.Value, str]("lower: unresolved generic call target");
    }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);

    val argc: u32 = e.data.call.type_args_len;
    val res_args: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](ctx.s.alloc, argc::usize);
    if (R.is_err[*type.TypeId, str](res_args)) { ret R.err[value.Value, str](R.unwrap_err[*type.TypeId, str](res_args)); }
    val args: *type.TypeId = R.unwrap_ok[*type.TypeId, str](res_args);

    var i: u32 = 0;
    for (i < argc) {
        val pool_ix: u32 = e.data.call.type_args_start + i;
        if (pool_ix::usize >= ctx.a.type_id_len) {
            A.deallocate[type.TypeId](ctx.s.alloc, args, argc::usize);
            ret R.err[value.Value, str]("lower: generic call type-argument index out of range");
        }
        var at: type.TypeId = context.type_resolved_of(ctx, ctx.a.type_ids[pool_ix]);
        if (ctx.subst != nil && ctx.subst_len > 0) {
            at = generics.substitute(ctx.s, at, ctx.subst, ctx.subst_len);
        }
        args[i] = at;
        i = i + 1;
    }

    # the instance is owned by the generic's origin module; mangle the instance
    # name against that module's FQN so the definition (emitted by the drain) and
    # every reference agree.
    val fqn: intern.StrId = session.module_fqn(ctx.s, sym.origin);
    val res_link: R.Result[intern.StrId, str] = mangle.instance_name(ctx.s, fqn, sym.name, args, argc);
    if (R.is_err[intern.StrId, str](res_link)) {
        A.deallocate[type.TypeId](ctx.s.alloc, args, argc::usize);
        ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_link));
    }
    val link: intern.StrId = R.unwrap_ok[intern.StrId, str](res_link);

    val res_enq: R.Result[bool, str] = context.enqueue_instance(ctx, sym.decl, sym.origin, args, argc, link);
    A.deallocate[type.TypeId](ctx.s.alloc, args, argc::usize);
    if (R.is_err[bool, str](res_enq)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_enq)); }

    val res_ptr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?ctx.m.types);
    if (R.is_err[ir_type.IrTypeId, str](res_ptr)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ptr)); }
    ret fn_reference(ctx, link, R.unwrap_ok[ir_type.IrTypeId, str](res_ptr));
}

# resolve a pack-tailed call to its monomorphized instance (#1475)
#
# Two paths:
#   - `va...` spread: the call forwards the current pack instance; the type-list
#     is borrowed from ctx.pack_types (enqueue copies it).
#   - collected: the type-list is gathered from the trailing call-site arguments,
#     with any enclosing generic substitution applied.
# In both cases the instance's mangled linkage name is computed under the disjoint
# `Q...E` pack namespace, the instance is enqueued for body emission, and a
# function reference to it is returned. All arguments are passed at runtime.
# ---
# ctx: per-module lowering context
# eid: the call expression
# e:   the resolved call node
# f:   the callee's DeclFun
# ret: a function reference to the instance, or an error
fun lower_pack_callee(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr, f: *decl.DeclFun) R.Result[value.Value, str] {
    val sid: resolve.SymbolId = context.expr_symbol_of(ctx, e.data.call.callee);
    val opt_sym: O.Option[*resolve.Symbol] = context.symbol_of(ctx, sid);
    if (O.is_none[*resolve.Symbol](opt_sym)) {
        ret R.err[value.Value, str]("lower: unresolved pack-tailed call target");
    }
    val sym: *resolve.Symbol = O.unwrap[*resolve.Symbol](opt_sym);

    # the pack is the trailing parameter; every argument past the leading fixed
    # parameters is a collected pack element.
    val fixed_len:  u32         = f.params_len - 1;
    var elem_len:   u32         = 0;
    var types:      *type.TypeId = nil;
    var owns_types: bool        = false;

    if (call_has_spread(ctx, e)) {
        # va... forward: borrow the current instance's type-list directly; enqueue
        # copies it, so we must not free it after enqueueing.
        elem_len = ctx.pack_len;
        types    = ctx.pack_types;
    } or {
        if (e.data.call.args_len < fixed_len) {
            ret R.err[value.Value, str]("lower: pack-tailed call has fewer arguments than fixed parameters");
        }
        elem_len = e.data.call.args_len - fixed_len;
        if (elem_len > 0) {
            val res_types: R.Result[*type.TypeId, str] = A.allocate[type.TypeId](ctx.s.alloc, elem_len::usize);
            if (R.is_err[*type.TypeId, str](res_types)) { ret R.err[value.Value, str](R.unwrap_err[*type.TypeId, str](res_types)); }
            types      = R.unwrap_ok[*type.TypeId, str](res_types);
            owns_types = true;

            var i: u32 = 0;
            for (i < elem_len) {
                val pool_ix: u32 = e.data.call.args_start + fixed_len + i;
                if (pool_ix::usize >= ctx.a.expr_id_len) {
                    A.deallocate[type.TypeId](ctx.s.alloc, types, elem_len::usize);
                    ret R.err[value.Value, str]("lower: pack-tailed call argument index out of range");
                }
                val arg_eid: id.ExprId = ctx.a.expr_ids[pool_ix];
                var et: type.TypeId = context.expr_type_of(ctx, arg_eid);
                if (ctx.subst != nil && ctx.subst_len > 0) {
                    et = generics.substitute(ctx.s, et, ctx.subst, ctx.subst_len);
                }
                types[i] = et;
                i = i + 1;
            }
        }
    }

    # the instance is owned by the function's origin module; mangle against that
    # module's FQN so the definition (emitted by the drain) and every reference
    # agree byte-for-byte.
    val fqn: intern.StrId = session.module_fqn(ctx.s, sym.origin);
    val res_link: R.Result[intern.StrId, str] = mangle.pack_instance_name(ctx.s, fqn, sym.name, types, elem_len);
    if (R.is_err[intern.StrId, str](res_link)) {
        if (owns_types && types != nil) { A.deallocate[type.TypeId](ctx.s.alloc, types, elem_len::usize); }
        ret R.err[value.Value, str](R.unwrap_err[intern.StrId, str](res_link));
    }
    val link: intern.StrId = R.unwrap_ok[intern.StrId, str](res_link);

    val res_enq: R.Result[bool, str] = context.enqueue_pack_instance(ctx, sym.decl, sym.origin, types, elem_len, link);
    if (owns_types && types != nil)   { A.deallocate[type.TypeId](ctx.s.alloc, types, elem_len::usize); }
    if (R.is_err[bool, str](res_enq)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_enq)); }

    val res_ptr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?ctx.m.types);
    if (R.is_err[ir_type.IrTypeId, str](res_ptr)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ptr)); }
    ret fn_reference(ctx, link, R.unwrap_ok[ir_type.IrTypeId, str](res_ptr));
}

# lower a binary expression
#
# Assignment evaluates the RHS and stores it through the LHS lvalue; logical
# `&&` / `||` short-circuit via cbr diamonds; every other operator maps to one
# arithmetic / comparison / bitwise instruction selected by the operand type.
# ---
# ctx: per-module lowering context
# eid: the binary expression
# e:   the resolved binary node
# ret: the operator's result Value, or an error
fun lower_binary(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val op: expr.BinOp = e.data.binary.op;

    if (op == expr.BIN_ASSIGN)                   { ret lower_assign(ctx, e); }
    if (op == expr.BIN_AND || op == expr.BIN_OR) { ret lower_logical(ctx, e); }

    val res_lhs: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.binary.lhs);
    if (R.is_err[value.Value, str](res_lhs)) { ret res_lhs; }
    var lhs: value.Value = R.unwrap_ok[value.Value, str](res_lhs);

    val res_rhs: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.binary.rhs);
    if (R.is_err[value.Value, str](res_rhs)) { ret res_rhs; }
    var rhs: value.Value = R.unwrap_ok[value.Value, str](res_rhs);

    val lty:    type.TypeId = context.expr_type_of(ctx, e.data.binary.lhs);
    val rty:    type.TypeId = context.expr_type_of(ctx, e.data.binary.rhs);
    val signed: bool        = is_signed_type(ctx, lty);

    # comparisons compare mathematical values across any integer signedness /
    # width mix and across float widths. lower_cmp owns the value-correct
    # widening and the irreducible i64/u64 sign-test sequence; the back end's
    # single-width CMP and the IR's signedness-free types make this the only
    # layer that can choose extension and compare signedness from the semantic
    # types. non-comparison integer ops share the operand type via sema.
    if (is_compare_binop(op)) { ret lower_cmp(ctx, op, lhs, lty, rhs, rty); }

    if (op == expr.BIN_ADD) { ret builder.emit_add(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_SUB) { ret builder.emit_sub(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_MUL) { ret builder.emit_mul(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_DIV) {
        if (signed) { ret builder.emit_div_s(?ctx.builder, lhs, rhs); }
        ret builder.emit_div_u(?ctx.builder, lhs, rhs);
    }
    if (op == expr.BIN_MOD) {
        # x86-64 SSE has no float-remainder instruction (unlike +/-/*//, which map
        # to SSE forms). a floating-point `%` is synthesized as the truncated
        # (C `fmod`) remainder from float primitives; the integer OP_REM_* opcodes
        # stay integer-only. routing a float `%` to OP_REM_* would run the integer
        # divide over the raw IEEE-754 bit patterns and miscompile (issue #1378).
        if (is_float_type(ctx, lty)) { ret lower_float_rem(ctx, lhs, rhs); }
        if (signed)                  { ret builder.emit_rem_s(?ctx.builder, lhs, rhs); }
        ret builder.emit_rem_u(?ctx.builder, lhs, rhs);
    }
    if (op == expr.BIN_BIT_AND) { ret builder.emit_and(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_BIT_OR)  { ret builder.emit_or(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_BIT_XOR) { ret builder.emit_xor(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_SHL)     { ret builder.emit_shl(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_SHR) {
        if (signed) { ret builder.emit_shr_s(?ctx.builder, lhs, rhs); }
        ret builder.emit_shr_u(?ctx.builder, lhs, rhs);
    }

    ret R.err[value.Value, str]("lower: unsupported binary operator");
}

# lower a floating-point remainder `lhs % rhs` to the truncated (C `fmod`) form
#
# The result takes the sign of the dividend: q = trunc(lhs / rhs),
# rem = lhs - q * rhs. x86-64 SSE has no float-remainder instruction, so the
# operation is built from the float divide, a truncate-toward-zero round trip
# through i64 (FP_TO_SI / SI_TO_FP), and a float multiply / subtract - all of
# which the back end already selects to their SSE forms. The i64 round trip bounds
# the exact range to |lhs / rhs| < 2^63, matching a libm-free fmod. Both operands
# share the float result type, so the divide / multiply / subtract carry lhs.ty.
# ---
# ctx: per-module lowering context
# lhs: the dividend
# rhs: the divisor
# ret: the remainder Value, or an error
fun lower_float_rem(ctx: *context.LowerContext, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    val res_i64: R.Result[ir_type.IrTypeId, str] = ir_type.intern_int(?ctx.m.types, 64);
    if (R.is_err[ir_type.IrTypeId, str](res_i64)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_i64)); }
    val i64ty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_i64);

    # q = lhs / rhs (float divide; OP_DIV_U mirrors how float `/` is emitted).
    val res_q: R.Result[value.Value, str] = builder.emit_div_u(?ctx.builder, lhs, rhs);
    if (R.is_err[value.Value, str](res_q)) { ret res_q; }
    val q: value.Value = R.unwrap_ok[value.Value, str](res_q);

    # trunc(q): float -> i64 truncates toward zero, then i64 -> float restores it.
    val res_qi: R.Result[value.Value, str] = builder.emit_fp_to_si(?ctx.builder, q, i64ty);
    if (R.is_err[value.Value, str](res_qi)) { ret res_qi; }
    val qi: value.Value = R.unwrap_ok[value.Value, str](res_qi);

    val res_qf: R.Result[value.Value, str] = builder.emit_si_to_fp(?ctx.builder, qi, lhs.ty);
    if (R.is_err[value.Value, str](res_qf)) { ret res_qf; }
    val qf: value.Value = R.unwrap_ok[value.Value, str](res_qf);

    # rem = lhs - trunc(q) * rhs.
    val res_prod: R.Result[value.Value, str] = builder.emit_mul(?ctx.builder, qf, rhs);
    if (R.is_err[value.Value, str](res_prod)) { ret res_prod; }
    val prod: value.Value = R.unwrap_ok[value.Value, str](res_prod);

    ret builder.emit_sub(?ctx.builder, lhs, prod);
}

# whether `op` is a comparison binary operator
#
# Comparison operands are read at a single unified width by the back end, so a
# mixed-width integer pair must be extended before the compare.
# ---
# op:  the binary operator
# ret: true for ==, !=, <, <=, >, >=
fun is_compare_binop(op: expr.BinOp) bool {
    ret op == expr.BIN_EQ  || op == expr.BIN_NEQ ||
        op == expr.BIN_LT  || op == expr.BIN_LEQ ||
        op == expr.BIN_GT  || op == expr.BIN_GEQ;
}

# lowers a comparison to its value-correct u8 result. comparisons relate the
# mathematical values of the operands, so the result is identical in both
# operand orders regardless of signedness or width:
#   - float vs float: widen the narrower side (exact) and compare as floats;
#     sema rejects int vs float, so a float operand implies both are floats.
#   - same signedness: widen the narrower side per that signedness, compare as
#     it (pointers fall here: unsigned, equal width).
#   - mixed signedness with the unsigned operand narrower than 64 bits: it fits
#     positive in i64, so widen each per its own signedness to 64 bits and
#     compare signed.
#   - the irreducible i64/u64 pair: no common wider integer, so emit a sign-test
#     on the signed operand plus an unsigned compare (a negative signed value is
#     less than every u64 and equal to none).
# ---
# ctx: per-module lowering context
# op:  the comparison operator
# lhs: the lowered left operand
# lty: the left operand's semantic type
# rhs: the lowered right operand
# rty: the right operand's semantic type
# ret: the u8 comparison result, or an error
fun lower_cmp(ctx: *context.LowerContext, op: expr.BinOp, lhs: value.Value, lty: type.TypeId, rhs: value.Value, rty: type.TypeId) R.Result[value.Value, str] {
    if (is_float_type(ctx, lty) || is_float_type(ctx, rty)) {
        var fl: value.Value = lhs;
        var fr: value.Value = rhs;
        val res_unify: R.Result[bool, str] = unify_float_compare_widths(ctx, ?fl, lty, ?fr, rty);
        if (R.is_err[bool, str](res_unify)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_unify)); }
        ret emit_cmp_int(ctx, op, false, fl, fr);
    }

    val ls: bool = is_signed_type(ctx, lty);
    val rs: bool = is_signed_type(ctx, rty);

    if (ls == rs) {
        var sl: value.Value = lhs;
        var sr: value.Value = rhs;
        val res_unify: R.Result[bool, str] = unify_int_compare_widths(ctx, ?sl, lty, ?sr, rty);
        if (R.is_err[bool, str](res_unify)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_unify)); }
        ret emit_cmp_int(ctx, op, ls, sl, sr);
    }

    # mixed signedness: name the signed and unsigned operand, keeping track of
    # which one was the left-hand side so the operator stays oriented.
    var s_val:    value.Value = lhs;
    var s_ty:     type.TypeId = lty;
    var u_val:    value.Value = rhs;
    var u_ty:     type.TypeId = rty;
    var s_is_lhs: bool        = true;
    if (!ls) {
        s_val    = rhs;
        s_ty     = rty;
        u_val    = lhs;
        u_ty     = lty;
        s_is_lhs = false;
    }

    val res_i64: R.Result[ir_type.IrTypeId, str] = ir_type.intern_int(?ctx.m.types, 64);
    if (R.is_err[ir_type.IrTypeId, str](res_i64)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_i64)); }
    val ty64: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_i64);

    val res_s64: R.Result[value.Value, str] = widen_signed_to_i64(ctx, s_val, s_ty, ty64);
    if (R.is_err[value.Value, str](res_s64)) { ret res_s64; }
    val s64: value.Value = R.unwrap_ok[value.Value, str](res_s64);

    if (scalar_bits(ctx, u_ty) < 64) {
        # reducible: the unsigned operand zero-extends to a positive i64, so a
        # signed 64-bit compare in the original operand order is value-correct.
        val res_u64: R.Result[value.Value, str] = builder.emit_zext(?ctx.builder, u_val, ty64);
        if (R.is_err[value.Value, str](res_u64)) { ret res_u64; }
        val u64v: value.Value = R.unwrap_ok[value.Value, str](res_u64);
        if (s_is_lhs) { ret emit_cmp_int(ctx, op, true, s64, u64v); }
        ret emit_cmp_int(ctx, op, true, u64v, s64);
    }

    ret lower_cmp_signed_u64(ctx, op, s64, u_val, s_is_lhs, ty64);
}

# emit an integer (or, with `signed` false, float-or-unsigned) comparison
#
# Operands are already unified to a single width. `>` and `>=` reuse `<` / `<=`
# with the operands swapped.
# ---
# ctx:    per-module lowering context
# op:     the comparison operator
# signed: true for a signed integer compare
# lhs:    the left operand
# rhs:    the right operand
# ret:    the comparison result Value, or an error
fun emit_cmp_int(ctx: *context.LowerContext, op: expr.BinOp, signed: bool, lhs: value.Value, rhs: value.Value) R.Result[value.Value, str] {
    if (op == expr.BIN_EQ)  { ret builder.emit_cmp_eq(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_NEQ) { ret builder.emit_cmp_ne(?ctx.builder, lhs, rhs); }
    if (op == expr.BIN_LT) {
        if (signed) { ret builder.emit_cmp_lt_s(?ctx.builder, lhs, rhs); }
        ret builder.emit_cmp_lt_u(?ctx.builder, lhs, rhs);
    }
    if (op == expr.BIN_LEQ) {
        if (signed) { ret builder.emit_cmp_le_s(?ctx.builder, lhs, rhs); }
        ret builder.emit_cmp_le_u(?ctx.builder, lhs, rhs);
    }
    if (op == expr.BIN_GT) {
        if (signed) { ret builder.emit_cmp_lt_s(?ctx.builder, rhs, lhs); }
        ret builder.emit_cmp_lt_u(?ctx.builder, rhs, lhs);
    }
    if (op == expr.BIN_GEQ) {
        if (signed) { ret builder.emit_cmp_le_s(?ctx.builder, rhs, lhs); }
        ret builder.emit_cmp_le_u(?ctx.builder, rhs, lhs);
    }
    ret R.err[value.Value, str]("lower: unsupported comparison operator");
}

# sign-extend a signed integer value to 64 bits
#
# Returns it unchanged when it is already 64-bit wide.
# ---
# ctx:  per-module lowering context
# v:    the value to widen
# vty:  the value's semantic type
# ty64: the i64 IR type
# ret:  the widened (or unchanged) value, or an error
fun widen_signed_to_i64(ctx: *context.LowerContext, v: value.Value, vty: type.TypeId, ty64: ir_type.IrTypeId) R.Result[value.Value, str] {
    if (scalar_bits(ctx, vty) >= 64) { ret R.ok[value.Value, str](v); }
    ret builder.emit_sext(?ctx.builder, v, ty64);
}

# lower the irreducible i64/u64 comparison
#
# `s64` is the signed operand widened to 64 bits, `u` the u64 operand, and
# `s_is_lhs` records whether the signed operand was the left-hand side (so the
# operator can be re-oriented to `s op u` form). A negative signed value is below
# every u64; a non-negative one compares bit-identically as unsigned. Composition
# is branch-free: every input is a 0/1 setcc result, so `||` is a bitwise OR and
# `&&` a bitwise AND.
# ---
# ctx:      per-module lowering context
# op:       the comparison operator
# s64:      the signed operand widened to 64 bits
# u:        the u64 operand
# s_is_lhs: true when the signed operand was the left-hand side
# ty64:     the i64 IR type
# ret:      the comparison result Value, or an error
fun lower_cmp_signed_u64(ctx: *context.LowerContext, op: expr.BinOp, s64: value.Value, u: value.Value, s_is_lhs: bool, ty64: ir_type.IrTypeId) R.Result[value.Value, str] {
    var nop: expr.BinOp = op;
    if (!s_is_lhs) { nop = swap_cmp_op(op); }
    val zero: value.Value = value.const_int(0, ty64);

    if (nop == expr.BIN_LT) {
        # s < u  ==  s < 0 || s::u64 < u
        ret cmp_or(ctx, builder.emit_cmp_lt_s(?ctx.builder, s64, zero),
                        builder.emit_cmp_lt_u(?ctx.builder, s64, u));
    }
    if (nop == expr.BIN_LEQ) {
        # s <= u  ==  s < 0 || s::u64 <= u
        ret cmp_or(ctx, builder.emit_cmp_lt_s(?ctx.builder, s64, zero),
                        builder.emit_cmp_le_u(?ctx.builder, s64, u));
    }
    if (nop == expr.BIN_GT) {
        # s > u  ==  s >= 0 && u < s::u64
        ret cmp_and(ctx, builder.emit_cmp_le_s(?ctx.builder, zero, s64),
                         builder.emit_cmp_lt_u(?ctx.builder, u, s64));
    }
    if (nop == expr.BIN_GEQ) {
        # s >= u  ==  s >= 0 && u <= s::u64
        ret cmp_and(ctx, builder.emit_cmp_le_s(?ctx.builder, zero, s64),
                         builder.emit_cmp_le_u(?ctx.builder, u, s64));
    }
    if (nop == expr.BIN_EQ) {
        # s == u  ==  s >= 0 && s::u64 == u
        ret cmp_and(ctx, builder.emit_cmp_le_s(?ctx.builder, zero, s64),
                         builder.emit_cmp_eq(?ctx.builder, s64, u));
    }
    if (nop == expr.BIN_NEQ) {
        # s != u  ==  s < 0 || s::u64 != u
        ret cmp_or(ctx, builder.emit_cmp_lt_s(?ctx.builder, s64, zero),
                        builder.emit_cmp_ne(?ctx.builder, s64, u));
    }
    ret R.err[value.Value, str]("lower: unsupported comparison operator");
}

# the operator that compares the same pair with the operands swapped
#
# `<`<->`>`, `<=`<->`>=`; equality and inequality are symmetric.
# ---
# op:  the comparison operator
# ret: the swapped operator
fun swap_cmp_op(op: expr.BinOp) expr.BinOp {
    if (op == expr.BIN_LT)  { ret expr.BIN_GT; }
    if (op == expr.BIN_LEQ) { ret expr.BIN_GEQ; }
    if (op == expr.BIN_GT)  { ret expr.BIN_LT; }
    if (op == expr.BIN_GEQ) { ret expr.BIN_LEQ; }
    ret op;
}

# bitwise-OR two 0/1 comparison results, short-circuiting on either error
# ---
# ctx: per-module lowering context
# a:   the first comparison result
# b:   the second comparison result
# ret: the OR of both results, or the first error
fun cmp_or(ctx: *context.LowerContext, a: R.Result[value.Value, str], b: R.Result[value.Value, str]) R.Result[value.Value, str] {
    if (R.is_err[value.Value, str](a)) { ret a; }
    if (R.is_err[value.Value, str](b)) { ret b; }
    ret builder.emit_or(?ctx.builder, R.unwrap_ok[value.Value, str](a), R.unwrap_ok[value.Value, str](b));
}

# bitwise-AND two 0/1 comparison results, short-circuiting on either error
# ---
# ctx: per-module lowering context
# a:   the first comparison result
# b:   the second comparison result
# ret: the AND of both results, or the first error
fun cmp_and(ctx: *context.LowerContext, a: R.Result[value.Value, str], b: R.Result[value.Value, str]) R.Result[value.Value, str] {
    if (R.is_err[value.Value, str](a)) { ret a; }
    if (R.is_err[value.Value, str](b)) { ret b; }
    ret builder.emit_and(?ctx.builder, R.unwrap_ok[value.Value, str](a), R.unwrap_ok[value.Value, str](b));
}

# widen the narrower operand of a mixed-width float comparison, in place
#
# Widens up to the wider operand's precision via an exact float extension.
# Equal-width pairs are left untouched.
# ---
# ctx: per-module lowering context
# lhs: pointer to the left operand, widened in place when it is narrower
# lty: the left operand's semantic type
# rhs: pointer to the right operand, widened in place when it is narrower
# rty: the right operand's semantic type
# ret: true on success, or an error
fun unify_float_compare_widths(ctx: *context.LowerContext, lhs: *value.Value, lty: type.TypeId, rhs: *value.Value, rty: type.TypeId) R.Result[bool, str] {
    val lw: u32 = scalar_bits(ctx, lty);
    val rw: u32 = scalar_bits(ctx, rty);
    if (lw == rw) { ret R.ok[bool, str](true); }
    if (lw < rw) {
        val res_ext: R.Result[value.Value, str] = builder.emit_fp_ext(?ctx.builder, @lhs, rhs.ty);
        if (R.is_err[value.Value, str](res_ext)) { ret R.err[bool, str](R.unwrap_err[value.Value, str](res_ext)); }
        @lhs = R.unwrap_ok[value.Value, str](res_ext);
        ret R.ok[bool, str](true);
    }
    val res_ext: R.Result[value.Value, str] = builder.emit_fp_ext(?ctx.builder, @rhs, lhs.ty);
    if (R.is_err[value.Value, str](res_ext)) { ret R.err[bool, str](R.unwrap_err[value.Value, str](res_ext)); }
    @rhs = R.unwrap_ok[value.Value, str](res_ext);
    ret R.ok[bool, str](true);
}

# widen the narrower operand of a same-signedness integer comparison, in place
#
# Extends up to the wider operand's bit width so the back end's single-width CMP
# reads two correctly-extended values. A signed narrower operand is sign-extended,
# an unsigned one zero-extended (the IR type carries no signedness, so this choice
# must be made here from the semantic types). Equal-width / non-scalar pairs are
# left untouched. The narrower operand takes on the wider operand's own IR type,
# the width the back end already sizes the CMP from.
# ---
# ctx: per-module lowering context
# lhs: pointer to the left operand, extended in place when it is narrower
# lty: the left operand's semantic type
# rhs: pointer to the right operand, extended in place when it is narrower
# rty: the right operand's semantic type
# ret: true on success, or an error
fun unify_int_compare_widths(ctx: *context.LowerContext, lhs: *value.Value, lty: type.TypeId, rhs: *value.Value, rty: type.TypeId) R.Result[bool, str] {
    val lw: u32 = scalar_bits(ctx, lty);
    val rw: u32 = scalar_bits(ctx, rty);
    if (lw == 0 || rw == 0 || lw == rw) { ret R.ok[bool, str](true); }
    if (lw < rw) {
        val res_ext: R.Result[value.Value, str] = extend_int_value(ctx, @lhs, lty, rhs.ty);
        if (R.is_err[value.Value, str](res_ext)) { ret R.err[bool, str](R.unwrap_err[value.Value, str](res_ext)); }
        @lhs = R.unwrap_ok[value.Value, str](res_ext);
        ret R.ok[bool, str](true);
    }
    val res_ext: R.Result[value.Value, str] = extend_int_value(ctx, @rhs, rty, lhs.ty);
    if (R.is_err[value.Value, str](res_ext)) { ret R.err[bool, str](R.unwrap_err[value.Value, str](res_ext)); }
    @rhs = R.unwrap_ok[value.Value, str](res_ext);
    ret R.ok[bool, str](true);
}

# extend an integer value to a wider IR type
#
# Sign-extends when the value's semantic type `from` is signed, zero-extends
# otherwise.
# ---
# ctx:  per-module lowering context
# v:    the value to extend
# from: the value's semantic type
# to:   the wider target IR type
# ret:  the extended value, or an error
fun extend_int_value(ctx: *context.LowerContext, v: value.Value, from: type.TypeId, to: ir_type.IrTypeId) R.Result[value.Value, str] {
    if (is_signed_type(ctx, from)) { ret builder.emit_sext(?ctx.builder, v, to); }
    ret builder.emit_zext(?ctx.builder, v, to);
}

# lower an assignment `lhs = rhs`
#
# Evaluate the RHS, store it through the LHS lvalue, and yield the stored value
# as the result.
# ---
# ctx: per-module lowering context
# e:   the resolved assignment node
# ret: the stored value, or an error
fun lower_assign(ctx: *context.LowerContext, e: *expr.Expr) R.Result[value.Value, str] {
    val res_rhs: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.binary.rhs);
    if (R.is_err[value.Value, str](res_rhs)) { ret res_rhs; }
    val rhs: value.Value = R.unwrap_ok[value.Value, str](res_rhs);

    val res_lhs: R.Result[value.Value, str] = lower_lvalue(ctx, e.data.binary.lhs);
    if (R.is_err[value.Value, str](res_lhs)) { ret res_lhs; }
    val ptr: value.Value = R.unwrap_ok[value.Value, str](res_lhs);

    val res_store: R.Result[bool, str] = builder.emit_store(?ctx.builder, rhs, ptr);
    if (R.is_err[bool, str](res_store)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_store)); }
    ret R.ok[value.Value, str](rhs);
}

# lower a short-circuiting `&&` / `||`
#
# lhs is evaluated; for `&&` rhs runs only when lhs is nonzero, for `||` only when
# lhs is zero. The result is materialised through a tiny alloca slot store / load
# that mem2reg turns into a phi, so lowering itself emits no phis.
# ---
# ctx: per-module lowering context
# e:   the resolved logical-binary node
# ret: the u8 short-circuit result, or an error
fun lower_logical(ctx: *context.LowerContext, e: *expr.Expr) R.Result[value.Value, str] {
    val res_i8: R.Result[ir_type.IrTypeId, str] = ir_type.intern_int(?ctx.m.types, 8);
    if (R.is_err[ir_type.IrTypeId, str](res_i8)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_i8)); }
    val i8: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_i8);

    val res_xty: R.Result[ir_type.IrTypeId, str] = index_type(ctx);
    if (R.is_err[ir_type.IrTypeId, str](res_xty)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_xty)); }
    val xty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_xty);

    val res_slot: R.Result[value.Value, str] = builder.emit_alloca(?ctx.builder, i8, value.const_int(1, xty));
    if (R.is_err[value.Value, str](res_slot)) { ret res_slot; }
    val slot: value.Value = R.unwrap_ok[value.Value, str](res_slot);

    val res_lhs: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.binary.lhs);
    if (R.is_err[value.Value, str](res_lhs)) { ret res_lhs; }
    val lhs: value.Value = R.unwrap_ok[value.Value, str](res_lhs);
    val res_store_lhs: R.Result[bool, str] = builder.emit_store(?ctx.builder, lhs, slot);
    if (R.is_err[bool, str](res_store_lhs)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_store_lhs)); }

    val res_rhs_block: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_rhs_block)) { ret R.err[value.Value, str](R.unwrap_err[ir.BlockId, str](res_rhs_block)); }
    val rhs_block: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_rhs_block);

    val res_join: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_join)) { ret R.err[value.Value, str](R.unwrap_err[ir.BlockId, str](res_join)); }
    val join: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_join);

    # `&&` takes the rhs block only when lhs is nonzero; `||` only when lhs is zero.
    var res_cbr: R.Result[bool, str] = R.ok[bool, str](true);
    if (e.data.binary.op == expr.BIN_AND) {
        res_cbr = builder.emit_cbr(?ctx.builder, lhs, rhs_block, join);
    } or {
        res_cbr = builder.emit_cbr(?ctx.builder, lhs, join, rhs_block);
    }
    if (R.is_err[bool, str](res_cbr)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_cbr)); }

    builder.set_block(?ctx.builder, rhs_block);
    val res_rhs: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.binary.rhs);
    if (R.is_err[value.Value, str](res_rhs)) { ret res_rhs; }
    val res_store_rhs: R.Result[bool, str] = builder.emit_store(?ctx.builder, R.unwrap_ok[value.Value, str](res_rhs), slot);
    if (R.is_err[bool, str](res_store_rhs)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_store_rhs)); }
    val res_br: R.Result[bool, str] = builder.emit_br(?ctx.builder, join);
    if (R.is_err[bool, str](res_br)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_br)); }

    builder.set_block(?ctx.builder, join);
    ret builder.emit_load(?ctx.builder, slot, i8);
}

# lower a unary expression
#
# `?x` is the lvalue of x; `@p` derefs a pointer (yielding the pointer itself for
# an aggregate, see rvalue_at); the remaining operators map to one negate / bitwise-
# not / logical-not instruction.
# ---
# ctx: per-module lowering context
# eid: the unary expression
# e:   the resolved unary node
# ret: the operator's result Value, or an error
fun lower_unary(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val op: expr.UnOp = e.data.unary.op;

    if (op == expr.UN_ADDR) {
        ret lower_lvalue(ctx, e.data.unary.operand);
    }
    if (op == expr.UN_DEREF) {
        # `@p` of aggregate type yields the pointer itself (an aggregate rvalue is
        # its storage address); rvalue_at retypes it so the back end copies by value
        # instead of storing only the 8-byte pointer.
        val res_ptr: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.unary.operand);
        if (R.is_err[value.Value, str](res_ptr)) { ret res_ptr; }
        val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
        if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
        ret rvalue_at(ctx, R.unwrap_ok[value.Value, str](res_ptr), R.unwrap_ok[ir_type.IrTypeId, str](res_ir));
    }

    val res_v: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.unary.operand);
    if (R.is_err[value.Value, str](res_v)) { ret res_v; }
    val v: value.Value = R.unwrap_ok[value.Value, str](res_v);

    if (op == expr.UN_NEG)     { ret builder.emit_neg(?ctx.builder, v); }
    if (op == expr.UN_BIT_NOT) { ret builder.emit_not(?ctx.builder, v); }
    if (op == expr.UN_NOT) {
        # logical not: x == 0
        ret builder.emit_cmp_eq(?ctx.builder, v, value.const_int(0, v.ty));
    }

    ret R.err[value.Value, str]("lower: unsupported unary operator");
}

# lower a cast
#
# A `::` value-convert selects a single conversion instruction from the source /
# target type pair (trunc/ext for integers, fp trunc/ext for floats, int<->float
# CVT). When source and target share a width, the operand's bit pattern already
# represents the target type (a same-type identity, a signedness flip like
# i64::u64, or a pointer retype), so it emits a same-size bitcast. A `:~`
# bit-reinterpret (sema-validated equal size) always emits a same-size bitcast
# that reinterprets the operand's raw bits as the target type, regardless of int /
# float category.
# ---
# ctx: per-module lowering context
# eid: the cast expression
# e:   the resolved cast node
# ret: the converted Value, or an error
fun lower_cast(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val res_v: R.Result[value.Value, str] = lower_rvalue(ctx, e.data.cast.value);
    if (R.is_err[value.Value, str](res_v)) { ret res_v; }
    val v: value.Value = R.unwrap_ok[value.Value, str](res_v);

    val from_ty: type.TypeId = context.expr_type_of(ctx, e.data.cast.value);
    val to_ty:   type.TypeId = context.type_resolved_of(ctx, e.data.cast.ty);

    val res_dst: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, to_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_dst)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_dst)); }
    val dst: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_dst);

    if (e.data.cast.reinterpret) { ret builder.emit_bitcast(?ctx.builder, v, dst); }

    val from_float:  bool = is_float_type(ctx, from_ty);
    val to_float:    bool = is_float_type(ctx, to_ty);
    val from_signed: bool = is_signed_type(ctx, from_ty);
    val to_signed:   bool = is_signed_type(ctx, to_ty);
    val from_bits:   u32  = scalar_bits(ctx, from_ty);
    val to_bits:     u32  = scalar_bits(ctx, to_ty);

    if (from_float && to_float) {
        if (to_bits < from_bits) { ret builder.emit_fp_trunc(?ctx.builder, v, dst); }
        if (to_bits > from_bits) { ret builder.emit_fp_ext(?ctx.builder, v, dst); }
        ret builder.emit_bitcast(?ctx.builder, v, dst);
    }
    if (from_float && !to_float) {
        if (to_signed) { ret builder.emit_fp_to_si(?ctx.builder, v, dst); }
        ret builder.emit_fp_to_ui(?ctx.builder, v, dst);
    }
    if (!from_float && to_float) {
        if (from_signed) { ret builder.emit_si_to_fp(?ctx.builder, v, dst); }
        ret builder.emit_ui_to_fp(?ctx.builder, v, dst);
    }

    if (to_bits < from_bits) { ret builder.emit_trunc(?ctx.builder, v, dst); }
    if (to_bits > from_bits) {
        if (from_signed) { ret builder.emit_sext(?ctx.builder, v, dst); }
        ret builder.emit_zext(?ctx.builder, v, dst);
    }
    ret builder.emit_bitcast(?ctx.builder, v, dst);
}

# lower a `:^` secret-qualifier strip cast to the value it wraps (#1645)
#
# `:^` removes secrecy without reinterpreting storage: secrecy has no runtime
# representation (a `^T` shares `T`'s machine shape), so stripping is a pure
# value passthrough. sema already proved the operand's stripped type matches the
# result, so no conversion is emitted.
# ---
# ctx: per-module lowering context
# e:   the resolved strip node
# ret: the operand's lowered Value, or an error
fun lower_strip(ctx: *context.LowerContext, e: *expr.Expr) R.Result[value.Value, str] {
    ret lower_rvalue(ctx, e.data.strip.value);
}

# fold a value-context comptime path to its constant value
#
# Handles `$mach.build.os`, `$mach.os.linux`, `$project.version`, ... via the
# comptime evaluator and materializes the result at the expression's IR type. Used
# for rooted comptime member chains in rvalue position, whose semantic type was set
# to the usage-site type during coercion. A standalone bare `$ident` also routes
# here: eval rejects it with the single teaching diagnostic (#1249), so lowering
# carries no separate resolution rule of its own.
# ---
# ctx: per-module lowering context
# eid: the comptime-path expression
# ret: the materialized constant Value, or an error
fun lower_comptime_path(ctx: *context.LowerContext, eid: id.ExprId) R.Result[value.Value, str] {
    val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(ctx.ctx, ctx.a, context.module_source(ctx), eid, ?ctx.s.interner);
    if (R.is_err[comptime.CTValue, str](res_eval)) { ret R.err[value.Value, str](R.unwrap_err[comptime.CTValue, str](res_eval)); }
    ret const_value_of(ctx, eid, R.unwrap_ok[comptime.CTValue, str](res_eval));
}

# lower an array literal into an alloca plus a per-element store through a gep
#
# The alloca slot pointer is the literal's value (an array rvalue is its storage
# address; loads happen at use sites).
# ---
# ctx: per-module lowering context
# eid: the array-literal expression (supplies the array type)
# e:   the resolved array-literal node
# ret: the array's storage address (retyped to the array), or an error
fun lower_array_lit(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val arr_ty: type.TypeId = context.expr_type_of(ctx, eid);
    val res_arr_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, arr_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_arr_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_arr_ir)); }
    val arr_ir: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_arr_ir);

    val res_xty: R.Result[ir_type.IrTypeId, str] = index_type(ctx);
    if (R.is_err[ir_type.IrTypeId, str](res_xty)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_xty)); }
    val xty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_xty);

    val res_slot: R.Result[value.Value, str] = builder.emit_alloca(?ctx.builder, arr_ir, value.const_int(1, xty));
    if (R.is_err[value.Value, str](res_slot)) { ret res_slot; }
    val slot: value.Value = R.unwrap_ok[value.Value, str](res_slot);

    var i: u32 = 0;
    for (i < e.data.array_lit.elems_len) {
        val pool_ix: u32 = e.data.array_lit.elems_start + i;
        if (pool_ix::usize >= ctx.a.expr_id_len) {
            ret R.err[value.Value, str]("lower: array literal element index out of range");
        }
        val elem_eid: id.ExprId = ctx.a.expr_ids[pool_ix];
        val res_elem: R.Result[value.Value, str] = lower_rvalue(ctx, elem_eid);
        if (R.is_err[value.Value, str](res_elem)) { ret res_elem; }

        var idx: [2]value.Value;
        idx[0] = value.const_int(0, xty);
        idx[1] = value.const_int(i::u64, xty);
        val res_gep: R.Result[value.Value, str] = builder.emit_gep(?ctx.builder, slot, arr_ir, ?idx[0], 2);
        if (R.is_err[value.Value, str](res_gep)) { ret res_gep; }
        val res_store: R.Result[bool, str] = builder.emit_store(?ctx.builder, R.unwrap_ok[value.Value, str](res_elem), R.unwrap_ok[value.Value, str](res_gep));
        if (R.is_err[bool, str](res_store)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_store)); }
        i = i + 1;
    }

    # the literal's value IS its storage; retype the slot to the array type so the
    # back end treats it as an aggregate, not a scalar pointer.
    ret R.ok[value.Value, str](value.retype(slot, arr_ir));
}

# lower a struct literal into an alloca plus a per-field store through a gep
#
# The alloca slot pointer is the literal's value (a struct rvalue is its storage
# address).
# ---
# ctx: per-module lowering context
# eid: the struct-literal expression (supplies the record type)
# e:   the resolved struct-literal node
# ret: the record's storage address (retyped to the record), or an error
fun lower_struct_lit(ctx: *context.LowerContext, eid: id.ExprId, e: *expr.Expr) R.Result[value.Value, str] {
    val rec_ty: type.TypeId = context.expr_type_of(ctx, eid);
    val res_rec_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, rec_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_rec_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_rec_ir)); }
    val rec_ir: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_rec_ir);

    val res_xty: R.Result[ir_type.IrTypeId, str] = index_type(ctx);
    if (R.is_err[ir_type.IrTypeId, str](res_xty)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_xty)); }
    val xty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_xty);

    val res_slot: R.Result[value.Value, str] = builder.emit_alloca(?ctx.builder, rec_ir, value.const_int(1, xty));
    if (R.is_err[value.Value, str](res_slot)) { ret res_slot; }
    val slot: value.Value = R.unwrap_ok[value.Value, str](res_slot);

    var i: u32 = 0;
    for (i < e.data.struct_lit.fields_len) {
        val pool_ix: u32 = e.data.struct_lit.fields_start + i;
        if (pool_ix::usize >= ctx.a.field_init_len) {
            ret R.err[value.Value, str]("lower: struct literal field index out of range");
        }
        val fi: *expr.FieldInit = ?ctx.a.field_inits[pool_ix];
        val field_ix: u32 = field_index_in_type(ctx, rec_ty, fi.name);
        val res_field: R.Result[value.Value, str] = lower_rvalue(ctx, fi.value);
        if (R.is_err[value.Value, str](res_field)) { ret res_field; }

        var idx: [2]value.Value;
        idx[0] = value.const_int(0, xty);
        idx[1] = value.const_int(field_ix::u64, xty);
        val res_gep: R.Result[value.Value, str] = builder.emit_gep(?ctx.builder, slot, rec_ir, ?idx[0], 2);
        if (R.is_err[value.Value, str](res_gep)) { ret res_gep; }
        val res_store: R.Result[bool, str] = builder.emit_store(?ctx.builder, R.unwrap_ok[value.Value, str](res_field), R.unwrap_ok[value.Value, str](res_gep));
        if (R.is_err[bool, str](res_store)) { ret R.err[value.Value, str](R.unwrap_err[bool, str](res_store)); }
        i = i + 1;
    }

    # the literal's value IS its storage; retype the slot pointer to the record so
    # the back end treats it as an aggregate (copied by value / passed by the
    # one-or-two-register or by-reference rules) rather than a scalar pointer.
    ret R.ok[value.Value, str](value.retype(slot, rec_ir));
}

# materialise a comptime CTValue as an IR constant Value in expression position
#
# A folded CT_KIND_STR is committed to an anonymous `.rodata` global and the Value
# is a pointer to it, exactly as lower_lit_str routes a string literal; a raw byte
# blob must never reach the back end as an operand. Used by COMPTIME_IDENT /
# comptime-path lowering, the imported-const fallback, and comptime
# value-parameter references.
# ---
# ctx: per-module lowering context
# eid: the expression whose IR type the constant takes
# v:   the folded comptime value
# ret: the corresponding constant Value, or an error
pub fun const_value_of(ctx: *context.LowerContext, eid: id.ExprId, v: comptime.CTValue) R.Result[value.Value, str] {
    ret materialize_const_value(ctx, eid, v, true);
}

# the global-initialiser counterpart of const_value_of
#
# A folded CT_KIND_STR is returned as the raw VAL_CONST_BYTES blob the global-init
# emission lays out as initialised data in place, rather than committed to a
# separate rodata global and referenced by pointer. Every other value kind is
# identical.
# ---
# ctx: per-module lowering context
# eid: the initialiser expression whose IR type the constant takes
# v:   the folded comptime value
# ret: the corresponding constant Value, or an error
pub fun const_value_of_init(ctx: *context.LowerContext, eid: id.ExprId, v: comptime.CTValue) R.Result[value.Value, str] {
    ret materialize_const_value(ctx, eid, v, false);
}

# materialise a comptime CTValue as an IR constant Value at the expression's IR type
#
# `expr_pos` selects how a CT_KIND_STR is realised: an expression-position string
# constant becomes a rodata global plus a pointer to it (a raw blob must never
# become an operand), while a global initialiser keeps the raw blob for in-place
# data emission. The int / bool / float kinds are position-independent.
# ---
# ctx:      per-module lowering context
# eid:      the expression whose IR type the constant takes
# v:        the folded comptime value
# expr_pos: true for expression position, false for a global initialiser
# ret:      the corresponding constant Value, or an error
fun materialize_const_value(ctx: *context.LowerContext, eid: id.ExprId, v: comptime.CTValue, expr_pos: bool) R.Result[value.Value, str] {
    val res_ir: R.Result[ir_type.IrTypeId, str] = ir_type_of_expr(ctx, eid);
    if (R.is_err[ir_type.IrTypeId, str](res_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ir)); }
    val ty_id: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_ir);

    if (v.kind == comptime.CT_KIND_INT) { ret R.ok[value.Value, str](value.const_int(v.data.i::u64, ty_id)); }
    if (v.kind == comptime.CT_KIND_BOOL) {
        var b: u64 = 0;
        if (v.data.b) { b = 1; }
        ret R.ok[value.Value, str](value.const_int(b, ty_id));
    }
    if (v.kind == comptime.CT_KIND_FLOAT) { ret R.ok[value.Value, str](value.const_float(v.data.f, ty_id)); }
    if (v.kind == comptime.CT_KIND_STR) {
        val opt_txt: O.Option[str] = intern.lookup(?ctx.s.interner, v.data.s);
        if (O.is_none[str](opt_txt)) { ret R.err[value.Value, str]("lower: comptime string lookup failed"); }
        val s: str = O.unwrap[str](opt_txt);
        # include the trailing '\0' so the emitted blob is a valid null-terminated
        # `str` rather than relying on section padding (see lower_lit_str).
        val blob: value.Value = value.const_bytes(s::*u8, (str_len(s) + 1::usize)::u32, ty_id);
        if (expr_pos) { ret context.add_rodata_bytes(ctx, blob, ty_id); }
        ret R.ok[value.Value, str](blob);
    }
    ret R.err[value.Value, str]("lower: unsupported comptime value kind");
}

# the rvalue denoted by a storage pointer
#
# An aggregate is left as its address, retyped to the aggregate IR type so a copy
# of it emits a sized memcpy (the back end consumes the address for two-register /
# by-reference argument passing and aggregate returns); a scalar is loaded. This
# is the single place the load-vs-address decision is made for locals, members,
# projections, index elements, pack slots, and dereferences.
# ---
# ctx: per-module lowering context
# ptr: the storage pointer
# ity: the IR type of the value the storage holds
# ret: the loaded scalar, the retyped aggregate address, or an error
fun rvalue_at(ctx: *context.LowerContext, ptr: value.Value, ity: ir_type.IrTypeId) R.Result[value.Value, str] {
    if (is_aggregate_ir(ctx, ity)) { ret R.ok[value.Value, str](value.retype(ptr, ity)); }
    ret builder.emit_load(?ctx.builder, ptr, ity);
}

# the storage pointer Value of a module global by index
# ---
# ctx:     per-module lowering context
# global_ix: the global's module index
# ret:     a `ptr`-typed global Value, or an error
fun global_pointer(ctx: *context.LowerContext, global_ix: u32) R.Result[value.Value, str] {
    val res_ptr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?ctx.m.types);
    if (R.is_err[ir_type.IrTypeId, str](res_ptr)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_ptr)); }
    ret R.ok[value.Value, str](value.global(global_ix, R.unwrap_ok[ir_type.IrTypeId, str](res_ptr)));
}

# the rvalue of a module global: a load, or the storage address for an aggregate
#
# An aggregate global's rvalue is its `ptr`-typed storage address (the back end
# loads halves / passes the pointer at use sites); a scalar global is loaded at
# its value type.
# ---
# ctx:       per-module lowering context
# global_ix: the global's module index
# vty:       the global's value IR type
# ret:       the global's rvalue, or an error
fun emit_global_rvalue(ctx: *context.LowerContext, global_ix: u32, vty: ir_type.IrTypeId) R.Result[value.Value, str] {
    val res_gptr: R.Result[value.Value, str] = global_pointer(ctx, global_ix);
    if (R.is_err[value.Value, str](res_gptr)) { ret res_gptr; }
    val gptr: value.Value = R.unwrap_ok[value.Value, str](res_gptr);
    # an aggregate global's rvalue is its storage address retyped to the aggregate
    # IR type (mirroring rvalue_at): a copy / by-value argument of it then classifies
    # as a sized aggregate rather than a scalar pointer move.
    if (is_aggregate_ir(ctx, vty)) { ret R.ok[value.Value, str](value.retype(gptr, vty)); }
    ret builder.emit_load(?ctx.builder, gptr, vty);
}

# resolve a linkage name to a function-reference Value
#
# A module-local function resolves to its module index; otherwise a signature-only
# extern declaration is created so the back end emits a name-based call relocation
# the linker binds to the defining object.
# ---
# ctx:  per-module lowering context
# link: the function's linkage name
# vty:  the function-reference IR type
# ret:  a VAL_FN Value, or an error
fun fn_reference(ctx: *context.LowerContext, link: intern.StrId, vty: ir_type.IrTypeId) R.Result[value.Value, str] {
    val opt_fi: O.Option[u32] = find_function(ctx, link);
    if (O.is_some[u32](opt_fi)) {
        ret R.ok[value.Value, str](value.fn(O.unwrap[u32](opt_fi), vty));
    }
    val res_xfn: R.Result[u32, str] = context.ensure_extern_function(ctx, link, vty);
    if (R.is_err[u32, str](res_xfn)) { ret R.err[value.Value, str](R.unwrap_err[u32, str](res_xfn)); }
    ret R.ok[value.Value, str](value.fn(R.unwrap_ok[u32, str](res_xfn), vty));
}

# resolve a member / projection receiver to its base pointer and record the record
# type the field belongs to
#
# A pointer receiver auto-derefs (base = the pointer rvalue, record = pointee); a
# value receiver uses its own storage (base = its lvalue, record = its type),
# mirroring the array / pointer split in lower_index_lvalue. The record type is
# written through `out_rec_ty`.
# ---
# ctx:             per-module lowering context
# eid:             the member / projection expression (for a located diagnostic)
# obj_eid:         the receiver expression
# untyped_ptr_msg: diagnostic when the receiver is an untyped `ptr`
# out_rec_ty:      written with the record type the field is resolved against
# ret:             the base pointer Value, or an error
fun member_receiver(ctx: *context.LowerContext, eid: id.ExprId, obj_eid: id.ExprId, untyped_ptr_msg: str, out_rec_ty: *type.TypeId) R.Result[value.Value, str] {
    val obj_ty: type.TypeId = context.expr_type_of(ctx, obj_eid);
    if (is_pointer_type(ctx, obj_ty)) {
        val opt_pt: O.Option[*type.Type] = type.get(?ctx.s.types, obj_ty);
        if (O.is_none[*type.Type](opt_pt)) { ret R.err[value.Value, str]("lower: receiver base has no pointer type"); }
        val pt: *type.Type = O.unwrap[*type.Type](opt_pt);
        if (pt.kind != type.TYPE_POINTER) {
            ret report_expr(ctx, eid, untyped_ptr_msg);
        }
        @out_rec_ty = pt.data.pointer.base;
        ret lower_rvalue(ctx, obj_eid);
    }
    @out_rec_ty = obj_ty;
    ret lower_lvalue(ctx, obj_eid);
}

# compute a field pointer: gep [0, field_ix] against `base` with source `rec_ty`
# ---
# ctx:      per-module lowering context
# base:     pointer at the record's storage
# rec_ty:   the record semantic type (the gep source)
# field_ix: the field ordinal
# ret:      the field pointer Value, or an error
fun field_gep(ctx: *context.LowerContext, base: value.Value, rec_ty: type.TypeId, field_ix: u32) R.Result[value.Value, str] {
    val res_rec_ir: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, rec_ty);
    if (R.is_err[ir_type.IrTypeId, str](res_rec_ir)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_rec_ir)); }
    val rec_ir: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_rec_ir);

    val res_xty: R.Result[ir_type.IrTypeId, str] = index_type(ctx);
    if (R.is_err[ir_type.IrTypeId, str](res_xty)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_xty)); }
    val xty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_xty);

    var idx: [2]value.Value;
    idx[0] = value.const_int(0, xty);
    idx[1] = value.const_int(field_ix::u64, xty);
    ret builder.emit_gep(?ctx.builder, base, rec_ir, ?idx[0], 2);
}

# the IR type of an expression, by lowering its semantic type
# ---
# ctx: per-module lowering context
# eid: the expression to type
# ret: the expression's IR type, or an error
fun ir_type_of_expr(ctx: *context.LowerContext, eid: id.ExprId) R.Result[ir_type.IrTypeId, str] {
    ret context.lower_type(ctx, context.expr_type_of(ctx, eid));
}

# the IR integer type used for gep indices and alloca element counts (pointer-width)
# ---
# ctx: per-module lowering context
# ret: the pointer-width IR int type, or an error
fun index_type(ctx: *context.LowerContext) R.Result[ir_type.IrTypeId, str] {
    ret ir_type.intern_int(?ctx.m.types, ctx.tgt.arch.pointer_width * 8);
}

# widen a runtime gep index to the pointer-width machine-word index type
#
# A narrower index (e.g. a u8 enum/kind) is extended per its signedness; a pointer-width
# (or wider) index is left as-is. Without this the back end scales the index's full
# register while its high bits are undefined, producing a wild address.
#
# This is the intentional, target-derived index-normalization point: the width is
# the active target's pointer width (index_type), and the sign/zero extension is
# chosen here from the semantic signedness. it deliberately stays in the middle-end,
# not the back end - the IR is signless and OP_GEP carries no per-index signedness,
# so the back end could not pick sext vs zext; relocating it would regress signed
# sub-word indices (#1598).
# ---
# ctx:    per-module lowering context
# v:      the index value
# sem_ty: the index's semantic type
# ret:    the widened (or unchanged) index, or an error
fun widen_index(ctx: *context.LowerContext, v: value.Value, sem_ty: type.TypeId) R.Result[value.Value, str] {
    val res_xty: R.Result[ir_type.IrTypeId, str] = index_type(ctx);
    if (R.is_err[ir_type.IrTypeId, str](res_xty)) { ret R.err[value.Value, str](R.unwrap_err[ir_type.IrTypeId, str](res_xty)); }
    val xty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_xty);
    if (scalar_bits(ctx, sem_ty) >= ctx.tgt.arch.pointer_width * 8) { ret R.ok[value.Value, str](v); }
    if (is_signed_type(ctx, sem_ty))    { ret builder.emit_sext(?ctx.builder, v, xty); }
    ret builder.emit_zext(?ctx.builder, v, xty);
}

# the bit width of a scalar semantic type, or 0 for non-scalars
#
# A function value is its code address, so it is pointer-width; a `fn::*ptr` cast
# is then a same-size bitcast, not a truncate / extend.
# ---
# ctx: per-module lowering context
# tid: the semantic type to size
# ret: the bit width, or 0 for a non-scalar
fun scalar_bits(ctx: *context.LowerContext, tid: type.TypeId) u32 {
    val opt_t: O.Option[*type.Type] = type.get(?ctx.s.types, tid);
    if (O.is_none[*type.Type](opt_t)) { ret 0; }
    val k: type.TypeKind = O.unwrap[*type.Type](opt_t).kind;
    val d: type.PrimDesc = type.prim_desc(k);
    if (d.class == type.PRIM_CLASS_INT || d.class == type.PRIM_CLASS_FLOAT) { ret d.bits; }
    if (k == type.TYPE_PTR || k == type.TYPE_POINTER || k == type.TYPE_FUN) { ret ctx.tgt.arch.pointer_width * 8; }
    ret 0;
}

# whether a semantic type is a signed integer
# ---
# ctx: per-module lowering context
# tid: the semantic type to classify
# ret: true for i8 / i16 / i32 / i64
fun is_signed_type(ctx: *context.LowerContext, tid: type.TypeId) bool {
    val opt_t: O.Option[*type.Type] = type.get(?ctx.s.types, tid);
    if (O.is_none[*type.Type](opt_t)) { ret false; }
    ret type.prim_desc(O.unwrap[*type.Type](opt_t).kind).signed;
}

# whether a semantic type is a float
# ---
# ctx: per-module lowering context
# tid: the semantic type to classify
# ret: true for f32 / f64
fun is_float_type(ctx: *context.LowerContext, tid: type.TypeId) bool {
    val opt_t: O.Option[*type.Type] = type.get(?ctx.s.types, tid);
    if (O.is_none[*type.Type](opt_t)) { ret false; }
    ret type.prim_desc(O.unwrap[*type.Type](opt_t).kind).class == type.PRIM_CLASS_FLOAT;
}

# whether a semantic type is a pointer (raw `ptr` or typed `*T`)
# ---
# ctx: per-module lowering context
# tid: the semantic type to classify
# ret: true for TYPE_PTR / TYPE_POINTER
fun is_pointer_type(ctx: *context.LowerContext, tid: type.TypeId) bool {
    val opt_t: O.Option[*type.Type] = type.get(?ctx.s.types, tid);
    if (O.is_none[*type.Type](opt_t)) { ret false; }
    val k: type.TypeKind = O.unwrap[*type.Type](opt_t).kind;
    ret k == type.TYPE_PTR || k == type.TYPE_POINTER;
}

# whether an IR type is an aggregate (a struct or array)
#
# Aggregates flow by address through lowering, not by loaded value: an aggregate
# rvalue is a pointer to its storage, which the back end consumes for two-register
# / by-reference argument passing and aggregate returns. Classifies on the IR type
# so the test matches the back end's mir.value_is_aggregate exactly.
# ---
# ctx: per-module lowering context
# ity: the IR type to classify
# ret: true for a struct or array IR type
fun is_aggregate_ir(ctx: *context.LowerContext, ity: ir_type.IrTypeId) bool {
    ret ir_type.is_aggregate(?ctx.m.types, ity);
}

# resolve a member name to a field index within a nominal semantic type
#
# Matches the interned member name against each field's interned name in the
# session-global field store (keyed by TypeId). Using the store rather than an AST
# declaration resolves anonymous records (structural identity) and cross-module
# records uniformly. An unmatched name records a `no such field` diagnostic at
# `name` (which gates the build before any artifact links) and returns 0, instead
# of silently folding to field 0. For `.field` access and struct literals sema
# guarantees the field exists, so the miss is unreachable there; `$offset_of`'s
# bare field argument is only validated here.
# ---
# ctx:    per-module lowering context
# rec_ty: the record semantic type to resolve against
# name:   the member name span
# ret:    the field ordinal, or 0 (with a diagnostic) when unmatched
pub fun field_index_in_type(ctx: *context.LowerContext, rec_ty: type.TypeId, name: token.Span) u32 {
    val src_text: str = context.module_source(ctx);
    val res_want: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, src_text, name);
    if (R.is_err[intern.StrId, str](res_want)) { ret 0; }
    val want: intern.StrId = R.unwrap_ok[intern.StrId, str](res_want);

    val fields_len: u32 = type.field_count(?ctx.s.types, rec_ty);
    var i: u32 = 0;
    for (i < fields_len) {
        val opt_fe: O.Option[*type.FieldEntry] = type.field_at(?ctx.s.types, rec_ty, i);
        if (O.is_some[*type.FieldEntry](opt_fe)) {
            if (O.unwrap[*type.FieldEntry](opt_fe).name == want) { ret i; }
        }
        i = i + 1;
    }

    # name the missing field from its source text; the span already underlines it,
    # and lowering has no semantic type renderer to also name the receiver type.
    val prefix: str   = "no field '";
    val suffix: str   = "' on the receiver type";
    val total:  usize = str_len(prefix) + name.len + str_len(suffix);
    val res_buf: R.Result[*u8, str] = A.allocate[u8](ctx.s.alloc, total + 1);
    if (R.is_err[*u8, str](res_buf)) {
        diagnostic.error(?ctx.s.diags, ctx.a.file_id, name, "no such field on the receiver type");
        ret 0;
    }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);
    var pos: usize = 0;
    var j:   usize = 0;
    for (j < str_len(prefix)) { buf[pos] = prefix[j];                pos = pos + 1; j = j + 1; }
    j = 0;
    for (j < name.len)        { buf[pos] = src_text[name.offset + j]; pos = pos + 1; j = j + 1; }
    j = 0;
    for (j < str_len(suffix)) { buf[pos] = suffix[j];                pos = pos + 1; j = j + 1; }
    buf[total] = 0;
    diagnostic.error(?ctx.s.diags, ctx.a.file_id, name, buf::str);
    A.deallocate[u8](ctx.s.alloc, buf, total + 1);
    ret 0;
}

# find the module function index whose interned name matches `name`, or none
#
# The module keeps a name -> index map updated on every append, so this is an O(1)
# lookup rather than a linear scan over every emitted function.
# ---
# ctx:  per-module lowering context
# name: the linkage name to look up
# ret:  some(index) when present, none otherwise
fun find_function(ctx: *context.LowerContext, name: intern.StrId) O.Option[u32] {
    ret ir.function_lookup(ctx.m, name);
}

# find the module global index whose interned name matches `name`, or none
#
# Resolves through the module's name -> index map (user / extern globals).
# ---
# ctx:  per-module lowering context
# name: the linkage name to look up
# ret:  some(index) when present, none otherwise
fun find_global(ctx: *context.LowerContext, name: intern.StrId) O.Option[u32] {
    ret ir.global_lookup(ctx.m, name);
}
