# mach.lang.me.lower.stmt: per-statement lowering.
#
# Drives control-flow emission: every branching or
# looping construct creates the blocks it needs and stitches the
# predecessor edges through the IR builder's terminator emitters.
#
# After a statement that produces a terminator (`ret`, an exhaustive
# `if`/`or` chain, an infinite `for`), the builder cursor is left on a
# fresh, unreachable block so the caller's next statement lands somewhere
# valid; `dce` drops the dead block later. The `fin` stack records deferred
# bodies that are replayed (lowered inline) before every reachable
# terminator that closes the enclosing scope.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.char.char;
use std.types.string.str;
use std.types.string.str_len;
use std.types.option.Option;
use std.types.option.none;
use std.types.option.is_none;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use intern:   mach.lang.intern;
use diag:     mach.lang.diagnostic;
use token:    mach.lang.fe.token;

use ast:      mach.lang.fe.ast;
use aid:      mach.lang.fe.ast.id;
use astmt:    mach.lang.fe.ast.stmt;
use adecl:    mach.lang.fe.ast.decl;
use resolve:  mach.lang.fe.resolve;
use comptime: mach.lang.fe.comptime;
use ty:       mach.lang.type;

use ir:       mach.lang.me.ir;
use ir_type:  mach.lang.me.ir.type;
use value:    mach.lang.me.ir.value;
use builder:  mach.lang.me.ir.builder;

use map: std.collections.map;

use sema:  mach.lang.fe.sema;

use lower: mach.lang.me.lower.context;
use expr:  mach.lang.me.lower.expr;

# lowers one statement, dispatching on its `StmtKind`.
# ---
# ctx: per-module lowering context
# sid: AST StmtId to lower
# ret: true on success, or an error
pub fun lower_stmt(ctx: *lower.LowerContext, sid: aid.StmtId) Result[bool, str] {
    val s_opt: Option[*astmt.Stmt] = ast.get_stmt(ctx.a, sid);
    if (is_none[*astmt.Stmt](s_opt)) {
        ret err[bool, str]("lower: statement id out of range");
    }
    val s: *astmt.Stmt = unwrap[*astmt.Stmt](s_opt);
    val k: astmt.StmtKind = s.kind;

    if (k == astmt.STMT_KIND_EXPR)        { ret lower_expr_stmt(ctx, s); }
    if (k == astmt.STMT_KIND_BLOCK)       { ret lower_block(ctx, s); }
    if (k == astmt.STMT_KIND_IF)          { ret lower_if(ctx, s); }
    if (k == astmt.STMT_KIND_FOR)         { ret lower_for(ctx, s); }
    if (k == astmt.STMT_KIND_RET)         { ret lower_ret(ctx, s); }
    if (k == astmt.STMT_KIND_BRK)         { ret lower_brk(ctx); }
    if (k == astmt.STMT_KIND_CNT)         { ret lower_cnt(ctx); }
    if (k == astmt.STMT_KIND_FIN)         { ret lower_fin(ctx, s); }
    if (k == astmt.STMT_KIND_DECL)        { ret lower_decl_stmt(ctx, s); }
    if (k == astmt.STMT_KIND_ASM)         { ret lower_asm(ctx, s); }
    if (k == astmt.STMT_KIND_COMPTIME_IF) { ret lower_comptime_if(ctx, s); }
    if (k == astmt.STMT_KIND_COMPTIME_EACH) { ret lower_comptime_each(ctx, s); }
    if (k == astmt.STMT_KIND_ERROR) {
        # an error stmt must never reach lowering: the driver aborts on
        # accumulated diagnostics before the middle end runs.
        ret err[bool, str]("lower: error statement reached the middle end");
    }

    ret err[bool, str]("lower: unsupported statement kind");
}

# lowers a list of statements (`start`..`start+len` in ast.stmt_ids), the
# common body shape for blocks, loop bodies, and arm bodies. stops early
# once the current block is terminated (further stmts are unreachable and
# are dropped here rather than emitted into a dead block).
# ---
# ctx:   the context
# start: start index into ast.stmt_ids
# len:   number of statements
# ret:   true on success, or an error
pub fun lower_stmt_list(ctx: *lower.LowerContext, start: u32, len: u32) Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        if (block_terminated(ctx)) { ret ok[bool, str](true); }
        val pool_ix: u32 = start + i;
        if (pool_ix::usize >= ctx.a.stmt_id_len) {
            ret err[bool, str]("lower: statement list index out of range");
        }
        val r: Result[bool, str] = lower_stmt(ctx, ctx.a.stmt_ids[pool_ix]);
        if (is_err[bool, str](r)) { ret r; }
        i = i + 1;
    }
    ret ok[bool, str](true);
}

fun lower_expr_stmt(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val r: Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.expr.expr);
    if (is_err[value.Value, str](r)) { ret err[bool, str](unwrap_err[value.Value, str](r)); }
    ret ok[bool, str](true);
}

fun lower_block(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    ret lower_stmt_list(ctx, s.data.block.stmts_start, s.data.block.stmts_len);
}

# lowers an `if`/`or` chain into a cbr diamond. the parser folds the `or`
# chain into `else_block`, so a chained `if` is just an `IF` whose else
# block holds the next `if`. each arm lowers into its own block; the merge
# block receives an edge from each non-terminated arm. no phis are emitted —
# mem2reg inserts them for variables mutated across arms.
fun lower_if(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val cr: Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.if_.cond);
    if (is_err[value.Value, str](cr)) { ret err[bool, str](unwrap_err[value.Value, str](cr)); }
    val cond: value.Value = unwrap_ok[value.Value, str](cr);

    val then_r: Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (is_err[ir.BlockId, str](then_r)) { ret err[bool, str](unwrap_err[ir.BlockId, str](then_r)); }
    val then_b: ir.BlockId = unwrap_ok[ir.BlockId, str](then_r);

    val has_else: bool = s.data.if_.else_block != aid.STMT_NIL;

    val else_r: Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (is_err[ir.BlockId, str](else_r)) { ret err[bool, str](unwrap_err[ir.BlockId, str](else_r)); }
    val else_b: ir.BlockId = unwrap_ok[ir.BlockId, str](else_r);

    val merge_r: Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (is_err[ir.BlockId, str](merge_r)) { ret err[bool, str](unwrap_err[ir.BlockId, str](merge_r)); }
    val merge_b: ir.BlockId = unwrap_ok[ir.BlockId, str](merge_r);

    val cbr_r: Result[bool, str] = builder.emit_cbr(?ctx.builder, cond, then_b, else_b);
    if (is_err[bool, str](cbr_r)) { ret cbr_r; }

    # then arm
    builder.set_block(?ctx.builder, then_b);
    val tr: Result[bool, str] = lower_stmt(ctx, s.data.if_.then_block);
    if (is_err[bool, str](tr)) { ret tr; }
    if (!block_terminated(ctx)) {
        val br_r: Result[bool, str] = builder.emit_br(?ctx.builder, merge_b);
        if (is_err[bool, str](br_r)) { ret br_r; }
    }

    # else arm
    builder.set_block(?ctx.builder, else_b);
    if (has_else) {
        val er: Result[bool, str] = lower_stmt(ctx, s.data.if_.else_block);
        if (is_err[bool, str](er)) { ret er; }
    }
    if (!block_terminated(ctx)) {
        val br_r: Result[bool, str] = builder.emit_br(?ctx.builder, merge_b);
        if (is_err[bool, str](br_r)) { ret br_r; }
    }

    builder.set_block(?ctx.builder, merge_b);
    ret ok[bool, str](true);
}

# lowers a `for` loop. an absent condition is an infinite loop (the header
# branches straight to the body). a present condition lowers to a cbr in the
# header that exits to the loop-exit block. the body's last block branches
# back to the header (the back-edge); `brk` / `cnt` use the loop frame.
fun lower_for(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val header_r: Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (is_err[ir.BlockId, str](header_r)) { ret err[bool, str](unwrap_err[ir.BlockId, str](header_r)); }
    val header: ir.BlockId = unwrap_ok[ir.BlockId, str](header_r);

    val body_r: Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (is_err[ir.BlockId, str](body_r)) { ret err[bool, str](unwrap_err[ir.BlockId, str](body_r)); }
    val body: ir.BlockId = unwrap_ok[ir.BlockId, str](body_r);

    val exit_r: Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (is_err[ir.BlockId, str](exit_r)) { ret err[bool, str](unwrap_err[ir.BlockId, str](exit_r)); }
    val exit: ir.BlockId = unwrap_ok[ir.BlockId, str](exit_r);

    # enter the loop from the current block
    val enter_r: Result[bool, str] = builder.emit_br(?ctx.builder, header);
    if (is_err[bool, str](enter_r)) { ret enter_r; }

    # header: branch to body unconditionally (infinite) or by condition
    builder.set_block(?ctx.builder, header);
    if (s.data.for_.cond == aid.EXPR_NIL) {
        val br_r: Result[bool, str] = builder.emit_br(?ctx.builder, body);
        if (is_err[bool, str](br_r)) { ret br_r; }
    } or {
        val cr: Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.for_.cond);
        if (is_err[value.Value, str](cr)) { ret err[bool, str](unwrap_err[value.Value, str](cr)); }
        val cbr_r: Result[bool, str] = builder.emit_cbr(?ctx.builder, unwrap_ok[value.Value, str](cr), body, exit);
        if (is_err[bool, str](cbr_r)) { ret cbr_r; }
    }

    # body
    val push_r: Result[bool, str] = lower.push_loop(ctx, header, exit);
    if (is_err[bool, str](push_r)) { ret push_r; }

    builder.set_block(?ctx.builder, body);
    val br: Result[bool, str] = lower_stmt(ctx, s.data.for_.body);
    if (is_err[bool, str](br)) { lower.pop_loop(ctx); ret br; }
    if (!block_terminated(ctx)) {
        val back_r: Result[bool, str] = builder.emit_br(?ctx.builder, header);
        if (is_err[bool, str](back_r)) { lower.pop_loop(ctx); ret back_r; }
    }

    lower.pop_loop(ctx);

    # continue lowering after the loop in the exit block
    builder.set_block(?ctx.builder, exit);
    ret ok[bool, str](true);
}

# lowers a return: replays the pending fin bodies (innermost first), then
# emits the `ret` terminator. a bare `ret` in a value-returning function
# returns a zero of the function's IR return type so the IR stays
# well-typed.
fun lower_ret(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val fr: Result[bool, str] = run_fins(ctx);
    if (is_err[bool, str](fr)) { ret fr; }
    if (block_terminated(ctx)) { ret ok[bool, str](true); }

    if (s.data.ret_.value != aid.EXPR_NIL) {
        val vr: Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.ret_.value);
        if (is_err[value.Value, str](vr)) { ret err[bool, str](unwrap_err[value.Value, str](vr)); }
        ret builder.emit_ret(?ctx.builder, unwrap_ok[value.Value, str](vr));
    }

    # bare ret: void if the function returns void, else a zero of ret_ty
    if (is_void(ctx, ctx.ret_ty)) {
        ret builder.emit_ret_void(?ctx.builder);
    }
    ret builder.emit_ret(?ctx.builder, value.const_int(0, ctx.ret_ty));
}

fun lower_brk(ctx: *lower.LowerContext) Result[bool, str] {
    val lf: *lower.LoopFrame = lower.current_loop(ctx);
    if (lf == nil) { ret err[bool, str]("lower: brk outside a loop"); }
    ret builder.emit_br(?ctx.builder, lf.exit);
}

fun lower_cnt(ctx: *lower.LowerContext) Result[bool, str] {
    val lf: *lower.LoopFrame = lower.current_loop(ctx);
    if (lf == nil) { ret err[bool, str]("lower: cnt outside a loop"); }
    ret builder.emit_br(?ctx.builder, lf.header);
}

# records a deferred `fin` body on the fin stack. the body is replayed
# before every reachable terminator that closes the enclosing function
# scope (currently: at each `ret` and at fall-through function exit).
fun lower_fin(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    ret lower.push_fin(ctx, s.data.fin_.body);
}

# replays every pending fin body in reverse registration order (innermost
# first). called immediately before a `ret` and at function fall-through.
fun run_fins(ctx: *lower.LowerContext) Result[bool, str] {
    val n: u32 = lower.fin_count(ctx);
    if (n == 0) { ret ok[bool, str](true); }
    var i: u32 = n;
    for (i > 0) {
        i = i - 1;
        if (block_terminated(ctx)) { ret ok[bool, str](true); }
        val body: aid.StmtId = lower.fin_at(ctx, i);
        if (body != aid.STMT_NIL) {
            val r: Result[bool, str] = lower_stmt(ctx, body);
            if (is_err[bool, str](r)) { ret r; }
        }
    }
    ret ok[bool, str](true);
}

# replays the pending fin bodies at function fall-through (no explicit ret).
# exposed for the decl lowerer's default-return path.
# ---
# ctx: the context
# ret: true on success, or an error
pub fun run_pending_fins(ctx: *lower.LowerContext) Result[bool, str] {
    ret run_fins(ctx);
}

# builds the typed zero constant for a scalar / pointer / float slot type, so a
# zero store passes the verifier's constant-typing rule (a float constant must
# carry an IRT_FLOAT type; an integer / pointer constant an IRT_INT or IRT_PTR
# type). the bit pattern is 0 in every case: 0.0 has an all-zero f64 encoding
# and a null pointer is the zero address.
fun zero_const(ctx: *lower.LowerContext, ty: ir_type.IrTypeId) value.Value {
    val o: Option[*ir_type.IrType] = ir_type.get(?ctx.m.types, ty);
    if (is_some[*ir_type.IrType](o)) {
        if (unwrap[*ir_type.IrType](o).kind == ir_type.IRT_FLOAT) {
            ret value.const_float(0.0, ty);
        }
    }
    ret value.const_int(0, ty);
}

# lowers a local `val` / `var`: allocate a stack slot, store the initial
# value if present, and bind the source SymbolId to the slot pointer so
# later reads / writes lower to load / store. mem2reg promotes the slot.
fun lower_decl_stmt(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val did: aid.DeclId = s.data.decl.decl;
    val d_opt: Option[*adecl.Decl] = ast.get_decl(ctx.a, did);
    if (is_none[*adecl.Decl](d_opt)) { ret err[bool, str]("lower: local decl id out of range"); }
    val d: *adecl.Decl = unwrap[*adecl.Decl](d_opt);

    if (d.kind != adecl.DECL_KIND_VAL && d.kind != adecl.DECL_KIND_VAR) {
        # nested rec/def/use at statement scope contribute no runtime code
        ret ok[bool, str](true);
    }

    val slot_ty_r: Result[ir_type.IrTypeId, str] = lower.lower_type(ctx, lower.decl_type_of(ctx, did));
    if (is_err[ir_type.IrTypeId, str](slot_ty_r)) { ret err[bool, str](unwrap_err[ir_type.IrTypeId, str](slot_ty_r)); }
    val slot_ty: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](slot_ty_r);

    val cr: Result[ir_type.IrTypeId, str] = ir_type.intern_int(?ctx.m.types, 64);
    if (is_err[ir_type.IrTypeId, str](cr)) { ret err[bool, str](unwrap_err[ir_type.IrTypeId, str](cr)); }
    val xty: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](cr);

    val slot_r: Result[value.Value, str] = builder.emit_alloca(?ctx.builder, slot_ty, value.const_int(1, xty));
    if (is_err[value.Value, str](slot_r)) { ret err[bool, str](unwrap_err[value.Value, str](slot_r)); }
    val slot: value.Value = unwrap_ok[value.Value, str](slot_r);

    val sid: resolve.SymbolId = decl_symbol_of(ctx, did);
    val bind_r: Result[bool, str] = lower.bind_local(ctx, sid, slot);
    if (is_err[bool, str](bind_r)) { ret bind_r; }

    if (d.data.bind.init != aid.EXPR_NIL) {
        val vr: Result[value.Value, str] = expr.lower_rvalue(ctx, d.data.bind.init);
        if (is_err[value.Value, str](vr)) { ret err[bool, str](unwrap_err[value.Value, str](vr)); }
        val sr: Result[bool, str] = builder.emit_store(?ctx.builder, unwrap_ok[value.Value, str](vr), slot);
        if (is_err[bool, str](sr)) { ret sr; }
    } or {
        # an uninitialized `val` / `var` is zero-initialized (the language
        # guarantees zeroed locals). an aggregate slot is cleared with a sized
        # OP_MEMZERO; a scalar / pointer / float slot takes a typed zero store
        # that mem2reg promotes and dce drops when the local is never read, so
        # zeroing never pessimizes a scalar local.
        if (ir_type.is_aggregate(?ctx.m.types, slot_ty)) {
            val zr: Result[bool, str] = builder.emit_memzero(?ctx.builder, slot, slot_ty);
            if (is_err[bool, str](zr)) { ret zr; }
        } or {
            val zr: Result[bool, str] = builder.emit_store(?ctx.builder, zero_const(ctx, slot_ty), slot);
            if (is_err[bool, str](zr)) { ret zr; }
        }
    }

    ret ok[bool, str](true);
}

# strip_asm_comments: allocate a NUL-terminated copy of the `len`-byte asm body
# at `src + offset` with each `#` line comment removed through the end of its line;
# the line's newline is kept so statement boundaries survive. the copy is sized to
# `len + 1` (its longest possible form) so the caller frees exactly that.
fun strip_asm_comments(alloc: *Allocator, src: str, offset: usize, len: usize) Result[str, str] {
    val r: Result[*u8, str] = allocate[u8](alloc, len + 1);
    if (is_err[*u8, str](r)) { ret err[str, str](unwrap_err[*u8, str](r)); }
    val out: *u8 = unwrap_ok[*u8, str](r);
    var i: usize = 0;
    var o: usize = 0;
    for (i < len) {
        val c: u8 = src[offset + i];
        if (c == '#'::char) {
            # drop the comment through (but not including) the line's newline.
            for (i < len && src[offset + i] != '\n'::char) { i = i + 1; }
            cnt;
        }
        out[o] = c;
        o = o + 1;
        i = i + 1;
    }
    out[o] = 0;
    ret ok[str, str](out::str);
}

# lowers an inline-asm statement to an OP_ASM instruction and registers its
# `IrAsm` payload (interned ISA tag + raw body) in `Function.asm`, keyed by
# the instruction id. operand / clobber inference happens in the back end,
# so no operands are attached here.
#
# each `{name}` reference in the body is resolved against the locals in scope
# and recorded as a `{name}` -> alloca binding so the back end can substitute
# the local's frame offset once the frame is laid out. an unknown `{name}` is
# a hard error: a mis-typed local would otherwise silently encode a bad
# address.
fun lower_asm(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val txt: str = lower.module_source(ctx);

    val isa_r: Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, txt, s.data.asm_.isa);
    if (is_err[intern.StrId, str](isa_r)) { ret err[bool, str](unwrap_err[intern.StrId, str](isa_r)); }
    val isa_id: intern.StrId = unwrap_ok[intern.StrId, str](isa_r);

    # strip `#` line comments before interning so a comment is opaque to bind
    # collection, local substitution, statement tokenization, and clobber
    # inference regardless of its bytes (a comment may hold `;`, `{`, `%`, ...).
    val span: token.Span = s.data.asm_.body;
    val strip_r: Result[str, str] = strip_asm_comments(ctx.s.alloc, txt, span.offset, span.len);
    if (is_err[str, str](strip_r)) { ret err[bool, str](unwrap_err[str, str](strip_r)); }
    val stripped: str = unwrap_ok[str, str](strip_r);
    val body_r: Result[intern.StrId, str] = intern.intern_bytes(?ctx.s.interner, stripped, str_len(stripped));
    deallocate[u8](ctx.s.alloc, stripped::*u8, span.len + 1);
    if (is_err[intern.StrId, str](body_r)) { ret err[bool, str](unwrap_err[intern.StrId, str](body_r)); }
    val body_id: intern.StrId = unwrap_ok[intern.StrId, str](body_r);

    var payload: ir.IrAsm;
    payload.isa        = isa_id;
    payload.body       = body_id;
    payload.binds      = nil;
    payload.bind_count = 0;
    payload.bind_cap   = 0;

    val br: Result[bool, str] = collect_asm_binds(ctx, body_id, s.data.asm_.body, ?payload);
    if (is_err[bool, str](br)) {
        if (payload.binds != nil) { deallocate[ir.IrAsmBind](ctx.s.alloc, payload.binds, payload.bind_cap::usize); }
        ret br;
    }

    val emit_r: Result[ir.InstructionId, str] = builder.emit_asm(?ctx.builder, nil, 0);
    if (is_err[ir.InstructionId, str](emit_r)) {
        if (payload.binds != nil) { deallocate[ir.IrAsmBind](ctx.s.alloc, payload.binds, payload.bind_cap::usize); }
        ret err[bool, str](unwrap_err[ir.InstructionId, str](emit_r));
    }
    val asm_iid: ir.InstructionId = unwrap_ok[ir.InstructionId, str](emit_r);

    val ir2: Result[bool, str] = map.insert[ir.InstructionId, ir.IrAsm](?ctx.builder.fn.asm_blocks, asm_iid, payload);
    if (is_err[bool, str](ir2)) {
        if (payload.binds != nil) { deallocate[ir.IrAsmBind](ctx.s.alloc, payload.binds, payload.bind_cap::usize); }
        ret ir2;
    }
    ret ok[bool, str](true);
}

# report_asm: file a located error at the asm body `span` and return the
# REPORTED sentinel so the driver shows a single file:line:col diagnostic.
fun report_asm(ctx: *lower.LowerContext, span: token.Span, message: str) Result[bool, str] {
    diag.error(?ctx.s.diags, ctx.a.file_id, span, message);
    ret err[bool, str](lower.REPORTED);
}

# report_asm_named: report_asm with the interned `name_id` interpolated between
# `prefix` and `suffix`. degrades to `prefix` alone on any lookup/alloc failure.
fun report_asm_named(ctx: *lower.LowerContext, span: token.Span, prefix: str, name_id: intern.StrId, suffix: str) Result[bool, str] {
    val no: Option[str] = intern.lookup(?ctx.s.interner, name_id);
    if (is_none[str](no)) { ret report_asm(ctx, span, prefix); }
    val nm: str = unwrap[str](no);

    val total: usize = str_len(prefix) + str_len(nm) + str_len(suffix);
    val r: Result[*u8, str] = allocate[u8](ctx.s.alloc, total + 1);
    if (is_err[*u8, str](r)) { ret report_asm(ctx, span, prefix); }
    val buf: *u8 = unwrap_ok[*u8, str](r);
    var k: usize = 0;
    var j: usize = 0;
    for (j < str_len(prefix)) { buf[k] = prefix[j]; k = k + 1; j = j + 1; }
    j = 0;
    for (j < str_len(nm)) { buf[k] = nm[j]; k = k + 1; j = j + 1; }
    j = 0;
    for (j < str_len(suffix)) { buf[k] = suffix[j]; k = k + 1; j = j + 1; }
    buf[total] = 0;
    diag.error(?ctx.s.diags, ctx.a.file_id, span, buf::str);
    deallocate[u8](ctx.s.alloc, buf, total + 1);
    ret err[bool, str](lower.REPORTED);
}

# scans an inline-asm body for `{name}` references and records each as a
# `{name}` -> alloca binding in `payload.binds`. a name is interned and resolved
# against the locals in scope (`lookup_local_name`); a duplicate `{name}` is
# recorded once. an unknown name, or one bound to a non-alloca Value, is a hard
# error rather than a silently dropped substitution. `body_span` locates every
# diagnostic on the inline-asm body in the source.
fun collect_asm_binds(ctx: *lower.LowerContext, body_id: intern.StrId, body_span: token.Span, payload: *ir.IrAsm) Result[bool, str] {
    val bopt: Option[str] = intern.lookup(?ctx.s.interner, body_id);
    if (is_none[str](bopt)) { ret err[bool, str]("lower: inline-asm body interning failed"); }
    val body: str = unwrap[str](bopt);

    var i: usize = 0;
    for (body[i] != 0) {
        if (body[i] != '{'::char) { i = i + 1; cnt; }

        # collect the name between '{' and the matching '}'.
        val name_start: usize = i + 1;
        var j: usize = name_start;
        for (body[j] != 0 && body[j] != '}'::char) { j = j + 1; }
        if (body[j] == 0) { ret report_asm(ctx, body_span, "unterminated '{' in inline asm body"); }
        val name_len: usize = j - name_start;
        if (name_len == 0) { ret report_asm(ctx, body_span, "empty '{}' in asm body; write '{name}' to reference a local"); }

        val nr: Result[intern.StrId, str] = intern.intern_bytes(?ctx.s.interner, (body::usize + name_start)::str, name_len);
        if (is_err[intern.StrId, str](nr)) { ret err[bool, str](unwrap_err[intern.StrId, str](nr)); }
        val name_id: intern.StrId = unwrap_ok[intern.StrId, str](nr);

        val ar: Result[bool, str] = add_asm_bind(ctx, body_span, payload, name_id);
        if (is_err[bool, str](ar)) { ret ar; }

        i = j + 1;
    }
    ret ok[bool, str](true);
}

# resolves a single `{name}` to its local alloca and appends the binding to
# `payload.binds` (once per distinct name). the local's storage Value must be a
# VAL_INSTR naming the alloca whose slot the back end addresses; anything else
# (an unbound name, a parameter still in a register, a constant) is rejected.
fun add_asm_bind(ctx: *lower.LowerContext, body_span: token.Span, payload: *ir.IrAsm, name_id: intern.StrId) Result[bool, str] {
    var k: u32 = 0;
    for (k < payload.bind_count) {
        if (payload.binds[k].name == name_id) { ret ok[bool, str](true); }
        k = k + 1;
    }

    val vopt: Option[value.Value] = lower.lookup_local_name(ctx, name_id);
    if (!is_some[value.Value](vopt)) {
        ret report_asm_named(ctx, body_span, "unknown local '", name_id, "' in inline asm; only stack-allocated variables in scope can be referenced");
    }
    val v: value.Value = unwrap[value.Value](vopt);
    if (v.kind != value.VAL_INSTR) {
        ret report_asm_named(ctx, body_span, "'", name_id, "' is not stack-allocated and cannot be used in inline asm");
    }

    if (payload.bind_count == payload.bind_cap) {
        val new_cap: u32 = grow_bind_cap(payload.bind_cap);
        var nb: *ir.IrAsmBind = nil;
        if (payload.binds == nil) {
            val r: Result[*ir.IrAsmBind, str] = allocate[ir.IrAsmBind](ctx.s.alloc, new_cap::usize);
            if (is_err[*ir.IrAsmBind, str](r)) { ret err[bool, str](unwrap_err[*ir.IrAsmBind, str](r)); }
            nb = unwrap_ok[*ir.IrAsmBind, str](r);
        } or {
            val r: Result[*ir.IrAsmBind, str] = reallocate[ir.IrAsmBind](ctx.s.alloc, payload.binds, payload.bind_cap::usize, new_cap::usize);
            if (is_err[*ir.IrAsmBind, str](r)) { ret err[bool, str](unwrap_err[*ir.IrAsmBind, str](r)); }
            nb = unwrap_ok[*ir.IrAsmBind, str](r);
        }
        payload.binds    = nb;
        payload.bind_cap = new_cap;
    }

    payload.binds[payload.bind_count].name  = name_id;
    payload.binds[payload.bind_count].instr = v.data.instr;
    payload.bind_count = payload.bind_count + 1;
    ret ok[bool, str](true);
}

# initial / doubling capacity for an inline-asm body's `{name}` binding array.
fun grow_bind_cap(cap: u32) u32 {
    if (cap == 0) { ret 4; }
    ret cap * 2;
}

# lowers a statement-scope `$if` chain: evaluates each arm's condition with
# the comptime evaluator and lowers only the first arm whose condition is
# true (or the final unconditional `$or` arm). inactive arms emit nothing.
fun lower_comptime_if(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val txt: str = lower.module_source(ctx);
    var bi: u32 = 0;
    for (bi < s.data.comptime_if.branches_len) {
        val branch_ix: u32 = s.data.comptime_if.branches_start + bi;
        if (branch_ix::usize >= ctx.a.comptime_branch_len) {
            ret err[bool, str]("lower: comptime branch index out of range");
        }
        val branch: *adecl.ComptimeBranch = ?ctx.a.comptime_branches[branch_ix];

        var active: bool = false;
        if (branch.cond == aid.EXPR_NIL) {
            active = true;
        } or {
            val ev: Result[comptime.CTValue, str] = comptime.eval(ctx.ctx, ctx.a, txt, branch.cond, ?ctx.s.interner);
            if (is_err[comptime.CTValue, str](ev)) { ret err[bool, str](unwrap_err[comptime.CTValue, str](ev)); }
            active = ct_truthy(unwrap_ok[comptime.CTValue, str](ev));
        }

        if (active) {
            ret lower_stmt_list(ctx, branch.body_start, branch.body_len);
        }
        bi = bi + 1;
    }
    ret ok[bool, str](true);
}

# lowers a `$each <ident> in $fields(T) { body }` (#1473) by unrolling it: the
# body is lowered once per field of T, with the loop variable bound in the
# comptime frame to that field's descriptor, so a `v.[f]` in the body projects
# the concrete field of each iteration. the lowering half of the splice sema
# mirrors. the owning type was resolved and recorded on the `$fields(T)` argument
# by sema.
fun lower_comptime_each(ctx: *lower.LowerContext, s: *astmt.Stmt) Result[bool, str] {
    val ce: *astmt.StmtComptimeEach = ?s.data.comptime_each;
    val src: str = lower.module_source(ctx);

    # a pack `$each a in va` (#1475): the sequence is a variadic-pack value (not a
    # `$fields(T)` call), so unroll over the pack instance's expanded elements —
    # re-typing then lowering the body per element, the loop variable bound to each.
    if (is_pack_type(ctx, lower.expr_type_of(ctx, ce.seq))) {
        ret lower_pack_each(ctx, ce);
    }

    if (!comptime.is_fields_call(ctx.a, src, ce.seq)) {
        ret err[bool, str]("lower: a `$each` sequence must be `$fields(T)` or a variadic pack");
    }
    val targ: aid.ExprId = comptime.fields_type_arg(ctx.a, ce.seq);
    if (targ == aid.EXPR_NIL) { ret err[bool, str]("lower: `$fields` is missing its type argument"); }
    val owner: ty.TypeId = lower.expr_type_of(ctx, targ);

    val name_r: Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, src, ce.var_name);
    if (is_err[intern.StrId, str](name_r)) { ret err[bool, str](unwrap_err[intern.StrId, str](name_r)); }
    val fname: intern.StrId = unwrap_ok[intern.StrId, str](name_r);

    val n: u32 = ty.field_count(?ctx.s.types, owner);
    var i: u32 = 0;
    for (i < n) {
        val mark: comptime.FrameMark = comptime.frame_open(ctx.ctx);
        val br: Result[bool, str] = comptime.bind(ctx.ctx, fname, comptime.field_value(owner::u32, i));
        if (is_err[bool, str](br)) {
            val cc: Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
            if (is_err[bool, str](cc)) { ret cc; }
            ret br;
        }
        val rb: Result[bool, str] = lower_stmt_list(ctx, ce.body_start, ce.body_len);
        val cc: Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
        if (is_err[bool, str](rb)) { ret rb; }
        if (is_err[bool, str](cc)) { ret cc; }
        i = i + 1;
    }
    ret ok[bool, str](true);
}

# lowers a pack `$each a in va { body }` (#1475) by unrolling it over the pack
# instance's expanded elements (lower_pack_instance recorded the element slots and
# types on the context). per element: the loop variable is bound in the comptime
# frame to the element's descriptor — carrying the element's type (so the body
# re-infers the loop variable to it) and its ordinal (so a body reference loads the
# matching expanded parameter slot) — then the body is re-typed for that element
# and lowered. typing and lowering interleave per element because a pack element's
# type is fixed only at the call site; the body was deferred at the original sema
# pass. the re-traverse-no-clone model mirrors the `$fields` unroll.
fun lower_pack_each(ctx: *lower.LowerContext, ce: *astmt.StmtComptimeEach) Result[bool, str] {
    val src: str = lower.module_source(ctx);
    val name_r: Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, src, ce.var_name);
    if (is_err[intern.StrId, str](name_r)) { ret err[bool, str](unwrap_err[intern.StrId, str](name_r)); }
    val fname: intern.StrId = unwrap_ok[intern.StrId, str](name_r);

    # one typing-snapshot set spanning every module, so the per-element body
    # re-inference can resolve cross-module references the pack body makes (a call
    # to a function in another module needs that module's signature types). built
    # once here and shared across the element iterations.
    val deps_r: Result[sema.SemaDeps, str] = sema.collect_module_deps(ctx.s);
    if (is_err[sema.SemaDeps, str](deps_r)) { ret err[bool, str](unwrap_err[sema.SemaDeps, str](deps_r)); }
    var deps: sema.SemaDeps = unwrap_ok[sema.SemaDeps, str](deps_r);

    var i: u32 = 0;
    for (i < ctx.pack_len) {
        val mark: comptime.FrameMark = comptime.frame_open(ctx.ctx);
        val desc: comptime.CTValue = comptime.pack_elem_value(i, ctx.pack_types[i]::u32);
        val br: Result[bool, str] = comptime.bind(ctx.ctx, fname, desc);
        if (is_err[bool, str](br)) {
            val cc: Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
            sema.free_module_deps(ctx.s, ?deps);
            if (is_err[bool, str](cc)) { ret cc; }
            ret br;
        }

        # re-type the body for this element (its type is fixed only here), writing
        # the body expressions' types into the shared array lowering reads next.
        val ir: Result[bool, str] = sema.reinfer_pack_each_body(ctx.s, ctx.a, ctx.rr, ?deps, ctx.ctx,
            ctx.own_module, ctx.sema_result, ctx.pack_ret_ty, ce.body_start, ce.body_len);
        if (is_err[bool, str](ir)) {
            val cc: Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
            sema.free_module_deps(ctx.s, ?deps);
            if (is_err[bool, str](cc)) { ret cc; }
            ret ir;
        }

        val rb: Result[bool, str] = lower_stmt_list(ctx, ce.body_start, ce.body_len);
        val cc: Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
        if (is_err[bool, str](rb)) { sema.free_module_deps(ctx.s, ?deps); ret rb; }
        if (is_err[bool, str](cc)) { sema.free_module_deps(ctx.s, ?deps); ret cc; }
        i = i + 1;
    }
    sema.free_module_deps(ctx.s, ?deps);
    ret ok[bool, str](true);
}

# true when a semantic type is a comptime variadic pack (TYPE_PACK), the marker
# that selects the pack unroll over the `$fields` unroll in lower_comptime_each.
fun is_pack_type(ctx: *lower.LowerContext, t: ty.TypeId) bool {
    val to: Option[*ty.Type] = ty.get(?ctx.s.types, t);
    if (is_none[*ty.Type](to)) { ret false; }
    ret unwrap[*ty.Type](to).kind == ty.TYPE_PACK;
}

# true when the builder's current block already has a terminator. used to
# avoid emitting a second terminator (which the builder refuses) and to skip
# unreachable trailing statements.
fun block_terminated(ctx: *lower.LowerContext) bool {
    if (ctx.builder.fn == nil) { ret false; }
    val b: ir.BlockId = ctx.builder.block;
    if (b == ir.BLOCK_NIL) { ret false; }
    if (b >= ctx.builder.fn.block_count) { ret false; }
    ret ctx.builder.fn.blocks[b].terminator != ir.INSTR_NIL;
}

# true when an IR type is the void type.
fun is_void(ctx: *lower.LowerContext, tid: ir_type.IrTypeId) bool {
    val t_opt: Option[*ir_type.IrType] = ir_type.get(?ctx.m.types, tid);
    if (is_none[*ir_type.IrType](t_opt)) { ret true; }
    ret unwrap[*ir_type.IrType](t_opt).kind == ir_type.IRT_VOID;
}

# truthiness of a comptime value for `$if` arm selection.
fun ct_truthy(v: comptime.CTValue) bool {
    if (v.kind == comptime.CT_KIND_BOOL) { ret v.data.b; }
    if (v.kind == comptime.CT_KIND_INT)  { ret v.data.i != 0; }
    ret false;
}

# the resolved SymbolId bound to a decl, or SYMBOL_NIL.
fun decl_symbol_of(ctx: *lower.LowerContext, did: aid.DeclId) resolve.SymbolId {
    if (did == aid.DECL_NIL) { ret resolve.SYMBOL_NIL; }
    if (did::usize >= ctx.rr.decl_count) { ret resolve.SYMBOL_NIL; }
    ret ctx.rr.decl_symbol[did];
}

