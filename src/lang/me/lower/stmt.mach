# per-statement lowering from the AST into the middle-end IR
#
# Drives control-flow emission: every branching or looping construct creates
# the blocks it needs and stitches the predecessor edges through the IR
# builder's terminator emitters.
#
# After a statement that produces a terminator (a `ret`, an exhaustive `if`/`or`
# chain, an infinite `for`), the builder cursor is left on a fresh, unreachable
# block so the caller's next statement lands somewhere valid; `dce` drops the
# dead block later. The `fin` stack records deferred bodies that are replayed
# (lowered inline) before every reachable terminator that closes the enclosing
# scope.

use std.collections.map;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.char.char;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.fe.ast.decl;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.stmt;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema;
use mach.lang.fe.token;
use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.ir.builder;
use ir_type: mach.lang.me.ir.type;
use mach.lang.me.ir.value;
use mach.lang.me.lower.context;
use mach.lang.me.lower.expr;
use mach.lang.source;
use mach.lang.type;

# initial / doubling capacity for an inline-asm body's `{name}` binding array
val ASM_BIND_INIT_CAP: u32 = 4;

# lower one statement, dispatching on its kind
# ---
# ctx: per-module lowering context
# sid: AST statement to lower
# ret: true on success, or an error
pub fun lower_stmt(ctx: *context.LowerContext, sid: id.StmtId) R.Result[bool, str] {
    val opt_stmt: O.Option[*stmt.Stmt] = ast.get_stmt(ctx.a, sid);
    if (O.is_none[*stmt.Stmt](opt_stmt)) {
        ret R.err[bool, str]("lower: statement id out of range");
    }
    val s: *stmt.Stmt     = O.unwrap[*stmt.Stmt](opt_stmt);

    # point the debug-location cursor at this statement, restoring the caller's on
    # exit so a nested statement never leaks its location to the enclosing scope.
    val saved_loc: source.SrcLoc = builder.current_loc(?ctx.builder);
    builder.set_loc(?ctx.builder, source.loc(ctx.a.file_id, s.span.offset));
    fin { builder.set_loc(?ctx.builder, saved_loc); }

    val k: stmt.StmtKind  = s.kind;

    if (k == stmt.STMT_KIND_EXPR)          { ret lower_expr_stmt(ctx, s); }
    if (k == stmt.STMT_KIND_BLOCK)         { ret lower_block(ctx, s); }
    if (k == stmt.STMT_KIND_IF)            { ret lower_if(ctx, s); }
    if (k == stmt.STMT_KIND_FOR)           { ret lower_for(ctx, s); }
    if (k == stmt.STMT_KIND_RET)           { ret lower_ret(ctx, s); }
    if (k == stmt.STMT_KIND_BRK)           { ret lower_brk(ctx); }
    if (k == stmt.STMT_KIND_CNT)           { ret lower_cnt(ctx); }
    if (k == stmt.STMT_KIND_FIN)           { ret lower_fin(ctx, s); }
    if (k == stmt.STMT_KIND_DECL)          { ret lower_decl_stmt(ctx, s); }
    if (k == stmt.STMT_KIND_ASM)           { ret lower_asm(ctx, s); }
    if (k == stmt.STMT_KIND_COMPTIME_IF)   { ret lower_comptime_if(ctx, s); }
    if (k == stmt.STMT_KIND_COMPTIME_EACH) { ret lower_comptime_each(ctx, s); }

    # a comptime directive (`$error(...)`) is compile-time-only and emits no IR;
    # a reached `$error` already failed the build at sema.
    if (k == stmt.STMT_KIND_COMPTIME_ATTR) { ret R.ok[bool, str](true); }

    # an error statement must never reach lowering: the driver aborts on
    # accumulated diagnostics before the middle end runs.
    if (k == stmt.STMT_KIND_ERROR) {
        ret R.err[bool, str]("lower: error statement reached the middle end");
    }

    ret R.err[bool, str]("lower: unsupported statement kind");
}

# lower a run of statements (`start`..`start+len` in `ast.stmt_ids`)
#
# The common body shape for blocks, loop bodies, and arm bodies. Stops early
# once the current block is terminated, since further statements are
# unreachable and are dropped here rather than emitted into a dead block.
# ---
# ctx:   the context
# start: start index into `ast.stmt_ids`
# len:   number of statements
# ret:   true on success, or an error
pub fun lower_stmt_list(ctx: *context.LowerContext, start: u32, len: u32) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < len) {
        if (block_terminated(ctx)) { ret R.ok[bool, str](true); }
        val pool_ix: u32 = start + i;
        if (pool_ix::usize >= ctx.a.stmt_id_len) {
            ret R.err[bool, str]("lower: statement list index out of range");
        }
        val res_stmt: R.Result[bool, str] = lower_stmt(ctx, ctx.a.stmt_ids[pool_ix]);
        if (R.is_err[bool, str](res_stmt)) { ret res_stmt; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# lower an expression statement, discarding its value
# ---
# ctx: the context
# s:   the expression statement
# ret: true on success, or an error
fun lower_expr_stmt(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val res_value: R.Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.expr.expr);
    if (R.is_err[value.Value, str](res_value)) {
        ret R.err[bool, str](R.unwrap_err[value.Value, str](res_value));
    }
    ret R.ok[bool, str](true);
}

# lower a block statement by lowering its statement list
# ---
# ctx: the context
# s:   the block statement
# ret: true on success, or an error
fun lower_block(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    ret lower_stmt_list(ctx, s.data.block.stmts_start, s.data.block.stmts_len);
}

# lower an `if`/`or` chain into a cbr diamond
#
# The parser folds the `or` chain into `else_block`, so a chained `if` is just
# an `IF` whose else block holds the next `if`. Each arm lowers into its own
# block; the merge block receives an edge from each non-terminated arm. No phis
# are emitted here -- mem2reg inserts them for variables mutated across arms.
# ---
# ctx: the context
# s:   the `if` statement
# ret: true on success, or an error
fun lower_if(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val res_cond: R.Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.if_.cond);
    if (R.is_err[value.Value, str](res_cond)) {
        ret R.err[bool, str](R.unwrap_err[value.Value, str](res_cond));
    }
    val cond: value.Value = R.unwrap_ok[value.Value, str](res_cond);

    val res_then: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_then)) {
        ret R.err[bool, str](R.unwrap_err[ir.BlockId, str](res_then));
    }
    val then_b: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_then);

    val res_else: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_else)) {
        ret R.err[bool, str](R.unwrap_err[ir.BlockId, str](res_else));
    }
    val else_b: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_else);

    val res_merge: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_merge)) {
        ret R.err[bool, str](R.unwrap_err[ir.BlockId, str](res_merge));
    }
    val merge_b: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_merge);

    val has_else: bool = s.data.if_.else_block != id.STMT_NIL;

    val res_cbr: R.Result[bool, str] = builder.emit_cbr(?ctx.builder, cond, then_b, else_b);
    if (R.is_err[bool, str](res_cbr)) { ret res_cbr; }

    builder.set_block(?ctx.builder, then_b);
    val res_then_body: R.Result[bool, str] = lower_stmt(ctx, s.data.if_.then_block);
    if (R.is_err[bool, str](res_then_body)) { ret res_then_body; }
    if (!block_terminated(ctx)) {
        val res_br: R.Result[bool, str] = builder.emit_br(?ctx.builder, merge_b);
        if (R.is_err[bool, str](res_br)) { ret res_br; }
    }

    builder.set_block(?ctx.builder, else_b);
    if (has_else) {
        val res_else_body: R.Result[bool, str] = lower_stmt(ctx, s.data.if_.else_block);
        if (R.is_err[bool, str](res_else_body)) { ret res_else_body; }
    }
    if (!block_terminated(ctx)) {
        val res_br: R.Result[bool, str] = builder.emit_br(?ctx.builder, merge_b);
        if (R.is_err[bool, str](res_br)) { ret res_br; }
    }

    builder.set_block(?ctx.builder, merge_b);
    ret R.ok[bool, str](true);
}

# lower a `for` loop
#
# An absent condition is an infinite loop (the header branches straight to the
# body). A present condition lowers to a cbr in the header that exits to the
# loop-exit block. The body's last block branches back to the header (the
# back-edge); `brk` / `cnt` use the loop frame.
# ---
# ctx: the context
# s:   the `for` statement
# ret: true on success, or an error
fun lower_for(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val res_header: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_header)) {
        ret R.err[bool, str](R.unwrap_err[ir.BlockId, str](res_header));
    }
    val header: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_header);

    val res_body: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_body)) {
        ret R.err[bool, str](R.unwrap_err[ir.BlockId, str](res_body));
    }
    val body: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_body);

    val res_exit: R.Result[ir.BlockId, str] = builder.new_block(?ctx.builder);
    if (R.is_err[ir.BlockId, str](res_exit)) {
        ret R.err[bool, str](R.unwrap_err[ir.BlockId, str](res_exit));
    }
    val exit: ir.BlockId = R.unwrap_ok[ir.BlockId, str](res_exit);

    # enter the loop from the current block
    val res_enter: R.Result[bool, str] = builder.emit_br(?ctx.builder, header);
    if (R.is_err[bool, str](res_enter)) { ret res_enter; }

    # header: branch to the body unconditionally (infinite) or by condition
    builder.set_block(?ctx.builder, header);
    if (s.data.for_.cond == id.EXPR_NIL) {
        val res_br: R.Result[bool, str] = builder.emit_br(?ctx.builder, body);
        if (R.is_err[bool, str](res_br)) { ret res_br; }
    } or {
        val res_cond: R.Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.for_.cond);
        if (R.is_err[value.Value, str](res_cond)) {
            ret R.err[bool, str](R.unwrap_err[value.Value, str](res_cond));
        }
        val cond: value.Value = R.unwrap_ok[value.Value, str](res_cond);
        val res_cbr: R.Result[bool, str] = builder.emit_cbr(?ctx.builder, cond, body, exit);
        if (R.is_err[bool, str](res_cbr)) { ret res_cbr; }
    }

    val res_push: R.Result[bool, str] = context.push_loop(ctx, header, exit);
    if (R.is_err[bool, str](res_push)) { ret res_push; }

    builder.set_block(?ctx.builder, body);
    val res_body_stmt: R.Result[bool, str] = lower_stmt(ctx, s.data.for_.body);
    if (R.is_err[bool, str](res_body_stmt)) {
        context.pop_loop(ctx);
        ret res_body_stmt;
    }
    if (!block_terminated(ctx)) {
        val res_back: R.Result[bool, str] = builder.emit_br(?ctx.builder, header);
        if (R.is_err[bool, str](res_back)) {
            context.pop_loop(ctx);
            ret res_back;
        }
    }

    context.pop_loop(ctx);

    # continue lowering after the loop in the exit block
    builder.set_block(?ctx.builder, exit);
    ret R.ok[bool, str](true);
}

# lower a return
#
# Replays the pending fin bodies (innermost first), then emits the `ret`
# terminator. A bare `ret` in a value-returning function returns a typed zero
# of the function's IR return type so the IR stays well-typed.
# ---
# ctx: the context
# s:   the `ret` statement
# ret: true on success, or an error
fun lower_ret(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val res_fins: R.Result[bool, str] = run_fins(ctx);
    if (R.is_err[bool, str](res_fins)) { ret res_fins; }
    if (block_terminated(ctx))         { ret R.ok[bool, str](true); }

    if (s.data.ret_.value != id.EXPR_NIL) {
        val res_value: R.Result[value.Value, str] = expr.lower_rvalue(ctx, s.data.ret_.value);
        if (R.is_err[value.Value, str](res_value)) {
            ret R.err[bool, str](R.unwrap_err[value.Value, str](res_value));
        }
        ret builder.emit_ret(?ctx.builder, R.unwrap_ok[value.Value, str](res_value));
    }

    # bare ret: void when the function returns void, else a typed zero of ret_type
    if (is_void(ctx, ctx.ret_type)) {
        ret builder.emit_ret_void(?ctx.builder);
    }
    ret builder.emit_ret(?ctx.builder, zero_const(ctx, ctx.ret_type));
}

# lower a `brk` as a branch to the current loop's exit block
# ---
# ctx: the context
# ret: true on success, or an error when outside a loop
fun lower_brk(ctx: *context.LowerContext) R.Result[bool, str] {
    val lf: *context.LoopFrame = context.current_loop(ctx);
    if (lf == nil) { ret R.err[bool, str]("lower: brk outside a loop"); }
    ret builder.emit_br(?ctx.builder, lf.exit);
}

# lower a `cnt` as a branch to the current loop's header block
# ---
# ctx: the context
# ret: true on success, or an error when outside a loop
fun lower_cnt(ctx: *context.LowerContext) R.Result[bool, str] {
    val lf: *context.LoopFrame = context.current_loop(ctx);
    if (lf == nil) { ret R.err[bool, str]("lower: cnt outside a loop"); }
    ret builder.emit_br(?ctx.builder, lf.header);
}

# record a deferred `fin` body on the fin stack
#
# The body is replayed before every reachable terminator that closes the
# enclosing function scope (currently at each `ret` and at fall-through exit).
# ---
# ctx: the context
# s:   the `fin` statement
# ret: true on success, or an error
fun lower_fin(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    ret context.push_fin(ctx, s.data.fin_.body);
}

# replay every pending fin body in reverse registration order (innermost first)
#
# Called immediately before a `ret` and at function fall-through. Exposed for
# the decl lowerer's default-return path.
# ---
# ctx: the context
# ret: true on success, or an error
pub fun run_fins(ctx: *context.LowerContext) R.Result[bool, str] {
    val n: u32 = context.fin_count(ctx);
    if (n == 0) { ret R.ok[bool, str](true); }
    var i: u32 = n;
    for (i > 0) {
        i = i - 1;
        if (block_terminated(ctx)) { ret R.ok[bool, str](true); }
        val body: id.StmtId = context.fin_at(ctx, i);
        if (body != id.STMT_NIL) {
            val res_body: R.Result[bool, str] = lower_stmt(ctx, body);
            if (R.is_err[bool, str](res_body)) { ret res_body; }
        }
    }
    ret R.ok[bool, str](true);
}

# lower a local `val` / `var`
#
# Allocate a stack slot, store the initial value if present, and bind the
# source SymbolId to the slot pointer so later reads / writes lower to load /
# store. mem2reg promotes the slot. An uninitialized binding is zero-filled:
# an aggregate slot with a sized OP_MEMZERO, a scalar / pointer / float slot
# with a typed zero store that mem2reg promotes and dce drops when the local is
# never read, so zeroing never pessimizes a scalar local.
# ---
# ctx: the context
# s:   the decl statement
# ret: true on success, or an error
fun lower_decl_stmt(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val did: id.DeclId = s.data.decl.decl;
    val opt_decl: O.Option[*decl.Decl] = ast.get_decl(ctx.a, did);
    if (O.is_none[*decl.Decl](opt_decl)) {
        ret R.err[bool, str]("lower: local decl id out of range");
    }
    val d: *decl.Decl = O.unwrap[*decl.Decl](opt_decl);

    # a nested rec / def / use at statement scope contributes no runtime code
    if (d.kind != decl.DECL_KIND_VAL && d.kind != decl.DECL_KIND_VAR) {
        ret R.ok[bool, str](true);
    }

    val res_slot_ty: R.Result[ir_type.IrTypeId, str] = context.lower_type(ctx, context.decl_type_of(ctx, did));
    if (R.is_err[ir_type.IrTypeId, str](res_slot_ty)) {
        ret R.err[bool, str](R.unwrap_err[ir_type.IrTypeId, str](res_slot_ty));
    }
    val slot_ty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_slot_ty);

    val res_count_ty: R.Result[ir_type.IrTypeId, str] = ir_type.intern_int(?ctx.m.types, 64);
    if (R.is_err[ir_type.IrTypeId, str](res_count_ty)) {
        ret R.err[bool, str](R.unwrap_err[ir_type.IrTypeId, str](res_count_ty));
    }
    val count_ty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](res_count_ty);

    val res_slot: R.Result[value.Value, str] = builder.emit_alloca(?ctx.builder, slot_ty, value.const_int(1, count_ty));
    if (R.is_err[value.Value, str](res_slot)) {
        ret R.err[bool, str](R.unwrap_err[value.Value, str](res_slot));
    }
    val slot: value.Value = R.unwrap_ok[value.Value, str](res_slot);

    val sym: resolve.SymbolId = decl_symbol_of(ctx, did);
    val res_bind: R.Result[bool, str] = context.bind_local(ctx, sym, slot);
    if (R.is_err[bool, str](res_bind)) { ret res_bind; }

    # the value the variable initially holds, used to birth its debug value under
    # -g: the initializer for an explicit binding, the storage pointer for a
    # zero-filled aggregate (an aggregate value IS its storage), the zero constant
    # for a scalar.
    var birth_val: value.Value;

    if (d.data.bind.init != id.EXPR_NIL) {
        val res_init: R.Result[value.Value, str] = expr.lower_rvalue(ctx, d.data.bind.init);
        if (R.is_err[value.Value, str](res_init)) {
            ret R.err[bool, str](R.unwrap_err[value.Value, str](res_init));
        }
        val init: value.Value = R.unwrap_ok[value.Value, str](res_init);
        val res_store: R.Result[bool, str] = builder.emit_store(?ctx.builder, init, slot);
        if (R.is_err[bool, str](res_store)) { ret res_store; }
        birth_val = init;
    }
    or (ir_type.is_aggregate(?ctx.m.types, slot_ty)) {
        val res_mz: R.Result[bool, str] = builder.emit_memzero(?ctx.builder, slot, slot_ty);
        if (R.is_err[bool, str](res_mz)) { ret res_mz; }
        birth_val = slot;
    }
    or {
        val zc: value.Value = zero_const(ctx, slot_ty);
        val res_store: R.Result[bool, str] = builder.emit_store(?ctx.builder, zc, slot);
        if (R.is_err[bool, str](res_store)) { ret res_store; }
        birth_val = zc;
    }

    # debug birth: bind the source variable to the value it currently holds. only
    # under -g, so a non-debug build emits identical code.
    if (ctx.s.debug) {
        ret emit_dbg_birth(ctx, d.data.bind.name, slot_ty, birth_val);
    }
    ret R.ok[bool, str](true);
}

# emit an OP_DBG_VALUE binding the source variable named by `name_span` (type
# `ty`) to `val_v`, its current value
#
# Interns the variable's source name and records the debug value in the current
# function. Scope is the function body (0) for now; the location-emitter tiers
# build the scope tree. Callers gate this on `ctx.s.debug`.
# ---
# ctx:       the context
# name_span: source span of the variable's identifier
# ty:        the variable's IR type
# val_v:     the value the variable currently holds
# ret:       true on success, or an error
fun emit_dbg_birth(ctx: *context.LowerContext, name_span: token.Span, ty: ir_type.IrTypeId, val_v: value.Value) R.Result[bool, str] {
    val res_name: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, context.module_source(ctx), name_span);
    if (R.is_err[intern.StrId, str](res_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_name));
    }
    val name: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);
    ret builder.emit_dbg_value(?ctx.builder, val_v, name, ty, 0);
}

# lower an inline-asm statement
#
# Emits an OP_ASM instruction and registers its `IrAsm` payload (interned ISA
# tag + raw body) in `Function.asm_blocks`, keyed by the instruction id.
# Operand / clobber inference happens in the back end, so no operands are
# attached here.
#
# Each `{name}` reference in the body is resolved against the locals in scope
# and recorded as a `{name}` -> alloca binding so the back end can substitute
# the local's frame offset once the frame is laid out. An unknown `{name}` is a
# hard error: a mis-typed local would otherwise silently encode a bad address.
# ---
# ctx: the context
# s:   the asm statement
# ret: true on success, or an error
fun lower_asm(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val txt: str = context.module_source(ctx);

    val res_isa: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, txt, s.data.asm_.isa);
    if (R.is_err[intern.StrId, str](res_isa)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_isa));
    }
    val isa_id: intern.StrId = R.unwrap_ok[intern.StrId, str](res_isa);

    # strip `#` line comments before interning so a comment is opaque to bind
    # collection, local substitution, statement tokenization, and clobber
    # inference regardless of its bytes (a comment may hold `;`, `{`, `%`, ...).
    val span: token.Span = s.data.asm_.body;
    val res_strip: R.Result[str, str] = strip_asm_comments(ctx.s.alloc, txt, span.offset, span.len);
    if (R.is_err[str, str](res_strip)) {
        ret R.err[bool, str](R.unwrap_err[str, str](res_strip));
    }
    val stripped: str = R.unwrap_ok[str, str](res_strip);

    val res_body: R.Result[intern.StrId, str] = intern.intern_bytes(?ctx.s.interner, stripped, str_len(stripped));
    A.deallocate[u8](ctx.s.alloc, stripped::*u8, span.len + 1);
    if (R.is_err[intern.StrId, str](res_body)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_body));
    }
    val body_id: intern.StrId = R.unwrap_ok[intern.StrId, str](res_body);

    var payload: ir.IrAsm;
    payload.isa        = isa_id;
    payload.body       = body_id;
    payload.binds      = nil;
    payload.bind_count = 0;
    payload.bind_cap   = 0;

    val res_binds: R.Result[bool, str] = collect_asm_binds(ctx, body_id, s.data.asm_.body, ?payload);
    if (R.is_err[bool, str](res_binds)) {
        asm_payload_free(ctx, ?payload);
        ret res_binds;
    }

    val res_emit: R.Result[ir.InstructionId, str] = builder.emit_asm(?ctx.builder, nil, 0);
    if (R.is_err[ir.InstructionId, str](res_emit)) {
        asm_payload_free(ctx, ?payload);
        ret R.err[bool, str](R.unwrap_err[ir.InstructionId, str](res_emit));
    }
    val asm_iid: ir.InstructionId = R.unwrap_ok[ir.InstructionId, str](res_emit);

    val res_put: R.Result[bool, str] = map.insert[ir.InstructionId, ir.IrAsm](?ctx.builder.fn.asm_blocks, asm_iid, payload);
    if (R.is_err[bool, str](res_put)) {
        asm_payload_free(ctx, ?payload);
        ret res_put;
    }
    ret R.ok[bool, str](true);
}

# lower a statement-scope `$if` chain
#
# Evaluates each arm's condition with the comptime evaluator and lowers only
# the first arm whose condition is true (or the final unconditional `$or` arm).
# Inactive arms emit nothing.
# ---
# ctx: the context
# s:   the comptime-if statement
# ret: true on success, or an error
fun lower_comptime_if(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val txt: str = context.module_source(ctx);
    var i: u32 = 0;
    for (i < s.data.comptime_if.branches_len) {
        val branch_ix: u32 = s.data.comptime_if.branches_start + i;
        if (branch_ix::usize >= ctx.a.comptime_branch_len) {
            ret R.err[bool, str]("lower: comptime branch index out of range");
        }
        val branch: *decl.ComptimeBranch = ?ctx.a.comptime_branches[branch_ix];

        var active: bool = false;
        if (branch.cond == id.EXPR_NIL) {
            active = true;
        } or {
            val res_eval: R.Result[comptime.CTValue, str] = comptime.eval(ctx.ctx, ctx.a, txt, branch.cond, ?ctx.s.interner);
            if (R.is_err[comptime.CTValue, str](res_eval)) {
                ret R.err[bool, str](R.unwrap_err[comptime.CTValue, str](res_eval));
            }
            active = ct_truthy(R.unwrap_ok[comptime.CTValue, str](res_eval));
        }

        if (active) {
            ret lower_stmt_list(ctx, branch.body_start, branch.body_len);
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# lower a `$each <ident> in $fields(T) { body }` by unrolling it
#
# The body is lowered once per field of T, with the loop variable bound in the
# comptime frame to that field's descriptor, so a `v.[f]` in the body projects
# the concrete field of each iteration. The lowering half mirrors the splice
# sema. The owning type was resolved and recorded on the `$fields(T)` argument
# by sema, except when T is a generic type param -- in that case the unroll was
# deferred to monomorphization, and the concrete type is substituted here.
# ---
# ctx: the context
# s:   the comptime-each statement
# ret: true on success, or an error
fun lower_comptime_each(ctx: *context.LowerContext, s: *stmt.Stmt) R.Result[bool, str] {
    val ce: *stmt.StmtComptimeEach = ?s.data.comptime_each;
    val src: str = context.module_source(ctx);

    # a pack `$each a in va`: the sequence is a variadic-pack value (not a
    # `$fields(T)` call), so unroll over the pack instance's expanded elements --
    # re-typing then lowering the body per element, the loop variable bound to each.
    if (is_pack_type(ctx, context.expr_type_of(ctx, ce.seq))) {
        ret lower_pack_each(ctx, ce);
    }

    if (!comptime.is_fields_call(ctx.a, src, ce.seq)) {
        ret R.err[bool, str]("lower: a `$each` sequence must be `$fields(T)` or a variadic pack");
    }
    val targ: id.ExprId = comptime.fields_type_arg(ctx.a, ce.seq);
    if (targ == id.EXPR_NIL) {
        ret R.err[bool, str]("lower: `$fields` is missing its type argument");
    }

    # when T was a generic type param at template sema, the unroll was deferred;
    # apply the active substitution to get the concrete record type for this instance.
    val raw_owner: type.TypeId = context.expr_type_of(ctx, targ);
    val deferred: bool = is_generic_param_type(ctx, raw_owner);
    var owner: type.TypeId = raw_owner;
    if (deferred) {
        if (ctx.subst == nil || ctx.subst_len == 0) {
            # no active substitution: this is the template body being lowered directly
            # (not an instance). the concrete $fields unroll runs per-instance instead;
            # emit nothing here, mirroring the pack path's body-skip approach.
            ret R.ok[bool, str](true);
        }
        owner = context.substitute_type(ctx, raw_owner);
        if (!is_fields_record_type(ctx, owner)) {
            diagnostic.error(?ctx.s.diags, ctx.a.file_id, s.span,
                "$fields(T): type argument instantiated as a non-record type");
            ret R.err[bool, str](context.REPORTED);
        }
    }

    val res_name: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, src, ce.var_name);
    if (R.is_err[intern.StrId, str](res_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_name));
    }
    val fname: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);

    # build a module-spanning typing snapshot for deferred body re-inference;
    # mirrors the pack case -- the body was not typed at template sema.
    var deps: sema.SemaDeps;
    if (deferred) {
        val res_deps: R.Result[sema.SemaDeps, str] = sema.collect_module_deps(ctx.s);
        if (R.is_err[sema.SemaDeps, str](res_deps)) {
            ret R.err[bool, str](R.unwrap_err[sema.SemaDeps, str](res_deps));
        }
        deps = R.unwrap_ok[sema.SemaDeps, str](res_deps);
    }

    val n: u32 = type.field_count(?ctx.s.types, owner);
    var i: u32 = 0;
    for (i < n) {
        val mark: comptime.FrameMark = comptime.frame_open(ctx.ctx);
        val res_bind: R.Result[bool, str] = comptime.bind(ctx.ctx, fname, comptime.field_value(owner::u32, i));
        if (R.is_err[bool, str](res_bind)) {
            val res_close: R.Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
            if (deferred)                       { sema.free_module_deps(ctx.s, ?deps); }
            if (R.is_err[bool, str](res_close)) { ret res_close; }
            ret res_bind;
        }
        if (deferred) {
            # re-type the body for this field (deferred at template sema), writing
            # expression types into the shared array lowering reads next.
            val res_reinfer: R.Result[bool, str] = sema.reinfer_pack_each_body(ctx.s, ctx.a, ctx.rr, ?deps, ctx.ctx,
                ctx.own_module, ctx.sema_result, ctx.fn_ret_sem, ce.body_start, ce.body_len);
            if (R.is_err[bool, str](res_reinfer)) {
                val res_close: R.Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
                sema.free_module_deps(ctx.s, ?deps);
                if (R.is_err[bool, str](res_close)) { ret res_close; }
                ret res_reinfer;
            }
        }
        val res_body: R.Result[bool, str] = lower_stmt_list(ctx, ce.body_start, ce.body_len);
        val res_close: R.Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
        if (R.is_err[bool, str](res_body)) {
            if (deferred) { sema.free_module_deps(ctx.s, ?deps); }
            ret res_body;
        }
        if (R.is_err[bool, str](res_close)) {
            if (deferred) { sema.free_module_deps(ctx.s, ?deps); }
            ret res_close;
        }
        i = i + 1;
    }
    if (deferred) { sema.free_module_deps(ctx.s, ?deps); }
    ret R.ok[bool, str](true);
}

# lower a pack `$each a in va { body }` by unrolling over the pack's elements
#
# `lower_pack_instance` recorded the element slots and types on the context. Per
# element: the loop variable is bound in the comptime frame to the element's
# descriptor -- carrying the element's type (so the body re-infers the loop
# variable to it) and its ordinal (so a body reference loads the matching
# expanded parameter slot) -- then the body is re-typed for that element and
# lowered. Typing and lowering interleave per element because a pack element's
# type is fixed only at the call site; the body was deferred at the original
# sema pass. The re-traverse-no-clone model mirrors the `$fields` unroll.
# ---
# ctx: the context
# ce:  the comptime-each descriptor
# ret: true on success, or an error
fun lower_pack_each(ctx: *context.LowerContext, ce: *stmt.StmtComptimeEach) R.Result[bool, str] {
    val src: str = context.module_source(ctx);
    val res_name: R.Result[intern.StrId, str] = intern.intern_span(?ctx.s.interner, src, ce.var_name);
    if (R.is_err[intern.StrId, str](res_name)) {
        ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_name));
    }
    val fname: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);

    # one typing-snapshot set spanning every module, so the per-element body
    # re-inference can resolve cross-module references the pack body makes (a call
    # to a function in another module needs that module's signature types). built
    # once here and shared across the element iterations.
    val res_deps: R.Result[sema.SemaDeps, str] = sema.collect_module_deps(ctx.s);
    if (R.is_err[sema.SemaDeps, str](res_deps)) {
        ret R.err[bool, str](R.unwrap_err[sema.SemaDeps, str](res_deps));
    }
    var deps: sema.SemaDeps = R.unwrap_ok[sema.SemaDeps, str](res_deps);

    var i: u32 = 0;
    for (i < ctx.pack_len) {
        val mark: comptime.FrameMark = comptime.frame_open(ctx.ctx);
        val desc: comptime.CTValue = comptime.pack_elem_value(i, ctx.pack_types[i]::u32);
        val res_bind: R.Result[bool, str] = comptime.bind(ctx.ctx, fname, desc);
        if (R.is_err[bool, str](res_bind)) {
            val res_close: R.Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
            sema.free_module_deps(ctx.s, ?deps);
            if (R.is_err[bool, str](res_close)) { ret res_close; }
            ret res_bind;
        }

        # re-type the body for this element (its type is fixed only here), writing
        # the body expressions' types into the shared array lowering reads next.
        val res_reinfer: R.Result[bool, str] = sema.reinfer_pack_each_body(ctx.s, ctx.a, ctx.rr, ?deps, ctx.ctx,
            ctx.own_module, ctx.sema_result, ctx.pack_ret_type, ce.body_start, ce.body_len);
        if (R.is_err[bool, str](res_reinfer)) {
            val res_close: R.Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
            sema.free_module_deps(ctx.s, ?deps);
            if (R.is_err[bool, str](res_close)) { ret res_close; }
            ret res_reinfer;
        }

        val res_body: R.Result[bool, str] = lower_stmt_list(ctx, ce.body_start, ce.body_len);
        val res_close: R.Result[bool, str] = comptime.frame_close(ctx.ctx, mark);
        if (R.is_err[bool, str](res_body)) {
            sema.free_module_deps(ctx.s, ?deps);
            ret res_body;
        }
        if (R.is_err[bool, str](res_close)) {
            sema.free_module_deps(ctx.s, ?deps);
            ret res_close;
        }
        i = i + 1;
    }
    sema.free_module_deps(ctx.s, ?deps);
    ret R.ok[bool, str](true);
}

# allocate a NUL-terminated copy of the `len`-byte asm body at `src + offset`
# with each `#` line comment removed through the end of its line
#
# The line's newline is kept so statement boundaries survive. The copy is sized
# to `len + 1` (its longest possible form) so the caller frees exactly that.
# ---
# a:      allocator for the returned copy
# src:    source text holding the asm body
# offset: byte offset of the body in `src`
# len:    byte length of the body
# ret:    the owned, NUL-terminated stripped copy, or an error
fun strip_asm_comments(a: *A.Allocator, src: str, offset: usize, len: usize) R.Result[str, str] {
    val res_buf: R.Result[*u8, str] = A.allocate[u8](a, len + 1);
    if (R.is_err[*u8, str](res_buf)) {
        ret R.err[str, str](R.unwrap_err[*u8, str](res_buf));
    }
    val out: *u8 = R.unwrap_ok[*u8, str](res_buf);

    var i: usize = 0;
    var o: usize = 0;
    for (i < len) {
        val c: u8 = src[offset + i];
        if (c == '#'::char) {
            # drop the comment through (but not including) the line's newline
            for (i < len && src[offset + i] != '\n'::char) { i = i + 1; }
            cnt;
        }
        out[o] = c;
        o = o + 1;
        i = i + 1;
    }
    out[o] = 0;
    ret R.ok[str, str](out::str);
}

# scan an inline-asm body for `{name}` references and record each as a binding
#
# A name is interned and resolved against the locals in scope; a duplicate
# `{name}` is recorded once. An unknown name, or one bound to a non-alloca
# Value, is a hard error rather than a silently dropped substitution.
# ---
# ctx:       the context
# body_id:   interned, comment-stripped asm body
# body_span: source span of the asm body, locating every diagnostic
# payload:   the `IrAsm` whose `binds` are appended
# ret:       true on success, or an error
fun collect_asm_binds(ctx: *context.LowerContext, body_id: intern.StrId, body_span: token.Span, payload: *ir.IrAsm) R.Result[bool, str] {
    val opt_body: O.Option[str] = intern.lookup(?ctx.s.interner, body_id);
    if (O.is_none[str](opt_body)) {
        ret R.err[bool, str]("lower: inline-asm body interning failed");
    }
    val body: str = O.unwrap[str](opt_body);

    var i: usize = 0;
    for (body[i] != 0) {
        if (body[i] != '{'::char) { i = i + 1; cnt; }

        # collect the name between '{' and the matching '}'
        val name_start: usize = i + 1;
        var j: usize = name_start;
        for (body[j] != 0 && body[j] != '}'::char) { j = j + 1; }
        if (body[j] == 0) {
            ret report_asm(ctx, body_span, "unterminated '{' in inline asm body");
        }
        val name_len: usize = j - name_start;
        if (name_len == 0) {
            ret report_asm(ctx, body_span, "empty '{}' in asm body; write '{name}' to reference a local");
        }

        val res_name: R.Result[intern.StrId, str] = intern.intern_bytes(?ctx.s.interner, (body::usize + name_start)::str, name_len);
        if (R.is_err[intern.StrId, str](res_name)) {
            ret R.err[bool, str](R.unwrap_err[intern.StrId, str](res_name));
        }
        val name_id: intern.StrId = R.unwrap_ok[intern.StrId, str](res_name);

        val res_add: R.Result[bool, str] = add_asm_bind(ctx, body_span, payload, name_id);
        if (R.is_err[bool, str](res_add)) { ret res_add; }

        i = j + 1;
    }
    ret R.ok[bool, str](true);
}

# resolve a single `{name}` to its local alloca and append the binding
#
# Recorded once per distinct name. The local's storage Value must be a
# VAL_INSTR naming the alloca whose slot the back end addresses; anything else
# (an unbound name, a parameter still in a register, a constant) is rejected.
# ---
# ctx:       the context
# body_span: source span of the asm body, for diagnostics
# payload:   the `IrAsm` whose `binds` are appended
# name_id:   interned `{name}` to resolve
# ret:       true on success, or an error
fun add_asm_bind(ctx: *context.LowerContext, body_span: token.Span, payload: *ir.IrAsm, name_id: intern.StrId) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < payload.bind_count) {
        if (payload.binds[i].name == name_id) { ret R.ok[bool, str](true); }
        i = i + 1;
    }

    val opt_local: O.Option[value.Value] = context.lookup_local_name(ctx, name_id);
    if (O.is_none[value.Value](opt_local)) {
        ret report_asm_named(ctx, body_span, "unknown local '", name_id, "' in inline asm; only stack-allocated variables in scope can be referenced");
    }
    val v: value.Value = O.unwrap[value.Value](opt_local);
    if (v.kind != value.VAL_INSTR) {
        ret report_asm_named(ctx, body_span, "'", name_id, "' is not stack-allocated and cannot be used in inline asm");
    }

    if (payload.bind_count == payload.bind_cap) {
        val new_cap: u32 = grow_bind_cap(payload.bind_cap);
        var nb: *ir.IrAsmBind = nil;
        if (payload.binds == nil) {
            val res_alloc: R.Result[*ir.IrAsmBind, str] = A.allocate[ir.IrAsmBind](ctx.s.alloc, new_cap::usize);
            if (R.is_err[*ir.IrAsmBind, str](res_alloc)) {
                ret R.err[bool, str](R.unwrap_err[*ir.IrAsmBind, str](res_alloc));
            }
            nb = R.unwrap_ok[*ir.IrAsmBind, str](res_alloc);
        } or {
            val res_grow: R.Result[*ir.IrAsmBind, str] = A.reallocate[ir.IrAsmBind](ctx.s.alloc, payload.binds, payload.bind_cap::usize, new_cap::usize);
            if (R.is_err[*ir.IrAsmBind, str](res_grow)) {
                ret R.err[bool, str](R.unwrap_err[*ir.IrAsmBind, str](res_grow));
            }
            nb = R.unwrap_ok[*ir.IrAsmBind, str](res_grow);
        }
        payload.binds    = nb;
        payload.bind_cap = new_cap;
    }

    payload.binds[payload.bind_count].name  = name_id;
    payload.binds[payload.bind_count].instr = v.data.instr;
    payload.bind_count = payload.bind_count + 1;
    ret R.ok[bool, str](true);
}

# release an `IrAsm` payload's binding array
# ---
# ctx:     the context
# payload: the `IrAsm` whose `binds` are freed
fun asm_payload_free(ctx: *context.LowerContext, payload: *ir.IrAsm) {
    if (payload.binds == nil) { ret; }
    A.deallocate[ir.IrAsmBind](ctx.s.alloc, payload.binds, payload.bind_cap::usize);
}

# next capacity for an asm body's `{name}` binding array, seeded then doubling
# ---
# cap: current capacity
# ret: the grown capacity
fun grow_bind_cap(cap: u32) u32 {
    if (cap == 0) { ret ASM_BIND_INIT_CAP; }
    ret cap * 2;
}

# file a located error at the asm body `span` and return the REPORTED sentinel
# so the driver shows a single file:line:col diagnostic
# ---
# ctx:     the context
# span:    source span of the asm body
# message: the diagnostic text
# ret:     the REPORTED sentinel error
fun report_asm(ctx: *context.LowerContext, span: token.Span, message: str) R.Result[bool, str] {
    diagnostic.error(?ctx.s.diags, ctx.a.file_id, span, message);
    ret R.err[bool, str](context.REPORTED);
}

# report_asm with the interned `name_id` interpolated between `prefix` and
# `suffix`; degrades to `prefix` alone on any lookup / alloc failure
# ---
# ctx:     the context
# span:    source span of the asm body
# prefix:  text before the name
# name_id: interned name to interpolate
# suffix:  text after the name
# ret:     the REPORTED sentinel error
fun report_asm_named(ctx: *context.LowerContext, span: token.Span, prefix: str, name_id: intern.StrId, suffix: str) R.Result[bool, str] {
    val opt_name: O.Option[str] = intern.lookup(?ctx.s.interner, name_id);
    if (O.is_none[str](opt_name)) { ret report_asm(ctx, span, prefix); }
    val name: str = O.unwrap[str](opt_name);

    val total: usize = str_len(prefix) + str_len(name) + str_len(suffix);
    val res_buf: R.Result[*u8, str] = A.allocate[u8](ctx.s.alloc, total + 1);
    if (R.is_err[*u8, str](res_buf)) { ret report_asm(ctx, span, prefix); }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);

    var k: usize = 0;
    k = bytes_append(buf, k, prefix);
    k = bytes_append(buf, k, name);
    k = bytes_append(buf, k, suffix);
    buf[k] = 0;

    diagnostic.error(?ctx.s.diags, ctx.a.file_id, span, buf::str);
    A.deallocate[u8](ctx.s.alloc, buf, total + 1);
    ret R.err[bool, str](context.REPORTED);
}

# copy the bytes of `src` into `dst` at offset `at`, returning the new offset
# ---
# dst: destination buffer
# at:  write offset into `dst`
# src: source string
# ret: the offset just past the copied bytes
fun bytes_append(dst: *u8, at: usize, src: str) usize {
    val n: usize = str_len(src);
    var i: usize = 0;
    for (i < n) {
        dst[at + i] = src[i];
        i = i + 1;
    }
    ret at + n;
}

# build the typed zero constant for a slot type
#
# A zero store passes the verifier's constant-typing rule (a float constant
# must carry an IRT_FLOAT type; an integer / pointer constant an IRT_INT or
# IRT_PTR type). The bit pattern is 0 in every case: 0.0 has an all-zero f64
# encoding and a null pointer is the zero address.
# ---
# ctx: the context
# tid: IR type of the slot
# ret: a zero Value carrying `tid`
fun zero_const(ctx: *context.LowerContext, tid: ir_type.IrTypeId) value.Value {
    val opt_ty: O.Option[*ir_type.IrType] = ir_type.get(?ctx.m.types, tid);
    if (O.is_some[*ir_type.IrType](opt_ty)) {
        if (O.unwrap[*ir_type.IrType](opt_ty).kind == ir_type.IRT_FLOAT) {
            ret value.const_float(0.0, tid);
        }
    }
    ret value.const_int(0, tid);
}

# true when a semantic type is a comptime variadic pack
#
# TYPE_PACK is the marker that selects the pack unroll over the `$fields` unroll
# in lower_comptime_each.
# ---
# ctx: the context
# t:   the semantic type
# ret: true when `t` is a pack type
fun is_pack_type(ctx: *context.LowerContext, t: type.TypeId) bool {
    val opt_ty: O.Option[*type.Type] = type.get(?ctx.s.types, t);
    if (O.is_none[*type.Type](opt_ty)) { ret false; }
    ret O.unwrap[*type.Type](opt_ty).kind == type.TYPE_PACK;
}

# true when `t` is an unbound generic type parameter
#
# Signals a deferred `$each $fields(T)` over a generic param that needs
# substitution at instantiation.
# ---
# ctx: the context
# t:   the semantic type
# ret: true when `t` is a generic parameter type
fun is_generic_param_type(ctx: *context.LowerContext, t: type.TypeId) bool {
    val opt_ty: O.Option[*type.Type] = type.get(?ctx.s.types, t);
    if (O.is_none[*type.Type](opt_ty)) { ret false; }
    ret O.unwrap[*type.Type](opt_ty).kind == type.TYPE_GENERIC_PARAM;
}

# true when `t` is a record or a generic record instance
#
# These are the types `$fields(T)` accepts after substitution at instantiation.
# ---
# ctx: the context
# t:   the semantic type
# ret: true when `t` is a record or record instance
fun is_fields_record_type(ctx: *context.LowerContext, t: type.TypeId) bool {
    val opt_ty: O.Option[*type.Type] = type.get(?ctx.s.types, t);
    if (O.is_none[*type.Type](opt_ty)) { ret false; }
    val k: type.TypeKind = O.unwrap[*type.Type](opt_ty).kind;
    if (k == type.TYPE_REC)                                                                            { ret true; }
    if (k == type.TYPE_INSTANCE && O.is_some[*type.FieldTable](type.field_table_for(?ctx.s.types, t))) { ret true; }
    ret false;
}

# true when the builder's current block already has a terminator
#
# Used to avoid emitting a second terminator (which the builder refuses) and to
# skip unreachable trailing statements.
# ---
# ctx: the context
# ret: true when the current block is terminated
fun block_terminated(ctx: *context.LowerContext) bool {
    if (ctx.builder.fn == nil) { ret false; }
    val b: ir.BlockId = ctx.builder.block;
    if (b == ir.BLOCK_NIL)               { ret false; }
    if (b >= ctx.builder.fn.block_count) { ret false; }
    ret ctx.builder.fn.blocks[b].terminator != ir.INSTR_NIL;
}

# true when an IR type is the void type
# ---
# ctx: the context
# tid: the IR type
# ret: true when `tid` is void (or out of range)
fun is_void(ctx: *context.LowerContext, tid: ir_type.IrTypeId) bool {
    val opt_ty: O.Option[*ir_type.IrType] = ir_type.get(?ctx.m.types, tid);
    if (O.is_none[*ir_type.IrType](opt_ty)) { ret true; }
    ret O.unwrap[*ir_type.IrType](opt_ty).kind == ir_type.IRT_VOID;
}

# truthiness of a comptime value for `$if` arm selection
# ---
# v:   the comptime value
# ret: true when `v` is a truthy bool or non-zero int
fun ct_truthy(v: comptime.CTValue) bool {
    if (v.kind == comptime.CT_KIND_BOOL) { ret v.data.b; }
    if (v.kind == comptime.CT_KIND_INT)  { ret v.data.i != 0; }
    ret false;
}

# the resolved SymbolId bound to a decl, or SYMBOL_NIL
# ---
# ctx: the context
# did: the decl
# ret: the bound SymbolId, or SYMBOL_NIL when unresolved or out of range
fun decl_symbol_of(ctx: *context.LowerContext, did: id.DeclId) resolve.SymbolId {
    if (did == id.DECL_NIL)              { ret resolve.SYMBOL_NIL; }
    if (did::usize >= ctx.rr.decl_count) { ret resolve.SYMBOL_NIL; }
    ret ctx.rr.decl_symbol[did];
}
