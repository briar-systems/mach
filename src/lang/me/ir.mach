# mach.lang.me.ir: SSA-form IR data model, the spine the middle end builds
# and the back end consumes.
#
# A `Module` owns `Function`s, each owning `Block`s, each owning an
# ordered list of `InstructionId`s; instruction operands are `Value`s.
# IR-level types (`me.ir.type`) are distinct from the semantic `lang.type`
# universe: by the time IR exists, generics, comptime, instances and aliases
# are gone. Exactly one IR `Module` is produced per source module.
#
# This file is the public surface of `me.ir`: it defines the container
# records and re-exports the leaf id types so downstream code can spell them
# as `ir.BlockId` / `ir.InstructionId` / `ir.BLOCK_NIL` / `ir.INSTR_NIL`.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_none;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use map: std.collections.map;

use intern:  mach.lang.intern;
use ir_type: mach.lang.me.ir.type;
use value:   mach.lang.me.ir.value;
use instr:   mach.lang.me.ir.instruction;
use id:      mach.lang.me.ir.id;

# re-export of the leaf id handles, so consumers use `ir.BlockId` etc.
fwd id.BlockId;
fwd id.InstructionId;
fwd id.BLOCK_NIL;
fwd id.INSTR_NIL;

# function flag bits (Function.flags is a u32 bitset).
# the function is exported from its module.
pub val FN_FLAG_PUB:      u32 = 0x01;
# the function has no body in this module (resolved at link time).
pub val FN_FLAG_EXTERN:   u32 = 0x02;
# the function is an inlining candidate / directive.
pub val FN_FLAG_INLINE:   u32 = 0x04;
# the function never returns to its caller.
pub val FN_FLAG_NORETURN: u32 = 0x08;
# the function is a test entry point (iterated by the test runner).
pub val FN_FLAG_TEST:     u32 = 0x10;
# the function is a monomorphized generic instance: emitted into every object
# that uses it under one globally-unique mangled name, and given weak linkage so
# the linker collapses the duplicate definitions to one.
pub val FN_FLAG_WEAK:     u32 = 0x20;

# one `{name}` local binding referenced by an inline-asm body: the interned
# source name and the alloca instruction that owns the local's stack slot. the
# back end resolves the alloca to a frame offset and substitutes `[rbp+off]`
# for `{name}` when it expands the asm body.
# ---
# name:  interned source local name (the text inside `{ }`)
# instr: OP_ALLOCA instruction id naming the local's storage slot
pub rec IrAsmBind {
    name:  intern.StrId;
    instr: id.InstructionId;
}

# the inline-asm payload attached to an OP_ASM instruction. kept out of the
# instruction proper (in Function.asm_blocks) so the common instruction stays small.
# matches the locked asm syntax model: an inline-asm statement is just an ISA
# tag plus a raw body span, with no structured operands (clobber / register
# inference happens in the back end against the target).
#
# `{name}` references in the body name locals in scope; their bindings are
# captured here (as alloca instruction ids) at lower time and resolved to frame
# offsets by the back end, since the frame layout is unknown until after
# register allocation.
# ---
# isa:        interned target ISA tag the body is written for
# body:       interned raw asm body text
# binds:      `{name}` -> alloca bindings referenced by the body (owned)
# bind_count: number of bindings
# bind_cap:   allocated capacity of `binds`
pub rec IrAsm {
    isa:        intern.StrId;
    body:       intern.StrId;
    binds:      *IrAsmBind;
    bind_count: u32;
    bind_cap:   u32;
}

# a basic block: an ordered instruction list ending in exactly one
# terminator, plus its phi nodes and predecessor list.
# ---
# id:           this block's BlockId within its function
# instructions: ordered non-phi instruction ids (owned)
# instr_count:  number of instructions
# instr_cap:    allocated capacity for instructions
# phis:         phi instruction ids, conceptually at block entry (owned)
# phi_count:    number of phi nodes
# phi_cap:      allocated capacity for phis
# terminator:   the block's terminator instruction id (INSTR_NIL until emitted)
# preds:        predecessor block ids (owned)
# pred_count:   number of predecessors
# pred_cap:     allocated capacity for preds
pub rec Block {
    id:           id.BlockId;

    instructions: *id.InstructionId;
    instr_count:  u32;
    instr_cap:    u32;

    phis:         *id.InstructionId;
    phi_count:    u32;
    phi_cap:      u32;

    terminator:   id.InstructionId;

    preds:        *id.BlockId;
    pred_count:   u32;
    pred_cap:     u32;
}

# a function in SSA form. block 0 is always the entry block.
# ---
# name:        interned symbol name
# sig:         IR function type (IRT_FN) describing params and return
# params:      VAL_PARAM values, one per parameter, in order (owned)
# param_count: number of parameters
# blocks:      basic blocks; blocks[0] is the entry block (owned)
# block_count: number of blocks
# block_cap:   allocated capacity for blocks
# instrs:      the function's instruction pool; InstructionId indexes here (owned)
# instr_len:   number of instructions in the pool
# instr_cap:   allocated capacity for the instruction pool
# flags:       bitwise-or of FN_FLAG_* bits
# asm_blocks:  OP_ASM instruction id -> IrAsm payload map
pub rec Function {
    name:        intern.StrId;
    sig:         ir_type.IrTypeId;

    params:      *value.Value;
    param_count: u32;

    blocks:      *Block;
    block_count: u32;
    block_cap:   u32;

    instrs:      *instr.Instruction;
    instr_len:   u32;
    instr_cap:   u32;

    flags:       u32;

    asm_blocks:  map.Map[id.InstructionId, IrAsm];
}

# a module-level global data declaration.
# ---
# name:   interned symbol name
# ty:     IR type of the global's storage
# init:   initial value; a constant Value, or a placeholder when the real
#         initializer is emitted as logic into the module's init_fn
# is_mut:    true for mutable globals (var), false for read-only (val)
# is_pub:    true when exported from the module
# is_extern: true for a global defined in another module; carries no storage
#            here and is emitted only as a relocation target (the linker binds
#            it to the defining module's object).
# is_local:  true for a compiler-synthesized anonymous data global (a string /
#            byte-blob literal), which is object-private — resolved per-object
#            and never entered into the cross-object symbol table, so two
#            modules' anonymous globals never collide. a named user global is
#            not local: its name is module-path-mangled and globally unique, so
#            it is given GLOBAL linkage and resolves cross-object.
pub rec Global {
    name:      intern.StrId;
    ty:        ir_type.IrTypeId;
    init:      value.Value;
    is_mut:    bool;
    is_pub:    bool;
    is_extern: bool;
    is_local:  bool;
}

# an IR module: one per source module.
# ---
# alloc:        allocator backing every owned array in the module
# name:         interned module FQN
# functions:    the module's functions (owned)
# function_len: number of functions
# function_cap: allocated capacity for functions
# globals:      the module's globals (owned)
# global_len:   number of globals
# global_cap:   allocated capacity for globals
# types:        the module's IR type universe
# init_fn:      some(index into functions) for the synthesized global-init
#               function, or none when the module needs no runtime init
pub rec Module {
    alloc: *Allocator;
    name:  intern.StrId;

    functions:    *Function;
    function_len: u32;
    function_cap: u32;

    globals:    *Global;
    global_len: u32;
    global_cap: u32;

    types: ir_type.IrTypeTable;

    init_fn: Option[u32];
}

val INITIAL_FN_CAP:     u32 = 8;
val INITIAL_GLOBAL_CAP: u32 = 8;

# constructs an empty IR module with an initialized type table and no
# functions, globals, or init function.
# ---
# alloc: allocator used for all owned storage in the module
# name:  interned module FQN
# ret:   a populated Module, or an allocation error
pub fun init_module(alloc: *Allocator, name: intern.StrId) Result[Module, str] {
    var m: Module;
    m.alloc = alloc;
    m.name  = name;

    m.functions    = nil;
    m.function_len = 0;
    m.function_cap = 0;
    m.globals      = nil;
    m.global_len   = 0;
    m.global_cap   = 0;
    m.init_fn      = none[u32]();

    val rt: Result[ir_type.IrTypeTable, str] = ir_type.init(alloc);
    if (is_err[ir_type.IrTypeTable, str](rt)) {
        ret err[Module, str](unwrap_err[ir_type.IrTypeTable, str](rt));
    }
    m.types = unwrap_ok[ir_type.IrTypeTable, str](rt);

    val rf: Result[*Function, str] = allocate[Function](alloc, INITIAL_FN_CAP::usize);
    if (is_err[*Function, str](rf)) {
        ir_type.dnit(?m.types);
        ret err[Module, str](unwrap_err[*Function, str](rf));
    }
    m.functions    = unwrap_ok[*Function, str](rf);
    m.function_cap = INITIAL_FN_CAP;

    val rg: Result[*Global, str] = allocate[Global](alloc, INITIAL_GLOBAL_CAP::usize);
    if (is_err[*Global, str](rg)) {
        deallocate[Function](alloc, m.functions, m.function_cap::usize);
        ir_type.dnit(?m.types);
        ret err[Module, str](unwrap_err[*Global, str](rg));
    }
    m.globals    = unwrap_ok[*Global, str](rg);
    m.global_cap = INITIAL_GLOBAL_CAP;

    ret ok[Module, str](m);
}

# releases every owned array in the module: each function's blocks and asm
# map, the function and global arrays, and the IR type table. safe on nil.
# ---
# m: the module to tear down; all owned storage is freed
pub fun dnit_module(m: *Module) {
    if (m == nil) { ret; }

    var f: u32 = 0;
    for (f < m.function_len) {
        dnit_function(m, ?m.functions[f]);
        f = f + 1;
    }

    if (m.functions != nil && m.function_cap > 0) {
        deallocate[Function](m.alloc, m.functions, m.function_cap::usize);
    }
    if (m.globals != nil && m.global_cap > 0) {
        deallocate[Global](m.alloc, m.globals, m.global_cap::usize);
    }
    ir_type.dnit(?m.types);

    m.functions    = nil;
    m.function_len = 0;
    m.function_cap = 0;
    m.globals      = nil;
    m.global_len   = 0;
    m.global_cap   = 0;
}

# frees one function's owned storage: per-block arrays, the block and param
# arrays, the instruction pool, and the asm map.
fun dnit_function(m: *Module, fn: *Function) {
    var b: u32 = 0;
    for (b < fn.block_count) {
        dnit_block(m, ?fn.blocks[b]);
        b = b + 1;
    }
    if (fn.blocks != nil && fn.block_cap > 0) {
        deallocate[Block](m.alloc, fn.blocks, fn.block_cap::usize);
    }
    if (fn.params != nil && fn.param_count > 0) {
        deallocate[value.Value](m.alloc, fn.params, fn.param_count::usize);
    }
    # release each inline-asm block's owned `{name}` binding array. every key in
    # `asm_blocks` is an OP_ASM instruction id, so iterating the instruction pool
    # reaches every payload through the public map lookup (the map exposes no
    # iterator).
    var ai: u32 = 0;
    for (ai < fn.instr_len) {
        if (fn.instrs[ai].kind == instr.OP_ASM) {
            var key: id.InstructionId = ai::id.InstructionId;
            val r: Result[*IrAsm, str] = map.get[id.InstructionId, IrAsm](?fn.asm_blocks, ?key);
            if (is_ok[*IrAsm, str](r)) {
                val pl: *IrAsm = unwrap_ok[*IrAsm, str](r);
                if (pl.binds != nil && pl.bind_cap > 0) {
                    deallocate[IrAsmBind](m.alloc, pl.binds, pl.bind_cap::usize);
                }
            }
        }
        ai = ai + 1;
    }

    var i: u32 = 0;
    for (i < fn.instr_len) {
        dnit_instruction(m, ?fn.instrs[i]);
        i = i + 1;
    }
    if (fn.instrs != nil && fn.instr_cap > 0) {
        deallocate[instr.Instruction](m.alloc, fn.instrs, fn.instr_cap::usize);
    }
    map.dnit[id.InstructionId, IrAsm](?fn.asm_blocks);
}

# frees one instruction's owned operand array. safe on a zero-operand instruction.
fun dnit_instruction(m: *Module, inst: *instr.Instruction) {
    if (inst.operands != nil && inst.operand_count > 0) {
        deallocate[value.Value](m.alloc, inst.operands, inst.operand_count::usize);
    }
}

# frees one block's owned instruction, phi, and predecessor arrays.
fun dnit_block(m: *Module, blk: *Block) {
    if (blk.instructions != nil && blk.instr_cap > 0) {
        deallocate[id.InstructionId](m.alloc, blk.instructions, blk.instr_cap::usize);
    }
    if (blk.phis != nil && blk.phi_cap > 0) {
        deallocate[id.InstructionId](m.alloc, blk.phis, blk.phi_cap::usize);
    }
    if (blk.preds != nil && blk.pred_cap > 0) {
        deallocate[id.BlockId](m.alloc, blk.preds, blk.pred_cap::usize);
    }
}

val INITIAL_INSTR_CAP: u32 = 16;

# builds a block-target operand encoding `block`, matching the IR convention
# used by the builder and read back by `block_target`: a VAL_CONST_INT carrying
# the block id, typed as the module's pointer type.
# ---
# m:     module whose type table interns the pointer type
# block: the target block id
# ret:   the encoded operand value, or an interning error
pub fun make_block_target(m: *Module, block: id.BlockId) Result[value.Value, str] {
    val rt: Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?m.types);
    if (is_err[ir_type.IrTypeId, str](rt)) {
        ret err[value.Value, str](unwrap_err[ir_type.IrTypeId, str](rt));
    }
    val pty: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](rt);
    ret ok[value.Value, str](value.const_int(block::u64, pty));
}

# appends a new empty function to the module and returns its index. the function
# carries the given name, signature, and flags, with no params, blocks, or
# instructions, and an empty inline-asm side table; the function array grows as
# needed. the single storage primitive for adding a function to a module.
# ---
# m:     module the function is appended to
# name:  interned function symbol name
# sig:   IRT_FN signature type id
# flags: bitwise-or of FN_FLAG_* bits
# ret:   the new function's index in m.functions, or an allocation error
pub fun add_function(m: *Module, name: intern.StrId, sig: ir_type.IrTypeId, flags: u32) Result[u32, str] {
    if (m.function_len == m.function_cap) {
        val new_cap: u32 = m.function_cap * 2;
        val r: Result[*Function, str] = reallocate[Function](m.alloc, m.functions, m.function_cap::usize, new_cap::usize);
        if (is_err[*Function, str](r)) { ret err[u32, str](unwrap_err[*Function, str](r)); }
        m.functions    = unwrap_ok[*Function, str](r);
        m.function_cap = new_cap;
    }
    val idx: u32 = m.function_len;
    var f: Function;
    f.name        = name;
    f.sig         = sig;
    f.params      = nil;
    f.param_count = 0;
    f.blocks      = nil;
    f.block_count = 0;
    f.block_cap   = 0;
    f.instrs      = nil;
    f.instr_len   = 0;
    f.instr_cap   = 0;
    f.flags       = flags;
    f.asm_blocks  = map.init[id.InstructionId, IrAsm](m.alloc, map.hash_u32, map.eq_u32);
    m.functions[idx] = f;
    m.function_len   = m.function_len + 1;
    ret ok[u32, str](idx);
}

# resolves an InstructionId to a borrowed pointer into the function's
# instruction pool. the single access point for every IR consumer (builder,
# verifier, printer, passes, codegen) that needs the Instruction behind an id.
# ---
# fn: the function owning the pool
# i:  an InstructionId; INSTR_NIL or out-of-range yields none
# ret: some(*Instruction) when in range, none otherwise
pub fun get_instruction(fn: *Function, i: id.InstructionId) Option[*instr.Instruction] {
    if (i == id.INSTR_NIL)    { ret none[*instr.Instruction](); }
    if (i::u32 >= fn.instr_len) { ret none[*instr.Instruction](); }
    ret some[*instr.Instruction](?fn.instrs[i::u32]);
}

# appends an instruction to a function's pool, growing it as needed, and
# returns its freshly assigned InstructionId. the instruction's `block` field
# is the caller's responsibility; this only manages pool storage and identity.
# ---
# m:    module owning the allocator
# fn:   the function whose pool receives the instruction
# inst: the instruction record to copy into the pool
# ret:  the new InstructionId, or an allocation error
pub fun add_instruction(m: *Module, fn: *Function, inst: instr.Instruction) Result[id.InstructionId, str] {
    if (fn.instr_len >= fn.instr_cap) {
        var new_cap: u32 = fn.instr_cap * 2;
        if (new_cap < INITIAL_INSTR_CAP) { new_cap = INITIAL_INSTR_CAP; }
        val r: Result[*instr.Instruction, str] =
            reallocate[instr.Instruction](m.alloc, fn.instrs, fn.instr_cap::usize, new_cap::usize);
        if (is_err[*instr.Instruction, str](r)) {
            ret err[id.InstructionId, str](unwrap_err[*instr.Instruction, str](r));
        }
        fn.instrs    = unwrap_ok[*instr.Instruction, str](r);
        fn.instr_cap = new_cap;
    }
    val iid: id.InstructionId = fn.instr_len::id.InstructionId;
    fn.instrs[fn.instr_len] = inst;
    fn.instr_len = fn.instr_len + 1;
    ret ok[id.InstructionId, str](iid);
}

val INITIAL_BLOCK_LIST_CAP: u32 = 4;

# appends an InstructionId to a block's body instruction list (excludes phis
# and the terminator), growing the list as needed.
# ---
# m:   module owning the allocator
# blk: block whose body receives the instruction id
# i:   the instruction id to append
# ret: ok(true) on success, or an allocation error
pub fun block_append_instr(m: *Module, blk: *Block, i: id.InstructionId) Result[bool, str] {
    if (blk.instr_count >= blk.instr_cap) {
        var new_cap: u32 = blk.instr_cap * 2;
        if (new_cap < INITIAL_BLOCK_LIST_CAP) { new_cap = INITIAL_BLOCK_LIST_CAP; }
        val r: Result[*id.InstructionId, str] =
            reallocate[id.InstructionId](m.alloc, blk.instructions, blk.instr_cap::usize, new_cap::usize);
        if (is_err[*id.InstructionId, str](r)) {
            ret err[bool, str](unwrap_err[*id.InstructionId, str](r));
        }
        blk.instructions = unwrap_ok[*id.InstructionId, str](r);
        blk.instr_cap    = new_cap;
    }
    blk.instructions[blk.instr_count] = i;
    blk.instr_count = blk.instr_count + 1;
    ret ok[bool, str](true);
}

# appends an InstructionId to a block's phi list, growing it as needed. Phis
# conceptually execute at block entry before any body instruction.
# ---
# m:   module owning the allocator
# blk: block whose phi list receives the instruction id
# i:   the phi instruction id to append
# ret: ok(true) on success, or an allocation error
pub fun block_append_phi(m: *Module, blk: *Block, i: id.InstructionId) Result[bool, str] {
    if (blk.phi_count >= blk.phi_cap) {
        var new_cap: u32 = blk.phi_cap * 2;
        if (new_cap < INITIAL_BLOCK_LIST_CAP) { new_cap = INITIAL_BLOCK_LIST_CAP; }
        val r: Result[*id.InstructionId, str] =
            reallocate[id.InstructionId](m.alloc, blk.phis, blk.phi_cap::usize, new_cap::usize);
        if (is_err[*id.InstructionId, str](r)) {
            ret err[bool, str](unwrap_err[*id.InstructionId, str](r));
        }
        blk.phis    = unwrap_ok[*id.InstructionId, str](r);
        blk.phi_cap = new_cap;
    }
    blk.phis[blk.phi_count] = i;
    blk.phi_count = blk.phi_count + 1;
    ret ok[bool, str](true);
}

# appends a BlockId to a block's predecessor list, growing it as needed. Does
# nothing if the predecessor is already recorded.
# ---
# m:    module owning the allocator
# blk:  block whose predecessor list receives the id
# pred: the predecessor block id to record
# ret:  ok(true) on success, or an allocation error
pub fun block_append_pred(m: *Module, blk: *Block, pred: id.BlockId) Result[bool, str] {
    var k: u32 = 0;
    for (k < blk.pred_count) {
        if (blk.preds[k] == pred) { ret ok[bool, str](true); }
        k = k + 1;
    }
    if (blk.pred_count >= blk.pred_cap) {
        var new_cap: u32 = blk.pred_cap * 2;
        if (new_cap < INITIAL_BLOCK_LIST_CAP) { new_cap = INITIAL_BLOCK_LIST_CAP; }
        val r: Result[*id.BlockId, str] =
            reallocate[id.BlockId](m.alloc, blk.preds, blk.pred_cap::usize, new_cap::usize);
        if (is_err[*id.BlockId, str](r)) {
            ret err[bool, str](unwrap_err[*id.BlockId, str](r));
        }
        blk.preds    = unwrap_ok[*id.BlockId, str](r);
        blk.pred_cap = new_cap;
    }
    blk.preds[blk.pred_count] = pred;
    blk.pred_count = blk.pred_count + 1;
    ret ok[bool, str](true);
}

# allocates a fresh, empty block at the end of a function's block array and
# returns its BlockId. The block's id field is set to its index; all owned
# lists start empty and its terminator is INSTR_NIL.
# ---
# m:  module owning the allocator
# fn: the function receiving the new block
# ret: the new BlockId, or an allocation error
pub fun add_block(m: *Module, fn: *Function) Result[id.BlockId, str] {
    if (fn.block_count >= fn.block_cap) {
        var new_cap: u32 = fn.block_cap * 2;
        if (new_cap < INITIAL_BLOCK_LIST_CAP) { new_cap = INITIAL_BLOCK_LIST_CAP; }
        val r: Result[*Block, str] =
            reallocate[Block](m.alloc, fn.blocks, fn.block_cap::usize, new_cap::usize);
        if (is_err[*Block, str](r)) {
            ret err[id.BlockId, str](unwrap_err[*Block, str](r));
        }
        fn.blocks    = unwrap_ok[*Block, str](r);
        fn.block_cap = new_cap;
    }
    val bid: id.BlockId = fn.block_count::id.BlockId;
    var blk: *Block = ?fn.blocks[fn.block_count];
    blk.id           = bid;
    blk.instructions = nil;
    blk.instr_count  = 0;
    blk.instr_cap    = 0;
    blk.phis         = nil;
    blk.phi_count    = 0;
    blk.phi_cap      = 0;
    blk.terminator   = id.INSTR_NIL;
    blk.preds        = nil;
    blk.pred_count   = 0;
    blk.pred_cap     = 0;
    fn.block_count = fn.block_count + 1;
    ret ok[id.BlockId, str](bid);
}

# reads the (up to two) successor BlockIds of `blk`'s terminator into out0/out1
# and returns the count. RET/UNREACHABLE have none, BR one, CBR two. Block
# targets ride in instr-slot Values per the OP_BR/OP_CBR operand conventions.
# ---
# fn:   the function owning blk and its terminator
# blk:  the block whose successors are wanted
# out0: receives the first successor (BLOCK_NIL if none)
# out1: receives the second successor (BLOCK_NIL if fewer than two)
# ret:  the number of successors (0, 1, or 2)
pub fun block_successors(fn: *Function, blk: *Block, out0: *id.BlockId, out1: *id.BlockId) u32 {
    @out0 = id.BLOCK_NIL;
    @out1 = id.BLOCK_NIL;
    if (blk.terminator == id.INSTR_NIL) { ret 0; }
    val t_opt: Option[*instr.Instruction] = get_instruction(fn, blk.terminator);
    if (is_none[*instr.Instruction](t_opt)) { ret 0; }
    val t: *instr.Instruction = unwrap[*instr.Instruction](t_opt);
    if (t.kind == instr.OP_BR) {
        if (t.operand_count >= 1) { @out0 = block_target(t.operands[0]); ret 1; }
        ret 0;
    }
    if (t.kind == instr.OP_CBR) {
        if (t.operand_count >= 3) {
            @out0 = block_target(t.operands[1]);
            @out1 = block_target(t.operands[2]);
            ret 2;
        }
        ret 0;
    }
    ret 0;
}

# decodes a BlockId from a block-target operand. By IR convention, block targets
# (BR/CBR successor slots and phi incoming block slots) are encoded as a
# VAL_CONST_INT whose int_lit holds the block id.
# ---
# v:   a block-target operand value
# ret: the BlockId it encodes
pub fun block_target(v: value.Value) id.BlockId {
    ret v.data.int_lit::id.BlockId;
}

# rebuilds every block's predecessor list from scratch by scanning all
# terminator edges. clears the existing pred lists (keeping their storage) and
# repopulates them, so callers that restructure control flow can restore
# predecessor consistency in one call.
# ---
# m:  module owning the allocator
# fn: the function whose predecessor lists are rebuilt
# ret: ok(true) on success, or an allocation error
pub fun rebuild_preds(m: *Module, fn: *Function) Result[bool, str] {
    var b: u32 = 0;
    for (b < fn.block_count) {
        fn.blocks[b].pred_count = 0;
        b = b + 1;
    }
    var s: u32 = 0;
    for (s < fn.block_count) {
        val blk: *Block = ?fn.blocks[s];
        var s0: id.BlockId = id.BLOCK_NIL;
        var s1: id.BlockId = id.BLOCK_NIL;
        val sn: u32 = block_successors(fn, blk, ?s0, ?s1);
        if (sn >= 1 && s0::u32 < fn.block_count) {
            val r: Result[bool, str] = block_append_pred(m, ?fn.blocks[s0::u32], s::id.BlockId);
            if (is_err[bool, str](r)) { ret r; }
        }
        if (sn >= 2 && s1::u32 < fn.block_count) {
            val r: Result[bool, str] = block_append_pred(m, ?fn.blocks[s1::u32], s::id.BlockId);
            if (is_err[bool, str](r)) { ret r; }
        }
        s = s + 1;
    }
    ret ok[bool, str](true);
}
