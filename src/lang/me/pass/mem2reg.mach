# mach.lang.me.pass.mem2reg: promote address-not-taken allocas to SSA registers.
#
# The lowerer emits every
# mutable local as an `alloca` plus `load`/`store` traffic; this pass is what
# turns that back into real SSA, inserting the phi nodes needed to merge a
# value across control flow. It is the dominant optimisation by impact, and the
# code generator expects mostly-SSA input.
#
# The algorithm is textbook Cytron et al.: classify promotable allocas (those
# whose result is only ever the pointer of a load or store), compute the
# dominator tree and dominance frontiers over the CFG, place phis at the
# iterated frontier of each alloca's defining blocks, then rename in
# dominator-tree order with a per-alloca value stack. Aliasing is intentionally
# trivial — only allocas whose address never escapes are touched.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.is_some;
use std.types.option.is_none;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;

use ir:      mach.lang.me.ir;
use instr:   mach.lang.me.ir.instruction;
use value:   mach.lang.me.ir.value;
use ir_type: mach.lang.me.ir.type;
use id:      mach.lang.me.ir.id;

# sentinel marking an unprocessed entry in u32 work arrays (idom / rpo index).
val NONE_U32: u32 = 0xFFFFFFFF;

# per-function working state for the promotion algorithm. Every array is sized
# to the function's block count, alloca count, or instruction pool length and
# freed in `dnit_state`.
# ---
# alloc:        backing allocator (the module's)
# m:            module under mutation
# fn:           function being promoted
# block_count:  number of blocks in the function
# rpo:          reverse-postorder block ids (defs precede uses on dominator paths)
# rpo_len:      number of reachable blocks in `rpo`
# rpo_index:    block id -> its position in `rpo`, or NONE_U32 if unreachable
# idom:         block id -> immediate dominator block id (entry's idom is itself)
# df:           flattened dominance-frontier sets; df_start/df_len index per block
# df_start:     block id -> start offset into `df`
# df_len:       block id -> frontier size
# df_total:     allocated length of `df`
# alloca_ids:   the promotable alloca InstructionIds
# alloca_ty:    parallel to alloca_ids: each promotable alloca's value (slot)
#               type, derived from a load/store on it — NOT the alloca's own
#               result type, which is always the IR pointer type
# alloca_count: number of promotable allocas
# phi_alloca:   instruction id -> the alloca a phi resolves (INSTR_NIL if not a
#               mem2reg phi); sized to the instruction pool
rec State {
    alloc:        *Allocator;
    m:            *ir.Module;
    fn:           *ir.Function;
    block_count:  u32;

    rpo:          *id.BlockId;
    rpo_len:      u32;
    rpo_index:    *u32;
    idom:         *u32;

    df:           *id.BlockId;
    df_start:     *u32;
    df_len:       *u32;
    df_total:     u32;

    alloca_ids:   *id.InstructionId;
    alloca_ty:    *ir_type.IrTypeId;
    alloca_count: u32;

    phi_alloca:     *id.InstructionId;
    phi_alloca_cap: u32;
}

# Pass entry. Runs the promotion algorithm independently on every function in
# the module.
# ---
# m:   module to mutate in place
# ret: ok(true) after a full pass, or the first allocation error encountered
pub fun run(m: *ir.Module) Result[bool, str] {
    var f: u32 = 0;
    for (f < m.function_len) {
        val fn: *ir.Function = ?m.functions[f];
        if ((fn.flags & ir.FN_FLAG_EXTERN) == 0) {
            val r: Result[bool, str] = promote_function(m, fn);
            if (is_err[bool, str](r)) { ret r; }
        }
        f = f + 1;
    }
    ret ok[bool, str](true);
}

# Runs the full pipeline on one function: classify allocas, compute dominance,
# insert phis, rename, and drop the promoted memory ops. A function with no
# promotable allocas is left untouched.
fun promote_function(m: *ir.Module, fn: *ir.Function) Result[bool, str] {
    var st: State;
    st.alloc        = m.alloc;
    st.m            = m;
    st.fn           = fn;
    st.block_count  = fn.block_count;
    st.rpo          = nil;
    st.rpo_len      = 0;
    st.rpo_index    = nil;
    st.idom         = nil;
    st.df           = nil;
    st.df_start     = nil;
    st.df_len       = nil;
    st.df_total     = 0;
    st.alloca_ids     = nil;
    st.alloca_ty      = nil;
    st.alloca_count   = 0;
    st.phi_alloca     = nil;
    st.phi_alloca_cap = 0;

    if (fn.block_count == 0) { ret ok[bool, str](true); }

    val rc: Result[bool, str] = collect_promotable(?st);
    if (is_err[bool, str](rc)) { dnit_state(?st); ret rc; }
    if (st.alloca_count == 0) { dnit_state(?st); ret ok[bool, str](true); }

    # phi ids are assigned past the current pool length as add_instruction
    # grows it. an alloca contributes at most one phi per block, so the highest
    # possible phi id is instr_len + block_count*alloca_count - 1. size the
    # alloca-tag table to cover every id we might assign.
    val phi_cap: u32 = fn.instr_len + st.block_count * st.alloca_count;
    val rphi: Result[*id.InstructionId, str] =
        allocate[id.InstructionId](st.alloc, phi_cap::usize);
    if (is_err[*id.InstructionId, str](rphi)) {
        dnit_state(?st);
        ret err[bool, str](unwrap_err[*id.InstructionId, str](rphi));
    }
    st.phi_alloca     = unwrap_ok[*id.InstructionId, str](rphi);
    st.phi_alloca_cap = phi_cap;
    var pi: u32 = 0;
    for (pi < phi_cap) { st.phi_alloca[pi] = id.INSTR_NIL; pi = pi + 1; }

    val rd: Result[bool, str] = compute_dominance(?st);
    if (is_err[bool, str](rd)) { dnit_state(?st); ret rd; }

    val rp: Result[bool, str] = insert_phis(?st);
    if (is_err[bool, str](rp)) { dnit_state(?st); ret rp; }

    val rr: Result[bool, str] = rename(?st);
    if (is_err[bool, str](rr)) { dnit_state(?st); ret rr; }

    dnit_state(?st);
    ret ok[bool, str](true);
}

# frees every owned array in the working state. safe to call partway through
# construction — each array is nil until allocated.
fun dnit_state(st: *State) {
    if (st.rpo != nil)        { deallocate[id.BlockId](st.alloc, st.rpo, st.block_count::usize); }
    if (st.rpo_index != nil)  { deallocate[u32](st.alloc, st.rpo_index, st.block_count::usize); }
    if (st.idom != nil)       { deallocate[u32](st.alloc, st.idom, st.block_count::usize); }
    if (st.df != nil)         { deallocate[id.BlockId](st.alloc, st.df, st.df_total::usize); }
    if (st.df_start != nil)   { deallocate[u32](st.alloc, st.df_start, st.block_count::usize); }
    if (st.df_len != nil)     { deallocate[u32](st.alloc, st.df_len, st.block_count::usize); }
    if (st.alloca_ids != nil) { deallocate[id.InstructionId](st.alloc, st.alloca_ids, st.alloca_count::usize); }
    if (st.alloca_ty != nil)  { deallocate[ir_type.IrTypeId](st.alloc, st.alloca_ty, st.alloca_count::usize); }
    if (st.phi_alloca != nil) { deallocate[id.InstructionId](st.alloc, st.phi_alloca, st.phi_alloca_cap::usize); }
}

# classify promotable allocas: an OP_ALLOCA whose result Value is referenced
# only as the pointer operand of an OP_LOAD or OP_STORE. Any other reference
# (the stored value of a store, a gep base, a call argument, …) means the
# address escaped and the alloca stays in memory. Each accepted alloca's value
# (slot) type is recorded in the parallel `alloca_ty` array, derived from a
# load/store on it — the alloca's own result type is always the IR pointer type.
fun collect_promotable(st: *State) Result[bool, str] {
    val fn: *ir.Function = st.fn;

    var cap: u32 = fn.instr_len;
    if (cap == 0) { ret ok[bool, str](true); }

    val ra: Result[*id.InstructionId, str] = allocate[id.InstructionId](st.alloc, cap::usize);
    if (is_err[*id.InstructionId, str](ra)) {
        ret err[bool, str](unwrap_err[*id.InstructionId, str](ra));
    }
    st.alloca_ids = unwrap_ok[*id.InstructionId, str](ra);

    val rt: Result[*ir_type.IrTypeId, str] = allocate[ir_type.IrTypeId](st.alloc, cap::usize);
    if (is_err[*ir_type.IrTypeId, str](rt)) {
        ret err[bool, str](unwrap_err[*ir_type.IrTypeId, str](rt));
    }
    st.alloca_ty = unwrap_ok[*ir_type.IrTypeId, str](rt);

    var i: u32 = 0;
    for (i < fn.instr_len) {
        val inst: *instr.Instruction = ?fn.instrs[i];
        if (inst.kind == instr.OP_ALLOCA) {
            if (alloca_is_promotable(st, i::id.InstructionId)) {
                st.alloca_ids[st.alloca_count] = i::id.InstructionId;
                st.alloca_ty[st.alloca_count]  = alloca_value_type(st, i::id.InstructionId);
                st.alloca_count = st.alloca_count + 1;
            }
        }
        i = i + 1;
    }
    ret ok[bool, str](true);
}

# derives the value (slot) type of a promotable alloca by scanning the pool for
# a load from it (use the load's result type) or a store to it (use the stored
# value's type). The alloca's result Value is the IR pointer type, so the slot
# type is recovered from its memory operations here rather than from the result.
# Returns IRT_NIL when the alloca has neither a load nor a store (a degenerate
# dead alloca); inserted phis for such an alloca carry no incoming values and are
# stripped by dce.
fun alloca_value_type(st: *State, alloca_id: id.InstructionId) ir_type.IrTypeId {
    val fn: *ir.Function = st.fn;
    var i: u32 = 0;
    for (i < fn.instr_len) {
        val inst: *instr.Instruction = ?fn.instrs[i];
        if (inst.kind == instr.OP_LOAD && inst.operand_count >= 1) {
            val ptr: value.Value = inst.operands[0];
            if (ptr.kind == value.VAL_INSTR && ptr.data.instr == alloca_id) {
                ret inst.ty;
            }
        }
        if (inst.kind == instr.OP_STORE && inst.operand_count >= 2) {
            val ptr: value.Value = inst.operands[1];
            if (ptr.kind == value.VAL_INSTR && ptr.data.instr == alloca_id) {
                ret inst.operands[0].ty;
            }
        }
        i = i + 1;
    }
    ret ir_type.IRT_NIL;
}

# true when no use of the alloca's result Value escapes load/store-pointer
# position. scans every operand of every instruction in the pool.
fun alloca_is_promotable(st: *State, alloca_id: id.InstructionId) bool {
    val fn: *ir.Function = st.fn;
    var i: u32 = 0;
    for (i < fn.instr_len) {
        val inst: *instr.Instruction = ?fn.instrs[i];
        var o: u32 = 0;
        for (o < inst.operand_count) {
            val op: value.Value = inst.operands[o];
            if (op.kind == value.VAL_INSTR && op.data.instr == alloca_id) {
                # legal uses: the ptr operand of a load (slot 0) or store (slot 1).
                # any other reference means the address escaped.
                val ok_load:  bool = inst.kind == instr.OP_LOAD  && o == 0;
                val ok_store: bool = inst.kind == instr.OP_STORE && o == 1;
                if (ok_load == false && ok_store == false) { ret false; }
            }
            o = o + 1;
        }
        i = i + 1;
    }
    ret true;
}

# Compute reverse postorder, the dominator tree (Cooper-Harvey-Kennedy), and
# dominance frontiers. Only reachable blocks participate; unreachable blocks
# get rpo_index == NONE_U32 and are skipped by later phases.
fun compute_dominance(st: *State) Result[bool, str] {
    val n: u32 = st.block_count;

    val r1: Result[*id.BlockId, str] = allocate[id.BlockId](st.alloc, n::usize);
    if (is_err[*id.BlockId, str](r1)) { ret err[bool, str](unwrap_err[*id.BlockId, str](r1)); }
    st.rpo = unwrap_ok[*id.BlockId, str](r1);

    val r2: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](r2)) { ret err[bool, str](unwrap_err[*u32, str](r2)); }
    st.rpo_index = unwrap_ok[*u32, str](r2);

    val r3: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](r3)) { ret err[bool, str](unwrap_err[*u32, str](r3)); }
    st.idom = unwrap_ok[*u32, str](r3);

    var b: u32 = 0;
    for (b < n) {
        st.rpo_index[b] = NONE_U32;
        st.idom[b]      = NONE_U32;
        b = b + 1;
    }

    val rr: Result[bool, str] = build_rpo(st);
    if (is_err[bool, str](rr)) { ret rr; }

    val rdom: Result[bool, str] = build_idom(st);
    if (is_err[bool, str](rdom)) { ret rdom; }

    ret build_frontiers(st);
}

# Depth-first traversal from the entry block producing reverse postorder.
# Uses an explicit stack to avoid recursion; postorder is reversed in place.
fun build_rpo(st: *State) Result[bool, str] {
    val n: u32 = st.block_count;

    val rv: Result[*bool, str] = allocate[bool](st.alloc, n::usize);
    if (is_err[*bool, str](rv)) { ret err[bool, str](unwrap_err[*bool, str](rv)); }
    val visited: *bool = unwrap_ok[*bool, str](rv);

    val rsb: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rsb)) {
        deallocate[bool](st.alloc, visited, n::usize);
        ret err[bool, str](unwrap_err[*u32, str](rsb));
    }
    val stk_block: *u32 = unwrap_ok[*u32, str](rsb);

    val rsi: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rsi)) {
        deallocate[bool](st.alloc, visited, n::usize);
        deallocate[u32](st.alloc, stk_block, n::usize);
        ret err[bool, str](unwrap_err[*u32, str](rsi));
    }
    val stk_succ: *u32 = unwrap_ok[*u32, str](rsi);

    val post: *id.BlockId = st.rpo;     # fill postorder, reverse at the end.
    var post_len: u32 = 0;

    var i: u32 = 0;
    for (i < n) { visited[i] = false; i = i + 1; }

    stk_block[0] = 0;       # entry is block 0
    stk_succ[0]  = 0;
    visited[0]   = true;
    var sp: u32 = 1;

    for (sp > 0) {
        val top: u32 = sp - 1;
        val bid: u32 = stk_block[top];
        val si:  u32 = stk_succ[top];

        var succ0: id.BlockId = id.BLOCK_NIL;
        var succ1: id.BlockId = id.BLOCK_NIL;
        val succ_n: u32 = block_successors(st, bid::id.BlockId, ?succ0, ?succ1);

        if (si < succ_n) {
            stk_succ[top] = si + 1;
            var next: id.BlockId = succ0;
            if (si == 1) { next = succ1; }
            if (next != id.BLOCK_NIL && next::u32 < n) {
                if (visited[next::u32] == false) {
                    visited[next::u32] = true;
                    stk_block[sp] = next::u32;
                    stk_succ[sp]  = 0;
                    sp = sp + 1;
                }
            }
        } or {
            post[post_len] = bid::id.BlockId;
            post_len = post_len + 1;
            sp = sp - 1;
        }
    }

    st.rpo_len = post_len;
    var a: u32 = 0;
    val z: u32 = post_len;
    for (a < z / 2) {
        val tmp: id.BlockId = post[a];
        post[a]         = post[z - 1 - a];
        post[z - 1 - a] = tmp;
        a = a + 1;
    }
    var p: u32 = 0;
    for (p < post_len) {
        st.rpo_index[post[p]::u32] = p;
        p = p + 1;
    }

    deallocate[bool](st.alloc, visited, n::usize);
    deallocate[u32](st.alloc, stk_block, n::usize);
    deallocate[u32](st.alloc, stk_succ, n::usize);
    ret ok[bool, str](true);
}

# writes the (up to two) successor block ids of `bid` into out0/out1 and returns
# the count, delegating to the shared ir.block_successors so the block-target
# encoding lives in one place.
fun block_successors(st: *State, bid: id.BlockId, out0: *id.BlockId, out1: *id.BlockId) u32 {
    ret ir.block_successors(st.fn, ?st.fn.blocks[bid::u32], out0, out1);
}

# Cooper-Harvey-Kennedy iterative dominator construction over reverse
# postorder. idom[entry] = entry; the rest converge in a few passes.
fun build_idom(st: *State) Result[bool, str] {
    val entry: u32 = 0;
    st.idom[entry] = entry;

    var changed: bool = true;
    for (changed) {
        changed = false;
        var r: u32 = 0;
        for (r < st.rpo_len) {
            val b: u32 = st.rpo[r]::u32;
            if (b == entry) { r = r + 1; cnt; }

            var new_idom: u32 = NONE_U32;
            val blk: *ir.Block = ?st.fn.blocks[b];
            var pi: u32 = 0;
            for (pi < blk.pred_count) {
                val pp: u32 = blk.preds[pi]::u32;
                if (pp < st.block_count && st.rpo_index[pp] != NONE_U32 && st.idom[pp] != NONE_U32) {
                    if (new_idom == NONE_U32) {
                        new_idom = pp;
                    } or {
                        new_idom = intersect(st, pp, new_idom);
                    }
                }
                pi = pi + 1;
            }
            if (new_idom != NONE_U32 && st.idom[b] != new_idom) {
                st.idom[b] = new_idom;
                changed = true;
            }
            r = r + 1;
        }
    }
    ret ok[bool, str](true);
}

# walks both fingers up the partially built dominator tree until they meet,
# comparing by reverse-postorder number. the meeting point is the nearest
# common dominator of b1 and b2.
fun intersect(st: *State, b1: u32, b2: u32) u32 {
    var f1: u32 = b1;
    var f2: u32 = b2;
    for (f1 != f2) {
        for (st.rpo_index[f1] > st.rpo_index[f2]) {
            f1 = st.idom[f1];
        }
        for (st.rpo_index[f2] > st.rpo_index[f1]) {
            f2 = st.idom[f2];
        }
    }
    ret f1;
}

# Dominance frontiers via the standard predecessor-walk: for each join block b
# and each predecessor p, walk from p up the dominator tree until idom[b],
# adding b to the frontier of every node passed. Computed in two sweeps so the
# flattened `df` arrays can be exactly sized.
fun build_frontiers(st: *State) Result[bool, str] {
    val n: u32 = st.block_count;

    val rs: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rs)) { ret err[bool, str](unwrap_err[*u32, str](rs)); }
    st.df_start = unwrap_ok[*u32, str](rs);

    val rl: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rl)) { ret err[bool, str](unwrap_err[*u32, str](rl)); }
    st.df_len = unwrap_ok[*u32, str](rl);

    var b: u32 = 0;
    for (b < n) { st.df_len[b] = 0; st.df_start[b] = 0; b = b + 1; }

    count_frontiers(st);

    var total: u32 = 0;
    var c: u32 = 0;
    for (c < n) {
        st.df_start[c] = total;
        total = total + st.df_len[c];
        c = c + 1;
    }

    var alloc_n: u32 = total;
    if (alloc_n == 0) { alloc_n = 1; }   # always allocate so dnit frees cleanly.
    st.df_total = alloc_n;

    val rd: Result[*id.BlockId, str] = allocate[id.BlockId](st.alloc, alloc_n::usize);
    if (is_err[*id.BlockId, str](rd)) { ret err[bool, str](unwrap_err[*id.BlockId, str](rd)); }
    st.df = unwrap_ok[*id.BlockId, str](rd);

    var z: u32 = 0;
    for (z < n) { st.df_len[z] = 0; z = z + 1; }
    fill_frontiers(st);
    ret ok[bool, str](true);
}

# first frontier sweep: increments df_len[runner] for every (b, runner) pair a
# fill sweep would emit. Slight over-count (no dedup here) is harmless — it only
# sizes the array; fill_frontiers dedups.
fun count_frontiers(st: *State) {
    var b: u32 = 0;
    for (b < st.block_count) {
        if (st.rpo_index[b] != NONE_U32) {
            val blk: *ir.Block = ?st.fn.blocks[b];
            if (blk.pred_count >= 2) {
                var pi: u32 = 0;
                for (pi < blk.pred_count) {
                    var runner: u32 = blk.preds[pi]::u32;
                    if (runner < st.block_count && st.rpo_index[runner] != NONE_U32) {
                        for (runner != st.idom[b]) {
                            st.df_len[runner] = st.df_len[runner] + 1;
                            runner = st.idom[runner];
                            if (runner == NONE_U32) { brk; }
                        }
                    }
                    pi = pi + 1;
                }
            }
        }
        b = b + 1;
    }
}

# second frontier sweep: appends b to df[runner] for each pair, skipping
# duplicates already present in the runner's slice.
fun fill_frontiers(st: *State) {
    var b: u32 = 0;
    for (b < st.block_count) {
        if (st.rpo_index[b] != NONE_U32) {
            val blk: *ir.Block = ?st.fn.blocks[b];
            if (blk.pred_count >= 2) {
                var pi: u32 = 0;
                for (pi < blk.pred_count) {
                    var runner: u32 = blk.preds[pi]::u32;
                    if (runner < st.block_count && st.rpo_index[runner] != NONE_U32) {
                        for (runner != st.idom[b]) {
                            frontier_add(st, runner, b::id.BlockId);
                            runner = st.idom[runner];
                            if (runner == NONE_U32) { brk; }
                        }
                    }
                    pi = pi + 1;
                }
            }
        }
        b = b + 1;
    }
}

# appends `target` to block `node`'s frontier slice if not already present.
# the slice occupies df[df_start[node] .. df_start[node]+df_len[node]).
fun frontier_add(st: *State, node: u32, target: id.BlockId) {
    val start: u32 = st.df_start[node];
    val len:   u32 = st.df_len[node];
    var k: u32 = 0;
    for (k < len) {
        if (st.df[start + k] == target) { ret; }
        k = k + 1;
    }
    st.df[start + len] = target;
    st.df_len[node] = len + 1;
}

# Phi-insertion (iterated dominance frontier per alloca). For each promotable
# alloca, the set of blocks that store to it seeds a worklist; a phi is placed
# in every dominance-frontier block, and those phi blocks themselves rejoin the
# worklist (iterated frontier). Each inserted phi records the alloca it stands
# for in `phi_alloca` so the rename pass can wire its incoming values.
fun insert_phis(st: *State) Result[bool, str] {
    val n: u32 = st.block_count;

    val rh: Result[*bool, str] = allocate[bool](st.alloc, n::usize);
    if (is_err[*bool, str](rh)) { ret err[bool, str](unwrap_err[*bool, str](rh)); }
    val has_phi: *bool = unwrap_ok[*bool, str](rh);

    val rq: Result[*bool, str] = allocate[bool](st.alloc, n::usize);
    if (is_err[*bool, str](rq)) {
        deallocate[bool](st.alloc, has_phi, n::usize);
        ret err[bool, str](unwrap_err[*bool, str](rq));
    }
    val on_work: *bool = unwrap_ok[*bool, str](rq);

    val rw: Result[*id.BlockId, str] = allocate[id.BlockId](st.alloc, n::usize);
    if (is_err[*id.BlockId, str](rw)) {
        deallocate[bool](st.alloc, has_phi, n::usize);
        deallocate[bool](st.alloc, on_work, n::usize);
        ret err[bool, str](unwrap_err[*id.BlockId, str](rw));
    }
    val work: *id.BlockId = unwrap_ok[*id.BlockId, str](rw);

    var err_msg: str = nil;
    var a: u32 = 0;
    for (a < st.alloca_count && err_msg == nil) {
        val alloca_id: id.InstructionId = st.alloca_ids[a];
        var i: u32 = 0;
        for (i < n) { has_phi[i] = false; on_work[i] = false; i = i + 1; }

        var wlen: u32 = 0;
        var s: u32 = 0;
        for (s < st.fn.instr_len) {
            val inst: *instr.Instruction = ?st.fn.instrs[s];
            if (inst.kind == instr.OP_STORE && inst.operand_count >= 2) {
                val ptr: value.Value = inst.operands[1];
                if (ptr.kind == value.VAL_INSTR && ptr.data.instr == alloca_id) {
                    val bb: u32 = inst.block::u32;
                    if (bb < n && on_work[bb] == false) {
                        on_work[bb] = true;
                        work[wlen] = bb::id.BlockId;
                        wlen = wlen + 1;
                    }
                }
            }
            s = s + 1;
        }

        for (wlen > 0 && err_msg == nil) {
            wlen = wlen - 1;
            val x: u32 = work[wlen]::u32;
            on_work[x] = false;
            val fstart: u32 = st.df_start[x];
            val flen:   u32 = st.df_len[x];
            var k: u32 = 0;
            for (k < flen) {
                val y: u32 = st.df[fstart + k]::u32;
                if (has_phi[y] == false) {
                    has_phi[y] = true;
                    val rp: Result[bool, str] = place_phi(st, y::id.BlockId, alloca_id);
                    if (is_err[bool, str](rp)) { err_msg = unwrap_err[bool, str](rp); }
                    if (on_work[y] == false) {
                        on_work[y] = true;
                        work[wlen] = y::id.BlockId;
                        wlen = wlen + 1;
                    }
                }
                k = k + 1;
            }
        }
        a = a + 1;
    }

    deallocate[bool](st.alloc, has_phi, n::usize);
    deallocate[bool](st.alloc, on_work, n::usize);
    deallocate[id.BlockId](st.alloc, work, n::usize);
    if (err_msg != nil) { ret err[bool, str](err_msg); }
    ret ok[bool, str](true);
}

# Materialises an empty OP_PHI in block `bid` carrying the alloca's value (slot)
# type and records, in `phi_alloca`, which alloca it resolves. The phi starts
# with zero operands; the rename pass appends one (block, value) pair per
# predecessor. The phi's result type is the alloca's value type from the
# parallel `alloca_ty` array — NOT the alloca instruction's own result type,
# which is the IR pointer type.
fun place_phi(st: *State, bid: id.BlockId, alloca_id: id.InstructionId) Result[bool, str] {
    val ai: u32 = alloca_index(st, alloca_id);
    if (ai == NONE_U32) {
        ret err[bool, str]("mem2reg: phi placed for a non-promotable alloca");
    }

    var phi: instr.Instruction;
    phi.kind          = instr.OP_PHI;
    phi.ty            = st.alloca_ty[ai];
    phi.operands      = nil;
    phi.operand_count = 0;
    phi.block         = bid;
    phi.flags         = 0;
    phi.aux_ty        = ir_type.IRT_NIL;

    val rid: Result[id.InstructionId, str] = ir.add_instruction(st.m, st.fn, phi);
    if (is_err[id.InstructionId, str](rid)) {
        ret err[bool, str](unwrap_err[id.InstructionId, str](rid));
    }
    val phi_id: id.InstructionId = unwrap_ok[id.InstructionId, str](rid);

    if (phi_id::u32 < st.phi_alloca_cap) {
        st.phi_alloca[phi_id::u32] = alloca_id;
    } or {
        ret err[bool, str]("mem2reg: phi id exceeds phi_alloca capacity");
    }

    val blk: *ir.Block = ?st.fn.blocks[bid::u32];
    ret ir.block_append_phi(st.m, blk, phi_id);
}

# The rename pass: a pre-order walk of the dominator tree maintaining one
# current-value slot per promotable alloca. Each load is recorded for
# substitution by the stack top; each store updates the slot; each inserted phi
# defines a new slot value. Successor phi operands are filled as edges are
# taken. Promoted loads/stores/allocas are then stripped from their blocks and
# all references to promoted loads rewritten to their SSA values.
fun rename(st: *State) Result[bool, str] {
    val na: u32 = st.alloca_count;
    val ilen: u32 = st.fn.instr_len;

    val rsub: Result[*value.Value, str] = allocate[value.Value](st.alloc, ilen::usize);
    if (is_err[*value.Value, str](rsub)) { ret err[bool, str](unwrap_err[*value.Value, str](rsub)); }
    val subst: *value.Value = unwrap_ok[*value.Value, str](rsub);

    val rhas: Result[*bool, str] = allocate[bool](st.alloc, ilen::usize);
    if (is_err[*bool, str](rhas)) {
        deallocate[value.Value](st.alloc, subst, ilen::usize);
        ret err[bool, str](unwrap_err[*bool, str](rhas));
    }
    val has_sub: *bool = unwrap_ok[*bool, str](rhas);
    var hi: u32 = 0;
    for (hi < ilen) { has_sub[hi] = false; hi = hi + 1; }

    val rcur: Result[*value.Value, str] = allocate[value.Value](st.alloc, na::usize);
    if (is_err[*value.Value, str](rcur)) {
        deallocate[value.Value](st.alloc, subst, ilen::usize);
        deallocate[bool](st.alloc, has_sub, ilen::usize);
        ret err[bool, str](unwrap_err[*value.Value, str](rcur));
    }
    val cur: *value.Value = unwrap_ok[*value.Value, str](rcur);

    val rdef: Result[*bool, str] = allocate[bool](st.alloc, na::usize);
    if (is_err[*bool, str](rdef)) {
        deallocate[value.Value](st.alloc, subst, ilen::usize);
        deallocate[bool](st.alloc, has_sub, ilen::usize);
        deallocate[value.Value](st.alloc, cur, na::usize);
        ret err[bool, str](unwrap_err[*bool, str](rdef));
    }
    val defined: *bool = unwrap_ok[*bool, str](rdef);

    var rc: RenameCtx;
    rc.st       = st;
    rc.subst    = subst;
    rc.has_sub  = has_sub;
    rc.cur      = cur;
    rc.defined  = defined;
    rc.instr_len = ilen;

    var a: u32 = 0;
    for (a < na) { defined[a] = false; a = a + 1; }

    val rr: Result[bool, str] = rename_walk(?rc);
    if (is_ok[bool, str](rr)) {
        apply_substitutions(?rc);
        strip_promoted(st);
    }

    deallocate[value.Value](st.alloc, subst, ilen::usize);
    deallocate[bool](st.alloc, has_sub, ilen::usize);
    deallocate[value.Value](st.alloc, cur, na::usize);
    deallocate[bool](st.alloc, defined, na::usize);
    ret rr;
}

# rename traversal context, threaded through the dominator-tree walk.
# ---
# st:        promotion state
# subst:     removed-load result id -> replacement SSA Value
# has_sub:   which instruction ids have an entry in `subst`
# cur:       per-alloca current SSA Value (stack top)
# defined:   per-alloca whether `cur` holds a live value yet
# instr_len: snapshot of the instruction pool length when rename began
rec RenameCtx {
    st:        *State;
    subst:     *value.Value;
    has_sub:   *bool;
    cur:       *value.Value;
    defined:   *bool;
    instr_len: u32;
}

# returns the index of `alloca_id` within the promotable set, or NONE_U32 if it
# is not a promoted alloca.
fun alloca_index(st: *State, alloca_id: id.InstructionId) u32 {
    var a: u32 = 0;
    for (a < st.alloca_count) {
        if (st.alloca_ids[a] == alloca_id) { ret a; }
        a = a + 1;
    }
    ret NONE_U32;
}

# Iterative pre-order walk of the dominator tree. At each block: bind phis as
# the new current value, rewrite body loads/stores, fill successor phi
# incomings, recurse into dominated children, then restore the per-alloca slots
# saved on entry. Implemented with an explicit frame stack over the dominator
# tree's children.
fun rename_walk(rc: *RenameCtx) Result[bool, str] {
    val st: *State = rc.st;
    val n: u32 = st.block_count;
    val na: u32 = st.alloca_count;

    val rcs: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rcs)) { ret err[bool, str](unwrap_err[*u32, str](rcs)); }
    val child_start: *u32 = unwrap_ok[*u32, str](rcs);
    val rcl: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rcl)) {
        deallocate[u32](st.alloc, child_start, n::usize);
        ret err[bool, str](unwrap_err[*u32, str](rcl));
    }
    val child_len: *u32 = unwrap_ok[*u32, str](rcl);
    val rch: Result[*id.BlockId, str] = allocate[id.BlockId](st.alloc, n::usize);
    if (is_err[*id.BlockId, str](rch)) {
        deallocate[u32](st.alloc, child_start, n::usize);
        deallocate[u32](st.alloc, child_len, n::usize);
        ret err[bool, str](unwrap_err[*id.BlockId, str](rch));
    }
    val children: *id.BlockId = unwrap_ok[*id.BlockId, str](rch);

    build_dom_children(st, child_start, child_len, children);

    var snap_n: u32 = n * na;
    if (snap_n == 0) { snap_n = 1; }
    val rsv: Result[*value.Value, str] = allocate[value.Value](st.alloc, snap_n::usize);
    if (is_err[*value.Value, str](rsv)) {
        deallocate[u32](st.alloc, child_start, n::usize);
        deallocate[u32](st.alloc, child_len, n::usize);
        deallocate[id.BlockId](st.alloc, children, n::usize);
        ret err[bool, str](unwrap_err[*value.Value, str](rsv));
    }
    val save_cur: *value.Value = unwrap_ok[*value.Value, str](rsv);
    val rsd: Result[*bool, str] = allocate[bool](st.alloc, snap_n::usize);
    if (is_err[*bool, str](rsd)) {
        deallocate[value.Value](st.alloc, save_cur, snap_n::usize);
        deallocate[u32](st.alloc, child_start, n::usize);
        deallocate[u32](st.alloc, child_len, n::usize);
        deallocate[id.BlockId](st.alloc, children, n::usize);
        ret err[bool, str](unwrap_err[*bool, str](rsd));
    }
    val save_def: *bool = unwrap_ok[*bool, str](rsd);

    val rfb: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rfb)) {
        deallocate[value.Value](st.alloc, save_cur, snap_n::usize);
        deallocate[bool](st.alloc, save_def, snap_n::usize);
        deallocate[u32](st.alloc, child_start, n::usize);
        deallocate[u32](st.alloc, child_len, n::usize);
        deallocate[id.BlockId](st.alloc, children, n::usize);
        ret err[bool, str](unwrap_err[*u32, str](rfb));
    }
    val frame_block: *u32 = unwrap_ok[*u32, str](rfb);
    val rfc: Result[*u32, str] = allocate[u32](st.alloc, n::usize);
    if (is_err[*u32, str](rfc)) {
        deallocate[u32](st.alloc, frame_block, n::usize);
        deallocate[value.Value](st.alloc, save_cur, snap_n::usize);
        deallocate[bool](st.alloc, save_def, snap_n::usize);
        deallocate[u32](st.alloc, child_start, n::usize);
        deallocate[u32](st.alloc, child_len, n::usize);
        deallocate[id.BlockId](st.alloc, children, n::usize);
        ret err[bool, str](unwrap_err[*u32, str](rfc));
    }
    val frame_child: *u32 = unwrap_ok[*u32, str](rfc);

    var err_msg: str = nil;
    snapshot(rc, save_cur, save_def, 0);
    val r0: Result[bool, str] = rename_enter_block(rc, 0::id.BlockId);
    if (is_err[bool, str](r0)) { err_msg = unwrap_err[bool, str](r0); }
    frame_block[0] = 0;
    frame_child[0] = 0;
    var sp: u32 = 1;

    for (sp > 0 && err_msg == nil) {
        val top: u32 = sp - 1;
        val b: u32 = frame_block[top];
        val ci: u32 = frame_child[top];
        val cstart: u32 = child_start[b];
        val clen:   u32 = child_len[b];
        if (ci < clen) {
            frame_child[top] = ci + 1;
            val child: u32 = children[cstart + ci]::u32;
            snapshot(rc, save_cur, save_def, sp);
            val rb: Result[bool, str] = rename_enter_block(rc, child::id.BlockId);
            if (is_err[bool, str](rb)) { err_msg = unwrap_err[bool, str](rb); }
            frame_block[sp] = child;
            frame_child[sp] = 0;
            sp = sp + 1;
        } or {
            restore(rc, save_cur, save_def, top);
            sp = sp - 1;
        }
    }

    deallocate[u32](st.alloc, frame_block, n::usize);
    deallocate[u32](st.alloc, frame_child, n::usize);
    deallocate[value.Value](st.alloc, save_cur, snap_n::usize);
    deallocate[bool](st.alloc, save_def, snap_n::usize);
    deallocate[u32](st.alloc, child_start, n::usize);
    deallocate[u32](st.alloc, child_len, n::usize);
    deallocate[id.BlockId](st.alloc, children, n::usize);

    if (err_msg != nil) { ret err[bool, str](err_msg); }
    ret ok[bool, str](true);
}

# saves the current cur/defined slots into the depth-`d` snapshot region.
fun snapshot(rc: *RenameCtx, save_cur: *value.Value, save_def: *bool, d: u32) {
    val na: u32 = rc.st.alloca_count;
    var a: u32 = 0;
    for (a < na) {
        save_cur[d * na + a] = rc.cur[a];
        save_def[d * na + a] = rc.defined[a];
        a = a + 1;
    }
}

# restores the cur/defined slots from the depth-`d` snapshot region.
fun restore(rc: *RenameCtx, save_cur: *value.Value, save_def: *bool, d: u32) {
    val na: u32 = rc.st.alloca_count;
    var a: u32 = 0;
    for (a < na) {
        rc.cur[a]     = save_cur[d * na + a];
        rc.defined[a] = save_def[d * na + a];
        a = a + 1;
    }
}

# builds the dominator-tree child lists from the idom array, flattened into
# children[] with per-block (child_start, child_len). reachable non-entry
# blocks are children of their idom.
fun build_dom_children(st: *State, child_start: *u32, child_len: *u32, children: *id.BlockId) {
    val n: u32 = st.block_count;
    var b: u32 = 0;
    for (b < n) { child_len[b] = 0; child_start[b] = 0; b = b + 1; }

    var c: u32 = 0;
    for (c < n) {
        if (c != 0 && st.rpo_index[c] != NONE_U32 && st.idom[c] != NONE_U32) {
            val p: u32 = st.idom[c];
            child_len[p] = child_len[p] + 1;
        }
        c = c + 1;
    }
    var total: u32 = 0;
    var k: u32 = 0;
    for (k < n) { child_start[k] = total; total = total + child_len[k]; k = k + 1; }
    var z: u32 = 0;
    for (z < n) { child_len[z] = 0; z = z + 1; }
    var d: u32 = 0;
    for (d < n) {
        if (d != 0 && st.rpo_index[d] != NONE_U32 && st.idom[d] != NONE_U32) {
            val p: u32 = st.idom[d];
            children[child_start[p] + child_len[p]] = d::id.BlockId;
            child_len[p] = child_len[p] + 1;
        }
        d = d + 1;
    }
}

# processes one block during rename: bind its phis as new current values,
# rewrite its body loads/stores against the per-alloca current values, then
# record the value carried along each outgoing edge into successor phis.
fun rename_enter_block(rc: *RenameCtx, bid: id.BlockId) Result[bool, str] {
    val st: *State = rc.st;
    val blk: *ir.Block = ?st.fn.blocks[bid::u32];

    var pi: u32 = 0;
    for (pi < blk.phi_count) {
        val phi_id: id.InstructionId = blk.phis[pi];
        val ai: u32 = phi_alloca_index(rc, phi_id);
        if (ai != NONE_U32) {
            val phi_opt: Option[*instr.Instruction] = ir.get_instruction(st.fn, phi_id);
            if (is_some[*instr.Instruction](phi_opt)) {
                val phi: *instr.Instruction = unwrap[*instr.Instruction](phi_opt);
                rc.cur[ai]     = value.instr_value(phi_id, phi.ty);
                rc.defined[ai] = true;
            }
        }
        pi = pi + 1;
    }

    var ii: u32 = 0;
    for (ii < blk.instr_count) {
        val iid: id.InstructionId = blk.instructions[ii];
        val inst_opt: Option[*instr.Instruction] = ir.get_instruction(st.fn, iid);
        if (is_some[*instr.Instruction](inst_opt)) {
            val inst: *instr.Instruction = unwrap[*instr.Instruction](inst_opt);
            if (inst.kind == instr.OP_LOAD && inst.operand_count >= 1) {
                val ptr: value.Value = inst.operands[0];
                if (ptr.kind == value.VAL_INSTR) {
                    val ai: u32 = alloca_index(st, ptr.data.instr);
                    if (ai != NONE_U32 && iid::u32 < rc.instr_len) {
                        if (rc.defined[ai]) {
                            rc.subst[iid::u32] = rc.cur[ai];
                        } or {
                            rc.subst[iid::u32] = value.const_null(inst.ty);
                        }
                        rc.has_sub[iid::u32] = true;
                    }
                }
            } or (inst.kind == instr.OP_STORE && inst.operand_count >= 2) {
                val ptr: value.Value = inst.operands[1];
                if (ptr.kind == value.VAL_INSTR) {
                    val ai: u32 = alloca_index(st, ptr.data.instr);
                    if (ai != NONE_U32) {
                        rc.cur[ai]     = resolve_value(rc, inst.operands[0]);
                        rc.defined[ai] = true;
                    }
                }
            }
        }
        ii = ii + 1;
    }

    var succ0: id.BlockId = id.BLOCK_NIL;
    var succ1: id.BlockId = id.BLOCK_NIL;
    val sn: u32 = block_successors(st, bid, ?succ0, ?succ1);
    if (sn >= 1) {
        val ra: Result[bool, str] = add_phi_incomings(rc, bid, succ0);
        if (is_err[bool, str](ra)) { ret ra; }
    }
    if (sn >= 2) {
        val rb: Result[bool, str] = add_phi_incomings(rc, bid, succ1);
        if (is_err[bool, str](rb)) { ret rb; }
    }
    ret ok[bool, str](true);
}

# returns the index, within the promotable set, of the alloca that phi `phi_id`
# resolves, or NONE_U32 if it is not a mem2reg phi.
fun phi_alloca_index(rc: *RenameCtx, phi_id: id.InstructionId) u32 {
    if (phi_id::u32 >= rc.st.phi_alloca_cap) { ret NONE_U32; }
    val alloca_id: id.InstructionId = rc.st.phi_alloca[phi_id::u32];
    if (alloca_id == id.INSTR_NIL) { ret NONE_U32; }
    ret alloca_index(rc.st, alloca_id);
}

# appends, to every mem2reg phi in `succ`, the current value of the phi's
# alloca paired with predecessor `pred`. Phi operands follow the standard
# [block0, val0, block1, val1, …] convention; block ids are encoded via the
# shared block-target form (matching OP_CBR/OP_BR targets and the builder).
fun add_phi_incomings(rc: *RenameCtx, pred: id.BlockId, succ: id.BlockId) Result[bool, str] {
    val st: *State = rc.st;
    if (succ::u32 >= st.block_count) { ret ok[bool, str](true); }
    val blk: *ir.Block = ?st.fn.blocks[succ::u32];
    var pi: u32 = 0;
    for (pi < blk.phi_count) {
        val phi_id: id.InstructionId = blk.phis[pi];
        val ai: u32 = phi_alloca_index(rc, phi_id);
        if (ai != NONE_U32) {
            val phi_opt: Option[*instr.Instruction] = ir.get_instruction(st.fn, phi_id);
            if (is_some[*instr.Instruction](phi_opt)) {
                val phi: *instr.Instruction = unwrap[*instr.Instruction](phi_opt);
                var incoming: value.Value;
                if (rc.defined[ai]) {
                    incoming = rc.cur[ai];
                } or {
                    incoming = value.const_null(phi.ty);
                }
                val r: Result[bool, str] = phi_push_incoming(rc, phi, pred, incoming);
                if (is_err[bool, str](r)) { ret r; }
            }
        }
        pi = pi + 1;
    }
    ret ok[bool, str](true);
}

# grows a phi's operand array by one (block, value) pair, encoding the
# predecessor block id via the shared block-target convention and pairing it
# with the incoming SSA value.
fun phi_push_incoming(rc: *RenameCtx, phi: *instr.Instruction, pred: id.BlockId, incoming: value.Value) Result[bool, str] {
    val st: *State = rc.st;
    val rbt: Result[value.Value, str] = ir.make_block_target(st.m, pred);
    if (is_err[value.Value, str](rbt)) { ret err[bool, str](unwrap_err[value.Value, str](rbt)); }
    val block_val: value.Value = unwrap_ok[value.Value, str](rbt);

    val old_n: u32 = phi.operand_count;
    val new_n: u32 = old_n + 2;
    val rn: Result[*value.Value, str] = allocate[value.Value](st.alloc, new_n::usize);
    if (is_err[*value.Value, str](rn)) { ret err[bool, str](unwrap_err[*value.Value, str](rn)); }
    val ops: *value.Value = unwrap_ok[*value.Value, str](rn);
    var k: u32 = 0;
    for (k < old_n) { ops[k] = phi.operands[k]; k = k + 1; }
    ops[old_n]     = block_val;
    ops[old_n + 1] = incoming;
    if (phi.operands != nil && old_n > 0) {
        deallocate[value.Value](st.alloc, phi.operands, old_n::usize);
    }
    phi.operands      = ops;
    phi.operand_count = new_n;
    ret ok[bool, str](true);
}

# resolves a Value through the substitution table: if it names a promoted load,
# follow to the load's replacement (transitively). otherwise returns it as-is.
fun resolve_value(rc: *RenameCtx, v: value.Value) value.Value {
    var cur: value.Value = v;
    for (cur.kind == value.VAL_INSTR) {
        val iid: u32 = cur.data.instr::u32;
        if (iid < rc.instr_len && rc.has_sub[iid]) {
            cur = rc.subst[iid];
        } or {
            ret cur;
        }
    }
    ret cur;
}

# applies the substitution table to every operand of every surviving
# instruction (including phi incomings), so references to promoted loads become
# their resolved SSA Values.
fun apply_substitutions(rc: *RenameCtx) {
    val st: *State = rc.st;
    var i: u32 = 0;
    for (i < st.fn.instr_len) {
        val inst: *instr.Instruction = ?st.fn.instrs[i];
        var o: u32 = 0;
        for (o < inst.operand_count) {
            val op: value.Value = inst.operands[o];
            if (op.kind == value.VAL_INSTR) {
                val iid: u32 = op.data.instr::u32;
                if (iid < rc.instr_len && rc.has_sub[iid]) {
                    inst.operands[o] = resolve_value(rc, op);
                }
            }
            o = o + 1;
        }
        i = i + 1;
    }
}

# strips promoted instructions (the allocas, and every load/store on them) from
# their block instruction lists. The pool entries remain but are unreferenced;
# the lists no longer name them, so the backend never sees them.
fun strip_promoted(st: *State) {
    var b: u32 = 0;
    for (b < st.block_count) {
        val blk: *ir.Block = ?st.fn.blocks[b];
        var w: u32 = 0;
        var r: u32 = 0;
        for (r < blk.instr_count) {
            val iid: id.InstructionId = blk.instructions[r];
            if (is_promoted_memop(st, iid) == false) {
                blk.instructions[w] = iid;
                w = w + 1;
            }
            r = r + 1;
        }
        blk.instr_count = w;
        b = b + 1;
    }
}

# true when an instruction is an alloca we promoted, or a load/store whose
# pointer is one of those allocas.
fun is_promoted_memop(st: *State, iid: id.InstructionId) bool {
    val inst_opt: Option[*instr.Instruction] = ir.get_instruction(st.fn, iid);
    if (is_none[*instr.Instruction](inst_opt)) { ret false; }
    val inst: *instr.Instruction = unwrap[*instr.Instruction](inst_opt);
    if (inst.kind == instr.OP_ALLOCA) {
        ret alloca_index(st, iid) != NONE_U32;
    }
    if (inst.kind == instr.OP_LOAD && inst.operand_count >= 1) {
        val ptr: value.Value = inst.operands[0];
        if (ptr.kind == value.VAL_INSTR) {
            ret alloca_index(st, ptr.data.instr) != NONE_U32;
        }
    }
    if (inst.kind == instr.OP_STORE && inst.operand_count >= 2) {
        val ptr: value.Value = inst.operands[1];
        if (ptr.kind == value.VAL_INSTR) {
            ret alloca_index(st, ptr.data.instr) != NONE_U32;
        }
    }
    ret false;
}
