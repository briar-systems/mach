# AST-to-IR lowering orchestrator for one module
#
# `lower_module` drives a single module's lowering: it builds a `LowerContext`
# (whose state and accessor API live in the `lower.context` leaf, so the decl /
# stmt / expr passes can share them without importing this orchestrator) and
# dispatches each top-level decl through the decl pass. it then drains the
# generic, comptime-value, and comptime-pack instance worklists to fixpoint, so
# every monomorphized body a call site needs is emitted. the produced IR module
# is unoptimised; the `Q_LOWER` compute body runs the pipeline over it.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use O: std.types.option;
use R: std.types.result;

use mach.lang.fe.ast;
use adecl: mach.lang.fe.ast.decl;
use mach.lang.fe.ast.id;
use mach.lang.fe.ast.module;
use mach.lang.fe.comptime;
use mach.lang.fe.resolve;
use mach.lang.fe.sema;
use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.lower.context;
use mach.lang.me.lower.decl;
use mach.lang.session;
use mach.lang.target.resolved;
use mach.lang.type;

# re-export the lowering context and its accessor API. they live in the
# `lower.context` leaf to break the orchestrator <-> pass import cycle, so this
# keeps external consumers spelling them `lower.LowerContext` / `lower.lower_type`.
fwd context.LoopFrame;
fwd context.LowerContext;
fwd context.init_context;
fwd context.dnit_context;
fwd context.begin_function;
fwd context.bind_local;
fwd context.lookup_local;
fwd context.push_loop;
fwd context.pop_loop;
fwd context.current_loop;
fwd context.push_fin;
fwd context.fin_count;
fwd context.fin_at;
fwd context.lower_type;
fwd context.expr_type_of;
fwd context.type_resolved_of;
fwd context.decl_type_of;
fwd context.expr_symbol_of;
fwd context.symbol_of;

# lowers one source module to an IR module
#
# builds a `LowerContext`, interns an IR module name, and dispatches each
# top-level decl through `decl.lower_decl`, then drains the generic, value, and
# pack instance worklists to fixpoint. the returned module is unoptimised; the
# `Q_LOWER` compute body runs the optimisation pipeline over it in place.
# ---
# s:           shared session
# tgt:         selected compilation target
# a:           parsed AST for the module
# fqn:         FQN of the module (names the IR module and qualifies its mangled symbols)
# own_module:  ModuleId of the module being lowered
# sema_result: typing output for the same module
# rr:          name-resolution output for the same module
# ctx:         comptime context (folded global initialisers)
# ret:         the lowered IR module, or an error
pub fun lower_module(
    s:           *session.Session,
    tgt:         *resolved.Target,
    a:           *ast.Ast,
    fqn:         intern.StrId,
    own_module:  session.ModuleId,
    sema_result: *sema.SemaResult,
    rr:          *resolve.ResolveResult,
    ctx:         *comptime.ComptimeCtx
) R.Result[ir.Module, str] {
    val res_module: R.Result[ir.Module, str] = ir.init(s.alloc, fqn);
    if (R.is_err[ir.Module, str](res_module)) {
        ret R.err[ir.Module, str](R.unwrap_err[ir.Module, str](res_module));
    }
    var m: ir.Module = R.unwrap_ok[ir.Module, str](res_module);

    # init_context cleans up its own partial allocations on failure, so the early
    # error path releases only the module.
    var lc: context.LowerContext;
    val res_init: R.Result[bool, str] = context.init_context(?lc, s, tgt, a, fqn, own_module, sema_result, rr, ctx, ?m);
    if (R.is_err[bool, str](res_init)) {
        ir.dnit(?m);
        ret R.err[ir.Module, str](R.unwrap_err[bool, str](res_init));
    }

    val opt_module: O.Option[*module.Module] = ast.get_module(a, a.root_module);
    if (O.is_none[*module.Module](opt_module)) {
        ret lower_module_fail(?lc, ?m, "lower: root_module is not set on this Ast");
    }
    val mnode: *module.Module = O.unwrap[*module.Module](opt_module);

    var i: u32 = 0;
    for (i < mnode.decls_len) {
        val pool_ix: u32 = mnode.decls_start + i;
        if (pool_ix::usize >= a.decl_id_len) {
            ret lower_module_fail(?lc, ?m, "lower: module decl index out of range");
        }
        val did: id.DeclId = a.decl_ids[pool_ix];
        val res_decl: R.Result[bool, str] = decl.lower_decl(?lc, did);
        if (R.is_err[bool, str](res_decl)) {
            ret lower_module_fail(?lc, ?m, R.unwrap_err[bool, str](res_decl));
        }
        i = i + 1;
    }

    # emit one concrete body per generic instance collected at this module's call
    # sites, draining to fixpoint so transitively-needed instances are emitted too.
    val res_drain_types: R.Result[bool, str] = drain_instances(?lc, s, a, sema_result, rr);
    if (R.is_err[bool, str](res_drain_types)) {
        ret lower_module_fail(?lc, ?m, R.unwrap_err[bool, str](res_drain_types));
    }

    # emit one concrete body per comptime value-parameter instance, draining to
    # fixpoint. a value body may call generics (landing on the type-instance
    # worklist) or other comptime-param functions (landing back here), so both
    # worklists are drained in turn.
    val res_drain_values: R.Result[bool, str] = drain_value_instances(?lc, s, a, sema_result, rr);
    if (R.is_err[bool, str](res_drain_values)) {
        ret lower_module_fail(?lc, ?m, R.unwrap_err[bool, str](res_drain_values));
    }

    # emit one concrete body per comptime variadic-pack instance, draining to
    # fixpoint. a pack body may call generics, other comptime-param functions, or
    # further pack-tailed functions, so all three worklists are re-drained until
    # none remains.
    val res_drain_packs: R.Result[bool, str] = drain_pack_instances(?lc, s, a, sema_result, rr);
    if (R.is_err[bool, str](res_drain_packs)) {
        ret lower_module_fail(?lc, ?m, R.unwrap_err[bool, str](res_drain_packs));
    }

    context.dnit_context(?lc);
    ret R.ok[ir.Module, str](m);
}

# tears down a partially built module after a lowering failure, then returns the
# error wrapped for `lower_module`. used by every error path past the point where
# both the context and the module exist
# ---
# lc:  the lowering context to release
# m:   the IR module to release
# msg: the error message to propagate
# ret: the wrapped error
fun lower_module_fail(lc: *context.LowerContext, m: *ir.Module, msg: str) R.Result[ir.Module, str] {
    context.dnit_context(lc);
    ir.dnit(m);
    ret R.err[ir.Module, str](msg);
}

# drains the generic-instance worklist to fixpoint, emitting one weak body per
# collected `(generic, type-args)` instance into the current IR module
#
# Each instance is lowered against its DECLARING module's AST / typing / name
# resolution (reached through the session registries) with the instance's
# substitution env active, so the body's types resolve to the concrete arguments.
# An instance body may itself call generics; those land on the same worklist and
# are processed by the same loop until none remain. The worklist resumes from a
# persistent cursor, so each generic body is emitted exactly once even when a
# re-entrant drain (type instances queued while value instances lower) re-invokes
# this. The home module's phase inputs are restored after the drain.
# ---
# lc:        the active lowering context (its worklist is drained)
# s:         shared session (origin-module registries)
# home_a:    the home module's AST (restored after the drain)
# home_sema: the home module's typing (restored after the drain)
# home_rr:   the home module's name resolution (restored after the drain)
# ret:       true once the worklist is empty, or the first lowering error
fun drain_instances(lc: *context.LowerContext, s: *session.Session,
                    home_a: *ast.Ast, home_sema: *sema.SemaResult,
                    home_rr: *resolve.ResolveResult) R.Result[bool, str] {
    for (lc.inst_drained < lc.inst_len) {
        # snapshot the entry by value: the worklist array may grow (reallocate)
        # while this instance's body enqueues transitive instances.
        val processed: u32              = lc.inst_drained;
        val decl_id:   id.DeclId        = lc.insts[processed].decl;
        val origin:    session.ModuleId = lc.insts[processed].origin;
        val arg_len:   u32              = lc.insts[processed].arg_len;
        val name:      intern.StrId     = lc.insts[processed].name;
        val args:      *type.TypeId     = lc.insts[processed].args;

        val res_emit: R.Result[bool, str] = emit_one_instance(lc, s, decl_id, origin, args, arg_len, name);
        if (R.is_err[bool, str](res_emit)) { ret res_emit; }

        lc.inst_drained = lc.inst_drained + 1;
    }

    context_home_restore(lc, s, home_a, home_sema, home_rr);
    ret R.ok[bool, str](true);
}

# emits one generic-instance body: binds the context to the instance's origin
# module and substitution env, lowers the template function under the instance
# name, then restores the comptime context and own_module (the enclosing drain
# restores the remaining home inputs)
#
# Swapping lc.ctx lets the body fold `$if` gates referencing the defining module's
# own `pub val`s; swapping lc.own_module keeps the origin-comparison helpers in
# expr.mach coherent while the origin AST is active. A missing origin registry or
# decl is skipped rather than aborted: the instance then resolves to an undefined
# symbol the linker reports, never a silently wrong body.
# ---
# lc:      the active lowering context
# s:       shared session (origin-module registries)
# decl_id: DeclId of the generic function in `origin`'s AST
# origin:  ModuleId that declares the generic
# args:    concrete type-argument sequence (by ordinal)
# arg_len: number of type arguments
# name:    instance linkage name
# ret:     true on success or skip, or the first lowering error
fun emit_one_instance(lc: *context.LowerContext, s: *session.Session,
                      decl_id: id.DeclId, origin: session.ModuleId,
                      args: *type.TypeId, arg_len: u32, name: intern.StrId) R.Result[bool, str] {
    val oa: *ast.Ast = session.module_ast(s, origin);
    if (oa == nil) { ret R.ok[bool, str](true); }
    val osema: *sema.SemaResult = (session.module_sema_ptr(s, origin))::*sema.SemaResult;
    if (osema == nil) { ret R.ok[bool, str](true); }
    val orr: *resolve.ResolveResult = (session.module_resolve_ptr(s, origin))::*resolve.ResolveResult;
    if (orr == nil) { ret R.ok[bool, str](true); }
    val octx: *comptime.ComptimeCtx = (session.module_comptime_ptr(s, origin))::*comptime.ComptimeCtx;
    if (octx == nil) { ret R.ok[bool, str](true); }

    val opt_decl: O.Option[*adecl.Decl] = ast.get_decl(oa, decl_id);
    if (O.is_none[*adecl.Decl](opt_decl)) { ret R.ok[bool, str](true); }
    val d: *adecl.Decl = O.unwrap[*adecl.Decl](opt_decl);
    if (d.kind != adecl.DECL_KIND_FUN) { ret R.ok[bool, str](true); }

    val home_ctx: *comptime.ComptimeCtx = lc.ctx;
    val home_own: session.ModuleId      = lc.own_module;
    context_origin_bind(lc, s, origin, oa, osema, orr, octx, args, arg_len);

    val res_lower: R.Result[bool, str] = decl.lower_instance(lc, decl_id, d, name);
    lc.ctx        = home_ctx;
    lc.own_module = home_own;
    ret res_lower;
}

# drains the comptime value-parameter instance worklist to fixpoint, emitting one
# weak body per collected `(decl, origin, comptime-values)` instance
#
# Each body is lowered against its DECLARING module's AST / typing / name
# resolution with the instance's `$param -> CTValue` bindings active, so its
# `$param`-gated `$if`s fold to the selected arm. A body may enqueue further value
# instances (a comptime-param function calling another) or type instances (a
# generic call), so value and type draining alternate to fixpoint: each worklist
# resumes from its own persistent cursor, so this drain is re-entrant (the pack
# drain re-invokes it) and emits every body once. The home module's phase inputs
# are restored after the drain.
# ---
# lc:        the active lowering context (its value worklist is drained)
# s:         shared session (origin-module registries)
# home_a:    the home module's AST (restored after the drain)
# home_sema: the home module's typing (restored after the drain)
# home_rr:   the home module's name resolution (restored after the drain)
# ret:       true once both worklists are empty, or the first lowering error
fun drain_value_instances(lc: *context.LowerContext, s: *session.Session,
                          home_a: *ast.Ast, home_sema: *sema.SemaResult,
                          home_rr: *resolve.ResolveResult) R.Result[bool, str] {
    # alternate value-instance and type-instance draining to fixpoint: a value body
    # may queue type instances (a generic call), and a type body may queue value
    # instances (a comptime-param call), so loop until both worklists are consumed.
    for (lc.vinst_drained < lc.vinst_len || lc.inst_drained < lc.inst_len) {
        for (lc.vinst_drained < lc.vinst_len) {
            # snapshot the entry by value: the worklist array may grow (reallocate)
            # while this instance's body enqueues transitive instances.
            val processed: u32               = lc.vinst_drained;
            val decl_id:   id.DeclId         = lc.vinsts[processed].decl;
            val origin:    session.ModuleId  = lc.vinsts[processed].origin;
            val val_len:   u32               = lc.vinsts[processed].val_len;
            val name:      intern.StrId      = lc.vinsts[processed].name;
            val vals:      *comptime.CTValue = lc.vinsts[processed].vals;
            val names:     *intern.StrId     = lc.vinsts[processed].names;

            val res_emit: R.Result[bool, str] = emit_one_value_instance(lc, s, decl_id, origin, vals, names, val_len, name);
            if (R.is_err[bool, str](res_emit)) {
                context_home_restore(lc, s, home_a, home_sema, home_rr);
                ret res_emit;
            }

            lc.vinst_drained = lc.vinst_drained + 1;
        }

        # drain any type instances queued by the value bodies just emitted; the
        # persistent cursor in drain_instances emits each generic body once.
        val res_drain_types: R.Result[bool, str] = drain_instances(lc, s, home_a, home_sema, home_rr);
        if (R.is_err[bool, str](res_drain_types)) { ret res_drain_types; }
    }

    context_home_restore(lc, s, home_a, home_sema, home_rr);
    ret R.ok[bool, str](true);
}

# emits one value-instance body: binds the context to the instance's origin
# module, opens a comptime frame on the origin context and binds the instance's
# `$param -> CTValue` bindings into it, lowers the template under the instance
# name, then closes the frame and restores the home comptime context
#
# The frame is closed on the error path too, so a failed instance never poisons
# the next. Innermost-wins lookup makes a param shadow a same-named module const
# for this body without disturbing the persistent module frame. Binding the ORIGIN
# module's comptime context (not the caller's) lets the body fold `$if` gates that
# reference the defining module's own `pub val`s. Every origin registry is
# populated before the drain runs (the caller already emitted an extern reference
# to this instance), so a missing one is a coherence violation, not a no-op: it
# aborts with an internal error rather than silently dropping the body.
# ---
# lc:      the active lowering context
# s:       shared session (origin-module registries)
# decl_id: DeclId of the comptime-param function in `origin`'s AST
# origin:  ModuleId that declares the function
# vals:    folded comptime-value sequence (by comptime ordinal)
# names:   bare comptime-param identifiers (by comptime ordinal), paired with vals
# val_len: number of comptime values
# name:    instance linkage name
# ret:     true on success, or the first binding / lowering error
fun emit_one_value_instance(lc: *context.LowerContext, s: *session.Session,
                            decl_id: id.DeclId, origin: session.ModuleId,
                            vals: *comptime.CTValue, names: *intern.StrId, val_len: u32,
                            name: intern.StrId) R.Result[bool, str] {
    val oa: *ast.Ast = session.module_ast(s, origin);
    if (oa == nil) { ret R.err[bool, str]("lower: value-instance origin AST not registered"); }
    val osema: *sema.SemaResult = (session.module_sema_ptr(s, origin))::*sema.SemaResult;
    if (osema == nil) { ret R.err[bool, str]("lower: value-instance origin typing not registered"); }
    val orr: *resolve.ResolveResult = (session.module_resolve_ptr(s, origin))::*resolve.ResolveResult;
    if (orr == nil) { ret R.err[bool, str]("lower: value-instance origin name-resolution not registered"); }
    val octx: *comptime.ComptimeCtx = (session.module_comptime_ptr(s, origin))::*comptime.ComptimeCtx;
    if (octx == nil) { ret R.err[bool, str]("lower: value-instance origin comptime context not registered"); }

    val opt_decl: O.Option[*adecl.Decl] = ast.get_decl(oa, decl_id);
    if (O.is_none[*adecl.Decl](opt_decl)) { ret R.err[bool, str]("lower: value-instance origin declaration not found"); }
    val d: *adecl.Decl = O.unwrap[*adecl.Decl](opt_decl);
    if (d.kind != adecl.DECL_KIND_FUN) { ret R.err[bool, str]("lower: value-instance origin declaration is not a function"); }

    val home_ctx: *comptime.ComptimeCtx = lc.ctx;
    val home_own: session.ModuleId      = lc.own_module;
    context_origin_bind(lc, s, origin, oa, osema, orr, octx, nil, 0);

    # open a frame on the ORIGIN context and bind the `$param -> CTValue` bindings
    # into it; the frame is closed afterward (on the error path too) so exactly
    # these bindings are popped.
    val mark: comptime.FrameMark = comptime.frame_open(octx);
    var i: u32 = 0;
    for (i < val_len) {
        val res_bind: R.Result[bool, str] = comptime.bind(octx, names[i], vals[i]);
        if (R.is_err[bool, str](res_bind)) {
            val res_close: R.Result[bool, str] = comptime.frame_close(octx, mark);
            lc.ctx        = home_ctx;
            lc.own_module = home_own;
            if (R.is_err[bool, str](res_close)) { ret R.err[bool, str](R.unwrap_err[bool, str](res_close)); }
            ret R.err[bool, str](R.unwrap_err[bool, str](res_bind));
        }
        i = i + 1;
    }

    val res_lower: R.Result[bool, str] = decl.lower_value_instance(lc, decl_id, d, name);
    val res_close: R.Result[bool, str] = comptime.frame_close(octx, mark);
    lc.ctx        = home_ctx;
    lc.own_module = home_own;
    if (R.is_err[bool, str](res_close)) { ret R.err[bool, str](R.unwrap_err[bool, str](res_close)); }
    ret res_lower;
}

# drains the comptime variadic-pack instance worklist to fixpoint, emitting one
# weak body per collected `(decl, origin, type-list)` instance
#
# Each body is lowered against its DECLARING module's AST / typing / name
# resolution, with the pack expanded to the instance's concrete element parameters;
# the `$each a in va` unroll inside it re-types and lowers per element. A pack body
# may queue type instances (a generic call), value instances (a comptime-param
# call), or further pack instances, so the type and value worklists are re-drained
# in turn and the loop repeats until all three are empty. Each worklist resumes
# from its persistent cursor, so every body is emitted exactly once. The home
# module's phase inputs are restored after the drain.
# ---
# lc:        the active lowering context (its pack worklist is drained)
# s:         shared session (origin-module registries)
# home_a:    the home module's AST (restored after the drain)
# home_sema: the home module's typing (restored after the drain)
# home_rr:   the home module's name resolution (restored after the drain)
# ret:       true once all three worklists are empty, or the first lowering error
fun drain_pack_instances(lc: *context.LowerContext, s: *session.Session,
                         home_a: *ast.Ast, home_sema: *sema.SemaResult,
                         home_rr: *resolve.ResolveResult) R.Result[bool, str] {
    for (lc.pinst_drained < lc.pinst_len || lc.inst_drained < lc.inst_len || lc.vinst_drained < lc.vinst_len) {
        for (lc.pinst_drained < lc.pinst_len) {
            # snapshot the entry by value: the worklist array may grow (reallocate)
            # while this instance's body enqueues transitive instances.
            val processed: u32              = lc.pinst_drained;
            val decl_id:   id.DeclId        = lc.pinsts[processed].decl;
            val origin:    session.ModuleId = lc.pinsts[processed].origin;
            val type_len:  u32              = lc.pinsts[processed].type_len;
            val name:      intern.StrId     = lc.pinsts[processed].name;
            val types:     *type.TypeId     = lc.pinsts[processed].types;

            val res_emit: R.Result[bool, str] = emit_one_pack_instance(lc, s, decl_id, origin, types, type_len, name);
            if (R.is_err[bool, str](res_emit)) {
                context_home_restore(lc, s, home_a, home_sema, home_rr);
                ret res_emit;
            }

            lc.pinst_drained = lc.pinst_drained + 1;
        }

        # drain any type / value instances the pack bodies just queued; both resume
        # from their persistent cursors, so each body is emitted once.
        val res_drain_types: R.Result[bool, str] = drain_instances(lc, s, home_a, home_sema, home_rr);
        if (R.is_err[bool, str](res_drain_types)) { ret res_drain_types; }
        val res_drain_values: R.Result[bool, str] = drain_value_instances(lc, s, home_a, home_sema, home_rr);
        if (R.is_err[bool, str](res_drain_values)) { ret res_drain_values; }
    }

    context_home_restore(lc, s, home_a, home_sema, home_rr);
    ret R.ok[bool, str](true);
}

# emits one pack-instance body: binds the context to the instance's origin module,
# installs the comptime resolvers, and lowers the pack-tailed template under the
# instance name with its concrete element type-list
#
# Mirrors emit_one_value_instance but without a comptime parameter frame - the
# per-element loop-variable binding is opened and closed inside the `$each` unroll.
# A missing origin registry is a coherence violation (the caller already emitted an
# extern reference to this instance), so it aborts rather than silently dropping
# the body.
# ---
# lc:       the active lowering context
# s:        shared session (origin-module registries)
# decl_id:  DeclId of the pack-tailed function in `origin`'s AST
# origin:   ModuleId that declares the function
# types:    pack element type-list (by pack ordinal)
# type_len: number of pack element types
# name:     instance linkage name
# ret:      true on success, or the first lowering error
fun emit_one_pack_instance(lc: *context.LowerContext, s: *session.Session,
                           decl_id: id.DeclId, origin: session.ModuleId,
                           types: *type.TypeId, type_len: u32, name: intern.StrId) R.Result[bool, str] {
    val oa: *ast.Ast = session.module_ast(s, origin);
    if (oa == nil) { ret R.err[bool, str]("lower: pack-instance origin AST not registered"); }
    val osema: *sema.SemaResult = (session.module_sema_ptr(s, origin))::*sema.SemaResult;
    if (osema == nil) { ret R.err[bool, str]("lower: pack-instance origin typing not registered"); }
    val orr: *resolve.ResolveResult = (session.module_resolve_ptr(s, origin))::*resolve.ResolveResult;
    if (orr == nil) { ret R.err[bool, str]("lower: pack-instance origin name-resolution not registered"); }
    val octx: *comptime.ComptimeCtx = (session.module_comptime_ptr(s, origin))::*comptime.ComptimeCtx;
    if (octx == nil) { ret R.err[bool, str]("lower: pack-instance origin comptime context not registered"); }

    val opt_decl: O.Option[*adecl.Decl] = ast.get_decl(oa, decl_id);
    if (O.is_none[*adecl.Decl](opt_decl)) { ret R.err[bool, str]("lower: pack-instance origin declaration not found"); }
    val d: *adecl.Decl = O.unwrap[*adecl.Decl](opt_decl);
    if (d.kind != adecl.DECL_KIND_FUN) { ret R.err[bool, str]("lower: pack-instance origin declaration is not a function"); }

    val home_ctx: *comptime.ComptimeCtx = lc.ctx;
    val home_own: session.ModuleId      = lc.own_module;
    context_origin_bind(lc, s, origin, oa, osema, orr, octx, nil, 0);

    val res_lower: R.Result[bool, str] = decl.lower_pack_instance(lc, decl_id, d, name, types, type_len);
    lc.ctx        = home_ctx;
    lc.own_module = home_own;
    ret res_lower;
}

# binds the lowering context's phase inputs and comptime context to `origin`'s
# session registries for an instance body, then installs the comptime resolvers
# against `octx`
#
# `subst` is the active generic substitution (nil for value and pack instances,
# the concrete type-args for a generic instance). The caller saves and restores
# lc.ctx / lc.own_module around the body; the enclosing drain restores the
# remaining phase inputs once the worklist empties.
# ---
# lc:        the context to rebind
# s:         shared session
# origin:    the origin module the body is lowered against
# oa:        origin module AST
# osema:     origin module typing
# orr:       origin module name resolution
# octx:      origin module comptime context
# subst:     active generic substitution, or nil
# subst_len: number of substitution arguments
fun context_origin_bind(lc: *context.LowerContext, s: *session.Session, origin: session.ModuleId,
                        oa: *ast.Ast, osema: *sema.SemaResult, orr: *resolve.ResolveResult,
                        octx: *comptime.ComptimeCtx, subst: *type.TypeId, subst_len: u32) {
    lc.a           = oa;
    lc.sema_result = osema;
    lc.rr          = orr;
    lc.fqn         = session.module_fqn(s, origin);
    lc.ctx         = octx;
    lc.own_module  = origin;
    lc.subst       = subst;
    lc.subst_len   = subst_len;

    # fold this body's `alias.CONST` paths and `$type_of(...)` / field gates against
    # the origin module's name resolution and types, now active on lc.
    comptime_resolvers_install(octx, lc);
}

# installs the member / type / field comptime resolvers against `octx`, routing
# each back to `lc` so `comptime.eval` folds `alias.CONST` paths, `$type_of(...)`
# gates, and `$each` field descriptors against the context's active module
# ---
# octx: the comptime context to install resolvers on
# lc:   the lowering context the resolvers read live
fun comptime_resolvers_install(octx: *comptime.ComptimeCtx, lc: *context.LowerContext) {
    comptime.set_member_resolver(octx, context.resolve_module_member_const::*u8, lc::ptr);
    comptime.set_type_resolver(octx, context.resolve_type_comparison_operand::*u8, lc::ptr);
    comptime.set_field_resolver(octx, context.resolve_field_member::*u8, lc::ptr);
}

# restores the home module's phase inputs after an instance drain (the body
# lowering swapped them to the origin module) and clears the generic substitution
# ---
# lc:        the context to restore
# s:         shared session
# home_a:    the home module's AST
# home_sema: the home module's typing
# home_rr:   the home module's name resolution
fun context_home_restore(lc: *context.LowerContext, s: *session.Session,
                         home_a: *ast.Ast, home_sema: *sema.SemaResult,
                         home_rr: *resolve.ResolveResult) {
    lc.a           = home_a;
    lc.sema_result = home_sema;
    lc.rr          = home_rr;
    lc.fqn         = session.module_fqn(s, lc.own_module);
    lc.subst       = nil;
    lc.subst_len   = 0;
}
