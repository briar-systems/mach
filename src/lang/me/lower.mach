# mach.lang.me.lower: typed-AST-to-IR lowering.
#
# Consumes a sema'd module (the parsed `Ast`
# plus name resolution and typing) and produces an `ir.Module` ready for
# the optimisation pipeline and the back end. This file owns the
# orchestration and the per-module / per-function `LowerContext`; the
# per-decl, per-stmt, and per-expr dispatch lives in the `lower.decl`,
# `lower.stmt`, and `lower.expr` sub-modules.
#
# The lowering is deliberately naive: locals become `alloca` slots that
# are read and written through `load` / `store`, control flow becomes
# explicit `cbr` diamonds and loop headers, and no `phi`s are emitted.
# `mem2reg` later promotes the allocas and inserts the phis. This keeps
# lowering simple and SSA-correct without dominance bookkeeping here.
#
# `LowerContext` carries, besides the public phase inputs, the working
# state a single function needs: the loop stack (header / exit blocks for
# `cnt` / `brk`), the deferred-statement (`fin`) stack, the function being
# emitted, and its return IR type. These live on the context because the
# fixed `lower_stmt(ctx, sid)` / `lower_expr(ctx, eid)` signatures give no
# other channel for control-flow state.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.is_none;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use map: std.collections.map;

use sess:     mach.lang.session;
use target:   mach.lang.target;
use ty:       mach.lang.type;
use intern:   mach.lang.intern;

use ast:      mach.lang.fe.ast;
use aid:      mach.lang.fe.ast.id;
use module:   mach.lang.fe.ast.module;
use adecl:    mach.lang.fe.ast.decl;
use resolve:  mach.lang.fe.resolve;
use sema:     mach.lang.fe.sema;
use comptime: mach.lang.fe.comptime;

use ir:       mach.lang.me.ir;
use ir_type:  mach.lang.me.ir.type;
use value:    mach.lang.me.ir.value;
use builder:  mach.lang.me.ir.builder;

use decl: mach.lang.me.lower.decl;

# initial capacity for the loop and fin working stacks on a LowerContext.
val INITIAL_STACK_CAP: u32 = 8;

# one entry on the loop stack: the header and exit blocks of an active
# loop. `cnt` branches to `header`, `brk` branches to `exit`.
# ---
# header: block a `cnt` (or back-edge) branches to
# exit:   block a `brk` branches to
pub rec LoopFrame {
    header: ir.BlockId;
    exit:   ir.BlockId;
}

# per-module lowering state, threaded through every decl / stmt / expr.
# the leading fields are the phase inputs and the IR being built; the
# trailing fields are the working state for the function currently being
# lowered (reset by `begin_function`).
# ---
# s:           shared session (allocator, interner, type universe)
# tgt:         selected target — drives IR type sizing
# a:           parsed AST being lowered
# sema_result: typing output parallel to the AST
# rr:          name-resolution output parallel to the AST
# ctx:         comptime context supplying folded global initialisers
# m:           the IR module being built
# builder:     insertion cursor into `m`
# locals:      source SymbolId -> the Value naming its current storage
#              (an alloca pointer for address-taken / mutable locals)
# fn_index:    index into m.functions of the function being lowered
# ret_ty:      IR return type of the function being lowered
# loops:       active loop stack (innermost last) for brk / cnt
# loop_len:    number of active loop frames
# loop_cap:    allocated capacity of the loop stack
# fins:        deferred `fin` body StmtIds (innermost last)
# fin_len:     number of pending fin entries
# fin_cap:     allocated capacity of the fin stack
pub rec LowerContext {
    s:           *sess.Session;
    tgt:         *target.Target;
    a:           *ast.Ast;
    sema_result: *sema.SemaResult;
    rr:          *resolve.ResolveResult;
    ctx:         *comptime.ComptimeCtx;
    m:           *ir.Module;
    builder:     builder.Builder;
    locals:      map.Map[resolve.SymbolId, value.Value];

    fn_index:    u32;
    ret_ty:      ir_type.IrTypeId;

    loops:       *LoopFrame;
    loop_len:    u32;
    loop_cap:    u32;

    fins:        *aid.StmtId;
    fin_len:     u32;
    fin_cap:     u32;
}

# lowers one source module to an IR module.
#
# builds a `LowerContext`, interns an IR module name, and dispatches each
# top-level decl through `lower.decl.lower_decl`. the returned module is
# unoptimised; the `Q_LOWER` compute body runs the optimisation pipeline
# on it in place.
# ---
# s:           shared session
# tgt:         selected compilation target
# a:           parsed AST for the module
# sema_result: typing output for the same module
# rr:          name-resolution output for the same module
# ctx:         comptime context (folded global initialisers)
# ret:         the lowered IR module, or an error
pub fun lower_module(
    s:           *sess.Session,
    tgt:         *target.Target,
    a:           *ast.Ast,
    sema_result: *sema.SemaResult,
    rr:          *resolve.ResolveResult,
    ctx:         *comptime.ComptimeCtx,
) Result[ir.Module, str] {
    val name_r: Result[intern.StrId, str] = intern.intern(?s.interner, module_name(a));
    if (is_err[intern.StrId, str](name_r)) {
        ret err[ir.Module, str](unwrap_err[intern.StrId, str](name_r));
    }

    val m_r: Result[ir.Module, str] = ir.init_module(s.alloc, unwrap_ok[intern.StrId, str](name_r));
    if (is_err[ir.Module, str](m_r)) {
        ret err[ir.Module, str](unwrap_err[ir.Module, str](m_r));
    }
    var m: ir.Module = unwrap_ok[ir.Module, str](m_r);

    var lc: LowerContext;
    val ic: Result[bool, str] = init_context(?lc, s, tgt, a, sema_result, rr, ctx, ?m);
    if (is_err[bool, str](ic)) {
        ir.dnit_module(?m);
        ret err[ir.Module, str](unwrap_err[bool, str](ic));
    }

    val mod_opt: Option[*module.Module] = ast.get_module(a, a.root_module);
    if (is_none[*module.Module](mod_opt)) {
        dnit_context(?lc);
        ir.dnit_module(?m);
        ret err[ir.Module, str]("lower: root_module is not set on this Ast");
    }
    val mnode: *module.Module = unwrap[*module.Module](mod_opt);

    var i: u32 = 0;
    for (i < mnode.decls_len) {
        val pool_ix: u32 = mnode.decls_start + i;
        if (pool_ix::usize >= a.decl_id_len) {
            dnit_context(?lc);
            ir.dnit_module(?m);
            ret err[ir.Module, str]("lower: module decl index out of range");
        }
        val did: aid.DeclId = a.decl_ids[pool_ix];
        val dr: Result[bool, str] = decl.lower_decl(?lc, did);
        if (is_err[bool, str](dr)) {
            dnit_context(?lc);
            ir.dnit_module(?m);
            ret err[ir.Module, str](unwrap_err[bool, str](dr));
        }
        i = i + 1;
    }

    dnit_context(?lc);
    ret ok[ir.Module, str](m);
}

# initialises a LowerContext: wires the phase inputs, points the builder
# at the module, builds the locals map, and allocates the loop / fin
# working stacks.
# ---
# lc:          context to populate
# s:           shared session
# tgt:         selected target
# a:           parsed AST
# sema_result: typing output
# rr:          name resolution
# ctx:         comptime context
# m:           IR module being built
# ret:         true on success, or an allocation error
pub fun init_context(
    lc:          *LowerContext,
    s:           *sess.Session,
    tgt:         *target.Target,
    a:           *ast.Ast,
    sema_result: *sema.SemaResult,
    rr:          *resolve.ResolveResult,
    ctx:         *comptime.ComptimeCtx,
    m:           *ir.Module,
) Result[bool, str] {
    lc.s           = s;
    lc.tgt         = tgt;
    lc.a           = a;
    lc.sema_result = sema_result;
    lc.rr          = rr;
    lc.ctx         = ctx;
    lc.m           = m;
    lc.builder     = builder.init(m);
    lc.locals      = map.init[resolve.SymbolId, value.Value](s.alloc, map.hash_u32, map.eq_u32);

    lc.fn_index = 0;
    lc.ret_ty   = ir_type.IRT_NIL;

    val lr: Result[*LoopFrame, str] = allocate[LoopFrame](s.alloc, INITIAL_STACK_CAP::usize);
    if (is_err[*LoopFrame, str](lr)) {
        map.dnit[resolve.SymbolId, value.Value](?lc.locals);
        ret err[bool, str](unwrap_err[*LoopFrame, str](lr));
    }
    lc.loops    = unwrap_ok[*LoopFrame, str](lr);
    lc.loop_len = 0;
    lc.loop_cap = INITIAL_STACK_CAP;

    val fr: Result[*aid.StmtId, str] = allocate[aid.StmtId](s.alloc, INITIAL_STACK_CAP::usize);
    if (is_err[*aid.StmtId, str](fr)) {
        deallocate[LoopFrame](s.alloc, lc.loops, lc.loop_cap::usize);
        map.dnit[resolve.SymbolId, value.Value](?lc.locals);
        ret err[bool, str](unwrap_err[*aid.StmtId, str](fr));
    }
    lc.fins    = unwrap_ok[*aid.StmtId, str](fr);
    lc.fin_len = 0;
    lc.fin_cap = INITIAL_STACK_CAP;

    ret ok[bool, str](true);
}

# releases the working storage held by a LowerContext (the locals map and
# the loop / fin stacks). does not touch the borrowed phase inputs or the
# module.
# ---
# lc: context to tear down
pub fun dnit_context(lc: *LowerContext) {
    if (lc == nil) { ret; }
    map.dnit[resolve.SymbolId, value.Value](?lc.locals);
    if (lc.loops != nil && lc.loop_cap > 0) {
        deallocate[LoopFrame](lc.s.alloc, lc.loops, lc.loop_cap::usize);
    }
    if (lc.fins != nil && lc.fin_cap > 0) {
        deallocate[aid.StmtId](lc.s.alloc, lc.fins, lc.fin_cap::usize);
    }
    lc.loops    = nil;
    lc.loop_len = 0;
    lc.loop_cap = 0;
    lc.fins     = nil;
    lc.fin_len  = 0;
    lc.fin_cap  = 0;
}

# resets the per-function working state before lowering a new function:
# clears the locals map and the loop / fin stacks, and records the new
# function index and IR return type. the builder cursor is set by the
# caller (`lower.decl.lower_fun`) once the entry block exists.
# ---
# lc:       the context
# fn_index: index of the function in m.functions
# ret_ty:   the function's IR return type
pub fun begin_function(lc: *LowerContext, fn_index: u32, ret_ty: ir_type.IrTypeId) {
    map.clear[resolve.SymbolId, value.Value](?lc.locals);
    lc.loop_len = 0;
    lc.fin_len  = 0;
    lc.fn_index = fn_index;
    lc.ret_ty   = ret_ty;
}

# binds a source SymbolId to the IR Value that names its storage. for
# locals this is the alloca-slot pointer; for parameters seeded before the
# body it may be a VAL_PARAM. overwrites any prior binding.
# ---
# lc:  the context
# sym: source symbol id
# v:   the Value to bind
# ret: true on success, or an allocation error from the map
pub fun bind_local(lc: *LowerContext, sym: resolve.SymbolId, v: value.Value) Result[bool, str] {
    ret map.insert[resolve.SymbolId, value.Value](?lc.locals, sym, v);
}

# looks up the Value bound to a source SymbolId, or none when the symbol
# has no local binding (a global or function reference).
# ---
# lc:  the context
# sym: source symbol id
# ret: some(Value) when bound, none otherwise
pub fun lookup_local(lc: *LowerContext, sym: resolve.SymbolId) Option[value.Value] {
    val r: Result[*value.Value, str] = map.get[resolve.SymbolId, value.Value](?lc.locals, ?sym);
    if (is_ok[*value.Value, str](r)) {
        ret some[value.Value](@unwrap_ok[*value.Value, str](r));
    }
    ret none[value.Value]();
}

# pushes a loop frame, recording the header and exit blocks the innermost
# `cnt` / `brk` branch to. grows the loop stack on overflow.
# ---
# lc:     the context
# header: block `cnt` branches to
# exit:   block `brk` branches to
# ret:    true on success, or an allocation error
pub fun push_loop(lc: *LowerContext, header: ir.BlockId, exit: ir.BlockId) Result[bool, str] {
    if (lc.loop_len == lc.loop_cap) {
        val new_cap: u32 = lc.loop_cap * 2;
        val r: Result[*LoopFrame, str] = reallocate[LoopFrame](lc.s.alloc, lc.loops, lc.loop_cap::usize, new_cap::usize);
        if (is_err[*LoopFrame, str](r)) { ret err[bool, str](unwrap_err[*LoopFrame, str](r)); }
        lc.loops    = unwrap_ok[*LoopFrame, str](r);
        lc.loop_cap = new_cap;
    }
    var f: LoopFrame;
    f.header = header;
    f.exit   = exit;
    lc.loops[lc.loop_len] = f;
    lc.loop_len = lc.loop_len + 1;
    ret ok[bool, str](true);
}

# pops the innermost loop frame. no-op when the stack is empty.
# ---
# lc: the context
pub fun pop_loop(lc: *LowerContext) {
    if (lc.loop_len > 0) { lc.loop_len = lc.loop_len - 1; }
}

# returns the innermost active loop frame, or none outside any loop.
# ---
# lc:  the context
# ret: some(LoopFrame) when inside a loop, none otherwise
pub fun current_loop(lc: *LowerContext) Option[LoopFrame] {
    if (lc.loop_len == 0) { ret none[LoopFrame](); }
    ret some[LoopFrame](lc.loops[lc.loop_len - 1]);
}

# pushes a deferred `fin` body. the body StmtId is replayed (lowered
# inline) before every reachable terminator that closes the enclosing
# scope. grows the fin stack on overflow.
# ---
# lc:   the context
# body: StmtId of the fin body
# ret:  true on success, or an allocation error
pub fun push_fin(lc: *LowerContext, body: aid.StmtId) Result[bool, str] {
    if (lc.fin_len == lc.fin_cap) {
        val new_cap: u32 = lc.fin_cap * 2;
        val r: Result[*aid.StmtId, str] = reallocate[aid.StmtId](lc.s.alloc, lc.fins, lc.fin_cap::usize, new_cap::usize);
        if (is_err[*aid.StmtId, str](r)) { ret err[bool, str](unwrap_err[*aid.StmtId, str](r)); }
        lc.fins    = unwrap_ok[*aid.StmtId, str](r);
        lc.fin_cap = new_cap;
    }
    lc.fins[lc.fin_len] = body;
    lc.fin_len = lc.fin_len + 1;
    ret ok[bool, str](true);
}

# returns the number of pending fin bodies.
# ---
# lc:  the context
# ret: count of deferred fin entries
pub fun fin_count(lc: *LowerContext) u32 {
    ret lc.fin_len;
}

# returns the fin body StmtId at stack index `i` (0 = outermost).
# ---
# lc: the context
# i:  stack index in [0, fin_count)
# ret: the StmtId, or STMT_NIL when out of range
pub fun fin_at(lc: *LowerContext, i: u32) aid.StmtId {
    if (i >= lc.fin_len) { ret aid.STMT_NIL; }
    ret lc.fins[i];
}

# lowers a semantic `type.TypeId` into the module's IR type universe.
# generics, instances, and aliases are assumed resolved by sema; this maps
# the concrete machine shapes. unknown / error types lower to void so that
# lowering never aborts on a poisoned upstream type (dce / the verifier
# surface the real problem).
# ---
# lc:  the context
# tid: semantic TypeId
# ret: the corresponding IrTypeId, or an allocation error
pub fun lower_type(lc: *LowerContext, tid: ty.TypeId) Result[ir_type.IrTypeId, str] {
    if (tid == ty.TYPE_NIL) {
        ret ir_type.intern_void(?lc.m.types);
    }
    val t_opt: Option[*ty.Type] = ty.get(?lc.s.types, tid);
    if (is_none[*ty.Type](t_opt)) {
        ret ir_type.intern_void(?lc.m.types);
    }
    val t: *ty.Type = unwrap[*ty.Type](t_opt);
    val k: ty.TypeKind = t.kind;

    if (k == ty.TYPE_U8 || k == ty.TYPE_I8)   { ret ir_type.intern_int(?lc.m.types, 8); }
    if (k == ty.TYPE_U16 || k == ty.TYPE_I16) { ret ir_type.intern_int(?lc.m.types, 16); }
    if (k == ty.TYPE_U32 || k == ty.TYPE_I32) { ret ir_type.intern_int(?lc.m.types, 32); }
    if (k == ty.TYPE_U64 || k == ty.TYPE_I64) { ret ir_type.intern_int(?lc.m.types, 64); }
    if (k == ty.TYPE_F32)                     { ret ir_type.intern_float(?lc.m.types, 32); }
    if (k == ty.TYPE_F64)                     { ret ir_type.intern_float(?lc.m.types, 64); }
    if (k == ty.TYPE_PTR)                     { ret ir_type.intern_ptr(?lc.m.types); }
    if (k == ty.TYPE_POINTER)                 { ret ir_type.intern_ptr(?lc.m.types); }

    if (k == ty.TYPE_ARRAY) {
        val er: Result[ir_type.IrTypeId, str] = lower_type(lc, t.data.array.base);
        if (is_err[ir_type.IrTypeId, str](er)) { ret er; }
        ret ir_type.intern_array(?lc.m.types, unwrap_ok[ir_type.IrTypeId, str](er), t.data.array.count);
    }

    if (k == ty.TYPE_REC || k == ty.TYPE_UNI) {
        ret lower_nominal(lc, tid);
    }

    if (k == ty.TYPE_FUN) {
        ret lower_function_type(lc, t);
    }

    # generic params / instances / errors that survived to here lower to a
    # pointer-width opaque slot so storage sizing still works.
    ret ir_type.intern_ptr(?lc.m.types);
}

# lowers a nominal (rec / uni) semantic type to an IR struct of its lowered
# field types, read from the declaration's typed-name field list. a nominal
# type whose declaration is unavailable or empty lowers to an empty struct,
# keeping lowering total.
fun lower_nominal(lc: *LowerContext, tid: ty.TypeId) Result[ir_type.IrTypeId, str] {
    val t_opt: Option[*ty.Type] = ty.get(?lc.s.types, tid);
    if (is_none[*ty.Type](t_opt)) {
        ret ir_type.intern_struct(?lc.m.types, nil, 0);
    }
    val t: *ty.Type = unwrap[*ty.Type](t_opt);
    val dr: Option[*adecl.Decl] = ast.get_decl(lc.a, t.data.nominal.decl);
    if (is_none[*adecl.Decl](dr)) {
        ret ir_type.intern_struct(?lc.m.types, nil, 0);
    }
    val d: *adecl.Decl = unwrap[*adecl.Decl](dr);
    if (d.kind != adecl.DECL_KIND_REC && d.kind != adecl.DECL_KIND_UNI) {
        ret ir_type.intern_struct(?lc.m.types, nil, 0);
    }
    var fields_start: u32 = 0;
    var fields_len:   u32 = 0;
    if (d.kind == adecl.DECL_KIND_REC) {
        fields_start = d.data.rec_.fields_start;
        fields_len   = d.data.rec_.fields_len;
    } or {
        fields_start = d.data.uni_.fields_start;
        fields_len   = d.data.uni_.fields_len;
    }
    if (fields_len == 0) {
        ret ir_type.intern_struct(?lc.m.types, nil, 0);
    }

    val buf_r: Result[*ir_type.IrTypeId, str] = allocate[ir_type.IrTypeId](lc.s.alloc, fields_len::usize);
    if (is_err[*ir_type.IrTypeId, str](buf_r)) {
        ret err[ir_type.IrTypeId, str](unwrap_err[*ir_type.IrTypeId, str](buf_r));
    }
    val buf: *ir_type.IrTypeId = unwrap_ok[*ir_type.IrTypeId, str](buf_r);

    var i: u32 = 0;
    for (i < fields_len) {
        val pool_ix: u32 = fields_start + i;
        var fty: ir_type.IrTypeId = ir_type.IRT_NIL;
        if (pool_ix::usize < lc.a.typed_name_len) {
            val tn: *adecl.TypedName = ?lc.a.typed_names[pool_ix];
            val sem: ty.TypeId = type_resolved_of(lc, tn.ty);
            val fr: Result[ir_type.IrTypeId, str] = lower_type(lc, sem);
            if (is_err[ir_type.IrTypeId, str](fr)) {
                deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
                ret fr;
            }
            fty = unwrap_ok[ir_type.IrTypeId, str](fr);
        } or {
            val vr: Result[ir_type.IrTypeId, str] = ir_type.intern_ptr(?lc.m.types);
            if (is_err[ir_type.IrTypeId, str](vr)) {
                deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
                ret vr;
            }
            fty = unwrap_ok[ir_type.IrTypeId, str](vr);
        }
        buf[i] = fty;
        i = i + 1;
    }

    val sr: Result[ir_type.IrTypeId, str] = ir_type.intern_struct(?lc.m.types, buf, fields_len);
    deallocate[ir_type.IrTypeId](lc.s.alloc, buf, fields_len::usize);
    ret sr;
}

# lowers a TYPE_FUN semantic type into an IRT_FN. parameter types come from
# the type interner's param pool; the IR function type is non-variadic here
# (variadic functions carry the flag on their declaration, handled by the
# decl lowerer).
fun lower_function_type(lc: *LowerContext, t: *ty.Type) Result[ir_type.IrTypeId, str] {
    val ret_r: Result[ir_type.IrTypeId, str] = lower_type(lc, t.data.fun.ret);
    if (is_err[ir_type.IrTypeId, str](ret_r)) { ret ret_r; }
    val ir_ret: ir_type.IrTypeId = unwrap_ok[ir_type.IrTypeId, str](ret_r);

    val count: u32 = t.data.fun.params_len;
    if (count == 0) {
        ret ir_type.intern_fn(?lc.m.types, ir_ret, nil, 0, false);
    }

    val buf_r: Result[*ir_type.IrTypeId, str] = allocate[ir_type.IrTypeId](lc.s.alloc, count::usize);
    if (is_err[*ir_type.IrTypeId, str](buf_r)) {
        ret err[ir_type.IrTypeId, str](unwrap_err[*ir_type.IrTypeId, str](buf_r));
    }
    val buf: *ir_type.IrTypeId = unwrap_ok[*ir_type.IrTypeId, str](buf_r);

    var i: u32 = 0;
    for (i < count) {
        val po: Option[ty.TypeId] = ty.get_param(?lc.s.types, t.data.fun.params_start + i);
        var p_sem: ty.TypeId = ty.TYPE_NIL;
        if (is_some[ty.TypeId](po)) { p_sem = unwrap[ty.TypeId](po); }
        val pr: Result[ir_type.IrTypeId, str] = lower_type(lc, p_sem);
        if (is_err[ir_type.IrTypeId, str](pr)) {
            deallocate[ir_type.IrTypeId](lc.s.alloc, buf, count::usize);
            ret pr;
        }
        buf[i] = unwrap_ok[ir_type.IrTypeId, str](pr);
        i = i + 1;
    }

    val fr: Result[ir_type.IrTypeId, str] = ir_type.intern_fn(?lc.m.types, ir_ret, buf, count, false);
    deallocate[ir_type.IrTypeId](lc.s.alloc, buf, count::usize);
    ret fr;
}

# returns the semantic type of an expression from the sema result, or
# TYPE_NIL when the id is out of range.
# ---
# lc:  the context
# eid: AST ExprId
# ret: the expression's interned semantic TypeId (TYPE_NIL if unknown)
pub fun expr_type_of(lc: *LowerContext, eid: aid.ExprId) ty.TypeId {
    if (eid == aid.EXPR_NIL) { ret ty.TYPE_NIL; }
    if (eid::usize >= lc.a.expr_len) { ret ty.TYPE_NIL; }
    ret lc.sema_result.expr_type[eid];
}

# returns the interned semantic type a syntactic AstType resolved to, or
# TYPE_NIL when the id is out of range.
# ---
# lc:  the context
# tid: AST TypeId
# ret: the interned semantic TypeId (TYPE_NIL if unknown)
pub fun type_resolved_of(lc: *LowerContext, tid: aid.TypeId) ty.TypeId {
    if (tid == aid.TYPE_NIL) { ret ty.TYPE_NIL; }
    if (tid::usize >= lc.a.type_len) { ret ty.TYPE_NIL; }
    ret lc.sema_result.type_resolved_ty[tid];
}

# returns the declared / inferred semantic type of a decl, or TYPE_NIL.
# ---
# lc:  the context
# did: AST DeclId
# ret: the decl's interned semantic TypeId (TYPE_NIL if unknown)
pub fun decl_type_of(lc: *LowerContext, did: aid.DeclId) ty.TypeId {
    if (did == aid.DECL_NIL) { ret ty.TYPE_NIL; }
    if (did::usize >= lc.a.decl_len) { ret ty.TYPE_NIL; }
    ret lc.sema_result.decl_type[did];
}

# returns the resolved SymbolId for an expression reference, or SYMBOL_NIL.
# ---
# lc:  the context
# eid: AST ExprId (typically an IDENT)
# ret: the bound SymbolId, or SYMBOL_NIL
pub fun expr_symbol_of(lc: *LowerContext, eid: aid.ExprId) resolve.SymbolId {
    if (eid == aid.EXPR_NIL) { ret resolve.SYMBOL_NIL; }
    if (eid::usize >= lc.rr.expr_count) { ret resolve.SYMBOL_NIL; }
    ret lc.rr.expr_resolved[eid];
}

# returns a pointer to a resolved Symbol by id, or none when out of range.
# ---
# lc:  the context
# sid: SymbolId into the resolve result
# ret: some(*Symbol) or none
pub fun symbol_of(lc: *LowerContext, sid: resolve.SymbolId) Option[*resolve.Symbol] {
    if (sid == resolve.SYMBOL_NIL) { ret none[*resolve.Symbol](); }
    if (sid >= lc.rr.symbol_count) { ret none[*resolve.Symbol](); }
    ret some[*resolve.Symbol](?lc.rr.symbols[sid]);
}

# derives a printable module name for the IR module. the AST does not carry
# an FQN, so a stable placeholder is interned here; the driver overwrites
# `Module.name` with the real FQN when assembling the project.
fun module_name(a: *ast.Ast) str {
    ret "module";
}
