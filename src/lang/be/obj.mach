# mach.lang.be.obj: the back end's builder for assembling and emitting an object image.
#
# The back end's convenience layer for assembling an
# `of.ObjectImage` — the format-agnostic object model of sections, symbols, and
# relocations — and handing it off to a format writer. The object model itself
# lives in `mach.lang.target.of`, where it is the contract between the back end
# and the per-format writers; this module owns only the builder API (append
# helpers) and the `emit` dispatch that selects the active format's `OfVTable`
# and invokes its writer with the target's ISA vtable.
#
# The image record exposes only element counts (no separate capacity), so each
# array is held exactly `count`-sized: appends reallocate to `count + 1`. Object
# images are small (one per module), so the simple exact-size growth keeps the
# builder correct without a capacity side-channel the model does not carry.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.string.str;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;
use std.types.size.usize;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use intern: mach.lang.intern;
use target: mach.lang.target;
use of:     mach.lang.target.of;

# init: allocate an empty object image for one module.
#
# the section, symbol, and relocation arrays start `nil` and grow on first
# append. the image owns every array it later allocates, plus each section's
# `bytes` buffer once it is supplied; `dnit` releases them all. the interner is
# recorded on the image so the format writer can resolve its interned names
# without a captured module global.
# ---
# alloc:    allocator backing every array on the image
# interner: session interner backing every StrId name on the image
# name:     interned module name, used for the output file's basename
# ret:      a fresh empty ObjectImage
pub fun init(alloc: *Allocator, interner: *intern.Interner, name: intern.StrId) Result[of.ObjectImage, str] {
    var o: of.ObjectImage;
    o.alloc         = alloc;
    o.interner      = interner;
    o.name          = name;
    o.sections      = nil;
    o.section_count = 0;
    o.symbols       = nil;
    o.symbol_count  = 0;
    o.relocations   = nil;
    o.reloc_count   = 0;
    ret ok[of.ObjectImage, str](o);
}

# dnit: release every array owned by the image and each section's byte buffer.
#
# `nil` is a no-op. after this call the image must not be used.
# ---
# o: the image to tear down; all owned storage is freed and counts zeroed
pub fun dnit(o: *of.ObjectImage) {
    if (o == nil) { ret; }

    if (o.sections != nil) {
        var i: u32 = 0;
        for (i < o.section_count) {
            if (o.sections[i].bytes != nil && o.sections[i].len > 0) {
                deallocate[u8](o.alloc, o.sections[i].bytes, o.sections[i].len::usize);
            }
            i = i + 1;
        }
        deallocate[of.Section](o.alloc, o.sections, o.section_count::usize);
        o.sections      = nil;
        o.section_count = 0;
    }

    if (o.symbols != nil) {
        deallocate[of.Symbol](o.alloc, o.symbols, o.symbol_count::usize);
        o.symbols      = nil;
        o.symbol_count = 0;
    }

    if (o.relocations != nil) {
        deallocate[of.Relocation](o.alloc, o.relocations, o.reloc_count::usize);
        o.relocations = nil;
        o.reloc_count = 0;
    }
}

# add_section: append a section, growing the backing array by one slot.
#
# the image takes ownership of the appended section's `bytes` buffer (it is
# freed by `dnit`). returns the new section's index, used by symbols and
# relocations to reference it.
# ---
# o: the image to append to
# s: the section value to copy in
# ret: the new section's index, or an allocation error
pub fun add_section(o: *of.ObjectImage, s: of.Section) Result[u32, str] {
    if (o.sections == nil) {
        val r: Result[*of.Section, str] = allocate[of.Section](o.alloc, 1);
        if (is_err[*of.Section, str](r)) { ret err[u32, str](unwrap_err[*of.Section, str](r)); }
        o.sections = unwrap_ok[*of.Section, str](r);
    }
    or {
        val new_cap: usize = (o.section_count + 1)::usize;
        val r: Result[*of.Section, str] = reallocate[of.Section](o.alloc, o.sections, o.section_count::usize, new_cap);
        if (is_err[*of.Section, str](r)) { ret err[u32, str](unwrap_err[*of.Section, str](r)); }
        o.sections = unwrap_ok[*of.Section, str](r);
    }

    val ix: u32 = o.section_count;
    o.sections[ix] = s;
    o.section_count = o.section_count + 1;
    ret ok[u32, str](ix);
}

# add_symbol: append a symbol, growing the backing array by one slot.
#
# returns the new symbol's index, available for back-references.
# ---
# o:   the image to append to
# sym: the symbol value to copy in
# ret: the new symbol's index, or an allocation error
pub fun add_symbol(o: *of.ObjectImage, sym: of.Symbol) Result[u32, str] {
    if (o.symbols == nil) {
        val r: Result[*of.Symbol, str] = allocate[of.Symbol](o.alloc, 1);
        if (is_err[*of.Symbol, str](r)) { ret err[u32, str](unwrap_err[*of.Symbol, str](r)); }
        o.symbols = unwrap_ok[*of.Symbol, str](r);
    }
    or {
        val new_cap: usize = (o.symbol_count + 1)::usize;
        val r: Result[*of.Symbol, str] = reallocate[of.Symbol](o.alloc, o.symbols, o.symbol_count::usize, new_cap);
        if (is_err[*of.Symbol, str](r)) { ret err[u32, str](unwrap_err[*of.Symbol, str](r)); }
        o.symbols = unwrap_ok[*of.Symbol, str](r);
    }

    val ix: u32 = o.symbol_count;
    o.symbols[ix] = sym;
    o.symbol_count = o.symbol_count + 1;
    ret ok[u32, str](ix);
}

# add_relocation: append a relocation, growing the backing array by one slot.
# ---
# o: the image to append to
# r: the relocation value to copy in
# ret: true on success, or an allocation error
pub fun add_relocation(o: *of.ObjectImage, r: of.Relocation) Result[bool, str] {
    if (o.relocations == nil) {
        val ar: Result[*of.Relocation, str] = allocate[of.Relocation](o.alloc, 1);
        if (is_err[*of.Relocation, str](ar)) { ret err[bool, str](unwrap_err[*of.Relocation, str](ar)); }
        o.relocations = unwrap_ok[*of.Relocation, str](ar);
    }
    or {
        val new_cap: usize = (o.reloc_count + 1)::usize;
        val ar: Result[*of.Relocation, str] = reallocate[of.Relocation](o.alloc, o.relocations, o.reloc_count::usize, new_cap);
        if (is_err[*of.Relocation, str](ar)) { ret err[bool, str](unwrap_err[*of.Relocation, str](ar)); }
        o.relocations = unwrap_ok[*of.Relocation, str](ar);
    }

    o.relocations[o.reloc_count] = r;
    o.reloc_count = o.reloc_count + 1;
    ret ok[bool, str](true);
}

# emit: serialize the image to disk through the active format's writer.
#
# looks up the `OfVTable` registered for the active object format (carried on
# `tgt.of`) and invokes its `emit_object` writer, passing `tgt.arch` (the ISA
# vtable) and the output path. this module never knows the format-specific byte
# layout; that lives in the `target/of/` writers. fails if the target has no
# object-format writer.
# ---
# o:        the image to serialize
# tgt:      active target, supplying the format vtable and ISA vtable
# out_path: null-terminated output file path
# ret:      true on success, or the writer's error
pub fun emit(o: *of.ObjectImage, tgt: *target.Target, out_path: *u8) Result[bool, str] {
    if (tgt == nil) { ret err[bool, str]("emit: nil target"); }
    if (tgt.of == nil) { ret err[bool, str]("emit: target has no object-format vtable"); }
    if (tgt.of.emit_object == nil) { ret err[bool, str]("emit: object format has no writer"); }
    ret tgt.of.emit_object(tgt.arch, o, out_path);
}
