# machine-code encoding dispatcher to the active ISA's encoder
#
# Byte encoding is target-specific: turning a fully-resolved (post-isel, post-
# regalloc, post-frame) `MirModule` into the exact bytes a CPU executes is an
# ISA's business. This module owns no x86-64 (or any other arch's) opcode,
# register, or encoding knowledge; it dispatches each MIR module to the active
# ISA's `encode` operation through the `isa` vtable, exactly as the shared `isel`
# dispatcher reaches the ISA's `select`. Adding a new architecture is implementing
# `target/isa/<arch>` and registering its `encode` entry point - no edit here.
#
# What this module DOES own is the target-agnostic output shape every ISA's
# encoder fills: the per-module `EncoderOutput` (encoded `.text` bytes, function
# symbol marks, and pending relocations) plus its `SymbolMark` and `PendingReloc`
# elements. The code-generation driver (`be.codegen`) packs these into an
# `of.ObjectImage`, and the per-arch encoder (e.g. `target/isa/x64/encode.mach`)
# allocates and populates them. Keeping the records here lets the driver and every
# ISA agree on one common output without depending on any specific architecture.
#
# It also owns the ISA-agnostic two-pass encoder driver every architecture's
# encoder runs over a module: `encode_driver` initialises an `EncodeState`
# (the growable text `ByteBuf` plus the symbol / relocation / branch-fixup /
# block-offset arrays), walks every function through an ISA-supplied per-function
# encode hook (recording marks, relocs, fixups, and block offsets via the shared
# `push_*` helpers), patches every intra-module branch in pass 2 through an
# ISA-supplied per-branch patch hook, right-sizes the text, and assembles the
# `EncoderOutput`. The two `EncodeHooks` are the only per-ISA seams: how one
# function's bytes are emitted (opcodes, prologue/epilogue, relocation offsets)
# and how one resolved branch displacement is written into the text. No opcode,
# register, displacement-width, or byte-encoding knowledge lives here.

use std.io.writer;
use std.system.panic.panic;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use std.allocator.page;

use A: std.allocator;
use R: std.types.result;

use mach.lang.be.codegen.mir;
use mach.lang.intern;
use mach.lang.source;
use mach.lang.target.abi;
use mach.lang.target.of;
use tos: mach.lang.target.os;
use target: mach.lang.target.resolved;

# the per-module result an ISA's encoder produces: the encoded `.text` bytes plus
# the symbol marks and pending relocations the object builder packs into an
# `of.ObjectImage`
# ---
# text:         encoded `.text` bytes (owned; freed by the object builder once packed)
# text_len:     number of valid bytes in `text`
# relocations:  pending relocations naming cross-function / symbol references (owned)
# reloc_count:  number of relocations
# symbols:      symbol marks, one per function entry (owned)
# symbol_count: number of symbol marks
# rows:         PC<->source line rows, ordered by ascending `text_offset` (owned)
# row_count:    number of line rows
pub rec EncoderOutput {
    text:         *u8;
    text_len:     u32;
    relocations:  *PendingReloc;
    reloc_count:  u32;
    symbols:      *SymbolMark;
    symbol_count: u32;
    rows:         *LineRow;
    row_count:    u32;
    varlocs:      *VarLoc;
    varloc_count: u32;
    inline_pcs:   *InlinePc;
    inline_pc_count: u32;
}

# one retained PC<->source mapping: a `.text` byte offset and the source location of
# the instruction that begins there
#
# The encoder appends one per instruction with a valid source location, in
# ascending `text_offset` order. `insert_text` (branch relaxation) keeps
# `text_offset` correct while the text grows; codegen's `#[section(...)]` re-homing
# (`pack_rows`) then assigns each row's final `sec` and rebases `text_offset` into
# that section. Until re-homing every row is relative to the single encoder `.text`
# blob and `sec` is 0. The source `loc` (file + byte offset) resolves to a 1-based
# line/column via `source.position`; the #1699 `.debug_line` / CodeView producer
# consumes it. The row never affects the emitted bytes.
# ---
# text_offset: byte offset of the instruction within its owning section (`.text`
#              blob-relative until re-homing rebases it)
# sec:         owning object-section index, assigned by codegen re-homing (0 while
#              the row is still relative to the single encoder blob)
# loc:         source location (file + byte offset) the instruction lowered from
pub rec LineRow {
    text_offset: u32;
    sec:         u32;
    loc:         source.SrcLoc;
}

# one inline-instance transition: at `text_offset` the active inline instance becomes
# `inline_site` (0 = the function's own body, else a 1-based ir.Function inline-site id).
# The encoder appends one only when the instance CHANGES between consecutive
# instructions, in ascending `text_offset` order, so a record governs `[text_offset,
# next_offset)`. insert_text keeps `text_offset` correct through branch relaxation, and
# pack re-homes it exactly like a LineRow. The DWARF inlined_subroutine producer (#1707)
# groups these into per-instance `.text` ranges; nothing else reads them and they never
# affect the emitted bytes.
# ---
# text_offset: `.text` byte offset where this instance becomes active
# sec:         owning section index after re-homing (0 until then)
# inline_site: the 1-based inline instance now active, or 0 for the function body
pub rec InlinePc {
    text_offset: u32;
    sec:         u32;
    inline_site: u32;
}

# a source-variable location record: at `.text` offset `text_offset`, the variable
# bound by OP_DBG_VALUE `iid` lives at the raw home `(kind, reg | off)`. The producer
# joins `iid` to the IR variable identity and orders records by offset to build the
# per-PC ranges of a `.debug_loclists` entry (#1705). `text_offset` / `sec` (and a
# nonzero `end_offset`) re-home exactly like a LineRow (insert_text shift,
# site_placed re-home) so a range stays correct across branch relaxation and
# `#[section]` excision.
#
# A VARLOC_CMP record is the fused-condition COMPUTED VALUE: the variable is the
# relation `cc(lhs, rhs)` evaluated over the two operand homes, observable only
# while the fused compare-and-branch executes - `end_offset` bounds the range to
# that instruction's byte extent (a plain record's range instead runs to the
# variable's next binding, the linear rule, and carries `end_offset` 0). the
# operand homes ride `(sub_lhs, reg, off)` / `(sub_rhs, reg2, off2)`, each one
# of VARLOC_REG (register id), VARLOC_FRAME (spill-slot offset holding the
# machine-word value), or VARLOC_IMM (the constant's raw bits in off / off2);
# `cmp_rel` + `cmp_signed` + `cmp_width` digest the relation so the producer
# needs no MIR opcode knowledge.
# ---
# text_offset: `.text` byte offset where this binding becomes live
# sec:         owning object-section index (re-homed from 0 by codegen)
# iid:         source OP_DBG_VALUE instruction id (joins the IR dbg-var identity)
# kind:        VARLOC_NONE / VARLOC_REG / VARLOC_FRAME / VARLOC_CMP
# reg:         physical register id when kind == VARLOC_REG; the lhs operand's
#              register for a VARLOC_CMP with sub_lhs VARLOC_REG
# off:         frame-base offset when kind == VARLOC_FRAME; the lhs operand's
#              frame offset or immediate bits for a VARLOC_CMP
# off_storage: true when a VARLOC_FRAME slot holds the value's storage directly (a
#              register-passed aggregate reconstructed into a slot it owns, #1954), so an
#              aggregate location addresses the slot without the byref pointer deref; false
#              for a regalloc spill, whose slot holds the value (a pointer, for an aggregate)
# end_offset:  explicit exclusive range end for a VARLOC_CMP (0 = linear rule)
# sub_lhs:     lhs operand home kind for a VARLOC_CMP (REG / FRAME / IMM)
# sub_rhs:     rhs operand home kind for a VARLOC_CMP (REG / FRAME / IMM)
# reg2:        rhs operand register for a VARLOC_CMP with sub_rhs VARLOC_REG
# off2:        rhs operand frame offset or immediate bits for a VARLOC_CMP
# cmp_rel:     the relation (one of CMPREL_*) for a VARLOC_CMP
# cmp_signed:  true for a signed relation (selects the width interpretation)
# cmp_width:   the compare width in bytes (0 reads as the machine word)
pub rec VarLoc {
    text_offset: u32;
    sec:         u32;
    iid:         u32;
    kind:        u8;
    reg:         i32;
    off:         i64;
    off_storage: bool;
    end_offset:  u32;
    sub_lhs:     u8;
    sub_rhs:     u8;
    reg2:        i32;
    off2:        i64;
    cmp_rel:     u8;
    cmp_signed:  bool;
    cmp_width:   u8;
}

# a variable-location record's home kind. VARLOC_CMP is the fused-condition
# computed value (see VarLoc); VARLOC_IMM appears only as a VARLOC_CMP operand
# sub-home, never as a record's own kind
pub val VARLOC_NONE:  u8 = 0;
pub val VARLOC_REG:   u8 = 1;
pub val VARLOC_FRAME: u8 = 2;
pub val VARLOC_CMP:   u8 = 3;
pub val VARLOC_IMM:   u8 = 4;

# the digested relation a VARLOC_CMP compares with (`cmp_signed` carries the
# signedness separately; only EQ / NE / LT / LE exist - lowering canonicalizes
# GT / GE by swapping operands)
pub val CMPREL_EQ: u8 = 0;
pub val CMPREL_NE: u8 = 1;
pub val CMPREL_LT: u8 = 2;
pub val CMPREL_LE: u8 = 3;

# one relocation the encoder leaves for the object writer to resolve
#
# `kind` is an abstract relocation kind (`of.RK_*`); `sym` is the interned
# target-symbol name; `offset` is the patch site within `.text`.
# ---
# offset: byte offset of the patch site within the `.text` section
# kind:   abstract relocation kind (one of of.RK_*)
# sym:    interned name of the referenced symbol
# addend: constant added to the resolved symbol address
pub rec PendingReloc {
    offset: u32;
    kind:   of.RelocKind;
    sym:    intern.StrId;
    addend: i32;
}

# a symbol defined in the encoded `.text` at a known offset: a function entry
# point or an exposed inline-asm label
# ---
# name:   interned symbol name
# offset: byte offset of the symbol within the `.text` section
# flags:  object-symbol flags carried through to `of.Symbol.flags`
pub rec SymbolMark {
    name:   intern.StrId;
    offset: u32;
    flags:  u32;
}

# the concrete signature the erased `isa.IsaVTable.encode` pointer is cast back to
# before it is called
#
# The vtable stores `encode` type-erased (`*u8`) because its signature names
# `target.Target`, `mir.MirModule`, and this module's `EncoderOutput`, each of
# which imports `isa` - a typed field there would invert that dependency and form
# an import cycle. This dispatcher already imports `target` and `mir` and declares
# `EncoderOutput`, so it declares the cast-back type locally and casts the erased
# pointer to it, exactly as `isel` casts `isa.select` back to its `SelectFn` and
# `mir` casts `abi.arg_passing` back to its concrete signature. The structurally
# identical typedef the x86-64 encoder exposes describes the same contract from
# the impl side; the structural fn-pointer cast binds them. The allocator is
# threaded explicitly for parity with `isel.SelectFn` and so the per-arch encoder
# has a backing allocator without reaching into the module.
# ---
# a:   backing allocator for the encoder's output arrays
# tgt: resolved compilation target
# m:   the fully-resolved MIR module (post isel / regalloc / frame)
# ret: the populated EncoderOutput (owned arrays), or an error naming the failure
pub def EncodeFn: fun(*A.Allocator, *target.Target, *mir.MirModule) R.Result[EncoderOutput, str];

# encode a fully-resolved MIR module into `.text` bytes, symbol marks, and pending
# relocations
#
# Dispatches the whole module to the active ISA's `encode` operation, reached
# through `tgt.arch.encode`. Carries no architecture-specific knowledge - the
# encoder the ISA registered owns the byte, opcode, register, and
# prologue/epilogue/relocation machinery. Fails loudly when the target has no ISA
# vtable or the ISA registered no `encode` operation (an unsupported
# architecture), and propagates any encoding error from the per-arch encoder.
# ---
# tgt: resolved compilation target; its `arch` vtable supplies the encoder
# m:   the fully-resolved MIR module to encode
# ret: the populated EncoderOutput (owned arrays), or an error string
pub fun run(tgt: *target.Target, m: *mir.MirModule) R.Result[EncoderOutput, str] {
    if (tgt == nil) { ret R.err[EncoderOutput, str]("encode: nil target"); }
    if (m == nil)   { ret R.err[EncoderOutput, str]("encode: nil mir module"); }
    if (tgt.arch == nil) {
        ret R.err[EncoderOutput, str]("encode: target has no ISA vtable");
    }
    if (tgt.arch.encode == nil) {
        ret R.err[EncoderOutput, str]("encode: ISA registered no encoder");
    }

    val encode: EncodeFn = tgt.arch.encode::EncodeFn;
    ret encode(m.alloc, tgt, m);
}

# the concrete signature the erased `isa.IsaVTable.emit_asm` pointer is cast back
# to before it is called
#
# The vtable stores `emit_asm` type-erased (`*u8`) for the same import-cycle
# reason as `encode`: its signature names `target.Target` and `mir.MirModule`,
# both of which import `isa`. This dispatcher already imports `target` and `mir`,
# so it declares the cast-back type locally and casts the erased pointer to it,
# exactly as `run` casts `encode` back to `EncodeFn`. The per-arch printer formats
# every function of the module as Intel-syntax assembly text into the writer; it
# is a debug-only artifact, byte-exactness is not its contract.
# ---
# tgt: resolved compilation target
# m:   the fully-resolved MIR module (post isel / regalloc / frame)
# out: destination writer the assembly text is written into
# ret: true on success, or an error string from a write failure
pub def PrintAsmFn: fun(*target.Target, *mir.MirModule, *writer.Writer) R.Result[bool, str];

# format a fully-resolved MIR module as human-readable assembly text
#
# Dispatches the whole module to the active ISA's `emit_asm` operation, reached
# through `tgt.arch.emit_asm`. Carries no architecture-specific knowledge - the
# per-arch printer owns the mnemonic, register, and operand formatting. An ISA
# that registered no `emit_asm` printer (an arch with no debug-asm support) is a
# clean no-op rather than an error, so `--emit-asm` simply produces no file for
# it.
# ---
# tgt: resolved compilation target; its `arch` vtable supplies the printer
# m:   the fully-resolved MIR module to format
# out: destination writer
# ret: true on success (including the no-printer no-op), or an error string
pub fun print_asm(tgt: *target.Target, m: *mir.MirModule, out: *writer.Writer) R.Result[bool, str] {
    if (tgt == nil) { ret R.err[bool, str]("print_asm: nil target"); }
    if (m == nil)   { ret R.err[bool, str]("print_asm: nil mir module"); }
    if (out == nil) { ret R.err[bool, str]("print_asm: nil writer"); }
    if (tgt.arch == nil) {
        ret R.err[bool, str]("print_asm: target has no ISA vtable");
    }
    if (tgt.arch.emit_asm == nil) {
        ret R.ok[bool, str](true);
    }

    val emit_asm: PrintAsmFn = tgt.arch.emit_asm::PrintAsmFn;
    ret emit_asm(tgt, m, out);
}

# initial capacity of a freshly grown encoder byte buffer
val BYTEBUF_INIT_CAP: usize = 256;

# a growable byte sink the encoders write machine code into
#
# The back end drains `data[0..len]` into the object image's `.text` section
# after every function is encoded; keeping the growth bookkeeping here lets
# `of.Section` stay a finalized container. The sink is ISA-general - it carries
# no opcode or width knowledge, so every architecture's encoder writes its bytes
# through the same buffer.
# ---
# data:  backing byte array (nil until the first byte is appended)
# len:   number of bytes written
# cap:   allocated capacity
# alloc: allocator backing `data`
pub rec ByteBuf {
    data:  *u8;
    len:   usize;
    cap:   usize;
    alloc: *A.Allocator;
}

# construct an empty encoder byte buffer
# ---
# alloc: allocator backing the buffer's storage
# ret:   an empty ByteBuf
pub fun buf_init(alloc: *A.Allocator) ByteBuf {
    var buf: ByteBuf;
    buf.data  = nil;
    buf.len   = 0;
    buf.cap   = 0;
    buf.alloc = alloc;
    ret buf;
}

# free a byte buffer's backing storage
# ---
# buf: buffer to destroy; safe on nil
pub fun buf_dnit(buf: *ByteBuf) {
    if (buf == nil) { ret; }
    if (buf.data != nil && buf.cap > 0) {
        A.deallocate[u8](buf.alloc, buf.data, buf.cap);
        buf.data = nil;
    }
    buf.len = 0;
    buf.cap = 0;
}

# append a single byte to the buffer, growing it if needed
#
# An allocation failure while growing is fatal (`panic`): byte emission is on the
# encoder's hot path and does not thread an error through every write.
# ---
# buf:  buffer to append to
# byte: byte to append
pub fun emit_byte(buf: *ByteBuf, byte: u8) {
    if (buf.len >= buf.cap) {
        var new_cap: usize = BYTEBUF_INIT_CAP;
        if (buf.cap > 0) { new_cap = buf.cap * 2; }
        val res_realloc: R.Result[*u8, str] = A.reallocate[u8](buf.alloc, buf.data, buf.cap, new_cap);
        if (R.is_err[*u8, str](res_realloc)) {
            panic("encode: byte buffer realloc failed\n");
        }
        buf.data = R.unwrap_ok[*u8, str](res_realloc);
        buf.cap  = new_cap;
    }
    buf.data[buf.len] = byte;
    buf.len = buf.len + 1;
}

# append a 16-bit value to the buffer, little-endian
# ---
# buf:   buffer to append to
# value: value to append, low byte first
pub fun emit_u16(buf: *ByteBuf, value: u16) {
    emit_byte(buf, (value & 0xFF)::u8);
    emit_byte(buf, ((value >> 8) & 0xFF)::u8);
}

# append a 32-bit value to the buffer, little-endian
# ---
# buf:   buffer to append to
# value: value to append, low byte first
pub fun emit_u32(buf: *ByteBuf, value: u32) {
    emit_byte(buf, (value & 0xFF)::u8);
    emit_byte(buf, ((value >> 8) & 0xFF)::u8);
    emit_byte(buf, ((value >> 16) & 0xFF)::u8);
    emit_byte(buf, ((value >> 24) & 0xFF)::u8);
}

# append a 64-bit value to the buffer, little-endian
# ---
# buf:   buffer to append to
# value: value to append, low 32 bits first
pub fun emit_u64(buf: *ByteBuf, value: u64) {
    emit_u32(buf, (value & 0xFFFFFFFF)::u32);
    emit_u32(buf, ((value >> 32) & 0xFFFFFFFF)::u32);
}

# initial capacity for the encoder driver's symbol, relocation, fixup, and
# block-offset arrays
val DRIVER_INIT_CAP: u32 = 16;

# a single pending branch fixup recorded in pass 1 and patched in pass 2
#
# An intra-module branch whose displacement field is at `patch_pos` and whose
# target is block `target_block` within the function based at `fn_text_base`. The
# field's width and how a resolved displacement is written into it are
# ISA-specific (the `EncodeHooks.patch_branch` hook), so this record names only
# the offsets the shared driver resolves.
# ---
# patch_pos:    byte offset of the displacement field within `.text`
# next_ip:      byte offset of the instruction following the branch within `.text`
# target_block: destination MIR block id (function-local)
# fn_text_base: text offset of the owning function's first block
pub rec BranchFixup {
    patch_pos:    u32;
    next_ip:      u32;
    target_block: u32;
    fn_text_base: u32;
}

# one resolved block start: a function-local block id paired with its `.text`
# offset, used to compute branch displacements in pass 2
# ---
# fn_text_base: text offset of the owning function's first block
# block_id:     function-local MIR block id
# offset:       byte offset of the block's first instruction within `.text`
rec BlockOffset {
    fn_text_base: u32;
    block_id:     u32;
    offset:       u32;
}

# mutable bookkeeping shared across the encoder driver's two passes
#
# Owns the growable text / symbol / relocation / fixup / block-offset arrays until
# `encode_driver` either transfers the text, symbol, and relocation arrays into
# the returned `EncoderOutput` or frees everything on error. Carries no
# architecture-specific state - every field is ISA-general bookkeeping the shared
# driver and every ISA's encode hook populate through the `push_*` helpers.
# ---
# alloc:       backing allocator for every owned array
# buf:         text byte sink
# syms:        symbol marks
# sym_count:   number of symbol marks
# sym_cap:     capacity of `syms`
# relocs:      pending relocations
# reloc_count: number of relocations
# reloc_cap:   capacity of `relocs`
# fixups:      pending branch fixups
# fixup_count: number of fixups
# fixup_cap:   capacity of `fixups`
# blocks:      resolved block offsets
# block_count: number of block offsets
# block_cap:   capacity of `blocks`
# next_block_id:  MIR id of the block physically following the one being emitted -
#                 its fallthrough successor, set per block by the encode hook so a
#                 terminator branching to it emits nothing (issue #1936)
# has_next_block: false while emitting the final (fallthrough-less) block, so the
#                 fallthrough check never fires on a terminator with no successor
# interner:    session interner; resolves inline-asm `{name}` binding names and
#              interns symbol names referenced from inline asm into relocations
# abi:         target ABI vtable (frame / argument model the encode hook reads)
# os:          target OS vtable (stack-probe / commit model the encode hook reads)
pub rec EncodeState {
    alloc:       *A.Allocator;
    buf:         ByteBuf;
    syms:        *SymbolMark;
    sym_count:   u32;
    sym_cap:     u32;
    relocs:      *PendingReloc;
    reloc_count: u32;
    reloc_cap:   u32;
    fixups:      *BranchFixup;
    fixup_count: u32;
    fixup_cap:   u32;
    blocks:      *BlockOffset;
    block_count: u32;
    block_cap:   u32;
    rows:        *LineRow;
    row_count:   u32;
    row_cap:     u32;
    varlocs:     *VarLoc;
    varloc_count: u32;
    varloc_cap:  u32;
    inline_pcs:  *InlinePc;
    inline_pc_count: u32;
    inline_pc_cap:   u32;
    last_inline_site: u32;
    next_block_id:  u32;
    has_next_block: bool;
    interner:    *intern.Interner;
    abi:         *abi.AbiVTable;
    os:          *tos.OsVTable;
}

# the per-function encode hook: emit one function's machine code into the shared
# `EncodeState`
#
# Emits the prologue, the instruction stream, and the epilogue, recording its
# entry `SymbolMark`, every block's `.text` offset (`push_block`), each
# cross-function / global symbol reference as a `PendingReloc` (`push_reloc`), and
# each intra-module branch as a `BranchFixup` (`push_fixup`) for pass 2. Owns all
# opcode, register, relocation-offset, and prologue/epilogue knowledge; the driver
# supplies only the shared state.
# ---
# st:  the shared encode state (text sink + mark / reloc / fixup / block arrays)
# f:   the function to encode
# ret: ok(true) on success, or an error string from the per-arch encoder
pub def EncodeFunctionFn: fun(*EncodeState, *mir.MirFunction) R.Result[bool, str];

# the per-branch patch hook: write the resolved displacement of one pass-1
# `BranchFixup` into its `.text` field now that its target block's offset is known
#
# Owns the ISA's branch encoding - the field width and the byte / bitfield layout
# (x86-64 overwrites a 4-byte rel32; AArch64 inserts an imm26 / imm19 into a
# 32-bit instruction word) and the displacement convention (relative to `next_ip`,
# the branch start, etc.). The driver resolves `target_off` and leaves the
# displacement computation and the write to the hook.
# ---
# st:         the shared encode state (its `buf` holds the text being patched)
# fx:         the fixup to patch (its `patch_pos` / `next_ip` name the site)
# target_off: the `.text` offset of the branch's resolved target block
# ret:        ok(true) on success, or an error string (e.g. an out-of-range site)
pub def PatchBranchFn: fun(*EncodeState, *BranchFixup, u32) R.Result[bool, str];

# the per-ISA seam of the shared two-pass encoder driver
#
# An architecture's encoder supplies one of each and calls `encode_driver`; the
# driver owns everything else (state lifetime, the function loop, pass-2 block
# resolution, text right-sizing, and output assembly). These two are the only
# operations that carry opcode / register / displacement knowledge.
# ---
# encode_function: emit one function's bytes into the shared state (pass 1)
# patch_branch:    write one resolved branch displacement into the text (pass 2)
pub rec EncodeHooks {
    encode_function: EncodeFunctionFn;
    patch_branch:    PatchBranchFn;
}

# the ISA-agnostic two-pass encoder driver every architecture runs over a
# fully-resolved MIR module to produce its `EncoderOutput`
#
# Initialises an `EncodeState` (empty text sink and mark / reloc / fixup / block
# arrays, threading the module interner and the target ABI / OS vtables), then
# runs pass 1 - walking every function in layout order through the ISA's
# `encode_function` hook, which appends bytes and records symbol marks, pending
# relocations, branch fixups, and block offsets through the shared `push_*`
# helpers. Pass 2 resolves every recorded `BranchFixup`'s target block offset and
# hands it to the ISA's `patch_branch` hook to write the displacement. The text is
# then right-sized (so the object builder's free-by-length matches the allocation)
# and transferred, with the symbol and relocation arrays, into the returned
# `EncoderOutput`; the driver-internal fixup and block arrays are released. On any
# error every owned array is freed and the error propagated. Carries no
# architecture-specific knowledge - the two hooks own all of it.
# ---
# alloc: backing allocator for the encoder's output arrays (threaded for parity
#        with `EncodeFn`; the dispatcher hands the module allocator)
# tgt:   resolved compilation target; supplies the ABI / OS vtables the hook reads
# m:     the fully-resolved MIR module (post isel / regalloc / frame)
# hooks: the per-ISA encode / patch operations
# ret:   the populated `EncoderOutput` (owned arrays), or an error string
pub fun encode_driver(alloc: *A.Allocator, tgt: *target.Target, m: *mir.MirModule, hooks: *EncodeHooks) R.Result[EncoderOutput, str] {
    if (tgt == nil)   { ret R.err[EncoderOutput, str]("encode: nil target"); }
    if (m == nil)     { ret R.err[EncoderOutput, str]("encode: nil mir module"); }
    if (hooks == nil) { ret R.err[EncoderOutput, str]("encode: nil encode hooks"); }
    if (hooks.encode_function == nil) {
        ret R.err[EncoderOutput, str]("encode: ISA supplied no per-function encode hook");
    }
    if (hooks.patch_branch == nil) {
        ret R.err[EncoderOutput, str]("encode: ISA supplied no per-branch patch hook");
    }

    var st: EncodeState;
    state_init(?st, alloc, m, tgt);

    var fi: u32 = 0;
    for (fi < m.function_len) {
        # each function starts in its own body (inline instance 0); reset the transition
        # tracker so a function whose last instruction was inlined does not suppress the
        # next function's opening transition (inline-site ids are per-function).
        st.last_inline_site = 0;
        val res_encode: R.Result[bool, str] = hooks.encode_function(?st, ?m.functions[fi]);
        if (R.is_err[bool, str](res_encode)) {
            state_dnit(?st);
            ret R.err[EncoderOutput, str](R.unwrap_err[bool, str](res_encode));
        }
        fi = fi + 1;
    }

    val res_patch: R.Result[bool, str] = patch_branches(?st, hooks);
    if (R.is_err[bool, str](res_patch)) {
        state_dnit(?st);
        ret R.err[EncoderOutput, str](R.unwrap_err[bool, str](res_patch));
    }

    val res_shrink: R.Result[bool, str] = shrink_text(?st);
    if (R.is_err[bool, str](res_shrink)) {
        state_dnit(?st);
        ret R.err[EncoderOutput, str](R.unwrap_err[bool, str](res_shrink));
    }

    var out: EncoderOutput;
    out.text         = st.buf.data;
    out.text_len     = st.buf.len::u32;
    out.relocations  = st.relocs;
    out.reloc_count  = st.reloc_count;
    out.symbols      = st.syms;
    out.symbol_count = st.sym_count;
    out.rows         = st.rows;
    out.row_count    = st.row_count;
    out.inline_pcs   = st.inline_pcs;
    out.inline_pc_count = st.inline_pc_count;
    out.varlocs      = st.varlocs;
    out.varloc_count = st.varloc_count;

    # the text, symbol, relocation, line-row, and varloc arrays are transferred to the
    # output; only the driver-internal fixup and block-offset arrays are released.
    scratch_release(?st);
    ret R.ok[EncoderOutput, str](out);
}

# determine whether an instruction names an intra-module branch target (a
# `MIR_OP_BLOCK` operand) or a relocatable symbol (a `MIR_OP_SYM` operand)
#
# Reports the first block id and the first interned symbol name through the
# out-parameters and stops as soon as both are found. MIR-level and ISA-agnostic
# - it reads only the generic operand model, so every architecture's encode hook
# uses it to drive fixup / relocation recording.
# ---
# mi:           the instruction to inspect
# target_block: out - the referenced block id (0 when none)
# has_block:    out - true when a MIR_OP_BLOCK operand was found
# sym:          out - the referenced interned symbol name (STR_NIL when none)
# has_sym:      out - true when a MIR_OP_SYM operand was found
# sym_addend:   out - the symbol operand's constant offset
pub fun classify_refs(mi: *mir.MirInstr, target_block: *u32, has_block: *bool,
                      sym: *intern.StrId, has_sym: *bool, sym_addend: *i32) {
    @has_block    = false;
    @has_sym      = false;
    @target_block = 0;
    @sym          = intern.STR_NIL;
    @sym_addend   = 0;

    var found_block: bool = false;
    var found_sym:   bool = false;
    var i:           u32  = 0;
    for (i < mi.operand_count) {
        val op: *mir.MirOperand = ?mi.operands[i];
        if (op.kind == mir.MIR_OP_BLOCK && found_block == false) {
            found_block   = true;
            @has_block    = true;
            @target_block = op.imm::u32;
        }
        if (op.kind == mir.MIR_OP_SYM && found_sym == false) {
            found_sym   = true;
            @has_sym    = true;
            @sym        = op.sym;
            @sym_addend = op.sym_off;
        }
        if (found_block && found_sym) { brk; }
        i = i + 1;
    }
}

# append a symbol mark, growing the symbol array on demand
# ---
# st:     the encode state whose symbol array receives the mark
# name:   interned symbol name
# offset: byte offset of the symbol within `.text`
# flags:  object-symbol flags
# ret:    ok(true) on success, or an allocation error
pub fun push_symbol(st: *EncodeState, name: intern.StrId, offset: u32, flags: u32) R.Result[bool, str] {
    if (st.sym_count >= st.sym_cap) {
        val res_grow: R.Result[bool, str] = grow_symbols(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.syms[st.sym_count].name   = name;
    st.syms[st.sym_count].offset = offset;
    st.syms[st.sym_count].flags  = flags;
    st.sym_count = st.sym_count + 1;
    ret R.ok[bool, str](true);
}

# append a pending relocation, growing the relocation array on demand
# ---
# st:     the encode state whose relocation array receives the entry
# offset: byte offset of the patch site within `.text`
# kind:   abstract relocation kind (one of of.RK_*)
# sym:    interned name of the referenced symbol
# addend: constant added to the resolved symbol address
# ret:    ok(true) on success, or an allocation error
pub fun push_reloc(st: *EncodeState, offset: u32, kind: of.RelocKind, sym: intern.StrId, addend: i32) R.Result[bool, str] {
    if (st.reloc_count >= st.reloc_cap) {
        val res_grow: R.Result[bool, str] = grow_relocs(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.relocs[st.reloc_count].offset = offset;
    st.relocs[st.reloc_count].kind   = kind;
    st.relocs[st.reloc_count].sym    = sym;
    st.relocs[st.reloc_count].addend = addend;
    st.reloc_count = st.reloc_count + 1;
    ret R.ok[bool, str](true);
}

# append a branch fixup, growing the fixup array on demand
# ---
# st:           the encode state whose fixup array receives the entry
# patch_pos:    byte offset of the displacement field within `.text`
# next_ip:      byte offset of the instruction following the branch
# target_block: destination MIR block id (function-local)
# fn_text_base: text offset of the owning function's first block
# ret:          ok(true) on success, or an allocation error
pub fun push_fixup(st: *EncodeState, patch_pos: u32, next_ip: u32, target_block: u32, fn_text_base: u32) R.Result[bool, str] {
    if (st.fixup_count >= st.fixup_cap) {
        val res_grow: R.Result[bool, str] = grow_fixups(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.fixups[st.fixup_count].patch_pos    = patch_pos;
    st.fixups[st.fixup_count].next_ip      = next_ip;
    st.fixups[st.fixup_count].target_block = target_block;
    st.fixups[st.fixup_count].fn_text_base = fn_text_base;
    st.fixup_count = st.fixup_count + 1;
    ret R.ok[bool, str](true);
}

# append a resolved block offset, growing the block-offset array on demand
# ---
# st:           the encode state whose block-offset array receives the entry
# fn_text_base: text offset of the owning function's first block
# block_id:     function-local MIR block id
# offset:       byte offset of the block's first instruction within `.text`
# ret:          ok(true) on success, or an allocation error
pub fun push_block(st: *EncodeState, fn_text_base: u32, block_id: u32, offset: u32) R.Result[bool, str] {
    if (st.block_count >= st.block_cap) {
        val res_grow: R.Result[bool, str] = grow_blocks(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.blocks[st.block_count].fn_text_base = fn_text_base;
    st.blocks[st.block_count].block_id     = block_id;
    st.blocks[st.block_count].offset       = offset;
    st.block_count = st.block_count + 1;
    ret R.ok[bool, str](true);
}

# record which block physically follows block index `bi` in `f`'s layout, the
# fallthrough successor a terminator can reach with no branch. the ISA encode hook
# calls this at the top of each block iteration, before emitting that block's
# instructions, so its terminator sees the correct successor. the final block has
# no fallthrough, so the marker is cleared (issue #1936)
# ---
# st: the encode state whose fallthrough marker is set
# f:  the function being emitted
# bi: index of the block about to be emitted
pub fun set_fallthrough(st: *EncodeState, f: *mir.MirFunction, bi: u32) {
    if (bi + 1 < f.block_count) {
        st.has_next_block = true;
        st.next_block_id  = f.blocks[bi + 1].id;
    } or {
        st.has_next_block = false;
        st.next_block_id  = 0;
    }
}

# true when a terminator branching to `target_block` reaches the fallthrough
# successor recorded by `set_fallthrough`, so its jump is redundant and emits
# nothing. only the not-taken / unconditional edge is ever tested this way; a
# conditional's taken edge always keeps its jump (issue #1936)
# ---
# st:           the encode state carrying the current fallthrough marker
# target_block: the branch edge's destination block id
# ret:          true when the edge falls through to the next block in layout order
pub fun branch_falls_through(st: *EncodeState, target_block: u32) bool {
    ret st.has_next_block && st.next_block_id == target_block;
}

# append a PC<->source line row, growing the row array on demand
#
# Called by an ISA encoder for each instruction that carries a source location, at
# the `.text` offset where its bytes begin. A location naming no file
# (`source.loc_nil()`, a compiler-synthesized instruction) is dropped so its byte
# range is attributed to the preceding row's line. The row survives into
# `EncoderOutput` and is kept correct under `insert_text` relaxation and codegen
# re-homing.
# ---
# st:          the encode state whose row array receives the entry
# text_offset: byte offset of the instruction's first byte within `.text`
# loc:         the instruction's source location
# ret:         ok(true) on success (or a dropped nil location), or an allocation error
pub fun push_row(st: *EncodeState, text_offset: u32, loc: source.SrcLoc) R.Result[bool, str] {
    if (!source.loc_is_valid(loc)) { ret R.ok[bool, str](true); }
    if (st.row_count >= st.row_cap) {
        val res_grow: R.Result[bool, str] = grow_rows(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.rows[st.row_count].text_offset = text_offset;
    st.rows[st.row_count].sec         = 0;
    st.rows[st.row_count].loc         = loc;
    st.row_count = st.row_count + 1;
    ret R.ok[bool, str](true);
}

# record a variable-location record for a source-variable binding `(iid, vreg)` that
# becomes live at `text_offset`. The vreg's post-regalloc home (assigned register or
# spill slot) becomes the raw home the producer maps to a DWARF location. A NIL vreg or
# a vreg with neither home is an optimized-out binding (VARLOC_NONE), which the producer
# renders as a gap
# ---
# st:          the encode state
# text_offset: `.text` offset where the binding becomes live
# fn:          the MIR function owning the vreg (its vregs / frame give the home)
# vreg:        the bound value's vreg, or mir.MIR_VREG_NIL for no home
# iid:         the source OP_DBG_VALUE instruction id
# ret:         ok(true), or an allocation error
pub fun push_varloc(st: *EncodeState, text_offset: u32, fn: *mir.MirFunction, vreg: u32, iid: u32) R.Result[bool, str] {
    var kind: u8  = VARLOC_NONE;
    var reg:  i32 = 0;
    var off:  i64 = 0;
    var storage: bool = false;
    if (vreg != mir.MIR_VREG_NIL && vreg < fn.vreg_count) {
        val vr: *mir.MirVReg = ?fn.vregs[vreg];
        if (vr.assigned != mir.MIR_VREG_NIL) {
            kind = VARLOC_REG;
            reg  = vr.assigned::i32;
        }
        or (vr.spill_slot >= 0) {
            var si: u32 = 0;
            for (si < fn.frame.slot_count) {
                if (fn.frame.slots[si].value == vreg) { kind = VARLOC_FRAME; off = fn.frame.slots[si].offset; }
                si = si + 1;
            }
        }
        or {
            # a register-passed aggregate parameter is reconstructed into a mir.SLOT_SPILL
            # slot it owns; regalloc excludes the slot-owner vreg, so it has no assigned
            # register and no regalloc spill. the slot holds the aggregate's bytes, so the
            # binding is a direct frame location addressing that storage (#1954).
            var si: u32 = 0;
            for (si < fn.frame.slot_count) {
                if (fn.frame.slots[si].value == vreg && fn.frame.slots[si].kind == mir.SLOT_SPILL) {
                    kind = VARLOC_FRAME; off = fn.frame.slots[si].offset; storage = true;
                }
                si = si + 1;
            }
        }
    }

    if (st.varloc_count >= st.varloc_cap) {
        val res_grow: R.Result[bool, str] = grow_varlocs(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.varlocs[st.varloc_count].text_offset = text_offset;
    st.varlocs[st.varloc_count].sec         = 0;
    st.varlocs[st.varloc_count].iid         = iid;
    st.varlocs[st.varloc_count].kind        = kind;
    st.varlocs[st.varloc_count].reg         = reg;
    st.varlocs[st.varloc_count].off         = off;
    st.varlocs[st.varloc_count].off_storage = storage;
    varloc_clear_cmp(?st.varlocs[st.varloc_count]);
    st.varloc_count = st.varloc_count + 1;
    ret R.ok[bool, str](true);
}

# zero a record's compare payload (a plain binding carries none; the fields are
# read only under kind VARLOC_CMP but must not be garbage)
fun varloc_clear_cmp(vl: *VarLoc) {
    vl.end_offset = 0;
    vl.sub_lhs    = VARLOC_NONE;
    vl.sub_rhs    = VARLOC_NONE;
    vl.reg2       = 0;
    vl.off2       = 0;
    vl.cmp_rel    = 0;
    vl.cmp_signed = false;
    vl.cmp_width  = 0;
}

# resolve one fused-compare operand to its VARLOC sub-home: an immediate is its
# raw bits (VARLOC_IMM), a register-assigned vreg its register, a spilled vreg
# its frame slot (holding the machine-word value), and anything else - a vreg
# with no home - VARLOC_NONE, which degrades the whole record
# ---
# fn:      the MIR function owning the vreg table and frame
# is_imm:  true when the operand is an immediate
# vreg:    the operand vreg (when not an immediate)
# imm:     the immediate's raw bits (when is_imm)
# out_kind/out_reg/out_off: the resolved sub-home
fun cmp_operand_home(fn: *mir.MirFunction, is_imm: bool, vreg: u32, imm: i64,
                     out_kind: *u8, out_reg: *i32, out_off: *i64) {
    @out_kind = VARLOC_NONE;
    @out_reg  = 0;
    @out_off  = 0;
    if (is_imm) {
        @out_kind = VARLOC_IMM;
        @out_off  = imm;
        ret;
    }
    if (vreg >= fn.vreg_count) { ret; }
    val vr: *mir.MirVReg = ?fn.vregs[vreg];
    if (vr.assigned != mir.MIR_VREG_NIL) {
        @out_kind = VARLOC_REG;
        @out_reg  = vr.assigned::i32;
        ret;
    }
    if (vr.spill_slot >= 0) {
        var si: u32 = 0;
        for (si < fn.frame.slot_count) {
            if (fn.frame.slots[si].value == vreg) {
                @out_kind = VARLOC_FRAME;
                @out_off  = fn.frame.slots[si].offset;
            }
            si = si + 1;
        }
    }
}

# record a fused-condition computed-value location for a compare binding (see
# VarLoc's VARLOC_CMP contract). both operand homes must resolve - a homeless
# operand degrades the record to a plain optimized-out binding, keeping the gap
# semantics rather than describing a half-computable value. the range stays open
# (`end_offset` 0) until the fused terminator's encoder closes it at the
# instruction's byte end via `close_cmp_varlocs`
# ---
# st:          the encode state
# text_offset: `.text` offset where the fused terminator begins
# fn:          the MIR function owning the operand vregs
# bind:        the compare binding (cmp_op nonzero)
# ret:         ok(true), or an allocation error
pub fun push_cmp_varloc(st: *EncodeState, text_offset: u32, fn: *mir.MirFunction, bind: *mir.MirDbgBinding) R.Result[bool, str] {
    var lk: u8 = VARLOC_NONE; var lr: i32 = 0; var lo: i64 = 0;
    var rk: u8 = VARLOC_NONE; var rr: i32 = 0; var ro: i64 = 0;
    cmp_operand_home(fn, bind.lhs_is_imm, bind.vreg, bind.imm, ?lk, ?lr, ?lo);
    cmp_operand_home(fn, bind.rhs_is_imm, bind.vreg2, bind.imm2, ?rk, ?rr, ?ro);
    if (lk == VARLOC_NONE || rk == VARLOC_NONE) {
        ret push_varloc(st, text_offset, fn, mir.MIR_VREG_NIL, bind.iid);
    }

    var rel: u8 = CMPREL_EQ;
    if (bind.cmp_op == mir.MIR_SEL_CBR_NE)                                            { rel = CMPREL_NE; }
    or (bind.cmp_op == mir.MIR_SEL_CBR_LT_S || bind.cmp_op == mir.MIR_SEL_CBR_LT_U)   { rel = CMPREL_LT; }
    or (bind.cmp_op == mir.MIR_SEL_CBR_LE_S || bind.cmp_op == mir.MIR_SEL_CBR_LE_U)   { rel = CMPREL_LE; }

    if (st.varloc_count >= st.varloc_cap) {
        val res_grow: R.Result[bool, str] = grow_varlocs(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    val vl: *VarLoc = ?st.varlocs[st.varloc_count];
    vl.text_offset = text_offset;
    vl.sec         = 0;
    vl.iid         = bind.iid;
    vl.kind        = VARLOC_CMP;
    vl.reg         = lr;
    vl.off         = lo;
    vl.off_storage = false;
    vl.end_offset  = 0;
    vl.sub_lhs     = lk;
    vl.sub_rhs     = rk;
    vl.reg2        = rr;
    vl.off2        = ro;
    vl.cmp_rel     = rel;
    vl.cmp_signed  = mir.is_signed_cmp(bind.cmp_op);
    vl.cmp_width   = bind.cmp_width;
    st.varloc_count = st.varloc_count + 1;
    ret R.ok[bool, str](true);
}

# close every still-open VARLOC_CMP record the fused terminator at
# `instr_start` pushed, bounding its range to the instruction's byte extent
# `[instr_start, instr_end)` - the only PCs where the computed relation is
# observable. called by each arch's fused-terminator encoder once the branch's
# last byte is emitted; records of other instructions are never touched (the
# backward walk stops at the first record of an earlier offset)
# ---
# st:          the encode state
# instr_start: the fused terminator's first byte offset (its records' offset)
# instr_end:   the offset one past the terminator's last byte
pub fun close_cmp_varlocs(st: *EncodeState, instr_start: u32, instr_end: u32) {
    var i: u32 = st.varloc_count;
    for (i > 0) {
        i = i - 1;
        val vl: *VarLoc = ?st.varlocs[i];
        if (vl.text_offset != instr_start) { ret; }
        if (vl.kind == VARLOC_CMP && vl.end_offset == 0) { vl.end_offset = instr_end; }
    }
}

# record a VarLoc for every `-g` source-variable binding attached to `mi`, at the
# instruction's current `.text` start offset (`st.buf.len`). Called by each ISA encoder
# at the top of `encode_mir_instr`, before the instruction's bytes are emitted, so the
# binding's PC is the instruction's start - the same position a standalone marker would
# have produced. A no-op for the common instruction with no bindings
# ---
# st: the encode state
# fn: the MIR function owning the vregs
# mi: the instruction whose attached bindings are recorded
# ret: ok(true), or an allocation error
pub fun emit_var_bindings(st: *EncodeState, fn: *mir.MirFunction, mi: *mir.MirInstr) R.Result[bool, str] {
    if (mi.dbg_binding_count == 0) { ret R.ok[bool, str](true); }
    val at: u32 = st.buf.len::u32;
    var i: u32 = 0;
    for (i < mi.dbg_binding_count) {
        val bind: *mir.MirDbgBinding = ?mi.dbg_bindings[i];
        # a fused-condition compare binding records the computed relation; a
        # plain binding the vreg's post-regalloc home.
        var r: R.Result[bool, str] = R.ok[bool, str](true);
        if (bind.cmp_op != 0) { r = push_cmp_varloc(st, at, fn, bind); }
        or                    { r = push_varloc(st, at, fn, bind.vreg, bind.iid); }
        if (R.is_err[bool, str](r)) { ret r; }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# grow the variable-location array, allocating it on first use
# ---
# st:  the state whose varloc array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_varlocs(st: *EncodeState) R.Result[bool, str] {
    if (st.varlocs == nil) {
        val res_alloc: R.Result[*VarLoc, str] = A.allocate[VarLoc](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*VarLoc, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*VarLoc, str](res_alloc)); }
        st.varlocs   = R.unwrap_ok[*VarLoc, str](res_alloc);
        st.varloc_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.varloc_cap * 2;
    val res_realloc: R.Result[*VarLoc, str] = A.reallocate[VarLoc](st.alloc, st.varlocs, st.varloc_cap::usize, new_cap::usize);
    if (R.is_err[*VarLoc, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*VarLoc, str](res_realloc)); }
    st.varlocs   = R.unwrap_ok[*VarLoc, str](res_realloc);
    st.varloc_cap = new_cap;
    ret R.ok[bool, str](true);
}

# initialise an encode state with empty output arrays for one driver run
# ---
# st:    the state to populate in place
# alloc: backing allocator for every owned array (and the text sink)
# m:     the MIR module whose interner the state borrows
# tgt:   resolved target whose ABI / OS vtables the encode hook reads
fun state_init(st: *EncodeState, alloc: *A.Allocator, m: *mir.MirModule, tgt: *target.Target) {
    st.alloc       = alloc;
    st.buf         = buf_init(alloc);
    st.syms        = nil;
    st.sym_count   = 0;
    st.sym_cap     = 0;
    st.relocs      = nil;
    st.reloc_count = 0;
    st.reloc_cap   = 0;
    st.fixups      = nil;
    st.fixup_count = 0;
    st.fixup_cap   = 0;
    st.blocks      = nil;
    st.block_count = 0;
    st.block_cap   = 0;
    st.rows        = nil;
    st.row_count   = 0;
    st.row_cap     = 0;
    st.varlocs     = nil;
    st.varloc_count = 0;
    st.varloc_cap  = 0;
    st.inline_pcs  = nil;
    st.inline_pc_count = 0;
    st.inline_pc_cap   = 0;
    st.last_inline_site = 0;
    st.next_block_id  = 0;
    st.has_next_block = false;
    st.interner    = m.interner;
    st.abi         = tgt.abi;
    st.os          = tgt.os;
}

# release every owned array on the error path, including the text sink and the
# symbol / relocation arrays that would otherwise transfer into `EncoderOutput`
# ---
# st: the state to tear down
fun state_dnit(st: *EncodeState) {
    buf_dnit(?st.buf);
    if (st.syms != nil && st.sym_cap > 0) {
        A.deallocate[SymbolMark](st.alloc, st.syms, st.sym_cap::usize);
    }
    st.syms      = nil;
    st.sym_count = 0;
    st.sym_cap   = 0;
    if (st.relocs != nil && st.reloc_cap > 0) {
        A.deallocate[PendingReloc](st.alloc, st.relocs, st.reloc_cap::usize);
    }
    st.relocs      = nil;
    st.reloc_count = 0;
    st.reloc_cap   = 0;
    if (st.rows != nil && st.row_cap > 0) {
        A.deallocate[LineRow](st.alloc, st.rows, st.row_cap::usize);
    }
    st.rows      = nil;
    st.row_count = 0;
    st.row_cap   = 0;
    if (st.varlocs != nil && st.varloc_cap > 0) {
        A.deallocate[VarLoc](st.alloc, st.varlocs, st.varloc_cap::usize);
    }
    st.varlocs      = nil;
    st.varloc_count = 0;
    st.varloc_cap   = 0;
    if (st.inline_pcs != nil && st.inline_pc_cap > 0) {
        A.deallocate[InlinePc](st.alloc, st.inline_pcs, st.inline_pc_cap::usize);
    }
    st.inline_pcs      = nil;
    st.inline_pc_count = 0;
    st.inline_pc_cap   = 0;
    scratch_release(st);
}

# release the driver-internal scratch arrays (fixups, block offsets) once their
# pass-2 work is done; the text / symbol / relocation arrays survive into
# `EncoderOutput`
# ---
# st: the state whose scratch arrays are freed
fun scratch_release(st: *EncodeState) {
    if (st.fixups != nil && st.fixup_cap > 0) {
        A.deallocate[BranchFixup](st.alloc, st.fixups, st.fixup_cap::usize);
    }
    st.fixups      = nil;
    st.fixup_count = 0;
    st.fixup_cap   = 0;
    if (st.blocks != nil && st.block_cap > 0) {
        A.deallocate[BlockOffset](st.alloc, st.blocks, st.block_cap::usize);
    }
    st.blocks      = nil;
    st.block_count = 0;
    st.block_cap   = 0;
}

# shrink the text byte sink so its backing allocation length equals the number of
# bytes written
#
# The object builder frees the transferred `.text` buffer by its `len`, so the
# allocation must be exactly `len` bytes wide. A no-op when the buffer is already
# exact, empty, or unallocated.
# ---
# st:  the state whose text sink is right-sized
# ret: ok(true) on success, or an allocation error
fun shrink_text(st: *EncodeState) R.Result[bool, str] {
    if (st.buf.data == nil) { ret R.ok[bool, str](true); }
    if (st.buf.len == 0) {
        A.deallocate[u8](st.alloc, st.buf.data, st.buf.cap);
        st.buf.data = nil;
        st.buf.cap  = 0;
        ret R.ok[bool, str](true);
    }
    if (st.buf.cap == st.buf.len) { ret R.ok[bool, str](true); }
    val res_shrink: R.Result[*u8, str] = A.reallocate[u8](st.alloc, st.buf.data, st.buf.cap, st.buf.len);
    if (R.is_err[*u8, str](res_shrink)) { ret R.err[bool, str](R.unwrap_err[*u8, str](res_shrink)); }
    st.buf.data = R.unwrap_ok[*u8, str](res_shrink);
    st.buf.cap  = st.buf.len;
    ret R.ok[bool, str](true);
}

# pass 2: resolve each recorded intra-module branch fixup's target block offset
# and hand it to the ISA's `patch_branch` hook, which writes the displacement
#
# The displacement convention and field layout are the hook's; the driver only
# resolves block offsets in the shared block-offset table.
# ---
# st:    the state holding the recorded fixups and block offsets
# hooks: the per-ISA encode / patch operations
# ret:   ok(true) on success, or an error from a lookup or the patch hook
fun patch_branches(st: *EncodeState, hooks: *EncodeHooks) R.Result[bool, str] {
    if (st.buf.data == nil) { ret R.ok[bool, str](true); }
    var i: u32 = 0;
    for (i < st.fixup_count) {
        val fx: *BranchFixup = ?st.fixups[i];
        val res_off: R.Result[u32, str] = block_offset(st, fx.fn_text_base, fx.target_block);
        if (R.is_err[u32, str](res_off)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_off)); }
        val target_off: u32 = R.unwrap_ok[u32, str](res_off);
        val res_patch: R.Result[bool, str] = hooks.patch_branch(st, fx, target_off);
        if (R.is_err[bool, str](res_patch)) { ret R.err[bool, str](R.unwrap_err[bool, str](res_patch)); }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# resolve a function-local block id to its `.text` offset
#
# An unrecorded target is a backend bug (a branch to a block the encoder never
# emitted), rejected loudly rather than resolved to offset 0 (which would be a
# branch into the first function's middle). Public so an ISA's branch-relaxation
# pass can resolve a branch's current target offset while it grows the text.
# ---
# st:       the state holding the recorded block offsets
# fn_base:  text offset of the owning function's first block
# block_id: the function-local block id to resolve
# ret:      the block's `.text` offset, or an error when it was never recorded
pub fun block_offset(st: *EncodeState, fn_base: u32, block_id: u32) R.Result[u32, str] {
    var i: u32 = 0;
    for (i < st.block_count) {
        if (st.blocks[i].fn_text_base == fn_base && st.blocks[i].block_id == block_id) {
            ret R.ok[u32, str](st.blocks[i].offset);
        }
        i = i + 1;
    }
    ret R.err[u32, str]("encode: branch target block was never recorded");
}

# open an `nbytes` gap at byte offset `pos` in the encoded text and keep every
# recorded offset consistent
#
# Shifts the bytes in `[pos, len)` up by `nbytes` (growing the sink as needed),
# zero-fills the opened gap, and advances by `nbytes` every recorded offset at or
# past `pos`: block offsets, branch-fixup patch / next-ip / function-base fields,
# symbol-mark offsets, relocation offsets, and line-row text offsets. This is the ISA-general mechanism a
# branch-relaxation pass uses to grow an out-of-range branch into a longer
# sequence while leaving the fixup, block, symbol, and relocation tables pointing
# at the right instructions. An entry strictly before `pos` is untouched, so the
# relaxing branch's own placeholder word (emitted before the gap) keeps its
# position while the instructions after it slide down. The function's own base
# offset shifts only when the whole function sits at or past `pos`, so opening a
# gap inside a function leaves its base put and moves only the blocks after the
# gap.
# ---
# st:     the encode state whose text and offset tables are adjusted
# pos:    byte offset at which the gap opens
# nbytes: width of the gap (the number of bytes the tail slides down)
# ret:    ok(true) on success, or an allocation error from growing the sink
pub fun insert_text(st: *EncodeState, pos: u32, nbytes: u32) R.Result[bool, str] {
    if (nbytes == 0) { ret R.ok[bool, str](true); }
    val p: usize = pos::usize;
    val n: usize = nbytes::usize;
    if (p > st.buf.len) {
        ret R.err[bool, str]("encode: text-gap offset is past the end of the buffer");
    }

    val need: usize = st.buf.len + n;
    if (need > st.buf.cap) {
        var new_cap: usize = BYTEBUF_INIT_CAP;
        if (st.buf.cap > 0) { new_cap = st.buf.cap; }
        for (new_cap < need) { new_cap = new_cap * 2; }
        val res_realloc: R.Result[*u8, str] = A.reallocate[u8](st.buf.alloc, st.buf.data, st.buf.cap, new_cap);
        if (R.is_err[*u8, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*u8, str](res_realloc)); }
        st.buf.data = R.unwrap_ok[*u8, str](res_realloc);
        st.buf.cap  = new_cap;
    }

    # slide the tail down, copying high-to-low so overlapping ranges stay intact.
    var i: usize = st.buf.len;
    for (i > p) {
        i = i - 1;
        st.buf.data[i + n] = st.buf.data[i];
    }
    var z: usize = p;
    for (z < p + n) {
        st.buf.data[z] = 0;
        z = z + 1;
    }
    st.buf.len = need;

    var bi: u32 = 0;
    for (bi < st.block_count) {
        if (st.blocks[bi].offset >= pos)       { st.blocks[bi].offset = st.blocks[bi].offset + nbytes; }
        if (st.blocks[bi].fn_text_base >= pos) { st.blocks[bi].fn_text_base = st.blocks[bi].fn_text_base + nbytes; }
        bi = bi + 1;
    }
    var fi: u32 = 0;
    for (fi < st.fixup_count) {
        if (st.fixups[fi].patch_pos >= pos)    { st.fixups[fi].patch_pos = st.fixups[fi].patch_pos + nbytes; }
        if (st.fixups[fi].next_ip >= pos)      { st.fixups[fi].next_ip = st.fixups[fi].next_ip + nbytes; }
        if (st.fixups[fi].fn_text_base >= pos) { st.fixups[fi].fn_text_base = st.fixups[fi].fn_text_base + nbytes; }
        fi = fi + 1;
    }
    var si: u32 = 0;
    for (si < st.sym_count) {
        if (st.syms[si].offset >= pos) { st.syms[si].offset = st.syms[si].offset + nbytes; }
        si = si + 1;
    }
    var ri: u32 = 0;
    for (ri < st.reloc_count) {
        if (st.relocs[ri].offset >= pos) { st.relocs[ri].offset = st.relocs[ri].offset + nbytes; }
        ri = ri + 1;
    }
    var wi: u32 = 0;
    for (wi < st.row_count) {
        if (st.rows[wi].text_offset >= pos) { st.rows[wi].text_offset = st.rows[wi].text_offset + nbytes; }
        wi = wi + 1;
    }
    var vli: u32 = 0;
    for (vli < st.varloc_count) {
        if (st.varlocs[vli].text_offset >= pos) { st.varlocs[vli].text_offset = st.varlocs[vli].text_offset + nbytes; }
        # a bounded compare range's end shifts with the text like its start.
        if (st.varlocs[vli].end_offset != 0 && st.varlocs[vli].end_offset >= pos) {
            st.varlocs[vli].end_offset = st.varlocs[vli].end_offset + nbytes;
        }
        vli = vli + 1;
    }
    var ipi: u32 = 0;
    for (ipi < st.inline_pc_count) {
        if (st.inline_pcs[ipi].text_offset >= pos) { st.inline_pcs[ipi].text_offset = st.inline_pcs[ipi].text_offset + nbytes; }
        ipi = ipi + 1;
    }
    ret R.ok[bool, str](true);
}

# grow the symbol-mark array, allocating it on first use
# ---
# st:  the state whose symbol array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_symbols(st: *EncodeState) R.Result[bool, str] {
    if (st.syms == nil) {
        val res_alloc: R.Result[*SymbolMark, str] = A.allocate[SymbolMark](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*SymbolMark, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*SymbolMark, str](res_alloc)); }
        st.syms    = R.unwrap_ok[*SymbolMark, str](res_alloc);
        st.sym_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.sym_cap * 2;
    val res_realloc: R.Result[*SymbolMark, str] = A.reallocate[SymbolMark](st.alloc, st.syms, st.sym_cap::usize, new_cap::usize);
    if (R.is_err[*SymbolMark, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*SymbolMark, str](res_realloc)); }
    st.syms    = R.unwrap_ok[*SymbolMark, str](res_realloc);
    st.sym_cap = new_cap;
    ret R.ok[bool, str](true);
}

# grow the relocation array, allocating it on first use
# ---
# st:  the state whose relocation array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_relocs(st: *EncodeState) R.Result[bool, str] {
    if (st.relocs == nil) {
        val res_alloc: R.Result[*PendingReloc, str] = A.allocate[PendingReloc](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*PendingReloc, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*PendingReloc, str](res_alloc)); }
        st.relocs    = R.unwrap_ok[*PendingReloc, str](res_alloc);
        st.reloc_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.reloc_cap * 2;
    val res_realloc: R.Result[*PendingReloc, str] = A.reallocate[PendingReloc](st.alloc, st.relocs, st.reloc_cap::usize, new_cap::usize);
    if (R.is_err[*PendingReloc, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*PendingReloc, str](res_realloc)); }
    st.relocs    = R.unwrap_ok[*PendingReloc, str](res_realloc);
    st.reloc_cap = new_cap;
    ret R.ok[bool, str](true);
}

# grow the branch-fixup array, allocating it on first use
# ---
# st:  the state whose fixup array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_fixups(st: *EncodeState) R.Result[bool, str] {
    if (st.fixups == nil) {
        val res_alloc: R.Result[*BranchFixup, str] = A.allocate[BranchFixup](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*BranchFixup, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*BranchFixup, str](res_alloc)); }
        st.fixups    = R.unwrap_ok[*BranchFixup, str](res_alloc);
        st.fixup_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.fixup_cap * 2;
    val res_realloc: R.Result[*BranchFixup, str] = A.reallocate[BranchFixup](st.alloc, st.fixups, st.fixup_cap::usize, new_cap::usize);
    if (R.is_err[*BranchFixup, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*BranchFixup, str](res_realloc)); }
    st.fixups    = R.unwrap_ok[*BranchFixup, str](res_realloc);
    st.fixup_cap = new_cap;
    ret R.ok[bool, str](true);
}

# grow the block-offset array, allocating it on first use
# ---
# st:  the state whose block-offset array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_blocks(st: *EncodeState) R.Result[bool, str] {
    if (st.blocks == nil) {
        val res_alloc: R.Result[*BlockOffset, str] = A.allocate[BlockOffset](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*BlockOffset, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*BlockOffset, str](res_alloc)); }
        st.blocks    = R.unwrap_ok[*BlockOffset, str](res_alloc);
        st.block_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.block_cap * 2;
    val res_realloc: R.Result[*BlockOffset, str] = A.reallocate[BlockOffset](st.alloc, st.blocks, st.block_cap::usize, new_cap::usize);
    if (R.is_err[*BlockOffset, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*BlockOffset, str](res_realloc)); }
    st.blocks    = R.unwrap_ok[*BlockOffset, str](res_realloc);
    st.block_cap = new_cap;
    ret R.ok[bool, str](true);
}

# grow the line-row array, allocating it on first use
# ---
# st:  the state whose row array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_rows(st: *EncodeState) R.Result[bool, str] {
    if (st.rows == nil) {
        val res_alloc: R.Result[*LineRow, str] = A.allocate[LineRow](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*LineRow, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*LineRow, str](res_alloc)); }
        st.rows    = R.unwrap_ok[*LineRow, str](res_alloc);
        st.row_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.row_cap * 2;
    val res_realloc: R.Result[*LineRow, str] = A.reallocate[LineRow](st.alloc, st.rows, st.row_cap::usize, new_cap::usize);
    if (R.is_err[*LineRow, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*LineRow, str](res_realloc)); }
    st.rows    = R.unwrap_ok[*LineRow, str](res_realloc);
    st.row_cap = new_cap;
    ret R.ok[bool, str](true);
}

# grow the inline-pc transition array, allocating it on first use
# ---
# st:  the state whose inline-pc array is grown
# ret: ok(true) once the array has room, or an allocation error
fun grow_inline_pcs(st: *EncodeState) R.Result[bool, str] {
    if (st.inline_pcs == nil) {
        val res_alloc: R.Result[*InlinePc, str] = A.allocate[InlinePc](st.alloc, DRIVER_INIT_CAP::usize);
        if (R.is_err[*InlinePc, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*InlinePc, str](res_alloc)); }
        st.inline_pcs    = R.unwrap_ok[*InlinePc, str](res_alloc);
        st.inline_pc_cap = DRIVER_INIT_CAP;
        ret R.ok[bool, str](true);
    }
    val new_cap: u32 = st.inline_pc_cap * 2;
    val res_realloc: R.Result[*InlinePc, str] = A.reallocate[InlinePc](st.alloc, st.inline_pcs, st.inline_pc_cap::usize, new_cap::usize);
    if (R.is_err[*InlinePc, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*InlinePc, str](res_realloc)); }
    st.inline_pcs    = R.unwrap_ok[*InlinePc, str](res_realloc);
    st.inline_pc_cap = new_cap;
    ret R.ok[bool, str](true);
}

# record that at `text_offset` the active inline instance becomes `inline_site`. Only a
# CHANGE from the previously active instance appends a record, so a run of instructions
# in one instance forms a single range `[text_offset, next_offset)`. Called for every
# instruction at its first byte; a no-op for the common body-to-body (0) run.
# ---
# st:          the encode state
# text_offset: `.text` offset of the instruction being encoded
# inline_site: the instruction's inline instance (0 = function body)
# ret:         ok(true), or an allocation error
pub fun push_inline_pc(st: *EncodeState, text_offset: u32, inline_site: u32) R.Result[bool, str] {
    if (inline_site == st.last_inline_site) { ret R.ok[bool, str](true); }
    if (st.inline_pc_count >= st.inline_pc_cap) {
        val res_grow: R.Result[bool, str] = grow_inline_pcs(st);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }
    st.inline_pcs[st.inline_pc_count].text_offset = text_offset;
    st.inline_pcs[st.inline_pc_count].sec         = 0;
    st.inline_pcs[st.inline_pc_count].inline_site = inline_site;
    st.inline_pc_count  = st.inline_pc_count + 1;
    st.last_inline_site = inline_site;
    ret R.ok[bool, str](true);
}

# a minimal encode state for the row / varloc / insert_text unit tests: a text sink and
# an empty set of mark / reloc / fixup / block / row / varloc arrays, no interner or
# vtables
fun t_row_state(alloc: *A.Allocator, st: *EncodeState) {
    st.alloc = alloc;
    st.buf = buf_init(alloc);
    st.syms = nil;   st.sym_count = 0;   st.sym_cap = 0;
    st.relocs = nil; st.reloc_count = 0; st.reloc_cap = 0;
    st.fixups = nil; st.fixup_count = 0; st.fixup_cap = 0;
    st.blocks = nil; st.block_count = 0; st.block_cap = 0;
    st.rows = nil;   st.row_count = 0;   st.row_cap = 0;
    st.varlocs = nil; st.varloc_count = 0; st.varloc_cap = 0;
    st.inline_pcs = nil; st.inline_pc_count = 0; st.inline_pc_cap = 0;
    st.interner = nil; st.abi = nil; st.os = nil;
}

# push_row drops a location naming no file, and insert_text (branch relaxation)
# advances every line row at or past the gap while leaving earlier rows put - so a
# row's text_offset keeps pointing at its instruction after the text grows
test "mach.lang.be.codegen.encode.insert_text:shifts_line_rows" {
    var alloc: A.Allocator;
    page.make(?alloc);

    var st: EncodeState;
    t_row_state(?alloc, ?st);

    # a 12-byte placeholder .text so insert_text has bytes to slide.
    var i: u32 = 0;
    for (i < 12) { emit_byte(?st.buf, 0x90); i = i + 1; }

    # three real rows at 0 / 4 / 8, plus a nil-location row that must be dropped.
    val r0: R.Result[bool, str] = push_row(?st, 0, source.loc(1, 100)); if (R.is_err[bool, str](r0)) { ret 1; }
    val r1: R.Result[bool, str] = push_row(?st, 4, source.loc(1, 200)); if (R.is_err[bool, str](r1)) { ret 1; }
    val rn: R.Result[bool, str] = push_row(?st, 4, source.loc_nil());   if (R.is_err[bool, str](rn)) { ret 1; }
    val r2: R.Result[bool, str] = push_row(?st, 8, source.loc(1, 300)); if (R.is_err[bool, str](r2)) { ret 1; }
    if (st.row_count != 3) { buf_dnit(?st.buf); ret 1; }

    # open a 4-byte gap at offset 4 (as a relaxed branch would).
    val it: R.Result[bool, str] = insert_text(?st, 4, 4);
    if (R.is_err[bool, str](it)) { buf_dnit(?st.buf); ret 1; }

    var code: i32 = 0;
    # the row before the gap is untouched; the rows at/after it advance by 4.
    if (st.rows[0].text_offset != 0)  { code = 1; }
    if (st.rows[1].text_offset != 8)  { code = 1; }
    if (st.rows[2].text_offset != 12) { code = 1; }
    # the source locations ride along unchanged.
    if (st.rows[1].loc.offset != 200) { code = 1; }

    buf_dnit(?st.buf);
    if (st.rows != nil && st.row_cap > 0) { A.deallocate[LineRow](?alloc, st.rows, st.row_cap::usize); }
    ret code;
}

# push_varloc resolves a source-variable binding's vreg to its post-regalloc home: an
# assigned register (VARLOC_REG), a spill slot (VARLOC_FRAME), or - for a vreg with
# neither, a value referenced only by debug and left dead by regalloc - VARLOC_NONE (an
# optimized-out binding), never a stale register id or a panic
test "mach.lang.be.codegen.encode.push_varloc:reg_frame_dead" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var code: i32 = 0;

    var st: EncodeState;
    t_row_state(?alloc, ?st);

    # vreg 0 -> physical register 7; vreg 1 -> spill slot at frame offset -16;
    # vreg 2 -> no home (dead).
    var vregs: [3]mir.MirVReg;
    vregs[0].id = 0; vregs[0].class = 0; vregs[0].spill_slot = -1; vregs[0].assigned = 7;
    vregs[1].id = 1; vregs[1].class = 0; vregs[1].spill_slot = 0;  vregs[1].assigned = mir.MIR_VREG_NIL;
    vregs[2].id = 2; vregs[2].class = 0; vregs[2].spill_slot = -1; vregs[2].assigned = mir.MIR_VREG_NIL;

    var slots: [1]mir.MirSlot;
    slots[0].value = 1; slots[0].kind = mir.SLOT_SPILL; slots[0].offset = -16; slots[0].size = 8; slots[0].align = 8;

    var fn: mir.MirFunction;
    fn.vregs = ?vregs[0]; fn.vreg_count = 3;
    fn.frame.slots = ?slots[0]; fn.frame.slot_count = 1; fn.frame.slot_cap = 1;
    fn.frame.size = 0; fn.frame.align = 0; fn.frame.outgoing_size = 0;

    val ra: R.Result[bool, str] = push_varloc(?st, 0, ?fn, 0, 100); if (R.is_err[bool, str](ra)) { code = 1; }
    val rb: R.Result[bool, str] = push_varloc(?st, 4, ?fn, 1, 101); if (R.is_err[bool, str](rb)) { code = 1; }
    val rc: R.Result[bool, str] = push_varloc(?st, 8, ?fn, 2, 102); if (R.is_err[bool, str](rc)) { code = 1; }

    if (st.varloc_count != 3) { code = 1; }
    if (st.varlocs[0].kind != VARLOC_REG || st.varlocs[0].reg != 7 || st.varlocs[0].iid != 100) { code = 1; }
    if (st.varlocs[1].kind != VARLOC_FRAME || st.varlocs[1].off != -16 || st.varlocs[1].iid != 101) { code = 1; }
    if (st.varlocs[2].kind != VARLOC_NONE || st.varlocs[2].iid != 102) { code = 1; }

    if (st.varlocs != nil && st.varloc_cap > 0) { A.deallocate[VarLoc](?alloc, st.varlocs, st.varloc_cap::usize); }
    buf_dnit(?st.buf);
    ret code;
}

# a fused-condition compare binding records the computed relation over both
# operand homes (register / spill slot / immediate), digested for the producer
# (relation + signedness + width), and close_cmp_varlocs bounds each such record
# to the fused terminator's byte extent while a plain record at the same offset
# keeps its linear-rule 0. a compare binding with a homeless operand degrades to
# a plain optimized-out record
test "mach.lang.be.codegen.encode.push_cmp_varloc:homes_digest_and_close" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var code: i32 = 0;

    var st: EncodeState;
    t_row_state(?alloc, ?st);

    # vreg 0 -> register 7; vreg 1 -> spill slot at -16; vreg 2 -> no home.
    var vregs: [3]mir.MirVReg;
    vregs[0].id = 0; vregs[0].class = 0; vregs[0].spill_slot = -1; vregs[0].assigned = 7;
    vregs[1].id = 1; vregs[1].class = 0; vregs[1].spill_slot = 0;  vregs[1].assigned = mir.MIR_VREG_NIL;
    vregs[2].id = 2; vregs[2].class = 0; vregs[2].spill_slot = -1; vregs[2].assigned = mir.MIR_VREG_NIL;

    var slots: [1]mir.MirSlot;
    slots[0].value = 1; slots[0].kind = mir.SLOT_SPILL; slots[0].offset = -16; slots[0].size = 8; slots[0].align = 8;

    var fn: mir.MirFunction;
    fn.vregs = ?vregs[0]; fn.vreg_count = 3;
    fn.frame.slots = ?slots[0]; fn.frame.slot_count = 1; fn.frame.slot_cap = 1;
    fn.frame.size = 0; fn.frame.align = 0; fn.frame.outgoing_size = 0;

    # unsigned i16 less-than of (reg vreg 0) against (imm 40000), bound at PC 12.
    var bind: mir.MirDbgBinding;
    bind.iid = 100; bind.cmp_op = mir.MIR_SEL_CBR_LT_U; bind.cmp_width = 2;
    bind.lhs_is_imm = false; bind.vreg = 0; bind.imm = 0;
    bind.rhs_is_imm = true;  bind.vreg2 = mir.MIR_VREG_NIL; bind.imm2 = 40000;
    val ra: R.Result[bool, str] = push_cmp_varloc(?st, 12, ?fn, ?bind);
    if (R.is_err[bool, str](ra)) { code = 1; }

    # signed le of (spilled vreg 1) against (reg vreg 0), same terminator.
    bind.iid = 101; bind.cmp_op = mir.MIR_SEL_CBR_LE_S; bind.cmp_width = 8;
    bind.lhs_is_imm = false; bind.vreg = 1;
    bind.rhs_is_imm = false; bind.vreg2 = 0;
    val rb: R.Result[bool, str] = push_cmp_varloc(?st, 12, ?fn, ?bind);
    if (R.is_err[bool, str](rb)) { code = 1; }

    # a plain binding at the same offset stays open under the linear rule.
    val rp: R.Result[bool, str] = push_varloc(?st, 12, ?fn, 0, 102);
    if (R.is_err[bool, str](rp)) { code = 1; }

    # a compare whose operand has no home degrades to a plain optimized-out gap.
    bind.iid = 103; bind.cmp_op = mir.MIR_SEL_CBR_EQ; bind.cmp_width = 4;
    bind.lhs_is_imm = false; bind.vreg = 2;
    bind.rhs_is_imm = true;  bind.imm2 = 0;
    val rd: R.Result[bool, str] = push_cmp_varloc(?st, 12, ?fn, ?bind);
    if (R.is_err[bool, str](rd)) { code = 1; }

    close_cmp_varlocs(?st, 12, 20);

    if (st.varloc_count != 4) { code = 1; }
    val a: *VarLoc = ?st.varlocs[0];
    if (a.kind != VARLOC_CMP)                     { code = 1; }
    if (a.sub_lhs != VARLOC_REG || a.reg != 7)    { code = 1; }
    if (a.sub_rhs != VARLOC_IMM || a.off2 != 40000) { code = 1; }
    if (a.cmp_rel != CMPREL_LT || a.cmp_signed)   { code = 1; }
    if (a.cmp_width != 2)                         { code = 1; }
    if (a.end_offset != 20)                       { code = 1; }
    val b: *VarLoc = ?st.varlocs[1];
    if (b.kind != VARLOC_CMP)                       { code = 1; }
    if (b.sub_lhs != VARLOC_FRAME || b.off != -16)  { code = 1; }
    if (b.sub_rhs != VARLOC_REG || b.reg2 != 7)     { code = 1; }
    if (b.cmp_rel != CMPREL_LE || !b.cmp_signed)    { code = 1; }
    if (b.end_offset != 20)                         { code = 1; }
    val c: *VarLoc = ?st.varlocs[2];
    if (c.kind != VARLOC_REG || c.end_offset != 0)  { code = 1; }
    val d: *VarLoc = ?st.varlocs[3];
    if (d.kind != VARLOC_NONE || d.iid != 103)      { code = 1; }

    if (st.varlocs != nil && st.varloc_cap > 0) { A.deallocate[VarLoc](?alloc, st.varlocs, st.varloc_cap::usize); }
    buf_dnit(?st.buf);
    ret code;
}

# push_varloc resolves a register-passed aggregate parameter - a vreg with no assigned
# register and no regalloc spill, but owning the mir.SLOT_SPILL slot its bytes are
# reconstructed into - to a direct frame location (VARLOC_FRAME with off_storage set), so
# the parameter is locatable rather than silently omitted (#1954)
test "mach.lang.be.codegen.encode.push_varloc:slot_spill_owner_is_direct_frame" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var code: i32 = 0;

    var st: EncodeState;
    t_row_state(?alloc, ?st);

    # vreg 0 owns a mir.SLOT_SPILL slot at -32 (its reconstructed aggregate bytes): no
    # assigned register and no regalloc spill.
    var vregs: [1]mir.MirVReg;
    vregs[0].id = 0; vregs[0].class = 0; vregs[0].spill_slot = -1; vregs[0].assigned = mir.MIR_VREG_NIL;

    var slots: [1]mir.MirSlot;
    slots[0].value = 0; slots[0].kind = mir.SLOT_SPILL; slots[0].offset = -32; slots[0].size = 16; slots[0].align = 8;

    var fn: mir.MirFunction;
    fn.vregs = ?vregs[0]; fn.vreg_count = 1;
    fn.frame.slots = ?slots[0]; fn.frame.slot_count = 1; fn.frame.slot_cap = 1;
    fn.frame.size = 0; fn.frame.align = 0; fn.frame.outgoing_size = 0;

    val r: R.Result[bool, str] = push_varloc(?st, 0, ?fn, 0, 200); if (R.is_err[bool, str](r)) { code = 1; }

    if (st.varloc_count != 1) { code = 1; }
    # a direct frame location at the slot offset, flagged storage so the producer omits the
    # byref pointer deref.
    if (st.varlocs[0].kind != VARLOC_FRAME || st.varlocs[0].off != -32 || !st.varlocs[0].off_storage) { code = 1; }

    if (st.varlocs != nil && st.varloc_cap > 0) { A.deallocate[VarLoc](?alloc, st.varlocs, st.varloc_cap::usize); }
    buf_dnit(?st.buf);
    ret code;
}
