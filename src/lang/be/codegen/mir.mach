# mach.lang.be.codegen.mir: the target-aware machine IR between SSA IR and encoded bytes.
#
# Machine IR (MIR) sits between the target-independent SSA IR
# (`mach.lang.me.ir`) and encoded machine bytes.
# A MIR instruction carries a generic, target-shaped opcode and operates on
# virtual registers; later codegen passes (isel, regalloc, frame, encode)
# rewrite generic opcodes into concrete per-arch forms and resolve virtual
# registers into physical registers and stack slots.
#
# `lower_ir` is the bridge: it walks an `ir.Module` and produces a parallel
# `MirModule`. The translation is deliberately mechanical and target-agnostic
# (it hardcodes no register names or calling-convention constants):
#   - every IR `Block` becomes a `MirBlock` with the same numeric id;
#   - every SSA result (instruction result or function parameter) is assigned
#     exactly one fresh virtual register, and every operand reference becomes a
#     `MIR_OP_VREG` operand naming it;
#   - inline integer / null constants become `MIR_OP_IMM` operands; globals and
#     function symbols become `MIR_OP_SYM` operands;
#   - `OP_CALL` lowers through the active ABI vtable: each argument is classified
#     and pre-colored with a `MIR_MOV` into its canonical argument register (or a
#     stack store), followed by a `MIR_CALL` pseudo naming the callee and a
#     `MIR_CALL_RES` pseudo binding the result vreg from the canonical return
#     register. the argument / return registers come entirely from `tgt.abi`, the
#     frame / stack pointers and division / shift registers from `tgt.isa`, so this
#     lowering hardcodes no register name or calling-convention constant;
#   - `OP_PHI` is eliminated out of SSA: each phi becomes a `MIR_MOV` of its
#     incoming value into the phi's result vreg, inserted at the end of every
#     predecessor block before its terminator (see `lower_phis`), so no phi
#     reaches isel / regalloc / encode.
#
# Generic MIR opcodes mirror the IR `OP_*` values one-for-one (so an IR add
# becomes a generic MIR add with the same number) and add a small block of
# pseudo-opcodes for the lowering-only constructs. Instruction selection
# (`isel`) replaces these generic opcodes with the concrete encoder opcodes
# owned by the active ISA.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use std.system.panic.panic;

use map: std.collections.map;

use intern:  mach.lang.intern;
use target:  mach.lang.target.resolved;
use abi:     mach.lang.target.abi;
use sysv:    mach.lang.target.abi.sysv;
use isa:     mach.lang.target.isa;
use ir:      mach.lang.me.ir;
use ir_type: mach.lang.me.ir.type;
use instr:   mach.lang.me.ir.instruction;
use value:   mach.lang.me.ir.value;
use id:      mach.lang.me.ir.id;

# MirOperandKind: discriminator for `MirOperand`; selects which operand fields are live.
pub def MirOperandKind: u8;

# MIR_OP_VREG: a virtual register reference; `vreg` indexes `MirFunction.vregs`, resolved by regalloc.
pub val MIR_OP_VREG:  MirOperandKind = 0;
# MIR_OP_PREG: a physical register reference; `preg` is a register id within its RegClass.
pub val MIR_OP_PREG:  MirOperandKind = 1;
# MIR_OP_IMM: an immediate integer constant carried in `imm`.
pub val MIR_OP_IMM:   MirOperandKind = 2;
# MIR_OP_MEM: a memory reference `[base + index*scale + imm]`. the base is
# disambiguated by `vreg`: when `vreg != MIR_VREG_NIL` it is a frame-slot key (a
# slot-owning vreg id the encoder resolves to `[rbp + slot.offset + imm]`); when
# `vreg == MIR_VREG_NIL` it is a physical register base in `preg` (the encoder
# forms `[preg + imm]`). a pre-regalloc value-pointer base rides as a value vreg
# in `vreg` and regalloc rewrites it to the physical-register form.
#
# the optional scaled index is the GEP address-folding component: `index` names a
# value vreg (pre-regalloc) or physical register id (`index_is_preg` set, after
# regalloc) holding a runtime index, scaled by `scale` (one of 1/2/4/8 — x86 SIB).
# when `index == MIR_VREG_NIL` there is no index and the form is the plain
# `[base + imm]`. regalloc treats the index like the base: a value vreg is
# rewritten to its physical register (setting `index_is_preg`) and reloaded if
# spilled. an index may ride any base — a physical register, a value-pointer
# base, or a frame-slot-key base (a GEP into an alloca with a runtime index folds
# the scaled index alongside the slot offset, and the encoder forms
# `[rbp + slot.offset + index*scale + imm]` via SIB).
pub val MIR_OP_MEM:   MirOperandKind = 3;
# MIR_OP_SYM: a symbol reference for a relocation; interned name in `sym`, addend `sym_off`.
pub val MIR_OP_SYM:   MirOperandKind = 4;
# MIR_OP_BLOCK: a branch-target block reference; target `MirBlock.id` carried in `imm`.
pub val MIR_OP_BLOCK: MirOperandKind = 5;

# MirOpcode: the generic MIR opcode emitted by `lower_ir` before isel, mirroring IR `OP_*` numbering one-for-one.
pub def MirOpcode: u32;

# MIR_ADD: integer / pointer addition.
pub val MIR_ADD:         MirOpcode = 0;
# MIR_SUB: integer / pointer subtraction.
pub val MIR_SUB:         MirOpcode = 1;
# MIR_MUL: integer multiplication.
pub val MIR_MUL:         MirOpcode = 2;
# MIR_DIV_S: signed integer division.
pub val MIR_DIV_S:       MirOpcode = 3;
# MIR_DIV_U: unsigned integer division.
pub val MIR_DIV_U:       MirOpcode = 4;
# MIR_REM_S: signed integer remainder.
pub val MIR_REM_S:       MirOpcode = 5;
# MIR_REM_U: unsigned integer remainder.
pub val MIR_REM_U:       MirOpcode = 6;
# MIR_NEG: integer negation.
pub val MIR_NEG:         MirOpcode = 7;
# MIR_AND: bitwise and.
pub val MIR_AND:         MirOpcode = 8;
# MIR_OR: bitwise or.
pub val MIR_OR:          MirOpcode = 9;
# MIR_XOR: bitwise exclusive or.
pub val MIR_XOR:         MirOpcode = 10;
# MIR_SHL: left shift.
pub val MIR_SHL:         MirOpcode = 11;
# MIR_SHR_S: arithmetic (sign-filling) right shift.
pub val MIR_SHR_S:       MirOpcode = 12;
# MIR_SHR_U: logical (zero-filling) right shift.
pub val MIR_SHR_U:       MirOpcode = 13;
# MIR_NOT: bitwise complement.
pub val MIR_NOT:         MirOpcode = 14;
# MIR_CMP_EQ: equality comparison.
pub val MIR_CMP_EQ:      MirOpcode = 15;
# MIR_CMP_NE: inequality comparison.
pub val MIR_CMP_NE:      MirOpcode = 16;
# MIR_CMP_LT_S: signed less-than comparison.
pub val MIR_CMP_LT_S:    MirOpcode = 17;
# MIR_CMP_LT_U: unsigned less-than comparison.
pub val MIR_CMP_LT_U:    MirOpcode = 18;
# MIR_CMP_LE_S: signed less-or-equal comparison.
pub val MIR_CMP_LE_S:    MirOpcode = 19;
# MIR_CMP_LE_U: unsigned less-or-equal comparison.
pub val MIR_CMP_LE_U:    MirOpcode = 20;
# MIR_TRUNC: integer truncation to a narrower width.
pub val MIR_TRUNC:       MirOpcode = 21;
# MIR_SEXT: sign-extension to a wider width.
pub val MIR_SEXT:        MirOpcode = 22;
# MIR_ZEXT: zero-extension to a wider width.
pub val MIR_ZEXT:        MirOpcode = 23;
# MIR_FP_TRUNC: float truncation to a narrower precision.
pub val MIR_FP_TRUNC:    MirOpcode = 24;
# MIR_FP_EXT: float extension to a wider precision.
pub val MIR_FP_EXT:      MirOpcode = 25;
# MIR_FP_TO_SI: float-to-signed-integer conversion.
pub val MIR_FP_TO_SI:    MirOpcode = 26;
# MIR_FP_TO_UI: float-to-unsigned-integer conversion.
pub val MIR_FP_TO_UI:    MirOpcode = 27;
# MIR_SI_TO_FP: signed-integer-to-float conversion.
pub val MIR_SI_TO_FP:    MirOpcode = 28;
# MIR_UI_TO_FP: unsigned-integer-to-float conversion.
pub val MIR_UI_TO_FP:    MirOpcode = 29;
# MIR_BITCAST: reinterpret a value's bits as another type of the same width.
pub val MIR_BITCAST:     MirOpcode = 30;
# MIR_ALLOCA: reserve a stack slot and yield its address.
pub val MIR_ALLOCA:      MirOpcode = 31;
# MIR_LOAD: load a value from a memory operand.
pub val MIR_LOAD:        MirOpcode = 32;
# MIR_STORE: store a value to a memory operand.
pub val MIR_STORE:       MirOpcode = 33;
# MIR_GEP: compute an element / field address (selects to LEA).
pub val MIR_GEP:         MirOpcode = 34;
# MIR_EXTRACT: extract a field value from an aggregate.
pub val MIR_EXTRACT:     MirOpcode = 35;
# MIR_INSERT: insert a field value into an aggregate.
pub val MIR_INSERT:      MirOpcode = 36;
# MIR_PHI: an SSA phi; never emitted — `lower_phis` eliminates phis into
# predecessor-end MIR_MOVs, and the encoder rejects any stray MIR_PHI loudly.
pub val MIR_PHI:         MirOpcode = 37;
# MIR_CALL_IR: the IR OP_CALL placeholder; never emitted directly — `lower_ir`
# expands calls into the argument pre-coloring, MIR_CALL, and MIR_CALL_RES.
pub val MIR_CALL_IR:     MirOpcode = 38;
# MIR_BR: an unconditional branch to a target block.
pub val MIR_BR:          MirOpcode = 39;
# MIR_CBR: a conditional branch to one of two target blocks.
pub val MIR_CBR:         MirOpcode = 40;
# MIR_RET: return from the function.
pub val MIR_RET:         MirOpcode = 41;
# MIR_UNREACHABLE: an unreachable terminator.
pub val MIR_UNREACHABLE: MirOpcode = 42;
# MIR_ASM: an inline-assembly block.
pub val MIR_ASM:         MirOpcode = 43;

# MIR_MOV: a register-to-register move pseudo; operands [dst, src].
# `lower_ir` emits MIR_MOV both for ordinary vreg copies and for ABI
# pre-coloring: the dst or src is a MIR_OP_PREG naming a physical argument /
# return / hidden-pointer register, and the other operand is the vreg (or an
# immediate, e.g. the fp-arg-count move into AL before a varargs call). isel
# rewrites MIR_MOV to the concrete machine move; regalloc treats a MIR_OP_PREG
# operand as a fixed pre-color it must honor.
pub val MIR_MOV:      MirOpcode = 0x1000;
# MIR_ARG: a vestigial outgoing-argument marker. `lower_ir` performs SysV
# classification inline and emits the argument-register MIR_MOV pre-coloring (or
# stack store) directly, so no MIR_ARG instructions are produced anymore; the
# opcode is retained only so isel's pass-through arm stays total.
pub val MIR_ARG:      MirOpcode = 0x1001;
# MIR_CALL: a call pseudo; operand 0 is the SYM-or-VREG callee. side effects
# only — the result is bound by the MIR_CALL_RES move and arguments arrive via
# the argument-register MIR_MOV pre-coloring `lower_ir` emits before it.
#
# CLOBBER CONVENTION (regalloc + encode must agree): a MIR_CALL implicitly
# clobbers EVERY caller-saved register of the active ABI — both the GP and FP
# files. There is no per-instruction clobber operand; the opcode itself IS the
# clobber barrier. regalloc derives the caller-saved set as "every allocatable
# physical register in a class that is NOT in `tgt.abi`'s callee_saved set" and,
# at each MIR_CALL, must spill/save any vreg whose assigned register is
# caller-saved (or FP) and reload it after, and must never satisfy a reload temp
# from a caller-saved register across the call. The fixed argument / return
# pre-coloring registers (RDI, RSI, RDX, RCX, R8, R9, RAX, XMM0..7, AL) are part
# of that caller-saved set, so the pre-coloring MIR_MOVs that bracket the call
# are consistent with this barrier. encode emits no extra bytes for the barrier;
# it relies on regalloc having already inserted the saves/reloads.
pub val MIR_CALL:     MirOpcode = 0x1002;
# MIR_CALL_RES: a call-result-binding pseudo; operand 0 is the dst vreg. for a
# value-returning call `lower_ir` emits the return-register MIR_MOV
# (`dst <- RAX|XMM0`, or the RAX:RDX / sret pair) immediately after MIR_CALL and
# leaves this pseudo only as a liveness marker for the result vreg.
pub val MIR_CALL_RES: MirOpcode = 0x1003;

# MIR_SEL_ADD: selection-output sentinel for an add with no single-instruction
# form. a handful of generic opcodes survive instruction selection so the encoder
# can materialize a multi-instruction byte sequence; isel rewrites each to a high
# sentinel (0x1100+) so it cannot collide with a concrete encoder opcode in the
# shared 0..74 value space.
pub val MIR_SEL_ADD:    MirOpcode = 0x1100;
# MIR_SEL_SUB: selection-output sentinel for a two-address subtract.
pub val MIR_SEL_SUB:    MirOpcode = 0x1101;
# MIR_SEL_MUL: selection-output sentinel for a two-address multiply.
pub val MIR_SEL_MUL:    MirOpcode = 0x1102;
# MIR_SEL_AND: selection-output sentinel for a two-address bitwise and.
pub val MIR_SEL_AND:    MirOpcode = 0x1103;
# MIR_SEL_OR: selection-output sentinel for a two-address bitwise or.
pub val MIR_SEL_OR:     MirOpcode = 0x1104;
# MIR_SEL_XOR: selection-output sentinel for a two-address bitwise xor.
pub val MIR_SEL_XOR:    MirOpcode = 0x1105;
# MIR_SEL_SHL: selection-output sentinel for a two-address left shift.
pub val MIR_SEL_SHL:    MirOpcode = 0x1106;
# MIR_SEL_SHR_U: selection-output sentinel for a two-address logical right shift.
pub val MIR_SEL_SHR_U:  MirOpcode = 0x1107;
# MIR_SEL_SHR_S: selection-output sentinel for a two-address arithmetic right shift.
pub val MIR_SEL_SHR_S:  MirOpcode = 0x1108;
# MIR_SEL_DIV_S: selection-output sentinel for a signed divide (high-half setup + IDIV).
pub val MIR_SEL_DIV_S:  MirOpcode = 0x1109;
# MIR_SEL_DIV_U: selection-output sentinel for an unsigned divide (high-half setup + DIV).
pub val MIR_SEL_DIV_U:  MirOpcode = 0x110A;
# MIR_SEL_REM_S: selection-output sentinel for a signed remainder.
pub val MIR_SEL_REM_S:  MirOpcode = 0x110B;
# MIR_SEL_REM_U: selection-output sentinel for an unsigned remainder.
pub val MIR_SEL_REM_U:  MirOpcode = 0x110C;
# MIR_SEL_CMP_EQ: selection-output sentinel for an equality compare (CMP;SETcc;MOVZX).
pub val MIR_SEL_CMP_EQ: MirOpcode = 0x110D;
# MIR_SEL_CMP_NE: selection-output sentinel for an inequality compare.
pub val MIR_SEL_CMP_NE: MirOpcode = 0x110E;
# MIR_SEL_CMP_LT_S: selection-output sentinel for a signed less-than compare.
pub val MIR_SEL_CMP_LT_S: MirOpcode = 0x110F;
# MIR_SEL_CMP_LT_U: selection-output sentinel for an unsigned less-than compare.
pub val MIR_SEL_CMP_LT_U: MirOpcode = 0x1110;
# MIR_SEL_CMP_LE_S: selection-output sentinel for a signed less-or-equal compare.
pub val MIR_SEL_CMP_LE_S: MirOpcode = 0x1111;
# MIR_SEL_CMP_LE_U: selection-output sentinel for an unsigned less-or-equal compare.
pub val MIR_SEL_CMP_LE_U: MirOpcode = 0x1112;
# MIR_SEL_CBR: selection-output sentinel for a conditional branch (TEST;JNE;JMP).
pub val MIR_SEL_CBR:    MirOpcode = 0x1113;

# the scalar floating-point arithmetic / comparison ops. the shared IR integer
# opcodes (OP_ADD / OP_SUB / OP_MUL / OP_DIV_* / OP_CMP_*) cover both int and
# float operands; `lower_ir` dispatches on operand/result float type and emits one
# of these dedicated opcodes for a float instead of the integer ALU form, which
# would mis-encode an XMM-classed value. like the compare / divide families they
# survive instruction selection unchanged and the encoder materializes the SSE
# byte sequence (operands loaded `[rbp+off]`/reg -> XMM scratch, the SSE op, the
# result stored back). the operation width (4 for f32, 8 for f64) rides on
# `mi.width` so the encoder selects the SS vs SD form. they occupy the high
# selection-output space so the encoder never confuses one with a concrete x86-64
# opcode of the same low value.
# MIR_FADD: scalar float addition (ADDSS / ADDSD).
pub val MIR_FADD:      MirOpcode = 0x1114;
# MIR_FSUB: scalar float subtraction (SUBSS / SUBSD).
pub val MIR_FSUB:      MirOpcode = 0x1115;
# MIR_FMUL: scalar float multiplication (MULSS / MULSD).
pub val MIR_FMUL:      MirOpcode = 0x1116;
# MIR_FDIV: scalar float division (DIVSS / DIVSD).
pub val MIR_FDIV:      MirOpcode = 0x1117;
# MIR_FCMP: scalar float comparison (UCOMISS / UCOMISD + unsigned SETcc + MOVZX).
# the condition code (one of CC_*) rides on `mi.src_width`'s companion field via a
# dedicated `fcc` carrier set by lowering.
pub val MIR_FCMP:      MirOpcode = 0x1118;

# float-comparison condition codes carried on a MIR_FCMP. a UCOMISD sets CF/ZF/PF
# (an UNORDERED result sets all three), so the float compare maps to UNSIGNED
# SETcc — distinct from the integer compare family's signed conditions.
# FCC_EQ: equal (SETE).
pub val FCC_EQ: u8 = 0;
# FCC_NE: not equal (SETNE).
pub val FCC_NE: u8 = 1;
# FCC_LT: less than (SETB — CF set when below).
pub val FCC_LT: u8 = 2;
# FCC_LE: less or equal (SETBE).
pub val FCC_LE: u8 = 3;
# FCC_GT: greater than (SETA).
pub val FCC_GT: u8 = 4;
# FCC_GE: greater or equal (SETAE).
pub val FCC_GE: u8 = 5;

# MIR_VREG_NIL: sentinel "no virtual register"; never a valid vreg id, never a default.
pub val MIR_VREG_NIL: u32 = 0xFFFFFFFF;

# canonical register-class indices used by `lower_ir`. by convention the
# general-purpose bank is the first declared class and the float/vector bank is
# selected by its wide bit width, so no arch-specific class name is hardcoded.
val REG_CLASS_GP:  u32 = 0;
# minimum register width in bits that identifies the float/vector bank.
val FP_CLASS_MIN_BITS: u32 = 128;

# canonical machine-word width in bytes for address-sized and pointer-sized
# operations (LEA address forms, ABI register moves, the call/branch pseudos).
# the encoder also treats a `width` of 0 as this width.
val WORD_WIDTH: u8 = 8;

# MirOperand: a single MIR operand whose live fields depend on `kind`.
# ---
# kind:         operand discriminant (one of MIR_OP_*)
# vreg:         virtual register id for VREG, or a MEM frame-slot-key base; for a
#               MEM physical-register base it is MIR_VREG_NIL (the base lives in
#               `preg`)
# preg:         physical register id for PREG, or a MEM physical-register base
#               (when the MEM operand's `vreg` is MIR_VREG_NIL); else 0
# imm:          immediate / displacement / block id, per kind
# sym:          interned symbol name for SYM (else intern.STR_NIL)
# sym_off:      addend applied to the symbol for SYM
# index:        MEM scaled-index register: a value vreg (pre-regalloc) or physical
#               register id (`index_is_preg` set). MIR_VREG_NIL when no index.
# scale:        MEM index scale (1, 2, 4, or 8); 0 when no index.
# index_is_preg: true when `index` is a physical register id (set by regalloc);
#               false when it is a value vreg awaiting allocation.
pub rec MirOperand {
    kind:          MirOperandKind;
    vreg:          u32;
    preg:          u32;
    imm:           i64;
    sym:           intern.StrId;
    sym_off:       i32;
    index:         u32;
    scale:         u8;
    index_is_preg: bool;
}

# MirAsmBind: one resolved `{name}` binding for an inline-asm block — the source
# name paired with the slot-owning vreg the alloca's result mapped to. the
# encoder resolves the vreg to a frame offset and substitutes `[rbp+off]` for
# `{name}` when it expands the body.
# ---
# name:      interned source local name (the text inside `{ }`)
# slot_vreg: slot-owning vreg id of the local's alloca storage
pub rec MirAsmBind {
    name:      intern.StrId;
    slot_vreg: u32;
}

# MirAsm: the inline-asm payload carried by a MIR_ASM instruction. the body text
# is resolved from the interner at lower time; the `{name}` bindings carry the
# slot-owning vreg ids the encoder turns into `[rbp+off]` once the frame is laid
# out. owned by the MIR_ASM instruction and freed in `dnit_instr`.
# ---
# isa:        the target ISA tag the body was written for (e.g. "x86_64")
# body:       raw inline-asm body text (borrowed from the interner; stable)
# binds:      `{name}` -> slot-vreg bindings referenced by the body (owned)
# bind_count: number of bindings
pub rec MirAsm {
    isa:        str;
    body:       str;
    binds:      *MirAsmBind;
    bind_count: u32;
}

# MirInstr: one MIR instruction — a generic-or-concrete opcode plus a flat operand list (dst at operand 0).
# ---
# opcode:        generic MIR opcode (pre-isel) or concrete encoder opcode (post-isel)
# operands:      pointer to a contiguous array of operands (owned)
# operand_count: number of operands
# width:         operation width in bytes (1, 2, 4, or 8) of the destination /
#                result the instruction drives — the byte width the encoder uses
#                to size MOV / ALU / CMP / LOAD / STORE / conversion ops (REX.W
#                only for 8, the 0x66 prefix only for 2). populated in
#                `lower_ir` from the IR result type (or, for void-result ops like
#                store and compare, the operated-on operand type). 0 means
#                "unset", which the encoder treats as the machine-word width so a
#                pseudo with no natural width (call / ret / branch / asm) still
#                encodes its address-sized fields correctly.
# src_width:     source operand width in bytes for the width-changing conversions
#                (TRUNC / SEXT / ZEXT and the integer-side CVT forms), where the
#                source is narrower or wider than the destination. for every other
#                opcode it equals `width`. the encoder sizes source operands by
#                this field so MOVZX / MOVSX select the byte-vs-word source form.
#                EXCEPTION: a MIR_FCMP carries its float-comparison condition code
#                (one of FCC_*) here, since a float comparison has no narrower /
#                wider source form — both operands ride at `width` (4 for f32, 8
#                for f64) and the single MIR_FCMP opcode selects the UNSIGNED SETcc
#                from this condition, mirroring how the integer compare family
#                encodes its condition in the opcode itself.
# asm_block:     inline-asm payload for a MIR_ASM instruction (owned), else nil.
#                carries the raw body text plus `{name}` -> slot-vreg bindings the
#                encoder expands into machine instructions.
pub rec MirInstr {
    opcode:        MirOpcode;
    operands:      *MirOperand;
    operand_count: u32;
    width:         u8;
    src_width:     u8;
    asm_block:     *MirAsm;
}

# MirBlock: a MIR basic block — an ordered instruction list plus predecessor ids, sharing the source IR `Block.id`.
# ---
# id:          block id, identical to the source IR block id
# instrs:      ordered MIR instructions (owned)
# instr_count: number of instructions
# instr_cap:   allocated capacity for instrs
# preds:       predecessor block ids (owned)
# pred_count:  number of predecessors
# pred_cap:    allocated capacity for preds
pub rec MirBlock {
    id:          u32;

    instrs:      *MirInstr;
    instr_count: u32;
    instr_cap:   u32;

    preds:       *u32;
    pred_count:  u32;
    pred_cap:    u32;
}

# MirVReg: a virtual register and its register-allocation state.
# ---
# id:         the vreg's own index into MirFunction.vregs
# class:      index into target.arch.reg_classes selecting the register bank
# spill_slot: stack-frame slot index when spilled (-1 while unspilled)
# assigned:   physical register id assigned by regalloc (MIR_VREG_NIL until then)
pub rec MirVReg {
    id:         u32;
    class:      u32;
    spill_slot: i32;
    assigned:   u32;
}

# MirSlotKind: discriminant distinguishing an addressed alloca slot from a by-value spill slot.
pub def MirSlotKind: u8;

# SLOT_ALLOCA: a slot whose address is the alloca pointer; the slot is the pointed-to storage.
pub val SLOT_ALLOCA: MirSlotKind = 0;
# SLOT_SPILL: a slot holding a by-value copy of a small-aggregate param, aggregate load, or aggregate return.
pub val SLOT_SPILL: MirSlotKind = 1;

# MirSlot: one stack-frame slot — a sized, aligned region for an alloca or a small-aggregate spill.
# ---
# value:  MIR value id that owns this slot; keys frame.run's offset lookup
# kind:   SLOT_ALLOCA (addressed) or SLOT_SPILL (by-value copy)
# offset: negative byte offset from the frame pointer (assigned by frame.run)
# size:   slot size in bytes
# align:  slot alignment in bytes
pub rec MirSlot {
    value:  u32;
    kind:   MirSlotKind;
    offset: i64;
    size:   u32;
    align:  u32;
}

# MirFrame: a function's stack layout, populated by frame.run after register allocation.
# ---
# slots:         stack slots (owned)
# slot_count:    number of slots
# slot_cap:      allocated capacity for slots
# size:          total frame size in bytes
# align:         frame alignment in bytes
# has_va_save:   true when the function reserves a variadic-argument save area
# va_save_size:  size in bytes of the variadic save area when has_va_save
# va_save_off:   frame-pointer offset of the variadic save area (assigned by frame.run)
# outgoing_size: bytes reserved at the bottom of the frame for stack-passed
#                outgoing call arguments — the maximum over every call this
#                function makes (16-byte aligned). `lower_ir` records it as it
#                lowers each call (see `lower_call`); frame.run reserves it as the
#                lowest region of the frame so a caller's `[rsp + off]` store
#                (`0 <= off < outgoing_size`) lands there without overlapping
#                locals, spills, or the callee-saved save area, and the call-site
#                RSP stays 16-byte aligned. zero when the function makes no call
#                with stack-passed arguments.
pub rec MirFrame {
    slots:         *MirSlot;
    slot_count:    u32;
    slot_cap:      u32;
    size:          u32;
    align:         u32;
    has_va_save:   bool;
    va_save_size:  u32;
    va_save_off:   i64;
    outgoing_size: u32;
}

# MirFunction: a function in MIR form — blocks, the virtual-register table, and frame layout.
# ---
# name:        interned function symbol name
# blocks:      MIR blocks; blocks[0] is the entry block (owned)
# block_count: number of blocks
# block_cap:   allocated capacity for blocks
# vregs:       virtual-register table indexed by vreg id (owned)
# vreg_count:  number of virtual registers
# vreg_cap:    allocated capacity for vregs
# frame:       stack-frame layout (filled in by frame.run)
# callee_mask: bitmask of callee-saved physical GP registers this function
#              actually assigns, written by regalloc and read by frame.run /
#              encode.run to emit the prologue save / epilogue restore. bit `n`
#              set means physical GP register id `n` is live in the function and
#              must be preserved. `lower_ir` initializes it to 0 (no callee-saved
#              register used until regalloc proves otherwise).
pub rec MirFunction {
    name:        intern.StrId;

    blocks:      *MirBlock;
    block_count: u32;
    block_cap:   u32;

    vregs:       *MirVReg;
    vreg_count:  u32;
    vreg_cap:    u32;

    frame:       MirFrame;
    callee_mask: u32;
}

# MirModule: the per-source-module unit produced by `lower_ir`.
# ---
# alloc:        allocator backing every owned array (mirrors the IR module's)
# interner:     the session interner, threaded through so the encoder can
#               resolve interned strings (inline-asm bodies) and intern new
#               symbol names referenced from inline asm into relocations
# functions:    MIR functions, parallel to the source IR module's functions (owned)
# function_len: number of functions
# function_cap: allocated capacity for functions
pub rec MirModule {
    alloc:        *Allocator;
    interner:     *intern.Interner;
    functions:    *MirFunction;
    function_len: u32;
    function_cap: u32;
}

val INITIAL_FN_CAP:    u32 = 8;
val INITIAL_VREG_CAP:  u32 = 32;
val INITIAL_INSTR_CAP: u32 = 16;
val INITIAL_SLOT_CAP:  u32 = 8;

# op_vreg: build a virtual-register operand.
# ---
# vreg: virtual register id
# ret:  a MIR_OP_VREG operand
pub fun op_vreg(vreg: u32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_VREG;
    o.vreg          = vreg;
    o.preg          = 0;
    o.imm           = 0;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_preg: build a physical-register operand.
# ---
# preg: physical register id within its class
# ret:  a MIR_OP_PREG operand
pub fun op_preg(preg: u32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_PREG;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = preg;
    o.imm           = 0;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_imm: build an immediate operand.
# ---
# imm: immediate value
# ret: a MIR_OP_IMM operand
pub fun op_imm(imm: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_IMM;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = 0;
    o.imm           = imm;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_mem_slot: build a memory operand whose base is a frame-slot key. `slotkey`
# is a slot-owning vreg id; the encoder resolves it to `[rbp + slot.offset +
# disp]` via the frame layout. regalloc never register-allocates a slot-owning
# vreg, so this base survives unchanged into encode.
# ---
# slotkey: slot-owning vreg id (alloca pointer, two-register param spill, or
#          register-allocator spill slot)
# disp:    displacement in bytes
# ret:     a MIR_OP_MEM operand with a frame-slot-key base
pub fun op_mem_slot(slotkey: u32, disp: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_MEM;
    o.vreg          = slotkey;
    o.preg          = 0;
    o.imm           = disp;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_mem_preg: build a memory operand whose base is a physical register. used for
# direct RBP/RSP bases (stack-parameter loads, outgoing stack-argument stores) and
# for value-pointer bases regalloc has resolved to a physical register. the
# encoder forms `[preg + disp]`.
# ---
# preg: physical register id of the base
# disp: displacement in bytes
# ret:  a MIR_OP_MEM operand with a physical-register base
pub fun op_mem_preg(preg: u32, disp: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_MEM;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = preg;
    o.imm           = disp;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_mem_value: build a memory operand whose base is a value vreg holding a
# runtime pointer (pre-regalloc). regalloc rewrites this base to its assigned
# physical register (the `op_mem_preg` form). a value vreg in a MEM base must not
# survive register allocation.
# ---
# base: value virtual register id holding the pointer
# disp: displacement in bytes
# ret:  a MIR_OP_MEM operand with a value-vreg base
pub fun op_mem_value(base: u32, disp: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_MEM;
    o.vreg          = base;
    o.preg          = 0;
    o.imm           = disp;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_sym: build a symbol-reference operand.
# ---
# sym:     interned symbol name
# sym_off: addend applied to the symbol
# ret:     a MIR_OP_SYM operand
pub fun op_sym(sym: intern.StrId, sym_off: i32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_SYM;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = 0;
    o.imm           = 0;
    o.sym           = sym;
    o.sym_off       = sym_off;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# op_block: build a branch-target block operand.
# ---
# block: target block id
# ret:   a MIR_OP_BLOCK operand
pub fun op_block(block: u32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_BLOCK;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = 0;
    o.imm           = block::i64;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# lower_ir: lower an IR module to a parallel MIR module, one MIR function per IR function.
# ---
# tgt:      resolved compilation target; supplies register classes via `tgt.arch`
# m:        the source IR module to lower
# interner: session interner, recorded on the MIR module so the encoder can
#           resolve interned strings and intern inline-asm symbol references
# ret:      a populated MirModule (owned, release with `dnit_module`), or an allocation / lowering error
pub fun lower_ir(tgt: *target.Target, m: *ir.Module, interner: *intern.Interner) Result[MirModule, str] {
    if (tgt == nil || m == nil) {
        ret err[MirModule, str]("mir.lower_ir: nil target or module");
    }

    var mm: MirModule;
    mm.alloc        = m.alloc;
    mm.interner     = interner;
    mm.functions    = nil;
    mm.function_len = 0;
    mm.function_cap = 0;

    val rf: Result[*MirFunction, str] = allocate[MirFunction](m.alloc, INITIAL_FN_CAP::usize);
    if (is_err[*MirFunction, str](rf)) {
        ret err[MirModule, str](unwrap_err[*MirFunction, str](rf));
    }
    mm.functions    = unwrap_ok[*MirFunction, str](rf);
    mm.function_cap = INITIAL_FN_CAP;

    var fi: u32 = 0;
    for (fi < m.function_len) {
        val lf: Result[MirFunction, str] = lower_function(tgt, m, ?m.functions[fi], interner);
        if (is_err[MirFunction, str](lf)) {
            dnit_module(?mm);
            ret err[MirModule, str](unwrap_err[MirFunction, str](lf));
        }
        val push: Result[bool, str] = push_function(?mm, unwrap_ok[MirFunction, str](lf));
        if (is_err[bool, str](push)) {
            dnit_module(?mm);
            ret err[MirModule, str](unwrap_err[bool, str](push));
        }
        fi = fi + 1;
    }

    ret ok[MirModule, str](mm);
}

# per-function lowering state. it maps each SSA definition (parameter or
# instruction result) to its virtual register: `param_vregs` indexed by
# parameter ordinal, `instr_vregs` by the function's instruction-pool index.
# ---
# alloc:       allocator for all per-function MIR storage
# tgt:         resolved compilation target; supplies the ABI vtable + arch id
#              for SysV classification of params, call args, and returns
# m:           the source IR module; resolves VAL_FN / VAL_GLOBAL symbol names
# types:       IR type table for register-class selection
# fn:          the source IR function being lowered (param / sig types)
# f:           the MIR function being built
# param_vregs: per-parameter vreg map (len param_count)
# param_count: number of parameters
# instr_vregs: per-instruction vreg map (MIR_VREG_NIL for void-defining)
# instr_count: number of instructions in the source pool
# interner:    session interner, for resolving inline-asm body / name strings
rec LowerCtx {
    alloc:       *Allocator;
    tgt:         *target.Target;
    m:           *ir.Module;
    types:       *ir_type.IrTypeTable;
    fn:          *ir.Function;
    f:           *MirFunction;
    param_vregs: *u32;
    param_count: u32;
    instr_vregs: *u32;
    # slot_key_vregs: per-instruction map (len instr_count) from an OP_ALLOCA
    # instruction id to the slot-key vreg that owns its frame slot, MIR_VREG_NIL
    # for every non-alloca id. an alloca's result vreg holds its pointer value
    # and may be register-allocated, while the frame slot is keyed on a separate
    # slot-key vreg; inline-asm `{name}` references need the slot key to resolve
    # the local to `[rbp + offset]`.
    slot_key_vregs: *u32;
    instr_count: u32;
    interner:    *intern.Interner;
    # sret_vreg: the vreg holding the hidden return-storage pointer when the
    # function returns a >16-byte aggregate (CLASS_SRET), captured from the first
    # GP argument register in `lower_params`; MIR_VREG_NIL otherwise. `lower_ret`
    # copies the returned aggregate into this storage and returns it in RAX.
    sret_vreg:   u32;
}

# lowers one IR function into a MirFunction. allocates the vreg table and the
# per-definition vreg maps, assigns a vreg to every parameter and every
# non-void instruction result, then translates each block's phis, body, and
# terminator into MIR instructions.
fun lower_function(tgt: *target.Target, m: *ir.Module, fn: *ir.Function, interner: *intern.Interner) Result[MirFunction, str] {
    var mf: MirFunction;
    mf.name        = fn.name;
    mf.blocks      = nil;
    mf.block_count = 0;
    mf.block_cap   = 0;
    mf.vregs       = nil;
    mf.vreg_count  = 0;
    mf.vreg_cap    = 0;
    mf.frame.slots        = nil;
    mf.frame.slot_count   = 0;
    mf.frame.slot_cap     = 0;
    mf.frame.size         = 0;
    mf.frame.align        = 0;
    mf.frame.has_va_save  = false;
    mf.frame.va_save_size = 0;
    mf.frame.va_save_off  = 0;
    mf.frame.outgoing_size = 0;
    mf.callee_mask        = 0;

    # extern / body-less functions lower to an empty MirFunction shell. extern
    # variadic declarations (e.g. printf) are fine here; only defining the body of
    # a variadic function needs the unimplemented va-save area.
    if ((fn.flags & ir.FN_FLAG_EXTERN) != 0 || fn.block_count == 0) {
        ret ok[MirFunction, str](mf);
    }

    # a variadic function definition would need a register-argument save area for
    # `va_arg`, which is not yet implemented; fail loudly rather than miscompile.
    # calls INTO variadic functions are unaffected (handled by lower_call).
    if (fn_sig_is_variadic(m, fn)) {
        ret err[MirFunction, str]("mir.lower_ir: variadic function definitions not yet supported");
    }

    val rv: Result[*MirVReg, str] = allocate[MirVReg](m.alloc, INITIAL_VREG_CAP::usize);
    if (is_err[*MirVReg, str](rv)) {
        ret err[MirFunction, str](unwrap_err[*MirVReg, str](rv));
    }
    mf.vregs    = unwrap_ok[*MirVReg, str](rv);
    mf.vreg_cap = INITIAL_VREG_CAP;

    var ctx: LowerCtx;
    ctx.alloc       = m.alloc;
    ctx.tgt         = tgt;
    ctx.m           = m;
    ctx.types       = ?m.types;
    ctx.fn          = fn;
    ctx.f           = ?mf;
    ctx.param_vregs = nil;
    ctx.param_count = fn.param_count;
    ctx.instr_vregs = nil;
    ctx.slot_key_vregs = nil;
    ctx.instr_count = fn.instr_len;
    ctx.interner    = interner;
    ctx.sret_vreg   = MIR_VREG_NIL;

    val setup: Result[bool, str] = ctx_setup(?ctx, tgt, fn);
    if (is_err[bool, str](setup)) {
        ctx_dnit(?ctx);
        dnit_function(m.alloc, ?mf);
        ret err[MirFunction, str](unwrap_err[bool, str](setup));
    }

    val rb: Result[*MirBlock, str] = allocate[MirBlock](m.alloc, fn.block_count::usize);
    if (is_err[*MirBlock, str](rb)) {
        ctx_dnit(?ctx);
        dnit_function(m.alloc, ?mf);
        ret err[MirFunction, str](unwrap_err[*MirBlock, str](rb));
    }
    mf.blocks    = unwrap_ok[*MirBlock, str](rb);
    mf.block_cap = fn.block_count;

    var bi: u32 = 0;
    for (bi < fn.block_count) {
        val is_entry: bool = bi == 0;
        val lb: Result[bool, str] = lower_block(?ctx, fn, ?fn.blocks[bi], is_entry);
        if (is_err[bool, str](lb)) {
            ctx_dnit(?ctx);
            dnit_function(m.alloc, ?mf);
            ret err[MirFunction, str](unwrap_err[bool, str](lb));
        }
        bi = bi + 1;
    }

    # out-of-SSA: every block now exists, so the phi merge copies can be inserted
    # at the predecessor block ends (before their terminators).
    val lph: Result[bool, str] = lower_phis(?ctx, fn);
    if (is_err[bool, str](lph)) {
        ctx_dnit(?ctx);
        dnit_function(m.alloc, ?mf);
        ret err[MirFunction, str](unwrap_err[bool, str](lph));
    }

    ctx_dnit(?ctx);
    ret ok[MirFunction, str](mf);
}

# fn_sig_is_variadic: true when a function's signature type (IRT_FN) is variadic.
# read from the module's type table directly so it is usable before the per-
# function lowering context exists. a missing or non-function signature is treated
# as non-variadic.
fun fn_sig_is_variadic(m: *ir.Module, fn: *ir.Function) bool {
    val it: Option[*ir_type.IrType] = ir_type.get(?m.types, fn.sig);
    if (!is_some[*ir_type.IrType](it)) { ret false; }
    val t: *ir_type.IrType = unwrap[*ir_type.IrType](it);
    if (t.kind != ir_type.IRT_FN) { ret false; }
    ret t.data.fn.varargs;
}

# allocates the per-definition vreg maps and assigns a vreg to every parameter
# and every non-void instruction result. parameter vregs come first so their
# ids are dense and stable.
fun ctx_setup(ctx: *LowerCtx, tgt: *target.Target, fn: *ir.Function) Result[bool, str] {
    if (ctx.param_count > 0) {
        val rp: Result[*u32, str] = allocate[u32](ctx.alloc, ctx.param_count::usize);
        if (is_err[*u32, str](rp)) { ret err[bool, str](unwrap_err[*u32, str](rp)); }
        ctx.param_vregs = unwrap_ok[*u32, str](rp);
    }
    if (ctx.instr_count > 0) {
        val ri: Result[*u32, str] = allocate[u32](ctx.alloc, ctx.instr_count::usize);
        if (is_err[*u32, str](ri)) { ret err[bool, str](unwrap_err[*u32, str](ri)); }
        ctx.instr_vregs = unwrap_ok[*u32, str](ri);

        val rk: Result[*u32, str] = allocate[u32](ctx.alloc, ctx.instr_count::usize);
        if (is_err[*u32, str](rk)) { ret err[bool, str](unwrap_err[*u32, str](rk)); }
        ctx.slot_key_vregs = unwrap_ok[*u32, str](rk);
        var ki: u32 = 0;
        for (ki < ctx.instr_count) { ctx.slot_key_vregs[ki] = MIR_VREG_NIL; ki = ki + 1; }
    }

    var pi: u32 = 0;
    for (pi < ctx.param_count) {
        val cls: u32 = reg_class_of(ctx, tgt, fn.params[pi].ty);
        val vr: Result[u32, str] = new_vreg(ctx, cls);
        if (is_err[u32, str](vr)) { ret err[bool, str](unwrap_err[u32, str](vr)); }
        ctx.param_vregs[pi] = unwrap_ok[u32, str](vr);
        pi = pi + 1;
    }

    var ii: u32 = 0;
    for (ii < ctx.instr_count) {
        ctx.instr_vregs[ii] = MIR_VREG_NIL;
        val inst: *instr.Instruction = ?fn.instrs[ii];
        if (defines_value(ctx, inst)) {
            # an alloca's instruction type is the allocated element type, but its
            # result is always a pointer, so its result vreg is general-purpose;
            # every other result takes its class from its own result type.
            var cls: u32 = REG_CLASS_GP;
            if (inst.kind != instr.OP_ALLOCA) {
                cls = reg_class_of(ctx, tgt, inst.ty);
            }
            val vr: Result[u32, str] = new_vreg(ctx, cls);
            if (is_err[u32, str](vr)) { ret err[bool, str](unwrap_err[u32, str](vr)); }
            ctx.instr_vregs[ii] = unwrap_ok[u32, str](vr);
        }
        ii = ii + 1;
    }
    ret ok[bool, str](true);
}

# releases the per-definition vreg maps held by a lowering context.
fun ctx_dnit(ctx: *LowerCtx) {
    if (ctx.param_vregs != nil && ctx.param_count > 0) {
        deallocate[u32](ctx.alloc, ctx.param_vregs, ctx.param_count::usize);
        ctx.param_vregs = nil;
    }
    if (ctx.instr_vregs != nil && ctx.instr_count > 0) {
        deallocate[u32](ctx.alloc, ctx.instr_vregs, ctx.instr_count::usize);
        ctx.instr_vregs = nil;
    }
    if (ctx.slot_key_vregs != nil && ctx.instr_count > 0) {
        deallocate[u32](ctx.alloc, ctx.slot_key_vregs, ctx.instr_count::usize);
        ctx.slot_key_vregs = nil;
    }
}

# true when an instruction defines a usable SSA value. void-typed instructions
# define nothing: terminators and stores are void by construction, and a
# void-returning OP_CALL or OP_ASM likewise produces no result. consulting the
# result type catches all of them so void calls/asm get MIR_VREG_NIL and the
# lowering skips their dead result bindings.
fun defines_value(ctx: *LowerCtx, inst: *instr.Instruction) bool {
    if (instr.is_terminator(inst.kind)) { ret false; }
    if (inst.kind == instr.OP_STORE)    { ret false; }
    val it: Option[*ir_type.IrType] = ir_type.get(ctx.types, inst.ty);
    if (is_some[*ir_type.IrType](it)) {
        val t: *ir_type.IrType = unwrap[*ir_type.IrType](it);
        if (t.kind == ir_type.IRT_VOID) { ret false; }
    }
    ret true;
}

# appends a fresh virtual register in the given register class and returns its
# id. grows the vreg table on demand.
fun new_vreg(ctx: *LowerCtx, class: u32) Result[u32, str] {
    val f: *MirFunction = ctx.f;
    if (f.vreg_count >= f.vreg_cap) {
        val new_cap: u32 = f.vreg_cap * 2;
        val r: Result[*MirVReg, str] = reallocate[MirVReg](ctx.alloc, f.vregs, f.vreg_cap::usize, new_cap::usize);
        if (is_err[*MirVReg, str](r)) { ret err[u32, str](unwrap_err[*MirVReg, str](r)); }
        f.vregs    = unwrap_ok[*MirVReg, str](r);
        f.vreg_cap = new_cap;
    }
    val vid: u32 = f.vreg_count;
    f.vregs[vid].id         = vid;
    f.vregs[vid].class      = class;
    f.vregs[vid].spill_slot = -1;
    f.vregs[vid].assigned   = MIR_VREG_NIL;
    f.vreg_count = f.vreg_count + 1;
    ret ok[u32, str](vid);
}

# selects the register class index for an IR value type. an IR float type maps
# to the float/vector bank; everything else maps to the general-purpose bank.
# the float bank is found by its wide register width via `tgt.arch.reg_classes`
# so no arch-specific class name or index is hardcoded.
fun reg_class_of(ctx: *LowerCtx, tgt: *target.Target, ty: ir_type.IrTypeId) u32 {
    val it: Option[*ir_type.IrType] = ir_type.get(ctx.types, ty);
    if (is_some[*ir_type.IrType](it)) {
        val t: *ir_type.IrType = unwrap[*ir_type.IrType](it);
        if (t.kind == ir_type.IRT_FLOAT) {
            ret fp_class_index(tgt);
        }
    }
    ret REG_CLASS_GP;
}

# returns the index of the float/vector register bank, identified as the first
# class whose register width is at least FP_CLASS_MIN_BITS. a target with no wide
# bank cannot hold a float value, so a missing bank is a target-configuration bug
# and fails loudly rather than misclassifying a float into the GP bank.
fun fp_class_index(tgt: *target.Target) u32 {
    var ci: u32 = 0;
    for (ci < tgt.arch.reg_class_count) {
        if (tgt.arch.reg_classes[ci].bit_width >= FP_CLASS_MIN_BITS) {
            ret ci;
        }
        ci = ci + 1;
    }
    panic("mir.lower_ir: target has no float/vector register bank\n");
    ret REG_CLASS_GP;
}

# op_width_of: the encoder operand width in bytes for an IR type — its
# `ir_type.byte_size` clamped to the nearest legal x86-64 operand width (1, 2, 4,
# or 8). a scalar (int / float / pointer) maps to its own size; an aggregate or a
# value wider than a machine word is held and addressed by pointer, so it rides at
# the word width. a zero-sized or void type (e.g. the void result of a store)
# yields the word width so a pseudo with no natural width still sizes its
# address-sized fields. this is the single carrier that makes the encoder drive
# 1 / 2 / 4 / 8-byte operations at the correct REX.W and prefix, replacing the old
# always-64-bit default.
fun op_width_of(ctx: *LowerCtx, ty: ir_type.IrTypeId) u8 {
    val sz: u32 = ir_type.byte_size(ctx.types, ty, ctx.tgt);
    if (sz == 1) { ret 1; }
    if (sz == 2) { ret 2; }
    if (sz == 4) { ret 4; }
    ret WORD_WIDTH;
}

# lowers one IR block into a MirBlock with the same id: copies predecessor ids,
# translates each body instruction, and finally the terminator. IR phis are NOT
# emitted here — they are eliminated out-of-SSA by `lower_phis` after every block
# exists, which inserts the merge copies at the predecessor block ends. the block
# is claimed in `mf` (block_count incremented) the moment its owned pointers are
# zeroed, so any partially-built block left behind by an allocation failure is
# still reclaimed by dnit_function on the cleanup path.
fun lower_block(ctx: *LowerCtx, fn: *ir.Function, blk: *ir.Block, is_entry: bool) Result[bool, str] {
    val f: *MirFunction = ctx.f;
    val mb: *MirBlock = ?f.blocks[f.block_count];
    mb.id          = blk.id::u32;
    mb.instrs      = nil;
    mb.instr_count = 0;
    mb.instr_cap   = 0;
    mb.preds       = nil;
    mb.pred_count  = 0;
    mb.pred_cap    = 0;
    f.block_count = f.block_count + 1;

    val cp: Result[bool, str] = copy_preds(ctx, mb, blk);
    if (is_err[bool, str](cp)) { ret cp; }

    # the entry block opens with the ABI param pre-coloring: each incoming
    # parameter is moved out of its canonical argument register (or loaded from
    # the caller's stack area) into the parameter vreg before any body code runs.
    if (is_entry) {
        val lp: Result[bool, str] = lower_params(ctx, mb);
        if (is_err[bool, str](lp)) { ret lp; }
    }

    var ii: u32 = 0;
    for (ii < blk.instr_count) {
        val ei: Result[bool, str] = lower_instr(ctx, fn, mb, blk.instructions[ii]);
        if (is_err[bool, str](ei)) { ret ei; }
        ii = ii + 1;
    }

    if (blk.terminator != id.INSTR_NIL) {
        val et: Result[bool, str] = lower_instr(ctx, fn, mb, blk.terminator);
        if (is_err[bool, str](et)) { ret et; }
    }

    ret ok[bool, str](true);
}

# copies an IR block's predecessor ids into a MirBlock.
fun copy_preds(ctx: *LowerCtx, mb: *MirBlock, blk: *ir.Block) Result[bool, str] {
    if (blk.pred_count == 0) { ret ok[bool, str](true); }
    val r: Result[*u32, str] = allocate[u32](ctx.alloc, blk.pred_count::usize);
    if (is_err[*u32, str](r)) { ret err[bool, str](unwrap_err[*u32, str](r)); }
    mb.preds    = unwrap_ok[*u32, str](r);
    mb.pred_cap = blk.pred_count;
    var i: u32 = 0;
    for (i < blk.pred_count) {
        mb.preds[i] = blk.preds[i]::u32;
        i = i + 1;
    }
    mb.pred_count = blk.pred_count;
    ret ok[bool, str](true);
}

# lower_phis: eliminate every IR phi out of SSA by inserting merge copies at the
# predecessor block ends. Conventional (Cytron-style) phi destruction: a phi in
# block `S` with result vreg `r` and incoming pairs `(pred, value)` is realized
# by emitting, at the end of each predecessor block `P` (before its terminator),
# a `MIR_MOV r <- lower_value(value)`, so `r` is defined on every path into `S`.
# After this pass no OP_PHI / MIR_PHI exists; the encoder's MIR_PHI rejection is
# only a backstop. The result vreg is the ordinary allocatable vreg `ctx_setup`
# already assigned to the phi instruction.
#
# All phis at the head of `S` execute simultaneously, so the copies along a single
# edge `P -> S` form one parallel-copy set; `emit_edge_copies` sequentializes it
# correctly (breaking cycles with a fresh temp) to avoid the lost-copy / swap
# problem. Phis whose incoming value lowers to itself contribute no copy.
fun lower_phis(ctx: *LowerCtx, fn: *ir.Function) Result[bool, str] {
    var bi: u32 = 0;
    for (bi < fn.block_count) {
        val blk: *ir.Block = ?fn.blocks[bi];
        if (blk.phi_count > 0) {
            val r: Result[bool, str] = lower_block_phis(ctx, fn, blk);
            if (is_err[bool, str](r)) { ret r; }
        }
        bi = bi + 1;
    }
    ret ok[bool, str](true);
}

# lower_block_phis: insert the merge copies for every phi of one successor block
# `S`. For each distinct predecessor block id appearing in `S`'s phis, it gathers
# the per-edge parallel-copy set (one `(phi result vreg, incoming operand)` per
# phi that has an incoming pair for that predecessor) and emits it, safely
# sequentialized, at the end of that predecessor's MIR block.
fun lower_block_phis(ctx: *LowerCtx, fn: *ir.Function, blk: *ir.Block) Result[bool, str] {
    # scratch parallel-copy set, at most one copy per phi in this block.
    val np: u32 = blk.phi_count;
    val rd: Result[*u32, str] = allocate[u32](ctx.alloc, np::usize);
    if (is_err[*u32, str](rd)) { ret err[bool, str](unwrap_err[*u32, str](rd)); }
    val dsts: *u32 = unwrap_ok[*u32, str](rd);
    val rs: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, np::usize);
    if (is_err[*MirOperand, str](rs)) {
        deallocate[u32](ctx.alloc, dsts, np::usize);
        ret err[bool, str](unwrap_err[*MirOperand, str](rs));
    }
    val srcs: *MirOperand = unwrap_ok[*MirOperand, str](rs);

    var err_msg: str = nil;
    # iterate the distinct predecessor block ids of `S`. preds were copied from the
    # IR block, deduped, so each names one edge `P -> S`.
    var pi: u32 = 0;
    for (pi < blk.pred_count && err_msg == nil) {
        val pred_id: u32 = blk.preds[pi]::u32;
        var pred_mb: *MirBlock = mir_block_by_id(ctx.f, pred_id);
        if (pred_mb == nil) {
            err_msg = "mir.lower_ir: phi predecessor block has no MIR block";
            pi = pi + 1;
            cnt;
        }

        # critical edge: a phi block always has multiple predecessors, so an edge
        # `P -> S` is critical when `P` also has multiple successors (a CBR). Placing
        # this edge's phi copies at the end of `P` would run them on `P`'s other
        # successor path too, which can corrupt a value the sibling edge's copies
        # need. Split the edge into a fresh block `B` that branches to `S`, retarget
        # `P`'s CBR to `B`, and emit this edge's copies into `B` (which ends in an
        # unconditional branch and so is a safe splice point).
        if (block_ends_in_cbr(pred_mb)) {
            val sr: Result[*MirBlock, str] = split_critical_edge(ctx, pred_mb, blk.id::u32);
            if (is_err[*MirBlock, str](sr)) { err_msg = unwrap_err[*MirBlock, str](sr); pi = pi + 1; cnt; }
            pred_mb = unwrap_ok[*MirBlock, str](sr);
        }

        # collect this edge's copies: for each phi, the incoming value paired with
        # this predecessor, targeting the phi's result vreg.
        var nc: u32 = 0;
        var hi: u32 = 0;
        for (hi < blk.phi_count && err_msg == nil) {
            val phi_opt: Option[*instr.Instruction] = ir.get_instruction(fn, blk.phis[hi]);
            if (!is_some[*instr.Instruction](phi_opt)) {
                err_msg = "mir.lower_ir: dangling phi instruction id";
                hi = hi + 1;
                cnt;
            }
            val phi: *instr.Instruction = unwrap[*instr.Instruction](phi_opt);
            val dst_vreg: u32 = result_vreg(ctx, blk.phis[hi]);
            if (dst_vreg == MIR_VREG_NIL) {
                err_msg = "mir.lower_ir: phi defines no result vreg";
                hi = hi + 1;
                cnt;
            }
            var found: bool = false;
            var k: u32 = 0;
            for (k + 1 < phi.operand_count && found == false) {
                if (phi.operands[k].data.int_lit::u32 == pred_id) {
                    dsts[nc] = dst_vreg;
                    srcs[nc] = lower_value(ctx, phi.operands[k + 1]);
                    nc = nc + 1;
                    found = true;
                }
                k = k + 2;
            }
            hi = hi + 1;
        }

        if (err_msg == nil && nc > 0) {
            val r: Result[bool, str] = emit_edge_copies(ctx, pred_mb, dsts, srcs, nc);
            if (is_err[bool, str](r)) { err_msg = unwrap_err[bool, str](r); }
        }
        pi = pi + 1;
    }

    deallocate[u32](ctx.alloc, dsts, np::usize);
    deallocate[MirOperand](ctx.alloc, srcs, np::usize);
    if (err_msg != nil) { ret err[bool, str](err_msg); }
    ret ok[bool, str](true);
}

# mir_block_by_id: return the MIR block whose id equals `id`, or nil if absent.
# MIR block ids mirror the source IR block ids, so a phi's predecessor id selects
# the predecessor's MIR block directly.
fun mir_block_by_id(f: *MirFunction, block_id: u32) *MirBlock {
    var bi: u32 = 0;
    for (bi < f.block_count) {
        if (f.blocks[bi].id == block_id) { ret ?f.blocks[bi]; }
        bi = bi + 1;
    }
    ret nil;
}

# emit_edge_copies: sequentialize and insert one edge's parallel-copy set
# `{dsts[i] <- srcs[i]}` into predecessor block `pred_mb`, before its terminator.
# All `dsts[i]` are distinct phi-result vregs; the `srcs[i]` operands are vregs,
# immediates, or symbols. The copies are conceptually simultaneous, so a naive
# in-order emission would clobber a value another copy still needs (the lost-copy
# / swap problem). Standard resolution: repeatedly emit any copy whose
# destination is not still needed as a source; when only a dependence cycle
# remains, break it by saving one destination's live value into a fresh temp vreg
# and redirecting the copies that read it. A `dst == src` self-copy is dropped.
fun emit_edge_copies(ctx: *LowerCtx, pred_mb: *MirBlock, dsts: *u32, srcs: *MirOperand, n: u32) Result[bool, str] {
    val re: Result[*bool, str] = allocate[bool](ctx.alloc, n::usize);
    if (is_err[*bool, str](re)) { ret err[bool, str](unwrap_err[*bool, str](re)); }
    val done: *bool = unwrap_ok[*bool, str](re);

    var remaining: u32 = 0;
    var i: u32 = 0;
    for (i < n) {
        # a copy whose source is the destination vreg itself is a no-op.
        if (srcs[i].kind == MIR_OP_VREG && srcs[i].vreg == dsts[i]) {
            done[i] = true;
        } or {
            done[i] = false;
            remaining = remaining + 1;
        }
        i = i + 1;
    }

    var err_msg: str = nil;
    for (remaining > 0 && err_msg == nil) {
        var progressed: bool = false;
        var j: u32 = 0;
        for (j < n) {
            if (done[j] == false && !dst_is_pending_src(dsts, srcs, done, n, dsts[j])) {
                val mv: Result[bool, str] = insert_mov_before_terminator(ctx, pred_mb,
                    op_vreg(dsts[j]), srcs[j]);
                if (is_err[bool, str](mv)) { err_msg = unwrap_err[bool, str](mv); j = n; cnt; }
                done[j] = true;
                remaining = remaining - 1;
                progressed = true;
            }
            j = j + 1;
        }

        if (err_msg == nil && progressed == false && remaining > 0) {
            # only a dependence cycle remains: every pending destination is still
            # needed as a pending source. Pick one pending copy, save its
            # destination's live value into a fresh temp, and redirect every pending
            # copy that reads that destination to read the temp instead. This frees
            # the destination so the loop resumes.
            var c: u32 = 0;
            for (done[c]) { c = c + 1; }
            val freed: u32 = dsts[c];
            val cls: u32 = ctx.f.vregs[freed].class;
            val tr: Result[u32, str] = new_vreg(ctx, cls);
            if (is_err[u32, str](tr)) { err_msg = unwrap_err[u32, str](tr); cnt; }
            val tmp: u32 = unwrap_ok[u32, str](tr);
            val sv: Result[bool, str] = insert_mov_before_terminator(ctx, pred_mb,
                op_vreg(tmp), op_vreg(freed));
            if (is_err[bool, str](sv)) { err_msg = unwrap_err[bool, str](sv); cnt; }
            var d: u32 = 0;
            for (d < n) {
                if (done[d] == false && srcs[d].kind == MIR_OP_VREG && srcs[d].vreg == freed) {
                    srcs[d] = op_vreg(tmp);
                }
                d = d + 1;
            }
        }
    }

    deallocate[bool](ctx.alloc, done, n::usize);
    if (err_msg != nil) { ret err[bool, str](err_msg); }
    ret ok[bool, str](true);
}

# dst_is_pending_src: true when vreg `v` is the source of some not-yet-emitted
# copy in the edge set — i.e. emitting a copy into `v` now would destroy a value
# another pending copy still needs.
fun dst_is_pending_src(dsts: *u32, srcs: *MirOperand, done: *bool, n: u32, v: u32) bool {
    var i: u32 = 0;
    for (i < n) {
        if (done[i] == false && srcs[i].kind == MIR_OP_VREG && srcs[i].vreg == v) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# insert_mov_before_terminator: append a `MIR_MOV (dst) <- (src)` to `mb` so it
# executes just before the block's terminator. A block that is a phi predecessor
# ends in a branch terminator (the last instruction); the move is spliced ahead of
# it, preserving terminator-last ordering that frame.run / encode.run rely on.
fun insert_mov_before_terminator(ctx: *LowerCtx, mb: *MirBlock, dst: MirOperand, src: MirOperand) Result[bool, str] {
    if (mb.instr_count == 0) {
        ret err[bool, str]("mir.lower_ir: phi predecessor block has no terminator");
    }
    val term: *MirInstr = ?mb.instrs[mb.instr_count - 1];
    if (!is_mir_terminator(term.opcode)) {
        ret err[bool, str]("mir.lower_ir: phi predecessor block does not end in a terminator");
    }

    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: MirInstr;
    mi.opcode        = MIR_MOV;
    mi.operands      = ops;
    mi.operand_count = 2;
    # a phi merge copy is a register-to-register / immediate move; the full-width
    # move copies the value's low bits intact regardless of its logical width.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;

    # grow by one, shift the terminator right, and drop the move into its place.
    val gr: Result[bool, str] = grow_instr(ctx, mb);
    if (is_err[bool, str](gr)) {
        deallocate[MirOperand](ctx.alloc, ops, 2::usize);
        ret gr;
    }
    mb.instrs[mb.instr_count] = mb.instrs[mb.instr_count - 1];
    mb.instrs[mb.instr_count - 1] = mi;
    mb.instr_count = mb.instr_count + 1;
    ret ok[bool, str](true);
}

# is_mir_terminator: true when a generic MIR opcode ends a block. The phi
# predecessor splice point is just before this instruction.
fun is_mir_terminator(o: MirOpcode) bool {
    if (o == MIR_BR)          { ret true; }
    if (o == MIR_CBR)         { ret true; }
    if (o == MIR_RET)         { ret true; }
    if (o == MIR_UNREACHABLE) { ret true; }
    ret false;
}

# block_ends_in_cbr: true when a block's terminator is a conditional branch, i.e.
# the block has two successors. Used to detect critical edges into phi blocks.
fun block_ends_in_cbr(mb: *MirBlock) bool {
    if (mb.instr_count == 0) { ret false; }
    ret mb.instrs[mb.instr_count - 1].opcode == MIR_CBR;
}

# grow_block: ensure the function's block array has room for one more block,
# growing it on demand. `lower_function` allocates exactly `fn.block_count`
# blocks, so any critical-edge split needs this to extend the array.
fun grow_block(ctx: *LowerCtx) Result[bool, str] {
    val f: *MirFunction = ctx.f;
    if (f.block_count >= f.block_cap) {
        var new_cap: u32 = f.block_cap * 2;
        if (new_cap < f.block_count + 1) { new_cap = f.block_count + 1; }
        val r: Result[*MirBlock, str] = reallocate[MirBlock](ctx.alloc, f.blocks, f.block_cap::usize, new_cap::usize);
        if (is_err[*MirBlock, str](r)) { ret err[bool, str](unwrap_err[*MirBlock, str](r)); }
        f.blocks    = unwrap_ok[*MirBlock, str](r);
        f.block_cap = new_cap;
    }
    ret ok[bool, str](true);
}

# fresh_block_id: a block id one past the current maximum, guaranteed not to
# collide with any existing block id.
fun fresh_block_id(f: *MirFunction) u32 {
    var max_id: u32 = 0;
    var bi: u32 = 0;
    for (bi < f.block_count) {
        if (f.blocks[bi].id > max_id) { max_id = f.blocks[bi].id; }
        bi = bi + 1;
    }
    ret max_id + 1;
}

# split_critical_edge: break the critical edge `pred -> succ_id` by inserting a
# fresh block `B` that unconditionally branches to `succ`. `pred`'s CBR target
# matching `succ_id` is retargeted to `B`, `succ`'s predecessor entry for `pred`
# is replaced by `B`, and `B`'s sole predecessor is `pred`. `B` is returned so
# the caller emits this edge's phi merge copies into it — `B` ends in an
# unconditional branch, so the splice is safe. Block pointers are re-fetched by
# id after the (possibly reallocating) growth, since growth invalidates them.
fun split_critical_edge(ctx: *LowerCtx, pred: *MirBlock, succ_id: u32) Result[*MirBlock, str] {
    val pred_id: u32 = pred.id;
    val new_id:  u32 = fresh_block_id(ctx.f);

    val gr: Result[bool, str] = grow_block(ctx);
    if (is_err[bool, str](gr)) { ret err[*MirBlock, str](unwrap_err[bool, str](gr)); }

    val f: *MirFunction = ctx.f;
    val b: *MirBlock = ?f.blocks[f.block_count];
    b.id          = new_id;
    b.instrs      = nil;
    b.instr_count = 0;
    b.instr_cap   = 0;
    b.preds       = nil;
    b.pred_count  = 0;
    b.pred_cap    = 0;

    # B's terminator: an unconditional branch to the merge block.
    val rb: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 1::usize);
    if (is_err[*MirOperand, str](rb)) { ret err[*MirBlock, str](unwrap_err[*MirOperand, str](rb)); }
    val bops: *MirOperand = unwrap_ok[*MirOperand, str](rb);
    bops[0] = op_block(succ_id);
    var br: MirInstr;
    br.opcode        = MIR_BR;
    br.operands      = bops;
    br.operand_count = 1;
    br.width         = WORD_WIDTH;
    br.src_width     = WORD_WIDTH;

    val ri: Result[*MirInstr, str] = allocate[MirInstr](ctx.alloc, 1::usize);
    if (is_err[*MirInstr, str](ri)) { deallocate[MirOperand](ctx.alloc, bops, 1::usize); ret err[*MirBlock, str](unwrap_err[*MirInstr, str](ri)); }
    b.instrs     = unwrap_ok[*MirInstr, str](ri);
    b.instrs[0]  = br;
    b.instr_count = 1;
    b.instr_cap   = 1;

    # B's predecessor is `pred`.
    val rp: Result[*u32, str] = allocate[u32](ctx.alloc, 1::usize);
    if (is_err[*u32, str](rp)) { ret err[*MirBlock, str](unwrap_err[*u32, str](rp)); }
    b.preds      = unwrap_ok[*u32, str](rp);
    b.preds[0]   = pred_id;
    b.pred_count = 1;
    b.pred_cap   = 1;

    f.block_count = f.block_count + 1;

    # retarget pred's CBR edge to succ so it now jumps to B, and replace succ's
    # predecessor entry for pred with B. both blocks are re-fetched by id since
    # the growth above may have moved the array.
    retarget_cbr(mir_block_by_id(f, pred_id), succ_id, new_id);
    replace_pred(mir_block_by_id(f, succ_id), pred_id, new_id);

    ret ok[*MirBlock, str](?f.blocks[f.block_count - 1]);
}

# retarget_cbr: rewrite every MIR_OP_BLOCK target operand of `mb`'s terminator
# that equals `from` to `to`. Used to redirect a conditional branch's edge
# through a freshly split block.
fun retarget_cbr(mb: *MirBlock, from: u32, to: u32) {
    if (mb == nil || mb.instr_count == 0) { ret; }
    val term: *MirInstr = ?mb.instrs[mb.instr_count - 1];
    var i: u32 = 0;
    for (i < term.operand_count) {
        if (term.operands[i].kind == MIR_OP_BLOCK && term.operands[i].imm::u32 == from) {
            term.operands[i].imm = to::i64;
        }
        i = i + 1;
    }
}

# replace_pred: replace the first predecessor entry of `mb` equal to `from` with
# `to`, so a split block takes over the original predecessor's edge.
fun replace_pred(mb: *MirBlock, from: u32, to: u32) {
    if (mb == nil) { ret; }
    var i: u32 = 0;
    for (i < mb.pred_count) {
        if (mb.preds[i] == from) { mb.preds[i] = to; ret; }
        i = i + 1;
    }
}

# grow_instr: ensure `mb` has room for one more instruction, growing the list on
# demand. Unlike push_instr it does not append; the caller places the instruction
# (used by the before-terminator splice).
fun grow_instr(ctx: *LowerCtx, mb: *MirBlock) Result[bool, str] {
    if (mb.instr_count >= mb.instr_cap) {
        var new_cap: u32 = mb.instr_cap * 2;
        if (new_cap < INITIAL_INSTR_CAP) { new_cap = INITIAL_INSTR_CAP; }
        val r: Result[*MirInstr, str] = reallocate[MirInstr](ctx.alloc, mb.instrs, mb.instr_cap::usize, new_cap::usize);
        if (is_err[*MirInstr, str](r)) { ret err[bool, str](unwrap_err[*MirInstr, str](r)); }
        mb.instrs    = unwrap_ok[*MirInstr, str](r);
        mb.instr_cap = new_cap;
    }
    ret ok[bool, str](true);
}

# lowers one IR instruction into one or more MIR instructions. OP_CALL expands
# into argument/call/result pseudos; OP_PHI is skipped here (phis are eliminated
# out of SSA by `lower_phis` into predecessor-end copies, never as body
# instructions); the memory opcodes (alloca / load / store / gep) have dedicated
# lowerings that form the stack slot and the `[base + disp]` memory operands the
# slot model resolves; every other opcode maps 1:1 to its generic MIR opcode.
fun lower_instr(ctx: *LowerCtx, fn: *ir.Function, mb: *MirBlock, iid: id.InstructionId) Result[bool, str] {
    val gi: Option[*instr.Instruction] = ir.get_instruction(fn, iid);
    if (!is_some[*instr.Instruction](gi)) {
        ret err[bool, str]("mir.lower_ir: dangling instruction id");
    }
    val inst: *instr.Instruction = unwrap[*instr.Instruction](gi);

    if (inst.kind == instr.OP_CALL) {
        ret lower_call(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_RET) {
        ret lower_ret(ctx, mb, inst);
    }
    # phis live in `blk.phis`, never the body list, and are eliminated by
    # `lower_phis`; should one appear here, it is not a body instruction to emit.
    if (inst.kind == instr.OP_PHI) {
        ret ok[bool, str](true);
    }
    if (inst.kind == instr.OP_ALLOCA) {
        ret lower_alloca(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_LOAD) {
        ret lower_load(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_STORE) {
        ret lower_store(ctx, mb, inst);
    }
    if (inst.kind == instr.OP_GEP) {
        ret lower_gep(ctx, mb, inst, iid);
    }
    # scalar floating-point arithmetic / comparison shares the IR integer opcodes
    # (the front end emits OP_ADD / OP_SUB / OP_MUL / OP_DIV_* / OP_CMP_* for both
    # int and float operands). a float instruction is dispatched to the dedicated
    # SSE lowering before the integer division / shift / generic paths, which would
    # emit the integer ALU / IDIV byte forms and silently miscompile an XMM-classed
    # value.
    if (is_float_op(ctx, inst)) {
        ret lower_float_op(ctx, mb, inst, iid);
    }
    # integer division / remainder needs the dividend / remainder register wiring
    # the active ISA's division form mandates (x86-64 IDIV/DIV reads the dividend
    # in RAX and yields the quotient in RAX / remainder in RDX). the accumulator
    # and high-half registers come from `tgt.arch.div_reg` / `div_hi_reg`; an ISA
    # whose division wires no fixed register reports -1 and `lower_div` errors
    # loudly rather than emitting an un-pre-colored divide.
    if (inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_DIV_U ||
        inst.kind == instr.OP_REM_S || inst.kind == instr.OP_REM_U) {
        ret lower_div(ctx, mb, inst, iid);
    }

    # a shift (SHL / SHR_S / SHR_U) is two-address on x86-64 (`value op= count`),
    # and a register count must occupy the ISA's shift-count register (x86-64 CL).
    # it is lowered into the two-address form with a runtime count pre-colored into
    # `tgt.arch.shift_count_reg`; an ISA wiring no fixed shift-count register reports
    # -1 and `lower_shift` errors loudly rather than emitting an un-pre-colored shift.
    if (inst.kind == instr.OP_SHL || inst.kind == instr.OP_SHR_S ||
        inst.kind == instr.OP_SHR_U) {
        ret lower_shift(ctx, mb, inst, iid);
    }

    # an inline-asm block carries its body + `{name}` bindings in `fn.asm_blocks`
    # keyed by this instruction id; build the MIR_ASM payload (resolving each
    # `{name}`'s alloca to its slot vreg) rather than dropping it through the
    # generic path, which keeps no asm field.
    if (inst.kind == instr.OP_ASM) {
        ret lower_asm_instr(ctx, mb, iid);
    }

    # a conditional branch whose condition lowers to a constant immediate (a
    # comptime-known / folded boolean) cannot drive the encoder's `TEST cond, cond`,
    # which requires a register. mirror cmach (`emit_cmp_branch` -> `load_operand`):
    # materialize the immediate into a register first, then branch on it.
    if (inst.kind == instr.OP_CBR) {
        ret lower_cbr(ctx, mb, inst, iid);
    }

    ret lower_generic(ctx, mb, inst, iid);
}

# lower_cbr: lower an IR OP_CBR `[cond, then_block, else_block]` into a
# `MIR_CBR [cond, then, else]`. the then/else targets ride as MIR_OP_BLOCK
# operands (per `lower_operand`). the condition is normally a register-resident
# boolean and lowers to a vreg operand, lowered unchanged. when the condition is
# a constant — a comptime-known / folded boolean reaching the back end as a
# VAL_CONST_INT — it lowers to a MIR_OP_IMM, which the encoder's `TEST cond, cond`
# cannot read. mirror cmach's `emit_cmp_branch`, which routes the condition through
# `load_operand` (emitting `MOV reg, imm` for an immediate): materialize the
# immediate into a fresh GP vreg via `MIR_MOV reg <- imm`, then branch on the
# register so the encoder always sees a register condition.
fun lower_cbr(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 3) {
        ret err[bool, str]("mir.lower_ir: conditional branch missing operands");
    }

    var cond: MirOperand = lower_operand(ctx, inst, 0);
    if (cond.kind == MIR_OP_IMM) {
        val rv: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
        if (is_err[u32, str](rv)) { ret err[bool, str](unwrap_err[u32, str](rv)); }
        val creg: u32 = unwrap_ok[u32, str](rv);
        val mv: Result[bool, str] = emit_mov(ctx, mb, op_vreg(creg), cond);
        if (is_err[bool, str](mv)) { ret mv; }
        cond = op_vreg(creg);
    }

    val rop: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 3::usize);
    if (is_err[*MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*MirOperand, str](rop)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](rop);
    ops[0] = cond;
    ops[1] = lower_operand(ctx, inst, 1);
    ops[2] = lower_operand(ctx, inst, 2);

    var mi: MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 3;
    set_generic_widths(ctx, inst, ?mi);
    # a conditional branch tests its boolean condition, but a bare bool value (e.g.
    # a struct's `tag` field) reaches the encoder in a register's low byte WITHOUT
    # being zero-extended — only a comparison result is widened by its MOVZX. test
    # the condition at its own width (1 byte for a bool, set_generic_widths leaves a
    # terminator at the machine word), so `TEST` reads only the meaningful low byte
    # instead of stale upper bits a full-width test would misread as a set condition.
    mi.width = op_width_of(ctx, inst.operands[0].ty);
    ret push_instr(ctx, mb, mi);
}

# lower_asm_instr: build a MIR_ASM instruction from the IR `IrAsm` payload bound
# to this OP_ASM instruction id. resolves the interned ISA / body strings to
# text and maps each `{name}` binding's alloca instruction id to the slot-owning
# vreg the encoder later turns into `[rbp+off]`. the payload is heap-owned and
# freed by `dnit_instr`.
fun lower_asm_instr(ctx: *LowerCtx, mb: *MirBlock, iid: id.InstructionId) Result[bool, str] {
    var key: id.InstructionId = iid;
    val pr: Result[*ir.IrAsm, str] = map.get[id.InstructionId, ir.IrAsm](?ctx.fn.asm_blocks, ?key);
    if (is_err[*ir.IrAsm, str](pr)) {
        ret err[bool, str]("mir.lower_ir: OP_ASM instruction has no asm payload");
    }
    val src: *ir.IrAsm = unwrap_ok[*ir.IrAsm, str](pr);

    val isa_opt: Option[str] = intern.lookup(ctx.interner, src.isa);
    if (!is_some[str](isa_opt)) { ret err[bool, str]("mir.lower_ir: inline-asm ISA tag not interned"); }
    val body_opt: Option[str] = intern.lookup(ctx.interner, src.body);
    if (!is_some[str](body_opt)) { ret err[bool, str]("mir.lower_ir: inline-asm body not interned"); }

    val rp: Result[*MirAsm, str] = allocate[MirAsm](ctx.alloc, 1::usize);
    if (is_err[*MirAsm, str](rp)) { ret err[bool, str](unwrap_err[*MirAsm, str](rp)); }
    val payload: *MirAsm = unwrap_ok[*MirAsm, str](rp);
    payload.isa        = unwrap[str](isa_opt);
    payload.body       = unwrap[str](body_opt);
    payload.binds      = nil;
    payload.bind_count = 0;

    if (src.bind_count > 0) {
        val rb: Result[*MirAsmBind, str] = allocate[MirAsmBind](ctx.alloc, src.bind_count::usize);
        if (is_err[*MirAsmBind, str](rb)) {
            deallocate[MirAsm](ctx.alloc, payload, 1::usize);
            ret err[bool, str](unwrap_err[*MirAsmBind, str](rb));
        }
        payload.binds = unwrap_ok[*MirAsmBind, str](rb);
        var k: u32 = 0;
        for (k < src.bind_count) {
            # a `{name}` local is the addressable storage behind an alloca; bind
            # to its slot-key vreg (which owns the frame slot) when the referenced
            # instruction is an alloca, else to the value's own vreg.
            var vreg: u32 = slot_key_vreg(ctx, src.binds[k].instr);
            if (vreg == MIR_VREG_NIL) { vreg = instr_vreg(ctx, src.binds[k].instr); }
            if (vreg == MIR_VREG_NIL) {
                deallocate[MirAsmBind](ctx.alloc, payload.binds, src.bind_count::usize);
                deallocate[MirAsm](ctx.alloc, payload, 1::usize);
                ret err[bool, str]("mir.lower_ir: inline-asm '{name}' local has no slot vreg");
            }
            payload.binds[k].name      = src.binds[k].name;
            payload.binds[k].slot_vreg = vreg;
            k = k + 1;
        }
        payload.bind_count = src.bind_count;
    }

    var mi: MirInstr;
    mi.opcode        = MIR_ASM;
    mi.operands      = nil;
    mi.operand_count = 0;
    mi.width         = 0;
    mi.src_width     = 0;
    mi.asm_block     = payload;

    val push: Result[bool, str] = push_instr(ctx, mb, mi);
    if (is_err[bool, str](push)) {
        if (payload.binds != nil) { deallocate[MirAsmBind](ctx.alloc, payload.binds, payload.bind_count::usize); }
        deallocate[MirAsm](ctx.alloc, payload, 1::usize);
        ret push;
    }
    ret ok[bool, str](true);
}

# lower_shift: lower an integer OP_SHL / OP_SHR_S / OP_SHR_U into a three-address
# generic shift `MIR_SHL/SHR_S/SHR_U [dst, value, count]`. the IR operands are
# `[value, count]`. operand 0 (`dst`) is a pure def, so the register allocator
# treats it cleanly (the encoder materializes the two-address `MOV dst, value ;
# shift dst, count` byte form). a constant count rides as an immediate; a runtime
# count is pre-colored into RCX (the only register the x86-64 variable-shift form
# reads, as CL) by a preceding `MIR_MOV RCX <- count`, mirroring the division's
# RAX:RDX pre-coloring. a function with a register-count shift reserves RCX from
# allocation (see `regalloc.function_has_reg_shift`) so no live value collides
# with the count.
fun lower_shift(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: shift missing value or count operand");
    }
    val dst: u32 = result_vreg(ctx, iid);
    if (dst == MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: shift defines no result vreg");
    }
    val w: u8 = op_width_of(ctx, inst.ty);

    var op: MirOpcode = MIR_SHR_U;
    if (inst.kind == instr.OP_SHL)   { op = MIR_SHL; }
    or (inst.kind == instr.OP_SHR_S) { op = MIR_SHR_S; }

    val value: MirOperand = lower_value(ctx, inst.operands[0]);
    val count: MirOperand = lower_value(ctx, inst.operands[1]);

    var count_op: MirOperand = count;
    if (count.kind != MIR_OP_IMM) {
        # a runtime count must occupy the ISA's shift-count register (x86-64 CL);
        # move it there and reference it so the encoder selects the `shift r/m, CL`
        # form. the register is reserved from allocation for the whole function, so
        # this move cannot clobber a live value. an ISA wiring no fixed shift-count
        # register (`shift_count_reg < 0`) cannot lower a runtime-count shift here.
        val cnt_reg: i32 = ctx.tgt.arch.shift_count_reg;
        if (cnt_reg < 0) {
            ret err[bool, str]("mir.lower_ir: ISA wires no shift-count register for a runtime shift count");
        }
        val mc: Result[bool, str] = emit_mov_w(ctx, mb, op_preg(cnt_reg::u32), count, w);
        if (is_err[bool, str](mc)) { ret mc; }
        count_op = op_preg(cnt_reg::u32);
    }

    # the three-address shift: operand 0 is the pure-def destination, operand 1 the
    # value shifted, operand 2 the count (immediate or CL). the opcode survives isel.
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 3::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = value;
    ops[2] = count_op;
    var mi: MirInstr;
    mi.opcode        = op;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;
    ret push_instr(ctx, mb, mi);
}

# lower_div: lower an integer OP_DIV_*/OP_REM_* into the x86-64 RAX:RDX division
# sequence with explicit register pre-coloring, mirroring the call/return ABI
# pre-coloring approach. the IR operands are `[a, b]` (dividend, divisor). the
# emitted sequence is, in order:
#   - `MIR_MOV RAX <- a` — the dividend occupies the accumulator;
#   - the divide pseudo `MIR_DIV_S/DIV_U/REM_S/REM_U [RAX, b]` — operand 0 is the
#     implicit RAX dividend/result register (so the register allocator reads a
#     non-defining barrier whose operand 1 is the divisor use), operand 1 is the
#     divisor `b`. the opcode survives instruction selection unchanged; the encoder
#     materializes the dividend high-half setup (CWD/CDQ/CQO sign-extension for the
#     signed forms, `XOR RDX, RDX` zero-extension for the unsigned forms) followed
#     by the single-operand `IDIV b` / `DIV b`;
#   - `MIR_MOV dst <- RAX` for a division, or `MIR_MOV dst <- RDX` for a remainder
#     — the quotient lands in RAX and the remainder in RDX.
# the divide clobbers RAX and RDX; regalloc keeps both out of allocation for any
# function that divides (they are caller-saved, so no prologue cost), so no live
# value or the divisor `b` can collide with the dividend wiring. the operation
# width (2/4/8 bytes — a byte divide is promoted to 32 bits below) is carried on
# the divide so the encoder selects the matching sign-extension opcode and sets
# REX.W / the 0x66 prefix.
fun lower_div(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: division missing dividend or divisor operand");
    }
    # floating-point division never reaches here: `lower_instr` dispatches every
    # float arithmetic / comparison op to `lower_float_op` (which emits MIR_FDIV)
    # before this integer-division path.
    val dst: u32 = result_vreg(ctx, iid);
    if (dst == MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: division defines no result vreg");
    }
    # the ISA's division form hard-wires the dividend / quotient accumulator and the
    # high-half / remainder register (x86-64 RAX:RDX). an ISA wiring no fixed
    # division register (`div_reg < 0` / `div_hi_reg < 0`) cannot lower an integer
    # division through this pre-coloring path; fail loudly rather than emit one with
    # an invalid register.
    val acc_reg: i32 = ctx.tgt.arch.div_reg;
    val hi_reg:  i32 = ctx.tgt.arch.div_hi_reg;
    if (acc_reg < 0 || hi_reg < 0) {
        ret err[bool, str]("mir.lower_ir: ISA wires no division registers for an integer divide");
    }
    val signed: bool = inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_REM_S;

    # x86-64 has no 8-bit dividend high register (a byte divide puts the dividend
    # in AX and the remainder in AH, not RDX), so a byte division is promoted to a
    # 32-bit divide: both operands are extended to 32 bits, the divide runs at
    # width 4 (remainder in EDX, quotient in EAX), and the result move truncates
    # back to the byte destination. 16/32/64-bit divisions run at their natural
    # width with the remainder in (R)DX.
    val natural_w: u8 = op_width_of(ctx, inst.ty);
    var w: u8 = natural_w;
    if (w < 4) { w = 4; }

    val dividend: MirOperand = lower_value(ctx, inst.operands[0]);
    val divisor:  MirOperand = lower_value(ctx, inst.operands[1]);

    # the dividend occupies the accumulator (x86-64 RAX) before the divide. a
    # promoted byte dividend is widened into it; otherwise it is a plain width-w move.
    val mr: Result[bool, str] = emit_promote(ctx, mb, op_preg(acc_reg::u32), dividend, w, natural_w, signed);
    if (is_err[bool, str](mr)) { ret mr; }

    # the divisor must live in a register or memory — x86-64 IDIV / DIV has no
    # immediate divisor form — so an immediate divisor is materialized into a fresh
    # value vreg. a promoted byte divisor is likewise widened into a fresh vreg. a
    # register / memory divisor at the natural width is used directly.
    var div_op: MirOperand = divisor;
    if (natural_w < w || divisor.kind == MIR_OP_IMM) {
        val bvr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
        if (is_err[u32, str](bvr)) { ret err[bool, str](unwrap_err[u32, str](bvr)); }
        val bv: u32 = unwrap_ok[u32, str](bvr);
        val ex: Result[bool, str] = emit_promote(ctx, mb, op_vreg(bv), divisor, w, natural_w, signed);
        if (is_err[bool, str](ex)) { ret ex; }
        div_op = op_vreg(bv);
    }

    # the divide itself: operand 0 is the implicit accumulator dividend/result
    # register (x86-64 RAX) and operand 1 is the divisor. the opcode survives
    # instruction selection; the encoder materializes the high-half setup + IDIV/DIV.
    val rop: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*MirOperand, str](rop)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](rop);
    ops[0] = op_preg(acc_reg::u32);
    ops[1] = div_op;
    var mi: MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    val pd: Result[bool, str] = push_instr(ctx, mb, mi);
    if (is_err[bool, str](pd)) { ret pd; }

    # the quotient lands in the accumulator (x86-64 RAX) and the remainder in the
    # high-half register (RDX); move the canonical result register into the result
    # vreg. the move is driven at the destination's natural width, truncating a
    # promoted byte result.
    var res_reg: i32 = acc_reg;
    if (inst.kind == instr.OP_REM_S || inst.kind == instr.OP_REM_U) {
        res_reg = hi_reg;
    }
    ret emit_mov_w(ctx, mb, op_vreg(dst), op_preg(res_reg::u32), natural_w);
}

# emit_promote: move `src` into `dst` at `dst_w` bytes, widening from `src_w` when
# the source is narrower. an immediate source carries its full value, so it is a
# plain width-`dst_w` move (a MOVSX/MOVZX of an immediate has no encoding). a
# register / memory source narrower than the destination is sign-extended
# (`signed`, → MOVSX) or zero-extended (→ MOVZX); at equal width it is a plain
# move. used to load a division's dividend into RAX and to widen a promoted byte
# divisor into a value vreg.
fun emit_promote(ctx: *LowerCtx, mb: *MirBlock, dst: MirOperand, src: MirOperand,
                 dst_w: u8, src_w: u8, signed: bool) Result[bool, str] {
    if (src_w >= dst_w || src.kind == MIR_OP_IMM) {
        ret emit_mov_w(ctx, mb, dst, src, dst_w);
    }
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: MirInstr;
    mi.opcode        = MIR_ZEXT;
    if (signed) { mi.opcode = MIR_SEXT; }
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = dst_w;
    mi.src_width     = src_w;
    ret push_instr(ctx, mb, mi);
}

# lowers a non-call IR instruction by mapping its opcode 1:1 to the generic MIR
# opcode of the same number and emitting [dst?, operands...]. branch operands
# that name block targets become MIR_OP_BLOCK operands.
fun lower_generic(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    # scalar floating-point arithmetic / comparison shares the IR integer opcodes
    # (OP_ADD / OP_SUB / OP_MUL / OP_CMP_* operate on both int and float operands),
    # but a float instruction never reaches here: `lower_instr` dispatches it to
    # `lower_float_op` (emitting the dedicated MIR_FADD / FSUB / FMUL / FDIV / FCMP
    # SSE opcodes) before the generic path. the float CONVERSIONS (FP_TRUNC / FP_EXT
    # / FP_TO_SI / SI_TO_FP / ...) carry their own opcodes and SSE encoders and DO
    # ride this generic path unchanged.
    val dst: u32 = result_vreg(ctx, iid);
    val has_dst: bool = dst != MIR_VREG_NIL;
    var total: u32 = inst.operand_count;
    if (has_dst) { total = total + 1; }

    var ops: *MirOperand = nil;
    if (total > 0) {
        val rop: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, total::usize);
        if (is_err[*MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*MirOperand, str](rop)); }
        ops = unwrap_ok[*MirOperand, str](rop);
    }

    var base: u32 = 0;
    if (has_dst) {
        ops[0] = op_vreg(dst);
        base = 1;
    }

    var k: u32 = 0;
    for (k < inst.operand_count) {
        ops[base + k] = lower_operand(ctx, inst, k);
        k = k + 1;
    }

    var mi: MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = total;
    set_generic_widths(ctx, inst, ?mi);
    ret push_instr(ctx, mb, mi);
}

# set_generic_widths: derive the destination and source operand widths for a
# 1:1-lowered IR instruction and stamp them onto the MIR instruction. the result
# width is the instruction's own result type, except:
#   - a width-changing integer conversion (TRUNC / SEXT / ZEXT) keeps the
#     destination width from the result type but takes its source width from operand
#     0, so the encoder's MOVZX / MOVSX selects the narrow / wide source form;
#   - a comparison (CMP_*) yields an i8 result but the CMP operates at the compared
#     operand width, so both widths come from operand 0;
#   - the float conversions (FP_TO_SI / SI_TO_FP family) and other FP ops ride at the
#     word width: their integer-vs-float operand widths are handled by the float
#     encoders, outside this base-width carrier, so the prior word-sized behavior is
#     preserved unchanged;
#   - a void-result terminator / branch has no natural width and rides at the word
#     width, which only sizes its address-sized fields.
fun set_generic_widths(ctx: *LowerCtx, inst: *instr.Instruction, mi: *MirInstr) {
    if (is_float_kind(ctx, inst)) {
        mi.width     = WORD_WIDTH;
        mi.src_width = WORD_WIDTH;
        ret;
    }
    if (is_compare_kind(inst.kind) && inst.operand_count >= 1) {
        val w: u8 = op_width_of(ctx, inst.operands[0].ty);
        mi.width     = w;
        mi.src_width = w;
        ret;
    }
    var dw: u8 = WORD_WIDTH;
    if (!instr.is_terminator(inst.kind)) { dw = op_width_of(ctx, inst.ty); }
    var sw: u8 = dw;
    if (is_int_conversion_kind(inst.kind) && inst.operand_count >= 1) {
        sw = op_width_of(ctx, inst.operands[0].ty);
    }
    mi.width     = dw;
    mi.src_width = sw;
}

# is_compare_kind: true for the IR comparison opcodes whose CMP operates at the
# operand width rather than the i8 result width.
fun is_compare_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_CMP_EQ || k == instr.OP_CMP_NE ||
        k == instr.OP_CMP_LT_S || k == instr.OP_CMP_LT_U ||
        k == instr.OP_CMP_LE_S || k == instr.OP_CMP_LE_U;
}

# is_int_conversion_kind: true for the width-changing integer conversions whose
# source operand width differs from the destination width (so the encoder must size
# the source operand independently). the float conversions are excluded — their
# operand widths are driven by the float encoders.
fun is_int_conversion_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_TRUNC || k == instr.OP_SEXT || k == instr.OP_ZEXT;
}

# is_float_op: true for a scalar floating-point arithmetic (OP_ADD / OP_SUB /
# OP_MUL / OP_DIV_*) or comparison (OP_CMP_*) instruction that shares an IR integer
# opcode. these select to SSE forms in `lower_float_op` rather than the integer ALU
# / IDIV / CMP byte forms, which would miscompile an XMM-classed value. the float
# CONVERSIONS (FP_TRUNC / FP_EXT / FP_TO_SI / FP_TO_UI / SI_TO_FP / UI_TO_FP) carry
# their own opcodes and SSE encoders and ride the generic path, so they are NOT
# claimed here. an op is float when its result or first operand is a float type.
fun is_float_op(ctx: *LowerCtx, inst: *instr.Instruction) bool {
    val k: instr.InstrKind = inst.kind;
    var shared: bool = false;
    if (k == instr.OP_ADD || k == instr.OP_SUB || k == instr.OP_MUL ||
        k == instr.OP_DIV_S || k == instr.OP_DIV_U) { shared = true; }
    if (is_compare_kind(k)) { shared = true; }
    if (!shared) { ret false; }
    if (value_is_float(ctx, inst.ty)) { ret true; }
    if (inst.operand_count >= 1 && value_is_float(ctx, inst.operands[0].ty)) { ret true; }
    ret false;
}

# float_op_width: the SSE operation width (4 for f32, 8 for f64) of a float
# arithmetic / comparison instruction. an arithmetic op takes it from its own float
# result type; a comparison's result is i8, so it takes the width from the compared
# float operand (operand 0).
fun float_op_width(ctx: *LowerCtx, inst: *instr.Instruction) u8 {
    if (is_compare_kind(inst.kind) && inst.operand_count >= 1) {
        ret op_width_of(ctx, inst.operands[0].ty);
    }
    ret op_width_of(ctx, inst.ty);
}

# float_cmp_cc: the FCC_* float-comparison condition code realizing an IR compare
# opcode. the front end emits only the EQ / NE / LT / LE forms (GT / GE are
# canonicalized to LT / LE with swapped operands), and a float compare is unordered-
# aware via UNSIGNED SETcc, so signedness is irrelevant: OP_CMP_LT_S and
# OP_CMP_LT_U both map to FCC_LT.
fun float_cmp_cc(k: instr.InstrKind) u8 {
    if (k == instr.OP_CMP_EQ)   { ret FCC_EQ; }
    if (k == instr.OP_CMP_NE)   { ret FCC_NE; }
    if (k == instr.OP_CMP_LT_S || k == instr.OP_CMP_LT_U) { ret FCC_LT; }
    ret FCC_LE;
}

# lower_float_op: lower a scalar floating-point arithmetic / comparison instruction
# to its dedicated SSE MIR opcode (MIR_FADD / FSUB / FMUL / FDIV for the four
# arithmetic ops, MIR_FCMP for a comparison). the opcode survives instruction
# selection and the encoder materializes the SSE byte sequence (operands loaded
# into XMM scratch, the SSE op, the result stored back) — mirroring cmach's
# `emit_float_op` / `emit_float_cmp`. the operation width (4 for f32, 8 for f64)
# rides on `mi.width` so the encoder selects the SS vs SD form; a MIR_FCMP also
# carries its FCC_* condition on `mi.src_width`. the layout is `[dst, lhs, rhs]`
# like the generic three-address ALU / compare forms.
fun lower_float_op(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: float op missing operand");
    }
    val dst: u32 = result_vreg(ctx, iid);
    if (dst == MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: float op defines no result vreg");
    }

    val rop: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 3::usize);
    if (is_err[*MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*MirOperand, str](rop)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](rop);
    ops[0] = op_vreg(dst);
    ops[1] = lower_value(ctx, inst.operands[0]);
    ops[2] = lower_value(ctx, inst.operands[1]);

    val w: u8 = float_op_width(ctx, inst);

    var mi: MirInstr;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;

    val k: instr.InstrKind = inst.kind;
    if (is_compare_kind(k)) {
        mi.opcode    = MIR_FCMP;
        mi.src_width = float_cmp_cc(k);
    } or (k == instr.OP_ADD) {
        mi.opcode = MIR_FADD;
    } or (k == instr.OP_SUB) {
        mi.opcode = MIR_FSUB;
    } or (k == instr.OP_MUL) {
        mi.opcode = MIR_FMUL;
    } or {
        mi.opcode = MIR_FDIV;
    }

    ret push_instr(ctx, mb, mi);
}

# is_float_kind: true when an instruction's result or first operand is a float, so
# its width is driven by the float encoders rather than this integer base-width
# carrier. the float conversions, scalar float arithmetic, and float comparisons
# all reach lowering through the generic path and must not be re-sized here.
fun is_float_kind(ctx: *LowerCtx, inst: *instr.Instruction) bool {
    if (inst.kind == instr.OP_FP_TO_SI || inst.kind == instr.OP_FP_TO_UI ||
        inst.kind == instr.OP_SI_TO_FP || inst.kind == instr.OP_UI_TO_FP ||
        inst.kind == instr.OP_FP_TRUNC || inst.kind == instr.OP_FP_EXT) {
        ret true;
    }
    if (value_is_float(ctx, inst.ty)) { ret true; }
    if (inst.operand_count >= 1 && value_is_float(ctx, inst.operands[0].ty)) { ret true; }
    ret false;
}

# lowers a single IR operand by position, honouring the per-opcode conventions
# for operands that name block targets rather than values: BR's single target
# and CBR's then/else targets ride in value slots as block-id constants.
fun lower_operand(ctx: *LowerCtx, inst: *instr.Instruction, idx: u32) MirOperand {
    val v: value.Value = inst.operands[idx];
    if (inst.kind == instr.OP_BR) {
        ret op_block(v.data.int_lit::u32);
    }
    if (inst.kind == instr.OP_CBR && idx >= 1) {
        ret op_block(v.data.int_lit::u32);
    }
    ret lower_value(ctx, v);
}

# lower_alloca: lower an OP_ALLOCA into a stack-slot reservation plus the address
# materialization. the instruction's type is the allocated ELEMENT type (the
# result Value is a pointer); operand 0 is the element count. a fresh internal
# slot-key vreg owns a SLOT_ALLOCA frame slot sized `element_size * count` and is
# used only as the LEA base, so regalloc never register-allocates it and the
# encoder resolves it to `[rbp + offset]`. the emitted `MIR_ALLOCA (result) <-
# [slot]` selects to `LEA result, [rbp + offset]`, leaving the allocation's
# address in the result vreg as an ordinary pointer for downstream uses.
fun lower_alloca(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: alloca with no count operand");
    }
    val cv: value.Value = inst.operands[0];
    if (cv.kind != value.VAL_CONST_INT) {
        ret err[bool, str]("mir.lower_ir: non-constant alloca count unsupported");
    }
    val count: u64 = cv.data.int_lit;

    # the element type is the instruction's own type; size and align the slot from
    # it. the allocated region is `count` contiguous elements.
    val elem_size: u32  = ir_type.byte_size(ctx.types, inst.ty, ctx.tgt);
    val elem_align: u32 = ir_type.byte_align(ctx.types, inst.ty, ctx.tgt);
    val total: u64 = elem_size::u64 * count;

    val dst: u32 = result_vreg(ctx, iid);
    if (dst == MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: alloca defines no result vreg");
    }

    # an internal slot-key vreg owns the storage; it is addressed only as a MEM
    # base, never register-allocated.
    val skr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
    if (is_err[u32, str](skr)) { ret err[bool, str](unwrap_err[u32, str](skr)); }
    val sk: u32 = unwrap_ok[u32, str](skr);

    val ar: Result[bool, str] = add_alloca_slot(ctx, sk, total, elem_align);
    if (is_err[bool, str](ar)) { ret ar; }

    # record the slot-key vreg under this alloca's instruction id so an
    # inline-asm `{name}` binding referencing the alloca resolves to its slot.
    if (ctx.slot_key_vregs != nil && iid::u32 < ctx.instr_count) {
        ctx.slot_key_vregs[iid::u32] = sk;
    }

    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = op_mem_slot(sk, 0);
    var mi: MirInstr;
    mi.opcode        = MIR_ALLOCA;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the alloca selects to a LEA computing a pointer-sized address.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# lower_load: lower an OP_LOAD into `MIR_LOAD (dst) <- [ptr]`. operand 0 is the
# pointer; a pointer that lowers to a vreg becomes the MEM base (so an alloca
# address resolves to `[rbp + offset]` and a runtime pointer to `[reg]`), while a
# symbol / immediate pointer is left as a plain operand for the encoder to form
# its own reference. the result vreg is the loaded value.
fun lower_load(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: load with no pointer operand");
    }
    val dst: u32 = result_vreg(ctx, iid);
    if (dst == MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: load defines no result vreg");
    }
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = mem_operand_of(ctx, inst.operands[0]);
    var mi: MirInstr;
    mi.opcode        = MIR_LOAD;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the load accesses memory at the loaded result type's width.
    mi.width         = op_width_of(ctx, inst.ty);
    mi.src_width     = mi.width;
    ret push_instr(ctx, mb, mi);
}

# lower_store: lower an OP_STORE into `MIR_STORE [ptr] <- (value)`. the IR operand
# order is [value, ptr]; the MIR destination (operand 0) is the pointer's MEM
# reference and operand 1 is the stored value, matching the store convention the
# ABI lowering and the encoder share (operand 0 = memory destination). a store
# whose value is an aggregate is a storage-to-storage copy: the value operand is
# the source aggregate's storage pointer (aggregates flow by address — see the
# lower expr aggregate-rvalue rules), so it is expanded into a sized memcpy rather
# than a single scalar store.
fun lower_store(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: store missing value or pointer operand");
    }
    if (value_is_aggregate(ctx, inst.operands[0].ty)) {
        ret lower_store_aggregate(ctx, mb, inst);
    }
    # the stored scalar value. a global / function symbol lowers to its address as
    # an rvalue (`op_sym`), and x86-64 cannot store a 64-bit symbol address straight
    # to memory (the encoder's mem-to-mem split would load the symbol's contents, not
    # its address) — so a symbol value is LEA-materialized into a register first,
    # mirroring the aggregate / by-reference / sret paths.
    var stored: MirOperand = lower_value(ctx, inst.operands[0]);
    if (stored.kind == MIR_OP_SYM) {
        var addr: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, stored, ?addr);
        if (is_err[bool, str](ar)) { ret ar; }
        stored = op_vreg(addr);
    }
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = mem_operand_of(ctx, inst.operands[1]);
    ops[1] = stored;
    var mi: MirInstr;
    mi.opcode        = MIR_STORE;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the store accesses memory at the stored value's type width (IR operand 0);
    # the store result is void, so the value type is the only width carrier.
    mi.width         = op_width_of(ctx, inst.operands[0].ty);
    mi.src_width     = mi.width;
    ret push_instr(ctx, mb, mi);
}

# lower_store_aggregate: expand an OP_STORE of an aggregate into a memcpy from the
# source aggregate's storage to the destination. both IR operands are pointers to
# storage (operand 0 = source aggregate address, operand 1 = destination address),
# matching the by-address convention aggregate rvalues flow under. the copy walks
# the aggregate in 8-byte chunks, finishing any 4/2/1-byte tail, emitting a
# `MIR_LOAD scratch <- [src + off]` / `MIR_STORE [dst + off] <- scratch` pair per
# chunk. a fresh scratch vreg per chunk keeps each load/store independent for the
# register allocator. a zero-sized aggregate copies nothing.
fun lower_store_aggregate(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction) Result[bool, str] {
    val size: u32 = ir_type.byte_size(ctx.types, inst.operands[0].ty, ctx.tgt);
    var off: i64 = 0;
    for (off::u32 < size) {
        val remaining: u32 = size - off::u32;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        } or (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val src: MirOperand = agg_pointer_mem(ctx, inst.operands[0], off);
        val dst: MirOperand = agg_pointer_mem(ctx, inst.operands[1], off);

        val tr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
        if (is_err[u32, str](tr)) { ret err[bool, str](unwrap_err[u32, str](tr)); }
        val tmp: u32 = unwrap_ok[u32, str](tr);

        val ldr: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
        if (is_err[*MirOperand, str](ldr)) { ret err[bool, str](unwrap_err[*MirOperand, str](ldr)); }
        val ldops: *MirOperand = unwrap_ok[*MirOperand, str](ldr);
        ldops[0] = op_vreg(tmp);
        ldops[1] = src;
        var ld: MirInstr;
        ld.opcode        = MIR_LOAD;
        ld.operands      = ldops;
        ld.operand_count = 2;
        ld.width         = chunk;
        ld.src_width     = chunk;
        val pl: Result[bool, str] = push_instr(ctx, mb, ld);
        if (is_err[bool, str](pl)) { ret pl; }

        val st: Result[bool, str] = push_store_chunk(ctx, mb, dst, op_vreg(tmp), chunk);
        if (is_err[bool, str](st)) { ret st; }

        off = off + chunk::i64;
    }
    ret ok[bool, str](true);
}

# push_store_chunk: emit one `MIR_STORE [mem] <- (src)` at an explicit byte width,
# used by the aggregate memcpy expansion. mirrors `emit_store_to` but carries the
# chunk width rather than the machine word so a 4/2/1-byte tail copies exactly its
# bytes without writing past the aggregate.
fun push_store_chunk(ctx: *LowerCtx, mb: *MirBlock, mem: MirOperand, src: MirOperand, w: u8) Result[bool, str] {
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = mem;
    ops[1] = src;
    var mi: MirInstr;
    mi.opcode        = MIR_STORE;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    ret push_instr(ctx, mb, mi);
}

# agg_pointer_mem: form the MEM operand addressing an aggregate's storage at a byte
# displacement, given the IR Value naming that storage pointer. a pointer that
# lowers to a value vreg (an alloca result or runtime pointer) becomes a value-vreg
# `[base + disp]` MEM operand; a global aggregate lowers to a symbol whose storage
# is addressed `[rip + sym + disp]`, the displacement riding in the symbol addend.
# matches `mem_operand_of`'s base disambiguation, extended with the displacement
# the per-chunk copy needs.
fun agg_pointer_mem(ctx: *LowerCtx, v: value.Value, disp: i64) MirOperand {
    val op: MirOperand = lower_value(ctx, v);
    if (op.kind == MIR_OP_VREG) { ret op_mem_value(op.vreg, disp); }
    if (op.kind == MIR_OP_SYM)  { ret op_sym(op.sym, op.sym_off + disp::i32); }
    ret op;
}

# lower_gep: lower an OP_GEP into `MIR_GEP (dst) <- [base + index*scale + disp]`
# (selected to LEA), folding the index walk into the effective address. the IR
# operands are `[base, idx0, idx1, ...]` and the instruction's `aux_ty` is the
# source pointee type the walk starts from (the base pointer itself is untyped, so
# element/field sizes come from `aux_ty` via `ir_type.byte_size`). the walk follows
# the standard getelementptr model: index 0 strides over `aux_ty`, and each later
# index descends one aggregate level (an array element stride, or a constant
# struct-field offset). constant index contributions fold into the displacement;
# at most one runtime index folds into the SIB `index*scale` term, and a scale
# that is not 1/2/4/8 (or a second runtime index) is materialized into a register
# with explicit MIR_MUL / MIR_ADD before the LEA.
fun lower_gep(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: gep with no base operand");
    }
    val dst: u32 = result_vreg(ctx, iid);
    if (dst == MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: gep defines no result vreg");
    }

    val base: MirOperand = mem_operand_of(ctx, inst.operands[0]);

    # the index walk needs the source pointee type to size each level; a GEP that
    # carries indices but no source type is a lowering bug, not silently foldable.
    if (inst.operand_count > 1 && inst.aux_ty == ir_type.IRT_NIL) {
        ret err[bool, str]("mir.lower_ir: gep with indices is missing its source pointee type");
    }

    # walk the indices, accumulating a constant displacement and at most one
    # scaled runtime index. a struct level needs a constant field ordinal.
    var disp:      i64 = 0;
    var idx_vreg:  u32 = MIR_VREG_NIL;
    var idx_scale: u8  = 0;
    var cur_ty:    ir_type.IrTypeId = inst.aux_ty;

    var k: u32 = 1;
    for (k < inst.operand_count) {
        val v: value.Value = inst.operands[k];
        val is_first: bool = k == 1;

        # determine the stride for this level and the type one level deeper. the
        # first index strides over the source pointee `cur_ty` without descending;
        # subsequent indices descend into the array element / struct field.
        var stride:    u64 = 0;
        var is_struct: bool = false;
        if (is_first) {
            stride = ir_type.byte_size(ctx.types, cur_ty, ctx.tgt)::u64;
        } or {
            val ct_opt: Option[*ir_type.IrType] = ir_type.get(ctx.types, cur_ty);
            if (!is_some[*ir_type.IrType](ct_opt)) {
                ret err[bool, str]("mir.lower_ir: gep index walks off a non-aggregate type");
            }
            val ct: *ir_type.IrType = unwrap[*ir_type.IrType](ct_opt);
            if (ct.kind == ir_type.IRT_ARRAY) {
                stride = ir_type.byte_size(ctx.types, ct.data.element, ctx.tgt)::u64;
                cur_ty = ct.data.element;
            } or (ct.kind == ir_type.IRT_STRUCT || ct.kind == ir_type.IRT_UNION) {
                is_struct = true;
            } or {
                ret err[bool, str]("mir.lower_ir: gep index into a non-aggregate type");
            }
        }

        if (is_struct) {
            # struct-field index: must be a constant ordinal; fold its byte offset.
            if (v.kind != value.VAL_CONST_INT) {
                ret err[bool, str]("mir.lower_ir: gep struct field index must be constant");
            }
            val field_ix: u32 = v.data.int_lit::u32;
            val fo: Result[i64, str] = struct_field_offset(ctx, cur_ty, field_ix);
            if (is_err[i64, str](fo)) { ret err[bool, str](unwrap_err[i64, str](fo)); }
            disp = disp + unwrap_ok[i64, str](fo);
            val ft: Result[ir_type.IrTypeId, str] = struct_field_type(ctx, cur_ty, field_ix);
            if (is_err[ir_type.IrTypeId, str](ft)) { ret err[bool, str](unwrap_err[ir_type.IrTypeId, str](ft)); }
            cur_ty = unwrap_ok[ir_type.IrTypeId, str](ft);
            k = k + 1;
            cnt;
        }

        if (v.kind == value.VAL_CONST_INT) {
            # constant array / pointer index: fold the scaled offset.
            disp = disp + (v.data.int_lit * stride)::i64;
            k = k + 1;
            cnt;
        }

        # runtime index: fold into the SIB index*scale when possible, else
        # materialize the scaling explicitly. the chosen scale rides back through
        # `?new_scale`, and the new accumulator vreg is the result.
        var new_scale: u8 = 0;
        val ir: Result[u32, str] = fold_runtime_index(ctx, mb, lower_value(ctx, v), stride, idx_vreg, idx_scale, ?new_scale);
        if (is_err[u32, str](ir)) { ret err[bool, str](unwrap_err[u32, str](ir)); }
        idx_vreg  = unwrap_ok[u32, str](ir);
        idx_scale = new_scale;
        k = k + 1;
    }

    # form the folded MEM operand from the base, carrying the scaled index.
    val mem: Result[MirOperand, str] = fold_gep_mem(ctx, mb, base, idx_vreg, idx_scale, disp);
    if (is_err[MirOperand, str](mem)) { ret err[bool, str](unwrap_err[MirOperand, str](mem)); }

    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = unwrap_ok[MirOperand, str](mem);
    var mi: MirInstr;
    mi.opcode        = MIR_GEP;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the GEP selects to a LEA computing a pointer-sized effective address.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# fold_runtime_index: combine one runtime index (value `idxop`, byte stride
# `stride`) into the running scaled-index accumulator. with no accumulator yet and
# a hardware-legal scale, the index rides the SIB `index*scale` term directly and
# `@scale_out` records that scale. otherwise the scaling is materialized — `t =
# index * stride` (MIR_MUL) — and either becomes the accumulator (scale 1) or is
# added into it (`acc = acc + t`, MIR_ADD), with `@scale_out` set to 1. returns the
# accumulator vreg. a non-vreg index operand is a lowering bug (indices are i64
# values), rejected loudly.
fun fold_runtime_index(ctx: *LowerCtx, mb: *MirBlock, idxop: MirOperand, stride: u64,
                       acc: u32, acc_scale: u8, scale_out: *u8) Result[u32, str] {
    if (idxop.kind != MIR_OP_VREG) {
        ret err[u32, str]("mir.lower_ir: gep runtime index is not a register value");
    }
    val idxv: u32 = idxop.vreg;

    if (acc == MIR_VREG_NIL && is_sib_scale(stride)) {
        @scale_out = stride::u8;
        ret ok[u32, str](idxv);
    }

    # materialize `t = idxv * stride`.
    val tr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
    if (is_err[u32, str](tr)) { ret err[u32, str](unwrap_err[u32, str](tr)); }
    val t: u32 = unwrap_ok[u32, str](tr);
    val mr: Result[bool, str] = emit_bin(ctx, mb, MIR_MUL, t, op_vreg(idxv), op_imm(stride::i64));
    if (is_err[bool, str](mr)) { ret err[u32, str](unwrap_err[bool, str](mr)); }

    if (acc == MIR_VREG_NIL) {
        @scale_out = 1;
        ret ok[u32, str](t);
    }

    # accumulate `acc = acc * acc_scale + t`. when the existing accumulator still
    # rode a SIB scale, fold that scale in first so the combined index is scale 1.
    var acc_term: u32 = acc;
    if (acc_scale > 1) {
        val sr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
        if (is_err[u32, str](sr)) { ret err[u32, str](unwrap_err[u32, str](sr)); }
        acc_term = unwrap_ok[u32, str](sr);
        val smr: Result[bool, str] = emit_bin(ctx, mb, MIR_MUL, acc_term, op_vreg(acc), op_imm(acc_scale::i64));
        if (is_err[bool, str](smr)) { ret err[u32, str](unwrap_err[bool, str](smr)); }
    }
    val ar: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
    if (is_err[u32, str](ar)) { ret err[u32, str](unwrap_err[u32, str](ar)); }
    val sum: u32 = unwrap_ok[u32, str](ar);
    val adr: Result[bool, str] = emit_bin(ctx, mb, MIR_ADD, sum, op_vreg(acc_term), op_vreg(t));
    if (is_err[bool, str](adr)) { ret err[u32, str](unwrap_err[bool, str](adr)); }
    @scale_out = 1;
    ret ok[u32, str](sum);
}

# is_sib_scale: true when a byte stride is a hardware SIB scale (1, 2, 4, or 8).
fun is_sib_scale(s: u64) bool {
    ret s == 1 || s == 2 || s == 4 || s == 8;
}

# fold_gep_mem: build the final folded MEM operand for a GEP from its base operand,
# the scaled runtime index (MIR_VREG_NIL when none), and the constant displacement.
# a value-vreg base carries the index in the SIB position; a symbol base with only a
# constant offset folds into `sym_off` (a pure `[rip+sym+off]` reference), and a
# symbol base with a runtime index LEA-materializes the symbol address into a value
# vreg first (`addr_to_vreg`) so the scaled index has a register base to ride.
fun fold_gep_mem(ctx: *LowerCtx, mb: *MirBlock, base: MirOperand, idx_vreg: u32, idx_scale: u8, disp: i64) Result[MirOperand, str] {
    var o: MirOperand = base;
    if (base.kind == MIR_OP_MEM) {
        # a value-pointer / physical-register / frame-slot-key base all fold the
        # constant displacement into `imm`; the encoder resolves a slot key to
        # `[rbp + off]` and can still carry the SIB index alongside.
        o.imm = base.imm + disp;
        if (idx_vreg != MIR_VREG_NIL) {
            o.index         = idx_vreg;
            o.scale         = idx_scale;
            o.index_is_preg = false;
        }
        ret ok[MirOperand, str](o);
    }
    if (base.kind == MIR_OP_SYM) {
        if (idx_vreg == MIR_VREG_NIL) {
            o.sym_off = base.sym_off + disp::i32;
            ret ok[MirOperand, str](o);
        }
        # runtime index against a global: there is no register in a `[rip+sym]`
        # reference to scale the index into, so LEA the symbol address (carrying
        # its `sym_off`) into a value vreg and index `[base + idx*scale + disp]`
        # off that register, the same materialization `addr_to_vreg` performs for
        # by-reference aggregate placement.
        var sbase: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, base, ?sbase);
        if (is_err[bool, str](ar)) { ret err[MirOperand, str](unwrap_err[bool, str](ar)); }
        var m: MirOperand = op_mem_value(sbase, disp);
        m.index         = idx_vreg;
        m.scale         = idx_scale;
        m.index_is_preg = false;
        ret ok[MirOperand, str](m);
    }
    ret err[MirOperand, str]("mir.lower_ir: gep base is neither a memory nor a symbol reference");
}

# struct_field_offset: byte offset of field `ix` within an IRT_STRUCT, computed by
# the same aligned-layout walk as `ir_type.byte_size`.
fun struct_field_offset(ctx: *LowerCtx, struct_ty: ir_type.IrTypeId, ix: u32) Result[i64, str] {
    val st_opt: Option[*ir_type.IrType] = ir_type.get(ctx.types, struct_ty);
    if (!is_some[*ir_type.IrType](st_opt)) {
        ret err[i64, str]("mir.lower_ir: gep struct type not found");
    }
    val st: *ir_type.IrType = unwrap[*ir_type.IrType](st_opt);
    # a union overlaps its members: every member is at offset 0.
    if (st.kind == ir_type.IRT_UNION) {
        if (ix >= st.data.struct_.field_count) {
            ret err[i64, str]("mir.lower_ir: gep union member index out of range");
        }
        ret ok[i64, str](0::i64);
    }
    if (st.kind != ir_type.IRT_STRUCT) {
        ret err[i64, str]("mir.lower_ir: gep struct index into a non-struct type");
    }
    if (ix >= st.data.struct_.field_count) {
        ret err[i64, str]("mir.lower_ir: gep struct field index out of range");
    }
    var off: u32 = 0;
    var i:   u32 = 0;
    for (i <= ix) {
        val fid: ir_type.IrTypeId = st.data.struct_.fields[i];
        val fa:  u32 = ir_type.byte_align(ctx.types, fid, ctx.tgt);
        off = round_up_u32(off, fa);
        if (i == ix) { ret ok[i64, str](off::i64); }
        off = off + ir_type.byte_size(ctx.types, fid, ctx.tgt);
        i = i + 1;
    }
    ret err[i64, str]("mir.lower_ir: gep struct field offset walk failed");
}

# struct_field_type: the IR type of field `ix` within an IRT_STRUCT.
fun struct_field_type(ctx: *LowerCtx, struct_ty: ir_type.IrTypeId, ix: u32) Result[ir_type.IrTypeId, str] {
    val st_opt: Option[*ir_type.IrType] = ir_type.get(ctx.types, struct_ty);
    if (!is_some[*ir_type.IrType](st_opt)) {
        ret err[ir_type.IrTypeId, str]("mir.lower_ir: gep struct type not found");
    }
    val st: *ir_type.IrType = unwrap[*ir_type.IrType](st_opt);
    if ((st.kind != ir_type.IRT_STRUCT && st.kind != ir_type.IRT_UNION) || ix >= st.data.struct_.field_count) {
        ret err[ir_type.IrTypeId, str]("mir.lower_ir: gep struct field index out of range");
    }
    ret ok[ir_type.IrTypeId, str](st.data.struct_.fields[ix]);
}

# round_up_u32: round `v` up to the next multiple of `align` (align >= 1).
fun round_up_u32(v: u32, align: u32) u32 {
    if (align <= 1) { ret v; }
    ret ((v + align - 1) / align) * align;
}

# emit_bin: append a generic binary MIR op `dst <- (a) OP (b)` to a block.
fun emit_bin(ctx: *LowerCtx, mb: *MirBlock, op: MirOpcode, dst: u32, a: MirOperand, b: MirOperand) Result[bool, str] {
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 3::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = a;
    ops[2] = b;
    var mi: MirInstr;
    mi.opcode        = op;
    mi.operands      = ops;
    mi.operand_count = 3;
    # GEP index scaling is pointer arithmetic over machine-word index registers.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# mem_operand_of: form the memory operand a load / store / gep addresses through.
# a pointer that lowers to a vreg is a value-pointer base (an alloca's result
# pointer or a runtime pointer — never the internal slot-key vreg), so it becomes
# a value-vreg `[base + 0]` MEM operand regalloc resolves to a physical register;
# a symbol or immediate pointer is returned as-is so the encoder forms its own
# (rip-relative / absolute) reference.
fun mem_operand_of(ctx: *LowerCtx, v: value.Value) MirOperand {
    val op: MirOperand = lower_value(ctx, v);
    if (op.kind == MIR_OP_VREG) { ret op_mem_value(op.vreg, 0); }
    ret op;
}

# add_alloca_slot: append a SLOT_ALLOCA frame slot keyed on an internal slot-key
# vreg, sized and aligned for the allocation, so frame.run assigns it an offset
# and the encoder forms `[rbp + offset]` for its address. mirrors add_spill_slot's
# growth but marks the slot as addressed alloca storage.
fun add_alloca_slot(ctx: *LowerCtx, value_id: u32, size: u64, align: u32) Result[bool, str] {
    val f: *MirFunction = ctx.f;
    val frame: *MirFrame = ?f.frame;
    if (frame.slot_count >= frame.slot_cap) {
        var new_cap: u32 = frame.slot_cap * 2;
        if (new_cap < INITIAL_SLOT_CAP) { new_cap = INITIAL_SLOT_CAP; }
        val r: Result[*MirSlot, str] = reallocate[MirSlot](ctx.alloc, frame.slots, frame.slot_cap::usize, new_cap::usize);
        if (is_err[*MirSlot, str](r)) { ret err[bool, str](unwrap_err[*MirSlot, str](r)); }
        frame.slots    = unwrap_ok[*MirSlot, str](r);
        frame.slot_cap = new_cap;
    }
    var al: u32 = align;
    if (al == 0) { al = 1; }
    var sz: u32 = size::u32;
    if (sz == 0) { sz = al; }
    val si: u32 = frame.slot_count;
    frame.slots[si].value  = value_id;
    frame.slots[si].kind   = SLOT_ALLOCA;
    frame.slots[si].offset = 0;
    frame.slots[si].size   = sz;
    frame.slots[si].align  = al;
    frame.slot_count = frame.slot_count + 1;
    ret ok[bool, str](true);
}

# MAX_GP_ARG_REGS: upper bound on the GP argument-register file size used to
# size the stack buffer `abi_gp_arg_reg` fills from `tgt.abi.gp_arg_regs`. every
# modeled convention's GP argument file (SysV's six, Win64's four) fits.
val MAX_GP_ARG_REGS: i32 = 16;

# require_abi: validate that the active target exposes the ABI and ISA vtable
# surface the params / calls / returns pre-coloring drives through, erroring
# loudly when it does not. ABI lowering is no longer gated by an architecture
# check: it is driven purely through the vtables, so an absent ABI vtable or one
# missing the classify / arg / ret / arg-register-file accessors (an unsupported
# convention) is a hard error rather than a silent un-pre-colored off-path.
# ---
# tgt: the active target
# ret: ok(true) when the vtable surface is present, or a loud error
fun require_abi(tgt: *target.Target) Result[bool, str] {
    if (tgt == nil)      { ret err[bool, str]("mir.lower_ir: nil target"); }
    if (tgt.abi == nil)  { ret err[bool, str]("mir.lower_ir: target has no ABI vtable"); }
    if (tgt.arch == nil) { ret err[bool, str]("mir.lower_ir: target has no ISA vtable"); }
    if (tgt.abi.arg_passing == nil || tgt.abi.ret_passing == nil) {
        ret err[bool, str]("mir.lower_ir: ABI vtable exposes no arg/ret classifier");
    }
    if (tgt.abi.gp_arg_regs == nil) {
        ret err[bool, str]("mir.lower_ir: ABI vtable exposes no GP argument register file");
    }
    ret ok[bool, str](true);
}

# abi_gp_arg_reg: the physical register id of the `index`-th GP argument register
# of the active ABI, read from `tgt.abi.gp_arg_regs` (the convention's GP argument
# bank in passing order). used for the hidden sret-pointer argument, which rides
# in the first GP argument register the same way an ordinary argument does. errors
# loudly when `index` is past the convention's GP argument file (a classification
# bug) rather than returning a wrong register.
# ---
# tgt:   the active target
# index: zero-based GP argument-register index
# out:   receives the physical register id on success
# ret:   ok(true) on success, or a loud error
fun abi_gp_arg_reg(tgt: *target.Target, index: i32, out: *i32) Result[bool, str] {
    var regs: [16]isa.Register;
    val fill: sysv.RegFileFn = tgt.abi.gp_arg_regs::sysv.RegFileFn;
    val n: i32 = fill(?regs[0]);
    if (index < 0 || index >= n || index >= MAX_GP_ARG_REGS) {
        ret err[bool, str]("mir.lower_ir: GP argument register index out of range");
    }
    @out = regs[index].id;
    ret ok[bool, str](true);
}

# abi_gp_ret_reg: the physical register id of the active ABI's general-purpose
# scalar-return register, obtained by classifying an 8-byte integer return through
# `tgt.abi.ret_passing`. SysV's varargs convention requires the count of vector
# registers a variadic call uses in this register (AL, the low byte of RAX) before
# every call; sourcing it from the return classifier keeps that placement
# vtable-driven rather than naming RAX directly. errors loudly when the classifier
# returns no register (an unsupported convention).
# ---
# tgt: the active target
# out: receives the physical register id on success
# ret: ok(true) on success, or a loud error
fun abi_gp_ret_reg(tgt: *target.Target, out: *i32) Result[bool, str] {
    val classify_ret: sysv.RetPassingFn = tgt.abi.ret_passing::sysv.RetPassingFn;
    val slot: abi.ParamSlot = classify_ret(tgt.arch_id, 8, 8, false, false);
    if (slot.class != abi.CLASS_GP || slot.reg < 0) {
        ret err[bool, str]("mir.lower_ir: ABI vtable has no GP return register");
    }
    @out = slot.reg;
    ret ok[bool, str](true);
}

# value_is_float: true when an IR type is a floating-point scalar, so the ABI
# classifier routes it through the FP register file.
fun value_is_float(ctx: *LowerCtx, ty: ir_type.IrTypeId) bool {
    ret ir_type.is_float_scalar(ctx.types, ty);
}

# value_is_aggregate: true when an IR type is a record or array, so the ABI
# classifier applies the aggregate (one/two-register or by-reference) rules.
fun value_is_aggregate(ctx: *LowerCtx, ty: ir_type.IrTypeId) bool {
    ret ir_type.is_aggregate(ctx.types, ty);
}

# emit_mov: append a `MIR_MOV (dst) <- (src)` to a block. used for every ABI
# pre-coloring move (vreg<->preg, imm->preg) as well as plain vreg copies. driven
# at the machine-word width: a scalar argument / return / hidden-pointer value
# occupies a full register or an 8-byte stack slot under SysV, so a full-width
# move copies the value's low bits intact without truncating or corrupting it.
fun emit_mov(ctx: *LowerCtx, mb: *MirBlock, dst: MirOperand, src: MirOperand) Result[bool, str] {
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: MirInstr;
    mi.opcode        = MIR_MOV;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# emit_mov_w: append a `MIR_MOV (dst) <- (src)` driven at an explicit operation
# width rather than the machine word. used for the division dividend / result
# pre-coloring moves, where the move must be exactly the divide's width so a
# 4-byte move zeroes the upper 32 bits of the accumulator and a 1/2-byte move
# leaves the surrounding bits untouched, matching the width the IDIV/DIV operates
# on. every other ABI pre-coloring move is full-width (`emit_mov`).
fun emit_mov_w(ctx: *LowerCtx, mb: *MirBlock, dst: MirOperand, src: MirOperand, w: u8) Result[bool, str] {
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: MirInstr;
    mi.opcode        = MIR_MOV;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    ret push_instr(ctx, mb, mi);
}

# emit_store_to: append a `MIR_STORE (mem) <- (src)` to a block. operand 0 is the
# fully-formed memory destination (a slot-key or physical-register MEM operand the
# caller builds with the matching constructor), operand 1 the stored value. driven
# at the machine-word width: every caller stores a full register into an 8-byte
# stack-argument / aggregate-half / spill slot under SysV.
fun emit_store_to(ctx: *LowerCtx, mb: *MirBlock, mem: MirOperand, src: MirOperand) Result[bool, str] {
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = mem;
    ops[1] = src;
    var mi: MirInstr;
    mi.opcode        = MIR_STORE;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# classify_signature: classify a whole function ABI in ONE left-to-right walk and
# fill `out` with the resulting `SigLayout`. this is the single ABI-lowering oracle
# the param / return / call lowering all read, so they can never disagree on a
# value's placement: every fact (size / float / aggregate) is taken from a DECLARED
# type via the IR layout oracle, never from a per-operand value type that diverges
# when an aggregate flows by address (its operand is an 8-byte pointer).
#
# the walk:
#   - classifies the return through `tgt.abi.ret_passing` from `ret_ty` (the
#     function's declared return type — the call passes its result type, the
#     callee its signature's return); a CLASS_SRET return reserves the first GP
#     argument register (seeds `gp_used = 1`) just as the hidden pointer consumes a
#     GP slot in the call / params lowering;
#   - when `sig` resolves to an IRT_FN, classifies each fixed parameter through
#     `tgt.abi.arg_passing` against the running GP/FP counters, then assigns the
#     real outgoing stack offset into the slot's `offset` (an eight-byte-granular
#     cursor) and advances the matching cursor — register slots advance `gp_used` /
#     `fp_used` (a 9–16 byte two-GP aggregate advances by two), a stack slot
#     advances `stack_off`. when `sig` is not an IRT_FN (an indirect call through
#     an untyped function pointer, whose declared parameter types the IR does not
#     carry), `param_count` is 0 and the caller classifies every argument from its
#     operand type against the returned running cursors — the same fallback the
#     variadic tail uses.
#
# `out.params` is a fresh allocation (sized to the signature's own param_count, so
# never over/under-run regardless of the caller's parameter count) the caller
# releases with `sig_layout_free` once the lowering of this signature is done. the
# 9–16 byte two-register and >16 byte by-reference / sret behavior is whatever
# `classify_arg` / `classify_return` return, unchanged — this oracle only walks
# them in order and records offsets.
# ---
# ctx:    the active lowering context (supplies the IR type oracle and target)
# sig:    the function signature (an IRT_FN id; non-IRT_FN yields zero fixed params)
# ret_ty: the declared return type to classify the return / sret reservation from
# out:    receives the assembled SigLayout (`params` is owned — free it with
#         `sig_layout_free`)
# ret:    ok(true) on success, or a loud error from the ABI vtable surface
fun classify_signature(ctx: *LowerCtx, sig: ir_type.IrTypeId, ret_ty: ir_type.IrTypeId,
                       out: *abi.SigLayout) Result[bool, str] {
    val rok: Result[bool, str] = require_abi(ctx.tgt);
    if (is_err[bool, str](rok)) { ret rok; }

    val arch: u32 = ctx.tgt.arch_id;
    val classify_arg: sysv.ArgPassingFn = ctx.tgt.abi.arg_passing::sysv.ArgPassingFn;
    val classify_ret: sysv.RetPassingFn = ctx.tgt.abi.ret_passing::sysv.RetPassingFn;

    out.params      = nil;
    out.param_count = 0;

    # the return value's placement decides whether the first GP argument register
    # is reserved for a hidden sret pointer; classify it from the declared return
    # type so its size / shape match what the params / ret lowering both reserve.
    val ret_size:  u64  = ir_type.byte_size(ctx.types, ret_ty, ctx.tgt)::u64;
    val ret_float: bool = value_is_float(ctx, ret_ty);
    val ret_aggr:  bool = value_is_aggregate(ctx, ret_ty);
    out.ret_slot = classify_ret(arch, ret_size, 0, ret_float, ret_aggr);

    var gp_used:   i32 = 0;
    var fp_used:   i32 = 0;
    var stack_off: i64 = 0;

    # a CLASS_SRET return reserves the first GP argument register for the hidden
    # result-storage pointer, so the parameters classify against that reservation.
    if (out.ret_slot.class == abi.CLASS_SRET) {
        gp_used = 1;
    }

    # an indirect call through an untyped function pointer carries no declared
    # parameter types (the signature is not an IRT_FN); leave the fixed-param list
    # empty so the caller classifies every argument from its operand type.
    val it: Option[*ir_type.IrType] = ir_type.get(ctx.types, sig);
    if (!is_some[*ir_type.IrType](it)) {
        out.gp_used   = gp_used;
        out.fp_used   = fp_used;
        out.stack_off = stack_off;
        ret ok[bool, str](true);
    }
    val t: *ir_type.IrType = unwrap[*ir_type.IrType](it);
    if (t.kind != ir_type.IRT_FN) {
        out.gp_used   = gp_used;
        out.fp_used   = fp_used;
        out.stack_off = stack_off;
        ret ok[bool, str](true);
    }

    val pc: u32 = t.data.fn.param_count;
    var slots: *abi.ParamSlot = nil;
    if (pc > 0) {
        val sb: Result[*abi.ParamSlot, str] = allocate[abi.ParamSlot](ctx.alloc, pc::usize);
        if (is_err[*abi.ParamSlot, str](sb)) { ret err[bool, str](unwrap_err[*abi.ParamSlot, str](sb)); }
        slots = unwrap_ok[*abi.ParamSlot, str](sb);
    }

    var pi: u32 = 0;
    for (pi < pc) {
        val pty:  ir_type.IrTypeId = t.data.fn.params[pi];
        val psz:  u64  = ir_type.byte_size(ctx.types, pty, ctx.tgt)::u64;
        val pfl:  bool = value_is_float(ctx, pty);
        val pag:  bool = value_is_aggregate(ctx, pty);
        var slot: abi.ParamSlot = classify_arg(arch, pi::i32, psz, 0, pfl, pag, gp_used, fp_used);

        # record the real outgoing stack offset on the slot (the ABI classifier
        # returns a sizing-only slot with offset 0); the param / call lowering
        # read this instead of re-deriving a parallel cursor.
        if (slot.class == abi.CLASS_STACK) {
            slot.offset = stack_off;
            stack_off   = stack_off + stack_slot_bytes(slot.size);
        } or (slot.class == abi.CLASS_FP) {
            fp_used = fp_used + 1;
        } or (slot.class == abi.CLASS_GP) {
            gp_used = gp_used + 1;
            if (slot.reg2 >= 0) { gp_used = gp_used + 1; }
        } or (slot.class == abi.CLASS_BYREF) {
            gp_used = gp_used + 1;
        }

        slots[pi] = slot;
        pi = pi + 1;
    }

    out.params      = slots;
    out.param_count = pc;
    out.gp_used     = gp_used;
    out.fp_used     = fp_used;
    out.stack_off   = stack_off;
    ret ok[bool, str](true);
}

# sig_layout_free: release the owned `params` array of a `SigLayout` produced by
# `classify_signature`. safe on an empty (nil-params) layout. every site that
# classifies a signature calls this once the layout's slots are consumed.
fun sig_layout_free(ctx: *LowerCtx, layout: *abi.SigLayout) {
    if (layout.params != nil && layout.param_count > 0) {
        deallocate[abi.ParamSlot](ctx.alloc, layout.params, layout.param_count::usize);
        layout.params      = nil;
        layout.param_count = 0;
    }
}

# expands an OP_CALL under SysV AMD64. classifies the callee's return value and
# each argument through the ABI vtable, then emits, in order:
#   - the SRET hidden-pointer move into RDI when the return is >16 bytes;
#   - one `MIR_MOV (argReg) <- (arg)` per register argument (RDI:RSI two-reg
#     aggregates take two), or a stack store for STACK args;
#   - `MIR_MOV (AL) <- imm(fp_arg_count)` (SysV varargs requirement);
#   - the `MIR_CALL` itself (the caller-saved clobber barrier);
#   - the return-register move(s) into the result vreg when the call returns a
#     value (RAX / XMM0, RAX:RDX, or RAX = the sret pointer);
#   - the `MIR_CALL_RES` liveness marker.
# operand 0 of the IR call is the callee; operands 1.. are the arguments. the
# whole placement is driven through the ABI vtable: an absent / unsupported ABI
# vtable is a loud error, never a silent un-pre-colored off-path.
fun lower_call(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: call with no callee operand");
    }
    val rok: Result[bool, str] = require_abi(ctx.tgt);
    if (is_err[bool, str](rok)) { ret rok; }

    val arch: u32 = ctx.tgt.arch_id;
    val classify_arg: sysv.ArgPassingFn = ctx.tgt.abi.arg_passing::sysv.ArgPassingFn;

    # classify the WHOLE declared signature once (the callee's IRT_FN rides on
    # `inst.aux_ty`, the call's result type on `inst.ty`); the return and every
    # fixed argument read their placement from this single layout so the call and
    # the callee's `lower_params` can never disagree — in particular a by-value
    # aggregate argument is classified from its DECLARED parameter type, not from
    # the 8-byte pointer its operand carries. an indirect call through an untyped
    # function pointer yields zero fixed params, so every argument falls back to
    # per-operand classification below.
    val sig: ir_type.IrTypeId = inst.aux_ty;
    val ret_ty: ir_type.IrTypeId = inst.ty;
    var layout: abi.SigLayout;
    val cls: Result[bool, str] = classify_signature(ctx, sig, ret_ty, ?layout);
    if (is_err[bool, str](cls)) { ret cls; }

    val rslot: abi.ParamSlot = layout.ret_slot;

    # the call's result type sizes the caller-owned aggregate result storage.
    val ret_size:  u64 = ir_type.byte_size(ctx.types, ret_ty, ctx.tgt)::u64;
    val ret_aggr:  bool = value_is_aggregate(ctx, ret_ty);

    # the running register / stack cursors resume from the fixed-parameter walk so
    # a variadic call's tail arguments continue against the same counters.
    var gp_used:   i32 = layout.gp_used;
    var fp_used:   i32 = layout.fp_used;
    var stack_off: i64 = layout.stack_off;

    # an aggregate return arrives by address: the caller owns the result storage
    # and the result vreg points at it. allocate that storage and LEA its address
    # into the result vreg before the return placement so the SRET hidden-pointer
    # move (>16B) passes it and the two-register form (9–16B) stores each half into
    # it; downstream consumers then read the aggregate result by this pointer.
    val res_dst: u32 = result_vreg(ctx, iid);
    if (ret_aggr && res_dst != MIR_VREG_NIL) {
        val ra: Result[bool, str] = alloc_result_storage(ctx, mb, res_dst, ret_size, ret_align(ctx, ret_ty));
        if (is_err[bool, str](ra)) {
            sig_layout_free(ctx, ?layout);
            ret ra;
        }
    }

    if (rslot.class == abi.CLASS_SRET) {
        # the caller allocates the return storage (above) and passes its address in
        # the first GP argument register (the ABI's GP argument file, RDI under
        # SysV); the result vreg names that storage. the layout already reserved the
        # GP slot in `gp_used`, so emit the pre-coloring move into the first register.
        if (res_dst != MIR_VREG_NIL) {
            var sret_reg: i32 = 0;
            val sr: Result[bool, str] = abi_gp_arg_reg(ctx.tgt, 0, ?sret_reg);
            if (is_err[bool, str](sr)) {
                sig_layout_free(ctx, ?layout);
                ret sr;
            }
            val pre: Result[bool, str] = emit_mov(ctx, mb,
                op_preg(sret_reg::u32), op_vreg(res_dst));
            if (is_err[bool, str](pre)) {
                sig_layout_free(ctx, ?layout);
                ret pre;
            }
        }
    }

    # arguments, in source order. a fixed argument reads its placement (and real
    # stack offset) from the precomputed layout; a variadic tail argument (past the
    # declared param count) classifies from its operand type against the running
    # counters — the one place an operand's own type is consulted.
    var ai:  u32 = 1;
    for (ai < inst.operand_count) {
        val av:   value.Value = inst.operands[ai];
        val pidx: u32 = ai - 1;
        var slot: abi.ParamSlot;
        var soff: i64 = 0;
        if (pidx < layout.param_count) {
            slot = layout.params[pidx];
            soff = slot.offset;
        } or {
            val asz:  u64  = ir_type.byte_size(ctx.types, av.ty, ctx.tgt)::u64;
            val afl:  bool = value_is_float(ctx, av.ty);
            val aag:  bool = value_is_aggregate(ctx, av.ty);
            slot = classify_arg(arch, pidx::i32, asz, 0, afl, aag, gp_used, fp_used);
            soff = stack_off;
        }

        val aag2: bool = value_is_aggregate(ctx, av.ty);
        # the operand's true byte size is the copy length for a by-value aggregate
        # spilled to the stack: a >16-byte aggregate's ABI slot carries a sizing-only
        # size of 8 (it is otherwise passed by reference), so reading slot.size would
        # truncate the copy. for a fixed param this equals the declared param size
        # (same interned type); for every register / by-ref / <=16B-stack slot it
        # equals slot.size, so only the >16B-on-stack copy length is affected.
        val asz2: u64 = ir_type.byte_size(ctx.types, av.ty, ctx.tgt)::u64;
        # a global / function symbol argument is its address; LEA-materialize it
        # so the register / stack move passes the address, not the symbol's bytes.
        val aor: Result[MirOperand, str] = lower_value_addr(ctx, mb, av);
        if (is_err[MirOperand, str](aor)) {
            sig_layout_free(ctx, ?layout);
            ret err[bool, str](unwrap_err[MirOperand, str](aor));
        }
        val argop: MirOperand = unwrap_ok[MirOperand, str](aor);

        val er: Result[bool, str] = emit_arg_slot(ctx, mb, slot, argop, soff, aag2, asz2);
        if (is_err[bool, str](er)) {
            sig_layout_free(ctx, ?layout);
            ret er;
        }

        # advance the running cursors only for the variadic tail; the fixed-param
        # cursors were already consumed by `classify_signature`.
        if (pidx >= layout.param_count) {
            if (slot.class == abi.CLASS_FP) {
                fp_used = fp_used + 1;
            } or (slot.class == abi.CLASS_GP) {
                gp_used = gp_used + 1;
                if (slot.reg2 >= 0) { gp_used = gp_used + 1; }
            } or (slot.class == abi.CLASS_BYREF) {
                gp_used = gp_used + 1;
            } or (slot.class == abi.CLASS_STACK) {
                stack_off = stack_off + stack_slot_bytes(slot.size);
            }
        }

        ai = ai + 1;
    }

    sig_layout_free(ctx, ?layout);

    # record this call's outgoing stack-argument footprint. frame.run reserves the
    # maximum over all calls, sixteen-byte aligned, as the lowest region of the
    # frame so these `[rsp + off]` stores never overlap locals or spills and the
    # call-site RSP stays sixteen-byte aligned.
    record_outgoing_size(ctx, stack_off);

    # SysV requires the GP return register (AL, the low byte of RAX) to hold the
    # number of vector registers used by variadic arguments before every call (a
    # conservative upper bound is the FP count). the register is the ABI's GP
    # scalar-return register, obtained by classifying an integer return through the
    # ret classifier rather than naming RAX directly.
    var al_reg: i32 = 0;
    val alr: Result[bool, str] = abi_gp_ret_reg(ctx.tgt, ?al_reg);
    if (is_err[bool, str](alr)) { ret alr; }
    val al: Result[bool, str] = emit_mov(ctx, mb,
        op_preg(al_reg::u32), op_imm(fp_used::i64));
    if (is_err[bool, str](al)) { ret al; }

    # the call itself: the caller-saved clobber barrier (see MIR_CALL docs).
    val rcall: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 1::usize);
    if (is_err[*MirOperand, str](rcall)) { ret err[bool, str](unwrap_err[*MirOperand, str](rcall)); }
    val callops: *MirOperand = unwrap_ok[*MirOperand, str](rcall);
    callops[0] = lower_value(ctx, inst.operands[0]);
    var cmi: MirInstr;
    cmi.opcode        = MIR_CALL;
    cmi.operands      = callops;
    cmi.operand_count = 1;
    # the call selects to an address-sized CALL; its operand carries no value width.
    cmi.width         = WORD_WIDTH;
    cmi.src_width     = WORD_WIDTH;
    val pc: Result[bool, str] = push_instr(ctx, mb, cmi);
    if (is_err[bool, str](pc)) { ret pc; }

    # bind the result. an sret call already named its storage via RDI; otherwise
    # move the value out of the canonical return register(s) into the result vreg.
    val dst: u32 = result_vreg(ctx, iid);
    if (dst != MIR_VREG_NIL && rslot.class != abi.CLASS_SRET) {
        val rr: Result[bool, str] = emit_ret_slot_to_vreg(ctx, mb, rslot, dst, ret_aggr);
        if (is_err[bool, str](rr)) { ret rr; }
    }
    if (dst != MIR_VREG_NIL) {
        val rres: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 1::usize);
        if (is_err[*MirOperand, str](rres)) { ret err[bool, str](unwrap_err[*MirOperand, str](rres)); }
        val resops: *MirOperand = unwrap_ok[*MirOperand, str](rres);
        resops[0] = op_vreg(dst);
        var rmi: MirInstr;
        rmi.opcode        = MIR_CALL_RES;
        rmi.operands      = resops;
        rmi.operand_count = 1;
        # a pure liveness marker; it emits no bytes, so its width is unobserved.
        rmi.width         = WORD_WIDTH;
        rmi.src_width     = WORD_WIDTH;
        val pr: Result[bool, str] = push_instr(ctx, mb, rmi);
        if (is_err[bool, str](pr)) { ret pr; }
    }

    ret ok[bool, str](true);
}

# addr_to_vreg: ensure an aggregate's storage address rides in a value vreg so the
# two-register / by-reference argument and return paths can index `[base+0]` /
# `[base+8]` off it and pass it as a pointer. an argop that already is a value vreg
# (an alloca result or runtime pointer) is returned unchanged; a symbol-addressed
# aggregate (a module-level global) is LEA'd into a fresh vreg (`MIR_GEP (vreg) <-
# [rip+sym]`, selected to LEA) so its address — not its first word — is what the
# ABI placement consumes. `out_vreg` receives the value-vreg id on success.
fun addr_to_vreg(ctx: *LowerCtx, mb: *MirBlock, argop: MirOperand, out_vreg: *u32) Result[bool, str] {
    if (argop.kind == MIR_OP_VREG) {
        @out_vreg = argop.vreg;
        ret ok[bool, str](true);
    }
    val vr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
    if (is_err[u32, str](vr)) { ret err[bool, str](unwrap_err[u32, str](vr)); }
    val v: u32 = unwrap_ok[u32, str](vr);
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(v);
    ops[1] = argop;
    var mi: MirInstr;
    mi.opcode        = MIR_GEP;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the address materialization selects to a pointer-sized LEA.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    val p: Result[bool, str] = push_instr(ctx, mb, mi);
    if (is_err[bool, str](p)) { ret p; }
    @out_vreg = v;
    ret ok[bool, str](true);
}

# lower_value_addr: lower an IR value to an rvalue-in-register operand. identical
# to `lower_value`, except a global / function symbol — whose address IS its
# rvalue — is LEA-materialized into a value vreg (via `addr_to_vreg`), so a
# value-position consumer (call argument, return value, phi edge copy, ALU/CMP
# operand) receives the symbol's ADDRESS rather than a MOV-load of the bytes at
# the symbol. callers that consume a symbol in a memory-base or call-target
# position must keep using `lower_value` (the raw `MIR_OP_SYM`).
fun lower_value_addr(ctx: *LowerCtx, mb: *MirBlock, v: value.Value) Result[MirOperand, str] {
    val op: MirOperand = lower_value(ctx, v);
    if (op.kind != MIR_OP_SYM) { ret ok[MirOperand, str](op); }
    var addr: u32 = MIR_VREG_NIL;
    val ar: Result[bool, str] = addr_to_vreg(ctx, mb, op, ?addr);
    if (is_err[bool, str](ar)) { ret err[MirOperand, str](unwrap_err[bool, str](ar)); }
    ret ok[MirOperand, str](op_vreg(addr));
}

# emit_arg_slot: emit the pre-coloring move(s) placing one classified argument.
# GP/FP register args move the value into the argument register (a 9–16 byte
# aggregate in two GP registers moves each half from `[base+0]` / `[base+8]` of
# the aggregate the argop names); BYREF args move the aggregate's address into
# the register; STACK args store the value at `[rsp + stack_off]`, where
# `stack_off` is the caller-tracked running offset into the outgoing-argument
# region (the ABI classifier returns a sizing-only slot with no offset of its
# own, so the running cursor is the caller's responsibility — see `lower_call`).
# an aggregate argop is a pointer to the aggregate's storage (aggregates flow by
# address); the register / stack forms load or copy the aggregate's bytes from
# that storage, and `addr_to_vreg` normalizes a global's symbol address into a
# value vreg so the two-register / by-reference forms index a register pointer
# base. a scalar argop is the value itself, placed directly.
fun emit_arg_slot(ctx: *LowerCtx, mb: *MirBlock, slot: abi.ParamSlot, argop: MirOperand,
                  stack_off: i64, is_aggr: bool, size: u64) Result[bool, str] {
    if (slot.class == abi.CLASS_STACK) {
        # outgoing stack arguments are addressed off the ISA's stack pointer
        # (x86-64 RSP), named through `tgt.arch.stack_ptr_reg` rather than a literal.
        val sp: u32 = ctx.tgt.arch.stack_ptr_reg::u32;
        if (is_aggr) {
            # the by-value aggregate is copied into the outgoing stack slot from its
            # storage; argop is a pointer to that storage.
            ret copy_aggregate(ctx, mb, op_mem_preg(sp, stack_off), argop, size);
        }
        # the outgoing scalar argument is stored at `[sp + stack_off]`; the stack
        # pointer is fixed after the prologue and points at the base of the outgoing
        # region, so the store lands in the slot frame.run reserved for it.
        ret emit_store_to(ctx, mb, op_mem_preg(sp, stack_off), argop);
    }
    if (slot.class == abi.CLASS_BYREF) {
        # the aggregate is passed by hidden pointer; move its address into the
        # register, materializing a global's symbol address into a vreg first.
        var base: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, argop, ?base);
        if (is_err[bool, str](ar)) { ret ar; }
        ret emit_mov(ctx, mb, op_preg(slot.reg::u32), op_vreg(base));
    }
    if (slot.reg2 >= 0) {
        # two-register aggregate: load each 8-byte half from the aggregate's
        # storage (a value-pointer base) into the two GP registers.
        var base: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, argop, ?base);
        if (is_err[bool, str](ar)) { ret ar; }
        val lo: Result[bool, str] = emit_mov(ctx, mb,
            op_preg(slot.reg::u32), op_mem_value(base, 0));
        if (is_err[bool, str](lo)) { ret lo; }
        ret emit_mov(ctx, mb, op_preg(slot.reg2::u32), op_mem_value(base, 8));
    }
    if (is_aggr) {
        # ≤8 byte single-register aggregate: load its one word from the aggregate's
        # storage into the argument register, normalizing a global's address first.
        var base: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, argop, ?base);
        if (is_err[bool, str](ar)) { ret ar; }
        ret emit_mov(ctx, mb, op_preg(slot.reg::u32), op_mem_value(base, 0));
    }
    # single GP or FP register scalar argument.
    ret emit_mov(ctx, mb, op_preg(slot.reg::u32), argop);
}

# copy_aggregate: memcpy `size` bytes from the source aggregate storage (`src`, a
# pointer-valued operand) into a destination memory operand (`dst_mem`, a base+disp
# MEM operand such as an outgoing-stack slot). walks the aggregate in 8/4/2/1-byte
# chunks through a scratch register, mirroring `lower_store_aggregate` but writing
# to a caller-supplied MEM destination whose base displacement advances per chunk.
fun copy_aggregate(ctx: *LowerCtx, mb: *MirBlock, dst_mem: MirOperand, src: MirOperand, size: u64) Result[bool, str] {
    var sbase: u32 = MIR_VREG_NIL;
    val ar: Result[bool, str] = addr_to_vreg(ctx, mb, src, ?sbase);
    if (is_err[bool, str](ar)) { ret ar; }

    var off: i64 = 0;
    for (off::u64 < size) {
        val remaining: u64 = size - off::u64;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        } or (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val tr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
        if (is_err[u32, str](tr)) { ret err[bool, str](unwrap_err[u32, str](tr)); }
        val tmp: u32 = unwrap_ok[u32, str](tr);

        val ldr: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
        if (is_err[*MirOperand, str](ldr)) { ret err[bool, str](unwrap_err[*MirOperand, str](ldr)); }
        val ldops: *MirOperand = unwrap_ok[*MirOperand, str](ldr);
        ldops[0] = op_vreg(tmp);
        ldops[1] = op_mem_value(sbase, off);
        var ld: MirInstr;
        ld.opcode        = MIR_LOAD;
        ld.operands      = ldops;
        ld.operand_count = 2;
        ld.width         = chunk;
        ld.src_width     = chunk;
        val pl: Result[bool, str] = push_instr(ctx, mb, ld);
        if (is_err[bool, str](pl)) { ret pl; }

        # the destination MEM operand at this chunk's displacement: a slot-key base
        # rides in `vreg`, a physical-register base in `preg`; either advances by off.
        var d: MirOperand = dst_mem;
        d.imm = dst_mem.imm + off;
        val st: Result[bool, str] = push_store_chunk(ctx, mb, d, op_vreg(tmp), chunk);
        if (is_err[bool, str](st)) { ret st; }

        off = off + chunk::i64;
    }
    ret ok[bool, str](true);
}

# stack_slot_bytes: the outgoing-region footprint of one stack-passed argument.
# SysV passes each stack argument in an eight-byte-granular slot (a value smaller
# than eight bytes still consumes a full slot), so round the value size up to the
# eight-byte boundary. mirrors the `[rbp + 16 + off]` layout the callee reads.
# ---
# size: the argument's value size in bytes (from its ABI ParamSlot)
# ret:  the eight-byte-aligned slot size in bytes
fun stack_slot_bytes(size: u64) i64 {
    var n: u64 = size;
    if (n == 0) { n = 8; }
    n = (n + 7) & ~7::u64;
    ret n::i64;
}

# record_outgoing_size: grow the function's reserved outgoing-argument region to
# cover one call's stack-argument footprint. frame.run reserves the running
# maximum (sixteen-byte aligned) as the lowest region of the frame; recording the
# maximum here keeps a single shared region sized for the worst call rather than
# one region per call.
# ---
# ctx:   the active lowering context (its function's frame is updated in place)
# bytes: this call's total outgoing stack-argument bytes
fun record_outgoing_size(ctx: *LowerCtx, bytes: i64) {
    if (bytes <= 0) { ret; }
    val need: u32 = bytes::u32;
    if (need > ctx.f.frame.outgoing_size) {
        ctx.f.frame.outgoing_size = need;
    }
}

# emit_ret_slot_to_vreg: move a call's return value out of its canonical return
# register(s) into the result vreg. for an aggregate return `dst` is the caller-
# owned result storage pointer (see `alloc_result_storage`): a 9–16 byte RAX:RDX
# pair stores each half into `[dst+0]` / `[dst+8]`, and a ≤8 byte single-register
# aggregate stores RAX into `[dst+0]` so `dst` stays the storage pointer downstream
# consumers read by. a scalar return is a plain move into the value vreg `dst`.
fun emit_ret_slot_to_vreg(ctx: *LowerCtx, mb: *MirBlock, slot: abi.ParamSlot, dst: u32, is_aggr: bool) Result[bool, str] {
    if (slot.reg2 >= 0) {
        val lo: Result[bool, str] = emit_store_to(ctx, mb, op_mem_value(dst, 0), op_preg(slot.reg::u32));
        if (is_err[bool, str](lo)) { ret lo; }
        ret emit_store_to(ctx, mb, op_mem_value(dst, 8), op_preg(slot.reg2::u32));
    }
    if (is_aggr) {
        ret emit_store_to(ctx, mb, op_mem_value(dst, 0), op_preg(slot.reg::u32));
    }
    ret emit_mov(ctx, mb, op_vreg(dst), op_preg(slot.reg::u32));
}

# lower_params: emit the entry-block ABI pre-coloring for incoming parameters.
# classifies each parameter through the ABI vtable and, for register parameters,
# moves the value out of its canonical argument register into the parameter
# vreg; for a two-register aggregate, stores both GP halves into the parameter's
# stack spill slot and rebinds the vreg to point at it; for STACK parameters,
# loads from the caller frame at `[fp + 16 + offset]`. driven purely through the
# ABI vtable: an absent / unsupported ABI vtable is a loud error.
fun lower_params(ctx: *LowerCtx, mb: *MirBlock) Result[bool, str] {
    # classify the whole function signature once: the same layout the caller's
    # `lower_call` derives, so a parameter is placed exactly where the call passed
    # it. an sret return reserves the first GP register (in the layout); the per-
    # parameter slots carry their real `[rbp + 16 + offset]` stack offsets.
    val ret_ty: ir_type.IrTypeId = fn_return_type(ctx);
    var layout: abi.SigLayout;
    val cls: Result[bool, str] = classify_signature(ctx, ctx.fn.sig, ret_ty, ?layout);
    if (is_err[bool, str](cls)) { ret cls; }

    # an sret return: the caller passes the hidden result-storage pointer in the
    # first GP argument register; capture it into a vreg so `lower_ret` copies the
    # returned aggregate into that storage and returns the pointer in RAX.
    if (layout.ret_slot.class == abi.CLASS_SRET) {
        var sret_reg: i32 = 0;
        val sr: Result[bool, str] = abi_gp_arg_reg(ctx.tgt, 0, ?sret_reg);
        if (is_err[bool, str](sr)) {
            sig_layout_free(ctx, ?layout);
            ret sr;
        }
        val svr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
        if (is_err[u32, str](svr)) {
            sig_layout_free(ctx, ?layout);
            ret err[bool, str](unwrap_err[u32, str](svr));
        }
        val sv: u32 = unwrap_ok[u32, str](svr);
        val mv: Result[bool, str] = emit_mov(ctx, mb, op_vreg(sv), op_preg(sret_reg::u32));
        if (is_err[bool, str](mv)) {
            sig_layout_free(ctx, ?layout);
            ret mv;
        }
        ctx.sret_vreg = sv;
    }

    # the signature's declared param count and the function's param count are the
    # same list (both lowered from the same semantic parameter types); iterate the
    # smaller as a hard bound so neither the layout slots nor the param vregs are
    # indexed out of range.
    var bound: u32 = ctx.param_count;
    if (layout.param_count < bound) { bound = layout.param_count; }
    var pi: u32 = 0;
    for (pi < bound) {
        val pv:   u32 = ctx.param_vregs[pi];
        val pty:  ir_type.IrTypeId = ctx.fn.params[pi].ty;
        val pag:  bool = value_is_aggregate(ctx, pty);
        val slot: abi.ParamSlot = layout.params[pi];

        val er: Result[bool, str] = emit_param_slot(ctx, mb, slot, pv, slot.size, slot.offset, pag);
        if (is_err[bool, str](er)) {
            sig_layout_free(ctx, ?layout);
            ret er;
        }
        pi = pi + 1;
    }

    sig_layout_free(ctx, ?layout);
    ret ok[bool, str](true);
}

# emit_param_slot: emit the entry pre-coloring move(s) for one classified
# incoming parameter. an aggregate parameter ends with `pv` holding a pointer to
# the aggregate's incoming bytes (aggregates flow by address): a register-passed
# aggregate (one or two GP halves) is spilled into a fresh SLOT_SPILL frame slot
# keyed on `pv` so the encoder resolves it to `[rbp + offset]` and `pv` names that
# storage; a BYREF aggregate takes the hidden pointer directly; a STACK aggregate
# is the caller's by-value copy at `[rbp + 16 + stack_off]`, whose address is LEA'd
# into `pv`. a scalar parameter moves its single register / stack word into the
# parameter value vreg `pv`. `stack_off` is the callee-tracked running offset (the
# ABI classifier returns a sizing-only slot — see `lower_params`).
fun emit_param_slot(ctx: *LowerCtx, mb: *MirBlock, slot: abi.ParamSlot, pv: u32, size: u64,
                    stack_off: i64, is_aggr: bool) Result[bool, str] {
    if (slot.class == abi.CLASS_STACK) {
        # incoming stack parameters are addressed off the ISA's frame pointer
        # (x86-64 RBP), named through `tgt.arch.frame_ptr_reg` rather than a literal.
        val fp: u32 = ctx.tgt.arch.frame_ptr_reg::u32;
        if (is_aggr) {
            # the aggregate's bytes already sit in the caller's by-value stack copy;
            # `pv` is its address so reads / the local copy index it directly.
            ret emit_lea_preg(ctx, mb, pv, fp, 16 + stack_off);
        }
        # a scalar stack argument lives above the return address and saved frame
        # pointer, addressed through the physical frame pointer at the running offset.
        ret emit_mov(ctx, mb, op_vreg(pv), op_mem_preg(fp, 16 + stack_off));
    }
    if (slot.class == abi.CLASS_BYREF) {
        ret emit_mov(ctx, mb, op_vreg(pv), op_preg(slot.reg::u32));
    }
    if (slot.reg2 >= 0) {
        # two-register aggregate: materialize a spill slot keyed on the parameter
        # vreg and store both halves into it. the slot base is the slot key, so the
        # encoder resolves it to `[rbp + offset]` and the param vreg names the
        # slot's storage for downstream uses.
        val sr: Result[bool, str] = add_spill_slot(ctx, pv, size);
        if (is_err[bool, str](sr)) { ret sr; }
        val lo: Result[bool, str] = emit_store_to(ctx, mb, op_mem_slot(pv, 0), op_preg(slot.reg::u32));
        if (is_err[bool, str](lo)) { ret lo; }
        ret emit_store_to(ctx, mb, op_mem_slot(pv, 8), op_preg(slot.reg2::u32));
    }
    if (is_aggr) {
        # ≤8 byte single-register aggregate: spill the register into a slot keyed on
        # the parameter vreg so `pv` is a storage pointer like the two-register form.
        val sr: Result[bool, str] = add_spill_slot(ctx, pv, size);
        if (is_err[bool, str](sr)) { ret sr; }
        ret emit_store_to(ctx, mb, op_mem_slot(pv, 0), op_preg(slot.reg::u32));
    }
    ret emit_mov(ctx, mb, op_vreg(pv), op_preg(slot.reg::u32));
}

# emit_lea_preg: append a `MIR_GEP (dst) <- [preg + disp]` (selected to LEA) that
# materializes a frame-relative address into a value vreg. used to point a STACK
# aggregate parameter vreg at the caller's by-value copy at `[rbp + 16 + off]`.
fun emit_lea_preg(ctx: *LowerCtx, mb: *MirBlock, dst: u32, base_preg: u32, disp: i64) Result[bool, str] {
    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = op_mem_preg(base_preg, disp);
    var mi: MirInstr;
    mi.opcode        = MIR_GEP;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the address materialization selects to a pointer-sized LEA.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# lower_ret: emit the return-value ABI pre-coloring before an OP_RET terminator.
# a value return moves the value into the canonical return register(s) (RAX /
# XMM0, RAX:RDX for a 9–16 byte aggregate, or RAX = the sret pointer when the
# return is >16 bytes), then the bare `MIR_RET`. a void return (no value
# operand) emits just `MIR_RET`. the placement is driven purely through the ABI
# vtable: an absent / unsupported ABI vtable is a loud error.
fun lower_ret(ctx: *LowerCtx, mb: *MirBlock, inst: *instr.Instruction) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret emit_bare_ret(ctx, mb);
    }
    val rv:   value.Value = inst.operands[0];
    # classify the return ABI from the function's declared return type, not the
    # value operand's IR type: an aggregate flows by address, so `rv.ty` is a
    # pointer (8 bytes) and would misclassify a >16-byte aggregate as a scalar
    # RAX return (returning a pointer to a dead local). the declared return type
    # carries the true size/shape. the same whole-signature oracle the caller and
    # `lower_params` use returns the slot, so the return placement is identical.
    val rt:   ir_type.IrTypeId = fn_return_type(ctx);
    val rsz:  u64  = ir_type.byte_size(ctx.types, rt, ctx.tgt)::u64;
    val rag:  bool = value_is_aggregate(ctx, rt);
    var layout: abi.SigLayout;
    val cls: Result[bool, str] = classify_signature(ctx, ctx.fn.sig, rt, ?layout);
    if (is_err[bool, str](cls)) { ret cls; }
    val slot: abi.ParamSlot = layout.ret_slot;
    sig_layout_free(ctx, ?layout);
    # a returned global / function symbol is its address; LEA-materialize it so
    # the scalar-register return carries the address, not the symbol's bytes. the
    # SRET / two-register branches re-`addr_to_vreg` the resulting vreg harmlessly.
    val rvr: Result[MirOperand, str] = lower_value_addr(ctx, mb, rv);
    if (is_err[MirOperand, str](rvr)) { ret err[bool, str](unwrap_err[MirOperand, str](rvr)); }
    val rvop: MirOperand = unwrap_ok[MirOperand, str](rvr);

    if (slot.class == abi.CLASS_SRET) {
        # copy the returned aggregate into the caller-owned result storage (the
        # hidden pointer captured from the first GP argument register in
        # `lower_params`), then return that pointer in RAX. without the copy the
        # callee would return the address of a dead local the caller never reads.
        if (ctx.sret_vreg == MIR_VREG_NIL) {
            ret err[bool, str]("mir.lower_ret: sret return without a captured result-storage pointer");
        }
        val cr: Result[bool, str] = copy_aggregate(ctx, mb, op_mem_value(ctx.sret_vreg, 0), rvop, rsz);
        if (is_err[bool, str](cr)) { ret cr; }
        val mr: Result[bool, str] = emit_mov(ctx, mb, op_preg(slot.reg::u32), op_vreg(ctx.sret_vreg));
        if (is_err[bool, str](mr)) { ret mr; }
    } or (slot.reg2 >= 0 && rag) {
        # 9–16 byte aggregate: load each half from the aggregate's storage (a
        # value-pointer base), materializing a global's symbol address first.
        var base: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, rvop, ?base);
        if (is_err[bool, str](ar)) { ret ar; }
        val lo: Result[bool, str] = emit_mov(ctx, mb, op_preg(slot.reg::u32), op_mem_value(base, 0));
        if (is_err[bool, str](lo)) { ret lo; }
        val hi: Result[bool, str] = emit_mov(ctx, mb, op_preg(slot.reg2::u32), op_mem_value(base, 8));
        if (is_err[bool, str](hi)) { ret hi; }
    } or (slot.reg >= 0 && rag) {
        # <=8 byte aggregate: the single eightbyte returns in one register, but the
        # value flows by address (rvop is a value-pointer base), so load the
        # eightbyte from the aggregate's storage rather than returning the pointer —
        # otherwise the callee returns the address of a dead local.
        var base: u32 = MIR_VREG_NIL;
        val ar: Result[bool, str] = addr_to_vreg(ctx, mb, rvop, ?base);
        if (is_err[bool, str](ar)) { ret ar; }
        val mr: Result[bool, str] = emit_mov(ctx, mb, op_preg(slot.reg::u32), op_mem_value(base, 0));
        if (is_err[bool, str](mr)) { ret mr; }
    } or (slot.reg >= 0) {
        val mr: Result[bool, str] = emit_mov(ctx, mb, op_preg(slot.reg::u32), rvop);
        if (is_err[bool, str](mr)) { ret mr; }
    }

    # the bare terminator carries no value operand once the result is pre-colored.
    ret emit_bare_ret(ctx, mb);
}

# emit_bare_ret: append a value-less MIR_RET terminator.
fun emit_bare_ret(ctx: *LowerCtx, mb: *MirBlock) Result[bool, str] {
    var mi: MirInstr;
    mi.opcode        = MIR_RET;
    mi.operands      = nil;
    mi.operand_count = 0;
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# fn_return_type: the lowered function's IR return type, read from its function
# type (IRT_FN). returns IRT_NIL when the signature is unavailable or void so
# the param classifier skips the sret reservation.
fun fn_return_type(ctx: *LowerCtx) ir_type.IrTypeId {
    val it: Option[*ir_type.IrType] = ir_type.get(ctx.types, ctx.fn.sig);
    if (!is_some[*ir_type.IrType](it)) { ret ir_type.IRT_NIL; }
    val t: *ir_type.IrType = unwrap[*ir_type.IrType](it);
    if (t.kind != ir_type.IRT_FN) { ret ir_type.IRT_NIL; }
    ret t.data.fn.ret_ty;
}

# add_spill_slot: append a SLOT_SPILL frame slot for a register-passed aggregate
# parameter, keyed on its vreg id so frame.run assigns it an offset and the encoder
# forms `[rbp + offset]` for the stored halves. the size is rounded up to the
# eight-byte register-store granularity (each incoming half is stored as a full GP
# register) so a sub-word aggregate's spill never overruns the slot.
fun add_spill_slot(ctx: *LowerCtx, value_id: u32, size: u64) Result[bool, str] {
    val f: *MirFunction = ctx.f;
    val frame: *MirFrame = ?f.frame;
    if (frame.slot_count >= frame.slot_cap) {
        var new_cap: u32 = frame.slot_cap * 2;
        if (new_cap < INITIAL_SLOT_CAP) { new_cap = INITIAL_SLOT_CAP; }
        val r: Result[*MirSlot, str] = reallocate[MirSlot](ctx.alloc, frame.slots, frame.slot_cap::usize, new_cap::usize);
        if (is_err[*MirSlot, str](r)) { ret err[bool, str](unwrap_err[*MirSlot, str](r)); }
        frame.slots    = unwrap_ok[*MirSlot, str](r);
        frame.slot_cap = new_cap;
    }
    var padded: u64 = (size + 7) & ~7::u64;
    if (padded == 0) { padded = 8; }
    val si: u32 = frame.slot_count;
    frame.slots[si].value  = value_id;
    frame.slots[si].kind   = SLOT_SPILL;
    frame.slots[si].offset = 0;
    frame.slots[si].size   = padded::u32;
    frame.slots[si].align  = 8;
    frame.slot_count = frame.slot_count + 1;
    ret ok[bool, str](true);
}

# add_spill_slot_aligned: like `add_spill_slot` but with an explicit alignment for
# the aggregate result-storage region (the natural alignment of the returned type),
# so a 16-byte-aligned aggregate result lands on its required boundary. the size is
# rounded up to the eight-byte register-store granularity so a 9–16 byte RAX:RDX or
# ≤8 byte single-register return writing full GP registers never overruns the slot.
fun add_spill_slot_aligned(ctx: *LowerCtx, value_id: u32, size: u64, align: u32) Result[bool, str] {
    val f: *MirFunction = ctx.f;
    val frame: *MirFrame = ?f.frame;
    if (frame.slot_count >= frame.slot_cap) {
        var new_cap: u32 = frame.slot_cap * 2;
        if (new_cap < INITIAL_SLOT_CAP) { new_cap = INITIAL_SLOT_CAP; }
        val r: Result[*MirSlot, str] = reallocate[MirSlot](ctx.alloc, frame.slots, frame.slot_cap::usize, new_cap::usize);
        if (is_err[*MirSlot, str](r)) { ret err[bool, str](unwrap_err[*MirSlot, str](r)); }
        frame.slots    = unwrap_ok[*MirSlot, str](r);
        frame.slot_cap = new_cap;
    }
    var al: u32 = align;
    if (al == 0) { al = 1; }
    var sz: u32 = ((size + 7) & ~7::u64)::u32;
    if (sz == 0) { sz = al; }
    val si: u32 = frame.slot_count;
    frame.slots[si].value  = value_id;
    frame.slots[si].kind   = SLOT_SPILL;
    frame.slots[si].offset = 0;
    frame.slots[si].size   = sz;
    frame.slots[si].align  = al;
    frame.slot_count = frame.slot_count + 1;
    ret ok[bool, str](true);
}

# alloc_result_storage: back an aggregate call's result vreg with a caller-owned
# stack region and leave its address in the result vreg. an internal slot-key vreg
# owns the SLOT_SPILL region (sized / aligned for the returned aggregate); the
# emitted `MIR_ALLOCA (dst) <- [slot]` selects to `LEA dst, [rbp + offset]`, so the
# result vreg is the address the return-register stores / SRET hidden pointer use
# and downstream aggregate consumers read by. mirrors `lower_alloca`.
fun alloc_result_storage(ctx: *LowerCtx, mb: *MirBlock, dst: u32, size: u64, align: u32) Result[bool, str] {
    val skr: Result[u32, str] = new_vreg(ctx, REG_CLASS_GP);
    if (is_err[u32, str](skr)) { ret err[bool, str](unwrap_err[u32, str](skr)); }
    val sk: u32 = unwrap_ok[u32, str](skr);

    val ar: Result[bool, str] = add_spill_slot_aligned(ctx, sk, size, align);
    if (is_err[bool, str](ar)) { ret ar; }

    val r: Result[*MirOperand, str] = allocate[MirOperand](ctx.alloc, 2::usize);
    if (is_err[*MirOperand, str](r)) { ret err[bool, str](unwrap_err[*MirOperand, str](r)); }
    val ops: *MirOperand = unwrap_ok[*MirOperand, str](r);
    ops[0] = op_vreg(dst);
    ops[1] = op_mem_slot(sk, 0);
    var mi: MirInstr;
    mi.opcode        = MIR_ALLOCA;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the address materialization selects to a pointer-sized LEA.
    mi.width         = WORD_WIDTH;
    mi.src_width     = WORD_WIDTH;
    ret push_instr(ctx, mb, mi);
}

# ret_align: the natural alignment of an aggregate return type, used to align its
# caller-owned result storage. defaults to the machine word when the type is
# unavailable so a slot is never sub-word aligned.
fun ret_align(ctx: *LowerCtx, ty: ir_type.IrTypeId) u32 {
    val a: u32 = ir_type.byte_align(ctx.types, ty, ctx.tgt);
    if (a == 0) { ret WORD_WIDTH::u32; }
    ret a;
}

# lowers an SSA Value reference to a MIR operand: instruction/parameter results
# become MIR_OP_VREG; integer / null constants become MIR_OP_IMM; float
# constants pass their bit pattern as an immediate; global and function symbols
# become MIR_OP_SYM carrying the interned name resolved from the IR module
# (`Module.globals[ix].name` / `Module.functions[ix].name`) — the symbol name is
# the only carrier of the callee / global relocation target into isel and
# encode. byte-blob constants are not expected here (lowering interns them as
# globals) and fall back to a zero immediate.
fun lower_value(ctx: *LowerCtx, v: value.Value) MirOperand {
    if (v.kind == value.VAL_INSTR) {
        ret op_vreg(instr_vreg(ctx, v.data.instr));
    }
    if (v.kind == value.VAL_PARAM) {
        ret op_vreg(param_vreg(ctx, v.data.param_ix));
    }
    if (v.kind == value.VAL_CONST_INT) {
        ret op_imm(v.data.int_lit::i64);
    }
    if (v.kind == value.VAL_CONST_NULL) {
        ret op_imm(0);
    }
    if (v.kind == value.VAL_CONST_FLOAT) {
        ret op_imm(v.data.int_lit::i64);
    }
    if (v.kind == value.VAL_GLOBAL) {
        if (v.data.global_ix < ctx.m.global_len) {
            ret op_sym(ctx.m.globals[v.data.global_ix].name, 0);
        }
        # an in-range global index is an IR invariant; an out-of-range one is a
        # lowering bug — fail loudly rather than emit a STR_NIL symbol the encoder
        # would turn into a relocation against no name.
        panic("mir.lower_ir: global value index out of range\n");
        ret op_imm(0);
    }
    if (v.kind == value.VAL_FN) {
        if (v.data.fn_ix < ctx.m.function_len) {
            ret op_sym(ctx.m.functions[v.data.fn_ix].name, 0);
        }
        panic("mir.lower_ir: function value index out of range\n");
        ret op_imm(0);
    }
    # every IR value kind reaching the back end is handled above; a value kind
    # arriving here (e.g. an un-interned byte blob) is a lowering bug, not a
    # silently-zeroed immediate.
    panic("mir.lower_ir: unexpected IR value kind in lower_value\n");
    ret op_imm(0);
}

# returns the result vreg assigned to an instruction id, or MIR_VREG_NIL when
# the instruction defines no value.
fun result_vreg(ctx: *LowerCtx, iid: id.InstructionId) u32 {
    ret instr_vreg(ctx, iid);
}

# returns the vreg mapped to an instruction id (MIR_VREG_NIL when out of range
# or void-defining).
fun instr_vreg(ctx: *LowerCtx, iid: id.InstructionId) u32 {
    if (iid == id.INSTR_NIL)         { ret MIR_VREG_NIL; }
    if (ctx.instr_vregs == nil)      { ret MIR_VREG_NIL; }
    if (iid::u32 >= ctx.instr_count) { ret MIR_VREG_NIL; }
    ret ctx.instr_vregs[iid::u32];
}

# returns the slot-key vreg owning the frame slot of the alloca at instruction
# `iid` (MIR_VREG_NIL when the id is out of range or names a non-alloca).
fun slot_key_vreg(ctx: *LowerCtx, iid: id.InstructionId) u32 {
    if (iid == id.INSTR_NIL)         { ret MIR_VREG_NIL; }
    if (ctx.slot_key_vregs == nil)   { ret MIR_VREG_NIL; }
    if (iid::u32 >= ctx.instr_count) { ret MIR_VREG_NIL; }
    ret ctx.slot_key_vregs[iid::u32];
}

# returns the vreg mapped to a parameter ordinal (MIR_VREG_NIL when out of range).
fun param_vreg(ctx: *LowerCtx, ix: u32) u32 {
    if (ctx.param_vregs == nil) { ret MIR_VREG_NIL; }
    if (ix >= ctx.param_count)  { ret MIR_VREG_NIL; }
    ret ctx.param_vregs[ix];
}

# appends a MIR instruction to a block, growing its instruction list on demand.
fun push_instr(ctx: *LowerCtx, mb: *MirBlock, mi: MirInstr) Result[bool, str] {
    val gr: Result[bool, str] = grow_instr(ctx, mb);
    if (is_err[bool, str](gr)) { ret gr; }
    mb.instrs[mb.instr_count] = mi;
    mb.instr_count = mb.instr_count + 1;
    ret ok[bool, str](true);
}

# appends a lowered function to the MIR module, growing the function array.
fun push_function(mm: *MirModule, mf: MirFunction) Result[bool, str] {
    if (mm.function_len >= mm.function_cap) {
        val new_cap: u32 = mm.function_cap * 2;
        val r: Result[*MirFunction, str] = reallocate[MirFunction](mm.alloc, mm.functions, mm.function_cap::usize, new_cap::usize);
        if (is_err[*MirFunction, str](r)) { ret err[bool, str](unwrap_err[*MirFunction, str](r)); }
        mm.functions    = unwrap_ok[*MirFunction, str](r);
        mm.function_cap = new_cap;
    }
    mm.functions[mm.function_len] = mf;
    mm.function_len = mm.function_len + 1;
    ret ok[bool, str](true);
}

# dnit_module: release every owned array in a MIR module, safe on a partially built module and on nil.
# ---
# mm: the module to tear down; all owned storage is freed and fields zeroed
pub fun dnit_module(mm: *MirModule) {
    if (mm == nil) { ret; }
    var fi: u32 = 0;
    for (fi < mm.function_len) {
        dnit_function(mm.alloc, ?mm.functions[fi]);
        fi = fi + 1;
    }
    if (mm.functions != nil && mm.function_cap > 0) {
        deallocate[MirFunction](mm.alloc, mm.functions, mm.function_cap::usize);
    }
    mm.functions    = nil;
    mm.function_len = 0;
    mm.function_cap = 0;
}

# releases one MIR function's owned storage: its blocks (and their nested
# instruction/operand/pred storage), the vreg table, and the frame slots.
fun dnit_function(alloc: *Allocator, mf: *MirFunction) {
    var bi: u32 = 0;
    for (bi < mf.block_count) {
        dnit_block(alloc, ?mf.blocks[bi]);
        bi = bi + 1;
    }
    if (mf.blocks != nil && mf.block_cap > 0) {
        deallocate[MirBlock](alloc, mf.blocks, mf.block_cap::usize);
    }
    if (mf.vregs != nil && mf.vreg_cap > 0) {
        deallocate[MirVReg](alloc, mf.vregs, mf.vreg_cap::usize);
    }
    if (mf.frame.slots != nil && mf.frame.slot_cap > 0) {
        deallocate[MirSlot](alloc, mf.frame.slots, mf.frame.slot_cap::usize);
    }
    mf.blocks      = nil;
    mf.block_count = 0;
    mf.block_cap   = 0;
    mf.vregs       = nil;
    mf.vreg_count  = 0;
    mf.vreg_cap    = 0;
}

# releases one MIR block's owned storage: every instruction's operand array,
# the block's instruction list, and its predecessor list.
fun dnit_block(alloc: *Allocator, mb: *MirBlock) {
    var ii: u32 = 0;
    for (ii < mb.instr_count) {
        val mi: *MirInstr = ?mb.instrs[ii];
        if (mi.operands != nil && mi.operand_count > 0) {
            deallocate[MirOperand](alloc, mi.operands, mi.operand_count::usize);
        }
        if (mi.opcode == MIR_ASM && mi.asm_block != nil) {
            if (mi.asm_block.binds != nil && mi.asm_block.bind_count > 0) {
                deallocate[MirAsmBind](alloc, mi.asm_block.binds, mi.asm_block.bind_count::usize);
            }
            deallocate[MirAsm](alloc, mi.asm_block, 1::usize);
        }
        ii = ii + 1;
    }
    if (mb.instrs != nil && mb.instr_cap > 0) {
        deallocate[MirInstr](alloc, mb.instrs, mb.instr_cap::usize);
    }
    if (mb.preds != nil && mb.pred_cap > 0) {
        deallocate[u32](alloc, mb.preds, mb.pred_cap::usize);
    }
}
