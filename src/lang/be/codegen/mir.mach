# the MIR data model shared across the back end
#
# Machine IR (MIR) sits between the target-independent SSA IR
# (`mach.lang.me.ir`) and encoded machine bytes. A MIR instruction carries a
# generic, target-shaped opcode and operates on virtual registers; later
# codegen passes (isel, regalloc, frame, encode) rewrite generic opcodes into
# concrete per-arch forms and resolve virtual registers into physical
# registers and stack slots.
#
# This module is the data model: the operand / instruction / block / vreg /
# slot / frame records, the generic and pseudo opcode space, the `op_*`
# operand constructors, and the module life-cycle (`push_function`,
# `dnit_module`). The IR-to-MIR translation that populates these records lives
# in `mir.lower` (with the ABI and variadic lowering in `mir.abi` / `mir.va`
# and the shared lowering context in `mir.context`).
#
# Generic MIR opcodes mirror the IR `OP_*` values one-for-one (so an IR add
# becomes a generic MIR add with the same number) and add a small block of
# pseudo-opcodes for the lowering-only constructs. Instruction selection
# (`isel`) replaces these generic opcodes with the concrete encoder opcodes
# owned by the active ISA.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use R: std.types.result;

use mach.lang.intern;
use source: mach.lang.source;

# discriminant selecting which fields of a MirOperand are live
pub def MirOperandKind: u8;

# a virtual register reference; `vreg` indexes `MirFunction.vregs`, resolved by regalloc
pub val MIR_OP_VREG:  MirOperandKind = 0;
# a physical register reference; `preg` is a register id within its RegClass
pub val MIR_OP_PREG:  MirOperandKind = 1;
# an immediate integer constant carried in `imm`
pub val MIR_OP_IMM:   MirOperandKind = 2;
# a memory reference `[base + index*scale + imm]`. the base is disambiguated by
# `vreg`: when `vreg != MIR_VREG_NIL` it is a frame-slot key (a slot-owning vreg
# id the encoder resolves to `[rbp + slot.offset + imm]`); when
# `vreg == MIR_VREG_NIL` it is a physical register base in `preg` (the encoder
# forms `[preg + imm]`). a pre-regalloc value-pointer base rides as a value vreg
# in `vreg` and regalloc rewrites it to the physical-register form.
#
# the optional scaled index is the GEP address-folding component: `index` names a
# value vreg (pre-regalloc) or physical register id (`index_is_preg` set, after
# regalloc) holding a runtime index, scaled by `scale` (one of 1/2/4/8 - x86 SIB).
# when `index == MIR_VREG_NIL` there is no index and the form is the plain
# `[base + imm]`. regalloc treats the index like the base: a value vreg is
# rewritten to its physical register (setting `index_is_preg`) and reloaded if
# spilled. an index may ride any base - a physical register, a value-pointer
# base, or a frame-slot-key base (a GEP into an alloca with a runtime index folds
# the scaled index alongside the slot offset, and the encoder forms
# `[rbp + slot.offset + index*scale + imm]` via SIB).
pub val MIR_OP_MEM:   MirOperandKind = 3;
# a symbol reference for a relocation; interned name in `sym`, addend `sym_off`
pub val MIR_OP_SYM:   MirOperandKind = 4;
# a branch-target block reference; target `MirBlock.id` carried in `imm`
pub val MIR_OP_BLOCK: MirOperandKind = 5;

# the generic MIR opcode emitted by `lower_ir` before isel, mirroring IR `OP_*` numbering one-for-one
pub def MirOpcode: u32;

pub val MIR_ADD:         MirOpcode = 0;    # integer / pointer addition
pub val MIR_SUB:         MirOpcode = 1;    # integer / pointer subtraction
pub val MIR_MUL:         MirOpcode = 2;    # integer multiplication
pub val MIR_DIV_S:       MirOpcode = 3;    # signed integer division
pub val MIR_DIV_U:       MirOpcode = 4;    # unsigned integer division
pub val MIR_REM_S:       MirOpcode = 5;    # signed integer remainder
pub val MIR_REM_U:       MirOpcode = 6;    # unsigned integer remainder
pub val MIR_NEG:         MirOpcode = 7;    # integer negation
pub val MIR_AND:         MirOpcode = 8;    # bitwise and
pub val MIR_OR:          MirOpcode = 9;    # bitwise or
pub val MIR_XOR:         MirOpcode = 10;   # bitwise exclusive or
pub val MIR_SHL:         MirOpcode = 11;   # left shift
pub val MIR_SHR_S:       MirOpcode = 12;   # arithmetic (sign-filling) right shift
pub val MIR_SHR_U:       MirOpcode = 13;   # logical (zero-filling) right shift
pub val MIR_NOT:         MirOpcode = 14;   # bitwise complement
pub val MIR_CMP_EQ:      MirOpcode = 15;   # equality comparison
pub val MIR_CMP_NE:      MirOpcode = 16;   # inequality comparison
pub val MIR_CMP_LT_S:    MirOpcode = 17;   # signed less-than comparison
pub val MIR_CMP_LT_U:    MirOpcode = 18;   # unsigned less-than comparison
pub val MIR_CMP_LE_S:    MirOpcode = 19;   # signed less-or-equal comparison
pub val MIR_CMP_LE_U:    MirOpcode = 20;   # unsigned less-or-equal comparison
pub val MIR_TRUNC:       MirOpcode = 21;   # integer truncation to a narrower width
pub val MIR_SEXT:        MirOpcode = 22;   # sign-extension to a wider width
pub val MIR_ZEXT:        MirOpcode = 23;   # zero-extension to a wider width
pub val MIR_FP_TRUNC:    MirOpcode = 24;   # float truncation to a narrower precision
pub val MIR_FP_EXT:      MirOpcode = 25;   # float extension to a wider precision
pub val MIR_FP_TO_SI:    MirOpcode = 26;   # float-to-signed-integer conversion
pub val MIR_FP_TO_UI:    MirOpcode = 27;   # float-to-unsigned-integer conversion
pub val MIR_SI_TO_FP:    MirOpcode = 28;   # signed-integer-to-float conversion
pub val MIR_UI_TO_FP:    MirOpcode = 29;   # unsigned-integer-to-float conversion
pub val MIR_BITCAST:     MirOpcode = 30;   # reinterpret a value's bits as a same-width type
pub val MIR_ALLOCA:      MirOpcode = 31;   # reserve a stack slot and yield its address
pub val MIR_LOAD:        MirOpcode = 32;   # load a value from a memory operand
pub val MIR_STORE:       MirOpcode = 33;   # store a value to a memory operand
pub val MIR_GEP:         MirOpcode = 34;   # compute an element / field address (selects to LEA)
pub val MIR_EXTRACT:     MirOpcode = 35;   # extract a field value from an aggregate
pub val MIR_INSERT:      MirOpcode = 36;   # insert a field value into an aggregate
# an SSA phi; never emitted - `lower_phis` eliminates phis into predecessor-end
# MIR_MOVs, and the encoder rejects any stray MIR_PHI loudly.
pub val MIR_PHI:         MirOpcode = 37;
# the IR OP_CALL placeholder; never emitted directly - `lower_ir` expands calls
# into the argument pre-coloring, MIR_CALL, and MIR_CALL_RES.
pub val MIR_CALL_IR:     MirOpcode = 38;
pub val MIR_BR:          MirOpcode = 39;   # an unconditional branch to a target block
pub val MIR_CBR:         MirOpcode = 40;   # a conditional branch to one of two target blocks
pub val MIR_RET:         MirOpcode = 41;   # return from the function
pub val MIR_UNREACHABLE: MirOpcode = 42;   # an unreachable terminator
pub val MIR_ASM:         MirOpcode = 43;   # an inline-assembly block

# a register-to-register move pseudo; operands [dst, src].
#
# `lower_ir` emits MIR_MOV both for ordinary vreg copies and for ABI
# pre-coloring: the dst or src is a MIR_OP_PREG naming a physical argument /
# return / hidden-pointer register, and the other operand is the vreg (or an
# immediate, e.g. the fp-arg-count move into AL before a varargs call). isel
# rewrites MIR_MOV to the concrete machine move; regalloc treats a MIR_OP_PREG
# operand as a fixed pre-color it must honor.
pub val MIR_MOV:      MirOpcode = 0x1000;
# a vestigial outgoing-argument marker.
#
# `lower_ir` performs SysV classification inline and emits the argument-register
# MIR_MOV pre-coloring (or stack store) directly, so no MIR_ARG instructions are
# produced anymore; the opcode is retained only so isel's pass-through arm stays
# total.
pub val MIR_ARG:      MirOpcode = 0x1001;
# a call pseudo; operand 0 is the SYM-or-VREG callee. side effects only - the
# result is bound by the MIR_CALL_RES move and arguments arrive via the
# argument-register MIR_MOV pre-coloring `lower_ir` emits before it.
#
# CLOBBER CONVENTION (regalloc + encode must agree): a MIR_CALL implicitly
# clobbers EVERY caller-saved register of the active ABI - both the GP and FP
# files. There is no per-instruction clobber operand; the opcode itself IS the
# clobber barrier. regalloc derives the caller-saved set as "every allocatable
# physical register in a class that is NOT in `tgt.abi`'s callee_saved set" and,
# at each MIR_CALL, must spill/save any vreg whose assigned register is
# caller-saved (or FP) and reload it after, and must never satisfy a reload temp
# from a caller-saved register across the call. The fixed argument / return
# pre-coloring registers (RDI, RSI, RDX, RCX, R8, R9, RAX, XMM0..7, AL) are part
# of that caller-saved set, so the pre-coloring MIR_MOVs that bracket the call
# are consistent with this barrier. encode emits no extra bytes for the barrier;
# it relies on regalloc having already inserted the saves/reloads.
pub val MIR_CALL:     MirOpcode = 0x1002;
# a call-result-binding pseudo; operand 0 is the dst vreg. for a value-returning
# call `lower_ir` emits the return-register MIR_MOV (`dst <- RAX|XMM0`, or the
# RAX:RDX / sret pair) immediately after MIR_CALL and leaves this pseudo only as
# a liveness marker for the result vreg.
pub val MIR_CALL_RES: MirOpcode = 0x1003;

# selection-output sentinels for the generic opcodes that survive instruction
# selection because they need a multi-instruction byte sequence the encoder
# materializes. isel rewrites each surviving generic opcode to a high sentinel
# (0x1100+) so it cannot collide with a concrete encoder opcode in the shared
# 0..74 value space.
pub val MIR_SEL_ADD:      MirOpcode = 0x1100;  # add with no single-instruction form
pub val MIR_SEL_SUB:      MirOpcode = 0x1101;  # two-address subtract
pub val MIR_SEL_MUL:      MirOpcode = 0x1102;  # two-address multiply
pub val MIR_SEL_AND:      MirOpcode = 0x1103;  # two-address bitwise and
pub val MIR_SEL_OR:       MirOpcode = 0x1104;  # two-address bitwise or
pub val MIR_SEL_XOR:      MirOpcode = 0x1105;  # two-address bitwise xor
pub val MIR_SEL_SHL:      MirOpcode = 0x1106;  # two-address left shift
pub val MIR_SEL_SHR_U:    MirOpcode = 0x1107;  # two-address logical right shift
pub val MIR_SEL_SHR_S:    MirOpcode = 0x1108;  # two-address arithmetic right shift
pub val MIR_SEL_DIV_S:    MirOpcode = 0x1109;  # signed divide (high-half setup + IDIV)
pub val MIR_SEL_DIV_U:    MirOpcode = 0x110A;  # unsigned divide (high-half setup + DIV)
pub val MIR_SEL_REM_S:    MirOpcode = 0x110B;  # signed remainder
pub val MIR_SEL_REM_U:    MirOpcode = 0x110C;  # unsigned remainder
pub val MIR_SEL_CMP_EQ:   MirOpcode = 0x110D;  # equality compare (CMP;SETcc;MOVZX)
pub val MIR_SEL_CMP_NE:   MirOpcode = 0x110E;  # inequality compare
pub val MIR_SEL_CMP_LT_S: MirOpcode = 0x110F;  # signed less-than compare
pub val MIR_SEL_CMP_LT_U: MirOpcode = 0x1110;  # unsigned less-than compare
pub val MIR_SEL_CMP_LE_S: MirOpcode = 0x1111;  # signed less-or-equal compare
pub val MIR_SEL_CMP_LE_U: MirOpcode = 0x1112;  # unsigned less-or-equal compare
pub val MIR_SEL_CBR:      MirOpcode = 0x1113;  # conditional branch (TEST;JNE;JMP)

# the scalar floating-point arithmetic / comparison ops. the shared IR integer
# opcodes (OP_ADD / OP_SUB / OP_MUL / OP_DIV_* / OP_CMP_*) cover both int and
# float operands; `lower_ir` dispatches on operand/result float type and emits one
# of these dedicated opcodes for a float instead of the integer ALU form, which
# would mis-encode an XMM-classed value. like the compare / divide families they
# survive instruction selection unchanged and the encoder materializes the SSE
# byte sequence (operands loaded `[rbp+off]`/reg -> XMM scratch, the SSE op, the
# result stored back). the operation width (4 for f32, 8 for f64) rides on
# `mi.width` so the encoder selects the SS vs SD form. they occupy the high
# selection-output space so the encoder never confuses one with a concrete x86-64
# opcode of the same low value.
pub val MIR_FADD: MirOpcode = 0x1114;  # scalar float addition (ADDSS / ADDSD)
pub val MIR_FSUB: MirOpcode = 0x1115;  # scalar float subtraction (SUBSS / SUBSD)
pub val MIR_FMUL: MirOpcode = 0x1116;  # scalar float multiplication (MULSS / MULSD)
pub val MIR_FDIV: MirOpcode = 0x1117;  # scalar float division (DIVSS / DIVSD)
# scalar float comparison (UCOMISS / UCOMISD + unsigned SETcc + MOVZX). the
# condition code (one of FCC_*) rides on the instruction's `src_width` carrier
# set by lowering.
pub val MIR_FCMP: MirOpcode = 0x1118;

# a scalar float register copy is a plain MIR_MOV: with disjoint GP / XMM register
# id spaces (a physical register id carries its class) the encoder dispatches the
# move family on operand register CLASS - an XMM-bank operand selects MOVSS / MOVSD,
# a GP<->XMM pair MOVD / MOVQ - so a float copy needs no dedicated opcode and can
# never mis-select to a move of the GP register that aliases an XMM index. the float
# width (4 / 8) rides on the move so the encoder picks the single- vs double-
# precision form.

# scalar float negation, operands [dst, src]. a float negate flips the IEEE-754
# sign bit, which an integer MIR_NEG (two's-complement of the whole bit pattern)
# would not produce; this dedicated opcode survives selection and the encoder
# materializes the sign-bit XOR on the XMM value (XORPS with a sign mask). the
# width (4 for f32, 8 for f64) selects the f32 vs f64 sign-bit mask.
pub val MIR_FNEG: MirOpcode = 0x111B;

# a source-variable debug marker (`-g` only), position-preserving so the encoder can
# record which PC a dbg-value binding becomes live at for `.debug_loclists` (#1705).
# Operands are both MIR_OP_IMM - operand[0] holds the bound value's vreg id (or
# MIR_VREG_NIL for a constant / optimized-out binding), operand[1] holds the source
# OP_DBG_VALUE instruction id - so the marker carries NO vreg operand and is inert to
# regalloc liveness (no use extends, no def), keeping codegen byte-identical. The
# encoder emits zero bytes for it (like MIR_CALL_RES) and reads the imms to record a
# VarLoc at the current text offset.
pub val MIR_DBG_VALUE: MirOpcode = 0x111C;

# a bit reinterpret (`:~`) is a plain MIR_BITCAST in every direction. a same-bank
# reinterpret (GP<->GP or XMM<->XMM) is a register copy; a `:~` between a float and
# an equal-size integer crosses the GP and XMM banks. both select to a plain MOV:
# the encoder dispatches the move family on operand register CLASS - a same-bank XMM
# pair emits MOVSS / MOVSD, a register-register GP<->XMM pair emits MOVD / MOVQ, and
# a spilled side is moved through memory at byte width - so no dedicated cross opcode
# is needed and the bank can never be lost across register allocation.

# float-comparison condition codes carried on a MIR_FCMP. a UCOMISD sets CF/ZF/PF
# (an UNORDERED result sets all three), so the float compare maps to UNSIGNED
# SETcc - distinct from the integer compare family's signed conditions.
pub val FCC_EQ: u8 = 0;  # equal (SETE)
pub val FCC_NE: u8 = 1;  # not equal (SETNE)
pub val FCC_LT: u8 = 2;  # less than (SETB - CF set when below)
pub val FCC_LE: u8 = 3;  # less or equal (SETBE)
pub val FCC_GT: u8 = 4;  # greater than (SETA)
pub val FCC_GE: u8 = 5;  # greater or equal (SETAE)

# sentinel "no virtual register"; never a valid vreg id, never a default
pub val MIR_VREG_NIL: u32 = 0xFFFFFFFF;

# canonical general-purpose register-class index used by `lower_ir`. by
# convention the general-purpose bank is the first declared class; the lowering
# locates the general and float banks by their RC_GENERAL / RC_FLOAT kind, so no
# arch-specific class name is hardcoded.
pub val REG_CLASS_GP: u32 = 0;

# the minimum byte width an integer ALU / shift result is computed at. a register
# that holds a value narrower than this is still saved and reloaded at the full
# machine-word width, so a sub-word ALU op (which leaves the upper register bits
# undefined) would persist garbage into the spill slot and corrupt any later
# full-width use (an index in a LEA address, a word-width move). running the op at
# >= 4 bytes keeps the live portion of the register defined up through the width an
# ISA's narrow-write clears (the 32-bit GP write that zero-extends to 64 on
# x86-64), so the spilled word is clean. logical sub-word truncation is unaffected:
# every consumer that needs the narrow value re-narrows it.
pub val ALU_MIN_WIDTH: u8 = 4;

# a single MIR operand whose live fields depend on `kind`
# ---
# kind:          operand discriminant (one of MIR_OP_*)
# vreg:          virtual register id for VREG, or a MEM frame-slot-key base; for a
#                MEM physical-register base it is MIR_VREG_NIL (the base lives in
#                `preg`)
# preg:          physical register id for PREG, or a MEM physical-register base
#                (when the MEM operand's `vreg` is MIR_VREG_NIL); else 0
# imm:           immediate / displacement / block id, per kind
# sym:           interned symbol name for SYM (else intern.STR_NIL)
# sym_off:       addend applied to the symbol for SYM
# index:         MEM scaled-index register: a value vreg (pre-regalloc) or physical
#                register id (`index_is_preg` set). MIR_VREG_NIL when no index.
# scale:         MEM index scale (1, 2, 4, or 8); 0 when no index
# index_is_preg: true when `index` is a physical register id (set by regalloc);
#                false when it is a value vreg awaiting allocation
pub rec MirOperand {
    kind:          MirOperandKind;
    vreg:          u32;
    preg:          u32;
    imm:           i64;
    sym:           intern.StrId;
    sym_off:       i32;
    index:         u32;
    scale:         u8;
    index_is_preg: bool;
}

# one resolved `{name}` binding for an inline-asm block
#
# Pairs the source name with the slot-owning vreg the alloca's result mapped to.
# The encoder resolves the vreg to a frame offset and substitutes `[rbp+off]` for
# `{name}` when it expands the body.
# ---
# name:      interned source local name (the text inside `{ }`)
# slot_vreg: slot-owning vreg id of the local's alloca storage
pub rec MirAsmBind {
    name:      intern.StrId;
    slot_vreg: u32;
}

# the inline-asm payload carried by a MIR_ASM instruction
#
# The body text is resolved from the interner at lower time; the `{name}`
# bindings carry the slot-owning vreg ids the encoder turns into `[rbp+off]` once
# the frame is laid out. Owned by the MIR_ASM instruction and freed in
# `dnit_block`.
# ---
# isa:        the target ISA tag the body was written for (e.g. "x86_64")
# body:       raw inline-asm body text (borrowed from the interner; stable)
# binds:      `{name}` -> slot-vreg bindings referenced by the body (owned)
# bind_count: number of bindings
pub rec MirAsm {
    isa:        str;
    body:       str;
    binds:      *MirAsmBind;
    bind_count: u32;
}

# one MIR instruction - a generic-or-concrete opcode plus a flat operand list (dst at operand 0)
# ---
# opcode:        generic MIR opcode (pre-isel) or concrete encoder opcode (post-isel)
# operands:      pointer to a contiguous array of operands (owned)
# operand_count: number of operands
# width:         operation width in bytes (1, 2, 4, or 8) of the destination /
#                result the instruction drives - the byte width the encoder uses
#                to size MOV / ALU / CMP / LOAD / STORE / conversion ops (REX.W
#                only for 8, the 0x66 prefix only for 2). populated in `lower_ir`
#                from the IR result type (or, for void-result ops like store and
#                compare, the operated-on operand type). 0 means "unset", which
#                the encoder treats as the machine-word width so a pseudo with no
#                natural width (call / ret / branch / asm) still encodes its
#                address-sized fields correctly.
# src_width:     source operand width in bytes for the width-changing conversions
#                (TRUNC / SEXT / ZEXT and the integer-side CVT forms), where the
#                source is narrower or wider than the destination. for every other
#                opcode it equals `width`. the encoder sizes source operands by
#                this field so MOVZX / MOVSX select the byte-vs-word source form.
#                EXCEPTION: a MIR_FCMP carries its float-comparison condition code
#                (one of FCC_*) here, since a float comparison has no narrower /
#                wider source form - both operands ride at `width` (4 for f32, 8
#                for f64) and the single MIR_FCMP opcode selects the UNSIGNED SETcc
#                from this condition, mirroring how the integer compare family
#                encodes its condition in the opcode itself.
# asm_block:     inline-asm payload for a MIR_ASM instruction (owned), else nil.
#                carries the raw body text plus `{name}` -> slot-vreg bindings the
#                encoder expands into machine instructions.
# loc:           source location (file + byte offset) this instruction lowered from,
#                forwarded from the IR instruction; source.loc_nil() for a
#                compiler-synthesized instruction with no source origin. the encoder
#                retains it as a PC<->source row for debug line tables; it never
#                affects the emitted bytes.
pub rec MirInstr {
    opcode:        MirOpcode;
    operands:      *MirOperand;
    operand_count: u32;
    width:         u8;
    src_width:     u8;
    asm_block:     *MirAsm;
    loc:           source.SrcLoc;
}

# a MIR basic block - an ordered instruction list plus predecessor ids, sharing the source IR `Block.id`
# ---
# id:          block id, identical to the source IR block id
# instrs:      ordered MIR instructions (owned)
# instr_count: number of instructions
# instr_cap:   allocated capacity for instrs
# preds:       predecessor block ids (owned)
# pred_count:  number of predecessors
# pred_cap:    allocated capacity for preds
pub rec MirBlock {
    id:          u32;

    instrs:      *MirInstr;
    instr_count: u32;
    instr_cap:   u32;

    preds:       *u32;
    pred_count:  u32;
    pred_cap:    u32;
}

# a virtual register and its register-allocation state
# ---
# id:         the vreg's own index into MirFunction.vregs
# class:      index into target.arch.reg_classes selecting the register bank
# spill_slot: stack-frame slot index when spilled (-1 while unspilled)
# assigned:   physical register id assigned by regalloc (MIR_VREG_NIL until then)
pub rec MirVReg {
    id:         u32;
    class:      u32;
    spill_slot: i32;
    assigned:   u32;
}

# discriminant distinguishing an addressed alloca slot from a by-value spill slot
pub def MirSlotKind: u8;

# a slot whose address is the alloca pointer; the slot is the pointed-to storage
pub val SLOT_ALLOCA: MirSlotKind = 0;
# a slot holding a by-value copy of a small-aggregate param, aggregate load, or aggregate return
pub val SLOT_SPILL:  MirSlotKind = 1;

# one stack-frame slot - a sized, aligned region for an alloca or a small-aggregate spill
# ---
# value:  MIR value id that owns this slot; keys frame.run's offset lookup
# kind:   SLOT_ALLOCA (addressed) or SLOT_SPILL (by-value copy)
# offset: negative byte offset from the frame pointer (assigned by frame.run)
# size:   slot size in bytes
# align:  slot alignment in bytes
pub rec MirSlot {
    value:  u32;
    kind:   MirSlotKind;
    offset: i64;
    size:   u32;
    align:  u32;
}

# a function's stack layout, populated by frame.run after register allocation
# ---
# slots:         stack slots (owned)
# slot_count:    number of slots
# slot_cap:      allocated capacity for slots
# size:          total frame size in bytes
# align:         frame alignment in bytes
# outgoing_size: bytes reserved at the bottom of the frame for stack-passed
#                outgoing call arguments - the maximum over every call this
#                function makes (16-byte aligned). `lower_ir` records it as it
#                lowers each call (see `lower_call`); frame.run reserves it as the
#                lowest region of the frame so a caller's `[rsp + off]` store
#                (`0 <= off < outgoing_size`) lands there without overlapping
#                locals, spills, or the callee-saved save area, and the call-site
#                RSP stays 16-byte aligned. zero when the function makes no call
#                with stack-passed arguments.
pub rec MirFrame {
    slots:         *MirSlot;
    slot_count:    u32;
    slot_cap:      u32;
    size:          u32;
    align:         u32;
    outgoing_size: u32;
}

# a source variable's home, captured at lowering for the -g DWARF variable emitter.
# The IR OP_DBG_VALUE (identified by `iid`, which keys the IR function's dbg_vars /
# dbg_exprs side tables) binds a source variable to a value; `vreg` is the MIR vreg
# that value lowered to, whose regalloc/frame assignment gives the final location
# (MIR_VREG_NIL when the operand had no register home - a constant or optimized-out
# value). Pure debug metadata: recorded only under -g, never affects emitted code.
# ---
# iid:  the IR OP_DBG_VALUE instruction id (joins the IR dbg_vars / dbg_exprs tables)
# vreg: the operand's MIR vreg, or MIR_VREG_NIL for no register/frame home
pub rec MirDbgVar {
    iid:  u32;
    vreg: u32;
}

# a function in MIR form - blocks, the virtual-register table, and frame layout
# ---
# name:           interned function symbol name
# blocks:         MIR blocks; blocks[0] is the entry block (owned)
# block_count:    number of blocks
# block_cap:      allocated capacity for blocks
# vregs:          virtual-register table indexed by vreg id (owned)
# vreg_count:     number of virtual registers
# vreg_cap:       allocated capacity for vregs
# frame:          stack-frame layout (filled in by frame.run)
# callee_mask:    bitmask of callee-saved physical GP registers this function
#                 actually assigns, written by regalloc and read by frame.run /
#                 encode.run to emit the prologue save / epilogue restore. bit `n`
#                 set means physical GP register id `n` is live in the function and
#                 must be preserved. `lower_ir` initializes it to 0 (no
#                 callee-saved register used until regalloc proves otherwise).
# callee_mask_fp: the FP-bank twin of `callee_mask` - a bitmask of callee-saved
#                 vector (XMM) register INDICES this function must preserve, written
#                 by regalloc. bit `n` set means XMM register `n` must be saved in
#                 the prologue and restored in the epilogue. only conventions with
#                 callee-saved vector registers (win64's XMM6-15) ever set bits
#                 here; under SysV, where every XMM is caller-saved, it stays 0.
pub rec MirFunction {
    name:        intern.StrId;

    blocks:      *MirBlock;
    block_count: u32;
    block_cap:   u32;

    vregs:       *MirVReg;
    vreg_count:  u32;
    vreg_cap:    u32;

    frame:          MirFrame;
    callee_mask:    u32;
    callee_mask_fp: u32;

    # source-variable homes for the -g DWARF variable emitter (owned); empty without
    # -g. captured at lowering, resolved to locations after regalloc / frame.run.
    dbg_vars:      *MirDbgVar;
    dbg_var_count: u32;
    dbg_var_cap:   u32;
}

# the per-source-module unit produced by `lower_ir`
# ---
# alloc:        allocator backing every owned array (mirrors the IR module's)
# interner:     the session interner, threaded through so the encoder can resolve
#               interned strings (inline-asm bodies) and intern new symbol names
#               referenced from inline asm into relocations
# functions:    MIR functions, parallel to the source IR module's functions (owned)
# function_len: number of functions
# function_cap: allocated capacity for functions
pub rec MirModule {
    alloc:        *A.Allocator;
    interner:     *intern.Interner;
    functions:    *MirFunction;
    function_len: u32;
    function_cap: u32;
}

# initial capacities for the MIR module's growable backing arrays
pub val INITIAL_FN_CAP:    u32 = 8;
pub val INITIAL_VREG_CAP:  u32 = 32;
pub val INITIAL_INSTR_CAP: u32 = 16;
pub val INITIAL_SLOT_CAP:  u32 = 8;

# build a virtual-register operand
# ---
# vreg: virtual register id
# ret:  a MIR_OP_VREG operand
pub fun op_vreg(vreg: u32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_VREG;
    o.vreg          = vreg;
    o.preg          = 0;
    o.imm           = 0;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build a physical-register operand
# ---
# preg: physical register id within its class
# ret:  a MIR_OP_PREG operand
pub fun op_preg(preg: u32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_PREG;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = preg;
    o.imm           = 0;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build an immediate operand
# ---
# imm: immediate value
# ret: a MIR_OP_IMM operand
pub fun op_imm(imm: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_IMM;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = 0;
    o.imm           = imm;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build a memory operand whose base is a frame-slot key
#
# `slotkey` is a slot-owning vreg id; the encoder resolves it to
# `[rbp + slot.offset + disp]` via the frame layout. regalloc never
# register-allocates a slot-owning vreg, so this base survives unchanged into
# encode.
# ---
# slotkey: slot-owning vreg id (alloca pointer, two-register param spill, or
#          register-allocator spill slot)
# disp:    displacement in bytes
# ret:     a MIR_OP_MEM operand with a frame-slot-key base
pub fun op_mem_slot(slotkey: u32, disp: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_MEM;
    o.vreg          = slotkey;
    o.preg          = 0;
    o.imm           = disp;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build a memory operand whose base is a physical register
#
# Used for direct RBP/RSP bases (stack-parameter loads, outgoing stack-argument
# stores) and for value-pointer bases regalloc has resolved to a physical
# register. The encoder forms `[preg + disp]`.
# ---
# preg: physical register id of the base
# disp: displacement in bytes
# ret:  a MIR_OP_MEM operand with a physical-register base
pub fun op_mem_preg(preg: u32, disp: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_MEM;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = preg;
    o.imm           = disp;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build a memory operand whose base is a value vreg holding a runtime pointer
#
# Pre-regalloc only; regalloc rewrites this base to its assigned physical
# register (the `op_mem_preg` form). A value vreg in a MEM base must not survive
# register allocation.
# ---
# base: value virtual register id holding the pointer
# disp: displacement in bytes
# ret:  a MIR_OP_MEM operand with a value-vreg base
pub fun op_mem_value(base: u32, disp: i64) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_MEM;
    o.vreg          = base;
    o.preg          = 0;
    o.imm           = disp;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build a symbol-reference operand
# ---
# sym:     interned symbol name
# sym_off: addend applied to the symbol
# ret:     a MIR_OP_SYM operand
pub fun op_sym(sym: intern.StrId, sym_off: i32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_SYM;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = 0;
    o.imm           = 0;
    o.sym           = sym;
    o.sym_off       = sym_off;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# build a branch-target block operand
# ---
# block: target block id
# ret:   a MIR_OP_BLOCK operand
pub fun op_block(block: u32) MirOperand {
    var o: MirOperand;
    o.kind          = MIR_OP_BLOCK;
    o.vreg          = MIR_VREG_NIL;
    o.preg          = 0;
    o.imm           = block::i64;
    o.sym           = intern.STR_NIL;
    o.sym_off       = 0;
    o.index         = MIR_VREG_NIL;
    o.scale         = 0;
    o.index_is_preg = false;
    ret o;
}

# whether a vreg id names a float/vector-bank value (a non-GP register class)
#
# Exposed so instruction selection can identify a float register copy from the
# function's recorded vreg classes without hardcoding the GP class convention. An
# out-of-range vreg id is not an FP value.
# ---
# fn:   the MIR function owning the vreg table
# vreg: the vreg id to test
# ret:  true when the vreg's class is the float/vector bank
pub fun vreg_is_fp(fn: *MirFunction, vreg: u32) bool {
    if (vreg >= fn.vreg_count) { ret false; }
    ret fn.vregs[vreg].class != REG_CLASS_GP;
}

# append a lowered function to the MIR module, growing the function array
# ---
# mm:  the module to append to
# mf:  the lowered function to append (copied into the array)
# ret: true on success, or an allocation error
pub fun push_function(mm: *MirModule, mf: MirFunction) R.Result[bool, str] {
    if (mm.function_len == mm.function_cap) {
        var new_cap: u32 = mm.function_cap * 2;

        if (new_cap == 0) { new_cap = INITIAL_FN_CAP; }

        if (mm.functions == nil) {
            val res_alloc: R.Result[*MirFunction, str] = A.allocate[MirFunction](mm.alloc, new_cap::usize);
            if (R.is_err[*MirFunction, str](res_alloc)) {
                ret R.err[bool, str](R.unwrap_err[*MirFunction, str](res_alloc));
            }
            mm.functions = R.unwrap_ok[*MirFunction, str](res_alloc);
        }
        or {
            val res_realloc: R.Result[*MirFunction, str] = A.reallocate[MirFunction](mm.alloc, mm.functions, mm.function_cap::usize, new_cap::usize);
            if (R.is_err[*MirFunction, str](res_realloc)) {
                ret R.err[bool, str](R.unwrap_err[*MirFunction, str](res_realloc));
            }
            mm.functions = R.unwrap_ok[*MirFunction, str](res_realloc);
        }

        mm.function_cap = new_cap;
    }

    mm.functions[mm.function_len] = mf;
    mm.function_len = mm.function_len + 1;
    ret R.ok[bool, str](true);
}

# record one source-variable home (`iid` -> `vreg`) in a function's dbg-var table,
# growing it as needed. -g only; called by lowering for each OP_DBG_VALUE.
# ---
# a:    the allocator backing the table
# mf:   the function to append to
# iid:  the IR OP_DBG_VALUE instruction id
# vreg: the operand's MIR vreg, or MIR_VREG_NIL for no home
# ret:  true on success, or an allocation error
pub fun dbg_var_add(a: *A.Allocator, mf: *MirFunction, iid: u32, vreg: u32) R.Result[bool, str] {
    if (mf.dbg_var_count == mf.dbg_var_cap) {
        var new_cap: u32 = mf.dbg_var_cap * 2;
        if (new_cap == 0) { new_cap = 4; }
        if (mf.dbg_vars == nil) {
            val ra: R.Result[*MirDbgVar, str] = A.allocate[MirDbgVar](a, new_cap::usize);
            if (R.is_err[*MirDbgVar, str](ra)) { ret R.err[bool, str](R.unwrap_err[*MirDbgVar, str](ra)); }
            mf.dbg_vars = R.unwrap_ok[*MirDbgVar, str](ra);
        }
        or {
            val rr: R.Result[*MirDbgVar, str] = A.reallocate[MirDbgVar](a, mf.dbg_vars, mf.dbg_var_cap::usize, new_cap::usize);
            if (R.is_err[*MirDbgVar, str](rr)) { ret R.err[bool, str](R.unwrap_err[*MirDbgVar, str](rr)); }
            mf.dbg_vars = R.unwrap_ok[*MirDbgVar, str](rr);
        }
        mf.dbg_var_cap = new_cap;
    }
    mf.dbg_vars[mf.dbg_var_count].iid  = iid;
    mf.dbg_vars[mf.dbg_var_count].vreg = vreg;
    mf.dbg_var_count = mf.dbg_var_count + 1;
    ret R.ok[bool, str](true);
}

# release every owned array in a MIR module, safe on a partially built module and on nil
# ---
# mm: the module to tear down; all owned storage is freed and fields zeroed
pub fun dnit_module(mm: *MirModule) {
    if (mm == nil) { ret; }

    var i: u32 = 0;
    for (i < mm.function_len) {
        dnit_function(mm.alloc, ?mm.functions[i]);
        i = i + 1;
    }
    if (mm.functions != nil && mm.function_cap > 0) {
        A.deallocate[MirFunction](mm.alloc, mm.functions, mm.function_cap::usize);
    }

    mm.functions    = nil;
    mm.function_len = 0;
    mm.function_cap = 0;
}

# release one MIR function's owned storage: its blocks (and their nested
# instruction / operand / pred storage), the vreg table, and the frame slots
# ---
# a:  allocator the function's storage was allocated from
# mf: the function to tear down; owned storage is freed and counts zeroed
pub fun dnit_function(a: *A.Allocator, mf: *MirFunction) {
    var i: u32 = 0;
    for (i < mf.block_count) {
        dnit_block(a, ?mf.blocks[i]);
        i = i + 1;
    }
    if (mf.blocks != nil && mf.block_cap > 0) {
        A.deallocate[MirBlock](a, mf.blocks, mf.block_cap::usize);
    }
    if (mf.vregs != nil && mf.vreg_cap > 0) {
        A.deallocate[MirVReg](a, mf.vregs, mf.vreg_cap::usize);
    }
    if (mf.frame.slots != nil && mf.frame.slot_cap > 0) {
        A.deallocate[MirSlot](a, mf.frame.slots, mf.frame.slot_cap::usize);
    }
    if (mf.dbg_vars != nil && mf.dbg_var_cap > 0) {
        A.deallocate[MirDbgVar](a, mf.dbg_vars, mf.dbg_var_cap::usize);
    }

    mf.blocks        = nil;
    mf.block_count   = 0;
    mf.block_cap     = 0;
    mf.vregs         = nil;
    mf.vreg_count    = 0;
    mf.vreg_cap      = 0;
    mf.dbg_vars      = nil;
    mf.dbg_var_count = 0;
    mf.dbg_var_cap   = 0;
}

# release one MIR block's owned storage: every instruction's operand array (and
# any inline-asm payload), the block's instruction list, and its predecessor list
# ---
# a:  allocator the block's storage was allocated from
# mb: the block to tear down; owned storage is freed
fun dnit_block(a: *A.Allocator, mb: *MirBlock) {
    var i: u32 = 0;
    for (i < mb.instr_count) {
        val mi: *MirInstr = ?mb.instrs[i];
        if (mi.operands != nil && mi.operand_count > 0) {
            A.deallocate[MirOperand](a, mi.operands, mi.operand_count::usize);
        }
        if (mi.opcode == MIR_ASM && mi.asm_block != nil) {
            if (mi.asm_block.binds != nil && mi.asm_block.bind_count > 0) {
                A.deallocate[MirAsmBind](a, mi.asm_block.binds, mi.asm_block.bind_count::usize);
            }
            A.deallocate[MirAsm](a, mi.asm_block, 1::usize);
        }
        i = i + 1;
    }
    if (mb.instrs != nil && mb.instr_cap > 0) {
        A.deallocate[MirInstr](a, mb.instrs, mb.instr_cap::usize);
    }
    if (mb.preds != nil && mb.pred_cap > 0) {
        A.deallocate[u32](a, mb.preds, mb.pred_cap::usize);
    }
}
