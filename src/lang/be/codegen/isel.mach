# mach.lang.be.codegen.isel: instruction-selection dispatcher to the active ISA's selector.
#
# Instruction selection is target-specific: the concrete machine forms a generic
# MIR opcode lowers to are an ISA's business. This module owns no x86-64 (or any
# other arch's) opcode or register knowledge; it dispatches each MIR function to
# the active ISA's `select` operation through the `isa` vtable, exactly as the
# shared regalloc / frame / encode driver files reach the ISA and ABI. Adding a
# new architecture is implementing `target/isa/<arch>` and registering its
# `select` entry point — no edit here.
#
# The per-arch selector (e.g. `target/isa/x64/isel.mach`) rewrites the generic
# MIR opcodes a `MirFunction` carries into that ISA's concrete encoder opcodes in
# place, materializing short fixed instruction sequences for the opcodes with no
# single-instruction machine form. This dispatcher only walks the module's
# functions and forwards each to that selector; it errors loudly if the active
# ISA registered no `select`.

use std.types.bool.bool;
use std.types.bool.true;

use std.types.string.str;

use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;

use std.allocator.Allocator;

use target: mach.lang.target;
use isa:    mach.lang.target.isa;
use mir:    mach.lang.be.codegen.mir;

# SelectFn: the concrete signature the erased `isa.IsaVTable.select` pointer is
# cast back to before it is called. The vtable stores `select` type-erased
# (`*u8`) because its signature names `target.Target`, `mir.MirFunction`, and
# `std.allocator`, each of which imports `isa` — a typed field there would invert
# that dependency and form an import cycle. This dispatcher already imports
# `target` and `mir`, so it declares the cast-back type locally and casts the
# erased pointer to it, exactly as `mir` casts `abi.arg_passing` back to its
# concrete signature. The structurally identical typedef the x86-64 selector
# exposes (`x64.isel.SelectFn`) describes the same contract from the impl side;
# the structural fn-pointer cast binds them. The allocator is threaded explicitly
# because the per-function selector needs it to rebuild a block's instruction
# list when expanding multi-instruction forms, and neither `Target` nor
# `MirFunction` carries one.
# ---
# alloc: backing allocator for any block-rebuilding the selector performs
# tgt:   resolved compilation target
# fn:    the MIR function to select instructions for; mutated in place
# ret:   ok(true) on success, or an error naming the failure
pub def SelectFn: fun(*Allocator, *target.Target, *mir.MirFunction) Result[bool, str];

# run: select concrete instructions for an entire MIR module.
#
# dispatches every function to the active ISA's `select` operation, reached
# through `tgt.isa.select`. carries no architecture-specific knowledge — the
# selector the ISA registered owns the opcode and register mapping. fails loudly
# if the target has no ISA vtable or the ISA registered no `select` operation
# (an unsupported architecture), and propagates any selection error from the
# per-function selector.
# ---
# tgt: resolved compilation target; its `isa` vtable supplies the selector
# m:   the MIR module to select instructions for; mutated in place
# ret: ok(true) on success, or an error naming the failure
pub fun run(tgt: *target.Target, m: *mir.MirModule) Result[bool, str] {
    if (tgt == nil) { ret err[bool, str]("isel: nil target"); }
    if (m == nil)   { ret err[bool, str]("isel: nil mir module"); }
    if (tgt.arch == nil) {
        ret err[bool, str]("isel: target has no ISA vtable");
    }
    if (tgt.arch.select == nil) {
        ret err[bool, str]("isel: ISA registered no instruction selector");
    }

    val select: SelectFn = tgt.arch.select::SelectFn;

    var fi: u32 = 0;
    for (fi < m.function_len) {
        val r: Result[bool, str] = select(m.alloc, tgt, ?m.functions[fi]);
        if (is_err[bool, str](r)) { ret r; }
        fi = fi + 1;
    }

    ret ok[bool, str](true);
}
