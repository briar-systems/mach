# mach.lang.be.codegen.mir.lower: IR-to-MIR translation and out-of-SSA.
#
# `lower_ir` is the bridge between the target-independent SSA IR
# (`mach.lang.me.ir`) and the MIR data model (`mach.lang.be.codegen.mir`): it
# walks an `ir.Module` and produces a parallel `MirModule`, one `MirFunction`
# per IR function. The translation is deliberately mechanical and
# target-agnostic (it routes every register name and calling-convention fact
# through the `tgt.abi` / `tgt.isa` vtables):
#   - every IR `Block` becomes a `MirBlock` with the same numeric id;
#   - every SSA result (instruction result or function parameter) is assigned
#     exactly one fresh virtual register, and every operand reference becomes a
#     `MIR_OP_VREG` operand naming it;
#   - inline integer / null constants become `MIR_OP_IMM` operands; globals and
#     function symbols become `MIR_OP_SYM` operands;
#   - `OP_CALL` lowers through the active ABI vtable (see `mir.abi`): each
#     argument is classified and pre-colored into its canonical argument
#     register or a stack store, followed by a `MIR_CALL` pseudo naming the
#     callee and a `MIR_CALL_RES` pseudo binding the result vreg;
#   - `OP_PHI` is eliminated out of SSA: each phi becomes a `MIR_MOV` of its
#     incoming value into the phi's result vreg, inserted at the end of every
#     predecessor block before its terminator (see `lower_phis`), so no phi
#     reaches isel / regalloc / encode.
#
# This module owns the generic per-instruction lowering and the out-of-SSA
# machinery; ABI call/param/ret lowering lives in `mir.abi`, variadic
# expansion in `mir.va`, and the shared `LowerCtx` and emit primitives in
# `mir.context`.

use std.collections.map;
use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mir:     mach.lang.be.codegen.mir;
use mabi:    mach.lang.be.codegen.mir.abi;
use lctx:    mach.lang.be.codegen.mir.context;
use intern:  mach.lang.intern;
use ir:      mach.lang.me.ir;
use id:      mach.lang.me.ir.id;
use instr:   mach.lang.me.ir.instruction;
use ir_type: mach.lang.me.ir.type;
use value:   mach.lang.me.ir.value;
use source:  mach.lang.source;
use target:  mach.lang.target.resolved;

# lower an IR module to a parallel MIR module, one MIR function per IR function
# ---
# tgt:      resolved compilation target; supplies register classes via `tgt.arch`
# m:        the source IR module to lower
# interner: session interner, recorded on the MIR module so the encoder can
#           resolve interned strings and intern inline-asm symbol references
# ret:      a populated mir.MirModule (owned, release with `mir.dnit_module`), or
#           an allocation / lowering error
pub fun lower_ir(tgt: *target.Target, m: *ir.Module, interner: *intern.Interner) R.Result[mir.MirModule, str] {
    if (tgt == nil || m == nil) {
        ret R.err[mir.MirModule, str]("mir.lower_ir: nil target or module");
    }

    var mm: mir.MirModule;
    mm.alloc        = m.alloc;
    mm.interner     = interner;
    mm.functions    = nil;
    mm.function_len = 0;
    mm.function_cap = 0;

    val rf: R.Result[*mir.MirFunction, str] = A.allocate[mir.MirFunction](m.alloc, mir.INITIAL_FN_CAP::usize);
    if (R.is_err[*mir.MirFunction, str](rf)) {
        ret R.err[mir.MirModule, str](R.unwrap_err[*mir.MirFunction, str](rf));
    }
    mm.functions    = R.unwrap_ok[*mir.MirFunction, str](rf);
    mm.function_cap = mir.INITIAL_FN_CAP;

    var fi: u32 = 0;
    for (fi < m.function_len) {
        val lf: R.Result[mir.MirFunction, str] = lower_function(tgt, m, ?m.functions[fi], interner);
        if (R.is_err[mir.MirFunction, str](lf)) {
            mir.dnit_module(?mm);
            ret R.err[mir.MirModule, str](R.unwrap_err[mir.MirFunction, str](lf));
        }
        val push: R.Result[bool, str] = mir.push_function(?mm, R.unwrap_ok[mir.MirFunction, str](lf));
        if (R.is_err[bool, str](push)) {
            mir.dnit_module(?mm);
            ret R.err[mir.MirModule, str](R.unwrap_err[bool, str](push));
        }
        fi = fi + 1;
    }

    ret R.ok[mir.MirModule, str](mm);
}

# lower one IR function into a mir.MirFunction
#
# Allocates the vreg table and the per-definition vreg maps, assigns a vreg to
# every parameter and every non-void instruction result, then translates each
# block's phis, body, and terminator into MIR instructions.
# ---
# tgt:      resolved compilation target; routes register classes and ABI facts
# m:        the source IR module owning `fn`
# fn:       the IR function to lower
# interner: session interner, recorded on the context for inline-asm resolution
# ret:      a populated mir.MirFunction (owned), or an allocation / lowering error
fun lower_function(tgt: *target.Target, m: *ir.Module, fn: *ir.Function, interner: *intern.Interner) R.Result[mir.MirFunction, str] {
    var mf: mir.MirFunction;
    mf.name                = fn.name;
    mf.blocks              = nil;
    mf.block_count         = 0;
    mf.block_cap           = 0;
    mf.vregs               = nil;
    mf.vreg_count          = 0;
    mf.vreg_cap            = 0;
    mf.frame.slots         = nil;
    mf.frame.slot_count    = 0;
    mf.frame.slot_cap      = 0;
    mf.frame.size          = 0;
    mf.frame.align         = 0;
    mf.frame.outgoing_size = 0;
    mf.callee_mask         = 0;
    mf.callee_mask_fp      = 0;

    # extern / body-less functions lower to an empty mir.MirFunction shell.
    if ((fn.flags & ir.FN_FLAG_EXTERN) != 0 || fn.block_count == 0) {
        ret R.ok[mir.MirFunction, str](mf);
    }

    val rv: R.Result[*mir.MirVReg, str] = A.allocate[mir.MirVReg](m.alloc, mir.INITIAL_VREG_CAP::usize);
    if (R.is_err[*mir.MirVReg, str](rv)) {
        ret R.err[mir.MirFunction, str](R.unwrap_err[*mir.MirVReg, str](rv));
    }
    mf.vregs    = R.unwrap_ok[*mir.MirVReg, str](rv);
    mf.vreg_cap = mir.INITIAL_VREG_CAP;

    var ctx: lctx.LowerCtx;
    ctx.alloc          = m.alloc;
    ctx.tgt            = tgt;
    ctx.m              = m;
    ctx.types          = ?m.types;
    ctx.fn             = fn;
    ctx.f              = ?mf;
    ctx.param_vregs    = nil;
    ctx.param_count    = fn.param_count;
    ctx.instr_vregs    = nil;
    ctx.slot_key_vregs = nil;
    ctx.instr_count    = fn.instr_len;
    ctx.interner       = interner;
    ctx.sret_vreg      = mir.MIR_VREG_NIL;
    ctx.cur_loc        = source.loc_nil();

    val setup: R.Result[bool, str] = lctx.ctx_setup(?ctx, tgt, fn);
    if (R.is_err[bool, str](setup)) {
        lctx.ctx_dnit(?ctx);
        mir.dnit_function(m.alloc, ?mf);
        ret R.err[mir.MirFunction, str](R.unwrap_err[bool, str](setup));
    }

    val rb: R.Result[*mir.MirBlock, str] = A.allocate[mir.MirBlock](m.alloc, fn.block_count::usize);
    if (R.is_err[*mir.MirBlock, str](rb)) {
        lctx.ctx_dnit(?ctx);
        mir.dnit_function(m.alloc, ?mf);
        ret R.err[mir.MirFunction, str](R.unwrap_err[*mir.MirBlock, str](rb));
    }
    mf.blocks    = R.unwrap_ok[*mir.MirBlock, str](rb);
    mf.block_cap = fn.block_count;

    var bi: u32 = 0;
    for (bi < fn.block_count) {
        val is_entry: bool = bi == 0;
        val lb: R.Result[bool, str] = lower_block(?ctx, fn, ?fn.blocks[bi], is_entry);
        if (R.is_err[bool, str](lb)) {
            lctx.ctx_dnit(?ctx);
            mir.dnit_function(m.alloc, ?mf);
            ret R.err[mir.MirFunction, str](R.unwrap_err[bool, str](lb));
        }
        bi = bi + 1;
    }

    # out-of-SSA: every block now exists, so the phi merge copies can be inserted
    # at the predecessor block ends (before their terminators).
    val lph: R.Result[bool, str] = lower_phis(?ctx, fn);
    if (R.is_err[bool, str](lph)) {
        lctx.ctx_dnit(?ctx);
        mir.dnit_function(m.alloc, ?mf);
        ret R.err[mir.MirFunction, str](R.unwrap_err[bool, str](lph));
    }

    lctx.ctx_dnit(?ctx);
    ret R.ok[mir.MirFunction, str](mf);
}

# lower one IR block into a mir.MirBlock with the same id
#
# Copies predecessor ids, translates each body instruction, then the terminator.
# IR phis are NOT emitted here - they are eliminated out of SSA by `lower_phis`
# after every block exists, which inserts the merge copies at the predecessor
# block ends. The block is claimed in `mf` (block_count incremented) the moment
# its owned pointers are zeroed, so a partially built block left behind by an
# allocation failure is still reclaimed by `dnit_function` on the cleanup path.
# ---
# ctx:      the per-function lowering context
# fn:       the IR function owning `blk`
# blk:      the IR block to lower
# is_entry: true for the entry block, which opens with the ABI param pre-coloring
# ret:      true on success, or an allocation / lowering error
fun lower_block(ctx: *lctx.LowerCtx, fn: *ir.Function, blk: *ir.Block, is_entry: bool) R.Result[bool, str] {
    val f: *mir.MirFunction = ctx.f;
    val mb: *mir.MirBlock = ?f.blocks[f.block_count];
    mb.id          = blk.id::u32;
    mb.instrs      = nil;
    mb.instr_count = 0;
    mb.instr_cap   = 0;
    mb.preds       = nil;
    mb.pred_count  = 0;
    mb.pred_cap    = 0;
    f.block_count = f.block_count + 1;

    val cp: R.Result[bool, str] = copy_preds(ctx, mb, blk);
    if (R.is_err[bool, str](cp)) { ret cp; }

    # the entry block opens with the ABI param pre-coloring: each incoming
    # parameter is moved out of its canonical argument register (or loaded from
    # the caller's stack area) into the parameter vreg before any body code runs.
    if (is_entry) {
        val lp: R.Result[bool, str] = mabi.lower_params(ctx, mb);
        if (R.is_err[bool, str](lp)) { ret lp; }
    }

    var ii: u32 = 0;
    for (ii < blk.instr_count) {
        val ei: R.Result[bool, str] = lower_instr(ctx, fn, mb, blk.instructions[ii]);
        if (R.is_err[bool, str](ei)) { ret ei; }
        ii = ii + 1;
    }

    if (blk.terminator != id.INSTR_NIL) {
        val et: R.Result[bool, str] = lower_instr(ctx, fn, mb, blk.terminator);
        if (R.is_err[bool, str](et)) { ret et; }
    }

    ret R.ok[bool, str](true);
}

# copy an IR block's predecessor ids into a mir.MirBlock
# ---
# ctx: the per-function lowering context
# mb:  the destination MIR block
# blk: the source IR block
# ret: true on success, or an allocation error
fun copy_preds(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, blk: *ir.Block) R.Result[bool, str] {
    if (blk.pred_count == 0) { ret R.ok[bool, str](true); }
    val r: R.Result[*u32, str] = A.allocate[u32](ctx.alloc, blk.pred_count::usize);
    if (R.is_err[*u32, str](r)) { ret R.err[bool, str](R.unwrap_err[*u32, str](r)); }
    mb.preds    = R.unwrap_ok[*u32, str](r);
    mb.pred_cap = blk.pred_count;
    var i: u32 = 0;
    for (i < blk.pred_count) {
        mb.preds[i] = blk.preds[i]::u32;
        i = i + 1;
    }
    mb.pred_count = blk.pred_count;
    ret R.ok[bool, str](true);
}

# eliminate every IR phi out of SSA by inserting merge copies at predecessor ends
#
# Conventional (Cytron-style) phi destruction: a phi in block `S` with result
# vreg `r` and incoming pairs `(pred, value)` is realized by emitting, at the end
# of each predecessor block `P` (before its terminator), a
# `mir.MIR_MOV r <- lctx.lower_value(value)`, so `r` is defined on every path into
# `S`. After this pass no OP_PHI / mir.MIR_PHI exists; the encoder's mir.MIR_PHI
# rejection is only a backstop. The result vreg is the ordinary allocatable vreg
# `lctx.ctx_setup` already assigned to the phi instruction.
#
# All phis at the head of `S` execute simultaneously, so the copies along a single
# edge `P -> S` form one parallel-copy set; `emit_edge_copies` sequentializes it
# correctly (breaking cycles with a fresh temp) to avoid the lost-copy / swap
# problem. Phis whose incoming value lowers to itself contribute no copy.
# ---
# ctx: the per-function lowering context
# fn:  the IR function whose phis are being destructed
# ret: true on success, or an allocation / lowering error
fun lower_phis(ctx: *lctx.LowerCtx, fn: *ir.Function) R.Result[bool, str] {
    var bi: u32 = 0;
    for (bi < fn.block_count) {
        val blk: *ir.Block = ?fn.blocks[bi];
        if (blk.phi_count > 0) {
            val r: R.Result[bool, str] = lower_block_phis(ctx, fn, blk);
            if (R.is_err[bool, str](r)) { ret r; }
        }
        bi = bi + 1;
    }
    ret R.ok[bool, str](true);
}

# insert the merge copies for every phi of one successor block `S`
#
# For each distinct predecessor block id appearing in `S`'s phis, gathers the
# per-edge parallel-copy set (one `(phi result vreg, incoming operand)` per phi
# that has an incoming pair for that predecessor) and emits it, safely
# sequentialized, at the end of that predecessor's MIR block.
# ---
# ctx: the per-function lowering context
# fn:  the IR function owning `blk`
# blk: the successor block `S` whose phis are being realized
# ret: true on success, or an allocation / lowering error
fun lower_block_phis(ctx: *lctx.LowerCtx, fn: *ir.Function, blk: *ir.Block) R.Result[bool, str] {
    # scratch parallel-copy set, at most one copy per phi in this block.
    val np: u32 = blk.phi_count;
    val rd: R.Result[*u32, str] = A.allocate[u32](ctx.alloc, np::usize);
    if (R.is_err[*u32, str](rd)) { ret R.err[bool, str](R.unwrap_err[*u32, str](rd)); }
    val dsts: *u32 = R.unwrap_ok[*u32, str](rd);
    val rs: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, np::usize);
    if (R.is_err[*mir.MirOperand, str](rs)) {
        A.deallocate[u32](ctx.alloc, dsts, np::usize);
        ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rs));
    }
    val srcs: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rs);
    # per-copy logical width, parallel to dsts / srcs: the phi result's byte width,
    # so an immediate incoming value materializes at the constant's true width.
    val rw: R.Result[*u8, str] = A.allocate[u8](ctx.alloc, np::usize);
    if (R.is_err[*u8, str](rw)) {
        A.deallocate[u32](ctx.alloc, dsts, np::usize);
        A.deallocate[mir.MirOperand](ctx.alloc, srcs, np::usize);
        ret R.err[bool, str](R.unwrap_err[*u8, str](rw));
    }
    val wids: *u8 = R.unwrap_ok[*u8, str](rw);

    var err_msg: str = nil;
    # iterate the distinct predecessor block ids of `S`. preds were copied from the
    # IR block, deduped, so each names one edge `P -> S`.
    var pi: u32 = 0;
    for (pi < blk.pred_count && err_msg == nil) {
        val pred_id: u32 = blk.preds[pi]::u32;
        var pred_mb: *mir.MirBlock = mir_block_by_id(ctx.f, pred_id);
        if (pred_mb == nil) {
            err_msg = "mir.lower_ir: phi predecessor block has no MIR block";
            pi = pi + 1;
            cnt;
        }

        # critical edge: a phi block always has multiple predecessors, so an edge
        # `P -> S` is critical when `P` also has multiple successors (a CBR). Placing
        # this edge's phi copies at the end of `P` would run them on `P`'s other
        # successor path too, which can corrupt a value the sibling edge's copies
        # need. Split the edge into a fresh block `B` that branches to `S`, retarget
        # `P`'s CBR to `B`, and emit this edge's copies into `B` (which ends in an
        # unconditional branch and so is a safe splice point).
        if (block_ends_in_cbr(pred_mb)) {
            val sr: R.Result[*mir.MirBlock, str] = split_critical_edge(ctx, pred_mb, blk.id::u32);
            if (R.is_err[*mir.MirBlock, str](sr)) { err_msg = R.unwrap_err[*mir.MirBlock, str](sr); pi = pi + 1; cnt; }
            pred_mb = R.unwrap_ok[*mir.MirBlock, str](sr);
        }

        # collect this edge's copies: for each phi, the incoming value paired with
        # this predecessor, targeting the phi's result vreg.
        var nc: u32 = 0;
        var hi: u32 = 0;
        for (hi < blk.phi_count && err_msg == nil) {
            val phi_opt: O.Option[*instr.Instruction] = ir.instruction_get(fn, blk.phis[hi]);
            if (!O.is_some[*instr.Instruction](phi_opt)) {
                err_msg = "mir.lower_ir: dangling phi instruction id";
                hi = hi + 1;
                cnt;
            }
            val phi: *instr.Instruction = O.unwrap[*instr.Instruction](phi_opt);
            val dst_vreg: u32 = lctx.instr_vreg(ctx, blk.phis[hi]);
            if (dst_vreg == mir.MIR_VREG_NIL) {
                err_msg = "mir.lower_ir: phi defines no result vreg";
                hi = hi + 1;
                cnt;
            }
            var found: bool = false;
            var k: u32 = 0;
            for (k + 1 < phi.operand_count && found == false) {
                if (phi.operands[k].data.int_lit::u32 == pred_id) {
                    dsts[nc] = dst_vreg;
                    srcs[nc] = lctx.lower_value(ctx, phi.operands[k + 1]);
                    wids[nc] = lctx.op_width_of(ctx, phi.ty);
                    nc = nc + 1;
                    found = true;
                }
                k = k + 2;
            }
            hi = hi + 1;
        }

        if (err_msg == nil && nc > 0) {
            val r: R.Result[bool, str] = emit_edge_copies(ctx, pred_mb, dsts, srcs, wids, nc);
            if (R.is_err[bool, str](r)) { err_msg = R.unwrap_err[bool, str](r); }
        }
        pi = pi + 1;
    }

    A.deallocate[u32](ctx.alloc, dsts, np::usize);
    A.deallocate[mir.MirOperand](ctx.alloc, srcs, np::usize);
    A.deallocate[u8](ctx.alloc, wids, np::usize);
    if (err_msg != nil) { ret R.err[bool, str](err_msg); }
    ret R.ok[bool, str](true);
}

# return the MIR block whose id equals `block_id`, or nil if absent
#
# MIR block ids mirror the source IR block ids, so a phi's predecessor id selects
# the predecessor's MIR block directly.
# ---
# f:        the MIR function to search
# block_id: the block id to match
# ret:      the matching MIR block, or nil when none has that id
fun mir_block_by_id(f: *mir.MirFunction, block_id: u32) *mir.MirBlock {
    var bi: u32 = 0;
    for (bi < f.block_count) {
        if (f.blocks[bi].id == block_id) { ret ?f.blocks[bi]; }
        bi = bi + 1;
    }
    ret nil;
}

# sequentialize and insert one edge's parallel-copy set into its predecessor
#
# The set `{dsts[i] <- srcs[i]}` is spliced into predecessor block `pred_mb`,
# before its terminator. All `dsts[i]` are distinct phi-result vregs; the
# `srcs[i]` operands are vregs, immediates, or symbols. The copies are
# conceptually simultaneous, so a naive in-order emission would clobber a value
# another copy still needs (the lost-copy / swap problem). Standard resolution:
# repeatedly emit any copy whose destination is not still needed as a source;
# when only a dependence cycle remains, break it by saving one destination's live
# value into a fresh temp vreg and redirecting the copies that read it. A
# `dst == src` self-copy is dropped.
# ---
# ctx:     the per-function lowering context
# pred_mb: the predecessor block the copies are spliced into
# dsts:    the per-copy destination vregs (len `n`)
# srcs:    the per-copy source operands (len `n`)
# wids:    the per-copy value logical width in bytes (len `n`)
# n:       the number of copies in the edge set
# ret:     true on success, or an allocation / lowering error
fun emit_edge_copies(ctx: *lctx.LowerCtx, pred_mb: *mir.MirBlock, dsts: *u32, srcs: *mir.MirOperand, wids: *u8, n: u32) R.Result[bool, str] {
    val re: R.Result[*bool, str] = A.allocate[bool](ctx.alloc, n::usize);
    if (R.is_err[*bool, str](re)) { ret R.err[bool, str](R.unwrap_err[*bool, str](re)); }
    val done: *bool = R.unwrap_ok[*bool, str](re);

    var remaining: u32 = 0;
    var i: u32 = 0;
    for (i < n) {
        # a copy whose source is the destination vreg itself is a no-op.
        if (srcs[i].kind == mir.MIR_OP_VREG && srcs[i].vreg == dsts[i]) {
            done[i] = true;
        } or {
            done[i] = false;
            remaining = remaining + 1;
        }
        i = i + 1;
    }

    var err_msg: str = nil;
    for (remaining > 0 && err_msg == nil) {
        var progressed: bool = false;
        var j: u32 = 0;
        for (j < n) {
            if (done[j] == false && !dst_is_pending_src(dsts, srcs, done, n, dsts[j])) {
                val mv: R.Result[bool, str] = insert_mov_before_terminator(ctx, pred_mb,
                    mir.op_vreg(dsts[j]), srcs[j], wids[j]);
                if (R.is_err[bool, str](mv)) { err_msg = R.unwrap_err[bool, str](mv); j = n; cnt; }
                done[j] = true;
                remaining = remaining - 1;
                progressed = true;
            }
            j = j + 1;
        }

        if (err_msg == nil && progressed == false && remaining > 0) {
            # only a dependence cycle remains: every pending destination is still
            # needed as a pending source. Pick one pending copy, save its
            # destination's live value into a fresh temp, and redirect every pending
            # copy that reads that destination to read the temp instead. This frees
            # the destination so the loop resumes.
            var c: u32 = 0;
            for (done[c]) { c = c + 1; }
            val freed: u32 = dsts[c];
            val cls: u32 = ctx.f.vregs[freed].class;
            val tr: R.Result[u32, str] = lctx.new_vreg(ctx, cls);
            if (R.is_err[u32, str](tr)) { err_msg = R.unwrap_err[u32, str](tr); cnt; }
            val tmp: u32 = R.unwrap_ok[u32, str](tr);
            # the cycle-break save is a register-to-register copy of a live value,
            # width-agnostic; carry the full register width.
            val sv: R.Result[bool, str] = insert_mov_before_terminator(ctx, pred_mb,
                mir.op_vreg(tmp), mir.op_vreg(freed), ctx.tgt.model.gpr_width::u8);
            if (R.is_err[bool, str](sv)) { err_msg = R.unwrap_err[bool, str](sv); cnt; }
            var d: u32 = 0;
            for (d < n) {
                if (done[d] == false && srcs[d].kind == mir.MIR_OP_VREG && srcs[d].vreg == freed) {
                    srcs[d] = mir.op_vreg(tmp);
                }
                d = d + 1;
            }
        }
    }

    A.deallocate[bool](ctx.alloc, done, n::usize);
    if (err_msg != nil) { ret R.err[bool, str](err_msg); }
    ret R.ok[bool, str](true);
}

# true when vreg `v` is the source of some not-yet-emitted copy in the edge set
#
# Emitting a copy into `v` now would destroy a value another pending copy still
# needs.
# ---
# dsts: the per-copy destination vregs (len `n`)
# srcs: the per-copy source operands (len `n`)
# done: per-copy emitted flags (len `n`)
# n:    the number of copies in the edge set
# v:    the vreg to test as a pending source
# ret:  true when some not-yet-emitted copy reads `v`
fun dst_is_pending_src(dsts: *u32, srcs: *mir.MirOperand, done: *bool, n: u32, v: u32) bool {
    var i: u32 = 0;
    for (i < n) {
        if (done[i] == false && srcs[i].kind == mir.MIR_OP_VREG && srcs[i].vreg == v) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# the width to materialize an immediate phi-merge source into a GP register. a
# 32-bit constant rides a width-4 move so the backend re-signs it to its register
# convention (riscv64 lp64 holds an i32 sign-extended, re-signed from the width);
# every other width keeps the full gpr-width move, since a sub-32 store leaves a
# target's upper register bits unspecified (an x86 `mov al` does not clear them) and
# a 64-bit value is already register-width. mirrors mir.abi.scalar_reg_move_width,
# which clamps argument / return materialization the same way.
fun imm_merge_width(ctx: *lctx.LowerCtx, wid: u8) u8 {
    if (wid == 4) { ret 4; }
    ret ctx.tgt.model.gpr_width::u8;
}

# splice a `mir.MIR_MOV (dst) <- (src)` just before a block's terminator
#
# A block that is a phi predecessor ends in a branch terminator (the last
# instruction); the move is spliced ahead of it, preserving the terminator-last
# ordering that frame.run / encode.run rely on.
# ---
# ctx: the per-function lowering context
# mb:  the block to splice into; must end in a terminator
# dst: the move destination operand
# src: the move source operand
# wid: the value's logical width in bytes; consulted only for an immediate source
# ret: true on success, or an allocation / lowering error
fun insert_mov_before_terminator(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand, wid: u8) R.Result[bool, str] {
    if (mb.instr_count == 0) {
        ret R.err[bool, str]("mir.lower_ir: phi predecessor block has no terminator");
    }
    val term: *mir.MirInstr = ?mb.instrs[mb.instr_count - 1];
    if (!is_mir_terminator(term.opcode)) {
        ret R.err[bool, str]("mir.lower_ir: phi predecessor block does not end in a terminator");
    }

    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: mir.MirInstr;
    # a global / function symbol incoming value is its ADDRESS as an rvalue: a
    # mir.MIR_MOV of a symbol selects to `mov dst, [sym]` (loading the symbol's
    # contents), so it is emitted as the address-computing mir.MIR_GEP (`lea dst,
    # [sym]`) instead - the same LEA-materialization the store / call-arg / return
    # symbol paths use.
    mi.opcode        = mir.MIR_MOV;
    if (src.kind == mir.MIR_OP_SYM) { mi.opcode = mir.MIR_GEP; }
    mi.operands      = ops;
    mi.operand_count = 2;
    # a register / symbol source transfers a value already in its target-canonical
    # register form, so a full-width bit copy is width-agnostic and correct. an
    # immediate source is a MATERIALIZATION of a constant, materialized at
    # `imm_merge_width`: a 32-bit constant rides a width-4 move so the backend
    # re-signs it to its register convention (riscv64 lp64 holds an i32
    # sign-extended), while every other width keeps the full-register move.
    mi.width         = ctx.tgt.model.gpr_width::u8;
    mi.src_width     = ctx.tgt.model.gpr_width::u8;
    if (src.kind == mir.MIR_OP_IMM) {
        val iw: u8 = imm_merge_width(ctx, wid);
        mi.width     = iw;
        mi.src_width = iw;
    }
    # this splice bypasses lctx.push_instr, so enforce the asm_block invariant here:
    # struct locals are not zero-initialized, and regalloc.flatten reads a non-nil
    # asm_block as an inline-asm clobber barrier. the same non-zero-init reasoning
    # applies to `loc` (FILE_NIL is not 0), so stamp the current lowering location.
    mi.asm_block     = nil;
    mi.loc           = ctx.cur_loc;

    # grow by one, shift the terminator right, and drop the move into its place.
    val gr: R.Result[bool, str] = lctx.grow_instr(ctx, mb);
    if (R.is_err[bool, str](gr)) {
        A.deallocate[mir.MirOperand](ctx.alloc, ops, 2::usize);
        ret gr;
    }
    mb.instrs[mb.instr_count] = mb.instrs[mb.instr_count - 1];
    mb.instrs[mb.instr_count - 1] = mi;
    mb.instr_count = mb.instr_count + 1;
    ret R.ok[bool, str](true);
}

# true when a generic MIR opcode ends a block
#
# The phi predecessor splice point is just before this instruction.
# ---
# o:   the MIR opcode to test
# ret: true for a branch / conditional branch / return / unreachable
fun is_mir_terminator(o: mir.MirOpcode) bool {
    if (o == mir.MIR_BR)          { ret true; }
    if (o == mir.MIR_CBR)         { ret true; }
    if (o == mir.MIR_RET)         { ret true; }
    if (o == mir.MIR_UNREACHABLE) { ret true; }
    ret false;
}

# true when a block's terminator is a conditional branch
#
# A CBR means the block has two successors, used to detect critical edges into
# phi blocks.
# ---
# mb:  the block to test
# ret: true when the block ends in a mir.MIR_CBR
fun block_ends_in_cbr(mb: *mir.MirBlock) bool {
    if (mb.instr_count == 0) { ret false; }
    ret mb.instrs[mb.instr_count - 1].opcode == mir.MIR_CBR;
}

# ensure the function's block array has room for one more block, growing on demand
#
# `lower_function` allocates exactly `fn.block_count` blocks, so any critical-edge
# split needs this to extend the array.
# ---
# ctx: the per-function lowering context
# ret: true on success, or an allocation error
fun grow_block(ctx: *lctx.LowerCtx) R.Result[bool, str] {
    val f: *mir.MirFunction = ctx.f;
    if (f.block_count >= f.block_cap) {
        var new_cap: u32 = f.block_cap * 2;
        if (new_cap < f.block_count + 1) { new_cap = f.block_count + 1; }
        val r: R.Result[*mir.MirBlock, str] = A.reallocate[mir.MirBlock](ctx.alloc, f.blocks, f.block_cap::usize, new_cap::usize);
        if (R.is_err[*mir.MirBlock, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirBlock, str](r)); }
        f.blocks    = R.unwrap_ok[*mir.MirBlock, str](r);
        f.block_cap = new_cap;
    }
    ret R.ok[bool, str](true);
}

# a block id one past the current maximum, guaranteed not to collide with any existing id
# ---
# f:   the MIR function whose block ids are scanned
# ret: an unused block id
fun fresh_block_id(f: *mir.MirFunction) u32 {
    var max_id: u32 = 0;
    var bi: u32 = 0;
    for (bi < f.block_count) {
        if (f.blocks[bi].id > max_id) { max_id = f.blocks[bi].id; }
        bi = bi + 1;
    }
    ret max_id + 1;
}

# break the critical edge `pred -> succ_id` by inserting a fresh branch block
#
# A fresh block `B` is inserted that unconditionally branches to `succ`. `pred`'s
# CBR target matching `succ_id` is retargeted to `B`, `succ`'s predecessor entry
# for `pred` is replaced by `B`, and `B`'s sole predecessor is `pred`. `B` is
# returned so the caller emits this edge's phi merge copies into it - `B` ends in
# an unconditional branch, so the splice is safe. Block pointers are re-fetched by
# id after the (possibly reallocating) growth, since growth invalidates them.
# ---
# ctx:     the per-function lowering context
# pred:    the predecessor block whose critical edge is split
# succ_id: the successor (phi) block id the edge targets
# ret:     the fresh splice block `B`, or an allocation error
fun split_critical_edge(ctx: *lctx.LowerCtx, pred: *mir.MirBlock, succ_id: u32) R.Result[*mir.MirBlock, str] {
    val pred_id: u32 = pred.id;
    val new_id:  u32 = fresh_block_id(ctx.f);

    val gr: R.Result[bool, str] = grow_block(ctx);
    if (R.is_err[bool, str](gr)) { ret R.err[*mir.MirBlock, str](R.unwrap_err[bool, str](gr)); }

    val f: *mir.MirFunction = ctx.f;
    val b: *mir.MirBlock = ?f.blocks[f.block_count];
    b.id          = new_id;
    b.instrs      = nil;
    b.instr_count = 0;
    b.instr_cap   = 0;
    b.preds       = nil;
    b.pred_count  = 0;
    b.pred_cap    = 0;

    # B's terminator: an unconditional branch to the merge block.
    val rb: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 1::usize);
    if (R.is_err[*mir.MirOperand, str](rb)) { ret R.err[*mir.MirBlock, str](R.unwrap_err[*mir.MirOperand, str](rb)); }
    val bops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rb);
    bops[0] = mir.op_block(succ_id);
    var br: mir.MirInstr;
    br.opcode        = mir.MIR_BR;
    br.operands      = bops;
    br.operand_count = 1;
    br.width         = ctx.tgt.model.gpr_width::u8;
    br.src_width     = ctx.tgt.model.gpr_width::u8;
    # this splice bypasses lctx.push_instr, so enforce the asm_block invariant here:
    # struct locals are not zero-initialized, and regalloc.flatten reads a non-nil
    # asm_block as an inline-asm clobber barrier. this is a synthesized critical-edge
    # branch with no source instruction, so its loc is nil (the line table attributes
    # it to the surrounding code).
    br.asm_block     = nil;
    br.loc           = source.loc_nil();

    val ri: R.Result[*mir.MirInstr, str] = A.allocate[mir.MirInstr](ctx.alloc, 1::usize);
    if (R.is_err[*mir.MirInstr, str](ri)) { A.deallocate[mir.MirOperand](ctx.alloc, bops, 1::usize); ret R.err[*mir.MirBlock, str](R.unwrap_err[*mir.MirInstr, str](ri)); }
    b.instrs      = R.unwrap_ok[*mir.MirInstr, str](ri);
    b.instrs[0]   = br;
    b.instr_count = 1;
    b.instr_cap   = 1;

    # B's predecessor is `pred`.
    val rp: R.Result[*u32, str] = A.allocate[u32](ctx.alloc, 1::usize);
    if (R.is_err[*u32, str](rp)) { ret R.err[*mir.MirBlock, str](R.unwrap_err[*u32, str](rp)); }
    b.preds      = R.unwrap_ok[*u32, str](rp);
    b.preds[0]   = pred_id;
    b.pred_count = 1;
    b.pred_cap   = 1;

    f.block_count = f.block_count + 1;

    # retarget pred's CBR edge to succ so it now jumps to B, and replace succ's
    # predecessor entry for pred with B. both blocks are re-fetched by id since
    # the growth above may have moved the array.
    retarget_cbr(mir_block_by_id(f, pred_id), succ_id, new_id);
    replace_pred(mir_block_by_id(f, succ_id), pred_id, new_id);

    ret R.ok[*mir.MirBlock, str](?f.blocks[f.block_count - 1]);
}

# rewrite every block-target operand of `mb`'s terminator from `from` to `to`
#
# Used to redirect a conditional branch's edge through a freshly split block.
# ---
# mb:   the block whose terminator is rewritten; nil and empty blocks are no-ops
# from: the block id to replace
# to:   the replacement block id
fun retarget_cbr(mb: *mir.MirBlock, from: u32, to: u32) {
    if (mb == nil || mb.instr_count == 0) { ret; }
    val term: *mir.MirInstr = ?mb.instrs[mb.instr_count - 1];
    var i: u32 = 0;
    for (i < term.operand_count) {
        if (term.operands[i].kind == mir.MIR_OP_BLOCK && term.operands[i].imm::u32 == from) {
            term.operands[i].imm = to::i64;
        }
        i = i + 1;
    }
}

# replace the first predecessor entry of `mb` equal to `from` with `to`
#
# A split block thereby takes over the original predecessor's edge.
# ---
# mb:   the block whose predecessor list is rewritten; nil is a no-op
# from: the predecessor id to replace
# to:   the replacement predecessor id
fun replace_pred(mb: *mir.MirBlock, from: u32, to: u32) {
    if (mb == nil) { ret; }
    var i: u32 = 0;
    for (i < mb.pred_count) {
        if (mb.preds[i] == from) { mb.preds[i] = to; ret; }
        i = i + 1;
    }
}

# lower one IR instruction into one or more MIR instructions
#
# OP_CALL expands into argument / call / result pseudos; OP_PHI is skipped here
# (phis are eliminated out of SSA by `lower_phis` into predecessor-end copies,
# never as body instructions); the memory opcodes (alloca / load / store / gep)
# have dedicated lowerings that form the stack slot and the `[base + disp]` memory
# operands the slot model resolves; every other opcode maps 1:1 to its generic
# MIR opcode.
# ---
# ctx: the per-function lowering context
# fn:  the IR function owning the instruction
# mb:  the destination MIR block
# iid: the IR instruction id to lower
# ret: true on success, or a lowering / allocation error
fun lower_instr(ctx: *lctx.LowerCtx, fn: *ir.Function, mb: *mir.MirBlock, iid: id.InstructionId) R.Result[bool, str] {
    val gi: O.Option[*instr.Instruction] = ir.instruction_get(fn, iid);
    if (!O.is_some[*instr.Instruction](gi)) {
        ret R.err[bool, str]("mir.lower_ir: dangling instruction id");
    }
    val inst: *instr.Instruction = O.unwrap[*instr.Instruction](gi);

    # stamp the current source location so every MirInstr this instruction lowers to
    # (through `push_instr`) carries its origin for the debug line table.
    ctx.cur_loc = inst.loc;

    if (inst.kind == instr.OP_CALL) {
        ret mabi.lower_call(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_RET) {
        ret mabi.lower_ret(ctx, mb, inst);
    }
    # phis live in `blk.phis`, never the body list, and are eliminated by
    # `lower_phis`; should one appear here, it is not a body instruction to emit.
    if (inst.kind == instr.OP_PHI) {
        ret R.ok[bool, str](true);
    }
    # OP_DBG_VALUE is pure debug metadata (present only under -g); it lowers to no
    # machine code, so builds with and without debug info emit identical text.
    if (inst.kind == instr.OP_DBG_VALUE) {
        ret R.ok[bool, str](true);
    }
    if (inst.kind == instr.OP_ALLOCA) {
        ret lower_alloca(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_LOAD) {
        ret lower_load(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_STORE) {
        ret lower_store(ctx, mb, inst);
    }
    if (inst.kind == instr.OP_MEMZERO) {
        ret lower_memzero(ctx, mb, inst);
    }
    if (inst.kind == instr.OP_GEP) {
        ret lower_gep(ctx, mb, inst, iid);
    }
    # scalar floating-point arithmetic / comparison shares the IR integer opcodes
    # (the front end emits OP_ADD / OP_SUB / OP_MUL / OP_DIV_* / OP_CMP_* for both
    # int and float operands). a float instruction is dispatched to the dedicated
    # SSE lowering before the integer division / shift / generic paths, which would
    # emit the integer ALU / IDIV byte forms and silently miscompile an XMM-classed
    # value.
    if (is_float_op(ctx, inst)) {
        ret lower_float_op(ctx, mb, inst, iid);
    }
    # a scalar float negate shares the IR integer OP_NEG opcode; routing it to the
    # integer path would emit a GP mir.MIR_NEG (two's-complement of the float bit
    # pattern) instead of flipping the IEEE-754 sign bit. dispatch a float-typed
    # negate to its dedicated SSE lowering before the generic path.
    if (inst.kind == instr.OP_NEG && lctx.value_is_float(ctx, inst.ty)) {
        ret lower_float_neg(ctx, mb, inst, iid);
    }
    # integer division / remainder needs the dividend / remainder register wiring
    # the active ISA's division form mandates (x86-64 IDIV/DIV reads the dividend
    # in RAX and yields the quotient in RAX / remainder in RDX). the accumulator
    # and high-half registers come from `tgt.arch.div_reg` / `div_hi_reg`; an ISA
    # whose division wires no fixed register reports -1 and `lower_div` errors
    # loudly rather than emitting an un-pre-colored divide.
    if (inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_DIV_U ||
        inst.kind == instr.OP_REM_S || inst.kind == instr.OP_REM_U) {
        ret lower_div(ctx, mb, inst, iid);
    }

    # a shift (SHL / SHR_S / SHR_U): an ISA whose variable-shift form hard-wires the
    # count register (x86-64 CL) pre-colors a runtime count into `tgt.arch.shift_count_reg`;
    # an ISA wiring no fixed shift-count register (-1, e.g. AArch64 LSLV/LSRV/ASRV)
    # passes the count straight through to the three-address register-shift form.
    if (inst.kind == instr.OP_SHL || inst.kind == instr.OP_SHR_S ||
        inst.kind == instr.OP_SHR_U) {
        ret lower_shift(ctx, mb, inst, iid);
    }

    # an inline-asm block carries its body + `{name}` bindings in `fn.asm_blocks`
    # keyed by this instruction id; build the mir.MIR_ASM payload (resolving each
    # `{name}`'s alloca to its slot vreg) rather than dropping it through the
    # generic path, which keeps no asm field.
    if (inst.kind == instr.OP_ASM) {
        ret lower_asm_instr(ctx, mb, iid);
    }

    # a conditional branch whose condition lowers to a constant immediate (a
    # comptime-known / folded boolean) cannot drive the encoder's `TEST cond, cond`,
    # which requires a register. mirror cmach (`emit_cmp_branch` -> `load_operand`):
    # materialize the immediate into a register first, then branch on it.
    if (inst.kind == instr.OP_CBR) {
        ret lower_cbr(ctx, mb, inst, iid);
    }

    ret lower_generic(ctx, mb, inst, iid);
}

# lower an IR OP_CBR into a `mir.MIR_CBR [cond, then, else]`
#
# The IR operands are `[cond, then_block, else_block]`; the then/else targets ride
# as mir.MIR_OP_BLOCK operands (per `lctx.lower_operand`). The condition is
# normally a register-resident boolean and lowers to a vreg operand, used
# unchanged. When the condition is a constant - a comptime-known / folded boolean
# reaching the back end as a VAL_CONST_INT - it lowers to a mir.MIR_OP_IMM, which
# the encoder's `TEST cond, cond` cannot read. Mirror cmach's `emit_cmp_branch`,
# which routes the condition through `load_operand` (emitting `MOV reg, imm` for an
# immediate): materialize the immediate into a fresh GP vreg via
# `mir.MIR_MOV reg <- imm`, then branch on the register so the encoder always sees
# a register condition.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_CBR instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_cbr(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count < 3) {
        ret R.err[bool, str]("mir.lower_ir: conditional branch missing operands");
    }

    var cond: mir.MirOperand = lctx.lower_operand(ctx, inst, 0);
    if (cond.kind == mir.MIR_OP_IMM) {
        val rv: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](rv)) { ret R.err[bool, str](R.unwrap_err[u32, str](rv)); }
        val creg: u32 = R.unwrap_ok[u32, str](rv);
        val mv: R.Result[bool, str] = lctx.emit_mov(ctx, mb, mir.op_vreg(creg), cond);
        if (R.is_err[bool, str](mv)) { ret mv; }
        cond = mir.op_vreg(creg);
    }

    val rop: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (R.is_err[*mir.MirOperand, str](rop)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = cond;
    ops[1] = lctx.lower_operand(ctx, inst, 1);
    ops[2] = lctx.lower_operand(ctx, inst, 2);

    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 3;
    set_generic_widths(ctx, inst, ?mi);
    # a conditional branch tests its boolean condition, but a bare bool value (e.g.
    # a struct's `tag` field) reaches the encoder in a register's low byte WITHOUT
    # being zero-extended - only a comparison result is widened by its MOVZX. test
    # the condition at its own width (1 byte for a bool, set_generic_widths leaves a
    # terminator at the machine word), so `TEST` reads only the meaningful low byte
    # instead of stale upper bits a full-width test would misread as a set condition.
    mi.width = lctx.op_width_of(ctx, inst.operands[0].ty);
    ret lctx.push_instr(ctx, mb, mi);
}

# build "<prefix><name><suffix>" naming an inline-asm bind, interned to outlive the call
#
# Resolves the bind's interned name through the context interner. Degrades to
# `fallback` on any failure.
# ---
# ctx:      the per-function lowering context
# prefix:   text placed before the resolved name
# name_id:  interned id of the bind name
# suffix:   text placed after the resolved name
# fallback: returned verbatim on any lookup / allocation / intern failure
# ret:      the interned composed message, or `fallback`
fun asm_bind_message(ctx: *lctx.LowerCtx, prefix: str, name_id: intern.StrId, suffix: str, fallback: str) str {
    val no: O.Option[str] = intern.lookup(ctx.interner, name_id);
    if (O.is_none[str](no)) { ret fallback; }
    val nm: str = O.unwrap[str](no);

    val total: usize = str_len(prefix) + str_len(nm) + str_len(suffix);
    val r: R.Result[*u8, str] = A.allocate[u8](ctx.alloc, total + 1);
    if (R.is_err[*u8, str](r)) { ret fallback; }
    val buf: *u8 = R.unwrap_ok[*u8, str](r);
    var k: usize = 0;
    var j: usize = 0;
    for (j < str_len(prefix)) { buf[k] = prefix[j]; k = k + 1; j = j + 1; }
    j = 0;
    for (j < str_len(nm)) { buf[k] = nm[j]; k = k + 1; j = j + 1; }
    j = 0;
    for (j < str_len(suffix)) { buf[k] = suffix[j]; k = k + 1; j = j + 1; }
    buf[total] = 0;

    val ir: R.Result[intern.StrId, str] = intern.intern(ctx.interner, buf::str);
    A.deallocate[u8](ctx.alloc, buf, total + 1);
    if (R.is_err[intern.StrId, str](ir)) { ret fallback; }
    val rn: O.Option[str] = intern.lookup(ctx.interner, R.unwrap_ok[intern.StrId, str](ir));
    if (O.is_some[str](rn)) { ret O.unwrap[str](rn); }
    ret fallback;
}

# build a mir.MIR_ASM instruction from the IR `IrAsm` payload bound to this OP_ASM id
#
# Resolves the interned ISA / body strings to text and maps each `{name}`
# binding's alloca instruction id to the slot-owning vreg the encoder later turns
# into `[rbp + off]`. The payload is heap-owned and freed by `dnit_instr`.
# ---
# ctx: the per-function lowering context
# mb:  the destination MIR block
# iid: the IR OP_ASM instruction id, keying `fn.asm_blocks`
# ret: true on success, or a lowering / allocation error
fun lower_asm_instr(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, iid: id.InstructionId) R.Result[bool, str] {
    var key: id.InstructionId = iid;
    val pr: R.Result[*ir.IrAsm, str] = map.get[id.InstructionId, ir.IrAsm](?ctx.fn.asm_blocks, ?key);
    if (R.is_err[*ir.IrAsm, str](pr)) {
        ret R.err[bool, str]("mir.lower_ir: OP_ASM instruction has no asm payload");
    }
    val src: *ir.IrAsm = R.unwrap_ok[*ir.IrAsm, str](pr);

    val isa_opt: O.Option[str] = intern.lookup(ctx.interner, src.isa);
    if (!O.is_some[str](isa_opt)) { ret R.err[bool, str]("mir.lower_ir: inline-asm ISA tag not interned"); }
    val body_opt: O.Option[str] = intern.lookup(ctx.interner, src.body);
    if (!O.is_some[str](body_opt)) { ret R.err[bool, str]("mir.lower_ir: inline-asm body not interned"); }

    val rp: R.Result[*mir.MirAsm, str] = A.allocate[mir.MirAsm](ctx.alloc, 1::usize);
    if (R.is_err[*mir.MirAsm, str](rp)) { ret R.err[bool, str](R.unwrap_err[*mir.MirAsm, str](rp)); }
    val payload: *mir.MirAsm = R.unwrap_ok[*mir.MirAsm, str](rp);
    payload.isa        = O.unwrap[str](isa_opt);
    payload.body       = O.unwrap[str](body_opt);
    payload.binds      = nil;
    payload.bind_count = 0;

    if (src.bind_count > 0) {
        val rb: R.Result[*mir.MirAsmBind, str] = A.allocate[mir.MirAsmBind](ctx.alloc, src.bind_count::usize);
        if (R.is_err[*mir.MirAsmBind, str](rb)) {
            A.deallocate[mir.MirAsm](ctx.alloc, payload, 1::usize);
            ret R.err[bool, str](R.unwrap_err[*mir.MirAsmBind, str](rb));
        }
        payload.binds = R.unwrap_ok[*mir.MirAsmBind, str](rb);
        var k: u32 = 0;
        for (k < src.bind_count) {
            # a `{name}` local is the addressable storage behind an alloca; bind
            # to its slot-key vreg (which owns the frame slot) when the referenced
            # instruction is an alloca, else to the value's own vreg.
            var vreg: u32 = lctx.slot_key_vreg(ctx, src.binds[k].instr);
            if (vreg == mir.MIR_VREG_NIL) { vreg = lctx.instr_vreg(ctx, src.binds[k].instr); }
            if (vreg == mir.MIR_VREG_NIL) {
                val msg: str = asm_bind_message(ctx, "inline-asm local '", src.binds[k].name, "' has no addressable storage slot", "inline-asm local has no addressable storage slot");
                A.deallocate[mir.MirAsmBind](ctx.alloc, payload.binds, src.bind_count::usize);
                A.deallocate[mir.MirAsm](ctx.alloc, payload, 1::usize);
                ret R.err[bool, str](msg);
            }
            payload.binds[k].name      = src.binds[k].name;
            payload.binds[k].slot_vreg = vreg;
            k = k + 1;
        }
        payload.bind_count = src.bind_count;
    }

    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_ASM;
    mi.operands      = nil;
    mi.operand_count = 0;
    mi.width         = 0;
    mi.src_width     = 0;
    mi.asm_block     = payload;

    val push: R.Result[bool, str] = lctx.push_instr(ctx, mb, mi);
    if (R.is_err[bool, str](push)) {
        if (payload.binds != nil) { A.deallocate[mir.MirAsmBind](ctx.alloc, payload.binds, payload.bind_count::usize); }
        A.deallocate[mir.MirAsm](ctx.alloc, payload, 1::usize);
        ret push;
    }
    ret R.ok[bool, str](true);
}

# lower an integer OP_SHL / OP_SHR_S / OP_SHR_U into a three-address generic shift
#
# Emits `mir.MIR_SHL/SHR_S/SHR_U [dst, value, count]`. The IR operands are
# `[value, count]`. Operand 0 (`dst`) is a pure def, so the register allocator
# treats it cleanly (the encoder materializes the two-address
# `MOV dst, value ; shift dst, count` byte form). A constant count rides as an
# immediate; a runtime count is pre-colored into RCX (the only register the x86-64
# variable-shift form reads, as CL) by a preceding `mir.MIR_MOV RCX <- count`,
# mirroring the division's RAX:RDX pre-coloring. A function with a register-count
# shift reserves RCX from allocation (see `regalloc.function_has_reg_shift`) so no
# live value collides with the count.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR shift instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_shift(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count < 2) {
        ret R.err[bool, str]("mir.lower_ir: shift missing value or count operand");
    }
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: shift defines no result vreg");
    }
    # a sub-word shift result, like any narrow GP ALU write, leaves the upper
    # register bits undefined; clamp the operation width so the spilled word stays
    # clean (mirrors `set_generic_widths` and the byte-divide promotion).
    val w: u8 = lctx.clamp_alu_width(lctx.op_width_of(ctx, inst.ty));

    var op: mir.MirOpcode = mir.MIR_SHR_U;
    if (inst.kind == instr.OP_SHL)   { op = mir.MIR_SHL; }
    or (inst.kind == instr.OP_SHR_S) { op = mir.MIR_SHR_S; }

    val value: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    val count: mir.MirOperand = lctx.lower_value(ctx, inst.operands[1]);

    var count_op: mir.MirOperand = count;
    if (count.kind != mir.MIR_OP_IMM) {
        # an ISA whose variable-shift form hard-wires the count register (x86-64 CL,
        # `shift_count_reg >= 0`) pre-colors the runtime count into it and references it
        # so the encoder selects the `shift r/m, CL` form; the register is reserved from
        # allocation for the whole function, so the move cannot clobber a live value. an
        # ISA wiring no fixed shift-count register (`shift_count_reg < 0`, e.g. AArch64
        # LSLV/LSRV/ASRV, which read the count from any GP register) passes the count
        # straight through to the three-address register-shift form - mirroring the
        # division's `div_reg < 0` three-address path.
        val cnt_reg: i32 = ctx.tgt.arch.shift_count_reg;
        if (cnt_reg >= 0) {
            val mc: R.Result[bool, str] = lctx.emit_mov_w(ctx, mb, mir.op_preg(cnt_reg::u32), count, w);
            if (R.is_err[bool, str](mc)) { ret mc; }
            count_op = mir.op_preg(cnt_reg::u32);
        }
    }

    # the three-address shift: operand 0 is the pure-def destination, operand 1 the
    # value shifted, operand 2 the count (immediate or CL). the opcode survives isel.
    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = value;
    ops[2] = count_op;
    var mi: mir.MirInstr;
    mi.opcode        = op;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower an integer OP_DIV_* / OP_REM_*
#
# An ISA whose division form
# hard-wires the dividend / quotient accumulator and the high-half / remainder
# register (`div_reg >= 0`, x86-64 RAX:RDX) takes the pre-coloring path below; an ISA
# that wires no fixed division register (`div_reg < 0`, e.g. AArch64 SDIV/UDIV, which
# write a normal destination register) takes the generic three-address path
# (`lower_div_three_address`).
#
# the pre-coloring path lowers into the x86-64 RAX:RDX division sequence with explicit
# register pre-coloring, mirroring the call/return ABI
# pre-coloring approach. the IR operands are `[a, b]` (dividend, divisor). the
# emitted sequence is, in order:
#   - `mir.MIR_MOV RAX <- a` - the dividend occupies the accumulator;
#   - the divide pseudo `mir.MIR_DIV_S/DIV_U/REM_S/REM_U [RAX, b]` - operand 0 is the
#     implicit RAX dividend/result register (so the register allocator reads a
#     non-defining barrier whose operand 1 is the divisor use), operand 1 is the
#     divisor `b`. the opcode survives instruction selection unchanged; the encoder
#     materializes the dividend high-half setup (CWD/CDQ/CQO sign-extension for the
#     signed forms, `XOR RDX, RDX` zero-extension for the unsigned forms) followed
#     by the single-operand `IDIV b` / `DIV b`;
#   - `mir.MIR_MOV dst <- RAX` for a division, or `mir.MIR_MOV dst <- RDX` for a remainder
#     - the quotient lands in RAX and the remainder in RDX.
# the divide clobbers RAX and RDX; regalloc keeps both out of allocation for any
# function that divides (they are caller-saved, so no prologue cost), so no live
# value or the divisor `b` can collide with the dividend wiring. the operation
# width (2/4/8 bytes - a byte divide is promoted to 32 bits below) is carried on
# the divide so the encoder selects the matching sign-extension opcode and sets
# REX.W / the 0x66 prefix.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR division / remainder instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_div(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count < 2) {
        ret R.err[bool, str]("mir.lower_ir: division missing dividend or divisor operand");
    }
    # floating-point division never reaches here: `lower_instr` dispatches every
    # float arithmetic / comparison op to `lower_float_op` (which emits mir.MIR_FDIV)
    # before this integer-division path.
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: division defines no result vreg");
    }
    # the ISA's division form hard-wires the dividend / quotient accumulator and the
    # high-half / remainder register (x86-64 RAX:RDX). an ISA wiring no fixed
    # division register (`div_reg < 0` / `div_hi_reg < 0`, e.g. AArch64 SDIV/UDIV)
    # lowers to the generic three-address divide the per-ISA encoder realizes, rather
    # than this pre-coloring path.
    val acc_reg: i32 = ctx.tgt.arch.div_reg;
    val hi_reg:  i32 = ctx.tgt.arch.div_hi_reg;
    if (acc_reg < 0 || hi_reg < 0) {
        ret lower_div_three_address(ctx, mb, inst, iid, dst);
    }
    val signed: bool = inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_REM_S;

    # x86-64 has no 8-bit dividend high register (a byte divide puts the dividend
    # in AX and the remainder in AH, not RDX), so a byte division is promoted to a
    # 32-bit divide: both operands are extended to 32 bits, the divide runs at
    # width 4 (remainder in EDX, quotient in EAX), and the result move truncates
    # back to the byte destination. 16/32/64-bit divisions run at their natural
    # width with the remainder in (R)DX.
    val natural_w: u8 = lctx.op_width_of(ctx, inst.ty);
    var w: u8 = natural_w;
    if (w < 4) { w = 4; }

    val dividend: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    val divisor:  mir.MirOperand = lctx.lower_value(ctx, inst.operands[1]);

    # the dividend occupies the accumulator (x86-64 RAX) before the divide. a
    # promoted byte dividend is widened into it; otherwise it is a plain width-w move.
    val mr: R.Result[bool, str] = emit_promote(ctx, mb, mir.op_preg(acc_reg::u32), dividend, w, natural_w, signed);
    if (R.is_err[bool, str](mr)) { ret mr; }

    # the divisor must live in a register or memory - x86-64 IDIV / DIV has no
    # immediate divisor form - so an immediate divisor is materialized into a fresh
    # value vreg. a promoted byte divisor is likewise widened into a fresh vreg. a
    # register / memory divisor at the natural width is used directly.
    var div_op: mir.MirOperand = divisor;
    if (natural_w < w || divisor.kind == mir.MIR_OP_IMM) {
        val bvr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](bvr)) { ret R.err[bool, str](R.unwrap_err[u32, str](bvr)); }
        val bv: u32 = R.unwrap_ok[u32, str](bvr);
        val ex: R.Result[bool, str] = emit_promote(ctx, mb, mir.op_vreg(bv), divisor, w, natural_w, signed);
        if (R.is_err[bool, str](ex)) { ret ex; }
        div_op = mir.op_vreg(bv);
    }

    # the divide itself: operand 0 is the implicit accumulator dividend/result
    # register (x86-64 RAX) and operand 1 is the divisor. the opcode survives
    # instruction selection; the encoder materializes the high-half setup + IDIV/DIV.
    val rop: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](rop)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_preg(acc_reg::u32);
    ops[1] = div_op;
    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    val pd: R.Result[bool, str] = lctx.push_instr(ctx, mb, mi);
    if (R.is_err[bool, str](pd)) { ret pd; }

    # the quotient lands in the accumulator (x86-64 RAX) and the remainder in the
    # high-half register (RDX); move the canonical result register into the result
    # vreg. the move is driven at the destination's natural width, truncating a
    # promoted byte result.
    var res_reg: i32 = acc_reg;
    if (inst.kind == instr.OP_REM_S || inst.kind == instr.OP_REM_U) {
        res_reg = hi_reg;
    }
    ret lctx.emit_mov_w(ctx, mb, mir.op_vreg(dst), mir.op_preg(res_reg::u32), natural_w);
}

# lower an integer division / remainder on an ISA with no fixed division register
#
# For an ISA wiring no fixed division register (`div_reg < 0`, e.g. AArch64
# SDIV/UDIV, which write a normal destination register), emits a clean
# three-address divide `[dst, dividend, divisor]` carrying the OP_DIV_* / OP_REM_*
# kind and the operation width; instruction selection rewrites it to the per-ISA
# selection-output sentinel and the encoder materializes the quotient / remainder
# plus the defined division-by-zero and signed-overflow traps. Operand 0 is a pure
# def the register allocator reads directly (no RAX/RDX pre-coloring). Mirrors the
# pre-coloring path's operand handling - a narrower-than-32-bit operand is promoted
# to the divide width (the encoder's divides have only 32- and 64-bit forms) and an
# immediate operand is materialized into a value vreg (so both operands reach the
# divide in a register, which the SDIV/UDIV and the trap checks require; a
# constant-zero divisor thus lands in a register and still traps). The destination
# IS the divide result, so a promoted narrow result needs no truncating move (a
# consumer reads its low bytes).
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR division / remainder instruction
# iid:  the IR instruction id
# dst:  the result vreg, already resolved by the caller
# ret:  true on success, or a lowering / allocation error
fun lower_div_three_address(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction,
                            iid: id.InstructionId, dst: u32) R.Result[bool, str] {
    val signed: bool = inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_REM_S;

    val natural_w: u8 = lctx.op_width_of(ctx, inst.ty);
    var w: u8 = natural_w;
    if (w < 4) { w = 4; }

    val dividend: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    val divisor:  mir.MirOperand = lctx.lower_value(ctx, inst.operands[1]);

    # the dividend reaches the divide in a register at the divide width: a promoted
    # narrow value is widened into a fresh vreg, an immediate is materialized into one,
    # and a register already at the divide width is used directly.
    var n_op: mir.MirOperand = dividend;
    if (natural_w < w || dividend.kind == mir.MIR_OP_IMM) {
        val nvr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](nvr)) { ret R.err[bool, str](R.unwrap_err[u32, str](nvr)); }
        val nv: u32 = R.unwrap_ok[u32, str](nvr);
        val ne: R.Result[bool, str] = emit_promote(ctx, mb, mir.op_vreg(nv), dividend, w, natural_w, signed);
        if (R.is_err[bool, str](ne)) { ret ne; }
        n_op = mir.op_vreg(nv);
    }

    # the divisor likewise reaches the divide in a register at the divide width.
    var m_op: mir.MirOperand = divisor;
    if (natural_w < w || divisor.kind == mir.MIR_OP_IMM) {
        val mvr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](mvr)) { ret R.err[bool, str](R.unwrap_err[u32, str](mvr)); }
        val mv: u32 = R.unwrap_ok[u32, str](mvr);
        val me: R.Result[bool, str] = emit_promote(ctx, mb, mir.op_vreg(mv), divisor, w, natural_w, signed);
        if (R.is_err[bool, str](me)) { ret me; }
        m_op = mir.op_vreg(mv);
    }

    # the three-address divide: operand 0 the pure-def destination, operand 1 the
    # dividend, operand 2 the divisor. the OP_DIV_*/OP_REM_* opcode survives isel
    # (rewritten to the selection-output sentinel) into the encoder.
    val rop: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (R.is_err[*mir.MirOperand, str](rop)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_vreg(dst);
    ops[1] = n_op;
    ops[2] = m_op;
    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;
    ret lctx.push_instr(ctx, mb, mi);
}

# move `src` into `dst` at `dst_w` bytes, widening from `src_w` when narrower
#
# An immediate source carries its full value, so it is a plain width-`dst_w` move
# (a MOVSX/MOVZX of an immediate has no encoding). A register / memory source
# narrower than the destination is sign-extended (`signed`, MOVSX) or
# zero-extended (MOVZX); at equal width it is a plain move. Used to load a
# division's dividend into RAX and to widen a promoted byte divisor into a value
# vreg.
# ---
# ctx:    the per-function lowering context
# mb:     the destination MIR block
# dst:    the destination operand
# src:    the source operand
# dst_w:  the destination width in bytes
# src_w:  the source width in bytes
# signed: true to sign-extend a narrow source, false to zero-extend
# ret:    true on success, or a lowering / allocation error
fun emit_promote(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand,
                 dst_w: u8, src_w: u8, signed: bool) R.Result[bool, str] {
    if (src_w >= dst_w || src.kind == mir.MIR_OP_IMM) {
        ret lctx.emit_mov_w(ctx, mb, dst, src, dst_w);
    }
    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_ZEXT;
    if (signed) { mi.opcode = mir.MIR_SEXT; }
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = dst_w;
    mi.src_width     = src_w;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower a non-call IR instruction by mapping its opcode 1:1 to the generic MIR opcode
#
# Emits `[dst?, operands...]` at the same opcode number. Branch operands that name
# block targets become mir.MIR_OP_BLOCK operands.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR instruction to lower
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_generic(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    # scalar floating-point arithmetic / comparison shares the IR integer opcodes
    # (OP_ADD / OP_SUB / OP_MUL / OP_CMP_* operate on both int and float operands),
    # but a float instruction never reaches here: `lower_instr` dispatches it to
    # `lower_float_op` (emitting the dedicated mir.MIR_FADD / FSUB / FMUL / FDIV / FCMP
    # SSE opcodes) before the generic path. the float CONVERSIONS (FP_TRUNC / FP_EXT
    # / FP_TO_SI / SI_TO_FP / ...) carry their own opcodes and SSE encoders and DO
    # ride this generic path unchanged.
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    val has_dst: bool = dst != mir.MIR_VREG_NIL;
    var total: u32 = inst.operand_count;
    if (has_dst) { total = total + 1; }

    var ops: *mir.MirOperand = nil;
    if (total > 0) {
        val rop: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, total::usize);
        if (R.is_err[*mir.MirOperand, str](rop)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rop)); }
        ops = R.unwrap_ok[*mir.MirOperand, str](rop);
    }

    var base: u32 = 0;
    if (has_dst) {
        ops[0] = mir.op_vreg(dst);
        base = 1;
    }

    var k: u32 = 0;
    for (k < inst.operand_count) {
        var op: mir.MirOperand = lctx.lower_operand(ctx, inst, k);
        # a global / function symbol operand is its ADDRESS as an rvalue; left as a
        # bare mir.MIR_OP_SYM the encoder would load `[sym]` into this ALU / compare /
        # bitcast slot (the symbol's contents) instead of its address. LEA-
        # materialize it into a vreg first, mirroring the store / call-arg / return
        # symbol paths.
        if (op.kind == mir.MIR_OP_SYM) {
            var av: u32 = mir.MIR_VREG_NIL;
            val ar: R.Result[bool, str] = lctx.addr_to_vreg(ctx, mb, op, ?av);
            if (R.is_err[bool, str](ar)) { ret ar; }
            op = mir.op_vreg(av);
        }
        ops[base + k] = op;
        k = k + 1;
    }

    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = total;
    set_generic_widths(ctx, inst, ?mi);
    ret lctx.push_instr(ctx, mb, mi);
}

# derive the destination and source operand widths for a 1:1-lowered instruction
#
# Stamps the widths onto the MIR instruction. The result width is the
# instruction's own result type, except:
#   - a width-changing integer conversion (TRUNC / SEXT / ZEXT) keeps the
#     destination width from the result type but takes its source width from operand
#     0, so the encoder's MOVZX / MOVSX selects the narrow / wide source form;
#   - a comparison (CMP_*) yields an i8 result but the CMP operates at the compared
#     operand width, so both widths come from operand 0;
#   - the float conversions (FP_TO_SI / SI_TO_FP family) carry their true result and
#     operand-0 widths so the SSE conversion encoder selects the SS-vs-SD float form
#     from the float side and sizes the GP integer side for REX.W (`set_conv_widths`);
#   - a void-result terminator / branch has no natural width and rides at the word
#     width, which only sizes its address-sized fields.
# ---
# ctx:  the per-function lowering context
# inst: the source IR instruction
# mi:   the MIR instruction to stamp the widths onto
fun set_generic_widths(ctx: *lctx.LowerCtx, inst: *instr.Instruction, mi: *mir.MirInstr) {
    if (is_float_kind(ctx, inst)) {
        set_conv_widths(ctx, inst, mi);
        ret;
    }
    if (is_compare_kind(inst.kind) && inst.operand_count >= 1) {
        val w: u8 = lctx.op_width_of(ctx, inst.operands[0].ty);
        mi.width     = w;
        mi.src_width = w;
        ret;
    }
    var dw: u8 = ctx.tgt.model.gpr_width::u8;
    if (!instr.is_terminator(inst.kind)) { dw = lctx.op_width_of(ctx, inst.ty); }
    # a register-writing integer ALU result must be defined across the full width
    # it is later spilled / reloaded at, or a sub-word op's undefined upper bits
    # leak through the word-width spill into a downstream full-width use. the
    # conversions are excluded: their destination width selects the MOVZX / MOVSX
    # narrow form and is load-bearing, not a clamp candidate.
    if (is_int_alu_kind(inst.kind)) { dw = lctx.clamp_alu_width(dw); }
    var sw: u8 = dw;
    if (is_int_conversion_kind(inst.kind) && inst.operand_count >= 1) {
        sw = lctx.op_width_of(ctx, inst.operands[0].ty);
    }
    mi.width     = dw;
    mi.src_width = sw;
}

# stamp the destination and source widths of a float conversion
#
# Covers FP_TO_SI / FP_TO_UI / SI_TO_FP / UI_TO_FP / FP_TRUNC / FP_EXT. `mi.width`
# is the result-type width and `mi.src_width` is operand 0's width. The SSE
# conversion encoder reads the FLOAT side of the pair (the side whose type is f32 /
# f64, determined from the concrete opcode) to pick the single-precision SS vs
# double SD form, and sizes the GP integer side from its own width for REX.W. An
# FP_TRUNC / FP_EXT has float on both sides; its single opcode needs no width
# selection, so the carried widths only document the operand sizes.
# ---
# ctx:  the per-function lowering context
# inst: the source IR conversion instruction
# mi:   the MIR instruction to stamp the widths onto
fun set_conv_widths(ctx: *lctx.LowerCtx, inst: *instr.Instruction, mi: *mir.MirInstr) {
    var dw: u8 = lctx.op_width_of(ctx, inst.ty);
    var sw: u8 = dw;
    if (inst.operand_count >= 1) { sw = lctx.op_width_of(ctx, inst.operands[0].ty); }
    mi.width     = dw;
    mi.src_width = sw;
}

# true for the integer arithmetic / bitwise opcodes materialized by a GP ALU write
#
# Covers ADD / SUB / MUL / NEG / AND / OR / XOR / NOT and the shifts. A sub-word
# write of one of these leaves the upper register bits undefined, so its result
# width is clamped to `mir.ALU_MIN_WIDTH`. The divisions are excluded - `lower_div`
# already promotes a byte divide to 32 bits.
# ---
# k:   the IR instruction kind to test
# ret: true for an integer ALU / bitwise / shift opcode
fun is_int_alu_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_ADD || k == instr.OP_SUB || k == instr.OP_MUL ||
        k == instr.OP_NEG || k == instr.OP_AND || k == instr.OP_OR ||
        k == instr.OP_XOR || k == instr.OP_NOT ||
        k == instr.OP_SHL || k == instr.OP_SHR_S || k == instr.OP_SHR_U;
}

# true for the IR comparison opcodes whose CMP operates at the operand width
#
# The compare runs at the operand width rather than the i8 result width.
# ---
# k:   the IR instruction kind to test
# ret: true for a comparison opcode
fun is_compare_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_CMP_EQ || k == instr.OP_CMP_NE ||
        k == instr.OP_CMP_LT_S || k == instr.OP_CMP_LT_U ||
        k == instr.OP_CMP_LE_S || k == instr.OP_CMP_LE_U;
}

# true for the width-changing integer conversions (TRUNC / SEXT / ZEXT)
#
# Their source operand width differs from the destination width, so the encoder
# must size the source operand independently. The float conversions are excluded -
# their operand widths are driven by the float encoders.
# ---
# k:   the IR instruction kind to test
# ret: true for an integer conversion opcode
fun is_int_conversion_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_TRUNC || k == instr.OP_SEXT || k == instr.OP_ZEXT;
}

# true for a scalar float arithmetic / comparison sharing an IR integer opcode
#
# Covers OP_ADD / OP_SUB / OP_MUL / OP_DIV_* and OP_CMP_*. These select to SSE
# forms in `lower_float_op` rather than the integer ALU / IDIV / CMP byte forms,
# which would miscompile an XMM-classed value. The float CONVERSIONS (FP_TRUNC /
# FP_EXT / FP_TO_SI / FP_TO_UI / SI_TO_FP / UI_TO_FP) carry their own opcodes and
# SSE encoders and ride the generic path, so they are NOT claimed here. An op is
# float when its result or first operand is a float type.
# ---
# ctx:  the per-function lowering context
# inst: the IR instruction to test
# ret:  true for a float-typed arithmetic / comparison op
fun is_float_op(ctx: *lctx.LowerCtx, inst: *instr.Instruction) bool {
    val k: instr.InstrKind = inst.kind;
    var shared: bool = false;
    if (k == instr.OP_ADD || k == instr.OP_SUB || k == instr.OP_MUL ||
        k == instr.OP_DIV_S || k == instr.OP_DIV_U) { shared = true; }
    if (is_compare_kind(k))                                                       { shared = true; }
    if (!shared)                                                                  { ret false; }
    if (lctx.value_is_float(ctx, inst.ty))                                        { ret true; }
    if (inst.operand_count >= 1 && lctx.value_is_float(ctx, inst.operands[0].ty)) { ret true; }
    ret false;
}

# the SSE operation width (4 for f32, 8 for f64) of a float arithmetic / comparison
#
# An arithmetic op takes it from its own float result type; a comparison's result
# is i8, so it takes the width from the compared float operand (operand 0).
# ---
# ctx:  the per-function lowering context
# inst: the IR float arithmetic / comparison instruction
# ret:  the SSE operation width in bytes
fun float_op_width(ctx: *lctx.LowerCtx, inst: *instr.Instruction) u8 {
    if (is_compare_kind(inst.kind) && inst.operand_count >= 1) {
        ret lctx.op_width_of(ctx, inst.operands[0].ty);
    }
    ret lctx.op_width_of(ctx, inst.ty);
}

# the FCC_* float-comparison condition code realizing an IR compare opcode
#
# The front end emits only the EQ / NE / LT / LE forms (GT / GE are canonicalized
# to LT / LE with swapped operands), and a float compare is unordered-aware via
# UNSIGNED SETcc, so signedness is irrelevant: OP_CMP_LT_S and OP_CMP_LT_U both
# map to mir.FCC_LT.
# ---
# k:   the IR comparison opcode
# ret: the matching FCC_* float condition code
fun float_cmp_cc(k: instr.InstrKind) u8 {
    if (k == instr.OP_CMP_EQ)                             { ret mir.FCC_EQ; }
    if (k == instr.OP_CMP_NE)                             { ret mir.FCC_NE; }
    if (k == instr.OP_CMP_LT_S || k == instr.OP_CMP_LT_U) { ret mir.FCC_LT; }
    ret mir.FCC_LE;
}

# lower a scalar float arithmetic / comparison to its dedicated SSE MIR opcode
#
# Emits mir.MIR_FADD / FSUB / FMUL / FDIV for the four arithmetic ops, or
# mir.MIR_FCMP for a comparison. The opcode survives instruction selection and the
# encoder materializes the SSE byte sequence (operands loaded into XMM scratch, the
# SSE op, the result stored back) - mirroring cmach's `emit_float_op` /
# `emit_float_cmp`. The operation width (4 for f32, 8 for f64) rides on `mi.width`
# so the encoder selects the SS vs SD form; a mir.MIR_FCMP also carries its FCC_*
# condition on `mi.src_width`. The layout is `[dst, lhs, rhs]` like the generic
# three-address ALU / compare forms.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR float arithmetic / comparison instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_float_op(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count < 2) {
        ret R.err[bool, str]("mir.lower_ir: float op missing operand");
    }
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: float op defines no result vreg");
    }

    val rop: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (R.is_err[*mir.MirOperand, str](rop)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_vreg(dst);
    ops[1] = lctx.lower_value(ctx, inst.operands[0]);
    ops[2] = lctx.lower_value(ctx, inst.operands[1]);

    val w: u8 = float_op_width(ctx, inst);

    var mi: mir.MirInstr;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;

    val k: instr.InstrKind = inst.kind;
    if (is_compare_kind(k)) {
        mi.opcode    = mir.MIR_FCMP;
        mi.src_width = float_cmp_cc(k);
    } or (k == instr.OP_ADD) {
        mi.opcode = mir.MIR_FADD;
    } or (k == instr.OP_SUB) {
        mi.opcode = mir.MIR_FSUB;
    } or (k == instr.OP_MUL) {
        mi.opcode = mir.MIR_FMUL;
    } or {
        mi.opcode = mir.MIR_FDIV;
    }

    ret lctx.push_instr(ctx, mb, mi);
}

# lower a scalar float negation (a float-typed OP_NEG) to the dedicated mir.MIR_FNEG
#
# The opcode survives instruction selection and the encoder flips the IEEE-754 sign
# bit on the XMM value (XORPS with a width-selected sign mask) rather than the
# integer mir.MIR_NEG, which would two's-complement the whole bit pattern and
# produce garbage. Operand layout is `[dst, src]` like a float MOV; the operation
# width (4 for f32, 8 for f64) rides on `mi.width` so the encoder selects the f32
# vs f64 sign-bit mask.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR float negate instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_float_neg(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count < 1) {
        ret R.err[bool, str]("mir.lower_ir: float negate missing operand");
    }
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: float negate defines no result vreg");
    }

    val rop: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](rop)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_vreg(dst);
    ops[1] = lctx.lower_value(ctx, inst.operands[0]);

    val w: u8 = lctx.op_width_of(ctx, inst.ty);

    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_FNEG;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    ret lctx.push_instr(ctx, mb, mi);
}

# true when an instruction's width is driven by the float encoders
#
# True when the result or first operand is a float, or the opcode is a float
# conversion, so its width must not be re-sized by the integer base-width carrier.
# The float conversions, scalar float arithmetic, and float comparisons all reach
# lowering through the generic path.
# ---
# ctx:  the per-function lowering context
# inst: the IR instruction to test
# ret:  true when the instruction's width is float-driven
fun is_float_kind(ctx: *lctx.LowerCtx, inst: *instr.Instruction) bool {
    if (inst.kind == instr.OP_FP_TO_SI || inst.kind == instr.OP_FP_TO_UI ||
        inst.kind == instr.OP_SI_TO_FP || inst.kind == instr.OP_UI_TO_FP ||
        inst.kind == instr.OP_FP_TRUNC || inst.kind == instr.OP_FP_EXT) {
        ret true;
    }
    if (lctx.value_is_float(ctx, inst.ty))                                        { ret true; }
    if (inst.operand_count >= 1 && lctx.value_is_float(ctx, inst.operands[0].ty)) { ret true; }
    ret false;
}

# lower an OP_ALLOCA into a stack-slot reservation plus address materialization
#
# The instruction's `aux_ty` is the allocated ELEMENT type (the result type and
# Value are the untyped pointer); operand 0 is the element count. A fresh internal
# slot-key vreg owns a mir.SLOT_ALLOCA frame slot sized `element_size * count` and
# is used only as the LEA base, so regalloc never register-allocates it and the
# encoder resolves it to `[rbp + offset]`. The emitted
# `mir.MIR_ALLOCA (result) <- [slot]` selects to `LEA result, [rbp + offset]`,
# leaving the allocation's address in the result vreg as an ordinary pointer for
# downstream uses.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_ALLOCA instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_alloca(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count == 0) {
        ret R.err[bool, str]("mir.lower_ir: alloca with no count operand");
    }
    val cv: value.Value = inst.operands[0];
    if (cv.kind != value.VAL_CONST_INT) {
        ret R.err[bool, str]("variable-length alloca is not supported; use a constant size");
    }
    val count: u64 = cv.data.int_lit;

    # the element type rides on `aux_ty`; size and align the slot from it. the
    # allocated region is `count` contiguous elements.
    val elem_size: u32  = ir_type.byte_size(ctx.types, inst.aux_ty, ctx.tgt);
    val elem_align: u32 = ir_type.byte_align(ctx.types, inst.aux_ty, ctx.tgt);
    val total: u64 = elem_size::u64 * count;

    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: alloca defines no result vreg");
    }

    # an internal slot-key vreg owns the storage; it is addressed only as a MEM
    # base, never register-allocated.
    val skr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (R.is_err[u32, str](skr)) { ret R.err[bool, str](R.unwrap_err[u32, str](skr)); }
    val sk: u32 = R.unwrap_ok[u32, str](skr);

    val ar: R.Result[bool, str] = lctx.add_alloca_slot(ctx, sk, total, elem_align);
    if (R.is_err[bool, str](ar)) { ret ar; }

    # record the slot-key vreg under this alloca's instruction id so an
    # inline-asm `{name}` binding referencing the alloca resolves to its slot.
    if (ctx.slot_key_vregs != nil && iid::u32 < ctx.instr_count) {
        ctx.slot_key_vregs[iid::u32] = sk;
    }

    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = mir.op_mem_slot(sk, 0);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_ALLOCA;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the alloca selects to a LEA computing a pointer-sized address.
    mi.width         = ctx.tgt.model.gpr_width::u8;
    mi.src_width     = ctx.tgt.model.gpr_width::u8;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower an OP_LOAD into `mir.MIR_LOAD (dst) <- [ptr]`
#
# Operand 0 is the pointer; a pointer that lowers to a vreg becomes the MEM base
# (so an alloca address resolves to `[rbp + offset]` and a runtime pointer to
# `[reg]`), while a symbol / immediate pointer is left as a plain operand for the
# encoder to form its own reference. The result vreg is the loaded value.
#
# A FLOAT load is a plain mir.MIR_MOV whose result is an XMM-class vreg; the encoder
# dispatches it on operand class and materializes a MOVSS / MOVSD off the resolved
# operand WITHOUT recording a symbol relocation (that path has no patch-site hook).
# A global / function symbol pointer must therefore be LEA-materialized into a GP
# base vreg first (the LEA carries the relocation through the generic path), so the
# float load addresses `[base]` rather than an unrelocated `[rip+sym]` that would
# read the wrong address. An integer load keeps the symbol operand: its generic
# encoding records the relocation directly.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_LOAD instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_load(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count == 0) {
        ret R.err[bool, str]("mir.lower_ir: load with no pointer operand");
    }
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: load defines no result vreg");
    }
    var mem: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);
    if (mem.kind == mir.MIR_OP_SYM && lctx.value_is_float(ctx, inst.ty)) {
        var base: u32 = mir.MIR_VREG_NIL;
        val ar: R.Result[bool, str] = lctx.addr_to_vreg(ctx, mb, mem, ?base);
        if (R.is_err[bool, str](ar)) { ret R.err[bool, str](R.unwrap_err[bool, str](ar)); }
        mem = mir.op_mem_value(base, 0);
    }
    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = mem;
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_LOAD;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the load accesses memory at the loaded result type's width (`src_width`) but
    # must DEFINE the full register it lands in (`width`): a sub-word load of a
    # scalar leaves the upper register bits undefined, and a downstream wider use
    # (e.g. a mixed-width integer compare reading the value at the other operand's
    # width) would read that garbage. clamping the destination width to
    # `mir.ALU_MIN_WIDTH` - the same full-register-definition invariant `lctx.clamp_alu_width`
    # gives a sub-word ALU result - makes the backend zero-extend the load into a
    # clean register (a wider load keeps its own width, so width == src_width there).
    mi.src_width     = lctx.op_width_of(ctx, inst.ty);
    mi.width         = lctx.clamp_alu_width(mi.src_width);
    ret lctx.push_instr(ctx, mb, mi);
}

# lower an OP_STORE into `mir.MIR_STORE [ptr] <- (value)`
#
# The IR operand order is `[value, ptr]`; the MIR destination (operand 0) is the
# pointer's MEM reference and operand 1 is the stored value, matching the store
# convention the ABI lowering and the encoder share (operand 0 = memory
# destination). A store whose value is an aggregate is a storage-to-storage copy:
# the value operand is the source aggregate's storage pointer (aggregates flow by
# address - see the lower-expr aggregate-rvalue rules), so it is expanded into a
# sized memcpy rather than a single scalar store.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_STORE instruction
# ret:  true on success, or a lowering / allocation error
fun lower_store(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) R.Result[bool, str] {
    if (inst.operand_count < 2) {
        ret R.err[bool, str]("mir.lower_ir: store missing value or pointer operand");
    }
    if (lctx.value_is_aggregate(ctx, inst.operands[0].ty)) {
        ret lower_store_aggregate(ctx, mb, inst);
    }
    # the stored scalar value. a global / function symbol lowers to its address as
    # an rvalue (`mir.op_sym`), and x86-64 cannot store a 64-bit symbol address straight
    # to memory (the encoder's mem-to-mem split would load the symbol's contents, not
    # its address) - so a symbol value is LEA-materialized into a register first,
    # mirroring the aggregate / by-reference / sret paths.
    var stored: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    if (stored.kind == mir.MIR_OP_SYM) {
        var addr: u32 = mir.MIR_VREG_NIL;
        val ar: R.Result[bool, str] = lctx.addr_to_vreg(ctx, mb, stored, ?addr);
        if (R.is_err[bool, str](ar)) { ret ar; }
        stored = mir.op_vreg(addr);
    }
    # a FLOAT store is a plain mir.MIR_MOV whose stored value is an XMM-class vreg; the
    # encoder dispatches it on operand class and records no symbol relocation for its
    # destination MEM. a global symbol destination must therefore be LEA-materialized
    # into a GP base vreg first (so the store addresses `[base]`), mirroring the
    # float-load path; an integer store keeps the symbol destination and relocates
    # through the generic encoding.
    var dest: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[1]);
    if (dest.kind == mir.MIR_OP_SYM && lctx.value_is_float(ctx, inst.operands[0].ty)) {
        var dbase: u32 = mir.MIR_VREG_NIL;
        val dr: R.Result[bool, str] = lctx.addr_to_vreg(ctx, mb, dest, ?dbase);
        if (R.is_err[bool, str](dr)) { ret R.err[bool, str](R.unwrap_err[bool, str](dr)); }
        dest = mir.op_mem_value(dbase, 0);
    }
    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = dest;
    ops[1] = stored;
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_STORE;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the store accesses memory at the stored value's type width (IR operand 0);
    # the store result is void, so the value type is the only width carrier.
    mi.width         = lctx.op_width_of(ctx, inst.operands[0].ty);
    mi.src_width     = mi.width;
    ret lctx.push_instr(ctx, mb, mi);
}

# expand an OP_STORE of an aggregate into a memcpy between two storage pointers
#
# Both IR operands are pointers to storage (operand 0 = source aggregate address,
# operand 1 = destination address), matching the by-address convention aggregate
# rvalues flow under. The copy walks the aggregate in 8-byte chunks, finishing any
# 4/2/1-byte tail, emitting a `mir.MIR_LOAD scratch <- [src + off]` /
# `mir.MIR_STORE [dst + off] <- scratch` pair per chunk. A fresh scratch vreg per
# chunk keeps each load/store independent for the register allocator. A zero-sized
# aggregate copies nothing.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_STORE instruction with aggregate operands
# ret:  true on success, or a lowering / allocation error
fun lower_store_aggregate(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) R.Result[bool, str] {
    val size: u32 = ir_type.byte_size(ctx.types, inst.operands[0].ty, ctx.tgt);
    var off: i64 = 0;
    for (off::u32 < size) {
        val remaining: u32 = size - off::u32;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        } or (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val src: mir.MirOperand = agg_pointer_mem(ctx, inst.operands[0], off);
        val dst: mir.MirOperand = agg_pointer_mem(ctx, inst.operands[1], off);

        val tr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](tr)) { ret R.err[bool, str](R.unwrap_err[u32, str](tr)); }
        val tmp: u32 = R.unwrap_ok[u32, str](tr);

        val ldr: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
        if (R.is_err[*mir.MirOperand, str](ldr)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](ldr)); }
        val ldops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](ldr);
        ldops[0] = mir.op_vreg(tmp);
        ldops[1] = src;
        var ld: mir.MirInstr;
        ld.opcode        = mir.MIR_LOAD;
        ld.operands      = ldops;
        ld.operand_count = 2;
        ld.width         = chunk;
        ld.src_width     = chunk;
        val pl: R.Result[bool, str] = lctx.push_instr(ctx, mb, ld);
        if (R.is_err[bool, str](pl)) { ret pl; }

        val st: R.Result[bool, str] = lctx.push_store_chunk(ctx, mb, dst, mir.op_vreg(tmp), chunk);
        if (R.is_err[bool, str](st)) { ret st; }

        off = off + chunk::i64;
    }
    ret R.ok[bool, str](true);
}

# expand an OP_MEMZERO into a sized zero-fill of the destination aggregate's storage
#
# Operand 0 is the destination pointer and `aux_ty` is the pointee aggregate type
# whose `byte_size` is the byte count to clear (operand 0 is an untyped IRT_PTR, so
# the size cannot come from its `.ty` - it must come from `aux_ty`). Mirrors
# `lower_store_aggregate`, but each chunk stores an immediate 0 (`MOV [mem], 0`)
# rather than a value loaded from a source - no scratch register and no source
# read. The fill walks 8/4/2/1-byte chunks so a 4/2/1-byte tail clears exactly its
# bytes without writing past the aggregate. A zero-sized aggregate clears nothing.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_MEMZERO instruction
# ret:  true on success, or a lowering / allocation error
fun lower_memzero(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) R.Result[bool, str] {
    if (inst.operand_count < 1) {
        ret R.err[bool, str]("mir.lower_ir: memzero missing destination pointer operand");
    }
    if (inst.aux_ty == ir_type.IRT_NIL) {
        ret R.err[bool, str]("mir.lower_ir: memzero is missing its pointee type");
    }
    val size: u32 = ir_type.byte_size(ctx.types, inst.aux_ty, ctx.tgt);
    var off: i64 = 0;
    for (off::u32 < size) {
        val remaining: u32 = size - off::u32;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        } or (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val dst: mir.MirOperand = agg_pointer_mem(ctx, inst.operands[0], off);
        val st: R.Result[bool, str] = lctx.push_store_chunk(ctx, mb, dst, mir.op_imm(0), chunk);
        if (R.is_err[bool, str](st)) { ret st; }

        off = off + chunk::i64;
    }
    ret R.ok[bool, str](true);
}

# form the MEM operand addressing an aggregate's storage at a byte displacement
#
# Given the IR Value naming the storage pointer: a pointer that lowers to a value
# vreg (an alloca result or runtime pointer) becomes a value-vreg `[base + disp]`
# MEM operand; a global aggregate lowers to a symbol whose storage is addressed
# `[rip + sym + disp]`, the displacement riding in the symbol addend. Matches
# `lctx.mem_operand_of`'s base disambiguation, extended with the displacement the
# per-chunk copy needs.
# ---
# ctx:  the per-function lowering context
# v:    the IR Value naming the aggregate's storage pointer
# disp: the byte displacement into the storage
# ret:  the MEM operand addressing `storage + disp`
fun agg_pointer_mem(ctx: *lctx.LowerCtx, v: value.Value, disp: i64) mir.MirOperand {
    val op: mir.MirOperand = lctx.lower_value(ctx, v);
    if (op.kind == mir.MIR_OP_VREG) { ret mir.op_mem_value(op.vreg, disp); }
    if (op.kind == mir.MIR_OP_SYM)  { ret mir.op_sym(op.sym, op.sym_off + disp::i32); }
    ret op;
}

# lower an OP_GEP into `mir.MIR_GEP (dst) <- [base + index*scale + disp]`
#
# Selected to LEA, folding the index walk into the effective address. The IR
# operands are `[base, idx0, idx1, ...]` and the instruction's `aux_ty` is the
# source pointee type the walk starts from (the base pointer itself is untyped, so
# element/field sizes come from `aux_ty` via `ir_type.byte_size`). The walk follows
# the standard getelementptr model: index 0 strides over `aux_ty`, and each later
# index descends one aggregate level (an array element stride, or a constant
# struct-field offset). Constant index contributions fold into the displacement; at
# most one runtime index folds into the SIB `index*scale` term, and a scale that is
# not 1/2/4/8 (or a second runtime index) is materialized into a register with
# explicit mir.MIR_MUL / mir.MIR_ADD before the LEA.
# ---
# ctx:  the per-function lowering context
# mb:   the destination MIR block
# inst: the IR OP_GEP instruction
# iid:  the IR instruction id
# ret:  true on success, or a lowering / allocation error
fun lower_gep(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) R.Result[bool, str] {
    if (inst.operand_count == 0) {
        ret R.err[bool, str]("mir.lower_ir: gep with no base operand");
    }
    val dst: u32 = lctx.instr_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret R.err[bool, str]("mir.lower_ir: gep defines no result vreg");
    }

    val base: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);

    # the index walk needs the source pointee type to size each level; a GEP that
    # carries indices but no source type is a lowering bug, not silently foldable.
    if (inst.operand_count > 1 && inst.aux_ty == ir_type.IRT_NIL) {
        ret R.err[bool, str]("mir.lower_ir: gep with indices is missing its source pointee type");
    }

    # walk the indices, accumulating a constant displacement and at most one
    # scaled runtime index. a struct level needs a constant field ordinal.
    var disp:      i64 = 0;
    var idx_vreg:  u32 = mir.MIR_VREG_NIL;
    var idx_scale: u8  = 0;
    var cur_ty:    ir_type.IrTypeId = inst.aux_ty;

    var k: u32 = 1;
    for (k < inst.operand_count) {
        val v: value.Value = inst.operands[k];
        val is_first: bool = k == 1;

        # determine the stride for this level and the type one level deeper. the
        # first index strides over the source pointee `cur_ty` without descending;
        # subsequent indices descend into the array element / struct field.
        var stride:    u64 = 0;
        var is_struct: bool = false;
        if (is_first) {
            stride = ir_type.byte_size(ctx.types, cur_ty, ctx.tgt)::u64;
        } or {
            val ct_opt: O.Option[*ir_type.IrType] = ir_type.get(ctx.types, cur_ty);
            if (!O.is_some[*ir_type.IrType](ct_opt)) {
                ret R.err[bool, str]("mir.lower_ir: gep index walks off a non-aggregate type");
            }
            val ct: *ir_type.IrType = O.unwrap[*ir_type.IrType](ct_opt);
            if (ct.kind == ir_type.IRT_ARRAY) {
                stride = ir_type.byte_size(ctx.types, ct.data.array_.element, ctx.tgt)::u64;
                cur_ty = ct.data.array_.element;
            } or (ct.kind == ir_type.IRT_STRUCT || ct.kind == ir_type.IRT_UNION) {
                is_struct = true;
            } or {
                ret R.err[bool, str]("mir.lower_ir: gep index into a non-aggregate type");
            }
        }

        if (is_struct) {
            # struct-field index: must be a constant ordinal; fold its byte offset.
            if (v.kind != value.VAL_CONST_INT) {
                ret R.err[bool, str]("mir.lower_ir: gep struct field index must be constant");
            }
            val field_ix: u32 = v.data.int_lit::u32;
            val fo: R.Result[i64, str] = struct_field_offset(ctx, cur_ty, field_ix);
            if (R.is_err[i64, str](fo)) { ret R.err[bool, str](R.unwrap_err[i64, str](fo)); }
            disp = disp + R.unwrap_ok[i64, str](fo);
            val ft: R.Result[ir_type.IrTypeId, str] = struct_field_type(ctx, cur_ty, field_ix);
            if (R.is_err[ir_type.IrTypeId, str](ft)) { ret R.err[bool, str](R.unwrap_err[ir_type.IrTypeId, str](ft)); }
            cur_ty = R.unwrap_ok[ir_type.IrTypeId, str](ft);
            k = k + 1;
            cnt;
        }

        if (v.kind == value.VAL_CONST_INT) {
            # constant array / pointer index: fold the scaled offset.
            disp = disp + (v.data.int_lit * stride)::i64;
            k = k + 1;
            cnt;
        }

        # runtime index: fold into the SIB index*scale when possible, else
        # materialize the scaling explicitly. the chosen scale rides back through
        # `?new_scale`, and the new accumulator vreg is the result.
        var new_scale: u8 = 0;
        val ir: R.Result[u32, str] = fold_runtime_index(ctx, mb, lctx.lower_value(ctx, v), stride, idx_vreg, idx_scale, ?new_scale);
        if (R.is_err[u32, str](ir)) { ret R.err[bool, str](R.unwrap_err[u32, str](ir)); }
        idx_vreg  = R.unwrap_ok[u32, str](ir);
        idx_scale = new_scale;
        k = k + 1;
    }

    # form the folded MEM operand from the base, carrying the scaled index.
    val mem: R.Result[mir.MirOperand, str] = fold_gep_mem(ctx, mb, base, idx_vreg, idx_scale, disp);
    if (R.is_err[mir.MirOperand, str](mem)) { ret R.err[bool, str](R.unwrap_err[mir.MirOperand, str](mem)); }

    val r: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](r)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = R.unwrap_ok[mir.MirOperand, str](mem);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_GEP;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the GEP selects to a LEA computing a pointer-sized effective address.
    mi.width         = ctx.tgt.model.gpr_width::u8;
    mi.src_width     = ctx.tgt.model.gpr_width::u8;
    ret lctx.push_instr(ctx, mb, mi);
}

# combine one runtime GEP index into the running scaled-index accumulator
#
# With no accumulator yet and a hardware-legal scale, the index rides the SIB
# `index*scale` term directly and `@scale_out` records that scale. Otherwise the
# scaling is materialized - `t = index * stride` (mir.MIR_MUL) - and either becomes
# the accumulator (scale 1) or is added into it (`acc = acc + t`, mir.MIR_ADD), with
# `@scale_out` set to 1. A non-vreg index operand is a lowering bug (indices are
# i64 values), rejected loudly.
# ---
# ctx:       the per-function lowering context
# mb:        the destination MIR block
# idxop:     the lowered runtime index operand (must be a vreg)
# stride:    the byte stride of this index level
# acc:       the current accumulator vreg, or mir.MIR_VREG_NIL when none
# acc_scale: the SIB scale the current accumulator still rides (1 when folded)
# scale_out: receives the SIB scale the returned accumulator rides
# ret:       the updated accumulator vreg, or a lowering / allocation error
fun fold_runtime_index(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, idxop: mir.MirOperand, stride: u64,
                       acc: u32, acc_scale: u8, scale_out: *u8) R.Result[u32, str] {
    if (idxop.kind != mir.MIR_OP_VREG) {
        ret R.err[u32, str]("mir.lower_ir: gep runtime index is not a register value");
    }
    val idxv: u32 = idxop.vreg;

    if (acc == mir.MIR_VREG_NIL && is_sib_scale(stride)) {
        @scale_out = stride::u8;
        ret R.ok[u32, str](idxv);
    }

    # materialize `t = idxv * stride`.
    val tr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (R.is_err[u32, str](tr)) { ret R.err[u32, str](R.unwrap_err[u32, str](tr)); }
    val t: u32 = R.unwrap_ok[u32, str](tr);
    val mr: R.Result[bool, str] = lctx.emit_bin(ctx, mb, mir.MIR_MUL, t, mir.op_vreg(idxv), mir.op_imm(stride::i64));
    if (R.is_err[bool, str](mr)) { ret R.err[u32, str](R.unwrap_err[bool, str](mr)); }

    if (acc == mir.MIR_VREG_NIL) {
        @scale_out = 1;
        ret R.ok[u32, str](t);
    }

    # accumulate `acc = acc * acc_scale + t`. when the existing accumulator still
    # rode a SIB scale, fold that scale in first so the combined index is scale 1.
    var acc_term: u32 = acc;
    if (acc_scale > 1) {
        val sr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](sr)) { ret R.err[u32, str](R.unwrap_err[u32, str](sr)); }
        acc_term = R.unwrap_ok[u32, str](sr);
        val smr: R.Result[bool, str] = lctx.emit_bin(ctx, mb, mir.MIR_MUL, acc_term, mir.op_vreg(acc), mir.op_imm(acc_scale::i64));
        if (R.is_err[bool, str](smr)) { ret R.err[u32, str](R.unwrap_err[bool, str](smr)); }
    }
    val ar: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (R.is_err[u32, str](ar)) { ret R.err[u32, str](R.unwrap_err[u32, str](ar)); }
    val sum: u32 = R.unwrap_ok[u32, str](ar);
    val adr: R.Result[bool, str] = lctx.emit_bin(ctx, mb, mir.MIR_ADD, sum, mir.op_vreg(acc_term), mir.op_vreg(t));
    if (R.is_err[bool, str](adr)) { ret R.err[u32, str](R.unwrap_err[bool, str](adr)); }
    @scale_out = 1;
    ret R.ok[u32, str](sum);
}

# true when a byte stride is a hardware SIB scale (1, 2, 4, or 8)
# ---
# s:   the byte stride to test
# ret: true for 1, 2, 4, or 8
fun is_sib_scale(s: u64) bool {
    ret s == 1 || s == 2 || s == 4 || s == 8;
}

# build the final folded MEM operand for a GEP
#
# Combines the base operand, the scaled runtime index (mir.MIR_VREG_NIL when none),
# and the constant displacement. A value-vreg base carries the index in the SIB
# position; a symbol base with only a constant offset folds into `sym_off` (a pure
# `[rip+sym+off]` reference), and a symbol base with a runtime index
# LEA-materializes the symbol address into a value vreg first (`lctx.addr_to_vreg`)
# so the scaled index has a register base to ride. A constant-address base (a null
# or integer pointer, e.g. a `null` argument inlined into a pointer parameter the
# callee GEPs) materializes the constant into a value vreg and indexes
# `[base + idx*scale + disp]` off it.
# ---
# ctx:       the per-function lowering context
# mb:        the destination MIR block
# base:      the lowered base operand (mem, symbol, or immediate address)
# idx_vreg:  the scaled runtime index vreg, or mir.MIR_VREG_NIL when none
# idx_scale: the SIB scale for `idx_vreg`
# disp:      the constant byte displacement folded into the address
# ret:       the folded MEM operand, or a lowering / allocation error
fun fold_gep_mem(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, base: mir.MirOperand, idx_vreg: u32, idx_scale: u8, disp: i64) R.Result[mir.MirOperand, str] {
    var o: mir.MirOperand = base;
    if (base.kind == mir.MIR_OP_IMM) {
        # the base is a compile-time address; MOV it into a value vreg so the LEA /
        # load / store has a register base to fold the constant displacement and the
        # optional scaled index against.
        val vr: R.Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](vr)) { ret R.err[mir.MirOperand, str](R.unwrap_err[u32, str](vr)); }
        val vbase: u32 = R.unwrap_ok[u32, str](vr);
        val mv: R.Result[bool, str] = lctx.emit_mov(ctx, mb, mir.op_vreg(vbase), mir.op_imm(base.imm));
        if (R.is_err[bool, str](mv)) { ret R.err[mir.MirOperand, str](R.unwrap_err[bool, str](mv)); }
        var m: mir.MirOperand = mir.op_mem_value(vbase, disp);
        if (idx_vreg != mir.MIR_VREG_NIL) {
            m.index         = idx_vreg;
            m.scale         = idx_scale;
            m.index_is_preg = false;
        }
        ret R.ok[mir.MirOperand, str](m);
    }
    if (base.kind == mir.MIR_OP_MEM) {
        # a value-pointer / physical-register / frame-slot-key base all fold the
        # constant displacement into `imm`; the encoder resolves a slot key to
        # `[rbp + off]` and can still carry the SIB index alongside.
        o.imm = base.imm + disp;
        if (idx_vreg != mir.MIR_VREG_NIL) {
            o.index         = idx_vreg;
            o.scale         = idx_scale;
            o.index_is_preg = false;
        }
        ret R.ok[mir.MirOperand, str](o);
    }
    if (base.kind == mir.MIR_OP_SYM) {
        if (idx_vreg == mir.MIR_VREG_NIL) {
            o.sym_off = base.sym_off + disp::i32;
            ret R.ok[mir.MirOperand, str](o);
        }
        # runtime index against a global: there is no register in a `[rip+sym]`
        # reference to scale the index into, so LEA the symbol address (carrying
        # its `sym_off`) into a value vreg and index `[base + idx*scale + disp]`
        # off that register, the same materialization `lctx.addr_to_vreg` performs for
        # by-reference aggregate placement.
        var sbase: u32 = mir.MIR_VREG_NIL;
        val ar: R.Result[bool, str] = lctx.addr_to_vreg(ctx, mb, base, ?sbase);
        if (R.is_err[bool, str](ar)) { ret R.err[mir.MirOperand, str](R.unwrap_err[bool, str](ar)); }
        var m: mir.MirOperand = mir.op_mem_value(sbase, disp);
        m.index         = idx_vreg;
        m.scale         = idx_scale;
        m.index_is_preg = false;
        ret R.ok[mir.MirOperand, str](m);
    }
    ret R.err[mir.MirOperand, str]("mir.lower_ir: gep base is neither a memory nor a symbol reference");
}

# byte offset of field `ix` within an IRT_STRUCT
#
# Computed by the same aligned-layout walk as `ir_type.byte_size`. A union
# overlaps its members, so every member is at offset 0.
# ---
# ctx:       the per-function lowering context
# struct_ty: the IR struct / union type id
# ix:        the field ordinal
# ret:       the field's byte offset, or a lowering error
fun struct_field_offset(ctx: *lctx.LowerCtx, struct_ty: ir_type.IrTypeId, ix: u32) R.Result[i64, str] {
    val st_opt: O.Option[*ir_type.IrType] = ir_type.get(ctx.types, struct_ty);
    if (!O.is_some[*ir_type.IrType](st_opt)) {
        ret R.err[i64, str]("mir.lower_ir: gep struct type not found");
    }
    val st: *ir_type.IrType = O.unwrap[*ir_type.IrType](st_opt);
    # a union overlaps its members: every member is at offset 0.
    if (st.kind == ir_type.IRT_UNION) {
        if (ix >= st.data.struct_.field_count) {
            ret R.err[i64, str]("mir.lower_ir: gep union member index out of range");
        }
        ret R.ok[i64, str](0::i64);
    }
    if (st.kind != ir_type.IRT_STRUCT) {
        ret R.err[i64, str]("mir.lower_ir: gep struct index into a non-struct type");
    }
    if (ix >= st.data.struct_.field_count) {
        ret R.err[i64, str]("mir.lower_ir: gep struct field index out of range");
    }
    var off: u32 = 0;
    var i:   u32 = 0;
    for (i <= ix) {
        val fid: ir_type.IrTypeId = st.data.struct_.fields[i];
        val fa:  u32 = ir_type.byte_align(ctx.types, fid, ctx.tgt);
        off = round_up_u32(off, fa);
        if (i == ix) { ret R.ok[i64, str](off::i64); }
        off = off + ir_type.byte_size(ctx.types, fid, ctx.tgt);
        i = i + 1;
    }
    ret R.err[i64, str]("mir.lower_ir: gep struct field offset walk failed");
}

# the IR type of field `ix` within an IRT_STRUCT or IRT_UNION
# ---
# ctx:       the per-function lowering context
# struct_ty: the IR struct / union type id
# ix:        the field ordinal
# ret:       the field's IR type id, or a lowering error
fun struct_field_type(ctx: *lctx.LowerCtx, struct_ty: ir_type.IrTypeId, ix: u32) R.Result[ir_type.IrTypeId, str] {
    val st_opt: O.Option[*ir_type.IrType] = ir_type.get(ctx.types, struct_ty);
    if (!O.is_some[*ir_type.IrType](st_opt)) {
        ret R.err[ir_type.IrTypeId, str]("mir.lower_ir: gep struct type not found");
    }
    val st: *ir_type.IrType = O.unwrap[*ir_type.IrType](st_opt);
    if ((st.kind != ir_type.IRT_STRUCT && st.kind != ir_type.IRT_UNION) || ix >= st.data.struct_.field_count) {
        ret R.err[ir_type.IrTypeId, str]("mir.lower_ir: gep struct field index out of range");
    }
    ret R.ok[ir_type.IrTypeId, str](st.data.struct_.fields[ix]);
}

# round `v` up to the next multiple of `align`
# ---
# v:     the value to round
# align: the alignment (a value of 1 or 0 leaves `v` unchanged)
# ret:   `v` rounded up to a multiple of `align`
fun round_up_u32(v: u32, align: u32) u32 {
    if (align <= 1) { ret v; }
    ret ((v + align - 1) / align) * align;
}
