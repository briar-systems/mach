# mach.lang.be.codegen.mir.lower: IR-to-MIR translation and out-of-SSA.
#
# `lower_ir` is the bridge between the target-independent SSA IR
# (`mach.lang.me.ir`) and the MIR data model (`mach.lang.be.codegen.mir`): it
# walks an `ir.Module` and produces a parallel `MirModule`, one `MirFunction`
# per IR function. The translation is deliberately mechanical and
# target-agnostic (it routes every register name and calling-convention fact
# through the `tgt.abi` / `tgt.isa` vtables):
#   - every IR `Block` becomes a `MirBlock` with the same numeric id;
#   - every SSA result (instruction result or function parameter) is assigned
#     exactly one fresh virtual register, and every operand reference becomes a
#     `MIR_OP_VREG` operand naming it;
#   - inline integer / null constants become `MIR_OP_IMM` operands; globals and
#     function symbols become `MIR_OP_SYM` operands;
#   - `OP_CALL` lowers through the active ABI vtable (see `mir.abi`): each
#     argument is classified and pre-colored into its canonical argument
#     register or a stack store, followed by a `MIR_CALL` pseudo naming the
#     callee and a `MIR_CALL_RES` pseudo binding the result vreg;
#   - `OP_PHI` is eliminated out of SSA: each phi becomes a `MIR_MOV` of its
#     incoming value into the phi's result vreg, inserted at the end of every
#     predecessor block before its terminator (see `lower_phis`), so no phi
#     reaches isel / regalloc / encode.
#
# This module owns the generic per-instruction lowering and the out-of-SSA
# machinery; ABI call/param/ret lowering lives in `mir.abi`, variadic
# expansion in `mir.va`, and the shared `LowerCtx` and emit primitives in
# `mir.context`.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.string.str;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.option.is_some;
use std.types.option.unwrap;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_ok;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use std.system.panic.panic;

use map: std.collections.map;

use float:   mach.lang.float;
use intern:  mach.lang.intern;
use target:  mach.lang.target.resolved;
use abi:     mach.lang.target.abi;
use isa:     mach.lang.target.isa;
use ir:      mach.lang.me.ir;
use ir_type: mach.lang.me.ir.type;
use instr:   mach.lang.me.ir.instruction;
use value:   mach.lang.me.ir.value;
use id:      mach.lang.me.ir.id;

use mir:     mach.lang.be.codegen.mir;
use lctx:    mach.lang.be.codegen.mir.context;
use mabi:    mach.lang.be.codegen.mir.abi;

# lower_ir: lower an IR module to a parallel MIR module, one MIR function per IR function.
# ---
# tgt:      resolved compilation target; supplies register classes via `tgt.arch`
# m:        the source IR module to lower
# interner: session interner, recorded on the MIR module so the encoder can
#           resolve interned strings and intern inline-asm symbol references
# ret:      a populated mir.MirModule (owned, release with `mir.dnit_module`), or an allocation / lowering error
pub fun lower_ir(tgt: *target.Target, m: *ir.Module, interner: *intern.Interner) Result[mir.MirModule, str] {
    if (tgt == nil || m == nil) {
        ret err[mir.MirModule, str]("mir.lower_ir: nil target or module");
    }

    var mm: mir.MirModule;
    mm.alloc        = m.alloc;
    mm.interner     = interner;
    mm.functions    = nil;
    mm.function_len = 0;
    mm.function_cap = 0;

    val rf: Result[*mir.MirFunction, str] = allocate[mir.MirFunction](m.alloc, mir.INITIAL_FN_CAP::usize);
    if (is_err[*mir.MirFunction, str](rf)) {
        ret err[mir.MirModule, str](unwrap_err[*mir.MirFunction, str](rf));
    }
    mm.functions    = unwrap_ok[*mir.MirFunction, str](rf);
    mm.function_cap = mir.INITIAL_FN_CAP;

    var fi: u32 = 0;
    for (fi < m.function_len) {
        val lf: Result[mir.MirFunction, str] = lower_function(tgt, m, ?m.functions[fi], interner);
        if (is_err[mir.MirFunction, str](lf)) {
            mir.dnit_module(?mm);
            ret err[mir.MirModule, str](unwrap_err[mir.MirFunction, str](lf));
        }
        val push: Result[bool, str] = mir.push_function(?mm, unwrap_ok[mir.MirFunction, str](lf));
        if (is_err[bool, str](push)) {
            mir.dnit_module(?mm);
            ret err[mir.MirModule, str](unwrap_err[bool, str](push));
        }
        fi = fi + 1;
    }

    ret ok[mir.MirModule, str](mm);
}

# lowers one IR function into a mir.MirFunction. allocates the vreg table and the
# per-definition vreg maps, assigns a vreg to every parameter and every
# non-void instruction result, then translates each block's phis, body, and
# terminator into MIR instructions.
fun lower_function(tgt: *target.Target, m: *ir.Module, fn: *ir.Function, interner: *intern.Interner) Result[mir.MirFunction, str] {
    var mf: mir.MirFunction;
    mf.name        = fn.name;
    mf.blocks      = nil;
    mf.block_count = 0;
    mf.block_cap   = 0;
    mf.vregs       = nil;
    mf.vreg_count  = 0;
    mf.vreg_cap    = 0;
    mf.frame.slots        = nil;
    mf.frame.slot_count   = 0;
    mf.frame.slot_cap     = 0;
    mf.frame.size         = 0;
    mf.frame.align        = 0;
    mf.frame.has_va_save  = false;
    mf.frame.va_save_size = 0;
    mf.frame.va_save_off  = 0;
    mf.frame.outgoing_size = 0;
    mf.callee_mask        = 0;
    mf.callee_mask_fp     = 0;

    # extern / body-less functions lower to an empty mir.MirFunction shell. extern
    # variadic declarations (e.g. printf) are fine here; only defining the body of
    # a variadic function needs the unimplemented va-save area.
    if ((fn.flags & ir.FN_FLAG_EXTERN) != 0 || fn.block_count == 0) {
        ret ok[mir.MirFunction, str](mf);
    }

    # a variadic function definition reserves a register-save area in its entry
    # prologue (see `emit_va_save_prologue`) so `va_arg` can read the GP/FP
    # argument registers; calls INTO variadic functions are handled by lower_call.

    val rv: Result[*mir.MirVReg, str] = allocate[mir.MirVReg](m.alloc, mir.INITIAL_VREG_CAP::usize);
    if (is_err[*mir.MirVReg, str](rv)) {
        ret err[mir.MirFunction, str](unwrap_err[*mir.MirVReg, str](rv));
    }
    mf.vregs    = unwrap_ok[*mir.MirVReg, str](rv);
    mf.vreg_cap = mir.INITIAL_VREG_CAP;

    var ctx: lctx.LowerCtx;
    ctx.alloc       = m.alloc;
    ctx.tgt         = tgt;
    ctx.m           = m;
    ctx.types       = ?m.types;
    ctx.fn          = fn;
    ctx.f           = ?mf;
    ctx.param_vregs = nil;
    ctx.param_count = fn.param_count;
    ctx.instr_vregs = nil;
    ctx.slot_key_vregs = nil;
    ctx.instr_count = fn.instr_len;
    ctx.interner    = interner;
    ctx.sret_vreg   = mir.MIR_VREG_NIL;
    ctx.va_active    = false;
    ctx.va_save_vreg = mir.MIR_VREG_NIL;
    ctx.va_named_gp  = 0;
    ctx.va_named_fp  = 0;
    ctx.va_overflow_off = 0;

    val setup: Result[bool, str] = lctx.ctx_setup(?ctx, tgt, fn);
    if (is_err[bool, str](setup)) {
        lctx.ctx_dnit(?ctx);
        mir.dnit_function(m.alloc, ?mf);
        ret err[mir.MirFunction, str](unwrap_err[bool, str](setup));
    }

    val rb: Result[*mir.MirBlock, str] = allocate[mir.MirBlock](m.alloc, fn.block_count::usize);
    if (is_err[*mir.MirBlock, str](rb)) {
        lctx.ctx_dnit(?ctx);
        mir.dnit_function(m.alloc, ?mf);
        ret err[mir.MirFunction, str](unwrap_err[*mir.MirBlock, str](rb));
    }
    mf.blocks    = unwrap_ok[*mir.MirBlock, str](rb);
    mf.block_cap = fn.block_count;

    var bi: u32 = 0;
    for (bi < fn.block_count) {
        val is_entry: bool = bi == 0;
        val lb: Result[bool, str] = lower_block(?ctx, fn, ?fn.blocks[bi], is_entry);
        if (is_err[bool, str](lb)) {
            lctx.ctx_dnit(?ctx);
            mir.dnit_function(m.alloc, ?mf);
            ret err[mir.MirFunction, str](unwrap_err[bool, str](lb));
        }
        bi = bi + 1;
    }

    # out-of-SSA: every block now exists, so the phi merge copies can be inserted
    # at the predecessor block ends (before their terminators).
    val lph: Result[bool, str] = lower_phis(?ctx, fn);
    if (is_err[bool, str](lph)) {
        lctx.ctx_dnit(?ctx);
        mir.dnit_function(m.alloc, ?mf);
        ret err[mir.MirFunction, str](unwrap_err[bool, str](lph));
    }

    lctx.ctx_dnit(?ctx);
    ret ok[mir.MirFunction, str](mf);
}

# fn_sig_is_variadic: true when a function's signature type (IRT_FN) is variadic.
# read from the module's type table directly so it is usable before the per-
# function lowering context exists. a missing or non-function signature is treated
# as non-variadic.
fun fn_sig_is_variadic(m: *ir.Module, fn: *ir.Function) bool {
    val it: Option[*ir_type.IrType] = ir_type.get(?m.types, fn.sig);
    if (!is_some[*ir_type.IrType](it)) { ret false; }
    val t: *ir_type.IrType = unwrap[*ir_type.IrType](it);
    if (t.kind != ir_type.IRT_FN) { ret false; }
    ret t.data.fn.varargs;
}

# lowers one IR block into a mir.MirBlock with the same id: copies predecessor ids,
# translates each body instruction, and finally the terminator. IR phis are NOT
# emitted here — they are eliminated out-of-SSA by `lower_phis` after every block
# exists, which inserts the merge copies at the predecessor block ends. the block
# is claimed in `mf` (block_count incremented) the moment its owned pointers are
# zeroed, so any partially-built block left behind by an allocation failure is
# still reclaimed by dnit_function on the cleanup path.
fun lower_block(ctx: *lctx.LowerCtx, fn: *ir.Function, blk: *ir.Block, is_entry: bool) Result[bool, str] {
    val f: *mir.MirFunction = ctx.f;
    val mb: *mir.MirBlock = ?f.blocks[f.block_count];
    mb.id          = blk.id::u32;
    mb.instrs      = nil;
    mb.instr_count = 0;
    mb.instr_cap   = 0;
    mb.preds       = nil;
    mb.pred_count  = 0;
    mb.pred_cap    = 0;
    f.block_count = f.block_count + 1;

    val cp: Result[bool, str] = copy_preds(ctx, mb, blk);
    if (is_err[bool, str](cp)) { ret cp; }

    # the entry block opens with the ABI param pre-coloring: each incoming
    # parameter is moved out of its canonical argument register (or loaded from
    # the caller's stack area) into the parameter vreg before any body code runs.
    if (is_entry) {
        val lp: Result[bool, str] = mabi.lower_params(ctx, mb);
        if (is_err[bool, str](lp)) { ret lp; }
        # a variadic definition spills its incoming GP/FP argument registers into a
        # register-save area so `va_arg` can read them. emitted after the named-
        # parameter pre-coloring so the save area dumps the FULL argument-register
        # file (the named params still read their own registers above).
        if (fn_sig_is_variadic(ctx.m, fn)) {
            val vp: Result[bool, str] = emit_va_save_prologue(ctx, mb);
            if (is_err[bool, str](vp)) { ret vp; }
        }
    }

    var ii: u32 = 0;
    for (ii < blk.instr_count) {
        val ei: Result[bool, str] = lower_instr(ctx, fn, mb, blk.instructions[ii]);
        if (is_err[bool, str](ei)) { ret ei; }
        ii = ii + 1;
    }

    if (blk.terminator != id.INSTR_NIL) {
        val et: Result[bool, str] = lower_instr(ctx, fn, mb, blk.terminator);
        if (is_err[bool, str](et)) { ret et; }
    }

    ret ok[bool, str](true);
}

# copies an IR block's predecessor ids into a mir.MirBlock.
fun copy_preds(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, blk: *ir.Block) Result[bool, str] {
    if (blk.pred_count == 0) { ret ok[bool, str](true); }
    val r: Result[*u32, str] = allocate[u32](ctx.alloc, blk.pred_count::usize);
    if (is_err[*u32, str](r)) { ret err[bool, str](unwrap_err[*u32, str](r)); }
    mb.preds    = unwrap_ok[*u32, str](r);
    mb.pred_cap = blk.pred_count;
    var i: u32 = 0;
    for (i < blk.pred_count) {
        mb.preds[i] = blk.preds[i]::u32;
        i = i + 1;
    }
    mb.pred_count = blk.pred_count;
    ret ok[bool, str](true);
}

# lower_phis: eliminate every IR phi out of SSA by inserting merge copies at the
# predecessor block ends. Conventional (Cytron-style) phi destruction: a phi in
# block `S` with result vreg `r` and incoming pairs `(pred, value)` is realized
# by emitting, at the end of each predecessor block `P` (before its terminator),
# a `mir.MIR_MOV r <- lctx.lower_value(value)`, so `r` is defined on every path into `S`.
# After this pass no OP_PHI / mir.MIR_PHI exists; the encoder's mir.MIR_PHI rejection is
# only a backstop. The result vreg is the ordinary allocatable vreg `lctx.ctx_setup`
# already assigned to the phi instruction.
#
# All phis at the head of `S` execute simultaneously, so the copies along a single
# edge `P -> S` form one parallel-copy set; `emit_edge_copies` sequentializes it
# correctly (breaking cycles with a fresh temp) to avoid the lost-copy / swap
# problem. Phis whose incoming value lowers to itself contribute no copy.
fun lower_phis(ctx: *lctx.LowerCtx, fn: *ir.Function) Result[bool, str] {
    var bi: u32 = 0;
    for (bi < fn.block_count) {
        val blk: *ir.Block = ?fn.blocks[bi];
        if (blk.phi_count > 0) {
            val r: Result[bool, str] = lower_block_phis(ctx, fn, blk);
            if (is_err[bool, str](r)) { ret r; }
        }
        bi = bi + 1;
    }
    ret ok[bool, str](true);
}

# lower_block_phis: insert the merge copies for every phi of one successor block
# `S`. For each distinct predecessor block id appearing in `S`'s phis, it gathers
# the per-edge parallel-copy set (one `(phi result vreg, incoming operand)` per
# phi that has an incoming pair for that predecessor) and emits it, safely
# sequentialized, at the end of that predecessor's MIR block.
fun lower_block_phis(ctx: *lctx.LowerCtx, fn: *ir.Function, blk: *ir.Block) Result[bool, str] {
    # scratch parallel-copy set, at most one copy per phi in this block.
    val np: u32 = blk.phi_count;
    val rd: Result[*u32, str] = allocate[u32](ctx.alloc, np::usize);
    if (is_err[*u32, str](rd)) { ret err[bool, str](unwrap_err[*u32, str](rd)); }
    val dsts: *u32 = unwrap_ok[*u32, str](rd);
    val rs: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, np::usize);
    if (is_err[*mir.MirOperand, str](rs)) {
        deallocate[u32](ctx.alloc, dsts, np::usize);
        ret err[bool, str](unwrap_err[*mir.MirOperand, str](rs));
    }
    val srcs: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](rs);

    var err_msg: str = nil;
    # iterate the distinct predecessor block ids of `S`. preds were copied from the
    # IR block, deduped, so each names one edge `P -> S`.
    var pi: u32 = 0;
    for (pi < blk.pred_count && err_msg == nil) {
        val pred_id: u32 = blk.preds[pi]::u32;
        var pred_mb: *mir.MirBlock = mir_block_by_id(ctx.f, pred_id);
        if (pred_mb == nil) {
            err_msg = "mir.lower_ir: phi predecessor block has no MIR block";
            pi = pi + 1;
            cnt;
        }

        # critical edge: a phi block always has multiple predecessors, so an edge
        # `P -> S` is critical when `P` also has multiple successors (a CBR). Placing
        # this edge's phi copies at the end of `P` would run them on `P`'s other
        # successor path too, which can corrupt a value the sibling edge's copies
        # need. Split the edge into a fresh block `B` that branches to `S`, retarget
        # `P`'s CBR to `B`, and emit this edge's copies into `B` (which ends in an
        # unconditional branch and so is a safe splice point).
        if (block_ends_in_cbr(pred_mb)) {
            val sr: Result[*mir.MirBlock, str] = split_critical_edge(ctx, pred_mb, blk.id::u32);
            if (is_err[*mir.MirBlock, str](sr)) { err_msg = unwrap_err[*mir.MirBlock, str](sr); pi = pi + 1; cnt; }
            pred_mb = unwrap_ok[*mir.MirBlock, str](sr);
        }

        # collect this edge's copies: for each phi, the incoming value paired with
        # this predecessor, targeting the phi's result vreg.
        var nc: u32 = 0;
        var hi: u32 = 0;
        for (hi < blk.phi_count && err_msg == nil) {
            val phi_opt: Option[*instr.Instruction] = ir.get_instruction(fn, blk.phis[hi]);
            if (!is_some[*instr.Instruction](phi_opt)) {
                err_msg = "mir.lower_ir: dangling phi instruction id";
                hi = hi + 1;
                cnt;
            }
            val phi: *instr.Instruction = unwrap[*instr.Instruction](phi_opt);
            val dst_vreg: u32 = lctx.result_vreg(ctx, blk.phis[hi]);
            if (dst_vreg == mir.MIR_VREG_NIL) {
                err_msg = "mir.lower_ir: phi defines no result vreg";
                hi = hi + 1;
                cnt;
            }
            var found: bool = false;
            var k: u32 = 0;
            for (k + 1 < phi.operand_count && found == false) {
                if (phi.operands[k].data.int_lit::u32 == pred_id) {
                    dsts[nc] = dst_vreg;
                    srcs[nc] = lctx.lower_value(ctx, phi.operands[k + 1]);
                    nc = nc + 1;
                    found = true;
                }
                k = k + 2;
            }
            hi = hi + 1;
        }

        if (err_msg == nil && nc > 0) {
            val r: Result[bool, str] = emit_edge_copies(ctx, pred_mb, dsts, srcs, nc);
            if (is_err[bool, str](r)) { err_msg = unwrap_err[bool, str](r); }
        }
        pi = pi + 1;
    }

    deallocate[u32](ctx.alloc, dsts, np::usize);
    deallocate[mir.MirOperand](ctx.alloc, srcs, np::usize);
    if (err_msg != nil) { ret err[bool, str](err_msg); }
    ret ok[bool, str](true);
}

# mir_block_by_id: return the MIR block whose id equals `id`, or nil if absent.
# MIR block ids mirror the source IR block ids, so a phi's predecessor id selects
# the predecessor's MIR block directly.
fun mir_block_by_id(f: *mir.MirFunction, block_id: u32) *mir.MirBlock {
    var bi: u32 = 0;
    for (bi < f.block_count) {
        if (f.blocks[bi].id == block_id) { ret ?f.blocks[bi]; }
        bi = bi + 1;
    }
    ret nil;
}

# emit_edge_copies: sequentialize and insert one edge's parallel-copy set
# `{dsts[i] <- srcs[i]}` into predecessor block `pred_mb`, before its terminator.
# All `dsts[i]` are distinct phi-result vregs; the `srcs[i]` operands are vregs,
# immediates, or symbols. The copies are conceptually simultaneous, so a naive
# in-order emission would clobber a value another copy still needs (the lost-copy
# / swap problem). Standard resolution: repeatedly emit any copy whose
# destination is not still needed as a source; when only a dependence cycle
# remains, break it by saving one destination's live value into a fresh temp vreg
# and redirecting the copies that read it. A `dst == src` self-copy is dropped.
fun emit_edge_copies(ctx: *lctx.LowerCtx, pred_mb: *mir.MirBlock, dsts: *u32, srcs: *mir.MirOperand, n: u32) Result[bool, str] {
    val re: Result[*bool, str] = allocate[bool](ctx.alloc, n::usize);
    if (is_err[*bool, str](re)) { ret err[bool, str](unwrap_err[*bool, str](re)); }
    val done: *bool = unwrap_ok[*bool, str](re);

    var remaining: u32 = 0;
    var i: u32 = 0;
    for (i < n) {
        # a copy whose source is the destination vreg itself is a no-op.
        if (srcs[i].kind == mir.MIR_OP_VREG && srcs[i].vreg == dsts[i]) {
            done[i] = true;
        } or {
            done[i] = false;
            remaining = remaining + 1;
        }
        i = i + 1;
    }

    var err_msg: str = nil;
    for (remaining > 0 && err_msg == nil) {
        var progressed: bool = false;
        var j: u32 = 0;
        for (j < n) {
            if (done[j] == false && !dst_is_pending_src(dsts, srcs, done, n, dsts[j])) {
                val mv: Result[bool, str] = insert_mov_before_terminator(ctx, pred_mb,
                    mir.op_vreg(dsts[j]), srcs[j]);
                if (is_err[bool, str](mv)) { err_msg = unwrap_err[bool, str](mv); j = n; cnt; }
                done[j] = true;
                remaining = remaining - 1;
                progressed = true;
            }
            j = j + 1;
        }

        if (err_msg == nil && progressed == false && remaining > 0) {
            # only a dependence cycle remains: every pending destination is still
            # needed as a pending source. Pick one pending copy, save its
            # destination's live value into a fresh temp, and redirect every pending
            # copy that reads that destination to read the temp instead. This frees
            # the destination so the loop resumes.
            var c: u32 = 0;
            for (done[c]) { c = c + 1; }
            val freed: u32 = dsts[c];
            val cls: u32 = ctx.f.vregs[freed].class;
            val tr: Result[u32, str] = lctx.new_vreg(ctx, cls);
            if (is_err[u32, str](tr)) { err_msg = unwrap_err[u32, str](tr); cnt; }
            val tmp: u32 = unwrap_ok[u32, str](tr);
            val sv: Result[bool, str] = insert_mov_before_terminator(ctx, pred_mb,
                mir.op_vreg(tmp), mir.op_vreg(freed));
            if (is_err[bool, str](sv)) { err_msg = unwrap_err[bool, str](sv); cnt; }
            var d: u32 = 0;
            for (d < n) {
                if (done[d] == false && srcs[d].kind == mir.MIR_OP_VREG && srcs[d].vreg == freed) {
                    srcs[d] = mir.op_vreg(tmp);
                }
                d = d + 1;
            }
        }
    }

    deallocate[bool](ctx.alloc, done, n::usize);
    if (err_msg != nil) { ret err[bool, str](err_msg); }
    ret ok[bool, str](true);
}

# dst_is_pending_src: true when vreg `v` is the source of some not-yet-emitted
# copy in the edge set — i.e. emitting a copy into `v` now would destroy a value
# another pending copy still needs.
fun dst_is_pending_src(dsts: *u32, srcs: *mir.MirOperand, done: *bool, n: u32, v: u32) bool {
    var i: u32 = 0;
    for (i < n) {
        if (done[i] == false && srcs[i].kind == mir.MIR_OP_VREG && srcs[i].vreg == v) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# insert_mov_before_terminator: append a `mir.MIR_MOV (dst) <- (src)` to `mb` so it
# executes just before the block's terminator. A block that is a phi predecessor
# ends in a branch terminator (the last instruction); the move is spliced ahead of
# it, preserving terminator-last ordering that frame.run / encode.run rely on.
fun insert_mov_before_terminator(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand) Result[bool, str] {
    if (mb.instr_count == 0) {
        ret err[bool, str]("mir.lower_ir: phi predecessor block has no terminator");
    }
    val term: *mir.MirInstr = ?mb.instrs[mb.instr_count - 1];
    if (!is_mir_terminator(term.opcode)) {
        ret err[bool, str]("mir.lower_ir: phi predecessor block does not end in a terminator");
    }

    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: mir.MirInstr;
    # a phi merge copy is normally a register-to-register / immediate move; the
    # full-width move copies the value's low bits intact regardless of its logical
    # width. but a global / function symbol incoming value is its ADDRESS as an
    # rvalue: a mir.MIR_MOV of a symbol selects to `mov dst, [sym]` (loading the
    # symbol's contents), so it is emitted as the address-computing mir.MIR_GEP
    # (`lea dst, [sym]`) instead — the same LEA-materialization the store /
    # call-arg / return symbol paths use.
    mi.opcode        = mir.MIR_MOV;
    if (src.kind == mir.MIR_OP_SYM) { mi.opcode = mir.MIR_GEP; }
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = mir.WORD_WIDTH;
    mi.src_width     = mir.WORD_WIDTH;
    # this splice bypasses lctx.push_instr, so enforce the asm_block invariant here:
    # struct locals are not zero-initialized, and regalloc.flatten reads a non-nil
    # asm_block as an inline-asm clobber barrier.
    mi.asm_block     = nil;

    # grow by one, shift the terminator right, and drop the move into its place.
    val gr: Result[bool, str] = lctx.grow_instr(ctx, mb);
    if (is_err[bool, str](gr)) {
        deallocate[mir.MirOperand](ctx.alloc, ops, 2::usize);
        ret gr;
    }
    mb.instrs[mb.instr_count] = mb.instrs[mb.instr_count - 1];
    mb.instrs[mb.instr_count - 1] = mi;
    mb.instr_count = mb.instr_count + 1;
    ret ok[bool, str](true);
}

# is_mir_terminator: true when a generic MIR opcode ends a block. The phi
# predecessor splice point is just before this instruction.
fun is_mir_terminator(o: mir.MirOpcode) bool {
    if (o == mir.MIR_BR)          { ret true; }
    if (o == mir.MIR_CBR)         { ret true; }
    if (o == mir.MIR_RET)         { ret true; }
    if (o == mir.MIR_UNREACHABLE) { ret true; }
    ret false;
}

# block_ends_in_cbr: true when a block's terminator is a conditional branch, i.e.
# the block has two successors. Used to detect critical edges into phi blocks.
fun block_ends_in_cbr(mb: *mir.MirBlock) bool {
    if (mb.instr_count == 0) { ret false; }
    ret mb.instrs[mb.instr_count - 1].opcode == mir.MIR_CBR;
}

# grow_block: ensure the function's block array has room for one more block,
# growing it on demand. `lower_function` allocates exactly `fn.block_count`
# blocks, so any critical-edge split needs this to extend the array.
fun grow_block(ctx: *lctx.LowerCtx) Result[bool, str] {
    val f: *mir.MirFunction = ctx.f;
    if (f.block_count >= f.block_cap) {
        var new_cap: u32 = f.block_cap * 2;
        if (new_cap < f.block_count + 1) { new_cap = f.block_count + 1; }
        val r: Result[*mir.MirBlock, str] = reallocate[mir.MirBlock](ctx.alloc, f.blocks, f.block_cap::usize, new_cap::usize);
        if (is_err[*mir.MirBlock, str](r)) { ret err[bool, str](unwrap_err[*mir.MirBlock, str](r)); }
        f.blocks    = unwrap_ok[*mir.MirBlock, str](r);
        f.block_cap = new_cap;
    }
    ret ok[bool, str](true);
}

# fresh_block_id: a block id one past the current maximum, guaranteed not to
# collide with any existing block id.
fun fresh_block_id(f: *mir.MirFunction) u32 {
    var max_id: u32 = 0;
    var bi: u32 = 0;
    for (bi < f.block_count) {
        if (f.blocks[bi].id > max_id) { max_id = f.blocks[bi].id; }
        bi = bi + 1;
    }
    ret max_id + 1;
}

# split_critical_edge: break the critical edge `pred -> succ_id` by inserting a
# fresh block `B` that unconditionally branches to `succ`. `pred`'s CBR target
# matching `succ_id` is retargeted to `B`, `succ`'s predecessor entry for `pred`
# is replaced by `B`, and `B`'s sole predecessor is `pred`. `B` is returned so
# the caller emits this edge's phi merge copies into it — `B` ends in an
# unconditional branch, so the splice is safe. Block pointers are re-fetched by
# id after the (possibly reallocating) growth, since growth invalidates them.
fun split_critical_edge(ctx: *lctx.LowerCtx, pred: *mir.MirBlock, succ_id: u32) Result[*mir.MirBlock, str] {
    val pred_id: u32 = pred.id;
    val new_id:  u32 = fresh_block_id(ctx.f);

    val gr: Result[bool, str] = grow_block(ctx);
    if (is_err[bool, str](gr)) { ret err[*mir.MirBlock, str](unwrap_err[bool, str](gr)); }

    val f: *mir.MirFunction = ctx.f;
    val b: *mir.MirBlock = ?f.blocks[f.block_count];
    b.id          = new_id;
    b.instrs      = nil;
    b.instr_count = 0;
    b.instr_cap   = 0;
    b.preds       = nil;
    b.pred_count  = 0;
    b.pred_cap    = 0;

    # B's terminator: an unconditional branch to the merge block.
    val rb: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 1::usize);
    if (is_err[*mir.MirOperand, str](rb)) { ret err[*mir.MirBlock, str](unwrap_err[*mir.MirOperand, str](rb)); }
    val bops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](rb);
    bops[0] = mir.op_block(succ_id);
    var br: mir.MirInstr;
    br.opcode        = mir.MIR_BR;
    br.operands      = bops;
    br.operand_count = 1;
    br.width         = mir.WORD_WIDTH;
    br.src_width     = mir.WORD_WIDTH;
    # this splice bypasses lctx.push_instr, so enforce the asm_block invariant here:
    # struct locals are not zero-initialized, and regalloc.flatten reads a non-nil
    # asm_block as an inline-asm clobber barrier.
    br.asm_block     = nil;

    val ri: Result[*mir.MirInstr, str] = allocate[mir.MirInstr](ctx.alloc, 1::usize);
    if (is_err[*mir.MirInstr, str](ri)) { deallocate[mir.MirOperand](ctx.alloc, bops, 1::usize); ret err[*mir.MirBlock, str](unwrap_err[*mir.MirInstr, str](ri)); }
    b.instrs     = unwrap_ok[*mir.MirInstr, str](ri);
    b.instrs[0]  = br;
    b.instr_count = 1;
    b.instr_cap   = 1;

    # B's predecessor is `pred`.
    val rp: Result[*u32, str] = allocate[u32](ctx.alloc, 1::usize);
    if (is_err[*u32, str](rp)) { ret err[*mir.MirBlock, str](unwrap_err[*u32, str](rp)); }
    b.preds      = unwrap_ok[*u32, str](rp);
    b.preds[0]   = pred_id;
    b.pred_count = 1;
    b.pred_cap   = 1;

    f.block_count = f.block_count + 1;

    # retarget pred's CBR edge to succ so it now jumps to B, and replace succ's
    # predecessor entry for pred with B. both blocks are re-fetched by id since
    # the growth above may have moved the array.
    retarget_cbr(mir_block_by_id(f, pred_id), succ_id, new_id);
    replace_pred(mir_block_by_id(f, succ_id), pred_id, new_id);

    ret ok[*mir.MirBlock, str](?f.blocks[f.block_count - 1]);
}

# retarget_cbr: rewrite every mir.MIR_OP_BLOCK target operand of `mb`'s terminator
# that equals `from` to `to`. Used to redirect a conditional branch's edge
# through a freshly split block.
fun retarget_cbr(mb: *mir.MirBlock, from: u32, to: u32) {
    if (mb == nil || mb.instr_count == 0) { ret; }
    val term: *mir.MirInstr = ?mb.instrs[mb.instr_count - 1];
    var i: u32 = 0;
    for (i < term.operand_count) {
        if (term.operands[i].kind == mir.MIR_OP_BLOCK && term.operands[i].imm::u32 == from) {
            term.operands[i].imm = to::i64;
        }
        i = i + 1;
    }
}

# replace_pred: replace the first predecessor entry of `mb` equal to `from` with
# `to`, so a split block takes over the original predecessor's edge.
fun replace_pred(mb: *mir.MirBlock, from: u32, to: u32) {
    if (mb == nil) { ret; }
    var i: u32 = 0;
    for (i < mb.pred_count) {
        if (mb.preds[i] == from) { mb.preds[i] = to; ret; }
        i = i + 1;
    }
}

# lowers one IR instruction into one or more MIR instructions. OP_CALL expands
# into argument/call/result pseudos; OP_PHI is skipped here (phis are eliminated
# out of SSA by `lower_phis` into predecessor-end copies, never as body
# instructions); the memory opcodes (alloca / load / store / gep) have dedicated
# lowerings that form the stack slot and the `[base + disp]` memory operands the
# slot model resolves; every other opcode maps 1:1 to its generic MIR opcode.
fun lower_instr(ctx: *lctx.LowerCtx, fn: *ir.Function, mb: *mir.MirBlock, iid: id.InstructionId) Result[bool, str] {
    val gi: Option[*instr.Instruction] = ir.get_instruction(fn, iid);
    if (!is_some[*instr.Instruction](gi)) {
        ret err[bool, str]("mir.lower_ir: dangling instruction id");
    }
    val inst: *instr.Instruction = unwrap[*instr.Instruction](gi);

    if (inst.kind == instr.OP_CALL) {
        ret mabi.lower_call(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_RET) {
        ret mabi.lower_ret(ctx, mb, inst);
    }
    # phis live in `blk.phis`, never the body list, and are eliminated by
    # `lower_phis`; should one appear here, it is not a body instruction to emit.
    if (inst.kind == instr.OP_PHI) {
        ret ok[bool, str](true);
    }
    if (inst.kind == instr.OP_ALLOCA) {
        ret lower_alloca(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_LOAD) {
        ret lower_load(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_STORE) {
        ret lower_store(ctx, mb, inst);
    }
    if (inst.kind == instr.OP_MEMZERO) {
        ret lower_memzero(ctx, mb, inst);
    }
    if (inst.kind == instr.OP_VA_START) {
        ret lower_va_start(ctx, mb, inst);
    }
    if (inst.kind == instr.OP_VA_ARG) {
        ret lower_va_arg(ctx, mb, inst, iid);
    }
    if (inst.kind == instr.OP_VA_END) {
        ret ok[bool, str](true);
    }
    if (inst.kind == instr.OP_GEP) {
        ret lower_gep(ctx, mb, inst, iid);
    }
    # scalar floating-point arithmetic / comparison shares the IR integer opcodes
    # (the front end emits OP_ADD / OP_SUB / OP_MUL / OP_DIV_* / OP_CMP_* for both
    # int and float operands). a float instruction is dispatched to the dedicated
    # SSE lowering before the integer division / shift / generic paths, which would
    # emit the integer ALU / IDIV byte forms and silently miscompile an XMM-classed
    # value.
    if (is_float_op(ctx, inst)) {
        ret lower_float_op(ctx, mb, inst, iid);
    }
    # a scalar float negate shares the IR integer OP_NEG opcode; routing it to the
    # integer path would emit a GP mir.MIR_NEG (two's-complement of the float bit
    # pattern) instead of flipping the IEEE-754 sign bit. dispatch a float-typed
    # negate to its dedicated SSE lowering before the generic path.
    if (inst.kind == instr.OP_NEG && lctx.value_is_float(ctx, inst.ty)) {
        ret lower_float_neg(ctx, mb, inst, iid);
    }
    # integer division / remainder needs the dividend / remainder register wiring
    # the active ISA's division form mandates (x86-64 IDIV/DIV reads the dividend
    # in RAX and yields the quotient in RAX / remainder in RDX). the accumulator
    # and high-half registers come from `tgt.arch.div_reg` / `div_hi_reg`; an ISA
    # whose division wires no fixed register reports -1 and `lower_div` errors
    # loudly rather than emitting an un-pre-colored divide.
    if (inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_DIV_U ||
        inst.kind == instr.OP_REM_S || inst.kind == instr.OP_REM_U) {
        ret lower_div(ctx, mb, inst, iid);
    }

    # a shift (SHL / SHR_S / SHR_U) is two-address on x86-64 (`value op= count`),
    # and a register count must occupy the ISA's shift-count register (x86-64 CL).
    # it is lowered into the two-address form with a runtime count pre-colored into
    # `tgt.arch.shift_count_reg`; an ISA wiring no fixed shift-count register reports
    # -1 and `lower_shift` errors loudly rather than emitting an un-pre-colored shift.
    if (inst.kind == instr.OP_SHL || inst.kind == instr.OP_SHR_S ||
        inst.kind == instr.OP_SHR_U) {
        ret lower_shift(ctx, mb, inst, iid);
    }

    # an inline-asm block carries its body + `{name}` bindings in `fn.asm_blocks`
    # keyed by this instruction id; build the mir.MIR_ASM payload (resolving each
    # `{name}`'s alloca to its slot vreg) rather than dropping it through the
    # generic path, which keeps no asm field.
    if (inst.kind == instr.OP_ASM) {
        ret lower_asm_instr(ctx, mb, iid);
    }

    # a conditional branch whose condition lowers to a constant immediate (a
    # comptime-known / folded boolean) cannot drive the encoder's `TEST cond, cond`,
    # which requires a register. mirror cmach (`emit_cmp_branch` -> `load_operand`):
    # materialize the immediate into a register first, then branch on it.
    if (inst.kind == instr.OP_CBR) {
        ret lower_cbr(ctx, mb, inst, iid);
    }

    ret lower_generic(ctx, mb, inst, iid);
}

# lower_cbr: lower an IR OP_CBR `[cond, then_block, else_block]` into a
# `mir.MIR_CBR [cond, then, else]`. the then/else targets ride as mir.MIR_OP_BLOCK
# operands (per `lctx.lower_operand`). the condition is normally a register-resident
# boolean and lowers to a vreg operand, lowered unchanged. when the condition is
# a constant — a comptime-known / folded boolean reaching the back end as a
# VAL_CONST_INT — it lowers to a mir.MIR_OP_IMM, which the encoder's `TEST cond, cond`
# cannot read. mirror cmach's `emit_cmp_branch`, which routes the condition through
# `load_operand` (emitting `MOV reg, imm` for an immediate): materialize the
# immediate into a fresh GP vreg via `mir.MIR_MOV reg <- imm`, then branch on the
# register so the encoder always sees a register condition.
fun lower_cbr(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 3) {
        ret err[bool, str]("mir.lower_ir: conditional branch missing operands");
    }

    var cond: mir.MirOperand = lctx.lower_operand(ctx, inst, 0);
    if (cond.kind == mir.MIR_OP_IMM) {
        val rv: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (is_err[u32, str](rv)) { ret err[bool, str](unwrap_err[u32, str](rv)); }
        val creg: u32 = unwrap_ok[u32, str](rv);
        val mv: Result[bool, str] = lctx.emit_mov(ctx, mb, mir.op_vreg(creg), cond);
        if (is_err[bool, str](mv)) { ret mv; }
        cond = mir.op_vreg(creg);
    }

    val rop: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (is_err[*mir.MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = cond;
    ops[1] = lctx.lower_operand(ctx, inst, 1);
    ops[2] = lctx.lower_operand(ctx, inst, 2);

    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 3;
    set_generic_widths(ctx, inst, ?mi);
    # a conditional branch tests its boolean condition, but a bare bool value (e.g.
    # a struct's `tag` field) reaches the encoder in a register's low byte WITHOUT
    # being zero-extended — only a comparison result is widened by its MOVZX. test
    # the condition at its own width (1 byte for a bool, set_generic_widths leaves a
    # terminator at the machine word), so `TEST` reads only the meaningful low byte
    # instead of stale upper bits a full-width test would misread as a set condition.
    mi.width = lctx.op_width_of(ctx, inst.operands[0].ty);
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_asm_instr: build a mir.MIR_ASM instruction from the IR `IrAsm` payload bound
# to this OP_ASM instruction id. resolves the interned ISA / body strings to
# text and maps each `{name}` binding's alloca instruction id to the slot-owning
# vreg the encoder later turns into `[rbp+off]`. the payload is heap-owned and
# freed by `dnit_instr`.
fun lower_asm_instr(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, iid: id.InstructionId) Result[bool, str] {
    var key: id.InstructionId = iid;
    val pr: Result[*ir.IrAsm, str] = map.get[id.InstructionId, ir.IrAsm](?ctx.fn.asm_blocks, ?key);
    if (is_err[*ir.IrAsm, str](pr)) {
        ret err[bool, str]("mir.lower_ir: OP_ASM instruction has no asm payload");
    }
    val src: *ir.IrAsm = unwrap_ok[*ir.IrAsm, str](pr);

    val isa_opt: Option[str] = intern.lookup(ctx.interner, src.isa);
    if (!is_some[str](isa_opt)) { ret err[bool, str]("mir.lower_ir: inline-asm ISA tag not interned"); }
    val body_opt: Option[str] = intern.lookup(ctx.interner, src.body);
    if (!is_some[str](body_opt)) { ret err[bool, str]("mir.lower_ir: inline-asm body not interned"); }

    val rp: Result[*mir.MirAsm, str] = allocate[mir.MirAsm](ctx.alloc, 1::usize);
    if (is_err[*mir.MirAsm, str](rp)) { ret err[bool, str](unwrap_err[*mir.MirAsm, str](rp)); }
    val payload: *mir.MirAsm = unwrap_ok[*mir.MirAsm, str](rp);
    payload.isa        = unwrap[str](isa_opt);
    payload.body       = unwrap[str](body_opt);
    payload.binds      = nil;
    payload.bind_count = 0;

    if (src.bind_count > 0) {
        val rb: Result[*mir.MirAsmBind, str] = allocate[mir.MirAsmBind](ctx.alloc, src.bind_count::usize);
        if (is_err[*mir.MirAsmBind, str](rb)) {
            deallocate[mir.MirAsm](ctx.alloc, payload, 1::usize);
            ret err[bool, str](unwrap_err[*mir.MirAsmBind, str](rb));
        }
        payload.binds = unwrap_ok[*mir.MirAsmBind, str](rb);
        var k: u32 = 0;
        for (k < src.bind_count) {
            # a `{name}` local is the addressable storage behind an alloca; bind
            # to its slot-key vreg (which owns the frame slot) when the referenced
            # instruction is an alloca, else to the value's own vreg.
            var vreg: u32 = lctx.slot_key_vreg(ctx, src.binds[k].instr);
            if (vreg == mir.MIR_VREG_NIL) { vreg = lctx.instr_vreg(ctx, src.binds[k].instr); }
            if (vreg == mir.MIR_VREG_NIL) {
                deallocate[mir.MirAsmBind](ctx.alloc, payload.binds, src.bind_count::usize);
                deallocate[mir.MirAsm](ctx.alloc, payload, 1::usize);
                ret err[bool, str]("mir.lower_ir: inline-asm '{name}' local has no slot vreg");
            }
            payload.binds[k].name      = src.binds[k].name;
            payload.binds[k].slot_vreg = vreg;
            k = k + 1;
        }
        payload.bind_count = src.bind_count;
    }

    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_ASM;
    mi.operands      = nil;
    mi.operand_count = 0;
    mi.width         = 0;
    mi.src_width     = 0;
    mi.asm_block     = payload;

    val push: Result[bool, str] = lctx.push_instr(ctx, mb, mi);
    if (is_err[bool, str](push)) {
        if (payload.binds != nil) { deallocate[mir.MirAsmBind](ctx.alloc, payload.binds, payload.bind_count::usize); }
        deallocate[mir.MirAsm](ctx.alloc, payload, 1::usize);
        ret push;
    }
    ret ok[bool, str](true);
}

# lower_shift: lower an integer OP_SHL / OP_SHR_S / OP_SHR_U into a three-address
# generic shift `mir.MIR_SHL/SHR_S/SHR_U [dst, value, count]`. the IR operands are
# `[value, count]`. operand 0 (`dst`) is a pure def, so the register allocator
# treats it cleanly (the encoder materializes the two-address `MOV dst, value ;
# shift dst, count` byte form). a constant count rides as an immediate; a runtime
# count is pre-colored into RCX (the only register the x86-64 variable-shift form
# reads, as CL) by a preceding `mir.MIR_MOV RCX <- count`, mirroring the division's
# RAX:RDX pre-coloring. a function with a register-count shift reserves RCX from
# allocation (see `regalloc.function_has_reg_shift`) so no live value collides
# with the count.
fun lower_shift(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: shift missing value or count operand");
    }
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: shift defines no result vreg");
    }
    # a sub-word shift result, like any narrow GP ALU write, leaves the upper
    # register bits undefined; clamp the operation width so the spilled word stays
    # clean (mirrors `set_generic_widths` and the byte-divide promotion).
    val w: u8 = lctx.clamp_alu_width(lctx.op_width_of(ctx, inst.ty));

    var op: mir.MirOpcode = mir.MIR_SHR_U;
    if (inst.kind == instr.OP_SHL)   { op = mir.MIR_SHL; }
    or (inst.kind == instr.OP_SHR_S) { op = mir.MIR_SHR_S; }

    val value: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    val count: mir.MirOperand = lctx.lower_value(ctx, inst.operands[1]);

    var count_op: mir.MirOperand = count;
    if (count.kind != mir.MIR_OP_IMM) {
        # a runtime count must occupy the ISA's shift-count register (x86-64 CL);
        # move it there and reference it so the encoder selects the `shift r/m, CL`
        # form. the register is reserved from allocation for the whole function, so
        # this move cannot clobber a live value. an ISA wiring no fixed shift-count
        # register (`shift_count_reg < 0`) cannot lower a runtime-count shift here.
        val cnt_reg: i32 = ctx.tgt.arch.shift_count_reg;
        if (cnt_reg < 0) {
            ret err[bool, str]("mir.lower_ir: ISA wires no shift-count register for a runtime shift count");
        }
        val mc: Result[bool, str] = lctx.emit_mov_w(ctx, mb, mir.op_preg(cnt_reg::u32), count, w);
        if (is_err[bool, str](mc)) { ret mc; }
        count_op = mir.op_preg(cnt_reg::u32);
    }

    # the three-address shift: operand 0 is the pure-def destination, operand 1 the
    # value shifted, operand 2 the count (immediate or CL). the opcode survives isel.
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = value;
    ops[2] = count_op;
    var mi: mir.MirInstr;
    mi.opcode        = op;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_div: lower an integer OP_DIV_*/OP_REM_* into the x86-64 RAX:RDX division
# sequence with explicit register pre-coloring, mirroring the call/return ABI
# pre-coloring approach. the IR operands are `[a, b]` (dividend, divisor). the
# emitted sequence is, in order:
#   - `mir.MIR_MOV RAX <- a` — the dividend occupies the accumulator;
#   - the divide pseudo `mir.MIR_DIV_S/DIV_U/REM_S/REM_U [RAX, b]` — operand 0 is the
#     implicit RAX dividend/result register (so the register allocator reads a
#     non-defining barrier whose operand 1 is the divisor use), operand 1 is the
#     divisor `b`. the opcode survives instruction selection unchanged; the encoder
#     materializes the dividend high-half setup (CWD/CDQ/CQO sign-extension for the
#     signed forms, `XOR RDX, RDX` zero-extension for the unsigned forms) followed
#     by the single-operand `IDIV b` / `DIV b`;
#   - `mir.MIR_MOV dst <- RAX` for a division, or `mir.MIR_MOV dst <- RDX` for a remainder
#     — the quotient lands in RAX and the remainder in RDX.
# the divide clobbers RAX and RDX; regalloc keeps both out of allocation for any
# function that divides (they are caller-saved, so no prologue cost), so no live
# value or the divisor `b` can collide with the dividend wiring. the operation
# width (2/4/8 bytes — a byte divide is promoted to 32 bits below) is carried on
# the divide so the encoder selects the matching sign-extension opcode and sets
# REX.W / the 0x66 prefix.
fun lower_div(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: division missing dividend or divisor operand");
    }
    # floating-point division never reaches here: `lower_instr` dispatches every
    # float arithmetic / comparison op to `lower_float_op` (which emits mir.MIR_FDIV)
    # before this integer-division path.
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: division defines no result vreg");
    }
    # the ISA's division form hard-wires the dividend / quotient accumulator and the
    # high-half / remainder register (x86-64 RAX:RDX). an ISA wiring no fixed
    # division register (`div_reg < 0` / `div_hi_reg < 0`) cannot lower an integer
    # division through this pre-coloring path; fail loudly rather than emit one with
    # an invalid register.
    val acc_reg: i32 = ctx.tgt.arch.div_reg;
    val hi_reg:  i32 = ctx.tgt.arch.div_hi_reg;
    if (acc_reg < 0 || hi_reg < 0) {
        ret err[bool, str]("mir.lower_ir: ISA wires no division registers for an integer divide");
    }
    val signed: bool = inst.kind == instr.OP_DIV_S || inst.kind == instr.OP_REM_S;

    # x86-64 has no 8-bit dividend high register (a byte divide puts the dividend
    # in AX and the remainder in AH, not RDX), so a byte division is promoted to a
    # 32-bit divide: both operands are extended to 32 bits, the divide runs at
    # width 4 (remainder in EDX, quotient in EAX), and the result move truncates
    # back to the byte destination. 16/32/64-bit divisions run at their natural
    # width with the remainder in (R)DX.
    val natural_w: u8 = lctx.op_width_of(ctx, inst.ty);
    var w: u8 = natural_w;
    if (w < 4) { w = 4; }

    val dividend: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    val divisor:  mir.MirOperand = lctx.lower_value(ctx, inst.operands[1]);

    # the dividend occupies the accumulator (x86-64 RAX) before the divide. a
    # promoted byte dividend is widened into it; otherwise it is a plain width-w move.
    val mr: Result[bool, str] = emit_promote(ctx, mb, mir.op_preg(acc_reg::u32), dividend, w, natural_w, signed);
    if (is_err[bool, str](mr)) { ret mr; }

    # the divisor must live in a register or memory — x86-64 IDIV / DIV has no
    # immediate divisor form — so an immediate divisor is materialized into a fresh
    # value vreg. a promoted byte divisor is likewise widened into a fresh vreg. a
    # register / memory divisor at the natural width is used directly.
    var div_op: mir.MirOperand = divisor;
    if (natural_w < w || divisor.kind == mir.MIR_OP_IMM) {
        val bvr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (is_err[u32, str](bvr)) { ret err[bool, str](unwrap_err[u32, str](bvr)); }
        val bv: u32 = unwrap_ok[u32, str](bvr);
        val ex: Result[bool, str] = emit_promote(ctx, mb, mir.op_vreg(bv), divisor, w, natural_w, signed);
        if (is_err[bool, str](ex)) { ret ex; }
        div_op = mir.op_vreg(bv);
    }

    # the divide itself: operand 0 is the implicit accumulator dividend/result
    # register (x86-64 RAX) and operand 1 is the divisor. the opcode survives
    # instruction selection; the encoder materializes the high-half setup + IDIV/DIV.
    val rop: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_preg(acc_reg::u32);
    ops[1] = div_op;
    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    val pd: Result[bool, str] = lctx.push_instr(ctx, mb, mi);
    if (is_err[bool, str](pd)) { ret pd; }

    # the quotient lands in the accumulator (x86-64 RAX) and the remainder in the
    # high-half register (RDX); move the canonical result register into the result
    # vreg. the move is driven at the destination's natural width, truncating a
    # promoted byte result.
    var res_reg: i32 = acc_reg;
    if (inst.kind == instr.OP_REM_S || inst.kind == instr.OP_REM_U) {
        res_reg = hi_reg;
    }
    ret lctx.emit_mov_w(ctx, mb, mir.op_vreg(dst), mir.op_preg(res_reg::u32), natural_w);
}

# emit_promote: move `src` into `dst` at `dst_w` bytes, widening from `src_w` when
# the source is narrower. an immediate source carries its full value, so it is a
# plain width-`dst_w` move (a MOVSX/MOVZX of an immediate has no encoding). a
# register / memory source narrower than the destination is sign-extended
# (`signed`, → MOVSX) or zero-extended (→ MOVZX); at equal width it is a plain
# move. used to load a division's dividend into RAX and to widen a promoted byte
# divisor into a value vreg.
fun emit_promote(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand,
                 dst_w: u8, src_w: u8, signed: bool) Result[bool, str] {
    if (src_w >= dst_w || src.kind == mir.MIR_OP_IMM) {
        ret lctx.emit_mov_w(ctx, mb, dst, src, dst_w);
    }
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = dst;
    ops[1] = src;
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_ZEXT;
    if (signed) { mi.opcode = mir.MIR_SEXT; }
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = dst_w;
    mi.src_width     = src_w;
    ret lctx.push_instr(ctx, mb, mi);
}

# lowers a non-call IR instruction by mapping its opcode 1:1 to the generic MIR
# opcode of the same number and emitting [dst?, operands...]. branch operands
# that name block targets become mir.MIR_OP_BLOCK operands.
fun lower_generic(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    # scalar floating-point arithmetic / comparison shares the IR integer opcodes
    # (OP_ADD / OP_SUB / OP_MUL / OP_CMP_* operate on both int and float operands),
    # but a float instruction never reaches here: `lower_instr` dispatches it to
    # `lower_float_op` (emitting the dedicated mir.MIR_FADD / FSUB / FMUL / FDIV / FCMP
    # SSE opcodes) before the generic path. the float CONVERSIONS (FP_TRUNC / FP_EXT
    # / FP_TO_SI / SI_TO_FP / ...) carry their own opcodes and SSE encoders and DO
    # ride this generic path unchanged.
    val dst: u32 = lctx.result_vreg(ctx, iid);
    val has_dst: bool = dst != mir.MIR_VREG_NIL;
    var total: u32 = inst.operand_count;
    if (has_dst) { total = total + 1; }

    var ops: *mir.MirOperand = nil;
    if (total > 0) {
        val rop: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, total::usize);
        if (is_err[*mir.MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](rop)); }
        ops = unwrap_ok[*mir.MirOperand, str](rop);
    }

    var base: u32 = 0;
    if (has_dst) {
        ops[0] = mir.op_vreg(dst);
        base = 1;
    }

    var k: u32 = 0;
    for (k < inst.operand_count) {
        var op: mir.MirOperand = lctx.lower_operand(ctx, inst, k);
        # a global / function symbol operand is its ADDRESS as an rvalue; left as a
        # bare mir.MIR_OP_SYM the encoder would load `[sym]` into this ALU / compare /
        # bitcast slot (the symbol's contents) instead of its address. LEA-
        # materialize it into a vreg first, mirroring the store / call-arg / return
        # symbol paths.
        if (op.kind == mir.MIR_OP_SYM) {
            var av: u32 = mir.MIR_VREG_NIL;
            val ar: Result[bool, str] = lctx.addr_to_vreg(ctx, mb, op, ?av);
            if (is_err[bool, str](ar)) { ret ar; }
            op = mir.op_vreg(av);
        }
        ops[base + k] = op;
        k = k + 1;
    }

    var mi: mir.MirInstr;
    mi.opcode        = inst.kind::u32;
    mi.operands      = ops;
    mi.operand_count = total;
    set_generic_widths(ctx, inst, ?mi);
    ret lctx.push_instr(ctx, mb, mi);
}

# set_generic_widths: derive the destination and source operand widths for a
# 1:1-lowered IR instruction and stamp them onto the MIR instruction. the result
# width is the instruction's own result type, except:
#   - a width-changing integer conversion (TRUNC / SEXT / ZEXT) keeps the
#     destination width from the result type but takes its source width from operand
#     0, so the encoder's MOVZX / MOVSX selects the narrow / wide source form;
#   - a comparison (CMP_*) yields an i8 result but the CMP operates at the compared
#     operand width, so both widths come from operand 0;
#   - the float conversions (FP_TO_SI / SI_TO_FP family) carry their true result and
#     operand-0 widths so the SSE conversion encoder selects the SS-vs-SD float form
#     from the float side and sizes the GP integer side for REX.W (`set_conv_widths`);
#   - a void-result terminator / branch has no natural width and rides at the word
#     width, which only sizes its address-sized fields.
fun set_generic_widths(ctx: *lctx.LowerCtx, inst: *instr.Instruction, mi: *mir.MirInstr) {
    if (is_float_kind(ctx, inst)) {
        set_conv_widths(ctx, inst, mi);
        ret;
    }
    if (is_compare_kind(inst.kind) && inst.operand_count >= 1) {
        val w: u8 = lctx.op_width_of(ctx, inst.operands[0].ty);
        mi.width     = w;
        mi.src_width = w;
        ret;
    }
    var dw: u8 = mir.WORD_WIDTH;
    if (!instr.is_terminator(inst.kind)) { dw = lctx.op_width_of(ctx, inst.ty); }
    # a register-writing integer ALU result must be defined across the full width
    # it is later spilled / reloaded at, or a sub-word op's undefined upper bits
    # leak through the word-width spill into a downstream full-width use. the
    # conversions are excluded: their destination width selects the MOVZX / MOVSX
    # narrow form and is load-bearing, not a clamp candidate.
    if (is_int_alu_kind(inst.kind)) { dw = lctx.clamp_alu_width(dw); }
    var sw: u8 = dw;
    if (is_int_conversion_kind(inst.kind) && inst.operand_count >= 1) {
        sw = lctx.op_width_of(ctx, inst.operands[0].ty);
    }
    mi.width     = dw;
    mi.src_width = sw;
}

# set_conv_widths: stamp the destination and source widths of a float conversion
# (FP_TO_SI / FP_TO_UI / SI_TO_FP / UI_TO_FP / FP_TRUNC / FP_EXT). `mi.width` is the
# result-type width and `mi.src_width` is operand 0's width. the SSE conversion
# encoder reads the FLOAT side of the pair (the side whose type is f32 / f64,
# determined from the concrete opcode) to pick the single-precision SS vs double SD
# form, and sizes the GP integer side from its own width for REX.W. an FP_TRUNC /
# FP_EXT has float on both sides; its single opcode needs no width selection, so the
# carried widths only document the operand sizes.
fun set_conv_widths(ctx: *lctx.LowerCtx, inst: *instr.Instruction, mi: *mir.MirInstr) {
    var dw: u8 = lctx.op_width_of(ctx, inst.ty);
    var sw: u8 = dw;
    if (inst.operand_count >= 1) { sw = lctx.op_width_of(ctx, inst.operands[0].ty); }
    mi.width     = dw;
    mi.src_width = sw;
}

# is_int_alu_kind: true for the integer arithmetic / bitwise opcodes whose result
# is materialized by a width-sized GP ALU write (ADD / SUB / MUL / NEG / AND / OR /
# XOR / NOT, and the shifts). a sub-word write of one of these leaves the upper
# register bits undefined, so its result width is clamped to `mir.ALU_MIN_WIDTH`. the
# divisions are excluded — `lower_div` already promotes a byte divide to 32 bits.
fun is_int_alu_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_ADD || k == instr.OP_SUB || k == instr.OP_MUL ||
        k == instr.OP_NEG || k == instr.OP_AND || k == instr.OP_OR ||
        k == instr.OP_XOR || k == instr.OP_NOT ||
        k == instr.OP_SHL || k == instr.OP_SHR_S || k == instr.OP_SHR_U;
}

# is_compare_kind: true for the IR comparison opcodes whose CMP operates at the
# operand width rather than the i8 result width.
fun is_compare_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_CMP_EQ || k == instr.OP_CMP_NE ||
        k == instr.OP_CMP_LT_S || k == instr.OP_CMP_LT_U ||
        k == instr.OP_CMP_LE_S || k == instr.OP_CMP_LE_U;
}

# is_int_conversion_kind: true for the width-changing integer conversions whose
# source operand width differs from the destination width (so the encoder must size
# the source operand independently). the float conversions are excluded — their
# operand widths are driven by the float encoders.
fun is_int_conversion_kind(k: instr.InstrKind) bool {
    ret k == instr.OP_TRUNC || k == instr.OP_SEXT || k == instr.OP_ZEXT;
}

# is_float_op: true for a scalar floating-point arithmetic (OP_ADD / OP_SUB /
# OP_MUL / OP_DIV_*) or comparison (OP_CMP_*) instruction that shares an IR integer
# opcode. these select to SSE forms in `lower_float_op` rather than the integer ALU
# / IDIV / CMP byte forms, which would miscompile an XMM-classed value. the float
# CONVERSIONS (FP_TRUNC / FP_EXT / FP_TO_SI / FP_TO_UI / SI_TO_FP / UI_TO_FP) carry
# their own opcodes and SSE encoders and ride the generic path, so they are NOT
# claimed here. an op is float when its result or first operand is a float type.
fun is_float_op(ctx: *lctx.LowerCtx, inst: *instr.Instruction) bool {
    val k: instr.InstrKind = inst.kind;
    var shared: bool = false;
    if (k == instr.OP_ADD || k == instr.OP_SUB || k == instr.OP_MUL ||
        k == instr.OP_DIV_S || k == instr.OP_DIV_U) { shared = true; }
    if (is_compare_kind(k)) { shared = true; }
    if (!shared) { ret false; }
    if (lctx.value_is_float(ctx, inst.ty)) { ret true; }
    if (inst.operand_count >= 1 && lctx.value_is_float(ctx, inst.operands[0].ty)) { ret true; }
    ret false;
}

# float_op_width: the SSE operation width (4 for f32, 8 for f64) of a float
# arithmetic / comparison instruction. an arithmetic op takes it from its own float
# result type; a comparison's result is i8, so it takes the width from the compared
# float operand (operand 0).
fun float_op_width(ctx: *lctx.LowerCtx, inst: *instr.Instruction) u8 {
    if (is_compare_kind(inst.kind) && inst.operand_count >= 1) {
        ret lctx.op_width_of(ctx, inst.operands[0].ty);
    }
    ret lctx.op_width_of(ctx, inst.ty);
}

# float_cmp_cc: the FCC_* float-comparison condition code realizing an IR compare
# opcode. the front end emits only the EQ / NE / LT / LE forms (GT / GE are
# canonicalized to LT / LE with swapped operands), and a float compare is unordered-
# aware via UNSIGNED SETcc, so signedness is irrelevant: OP_CMP_LT_S and
# OP_CMP_LT_U both map to mir.FCC_LT.
fun float_cmp_cc(k: instr.InstrKind) u8 {
    if (k == instr.OP_CMP_EQ)   { ret mir.FCC_EQ; }
    if (k == instr.OP_CMP_NE)   { ret mir.FCC_NE; }
    if (k == instr.OP_CMP_LT_S || k == instr.OP_CMP_LT_U) { ret mir.FCC_LT; }
    ret mir.FCC_LE;
}

# lower_float_op: lower a scalar floating-point arithmetic / comparison instruction
# to its dedicated SSE MIR opcode (mir.MIR_FADD / FSUB / FMUL / FDIV for the four
# arithmetic ops, mir.MIR_FCMP for a comparison). the opcode survives instruction
# selection and the encoder materializes the SSE byte sequence (operands loaded
# into XMM scratch, the SSE op, the result stored back) — mirroring cmach's
# `emit_float_op` / `emit_float_cmp`. the operation width (4 for f32, 8 for f64)
# rides on `mi.width` so the encoder selects the SS vs SD form; a mir.MIR_FCMP also
# carries its FCC_* condition on `mi.src_width`. the layout is `[dst, lhs, rhs]`
# like the generic three-address ALU / compare forms.
fun lower_float_op(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: float op missing operand");
    }
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: float op defines no result vreg");
    }

    val rop: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (is_err[*mir.MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_vreg(dst);
    ops[1] = lctx.lower_value(ctx, inst.operands[0]);
    ops[2] = lctx.lower_value(ctx, inst.operands[1]);

    val w: u8 = float_op_width(ctx, inst);

    var mi: mir.MirInstr;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = w;
    mi.src_width     = w;

    val k: instr.InstrKind = inst.kind;
    if (is_compare_kind(k)) {
        mi.opcode    = mir.MIR_FCMP;
        mi.src_width = float_cmp_cc(k);
    } or (k == instr.OP_ADD) {
        mi.opcode = mir.MIR_FADD;
    } or (k == instr.OP_SUB) {
        mi.opcode = mir.MIR_FSUB;
    } or (k == instr.OP_MUL) {
        mi.opcode = mir.MIR_FMUL;
    } or {
        mi.opcode = mir.MIR_FDIV;
    }

    ret lctx.push_instr(ctx, mb, mi);
}

# lower_float_neg: lower a scalar floating-point negation (a float-typed OP_NEG) to
# the dedicated mir.MIR_FNEG opcode. the opcode survives instruction selection and the
# encoder flips the IEEE-754 sign bit on the XMM value (XORPS with a width-selected
# sign mask) rather than the integer mir.MIR_NEG, which would two's-complement the whole
# bit pattern and produce garbage. operand layout is `[dst, src]` like a float MOV;
# the operation width (4 for f32, 8 for f64) rides on `mi.width` so the encoder
# selects the f32 vs f64 sign-bit mask.
fun lower_float_neg(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count < 1) {
        ret err[bool, str]("mir.lower_ir: float negate missing operand");
    }
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: float negate defines no result vreg");
    }

    val rop: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](rop)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](rop)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](rop);
    ops[0] = mir.op_vreg(dst);
    ops[1] = lctx.lower_value(ctx, inst.operands[0]);

    val w: u8 = lctx.op_width_of(ctx, inst.ty);

    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_FNEG;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = w;
    mi.src_width     = w;
    ret lctx.push_instr(ctx, mb, mi);
}

# is_float_kind: true when an instruction's result or first operand is a float, so
# its width is driven by the float encoders rather than this integer base-width
# carrier. the float conversions, scalar float arithmetic, and float comparisons
# all reach lowering through the generic path and must not be re-sized here.
fun is_float_kind(ctx: *lctx.LowerCtx, inst: *instr.Instruction) bool {
    if (inst.kind == instr.OP_FP_TO_SI || inst.kind == instr.OP_FP_TO_UI ||
        inst.kind == instr.OP_SI_TO_FP || inst.kind == instr.OP_UI_TO_FP ||
        inst.kind == instr.OP_FP_TRUNC || inst.kind == instr.OP_FP_EXT) {
        ret true;
    }
    if (lctx.value_is_float(ctx, inst.ty)) { ret true; }
    if (inst.operand_count >= 1 && lctx.value_is_float(ctx, inst.operands[0].ty)) { ret true; }
    ret false;
}

# lower_alloca: lower an OP_ALLOCA into a stack-slot reservation plus the address
# materialization. the instruction's type is the allocated ELEMENT type (the
# result Value is a pointer); operand 0 is the element count. a fresh internal
# slot-key vreg owns a mir.SLOT_ALLOCA frame slot sized `element_size * count` and is
# used only as the LEA base, so regalloc never register-allocates it and the
# encoder resolves it to `[rbp + offset]`. the emitted `mir.MIR_ALLOCA (result) <-
# [slot]` selects to `LEA result, [rbp + offset]`, leaving the allocation's
# address in the result vreg as an ordinary pointer for downstream uses.
fun lower_alloca(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: alloca with no count operand");
    }
    val cv: value.Value = inst.operands[0];
    if (cv.kind != value.VAL_CONST_INT) {
        ret err[bool, str]("mir.lower_ir: non-constant alloca count unsupported");
    }
    val count: u64 = cv.data.int_lit;

    # the element type is the instruction's own type; size and align the slot from
    # it. the allocated region is `count` contiguous elements.
    val elem_size: u32  = ir_type.byte_size(ctx.types, inst.ty, ctx.tgt);
    val elem_align: u32 = ir_type.byte_align(ctx.types, inst.ty, ctx.tgt);
    val total: u64 = elem_size::u64 * count;

    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: alloca defines no result vreg");
    }

    # an internal slot-key vreg owns the storage; it is addressed only as a MEM
    # base, never register-allocated.
    val skr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (is_err[u32, str](skr)) { ret err[bool, str](unwrap_err[u32, str](skr)); }
    val sk: u32 = unwrap_ok[u32, str](skr);

    val ar: Result[bool, str] = lctx.add_alloca_slot(ctx, sk, total, elem_align);
    if (is_err[bool, str](ar)) { ret ar; }

    # record the slot-key vreg under this alloca's instruction id so an
    # inline-asm `{name}` binding referencing the alloca resolves to its slot.
    if (ctx.slot_key_vregs != nil && iid::u32 < ctx.instr_count) {
        ctx.slot_key_vregs[iid::u32] = sk;
    }

    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = mir.op_mem_slot(sk, 0);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_ALLOCA;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the alloca selects to a LEA computing a pointer-sized address.
    mi.width         = mir.WORD_WIDTH;
    mi.src_width     = mir.WORD_WIDTH;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_load: lower an OP_LOAD into `mir.MIR_LOAD (dst) <- [ptr]`. operand 0 is the
# pointer; a pointer that lowers to a vreg becomes the MEM base (so an alloca
# address resolves to `[rbp + offset]` and a runtime pointer to `[reg]`), while a
# symbol / immediate pointer is left as a plain operand for the encoder to form
# its own reference. the result vreg is the loaded value.
#
# a FLOAT load is a plain mir.MIR_MOV whose result is an XMM-class vreg; the encoder
# dispatches it on operand class and materializes a MOVSS / MOVSD off the resolved
# operand WITHOUT recording a symbol relocation (that path has no patch-site hook).
# a global / function symbol pointer must therefore be LEA-materialized into a GP
# base vreg first (the LEA carries the relocation through the generic path), so the
# float load addresses `[base]` rather than an unrelocated `[rip+sym]` that would
# read the wrong address. an integer load keeps the symbol operand: its generic
# encoding records the relocation directly.
fun lower_load(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: load with no pointer operand");
    }
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: load defines no result vreg");
    }
    var mem: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);
    if (mem.kind == mir.MIR_OP_SYM && lctx.value_is_float(ctx, inst.ty)) {
        var base: u32 = mir.MIR_VREG_NIL;
        val ar: Result[bool, str] = lctx.addr_to_vreg(ctx, mb, mem, ?base);
        if (is_err[bool, str](ar)) { ret err[bool, str](unwrap_err[bool, str](ar)); }
        mem = mir.op_mem_value(base, 0);
    }
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = mem;
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_LOAD;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the load accesses memory at the loaded result type's width (`src_width`) but
    # must DEFINE the full register it lands in (`width`): a sub-word load of a
    # scalar leaves the upper register bits undefined, and a downstream wider use
    # (e.g. a mixed-width integer compare reading the value at the other operand's
    # width) would read that garbage. clamping the destination width to
    # `mir.ALU_MIN_WIDTH` — the same full-register-definition invariant `lctx.clamp_alu_width`
    # gives a sub-word ALU result — makes the backend zero-extend the load into a
    # clean register (a wider load keeps its own width, so width == src_width there).
    mi.src_width     = lctx.op_width_of(ctx, inst.ty);
    mi.width         = lctx.clamp_alu_width(mi.src_width);
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_store: lower an OP_STORE into `mir.MIR_STORE [ptr] <- (value)`. the IR operand
# order is [value, ptr]; the MIR destination (operand 0) is the pointer's MEM
# reference and operand 1 is the stored value, matching the store convention the
# ABI lowering and the encoder share (operand 0 = memory destination). a store
# whose value is an aggregate is a storage-to-storage copy: the value operand is
# the source aggregate's storage pointer (aggregates flow by address — see the
# lower expr aggregate-rvalue rules), so it is expanded into a sized memcpy rather
# than a single scalar store.
fun lower_store(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) Result[bool, str] {
    if (inst.operand_count < 2) {
        ret err[bool, str]("mir.lower_ir: store missing value or pointer operand");
    }
    if (lctx.value_is_aggregate(ctx, inst.operands[0].ty)) {
        ret lower_store_aggregate(ctx, mb, inst);
    }
    # the stored scalar value. a global / function symbol lowers to its address as
    # an rvalue (`mir.op_sym`), and x86-64 cannot store a 64-bit symbol address straight
    # to memory (the encoder's mem-to-mem split would load the symbol's contents, not
    # its address) — so a symbol value is LEA-materialized into a register first,
    # mirroring the aggregate / by-reference / sret paths.
    var stored: mir.MirOperand = lctx.lower_value(ctx, inst.operands[0]);
    if (stored.kind == mir.MIR_OP_SYM) {
        var addr: u32 = mir.MIR_VREG_NIL;
        val ar: Result[bool, str] = lctx.addr_to_vreg(ctx, mb, stored, ?addr);
        if (is_err[bool, str](ar)) { ret ar; }
        stored = mir.op_vreg(addr);
    }
    # a FLOAT store is a plain mir.MIR_MOV whose stored value is an XMM-class vreg; the
    # encoder dispatches it on operand class and records no symbol relocation for its
    # destination MEM. a global symbol destination must therefore be LEA-materialized
    # into a GP base vreg first (so the store addresses `[base]`), mirroring the
    # float-load path; an integer store keeps the symbol destination and relocates
    # through the generic encoding.
    var dest: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[1]);
    if (dest.kind == mir.MIR_OP_SYM && lctx.value_is_float(ctx, inst.operands[0].ty)) {
        var dbase: u32 = mir.MIR_VREG_NIL;
        val dr: Result[bool, str] = lctx.addr_to_vreg(ctx, mb, dest, ?dbase);
        if (is_err[bool, str](dr)) { ret err[bool, str](unwrap_err[bool, str](dr)); }
        dest = mir.op_mem_value(dbase, 0);
    }
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = dest;
    ops[1] = stored;
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_STORE;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the store accesses memory at the stored value's type width (IR operand 0);
    # the store result is void, so the value type is the only width carrier.
    mi.width         = lctx.op_width_of(ctx, inst.operands[0].ty);
    mi.src_width     = mi.width;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_store_aggregate: expand an OP_STORE of an aggregate into a memcpy from the
# source aggregate's storage to the destination. both IR operands are pointers to
# storage (operand 0 = source aggregate address, operand 1 = destination address),
# matching the by-address convention aggregate rvalues flow under. the copy walks
# the aggregate in 8-byte chunks, finishing any 4/2/1-byte tail, emitting a
# `mir.MIR_LOAD scratch <- [src + off]` / `mir.MIR_STORE [dst + off] <- scratch` pair per
# chunk. a fresh scratch vreg per chunk keeps each load/store independent for the
# register allocator. a zero-sized aggregate copies nothing.
fun lower_store_aggregate(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) Result[bool, str] {
    val size: u32 = ir_type.byte_size(ctx.types, inst.operands[0].ty, ctx.tgt);
    var off: i64 = 0;
    for (off::u32 < size) {
        val remaining: u32 = size - off::u32;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        } or (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val src: mir.MirOperand = agg_pointer_mem(ctx, inst.operands[0], off);
        val dst: mir.MirOperand = agg_pointer_mem(ctx, inst.operands[1], off);

        val tr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (is_err[u32, str](tr)) { ret err[bool, str](unwrap_err[u32, str](tr)); }
        val tmp: u32 = unwrap_ok[u32, str](tr);

        val ldr: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
        if (is_err[*mir.MirOperand, str](ldr)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](ldr)); }
        val ldops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](ldr);
        ldops[0] = mir.op_vreg(tmp);
        ldops[1] = src;
        var ld: mir.MirInstr;
        ld.opcode        = mir.MIR_LOAD;
        ld.operands      = ldops;
        ld.operand_count = 2;
        ld.width         = chunk;
        ld.src_width     = chunk;
        val pl: Result[bool, str] = lctx.push_instr(ctx, mb, ld);
        if (is_err[bool, str](pl)) { ret pl; }

        val st: Result[bool, str] = lctx.push_store_chunk(ctx, mb, dst, mir.op_vreg(tmp), chunk);
        if (is_err[bool, str](st)) { ret st; }

        off = off + chunk::i64;
    }
    ret ok[bool, str](true);
}

# lower_memzero: expand an OP_MEMZERO into a sized zero-fill of the destination
# aggregate's storage. operand 0 is the destination pointer and `aux_ty` is the
# pointee aggregate type whose `byte_size` is the byte count to clear (operand 0
# is an untyped IRT_PTR, so the size cannot come from its `.ty` — it must come
# from `aux_ty`). mirrors `lower_store_aggregate`, but each chunk stores an
# immediate 0 (`MOV [mem], 0`) rather than a value loaded from a source — no
# scratch register and no source read. the fill walks 8/4/2/1-byte chunks so a
# 4/2/1-byte tail clears exactly its bytes without writing past the aggregate.
# a zero-sized aggregate clears nothing.
fun lower_memzero(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) Result[bool, str] {
    if (inst.operand_count < 1) {
        ret err[bool, str]("mir.lower_ir: memzero missing destination pointer operand");
    }
    if (inst.aux_ty == ir_type.IRT_NIL) {
        ret err[bool, str]("mir.lower_ir: memzero is missing its pointee type");
    }
    val size: u32 = ir_type.byte_size(ctx.types, inst.aux_ty, ctx.tgt);
    var off: i64 = 0;
    for (off::u32 < size) {
        val remaining: u32 = size - off::u32;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        } or (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val dst: mir.MirOperand = agg_pointer_mem(ctx, inst.operands[0], off);
        val st: Result[bool, str] = lctx.push_store_chunk(ctx, mb, dst, mir.op_imm(0), chunk);
        if (is_err[bool, str](st)) { ret st; }

        off = off + chunk::i64;
    }
    ret ok[bool, str](true);
}

# agg_pointer_mem: form the MEM operand addressing an aggregate's storage at a byte
# displacement, given the IR Value naming that storage pointer. a pointer that
# lowers to a value vreg (an alloca result or runtime pointer) becomes a value-vreg
# `[base + disp]` MEM operand; a global aggregate lowers to a symbol whose storage
# is addressed `[rip + sym + disp]`, the displacement riding in the symbol addend.
# matches `lctx.mem_operand_of`'s base disambiguation, extended with the displacement
# the per-chunk copy needs.
fun agg_pointer_mem(ctx: *lctx.LowerCtx, v: value.Value, disp: i64) mir.MirOperand {
    val op: mir.MirOperand = lctx.lower_value(ctx, v);
    if (op.kind == mir.MIR_OP_VREG) { ret mir.op_mem_value(op.vreg, disp); }
    if (op.kind == mir.MIR_OP_SYM)  { ret mir.op_sym(op.sym, op.sym_off + disp::i32); }
    ret op;
}

# lower_gep: lower an OP_GEP into `mir.MIR_GEP (dst) <- [base + index*scale + disp]`
# (selected to LEA), folding the index walk into the effective address. the IR
# operands are `[base, idx0, idx1, ...]` and the instruction's `aux_ty` is the
# source pointee type the walk starts from (the base pointer itself is untyped, so
# element/field sizes come from `aux_ty` via `ir_type.byte_size`). the walk follows
# the standard getelementptr model: index 0 strides over `aux_ty`, and each later
# index descends one aggregate level (an array element stride, or a constant
# struct-field offset). constant index contributions fold into the displacement;
# at most one runtime index folds into the SIB `index*scale` term, and a scale
# that is not 1/2/4/8 (or a second runtime index) is materialized into a register
# with explicit mir.MIR_MUL / mir.MIR_ADD before the LEA.
fun lower_gep(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: gep with no base operand");
    }
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: gep defines no result vreg");
    }

    val base: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);

    # the index walk needs the source pointee type to size each level; a GEP that
    # carries indices but no source type is a lowering bug, not silently foldable.
    if (inst.operand_count > 1 && inst.aux_ty == ir_type.IRT_NIL) {
        ret err[bool, str]("mir.lower_ir: gep with indices is missing its source pointee type");
    }

    # walk the indices, accumulating a constant displacement and at most one
    # scaled runtime index. a struct level needs a constant field ordinal.
    var disp:      i64 = 0;
    var idx_vreg:  u32 = mir.MIR_VREG_NIL;
    var idx_scale: u8  = 0;
    var cur_ty:    ir_type.IrTypeId = inst.aux_ty;

    var k: u32 = 1;
    for (k < inst.operand_count) {
        val v: value.Value = inst.operands[k];
        val is_first: bool = k == 1;

        # determine the stride for this level and the type one level deeper. the
        # first index strides over the source pointee `cur_ty` without descending;
        # subsequent indices descend into the array element / struct field.
        var stride:    u64 = 0;
        var is_struct: bool = false;
        if (is_first) {
            stride = ir_type.byte_size(ctx.types, cur_ty, ctx.tgt)::u64;
        } or {
            val ct_opt: Option[*ir_type.IrType] = ir_type.get(ctx.types, cur_ty);
            if (!is_some[*ir_type.IrType](ct_opt)) {
                ret err[bool, str]("mir.lower_ir: gep index walks off a non-aggregate type");
            }
            val ct: *ir_type.IrType = unwrap[*ir_type.IrType](ct_opt);
            if (ct.kind == ir_type.IRT_ARRAY) {
                stride = ir_type.byte_size(ctx.types, ct.data.element, ctx.tgt)::u64;
                cur_ty = ct.data.element;
            } or (ct.kind == ir_type.IRT_STRUCT || ct.kind == ir_type.IRT_UNION) {
                is_struct = true;
            } or {
                ret err[bool, str]("mir.lower_ir: gep index into a non-aggregate type");
            }
        }

        if (is_struct) {
            # struct-field index: must be a constant ordinal; fold its byte offset.
            if (v.kind != value.VAL_CONST_INT) {
                ret err[bool, str]("mir.lower_ir: gep struct field index must be constant");
            }
            val field_ix: u32 = v.data.int_lit::u32;
            val fo: Result[i64, str] = struct_field_offset(ctx, cur_ty, field_ix);
            if (is_err[i64, str](fo)) { ret err[bool, str](unwrap_err[i64, str](fo)); }
            disp = disp + unwrap_ok[i64, str](fo);
            val ft: Result[ir_type.IrTypeId, str] = struct_field_type(ctx, cur_ty, field_ix);
            if (is_err[ir_type.IrTypeId, str](ft)) { ret err[bool, str](unwrap_err[ir_type.IrTypeId, str](ft)); }
            cur_ty = unwrap_ok[ir_type.IrTypeId, str](ft);
            k = k + 1;
            cnt;
        }

        if (v.kind == value.VAL_CONST_INT) {
            # constant array / pointer index: fold the scaled offset.
            disp = disp + (v.data.int_lit * stride)::i64;
            k = k + 1;
            cnt;
        }

        # runtime index: fold into the SIB index*scale when possible, else
        # materialize the scaling explicitly. the chosen scale rides back through
        # `?new_scale`, and the new accumulator vreg is the result.
        var new_scale: u8 = 0;
        val ir: Result[u32, str] = fold_runtime_index(ctx, mb, lctx.lower_value(ctx, v), stride, idx_vreg, idx_scale, ?new_scale);
        if (is_err[u32, str](ir)) { ret err[bool, str](unwrap_err[u32, str](ir)); }
        idx_vreg  = unwrap_ok[u32, str](ir);
        idx_scale = new_scale;
        k = k + 1;
    }

    # form the folded MEM operand from the base, carrying the scaled index.
    val mem: Result[mir.MirOperand, str] = fold_gep_mem(ctx, mb, base, idx_vreg, idx_scale, disp);
    if (is_err[mir.MirOperand, str](mem)) { ret err[bool, str](unwrap_err[mir.MirOperand, str](mem)); }

    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = unwrap_ok[mir.MirOperand, str](mem);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_GEP;
    mi.operands      = ops;
    mi.operand_count = 2;
    # the GEP selects to a LEA computing a pointer-sized effective address.
    mi.width         = mir.WORD_WIDTH;
    mi.src_width     = mir.WORD_WIDTH;
    ret lctx.push_instr(ctx, mb, mi);
}

# fold_runtime_index: combine one runtime index (value `idxop`, byte stride
# `stride`) into the running scaled-index accumulator. with no accumulator yet and
# a hardware-legal scale, the index rides the SIB `index*scale` term directly and
# `@scale_out` records that scale. otherwise the scaling is materialized — `t =
# index * stride` (mir.MIR_MUL) — and either becomes the accumulator (scale 1) or is
# added into it (`acc = acc + t`, mir.MIR_ADD), with `@scale_out` set to 1. returns the
# accumulator vreg. a non-vreg index operand is a lowering bug (indices are i64
# values), rejected loudly.
fun fold_runtime_index(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, idxop: mir.MirOperand, stride: u64,
                       acc: u32, acc_scale: u8, scale_out: *u8) Result[u32, str] {
    if (idxop.kind != mir.MIR_OP_VREG) {
        ret err[u32, str]("mir.lower_ir: gep runtime index is not a register value");
    }
    val idxv: u32 = idxop.vreg;

    if (acc == mir.MIR_VREG_NIL && is_sib_scale(stride)) {
        @scale_out = stride::u8;
        ret ok[u32, str](idxv);
    }

    # materialize `t = idxv * stride`.
    val tr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (is_err[u32, str](tr)) { ret err[u32, str](unwrap_err[u32, str](tr)); }
    val t: u32 = unwrap_ok[u32, str](tr);
    val mr: Result[bool, str] = lctx.emit_bin(ctx, mb, mir.MIR_MUL, t, mir.op_vreg(idxv), mir.op_imm(stride::i64));
    if (is_err[bool, str](mr)) { ret err[u32, str](unwrap_err[bool, str](mr)); }

    if (acc == mir.MIR_VREG_NIL) {
        @scale_out = 1;
        ret ok[u32, str](t);
    }

    # accumulate `acc = acc * acc_scale + t`. when the existing accumulator still
    # rode a SIB scale, fold that scale in first so the combined index is scale 1.
    var acc_term: u32 = acc;
    if (acc_scale > 1) {
        val sr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (is_err[u32, str](sr)) { ret err[u32, str](unwrap_err[u32, str](sr)); }
        acc_term = unwrap_ok[u32, str](sr);
        val smr: Result[bool, str] = lctx.emit_bin(ctx, mb, mir.MIR_MUL, acc_term, mir.op_vreg(acc), mir.op_imm(acc_scale::i64));
        if (is_err[bool, str](smr)) { ret err[u32, str](unwrap_err[bool, str](smr)); }
    }
    val ar: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (is_err[u32, str](ar)) { ret err[u32, str](unwrap_err[u32, str](ar)); }
    val sum: u32 = unwrap_ok[u32, str](ar);
    val adr: Result[bool, str] = lctx.emit_bin(ctx, mb, mir.MIR_ADD, sum, mir.op_vreg(acc_term), mir.op_vreg(t));
    if (is_err[bool, str](adr)) { ret err[u32, str](unwrap_err[bool, str](adr)); }
    @scale_out = 1;
    ret ok[u32, str](sum);
}

# is_sib_scale: true when a byte stride is a hardware SIB scale (1, 2, 4, or 8).
fun is_sib_scale(s: u64) bool {
    ret s == 1 || s == 2 || s == 4 || s == 8;
}

# fold_gep_mem: build the final folded MEM operand for a GEP from its base operand,
# the scaled runtime index (mir.MIR_VREG_NIL when none), and the constant displacement.
# a value-vreg base carries the index in the SIB position; a symbol base with only a
# constant offset folds into `sym_off` (a pure `[rip+sym+off]` reference), and a
# symbol base with a runtime index LEA-materializes the symbol address into a value
# vreg first (`lctx.addr_to_vreg`) so the scaled index has a register base to ride. a
# constant-address base (a null or integer pointer, e.g. a `null` argument inlined
# into a pointer parameter the callee GEPs) materializes the constant into a value
# vreg and indexes `[base + idx*scale + disp]` off it.
fun fold_gep_mem(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, base: mir.MirOperand, idx_vreg: u32, idx_scale: u8, disp: i64) Result[mir.MirOperand, str] {
    var o: mir.MirOperand = base;
    if (base.kind == mir.MIR_OP_IMM) {
        # the base is a compile-time address; MOV it into a value vreg so the LEA /
        # load / store has a register base to fold the constant displacement and the
        # optional scaled index against.
        val vr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
        if (is_err[u32, str](vr)) { ret err[mir.MirOperand, str](unwrap_err[u32, str](vr)); }
        val vbase: u32 = unwrap_ok[u32, str](vr);
        val mv: Result[bool, str] = lctx.emit_mov(ctx, mb, mir.op_vreg(vbase), mir.op_imm(base.imm));
        if (is_err[bool, str](mv)) { ret err[mir.MirOperand, str](unwrap_err[bool, str](mv)); }
        var m: mir.MirOperand = mir.op_mem_value(vbase, disp);
        if (idx_vreg != mir.MIR_VREG_NIL) {
            m.index         = idx_vreg;
            m.scale         = idx_scale;
            m.index_is_preg = false;
        }
        ret ok[mir.MirOperand, str](m);
    }
    if (base.kind == mir.MIR_OP_MEM) {
        # a value-pointer / physical-register / frame-slot-key base all fold the
        # constant displacement into `imm`; the encoder resolves a slot key to
        # `[rbp + off]` and can still carry the SIB index alongside.
        o.imm = base.imm + disp;
        if (idx_vreg != mir.MIR_VREG_NIL) {
            o.index         = idx_vreg;
            o.scale         = idx_scale;
            o.index_is_preg = false;
        }
        ret ok[mir.MirOperand, str](o);
    }
    if (base.kind == mir.MIR_OP_SYM) {
        if (idx_vreg == mir.MIR_VREG_NIL) {
            o.sym_off = base.sym_off + disp::i32;
            ret ok[mir.MirOperand, str](o);
        }
        # runtime index against a global: there is no register in a `[rip+sym]`
        # reference to scale the index into, so LEA the symbol address (carrying
        # its `sym_off`) into a value vreg and index `[base + idx*scale + disp]`
        # off that register, the same materialization `lctx.addr_to_vreg` performs for
        # by-reference aggregate placement.
        var sbase: u32 = mir.MIR_VREG_NIL;
        val ar: Result[bool, str] = lctx.addr_to_vreg(ctx, mb, base, ?sbase);
        if (is_err[bool, str](ar)) { ret err[mir.MirOperand, str](unwrap_err[bool, str](ar)); }
        var m: mir.MirOperand = mir.op_mem_value(sbase, disp);
        m.index         = idx_vreg;
        m.scale         = idx_scale;
        m.index_is_preg = false;
        ret ok[mir.MirOperand, str](m);
    }
    ret err[mir.MirOperand, str]("mir.lower_ir: gep base is neither a memory nor a symbol reference");
}

# struct_field_offset: byte offset of field `ix` within an IRT_STRUCT, computed by
# the same aligned-layout walk as `ir_type.byte_size`.
fun struct_field_offset(ctx: *lctx.LowerCtx, struct_ty: ir_type.IrTypeId, ix: u32) Result[i64, str] {
    val st_opt: Option[*ir_type.IrType] = ir_type.get(ctx.types, struct_ty);
    if (!is_some[*ir_type.IrType](st_opt)) {
        ret err[i64, str]("mir.lower_ir: gep struct type not found");
    }
    val st: *ir_type.IrType = unwrap[*ir_type.IrType](st_opt);
    # a union overlaps its members: every member is at offset 0.
    if (st.kind == ir_type.IRT_UNION) {
        if (ix >= st.data.struct_.field_count) {
            ret err[i64, str]("mir.lower_ir: gep union member index out of range");
        }
        ret ok[i64, str](0::i64);
    }
    if (st.kind != ir_type.IRT_STRUCT) {
        ret err[i64, str]("mir.lower_ir: gep struct index into a non-struct type");
    }
    if (ix >= st.data.struct_.field_count) {
        ret err[i64, str]("mir.lower_ir: gep struct field index out of range");
    }
    var off: u32 = 0;
    var i:   u32 = 0;
    for (i <= ix) {
        val fid: ir_type.IrTypeId = st.data.struct_.fields[i];
        val fa:  u32 = ir_type.byte_align(ctx.types, fid, ctx.tgt);
        off = round_up_u32(off, fa);
        if (i == ix) { ret ok[i64, str](off::i64); }
        off = off + ir_type.byte_size(ctx.types, fid, ctx.tgt);
        i = i + 1;
    }
    ret err[i64, str]("mir.lower_ir: gep struct field offset walk failed");
}

# struct_field_type: the IR type of field `ix` within an IRT_STRUCT.
fun struct_field_type(ctx: *lctx.LowerCtx, struct_ty: ir_type.IrTypeId, ix: u32) Result[ir_type.IrTypeId, str] {
    val st_opt: Option[*ir_type.IrType] = ir_type.get(ctx.types, struct_ty);
    if (!is_some[*ir_type.IrType](st_opt)) {
        ret err[ir_type.IrTypeId, str]("mir.lower_ir: gep struct type not found");
    }
    val st: *ir_type.IrType = unwrap[*ir_type.IrType](st_opt);
    if ((st.kind != ir_type.IRT_STRUCT && st.kind != ir_type.IRT_UNION) || ix >= st.data.struct_.field_count) {
        ret err[ir_type.IrTypeId, str]("mir.lower_ir: gep struct field index out of range");
    }
    ret ok[ir_type.IrTypeId, str](st.data.struct_.fields[ix]);
}

# round_up_u32: round `v` up to the next multiple of `align` (align >= 1).
fun round_up_u32(v: u32, align: u32) u32 {
    if (align <= 1) { ret v; }
    ret ((v + align - 1) / align) * align;
}

# emit_va_save_prologue: emit the variadic-argument save prologue for the active
# ABI's save model. captures the named-parameter register usage and first
# stack-argument offset from the signature layout (the same oracle `lower_params`
# walks), then dispatches on the model read from the ABI vtable: the register-save
# model (SysV) reserves a frame-local save area and spills the GP/FP argument
# files into it; the home-area model (win64) spills the integer argument registers
# at/after the named parameters into the caller's home slots. the dispatch is on
# `VaModel.kind`, never the convention id.
fun emit_va_save_prologue(ctx: *lctx.LowerCtx, mb: *mir.MirBlock) Result[bool, str] {
    val rok: Result[bool, str] = mabi.require_abi(ctx.tgt);
    if (is_err[bool, str](rok)) { ret rok; }

    var model: abi.VaModel;
    val mr: Result[bool, str] = mabi.abi_va_model(ctx.tgt, ?model);
    if (is_err[bool, str](mr)) { ret mr; }

    # capture the named-parameter register usage and overflow base from the
    # signature layout (the same oracle `lower_params` walks). a CLASS_SRET return
    # consumes the first GP argument register, so `va_named_gp` already counts it.
    val ret_ty: ir_type.IrTypeId = lctx.fn_return_type(ctx);
    var layout: abi.SigLayout;
    val cls: Result[bool, str] = mabi.classify_signature(ctx, ctx.fn.sig, ret_ty, ?layout);
    if (is_err[bool, str](cls)) { ret cls; }
    ctx.va_named_gp     = layout.gp_used;
    ctx.va_named_fp     = layout.fp_used;
    # the home model is strictly one positional slot per argument, so the named
    # slots are the fixed params plus a hidden sret pointer (a CLASS_SRET return
    # consumes positional slot 0). counts stack-passed named params that the
    # register cursors do not, so `va_start` seeds past every named argument.
    var named_slots: i32 = layout.param_count::i32;
    if (layout.ret_slot.class == abi.CLASS_SRET) { named_slots = named_slots + 1; }
    ctx.va_named_slots  = named_slots;
    ctx.va_overflow_off = ctx.tgt.arch.incoming_arg_base + layout.stack_off;
    mabi.sig_layout_free(ctx, ?layout);
    ctx.va_active = true;

    if (model.kind == abi.VA_MODEL_HOME) {
        ret emit_va_save_home(ctx, mb, ?model);
    }
    ret emit_va_save_regsave(ctx, mb, ?model);
}

# emit_va_save_regsave: reserve the SysV register-save area and spill the incoming
# GP/FP argument registers into it so `va_arg` can read them. the save area is a
# mir.SLOT_ALLOCA frame slot keyed on a fresh slot-key vreg (`va_save_vreg`), sized by
# the active ABI's `va_save_size`. the GP argument registers are stored at offsets
# 0,8,..,40 and the FP argument registers at `va_fp_save_offset()` + i*16 —
# matching the register-save layout the `va_arg` field offsets index. every layout
# fact — the save-area size, the FP dump offset, the argument-register files — is
# read from the `VaModel` and the ABI vtable's register-file accessors, so the
# mechanism names no convention module.
fun emit_va_save_regsave(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, model: *abi.VaModel) Result[bool, str] {
    # the register-save area: one addressed alloca slot keyed on a slot-key vreg.
    val skr: Result[u32, str] = lctx.new_vreg(ctx, mir.REG_CLASS_GP);
    if (is_err[u32, str](skr)) { ret err[bool, str](unwrap_err[u32, str](skr)); }
    val sk: u32 = unwrap_ok[u32, str](skr);
    val ar: Result[bool, str] = lctx.add_alloca_slot(ctx, sk, model.save_size, 8);
    if (is_err[bool, str](ar)) { ret ar; }
    ctx.va_save_vreg = sk;

    # spill every GP argument register into its fixed save-area slot (0,8,..).
    var gi: i32 = 0;
    for (gi < model.gp_save_count) {
        var greg: i32 = 0;
        val gr: Result[bool, str] = mabi.abi_gp_arg_reg(ctx.tgt, gi, ?greg);
        if (is_err[bool, str](gr)) { ret gr; }
        val off: i64 = gi::i64 * 8;
        val st: Result[bool, str] = lctx.emit_store_to(ctx, mb, mir.op_mem_slot(sk, off), mir.op_preg(greg::u32));
        if (is_err[bool, str](st)) { ret st; }
        gi = gi + 1;
    }

    # spill the FP argument registers (XMM0–XMM7) into the save area's FP region,
    # AL-guarded: the SysV variadic call convention passes the number of vector
    # registers used in AL, so when AL is zero (no FP varargs) the dump is skipped.
    # the self-contained pseudo materializes `test al,al ; jz over ; movsd
    # [save+i*16], xmm_i` in the encoder, keeping the conditional spill in one block
    # (no entry-block CFG split). its base is the save-area slot at the FP region's
    # start; its count is the convention's FP argument-register file size.
    val sp: Result[bool, str] = emit_va_fp_save(ctx, mb, sk, model);
    if (is_err[bool, str](sp)) { ret sp; }
    ret ok[bool, str](true);
}

# emit_va_save_home: spill the integer argument registers that hold UNNAMED
# arguments into the caller's home/shadow space (win64). the home area sits just
# above the saved frame pointer and return address (the ISA's `incoming_arg_base`,
# `[rbp+16]`), one 8-byte slot per positional argument register (RCX/RDX/R8/R9);
# the caller always reserves it. the named parameters already occupy the first
# `va_named_gp + va_named_fp` REGISTER positional slots (`lower_params` pre-colored
# them from their registers), so this stores `slot_gp_reg(i)` into
# `[rbp + base + i*8]` for each remaining register slot, making the named and
# unnamed arguments one contiguous stack array; `va_start` then seeds the va_list
# pointer just past the named arguments. there is NO frame-local save area, so
# `va_save_vreg` stays NIL and the frame reserves no va-save slot — the home spill
# targets the caller's frame. a variadic float rides both its XMM register and the
# matching integer register, so spilling the integer registers alone captures every
# unnamed argument (`fp_save_count` is 0 for this model).
fun emit_va_save_home(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, model: *abi.VaModel) Result[bool, str] {
    # the number of register-passed named arguments is the start of the unnamed
    # register slots; a named param spilled to the stack consumed no register, so
    # this is the right (register-count) quantity, not the full positional count.
    val named_regs: i32 = ctx.va_named_gp + ctx.va_named_fp;
    val base: i64 = ctx.tgt.arch.incoming_arg_base;
    val fp: u32 = ctx.tgt.arch.frame_ptr_reg::u32;
    var si: i32 = named_regs;
    for (si < model.gp_save_count) {
        var greg: i32 = 0;
        val gr: Result[bool, str] = mabi.abi_gp_arg_reg(ctx.tgt, si, ?greg);
        if (is_err[bool, str](gr)) { ret gr; }
        val off: i64 = base + si::i64 * 8;
        val st: Result[bool, str] = lctx.emit_store_to(ctx, mb, mir.op_mem_preg(fp, off), mir.op_preg(greg::u32));
        if (is_err[bool, str](st)) { ret st; }
        si = si + 1;
    }
    ret ok[bool, str](true);
}

# emit_va_fp_save: append the AL-guarded FP-register spill pseudo to the prologue.
# `save_vreg` is the register-save area's slot-key vreg; operand 0 addresses the FP
# region at the model's `fp_save_offset` within it, operand 1 carries the FP
# argument-register count (`fp_save_count`), operand 2 is a mir.MIR_OP_PREG use of the
# model's vector-count register (AL/RAX) the guard reads. the encoder expands
# operands 0-1 into the conditional XMM dump (see mir.MIR_VA_FP_SAVE); operand 2 is
# invisible to the encoder but makes the AL read visible to regalloc so no value
# vreg is colored to that register before the guard.
fun emit_va_fp_save(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, save_vreg: u32, model: *abi.VaModel) Result[bool, str] {
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_mem_slot(save_vreg, model.fp_save_offset::i64);
    ops[1] = mir.op_imm(model.fp_save_count::i64);
    ops[2] = mir.op_preg(model.vector_count_reg::u32);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_VA_FP_SAVE;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = 8;
    mi.src_width     = 8;
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_va_start: expand `OP_VA_START [ap]` for the active ABI's variadic save
# model. dispatches on the model read from the ABI vtable: the register-save model
# (SysV) initializes the four-field `__va_list_tag`; the home-area model (win64)
# seeds the single va_list pointer just past the named arguments. the dispatch is
# on `VaModel.kind`, never the convention id.
fun lower_va_start(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: va_start with no va_list operand");
    }
    if (!ctx.va_active) {
        ret err[bool, str]("mir.lower_ir: va_start in a non-variadic function");
    }
    var model: abi.VaModel;
    val mr: Result[bool, str] = mabi.abi_va_model(ctx.tgt, ?model);
    if (is_err[bool, str](mr)) { ret mr; }
    if (model.kind == abi.VA_MODEL_HOME) {
        ret lower_va_start_home(ctx, mb, inst, ?model);
    }
    ret lower_va_start_regsave(ctx, mb, inst, ?model);
}

# lower_va_start_regsave: initialize the SysV `__va_list_tag`. with `ap` the
# va_list storage pointer, it writes:
#   gp_offset         = named GP regs * 8   (cursor past the fixed params)
#   fp_offset         = GP area size + named FP regs * 16
#   reg_save_area     = &register-save slot
#   overflow_arg_area = &first incoming stack argument (`[rbp + overflow_off]`)
# all four fields at the model's `__va_list_tag` offsets the lowering and `va_arg`
# share.
fun lower_va_start_regsave(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, model: *abi.VaModel) Result[bool, str] {
    # base address of the va_list struct (the `ap` pointer operand).
    val apbase: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);

    # gp_offset = named GP regs * 8.
    val gp_init: i64 = ctx.va_named_gp::i64 * 8;
    val sg: Result[bool, str] = lctx.emit_store_imm(ctx, mb, va_field_mem(apbase, model.gp_offset_field), gp_init, 4);
    if (is_err[bool, str](sg)) { ret sg; }

    # fp_offset = FP region offset + named FP regs * per-XMM stride.
    val fp_init: i64 = model.fp_save_offset::i64 + ctx.va_named_fp::i64 * model.fp_save_stride::i64;
    val sf: Result[bool, str] = lctx.emit_store_imm(ctx, mb, va_field_mem(apbase, model.fp_offset_field), fp_init, 4);
    if (is_err[bool, str](sf)) { ret sf; }

    # reg_save_area = &register-save slot.
    var rsa: u32 = mir.MIR_VREG_NIL;
    val lr: Result[bool, str] = lctx.emit_lea_slot(ctx, mb, mir.op_mem_slot(ctx.va_save_vreg, 0), ?rsa);
    if (is_err[bool, str](lr)) { ret lr; }
    val sr: Result[bool, str] = lctx.emit_store_to(ctx, mb, va_field_mem(apbase, model.reg_save_field), mir.op_vreg(rsa));
    if (is_err[bool, str](sr)) { ret sr; }

    # overflow_arg_area = &first incoming stack argument (`[rbp + overflow_off]`).
    val fp: u32 = ctx.tgt.arch.frame_ptr_reg::u32;
    var ovf: u32 = mir.MIR_VREG_NIL;
    val lo: Result[bool, str] = lctx.emit_lea_slot(ctx, mb, mir.op_mem_preg(fp, ctx.va_overflow_off), ?ovf);
    if (is_err[bool, str](lo)) { ret lo; }
    ret lctx.emit_store_to(ctx, mb, va_field_mem(apbase, model.overflow_field), mir.op_vreg(ovf));
}

# lower_va_start_home: seed the win64 single-pointer va_list. the named and unnamed
# arguments form one contiguous stack array starting at the caller's first home slot
# (`[rbp + incoming_arg_base]`, where `emit_va_save_home` spilled the integer
# argument registers); the named parameters occupy the first `va_named_slots`
# positional slots (every named argument, register- AND stack-passed, plus a hidden
# sret pointer), so the first unnamed argument is at `[rbp + incoming_arg_base +
# named_slots*8]`. store that address into the va_list pointer (field offset 0);
# `va_arg` then reads `arg_stride` bytes and advances the pointer. using the full
# positional slot count (not the register-passed count) keeps the cursor correct
# when more than four named parameters precede the varargs.
fun lower_va_start_home(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, model: *abi.VaModel) Result[bool, str] {
    val apbase: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);
    val first_off: i64 = ctx.tgt.arch.incoming_arg_base + ctx.va_named_slots::i64 * 8;
    val fp: u32 = ctx.tgt.arch.frame_ptr_reg::u32;
    var ap0: u32 = mir.MIR_VREG_NIL;
    val la: Result[bool, str] = lctx.emit_lea_slot(ctx, mb, mir.op_mem_preg(fp, first_off), ?ap0);
    if (is_err[bool, str](la)) { ret la; }
    ret lctx.emit_store_to(ctx, mb, va_field_mem(apbase, 0), mir.op_vreg(ap0));
}

# va_field_mem: form a memory operand addressing field `field_off` of a va_list
# whose base operand is `apbase`. the base is the `ap` pointer; a value-vreg base
# becomes `[base + field_off]`, a slot base keeps its slot key.
fun va_field_mem(apbase: mir.MirOperand, field_off: u32) mir.MirOperand {
    var o: mir.MirOperand = apbase;
    o.imm = o.imm + field_off::i64;
    ret o;
}

# lower_va_arg: expand `OP_VA_ARG [ap]` for a GP-class scalar / pointer result.
# per SysV, the next argument is taken from the register-save area while a GP slot
# remains (gp_offset < 48), else from the overflow area; the matching cursor
# advances. the register-vs-overflow choice is realized branch-free with a 0/-1
# mask so the expansion needs no extra basic blocks:
#   in_reg = gp_offset < gp_offset_max
#   mask   = 0 - in_reg                      (i64: all-ones when in_reg else 0)
#   reg_ad = reg_save_area + gp_offset
#   addr   = (reg_ad & mask) | (overflow & ~mask)
#   gp_offset       += (8 & mask32)          (only when a register was used)
#   overflow_arg_area += (8 & ~mask)         (only when overflow was used)
#   result = load.T [addr]
# a float result is handled by `lower_va_arg_fp` (the same branch-free select over
# the fp_offset cursor / FP register-save region); an aggregate result is handled by
# `lower_va_arg_aggregate` (the GP-cursor select plus a by-value copy). under the
# home-area model (win64) every result category — scalar, float, aggregate — walks
# a single va_list pointer, so it routes to `lower_va_arg_home` before the SysV
# category split. the dispatch is on `VaModel.kind`, never the convention id.
fun lower_va_arg(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, iid: id.InstructionId) Result[bool, str] {
    if (inst.operand_count == 0) {
        ret err[bool, str]("mir.lower_ir: va_arg with no va_list operand");
    }
    if (!ctx.va_active) {
        ret err[bool, str]("mir.lower_ir: va_arg in a non-variadic function");
    }
    val dst: u32 = lctx.result_vreg(ctx, iid);
    if (dst == mir.MIR_VREG_NIL) {
        ret err[bool, str]("mir.lower_ir: va_arg defines no result vreg");
    }
    var vmodel: abi.VaModel;
    val vmr: Result[bool, str] = mabi.abi_va_model(ctx.tgt, ?vmodel);
    if (is_err[bool, str](vmr)) { ret vmr; }
    if (vmodel.kind == abi.VA_MODEL_HOME) {
        ret lower_va_arg_home(ctx, mb, inst, dst, ?vmodel);
    }
    if (lctx.value_is_float(ctx, inst.ty)) {
        ret lower_va_arg_fp(ctx, mb, inst, dst, ?vmodel);
    }
    if (lctx.value_is_aggregate(ctx, inst.ty)) {
        ret lower_va_arg_aggregate(ctx, mb, inst, dst, ?vmodel);
    }

    val apbase: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);

    # gp = load.i32 [ap + gp_offset]; gp64 = zext gp.
    var gp: u32 = mir.MIR_VREG_NIL;
    val lg: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, vmodel.gp_offset_field), 4, ?gp);
    if (is_err[bool, str](lg)) { ret lg; }

    # in_reg = gp < gp_offset_max  (u32 compare -> i8 boolean).
    var in_reg: u32 = mir.MIR_VREG_NIL;
    val cr: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_CMP_LT_U, mir.op_vreg(gp),
        mir.op_imm(vmodel.gp_offset_max::i64), 4, ?in_reg);
    if (is_err[bool, str](cr)) { ret cr; }

    # mask = 0 - zext(in_reg)  -> 0 or 0xFFFFFFFFFFFFFFFF (64-bit).
    var inz: u32 = mir.MIR_VREG_NIL;
    val zr: Result[bool, str] = lctx.emit_zext_to(ctx, mb, mir.op_vreg(in_reg), 1, ?inz);
    if (is_err[bool, str](zr)) { ret zr; }
    var mask: u32 = mir.MIR_VREG_NIL;
    val mr: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_SUB, mir.op_imm(0), mir.op_vreg(inz), 8, ?mask);
    if (is_err[bool, str](mr)) { ret mr; }
    var nmask: u32 = mir.MIR_VREG_NIL;
    val nr: Result[bool, str] = lctx.emit_not_to(ctx, mb, mir.op_vreg(mask), 8, ?nmask);
    if (is_err[bool, str](nr)) { ret nr; }

    # reg_addr = reg_save_area + zext(gp).
    var rsa: u32 = mir.MIR_VREG_NIL;
    val lr: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, vmodel.reg_save_field), 8, ?rsa);
    if (is_err[bool, str](lr)) { ret lr; }
    var gp64: u32 = mir.MIR_VREG_NIL;
    val gzr: Result[bool, str] = lctx.emit_zext_to(ctx, mb, mir.op_vreg(gp), 4, ?gp64);
    if (is_err[bool, str](gzr)) { ret gzr; }
    var reg_addr: u32 = mir.MIR_VREG_NIL;
    val rar: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(rsa), mir.op_vreg(gp64), 8, ?reg_addr);
    if (is_err[bool, str](rar)) { ret rar; }

    # ovf = overflow_arg_area.
    var ovf: u32 = mir.MIR_VREG_NIL;
    val lo: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, vmodel.overflow_field), 8, ?ovf);
    if (is_err[bool, str](lo)) { ret lo; }

    # addr = (reg_addr & mask) | (ovf & ~mask).
    var ra_m: u32 = mir.MIR_VREG_NIL;
    val r1: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(reg_addr), mir.op_vreg(mask), 8, ?ra_m);
    if (is_err[bool, str](r1)) { ret r1; }
    var ov_m: u32 = mir.MIR_VREG_NIL;
    val r2: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(ovf), mir.op_vreg(nmask), 8, ?ov_m);
    if (is_err[bool, str](r2)) { ret r2; }
    var addr: u32 = mir.MIR_VREG_NIL;
    val r3: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_OR, mir.op_vreg(ra_m), mir.op_vreg(ov_m), 8, ?addr);
    if (is_err[bool, str](r3)) { ret r3; }

    # gp_offset += (8 & mask32): advance only when a register slot was used.
    var step_gp: u32 = mir.MIR_VREG_NIL;
    val sg: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_imm(8), mir.op_vreg(mask), 4, ?step_gp);
    if (is_err[bool, str](sg)) { ret sg; }
    var new_gp: u32 = mir.MIR_VREG_NIL;
    val ng: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(gp), mir.op_vreg(step_gp), 4, ?new_gp);
    if (is_err[bool, str](ng)) { ret ng; }
    val wg: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, vmodel.gp_offset_field), mir.op_vreg(new_gp), 4);
    if (is_err[bool, str](wg)) { ret wg; }

    # overflow_arg_area += (8 & ~mask): advance only when the overflow area was used.
    var step_ov: u32 = mir.MIR_VREG_NIL;
    val so: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_imm(8), mir.op_vreg(nmask), 8, ?step_ov);
    if (is_err[bool, str](so)) { ret so; }
    var new_ov: u32 = mir.MIR_VREG_NIL;
    val no: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(ovf), mir.op_vreg(step_ov), 8, ?new_ov);
    if (is_err[bool, str](no)) { ret no; }
    val wo: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, vmodel.overflow_field), mir.op_vreg(new_ov), 8);
    if (is_err[bool, str](wo)) { ret wo; }

    # result = load.T [addr], at the result type's width.
    val w: u8 = lctx.op_width_of(ctx, inst.ty);
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = mir.op_mem_value(addr, 0);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_LOAD;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.src_width     = w;
    mi.width         = lctx.clamp_alu_width(w);
    ret lctx.push_instr(ctx, mb, mi);
}

# lower_va_arg_fp: expand `OP_VA_ARG [ap]` for a floating-point (f32 / f64) result.
# the FP analogue of `lower_va_arg`: per SysV the next float argument is taken from
# the FP register-save region while an FP slot remains (fp_offset < fp_offset_max),
# else from the overflow area. fp_offset starts past the named FP params at the FP
# region base and advances by 16 (the XMM save stride) on a register read; the
# overflow cursor advances by 8 on an overflow read. the register-vs-overflow choice
# is realized branch-free with the same 0/-1 mask the GP path uses, so no extra basic
# blocks are introduced:
#   in_reg = fp_offset < fp_offset_max
#   mask   = 0 - in_reg                       (i64: all-ones when in_reg else 0)
#   reg_ad = reg_save_area + fp_offset        (low lane of the saved XMM slot)
#   addr   = (reg_ad & mask) | (overflow & ~mask)
#   fp_offset         += (16 & mask32)        (only when a register was used)
#   overflow_arg_area += (8  & ~mask)         (only when overflow was used)
#   result = fmov.T [addr]                    (MOVSS / MOVSD into the FP-class dst)
# the address arithmetic / select runs in GP vregs; only the final load is a float
# move so the value lands in the XMM-classed result vreg.
fun lower_va_arg_fp(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, dst: u32,
                    model: *abi.VaModel) Result[bool, str] {
    val apbase: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);

    # fp = load.i32 [ap + fp_offset].
    var fp: u32 = mir.MIR_VREG_NIL;
    val lf: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, model.fp_offset_field), 4, ?fp);
    if (is_err[bool, str](lf)) { ret lf; }

    # in_reg = fp < fp_offset_max  (u32 compare -> i8 boolean).
    var in_reg: u32 = mir.MIR_VREG_NIL;
    val cr: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_CMP_LT_U, mir.op_vreg(fp),
        mir.op_imm(model.fp_offset_max::i64), 4, ?in_reg);
    if (is_err[bool, str](cr)) { ret cr; }

    # mask = 0 - zext(in_reg)  -> 0 or 0xFFFFFFFFFFFFFFFF (64-bit).
    var inz: u32 = mir.MIR_VREG_NIL;
    val zr: Result[bool, str] = lctx.emit_zext_to(ctx, mb, mir.op_vreg(in_reg), 1, ?inz);
    if (is_err[bool, str](zr)) { ret zr; }
    var mask: u32 = mir.MIR_VREG_NIL;
    val mr: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_SUB, mir.op_imm(0), mir.op_vreg(inz), 8, ?mask);
    if (is_err[bool, str](mr)) { ret mr; }
    var nmask: u32 = mir.MIR_VREG_NIL;
    val nr: Result[bool, str] = lctx.emit_not_to(ctx, mb, mir.op_vreg(mask), 8, ?nmask);
    if (is_err[bool, str](nr)) { ret nr; }

    # reg_addr = reg_save_area + zext(fp).
    var rsa: u32 = mir.MIR_VREG_NIL;
    val lr: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, model.reg_save_field), 8, ?rsa);
    if (is_err[bool, str](lr)) { ret lr; }
    var fp64: u32 = mir.MIR_VREG_NIL;
    val fzr: Result[bool, str] = lctx.emit_zext_to(ctx, mb, mir.op_vreg(fp), 4, ?fp64);
    if (is_err[bool, str](fzr)) { ret fzr; }
    var reg_addr: u32 = mir.MIR_VREG_NIL;
    val rar: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(rsa), mir.op_vreg(fp64), 8, ?reg_addr);
    if (is_err[bool, str](rar)) { ret rar; }

    # ovf = overflow_arg_area.
    var ovf: u32 = mir.MIR_VREG_NIL;
    val lo: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, model.overflow_field), 8, ?ovf);
    if (is_err[bool, str](lo)) { ret lo; }

    # addr = (reg_addr & mask) | (ovf & ~mask).
    var ra_m: u32 = mir.MIR_VREG_NIL;
    val r1: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(reg_addr), mir.op_vreg(mask), 8, ?ra_m);
    if (is_err[bool, str](r1)) { ret r1; }
    var ov_m: u32 = mir.MIR_VREG_NIL;
    val r2: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(ovf), mir.op_vreg(nmask), 8, ?ov_m);
    if (is_err[bool, str](r2)) { ret r2; }
    var addr: u32 = mir.MIR_VREG_NIL;
    val r3: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_OR, mir.op_vreg(ra_m), mir.op_vreg(ov_m), 8, ?addr);
    if (is_err[bool, str](r3)) { ret r3; }

    # fp_offset += (stride & mask32): advance by the per-XMM save stride when a register was used.
    var step_fp: u32 = mir.MIR_VREG_NIL;
    val sf: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_imm(model.fp_save_stride::i64), mir.op_vreg(mask), 4, ?step_fp);
    if (is_err[bool, str](sf)) { ret sf; }
    var new_fp: u32 = mir.MIR_VREG_NIL;
    val nf: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(fp), mir.op_vreg(step_fp), 4, ?new_fp);
    if (is_err[bool, str](nf)) { ret nf; }
    val wf: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, model.fp_offset_field), mir.op_vreg(new_fp), 4);
    if (is_err[bool, str](wf)) { ret wf; }

    # overflow_arg_area += (8 & ~mask): advance by one eightbyte when the overflow area was used.
    var step_ov: u32 = mir.MIR_VREG_NIL;
    val so: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_imm(8), mir.op_vreg(nmask), 8, ?step_ov);
    if (is_err[bool, str](so)) { ret so; }
    var new_ov: u32 = mir.MIR_VREG_NIL;
    val no: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(ovf), mir.op_vreg(step_ov), 8, ?new_ov);
    if (is_err[bool, str](no)) { ret no; }
    val wo: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, model.overflow_field), mir.op_vreg(new_ov), 8);
    if (is_err[bool, str](wo)) { ret wo; }

    # result = fmov.T [addr]: a float move so the value lands in the XMM-classed dst.
    val w: u8 = lctx.op_width_of(ctx, inst.ty);
    ret lctx.emit_fmov(ctx, mb, mir.op_vreg(dst), mir.op_mem_value(addr, 0), w);
}

# lower_va_arg_aggregate: expand `OP_VA_ARG [ap]` for a by-value aggregate result.
# the aggregate analogue of `lower_va_arg`: the next argument's eightbytes are taken
# from the GP register-save area while they fit (gp_offset + gp_bytes <= 48), else
# from the overflow area; matching the SysV aggregate placement this compiler's
# `classify_arg` emits for the same operand:
#   * <=16B aggregates ride in one (<=8B) or two (9-16B) consecutive GP eightbytes,
#     saved contiguously in the register-save area, so the bytes there ARE the value;
#     the overflow copy reads the same by-value bytes.
#   * >16B aggregates are passed BY REFERENCE in one GP register when one remains, so
#     the saved eightbyte is a POINTER to the aggregate (dereferenced before the copy);
#     once the GP file is exhausted they spill BY VALUE into the overflow area.
# the register-vs-overflow choice reuses the GP path's branch-free 0/-1 mask so no
# extra basic blocks are introduced; the chosen source address feeds a sized
# `lctx.copy_aggregate` into caller-owned result storage, and the result vreg carries that
# storage pointer so downstream consumers read the aggregate by value:
#   gp_bytes = (>16B ? 8 : (>8B ? 16 : 8))     (GP eightbytes the operand consumed)
#   in_reg   = gp_offset < (49 - gp_bytes)      (the eightbytes all fit in the save area)
#   mask     = 0 - in_reg                        (i64: all-ones when in_reg else 0)
#   reg_base = reg_save_area + gp_offset
#   reg_src  = (>16B ? load8[reg_base] : reg_base)   (pointer deref for the by-ref form)
#   ovf_al   = (overflow_arg_area + 7) & ~7      (overflow is eight-byte granular)
#   src      = (reg_src & mask) | (ovf_al & ~mask)
#   gp_offset         += (gp_bytes      & mask32)
#   overflow_arg_area  = (overflow & mask) | ((ovf_al + lctx.stack_slot_bytes(size)) & ~mask)
#   copy size bytes from [src] into the result storage
fun lower_va_arg_aggregate(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, dst: u32,
                           model: *abi.VaModel) Result[bool, str] {
    val rok: Result[bool, str] = mabi.require_abi(ctx.tgt);
    if (is_err[bool, str](rok)) { ret rok; }

    val apbase: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);
    val size:   u64 = ir_type.byte_size(ctx.types, inst.ty, ctx.tgt)::u64;

    # derive the placement from the same ABI classifier the call site emits, against
    # a fresh register file so the result is the operand's canonical shape: BYREF (a
    # hidden pointer, one GP eightbyte) for a >16B aggregate, two GP eightbytes for a
    # 9-16B aggregate, one for a <=8B aggregate. the runtime gp_offset cursor — not
    # gp_used — decides registers vs overflow below.
    val classify_arg: abi.ArgPassingFn = ctx.tgt.abi.arg_passing::abi.ArgPassingFn;
    val align: u64 = ir_type.byte_align(ctx.types, inst.ty, ctx.tgt)::u64;
    val slot:  abi.ParamSlot = classify_arg(0, size, align, false, 0, true, 0, 0);
    val byref: bool = slot.class == abi.CLASS_BYREF;
    var gp_bytes: i64 = 8;
    if (!byref && slot.reg2 >= 0) { gp_bytes = 16; }

    # back the result vreg with caller-owned storage; its address is the result so
    # downstream copies / stores / returns treat the aggregate by value.
    val rs: Result[bool, str] = lctx.alloc_result_storage(ctx, mb, dst, size, lctx.ret_align(ctx, inst.ty));
    if (is_err[bool, str](rs)) { ret rs; }

    # gp = load.i32 [ap + gp_offset].
    var gp: u32 = mir.MIR_VREG_NIL;
    val lg: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, model.gp_offset_field), 4, ?gp);
    if (is_err[bool, str](lg)) { ret lg; }

    # in_reg = gp < (gp_offset_max - gp_bytes + 1): the operand's eightbytes all fit.
    val thr: i64 = model.gp_offset_max::i64 - gp_bytes + 1;
    var in_reg: u32 = mir.MIR_VREG_NIL;
    val cr: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_CMP_LT_U, mir.op_vreg(gp), mir.op_imm(thr), 4, ?in_reg);
    if (is_err[bool, str](cr)) { ret cr; }

    # mask = 0 - zext(in_reg) -> 0 or all-ones (64-bit); nmask = ~mask.
    var inz: u32 = mir.MIR_VREG_NIL;
    val zr: Result[bool, str] = lctx.emit_zext_to(ctx, mb, mir.op_vreg(in_reg), 1, ?inz);
    if (is_err[bool, str](zr)) { ret zr; }
    var mask: u32 = mir.MIR_VREG_NIL;
    val mr: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_SUB, mir.op_imm(0), mir.op_vreg(inz), 8, ?mask);
    if (is_err[bool, str](mr)) { ret mr; }
    var nmask: u32 = mir.MIR_VREG_NIL;
    val nr: Result[bool, str] = lctx.emit_not_to(ctx, mb, mir.op_vreg(mask), 8, ?nmask);
    if (is_err[bool, str](nr)) { ret nr; }

    # reg_base = reg_save_area + zext(gp).
    var rsa: u32 = mir.MIR_VREG_NIL;
    val lr: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, model.reg_save_field), 8, ?rsa);
    if (is_err[bool, str](lr)) { ret lr; }
    var gp64: u32 = mir.MIR_VREG_NIL;
    val gzr: Result[bool, str] = lctx.emit_zext_to(ctx, mb, mir.op_vreg(gp), 4, ?gp64);
    if (is_err[bool, str](gzr)) { ret gzr; }
    var reg_base: u32 = mir.MIR_VREG_NIL;
    val rar: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(rsa), mir.op_vreg(gp64), 8, ?reg_base);
    if (is_err[bool, str](rar)) { ret rar; }

    # reg_src: the in-register source address. a >16B aggregate is passed by hidden
    # pointer, so the saved eightbyte IS that pointer (dereference it); a <=16B
    # aggregate's eightbytes sit in the save area by value, so the address is reg_base.
    var reg_src: u32 = reg_base;
    if (byref) {
        var p: u32 = mir.MIR_VREG_NIL;
        val lp: Result[bool, str] = lctx.emit_load_w(ctx, mb, mir.op_mem_value(reg_base, 0), 8, ?p);
        if (is_err[bool, str](lp)) { ret lp; }
        reg_src = p;
    }

    # ovf = overflow_arg_area; ovf_al = (ovf + 7) & ~7 (eight-byte granular overflow).
    var ovf: u32 = mir.MIR_VREG_NIL;
    val lo: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, model.overflow_field), 8, ?ovf);
    if (is_err[bool, str](lo)) { ret lo; }
    var ovf_up: u32 = mir.MIR_VREG_NIL;
    val au: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(ovf), mir.op_imm(7), 8, ?ovf_up);
    if (is_err[bool, str](au)) { ret au; }
    var ovf_al: u32 = mir.MIR_VREG_NIL;
    val ad: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(ovf_up), mir.op_imm(~7::i64), 8, ?ovf_al);
    if (is_err[bool, str](ad)) { ret ad; }

    # src = (reg_src & mask) | (ovf_al & ~mask).
    var rs_m: u32 = mir.MIR_VREG_NIL;
    val r1: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(reg_src), mir.op_vreg(mask), 8, ?rs_m);
    if (is_err[bool, str](r1)) { ret r1; }
    var ov_m: u32 = mir.MIR_VREG_NIL;
    val r2: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(ovf_al), mir.op_vreg(nmask), 8, ?ov_m);
    if (is_err[bool, str](r2)) { ret r2; }
    var src: u32 = mir.MIR_VREG_NIL;
    val r3: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_OR, mir.op_vreg(rs_m), mir.op_vreg(ov_m), 8, ?src);
    if (is_err[bool, str](r3)) { ret r3; }

    # gp_offset += (gp_bytes & mask32): advance the consumed GP eightbytes when used.
    var step_gp: u32 = mir.MIR_VREG_NIL;
    val sg: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_imm(gp_bytes), mir.op_vreg(mask), 4, ?step_gp);
    if (is_err[bool, str](sg)) { ret sg; }
    var new_gp: u32 = mir.MIR_VREG_NIL;
    val ng: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(gp), mir.op_vreg(step_gp), 4, ?new_gp);
    if (is_err[bool, str](ng)) { ret ng; }
    val wg: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, model.gp_offset_field), mir.op_vreg(new_gp), 4);
    if (is_err[bool, str](wg)) { ret wg; }

    # overflow_arg_area = (ovf & mask) | ((ovf_al + lctx.stack_slot_bytes(size)) & ~mask):
    # when the overflow area was used, advance past the aligned by-value bytes; else
    # leave it. uses lctx.stack_slot_bytes (size==0 -> 8) to stay in lockstep with the
    # caller's slot footprint, so an empty-struct vararg still consumes one eightbyte.
    val ovf_step: i64 = lctx.stack_slot_bytes(size);
    var ovf_next: u32 = mir.MIR_VREG_NIL;
    val on: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(ovf_al), mir.op_imm(ovf_step), 8, ?ovf_next);
    if (is_err[bool, str](on)) { ret on; }
    var ovf_keep: u32 = mir.MIR_VREG_NIL;
    val ok1: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(ovf), mir.op_vreg(mask), 8, ?ovf_keep);
    if (is_err[bool, str](ok1)) { ret ok1; }
    var ovf_take: u32 = mir.MIR_VREG_NIL;
    val ok2: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_AND, mir.op_vreg(ovf_next), mir.op_vreg(nmask), 8, ?ovf_take);
    if (is_err[bool, str](ok2)) { ret ok2; }
    var new_ovf: u32 = mir.MIR_VREG_NIL;
    val ok3: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_OR, mir.op_vreg(ovf_keep), mir.op_vreg(ovf_take), 8, ?new_ovf);
    if (is_err[bool, str](ok3)) { ret ok3; }
    val wo: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, model.overflow_field), mir.op_vreg(new_ovf), 8);
    if (is_err[bool, str](wo)) { ret wo; }

    # copy the aggregate's bytes from the selected source into the result storage.
    ret lctx.copy_aggregate(ctx, mb, mir.op_mem_value(dst, 0), mir.op_vreg(src), size);
}

# lower_va_arg_home: expand `OP_VA_ARG [ap]` under the win64 home-area model. the
# named and unnamed arguments form one contiguous array of 8-byte stack slots; the
# va_list is a single pointer (field offset 0) walking up it, one slot per argument
# (`model.arg_stride`). every result category reads from the current slot and the
# cursor advances by one slot:
#   * a scalar / pointer / float occupies its slot by value — load `width` bytes
#     (a variadic float was duplicated into the integer slot, so it is read here).
#   * a 1/2/4/8-byte aggregate rides one slot by value — copy `size` bytes from the
#     slot.
#   * any other aggregate is passed by hidden reference — the slot holds a pointer;
#     dereference it, then copy `size` bytes.
# the aggregate's by-value vs by-reference shape is read from the ABI's `arg_passing`
# classifier (a fresh register file), so the in-slot / pointer choice stays driven by
# the vtable, not hard-coded here.
fun lower_va_arg_home(ctx: *lctx.LowerCtx, mb: *mir.MirBlock, inst: *instr.Instruction, dst: u32,
                      model: *abi.VaModel) Result[bool, str] {
    val apbase: mir.MirOperand = lctx.mem_operand_of(ctx, inst.operands[0]);

    # ap = the current slot pointer (va_list field 0).
    var ap: u32 = mir.MIR_VREG_NIL;
    val la: Result[bool, str] = lctx.emit_load_w(ctx, mb, va_field_mem(apbase, 0), 8, ?ap);
    if (is_err[bool, str](la)) { ret la; }

    # advance the cursor by one slot and store it back before reading, so a later
    # va_arg sees the next slot.
    var next: u32 = mir.MIR_VREG_NIL;
    val ad: Result[bool, str] = lctx.emit_alu3(ctx, mb, mir.MIR_ADD, mir.op_vreg(ap), mir.op_imm(model.arg_stride), 8, ?next);
    if (is_err[bool, str](ad)) { ret ad; }
    val ws: Result[bool, str] = lctx.emit_store_to_w(ctx, mb, va_field_mem(apbase, 0), mir.op_vreg(next), 8);
    if (is_err[bool, str](ws)) { ret ws; }

    if (lctx.value_is_aggregate(ctx, inst.ty)) {
        val rok: Result[bool, str] = mabi.require_abi(ctx.tgt);
        if (is_err[bool, str](rok)) { ret rok; }
        val size:  u64 = ir_type.byte_size(ctx.types, inst.ty, ctx.tgt)::u64;
        val align: u64 = ir_type.byte_align(ctx.types, inst.ty, ctx.tgt)::u64;

        # classify the aggregate to learn whether the slot holds it by value or a
        # hidden pointer to it.
        val classify_arg: abi.ArgPassingFn = ctx.tgt.abi.arg_passing::abi.ArgPassingFn;
        val slot: abi.ParamSlot = classify_arg(0, size, align, false, 0, true, 0, 0);
        val byref: bool = slot.class == abi.CLASS_BYREF;

        # back the result vreg with caller-owned storage so downstream copies / stores
        # / returns treat the aggregate by value.
        val rs: Result[bool, str] = lctx.alloc_result_storage(ctx, mb, dst, size, lctx.ret_align(ctx, inst.ty));
        if (is_err[bool, str](rs)) { ret rs; }

        # the source is the slot itself for a by-value aggregate, or the pointer it
        # holds for a by-reference aggregate.
        var src: u32 = ap;
        if (byref) {
            var p: u32 = mir.MIR_VREG_NIL;
            val lp: Result[bool, str] = lctx.emit_load_w(ctx, mb, mir.op_mem_value(ap, 0), 8, ?p);
            if (is_err[bool, str](lp)) { ret lp; }
            src = p;
        }
        ret lctx.copy_aggregate(ctx, mb, mir.op_mem_value(dst, 0), mir.op_vreg(src), size);
    }

    val w: u8 = lctx.op_width_of(ctx, inst.ty);
    if (lctx.value_is_float(ctx, inst.ty)) {
        # a variadic float was duplicated into its integer/stack slot; read it there
        # with a float move so the value lands in the XMM-classed result vreg.
        ret lctx.emit_fmov(ctx, mb, mir.op_vreg(dst), mir.op_mem_value(ap, 0), w);
    }

    # a scalar / pointer rides its slot by value: load `width` bytes into the result.
    val r: Result[*mir.MirOperand, str] = allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (is_err[*mir.MirOperand, str](r)) { ret err[bool, str](unwrap_err[*mir.MirOperand, str](r)); }
    val ops: *mir.MirOperand = unwrap_ok[*mir.MirOperand, str](r);
    ops[0] = mir.op_vreg(dst);
    ops[1] = mir.op_mem_value(ap, 0);
    var mi: mir.MirInstr;
    mi.opcode        = mir.MIR_LOAD;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.src_width     = w;
    mi.width         = lctx.clamp_alu_width(w);
    ret lctx.push_instr(ctx, mb, mi);
}
