# the shared lowering context and emit primitives for IR-to-MIR translation
#
# `LowerCtx` is the per-function lowering state threaded through every pass of
# the IR-to-MIR translation (`mir.lower`) and the ABI call/param/ret lowering
# (`mir.abi`). It carries the target, the source IR function, and the vreg /
# slot cursors.
#
# This leaf owns that state plus the low-level emit primitives the three passes
# share: vreg allocation, the `emit_*` instruction builders, value / operand
# lowering, the frame-slot allocators, and the small type predicates. Factoring
# it out (the same role `me.lower.context` plays for the AST-to-IR lowering)
# keeps the pass modules from importing one another: each pass imports this
# context, never its siblings.

use std.system.panic.panic;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use std.allocator.page;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.be.codegen.mir;
use mach.lang.float;
use mach.lang.intern;
use mach.lang.me.ir;
use mach.lang.me.ir.id;
use mach.lang.me.ir.instruction;
use ir_type: mach.lang.me.ir.type;
use mach.lang.me.ir.value;
use mach.lang.source;
use mach.lang.target.isa;
use target:  mach.lang.target.resolved;

# per-function lowering state mapping each SSA definition to its virtual
# register
#
# A definition is a parameter (indexed by ordinal in `param_vregs`) or an
# instruction result (indexed by the function's instruction-pool index in
# `instr_vregs`). Parameter vregs are assigned first so their ids are dense and
# stable.
# ---
# alloc:       allocator for all per-function MIR storage
# tgt:         resolved compilation target; supplies the ABI vtable and arch id
#              for SysV classification of params, call args, and returns
# m:           source IR module; resolves VAL_FN / VAL_GLOBAL symbol names
# types:       IR type table for register-class selection
# fn:          source IR function being lowered (param / sig types)
# f:           MIR function being built
# param_vregs: per-parameter vreg map (length param_count)
# param_count: number of parameters
# instr_vregs: per-instruction vreg map (mir.MIR_VREG_NIL for a void definition)
# instr_count: number of instructions in the source pool
# interner:    session interner, for resolving inline-asm body / name strings
pub rec LowerCtx {
    alloc:       *A.Allocator;
    tgt:         *target.Target;
    m:           *ir.Module;
    types:       *ir_type.IrTypeTable;
    fn:          *ir.Function;
    f:           *mir.MirFunction;
    param_vregs: *u32;
    param_count: u32;
    instr_vregs: *u32;

    # per-instruction map (length instr_count) from an OP_ALLOCA instruction id
    # to the slot-key vreg that owns its frame slot, mir.MIR_VREG_NIL for every
    # non-alloca id. an alloca's result vreg holds its pointer value and may be
    # register-allocated, while the frame slot is keyed on a separate slot-key
    # vreg; inline-asm `{name}` references need the slot key to resolve the local
    # to `[rbp + offset]`.
    slot_key_vregs: *u32;

    instr_count: u32;
    interner:    *intern.Interner;

    # the vreg holding the hidden return-storage pointer when the function
    # returns a >16-byte aggregate (CLASS_SRET), captured from the first GP
    # argument register in `lower_params`; mir.MIR_VREG_NIL otherwise. `lower_ret`
    # copies the returned aggregate into this storage and returns it in RAX.
    sret_vreg: u32;

    # source location of the IR instruction currently being lowered, stamped onto
    # every MirInstr `push_instr` appends so lowered machine instructions carry a
    # PC<->source mapping for debug line tables. set per IR instruction by the
    # lowering loop; source.loc_nil() outside one (params / prologue setup).
    cur_loc: source.SrcLoc;

    # inline instance (1-based, 0 = function body) of the IR instruction currently
    # being lowered, stamped onto every MirInstr `push_instr` appends so the encoder
    # can group an inlined expansion's PC ranges. set per IR instruction by the
    # lowering loop alongside cur_loc; 0 outside one.
    cur_inline_site: u32;

    # the 128-bit vector lane descriptor of the IR instruction currently being
    # lowered (#1965), stamped onto every MirInstr `push_instr` appends so a backend
    # selector can read the lane element kind + width a vector op needs. set per IR
    # instruction by the lowering loop alongside cur_loc; VEC_LANE_NONE (0) outside
    # one and for every non-vector instruction, so non-vector code is unaffected.
    cur_vec_lane: u8;

    # the constant-time secrecy taint of the IR instruction currently being lowered
    # (#1646), stamped onto every MirInstr `push_instr` appends so the lowered stream
    # carries the taint. set per IR instruction by the lowering loop from the
    # instruction's result taint alongside cur_loc; false outside one and for every
    # public instruction, so secret-free code is unaffected and stays byte-identical.
    cur_secret: bool;

    # `-g`-only source-variable bindings awaiting attachment: an OP_DBG_VALUE records
    # its (iid, vreg) here, and the next `push_instr` attaches the whole list (in order)
    # to the instruction at whose PC the variables become live, then clears it. any
    # remaining at block end flush onto the block's last instruction. empty without -g.
    pending:       *mir.MirDbgBinding;
    pending_count: u32;
    pending_cap:   u32;
}

# allocate the per-definition vreg maps and assign a vreg to every parameter and
# every non-void instruction result
#
# Parameter vregs come first so their ids are dense and stable.
# ---
# ctx: the lowering context to populate
# tgt: resolved target supplying register-class classification
# fn:  source IR function whose params and instructions are mapped
# ret: true on success, or an allocation error
pub fun ctx_setup(ctx: *LowerCtx, tgt: *target.Target, fn: *ir.Function) R.Result[bool, str] {
    if (ctx.param_count > 0) {
        val res_params: R.Result[*u32, str] = A.allocate[u32](ctx.alloc, ctx.param_count::usize);
        if (R.is_err[*u32, str](res_params)) { ret R.err[bool, str](R.unwrap_err[*u32, str](res_params)); }
        ctx.param_vregs = R.unwrap_ok[*u32, str](res_params);
    }

    if (ctx.instr_count > 0) {
        val res_instrs: R.Result[*u32, str] = A.allocate[u32](ctx.alloc, ctx.instr_count::usize);
        if (R.is_err[*u32, str](res_instrs)) { ret R.err[bool, str](R.unwrap_err[*u32, str](res_instrs)); }
        ctx.instr_vregs = R.unwrap_ok[*u32, str](res_instrs);

        val res_keys: R.Result[*u32, str] = A.allocate[u32](ctx.alloc, ctx.instr_count::usize);
        if (R.is_err[*u32, str](res_keys)) { ret R.err[bool, str](R.unwrap_err[*u32, str](res_keys)); }
        ctx.slot_key_vregs = R.unwrap_ok[*u32, str](res_keys);

        var i: u32 = 0;
        for (i < ctx.instr_count) {
            ctx.slot_key_vregs[i] = mir.MIR_VREG_NIL;
            i = i + 1;
        }
    }

    var i: u32 = 0;
    for (i < ctx.param_count) {
        val reg_class: u32 = reg_class_of(ctx, tgt, fn.params[i].ty);
        val res_vreg: R.Result[u32, str] = new_vreg_vec(ctx, reg_class, value_is_vector(ctx, fn.params[i].ty));
        if (R.is_err[u32, str](res_vreg)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_vreg)); }
        val pv: u32 = R.unwrap_ok[u32, str](res_vreg);
        ctx.param_vregs[i] = pv;
        # carry a secret parameter's taint onto its vreg so the MIR value is queryable (#1646)
        if (fn.params[i].secret) { ctx.f.vregs[pv].secret = true; }
        i = i + 1;
    }

    i = 0;
    for (i < ctx.instr_count) {
        ctx.instr_vregs[i] = mir.MIR_VREG_NIL;
        val inst: *instruction.Instruction = ?fn.instrs[i];
        if (defines_value(ctx, inst)) {
            # every result's vreg class comes from its own result type; an alloca
            # now carries the IR pointer type (its element type rides on aux_ty),
            # so it classifies general-purpose without a special case.
            val reg_class: u32 = reg_class_of(ctx, tgt, inst.ty);
            val res_vreg: R.Result[u32, str] = new_vreg_vec(ctx, reg_class, value_is_vector(ctx, inst.ty));
            if (R.is_err[u32, str](res_vreg)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_vreg)); }
            val rv: u32 = R.unwrap_ok[u32, str](res_vreg);
            ctx.instr_vregs[i] = rv;
            # carry the instruction's result taint onto its vreg so the MIR value is
            # queryable by the #1648 validator (#1646).
            if (inst.secret) { ctx.f.vregs[rv].secret = true; }
        }
        i = i + 1;
    }

    ret R.ok[bool, str](true);
}

# release the per-definition vreg maps held by a lowering context
# ---
# ctx: the context to tear down
pub fun ctx_dnit(ctx: *LowerCtx) {
    if (ctx.param_vregs != nil && ctx.param_count > 0) {
        A.deallocate[u32](ctx.alloc, ctx.param_vregs, ctx.param_count::usize);
        ctx.param_vregs = nil;
    }
    if (ctx.instr_vregs != nil && ctx.instr_count > 0) {
        A.deallocate[u32](ctx.alloc, ctx.instr_vregs, ctx.instr_count::usize);
        ctx.instr_vregs = nil;
    }
    if (ctx.slot_key_vregs != nil && ctx.instr_count > 0) {
        A.deallocate[u32](ctx.alloc, ctx.slot_key_vregs, ctx.instr_count::usize);
        ctx.slot_key_vregs = nil;
    }
    if (ctx.pending != nil && ctx.pending_cap > 0) {
        A.deallocate[mir.MirDbgBinding](ctx.alloc, ctx.pending, ctx.pending_cap::usize);
        ctx.pending = nil;
    }
}

# record one `-g` source-variable binding to attach to the next lowered instruction.
# Grows the pending buffer on demand. Called by OP_DBG_VALUE lowering instead of
# emitting any instruction, so the binding rides a real instruction and never perturbs
# codegen
# ---
# ctx:  the lowering context
# iid:  the IR OP_DBG_VALUE instruction id
# vreg: the operand's MIR vreg, or mir.MIR_VREG_NIL for no home
# ret:  true on success, or an allocation error
pub fun push_pending_dbg(ctx: *LowerCtx, iid: u32, vreg: u32) R.Result[bool, str] {
    if (ctx.pending_count >= ctx.pending_cap) {
        var new_cap: u32 = ctx.pending_cap * 2;
        if (new_cap < 4) { new_cap = 4; }
        if (ctx.pending == nil) {
            val ra: R.Result[*mir.MirDbgBinding, str] = A.allocate[mir.MirDbgBinding](ctx.alloc, new_cap::usize);
            if (R.is_err[*mir.MirDbgBinding, str](ra)) { ret R.err[bool, str](R.unwrap_err[*mir.MirDbgBinding, str](ra)); }
            ctx.pending = R.unwrap_ok[*mir.MirDbgBinding, str](ra);
        }
        or {
            val rr: R.Result[*mir.MirDbgBinding, str] = A.reallocate[mir.MirDbgBinding](ctx.alloc, ctx.pending, ctx.pending_cap::usize, new_cap::usize);
            if (R.is_err[*mir.MirDbgBinding, str](rr)) { ret R.err[bool, str](R.unwrap_err[*mir.MirDbgBinding, str](rr)); }
            ctx.pending = R.unwrap_ok[*mir.MirDbgBinding, str](rr);
        }
        ctx.pending_cap = new_cap;
    }
    ctx.pending[ctx.pending_count].iid  = iid;
    ctx.pending[ctx.pending_count].vreg = vreg;
    ctx.pending_count = ctx.pending_count + 1;
    ret R.ok[bool, str](true);
}

# attach every pending `-g` binding (in order) to `mi`, then clear the pending buffer.
# A no-op without -g / when no binding is pending. Called from `push_instr` (the next
# instruction after the OP_DBG_VALUE) and from the block-end flush
# ---
# ctx: the lowering context
# mi:  the instruction the pending bindings become live at
# ret: true on success, or an allocation error
pub fun drain_pending_dbg(ctx: *LowerCtx, mi: *mir.MirInstr) R.Result[bool, str] {
    var i: u32 = 0;
    for (i < ctx.pending_count) {
        val ra: R.Result[bool, str] = mir.instr_attach_dbg(ctx.alloc, mi, ctx.pending[i].iid, ctx.pending[i].vreg);
        if (R.is_err[bool, str](ra)) { ret ra; }
        i = i + 1;
    }
    ctx.pending_count = 0;
    ret R.ok[bool, str](true);
}

# append a fresh virtual register in the given register class and return its id
#
# Grows the function's vreg table on demand.
# ---
# ctx:       the lowering context
# reg_class: register-class index into target.arch.reg_classes
# ret:       the new vreg id, or an allocation error
pub fun new_vreg(ctx: *LowerCtx, reg_class: u32) R.Result[u32, str] {
    val f: *mir.MirFunction = ctx.f;
    if (f.vreg_count >= f.vreg_cap) {
        val new_cap: u32 = f.vreg_cap * 2;
        val res_vregs: R.Result[*mir.MirVReg, str] = A.reallocate[mir.MirVReg](ctx.alloc, f.vregs, f.vreg_cap::usize, new_cap::usize);
        if (R.is_err[*mir.MirVReg, str](res_vregs)) { ret R.err[u32, str](R.unwrap_err[*mir.MirVReg, str](res_vregs)); }
        f.vregs    = R.unwrap_ok[*mir.MirVReg, str](res_vregs);
        f.vreg_cap = new_cap;
    }
    val vid: u32 = f.vreg_count;
    f.vregs[vid].id         = vid;
    f.vregs[vid].class      = reg_class;
    f.vregs[vid].spill_slot = -1;
    f.vregs[vid].assigned   = mir.MIR_VREG_NIL;
    f.vregs[vid].vector     = false;
    f.vregs[vid].secret     = false;   # public until ctx_setup marks a secret definition (#1646)
    f.vreg_count = f.vreg_count + 1;
    ret R.ok[u32, str](vid);
}

# append a fresh vreg that holds a 128-bit vector when `vector` is set, so regalloc
# 16-byte-aligns its spill slot for MOVAPS reloads (#2014)
# ---
# ctx:       the lowering context
# reg_class: register-class index into target.arch.reg_classes
# vector:    whether the vreg holds a 128-bit SIMD vector
# ret:       the new vreg id, or an allocation error
pub fun new_vreg_vec(ctx: *LowerCtx, reg_class: u32, vector: bool) R.Result[u32, str] {
    val r: R.Result[u32, str] = new_vreg(ctx, reg_class);
    if (R.is_err[u32, str](r)) { ret r; }
    ctx.f.vregs[R.unwrap_ok[u32, str](r)].vector = vector;
    ret r;
}

# the result vreg mapped to an instruction id, or mir.MIR_VREG_NIL when the id is
# out of range or names a void-defining instruction
# ---
# ctx: the lowering context
# iid: the source instruction id
# ret: the result vreg, or mir.MIR_VREG_NIL
pub fun instr_vreg(ctx: *LowerCtx, iid: id.InstructionId) u32 {
    if (iid == id.INSTR_NIL)         { ret mir.MIR_VREG_NIL; }
    if (ctx.instr_vregs == nil)      { ret mir.MIR_VREG_NIL; }
    if (iid::u32 >= ctx.instr_count) { ret mir.MIR_VREG_NIL; }
    ret ctx.instr_vregs[iid::u32];
}

# the slot-key vreg owning the frame slot of the alloca at instruction `iid`, or
# mir.MIR_VREG_NIL when the id is out of range or names a non-alloca
# ---
# ctx: the lowering context
# iid: the source instruction id
# ret: the slot-key vreg, or mir.MIR_VREG_NIL
pub fun slot_key_vreg(ctx: *LowerCtx, iid: id.InstructionId) u32 {
    if (iid == id.INSTR_NIL)         { ret mir.MIR_VREG_NIL; }
    if (ctx.slot_key_vregs == nil)   { ret mir.MIR_VREG_NIL; }
    if (iid::u32 >= ctx.instr_count) { ret mir.MIR_VREG_NIL; }
    ret ctx.slot_key_vregs[iid::u32];
}

# true when an IR type is a floating-point scalar, so the ABI classifier routes
# it through the FP register file
# ---
# ctx: the lowering context
# ty:  the IR type to classify
# ret: true for a float scalar
pub fun value_is_float(ctx: *LowerCtx, ty: ir_type.IrTypeId) bool {
    ret ir_type.is_float_scalar(ctx.types, ty);
}

# true when an IR type is a record or array, so the ABI classifier applies the
# aggregate (one/two-register or by-reference) rules
# ---
# ctx: the lowering context
# ty:  the IR type to classify
# ret: true for an aggregate
pub fun value_is_aggregate(ctx: *LowerCtx, ty: ir_type.IrTypeId) bool {
    ret ir_type.is_aggregate(ctx.types, ty);
}

# whether an IR value type is a 128-bit vector (#1965)
#
# The neutral classifier the psABI classify driver and the target-generic MIR
# guard both consult; each backend owns only its own vector-class ABI branch.
# ---
# ctx: the lowering context
# ty:  the IR value type to classify
# ret: true for an IRT_VECTOR
pub fun value_is_vector(ctx: *LowerCtx, ty: ir_type.IrTypeId) bool {
    ret ir_type.is_vector(ctx.types, ty);
}

# the vec_lane MIR descriptor for an IR value type (#1965)
#
# VEC_LANE_NONE for a non-vector; otherwise the lane element kind (float vs
# integer) and byte-width packed for the backend selectors. Signedness is not part
# of the shape - it rides the consuming opcode.
# ---
# ctx: the lowering context
# ty:  the IR value type
# ret: the packed vec_lane descriptor
pub fun vec_lane_for_type(ctx: *LowerCtx, ty: ir_type.IrTypeId) u8 {
    var is_float:   bool = false;
    var elem_bytes: u8   = 0;
    if (!ir_type.vector_lane(ctx.types, ty, ?is_float, ?elem_bytes)) { ret mir.VEC_LANE_NONE; }
    var kind: u8 = mir.VEC_LANE_INT;
    if (is_float) { kind = mir.VEC_LANE_FLOAT; }
    ret mir.vec_lane_make(kind, elem_bytes);
}

# the vec_lane descriptor for a whole IR instruction (#1965)
#
# The lane shape of its first vector-typed operand - a comparison's operand carries
# the element kind/width its unsigned-mask result does not - falling back to a
# vector result (a load or literal has no vector operand). VEC_LANE_NONE when
# nothing vector-typed flows through, which is every non-vector instruction.
# ---
# ctx:  the lowering context
# inst: the IR instruction being lowered
# ret:  the packed vec_lane descriptor to stamp on its MIR instructions
pub fun compute_vec_lane(ctx: *LowerCtx, inst: *instruction.Instruction) u8 {
    var i: u32 = 0;
    for (i < inst.operand_count) {
        val d: u8 = vec_lane_for_type(ctx, inst.operands[i].ty);
        if (mir.vec_lane_is_vector(d)) { ret d; }
        i = i + 1;
    }
    ret vec_lane_for_type(ctx, inst.ty);
}

# the lowered function's IR return type, read from its function type (IRT_FN)
#
# Returns IRT_NIL when the signature is unavailable or void so the param
# classifier skips the sret reservation.
# ---
# ctx: the lowering context
# ret: the IR return type, or IRT_NIL
pub fun fn_return_type(ctx: *LowerCtx) ir_type.IrTypeId {
    val opt_type: O.Option[*ir_type.IrType] = ir_type.get(ctx.types, ctx.fn.sig);
    if (O.is_none[*ir_type.IrType](opt_type)) { ret ir_type.IRT_NIL; }
    val t: *ir_type.IrType = O.unwrap[*ir_type.IrType](opt_type);
    if (t.kind != ir_type.IRT_FN) { ret ir_type.IRT_NIL; }
    ret t.data.fn.ret_type;
}

# the natural alignment of an aggregate return type, used to align its
# caller-owned result storage
#
# Defaults to the machine word when the type is unavailable so a slot is never
# sub-word aligned.
# ---
# ctx: the lowering context
# ty:  the aggregate return type
# ret: the alignment in bytes
pub fun ret_align(ctx: *LowerCtx, ty: ir_type.IrTypeId) u32 {
    val align: u32 = ir_type.byte_align(ctx.types, ty, ctx.tgt);
    if (align == 0) { ret ctx.tgt.model.gpr_width; }
    ret align;
}

# the encoder operand width in bytes for an IR type: its `ir_type.byte_size`
# clamped to the nearest legal x86-64 operand width (1, 2, 4, or 8)
#
# A scalar (int / float / pointer) maps to its own size; an aggregate or a value
# wider than a machine word is held and addressed by pointer, so it rides at the
# word width. A zero-sized or void type (the void result of a store) yields the
# word width so a pseudo with no natural width still sizes its address-sized
# fields. This is the single carrier that makes the encoder drive 1 / 2 / 4 /
# 8-byte operations at the correct REX.W and prefix.
# ---
# ctx: the lowering context
# ty:  the IR type to size
# ret: the operand width in bytes (1, 2, 4, or 8)
pub fun op_width_of(ctx: *LowerCtx, ty: ir_type.IrTypeId) u8 {
    val sz: u32 = ir_type.byte_size(ctx.types, ty, ctx.tgt);
    if (sz == 1) { ret 1; }
    if (sz == 2) { ret 2; }
    if (sz == 4) { ret 4; }
    # a 128-bit vector rides its full 16-byte width in a vector register, rather
    # than clamping to the GP word width (#1965).
    if (sz == 16 && value_is_vector(ctx, ty)) { ret 16; }
    ret ctx.tgt.model.gpr_width::u8;
}

# raise a sub-`mir.ALU_MIN_WIDTH` integer ALU operation width up to the target's
# ALU floor so the result fully defines the register it spills through
#
# The floor is the smaller of `mir.ALU_MIN_WIDTH` and the target's machine word: a
# sub-word ALU op computes at >= 4 bytes so its low result fully defines the
# register it spills through and no sub-word garbage persists (the x86_64 / arm64 /
# riscv64 invariant, whose machine word is >= 4). A target whose machine word is
# NARROWER than that - the 8-bit mos6502, one byte - cannot compute wider than its
# word, so it floors at the word width and the width legalizer splits anything a
# type genuinely needs wider. For every wide-native target `min(4, gpr_width)` is 4,
# so this is byte-identical to the old fixed clamp.
# ---
# gpr_width: the target machine-word width in bytes (`model.gpr_width`)
# w:         the requested operation width in bytes
# ret:       the width raised to at least the target ALU floor
pub fun clamp_alu_width(gpr_width: u32, w: u8) u8 {
    var floor: u8 = mir.ALU_MIN_WIDTH;
    if (gpr_width::u8 < floor) { floor = gpr_width::u8; }
    if (w < floor) { ret floor; }
    ret w;
}

# the outgoing-region footprint of one stack-passed argument
#
# SysV passes each stack argument in an eight-byte-granular slot (a value
# smaller than eight bytes still consumes a full slot), so round the value size
# up to the eight-byte boundary. Mirrors the `[rbp + 16 + off]` layout the
# callee reads.
# ---
# size: the argument's value size in bytes (from its ABI ParamSlot)
# ret:  the eight-byte-aligned slot size in bytes
pub fun stack_slot_bytes(size: u64) i64 {
    var n: u64 = size;
    if (n == 0) { n = 8; }
    n = (n + 7) & ~7::u64;
    ret n::i64;
}

# lower an SSA Value reference to a MIR operand
#
# Instruction / parameter results become mir.MIR_OP_VREG; integer / null
# constants become mir.MIR_OP_IMM; a float constant passes its bit pattern as an
# immediate (narrowed to single precision for an f32, so the low 32 bits an
# SS-form load reads are the f32 value); global and function symbols become
# mir.MIR_OP_SYM carrying the interned name resolved from the IR module -- the
# symbol name is the only carrier of the callee / global relocation target into
# isel and encode. An unexpected value kind (an out-of-range symbol index or an
# un-interned byte blob) is a lowering bug and fails loudly rather than emitting
# a silently-zeroed immediate or a relocation against no name.
# ---
# ctx: the lowering context
# v:   the IR value to lower
# ret: the MIR operand for `v`
pub fun lower_value(ctx: *LowerCtx, v: value.Value) mir.MirOperand {
    if (v.kind == value.VAL_INSTR) {
        ret mir.op_vreg(instr_vreg(ctx, v.data.instr));
    }
    if (v.kind == value.VAL_PARAM) {
        ret mir.op_vreg(param_vreg(ctx, v.data.param_ix));
    }
    if (v.kind == value.VAL_CONST_INT) {
        ret mir.op_imm(v.data.int_lit::i64);
    }
    if (v.kind == value.VAL_CONST_NULL) {
        ret mir.op_imm(0);
    }
    if (v.kind == value.VAL_CONST_FLOAT) {
        # the constant carries its comptime f64 bit pattern (the `int_lit` /
        # `float_lit` union alias). an f32 constant must materialize its
        # single-precision pattern so the low 32 bits an SS-form load / op reads
        # are the f32 value, not the low half of the f64 representation. narrow
        # with the shared round-to-nearest-even conversion, matching the global
        # initializer emission.
        if (op_width_of(ctx, v.ty) == 4) {
            ret mir.op_imm(float.f64_to_f32_bits(v.data.int_lit)::i64);
        }
        ret mir.op_imm(v.data.int_lit::i64);
    }
    if (v.kind == value.VAL_GLOBAL) {
        if (v.data.global_ix < ctx.m.global_len) {
            # a genuine foreign/dynamic data import (`is_import`, an `ext val`/
            # `ext var`) is preemptible: its definition lives in another object
            # bound at run time, so its address is loaded GOT-indirect (#2026). a
            # plain same-artifact cross-module reference (`is_extern` but not
            # `is_import`) is resolved within the artifact and keeps the direct,
            # position-independent adrp+add form. the linker builds the GOT slot -
            # GLOB_DAT for a dynamic import, a filled slot for a static definition.
            var o: mir.MirOperand = mir.op_sym(ctx.m.globals[v.data.global_ix].name, 0);
            if (ctx.m.globals[v.data.global_ix].is_import) { o.sym_got = true; }
            ret o;
        }
        # an in-range global index is an IR invariant; an out-of-range one is a
        # lowering bug -- fail loudly rather than emit a STR_NIL symbol the
        # encoder would turn into a relocation against no name.
        panic("mir.lower_ir: global value index out of range\n");
        ret mir.op_imm(0);
    }
    if (v.kind == value.VAL_FN) {
        if (v.data.fn_ix < ctx.m.function_len) {
            ret mir.op_sym(ctx.m.functions[v.data.fn_ix].name, 0);
        }
        panic("mir.lower_ir: function value index out of range\n");
        ret mir.op_imm(0);
    }
    panic("mir.lower_ir: unexpected IR value kind in lower_value\n");
    ret mir.op_imm(0);
}

# lower a single IR operand by position, honouring the per-opcode conventions
# for operands that name block targets rather than values
#
# BR's single target and CBR's then/else targets ride in value slots as block-id
# constants and lower to block operands; every other operand lowers as a value.
# ---
# ctx:  the lowering context
# inst: the instruction owning the operand
# idx:  the operand position
# ret:  the MIR operand for operand `idx`
pub fun lower_operand(ctx: *LowerCtx, inst: *instruction.Instruction, idx: u32) mir.MirOperand {
    val v: value.Value = inst.operands[idx];
    if (inst.kind == instruction.OP_BR) {
        ret mir.op_block(v.data.int_lit::u32);
    }
    if (inst.kind == instruction.OP_CBR && idx >= 1) {
        ret mir.op_block(v.data.int_lit::u32);
    }
    ret lower_value(ctx, v);
}

# form the memory operand a load / store / gep addresses through
#
# A pointer that lowers to a vreg is a value-pointer base (an alloca's result
# pointer or a runtime pointer -- never the internal slot-key vreg), so it
# becomes a value-vreg `[base + 0]` MEM operand regalloc resolves to a physical
# register; a symbol or immediate pointer is returned as-is so the encoder forms
# its own (rip-relative / absolute) reference.
# ---
# ctx: the lowering context
# v:   the pointer value to address through
# ret: the memory operand
pub fun mem_operand_of(ctx: *LowerCtx, v: value.Value) mir.MirOperand {
    val op: mir.MirOperand = lower_value(ctx, v);
    if (op.kind == mir.MIR_OP_VREG) { ret mir.op_mem_value(op.vreg, 0); }
    ret op;
}

# append a MIR instruction to a block, growing its instruction list on demand
#
# Enforces the asm_block invariant: a mir.MirInstr carries an inline-asm payload
# only for a mir.MIR_ASM instruction, and nil otherwise. Instructions are built
# field-by-field and only the mir.MIR_ASM emitter ever sets asm_block; since
# struct locals are not guaranteed zero-initialized, an otherwise-indeterminate
# asm_block would reach the back end -- `regalloc.flatten` reads `asm_block !=
# nil` as the inline-asm clobber-barrier discriminant and would wrongly fence
# almost every instruction, collapsing the argument-register reservation
# windows. Nil it here, at the single store chokepoint, so the field's
# documented contract holds.
# ---
# ctx: the lowering context
# mb:  the block to append to
# mi:  the instruction to append
# ret: true on success, or an allocation error
pub fun push_instr(ctx: *LowerCtx, mb: *mir.MirBlock, mi: mir.MirInstr) R.Result[bool, str] {
    var ni: mir.MirInstr = mi;
    if (ni.opcode != mir.MIR_ASM) { ni.asm_block = nil; }
    # stamp the source location of the IR instruction being lowered, at the single
    # append chokepoint, so every MirInstr carries its real source line. (a residual
    # unstamped loc is zeroed to {FILE_NIL=0, 0} == loc_nil == no row, harmless, but
    # the real loc is what the line table wants.)
    ni.loc = ctx.cur_loc;
    # the inline instance rides beside loc, stamped at the same chokepoint for the same
    # non-zero-init reason, so every lowered instruction carries its inlined-from origin.
    ni.inline_site = ctx.cur_inline_site;
    # the vector lane descriptor rides beside loc for the same non-zero-init reason,
    # so every lowered instruction carries the lane shape of the IR op it came from
    # (VEC_LANE_NONE for non-vector code, leaving those instructions unaffected).
    ni.vec_lane = ctx.cur_vec_lane;
    # the constant-time secrecy taint rides beside loc for the same non-zero-init reason,
    # so every lowered instruction carries the taint of the IR op it came from (false for
    # public code, leaving secret-free instructions untouched and byte-identical). (#1646)
    ni.secret = ctx.cur_secret;
    # the dbg-binding list defaults empty here for the same reason (callers build
    # instructions field-by-field and never set it); any pending -g binding then
    # attaches to this instruction, the next one after its OP_DBG_VALUE.
    ni.dbg_bindings      = nil;
    ni.dbg_binding_count = 0;
    val res_drain: R.Result[bool, str] = drain_pending_dbg(ctx, ?ni);
    if (R.is_err[bool, str](res_drain)) { ret res_drain; }
    val res_grow: R.Result[bool, str] = grow_instr(ctx, mb);
    if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    mb.instrs[mb.instr_count] = ni;
    mb.instr_count = mb.instr_count + 1;
    ret R.ok[bool, str](true);
}

# ensure `mb` has room for one more instruction, growing the list on demand
#
# Unlike `push_instr` it does not append; the caller places the instruction
# (used by the before-terminator splice).
# ---
# ctx: the lowering context
# mb:  the block to grow
# ret: true once the block has room, or an allocation error
pub fun grow_instr(ctx: *LowerCtx, mb: *mir.MirBlock) R.Result[bool, str] {
    if (mb.instr_count >= mb.instr_cap) {
        var new_cap: u32 = mb.instr_cap * 2;
        if (new_cap < mir.INITIAL_INSTR_CAP) { new_cap = mir.INITIAL_INSTR_CAP; }
        val res_instrs: R.Result[*mir.MirInstr, str] = A.reallocate[mir.MirInstr](ctx.alloc, mb.instrs, mb.instr_cap::usize, new_cap::usize);
        if (R.is_err[*mir.MirInstr, str](res_instrs)) { ret R.err[bool, str](R.unwrap_err[*mir.MirInstr, str](res_instrs)); }
        mb.instrs    = R.unwrap_ok[*mir.MirInstr, str](res_instrs);
        mb.instr_cap = new_cap;
    }
    ret R.ok[bool, str](true);
}

# append a machine-word `mir.MIR_MOV (dst) <- (src)` to a block
#
# Used for every ABI pre-coloring move (vreg<->preg, imm->preg) as well as plain
# vreg copies. A scalar argument / return / hidden-pointer value occupies a full
# register or an 8-byte stack slot under SysV, so a full-width move copies the
# value's low bits intact without truncating it.
# ---
# ctx: the lowering context
# mb:  the block to append to
# dst: destination operand
# src: source operand
# ret: true on success, or an allocation error
pub fun emit_mov(ctx: *LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_MOV, dst, src, ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
}

# append a `mir.MIR_MOV (dst) <- (src)` driven at an explicit operation width
# rather than the machine word
#
# Used for the division dividend / result pre-coloring moves, where the move
# must be exactly the divide's width so a 4-byte move zeroes the upper 32 bits
# of the accumulator and a 1/2-byte move leaves the surrounding bits untouched,
# matching the width the IDIV/DIV operates on. Every other ABI pre-coloring move
# is full-width (`emit_mov`).
# ---
# ctx: the lowering context
# mb:  the block to append to
# dst: destination operand
# src: source operand
# w:   the operation width in bytes
# ret: true on success, or an allocation error
pub fun emit_mov_w(ctx: *LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand, w: u8) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_MOV, dst, src, w, w);
}

# append a scalar floating-point register copy `mir.MIR_MOV (dst) <- (src)` at
# the given float width (4 for f32, 8 for f64)
#
# Used for the CLASS_FP ABI pre-coloring moves -- a float argument / return /
# parameter that pairs an XMM physical register with a value vreg or a
# float-constant immediate. A float copy is a plain mir.MIR_MOV; the encoder
# dispatches the move family on operand register class (an XMM-bank operand
# selects MOVSS / MOVSD, a cross-bank pair MOVD / MOVQ), so a float can never be
# encoded as a move of the GP register that aliases its XMM index. The float
# width is carried on the move so the encoder picks the single- vs
# double-precision SSE form; it is preserved across register allocation.
# ---
# ctx: the lowering context
# mb:  the block to append to
# dst: destination operand
# src: source operand
# w:   the float width in bytes (4 or 8)
# ret: true on success, or an allocation error
pub fun emit_fmov(ctx: *LowerCtx, mb: *mir.MirBlock, dst: mir.MirOperand, src: mir.MirOperand, w: u8) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_MOV, dst, src, w, w);
}

# append a machine-word `mir.MIR_STORE (mem) <- (src)` to a block
#
# Operand 0 is the fully-formed memory destination (a slot-key or
# physical-register MEM operand the caller builds), operand 1 the stored value.
# Every caller stores a full register into an 8-byte stack-argument /
# aggregate-half / spill slot under SysV.
# ---
# ctx: the lowering context
# mb:  the block to append to
# mem: the memory destination operand
# src: the stored value operand
# ret: true on success, or an allocation error
pub fun emit_store_to(ctx: *LowerCtx, mb: *mir.MirBlock, mem: mir.MirOperand, src: mir.MirOperand) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_STORE, mem, src, ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
}

# append a `mir.MIR_STORE (mem) <- (src)` at an explicit `width` (vs
# `emit_store_to`'s machine-word default)
#
# Used to write the 4-byte gp_offset and the 8-byte overflow_arg_area back into
# the va_list.
# ---
# ctx:   the lowering context
# mb:    the block to append to
# mem:   the memory destination operand
# src:   the stored value operand
# width: the store width in bytes
# ret:   true on success, or an allocation error
pub fun emit_store_to_w(ctx: *LowerCtx, mb: *mir.MirBlock, mem: mir.MirOperand, src: mir.MirOperand, width: u8) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_STORE, mem, src, width, width);
}

# emit one `mir.MIR_STORE [mem] <- (src)` at an explicit byte width, used by the
# aggregate memcpy expansion
#
# Mirrors `emit_store_to` but carries the chunk width rather than the machine
# word so a 4/2/1-byte tail copies exactly its bytes without writing past the
# aggregate.
# ---
# ctx: the lowering context
# mb:  the block to append to
# mem: the memory destination operand
# src: the stored value operand
# w:   the chunk width in bytes
# ret: true on success, or an allocation error
pub fun push_store_chunk(ctx: *LowerCtx, mb: *mir.MirBlock, mem: mir.MirOperand, src: mir.MirOperand, w: u8) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_STORE, mem, src, w, w);
}

# append a generic binary MIR op `dst <- (a) OP (b)` to a block
#
# Driven at the machine word: GEP index scaling is pointer arithmetic over
# machine-word index registers.
# ---
# ctx: the lowering context
# mb:  the block to append to
# op:  the binary MIR opcode
# dst: destination vreg id
# a:   left operand
# b:   right operand
# ret: true on success, or an allocation error
pub fun emit_bin(ctx: *LowerCtx, mb: *mir.MirBlock, op: mir.MirOpcode, dst: u32, a: mir.MirOperand, b: mir.MirOperand) R.Result[bool, str] {
    ret inst3(ctx, mb, op, mir.op_vreg(dst), a, b, ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
}

# append a `mir.MIR_GEP (dst) <- [preg + disp]` (selected to LEA) that
# materializes a frame-relative address into a value vreg
#
# Used to point a STACK aggregate parameter vreg at the caller's by-value copy
# at `[rbp + 16 + off]`.
# ---
# ctx:       the lowering context
# mb:        the block to append to
# dst:       destination vreg id
# base_preg: the physical base register
# disp:      the displacement from the base
# ret:       true on success, or an allocation error
pub fun emit_lea_preg(ctx: *LowerCtx, mb: *mir.MirBlock, dst: u32, base_preg: u32, disp: i64) R.Result[bool, str] {
    ret inst2(ctx, mb, mir.MIR_GEP, mir.op_vreg(dst), mir.op_mem_preg(base_preg, disp), ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
}

# materialize a frame-slot-relative address `[slot + disp]` into a fresh value
# vreg via `mir.MIR_GEP (out) <- [slot]` (selected to LEA), returned in `out`
#
# Used to point the va_list reg_save_area / overflow_arg_area at the
# register-save slot and the incoming stack-argument region.
# ---
# ctx: the lowering context
# mb:  the block to append to
# mem: the slot-relative memory operand
# out: receives the destination vreg id on success
# ret: true on success, or an allocation error
pub fun emit_lea_slot(ctx: *LowerCtx, mb: *mir.MirBlock, mem: mir.MirOperand, out: *u32) R.Result[bool, str] {
    val res_vreg: R.Result[u32, str] = new_vreg(ctx, mir.REG_CLASS_GP);
    if (R.is_err[u32, str](res_vreg)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_vreg)); }
    val v: u32 = R.unwrap_ok[u32, str](res_vreg);

    val res_emit: R.Result[bool, str] = inst2(ctx, mb, mir.MIR_GEP, mir.op_vreg(v), mem, ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
    if (R.is_err[bool, str](res_emit)) { ret res_emit; }
    @out = v;
    ret R.ok[bool, str](true);
}

# ensure an aggregate's storage address rides in a value vreg, returned in
# `out_vreg`
#
# The two-register / by-reference argument and return paths index `[base+0]` /
# `[base+8]` off the value vreg and pass it as a pointer. An argop that already
# is a value vreg (an alloca result or runtime pointer) is returned unchanged; a
# symbol-addressed aggregate (a module-level global) is LEA'd into a fresh vreg
# (`mir.MIR_GEP (vreg) <- [rip+sym]`, selected to LEA) so its address -- not its
# first word -- is what the ABI placement consumes.
# ---
# ctx:      the lowering context
# mb:       the block to append to
# argop:    the aggregate's address operand
# out_vreg: receives the value-vreg id on success
# ret:      true on success, or an allocation error
pub fun addr_to_vreg(ctx: *LowerCtx, mb: *mir.MirBlock, argop: mir.MirOperand, out_vreg: *u32) R.Result[bool, str] {
    if (argop.kind == mir.MIR_OP_VREG) {
        @out_vreg = argop.vreg;
        ret R.ok[bool, str](true);
    }
    val res_vreg: R.Result[u32, str] = new_vreg(ctx, mir.REG_CLASS_GP);
    if (R.is_err[u32, str](res_vreg)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_vreg)); }
    val v: u32 = R.unwrap_ok[u32, str](res_vreg);

    # the address materialization selects to a pointer-sized LEA.
    val res_emit: R.Result[bool, str] = inst2(ctx, mb, mir.MIR_GEP, mir.op_vreg(v), argop, ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
    if (R.is_err[bool, str](res_emit)) { ret res_emit; }
    @out_vreg = v;
    ret R.ok[bool, str](true);
}

# memcpy `size` bytes from the source aggregate storage into a destination
# memory operand
#
# `src` is a pointer-valued operand; `dst_mem` is a base+disp MEM operand such
# as an outgoing-stack slot. Walks the aggregate in 8/4/2/1-byte chunks through
# a scratch register, mirroring `lower_store_aggregate` but writing to a
# caller-supplied MEM destination whose base displacement advances per chunk.
# ---
# ctx:     the lowering context
# mb:      the block to append to
# dst_mem: the destination memory operand (advanced per chunk)
# src:     the source aggregate pointer operand
# size:    the number of bytes to copy
# ret:     true on success, or an allocation error
pub fun copy_aggregate(ctx: *LowerCtx, mb: *mir.MirBlock, dst_mem: mir.MirOperand, src: mir.MirOperand, size: u64) R.Result[bool, str] {
    var sbase: u32 = mir.MIR_VREG_NIL;
    val res_addr: R.Result[bool, str] = addr_to_vreg(ctx, mb, src, ?sbase);
    if (R.is_err[bool, str](res_addr)) { ret res_addr; }

    var off: i64 = 0;
    for (off::u64 < size) {
        val remaining: u64 = size - off::u64;
        var chunk: u8 = 1;
        if (remaining >= 8) {
            chunk = 8;
        }
        or (remaining >= 4) {
            chunk = 4;
        }
        or (remaining >= 2) {
            chunk = 2;
        }

        val res_tmp: R.Result[u32, str] = new_vreg(ctx, mir.REG_CLASS_GP);
        if (R.is_err[u32, str](res_tmp)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_tmp)); }
        val tmp: u32 = R.unwrap_ok[u32, str](res_tmp);

        val res_load: R.Result[bool, str] = inst2(ctx, mb, mir.MIR_LOAD, mir.op_vreg(tmp), mir.op_mem_value(sbase, off), chunk, chunk);
        if (R.is_err[bool, str](res_load)) { ret res_load; }

        # the destination MEM operand at this chunk's displacement: a slot-key
        # base rides in `vreg`, a physical-register base in `preg`; either
        # advances by off.
        var d: mir.MirOperand = dst_mem;
        d.imm = dst_mem.imm + off;
        val res_store: R.Result[bool, str] = push_store_chunk(ctx, mb, d, mir.op_vreg(tmp), chunk);
        if (R.is_err[bool, str](res_store)) { ret res_store; }

        off = off + chunk::i64;
    }
    ret R.ok[bool, str](true);
}

# append a mir.SLOT_ALLOCA frame slot keyed on an internal slot-key vreg, sized
# and aligned for the allocation
#
# frame.run assigns it an offset and the encoder forms `[rbp + offset]` for its
# address.
# ---
# ctx:      the lowering context
# value_id: the slot-key vreg owning the slot
# size:     the allocation size in bytes (0 falls back to its alignment)
# align:    the allocation alignment in bytes (0 falls back to 1)
# ret:      true on success, or an allocation error
pub fun add_alloca_slot(ctx: *LowerCtx, value_id: u32, size: u64, align: u32) R.Result[bool, str] {
    var al: u32 = align;
    if (al == 0) { al = 1; }
    var sz: u32 = size::u32;
    if (sz == 0) { sz = al; }
    ret frame_slot_add(ctx, value_id, mir.SLOT_ALLOCA, sz, al);
}

# append a mir.SLOT_SPILL frame slot for a register-passed aggregate parameter,
# keyed on its vreg id
#
# frame.run assigns it an offset and the encoder forms `[rbp + offset]` for the
# stored halves. The size is rounded up to the eight-byte register-store
# granularity (each incoming half is stored as a full GP register) so a sub-word
# aggregate's spill never overruns the slot.
# ---
# ctx:      the lowering context
# value_id: the vreg id owning the slot
# size:     the aggregate size in bytes
# ret:      true on success, or an allocation error
pub fun add_spill_slot(ctx: *LowerCtx, value_id: u32, size: u64) R.Result[bool, str] {
    var padded: u64 = (size + 7) & ~7::u64;
    if (padded == 0) { padded = 8; }
    ret frame_slot_add(ctx, value_id, mir.SLOT_SPILL, padded::u32, 8);
}

# back an aggregate call's result vreg with a caller-owned stack region and
# leave its address in the result vreg
#
# An internal slot-key vreg owns the mir.SLOT_SPILL region (sized / aligned for
# the returned aggregate); the emitted `mir.MIR_ALLOCA (dst) <- [slot]` selects
# to `LEA dst, [rbp + offset]`, so the result vreg is the address the
# return-register stores / SRET hidden pointer use and downstream aggregate
# consumers read by. Mirrors `lower_alloca`.
# ---
# ctx:   the lowering context
# mb:    the block to append to
# dst:   the result vreg to back
# size:  the returned aggregate size in bytes
# align: the returned aggregate alignment in bytes
# ret:   true on success, or an allocation error
pub fun alloc_result_storage(ctx: *LowerCtx, mb: *mir.MirBlock, dst: u32, size: u64, align: u32) R.Result[bool, str] {
    val res_key: R.Result[u32, str] = new_vreg(ctx, mir.REG_CLASS_GP);
    if (R.is_err[u32, str](res_key)) { ret R.err[bool, str](R.unwrap_err[u32, str](res_key)); }
    val sk: u32 = R.unwrap_ok[u32, str](res_key);

    val res_slot: R.Result[bool, str] = add_spill_slot_aligned(ctx, sk, size, align);
    if (R.is_err[bool, str](res_slot)) { ret res_slot; }

    # the address materialization selects to a pointer-sized LEA.
    ret inst2(ctx, mb, mir.MIR_ALLOCA, mir.op_vreg(dst), mir.op_mem_slot(sk, 0), ctx.tgt.model.gpr_width::u8, ctx.tgt.model.gpr_width::u8);
}

# true when an instruction defines a usable SSA value
#
# Void-typed instructions define nothing: terminators and stores are void by
# construction, and a void-returning OP_CALL or OP_ASM likewise produces no
# result. Consulting the result type catches all of them so void calls/asm get
# mir.MIR_VREG_NIL and the lowering skips their dead result bindings.
# ---
# ctx:  the lowering context
# inst: the instruction to classify
# ret:  true when the instruction defines a value
fun defines_value(ctx: *LowerCtx, inst: *instruction.Instruction) bool {
    if (instruction.is_terminator(inst.kind)) { ret false; }
    if (inst.kind == instruction.OP_STORE)    { ret false; }
    val opt_type: O.Option[*ir_type.IrType] = ir_type.get(ctx.types, inst.ty);
    if (O.is_some[*ir_type.IrType](opt_type)) {
        val t: *ir_type.IrType = O.unwrap[*ir_type.IrType](opt_type);
        if (t.kind == ir_type.IRT_VOID) { ret false; }
    }
    ret true;
}

# the vreg mapped to a parameter ordinal, or mir.MIR_VREG_NIL when out of range
# ---
# ctx: the lowering context
# ix:  the parameter ordinal
# ret: the parameter's vreg, or mir.MIR_VREG_NIL
fun param_vreg(ctx: *LowerCtx, ix: u32) u32 {
    if (ctx.param_vregs == nil) { ret mir.MIR_VREG_NIL; }
    if (ix >= ctx.param_count)  { ret mir.MIR_VREG_NIL; }
    ret ctx.param_vregs[ix];
}

# select the register-class index for an IR value type
#
# An IR float type maps to the float/vector bank; everything else maps to the
# general-purpose bank. Both banks are located in `tgt.model.reg_classes` by kind -
# the float bank by RC_FLOAT, the general bank by RC_GENERAL - so no arch-specific
# class name, index, or register width is hardcoded.
# ---
# ctx: the lowering context
# tgt: resolved target supplying the machine model's register-class table
# ty:  the IR value type to classify
# ret: the register-class index
fun reg_class_of(ctx: *LowerCtx, tgt: *target.Target, ty: ir_type.IrTypeId) u32 {
    val opt_type: O.Option[*ir_type.IrType] = ir_type.get(ctx.types, ty);
    if (O.is_some[*ir_type.IrType](opt_type)) {
        val t: *ir_type.IrType = O.unwrap[*ir_type.IrType](opt_type);
        # a 128-bit vector shares the float/vector bank (#1965).
        if (t.kind == ir_type.IRT_FLOAT || t.kind == ir_type.IRT_VECTOR) {
            ret fp_class_index(tgt);
        }
    }
    ret gp_class_index(tgt);
}

# the index of the float/vector register bank
#
# Located in `tgt.model.reg_classes` by its RC_FLOAT kind rather than a register
# width, parallel to `gp_class_index`'s RC_GENERAL lookup. The width plays no part
# in identifying the bank, so a target whose float bank is narrower than a vector
# register (rv64d's 64-bit f-registers) is found just like a 128-bit XMM / V bank.
# A target with no float bank cannot hold a float value, so a missing bank is a
# target-configuration bug and fails loudly rather than misclassifying a float
# into the GP bank.
# ---
# tgt: resolved target supplying the machine model's register-class table
# ret: the float/vector register-class index
fun fp_class_index(tgt: *target.Target) u32 {
    var ci: u32 = 0;
    for (ci < tgt.model.reg_class_len) {
        if (tgt.model.reg_classes[ci].kind == isa.RC_FLOAT) {
            ret ci;
        }
        ci = ci + 1;
    }
    panic("mir.lower_ir: target has no float/vector register bank\n");
    ret mir.REG_CLASS_GP;
}

# the index of the general-purpose register bank
#
# Located in `tgt.model.reg_classes` by its RC_GENERAL kind rather than a magic
# index, so the canonical general-purpose class is read from the machine model.
# A target that declares no general-purpose bank is a target-configuration bug and
# fails loudly.
# ---
# tgt: resolved target supplying the machine model's register-class table
# ret: the general-purpose register-class index
fun gp_class_index(tgt: *target.Target) u32 {
    var ci: u32 = 0;
    for (ci < tgt.model.reg_class_len) {
        if (tgt.model.reg_classes[ci].kind == isa.RC_GENERAL) {
            ret ci;
        }
        ci = ci + 1;
    }
    panic("mir.lower_ir: target has no general-purpose register bank\n");
    ret mir.REG_CLASS_GP;
}

# like `add_spill_slot` but with an explicit alignment for the aggregate
# result-storage region (the natural alignment of the returned type)
#
# A 16-byte-aligned aggregate result lands on its required boundary. The size is
# rounded up to the eight-byte register-store granularity so a 9-16 byte
# RAX:RDX or <=8 byte single-register return writing full GP registers never
# overruns the slot.
# ---
# ctx:      the lowering context
# value_id: the slot-key vreg owning the slot
# size:     the aggregate size in bytes
# align:    the slot alignment in bytes (0 falls back to 1)
# ret:      true on success, or an allocation error
pub fun add_spill_slot_aligned(ctx: *LowerCtx, value_id: u32, size: u64, align: u32) R.Result[bool, str] {
    var al: u32 = align;
    if (al == 0) { al = 1; }
    var sz: u32 = ((size + 7) & ~7::u64)::u32;
    if (sz == 0) { sz = al; }
    ret frame_slot_add(ctx, value_id, mir.SLOT_SPILL, sz, al);
}

# append a frame slot of the given kind, size, and alignment, growing the slot
# array on demand
#
# The shared core of the three frame-slot allocators: each computes its own
# sized / aligned values and the slot kind, then appends through here. The
# offset is left 0 for frame.run to assign.
# ---
# ctx:      the lowering context
# value_id: the MIR value id that owns the slot
# kind:     mir.SLOT_ALLOCA or mir.SLOT_SPILL
# size:     the slot size in bytes
# align:    the slot alignment in bytes
# ret:      true on success, or an allocation error
fun frame_slot_add(ctx: *LowerCtx, value_id: u32, kind: mir.MirSlotKind, size: u32, align: u32) R.Result[bool, str] {
    val f: *mir.MirFunction = ctx.f;
    val frame: *mir.MirFrame = ?f.frame;
    if (frame.slot_count >= frame.slot_cap) {
        var new_cap: u32 = frame.slot_cap * 2;
        if (new_cap < mir.INITIAL_SLOT_CAP) { new_cap = mir.INITIAL_SLOT_CAP; }
        val res_slots: R.Result[*mir.MirSlot, str] = A.reallocate[mir.MirSlot](ctx.alloc, frame.slots, frame.slot_cap::usize, new_cap::usize);
        if (R.is_err[*mir.MirSlot, str](res_slots)) { ret R.err[bool, str](R.unwrap_err[*mir.MirSlot, str](res_slots)); }
        frame.slots    = R.unwrap_ok[*mir.MirSlot, str](res_slots);
        frame.slot_cap = new_cap;
    }
    val si: u32 = frame.slot_count;
    frame.slots[si].value  = value_id;
    frame.slots[si].kind   = kind;
    frame.slots[si].offset = 0;
    frame.slots[si].size   = size;
    frame.slots[si].align  = align;
    frame.slot_count = frame.slot_count + 1;
    ret R.ok[bool, str](true);
}

# build and append a two-operand MIR instruction `(op0), (op1)` at the given
# operation and source widths
#
# The shared core of the two-operand `emit_*` family: it allocates the operand
# array, fills it, builds the instruction, and pushes it through `push_instr`.
# ---
# ctx:       the lowering context
# mb:        the block to append to
# opcode:    the MIR opcode
# op0:       operand 0 (the destination)
# op1:       operand 1
# width:     the operation width in bytes
# src_width: the source operand width in bytes
# ret:       true on success, or an allocation error
fun inst2(ctx: *LowerCtx, mb: *mir.MirBlock, opcode: mir.MirOpcode, op0: mir.MirOperand, op1: mir.MirOperand,
          width: u8, src_width: u8) R.Result[bool, str] {
    val res_ops: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 2::usize);
    if (R.is_err[*mir.MirOperand, str](res_ops)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](res_ops)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](res_ops);
    ops[0] = op0;
    ops[1] = op1;
    var mi: mir.MirInstr;
    mi.opcode        = opcode;
    mi.operands      = ops;
    mi.operand_count = 2;
    mi.width         = width;
    mi.src_width     = src_width;
    ret push_instr(ctx, mb, mi);
}

# build and append a three-operand MIR instruction `(op0), (op1), (op2)` at the
# given operation and source widths
#
# The shared core of the three-operand `emit_*` family (binary ALU ops, where
# operand 0 is the destination).
# ---
# ctx:       the lowering context
# mb:        the block to append to
# opcode:    the MIR opcode
# op0:       operand 0 (the destination)
# op1:       operand 1 (left)
# op2:       operand 2 (right)
# width:     the operation width in bytes
# src_width: the source operand width in bytes
# ret:       true on success, or an allocation error
fun inst3(ctx: *LowerCtx, mb: *mir.MirBlock, opcode: mir.MirOpcode, op0: mir.MirOperand, op1: mir.MirOperand,
          op2: mir.MirOperand, width: u8, src_width: u8) R.Result[bool, str] {
    val res_ops: R.Result[*mir.MirOperand, str] = A.allocate[mir.MirOperand](ctx.alloc, 3::usize);
    if (R.is_err[*mir.MirOperand, str](res_ops)) { ret R.err[bool, str](R.unwrap_err[*mir.MirOperand, str](res_ops)); }
    val ops: *mir.MirOperand = R.unwrap_ok[*mir.MirOperand, str](res_ops);
    ops[0] = op0;
    ops[1] = op1;
    ops[2] = op2;
    var mi: mir.MirInstr;
    mi.opcode        = opcode;
    mi.operands      = ops;
    mi.operand_count = 3;
    mi.width         = width;
    mi.src_width     = src_width;
    ret push_instr(ctx, mb, mi);
}

# size=0 treated as 8; 1..8 all round up to 8; 9 rounds to 16
test "mach.lang.be.codegen.mir.context.stack_slot_bytes" {
    if (stack_slot_bytes(0) != 8)  { ret 1; }
    if (stack_slot_bytes(1) != 8)  { ret 1; }
    if (stack_slot_bytes(8) != 8)  { ret 1; }
    if (stack_slot_bytes(9) != 16) { ret 1; }
    ret 0;
}

# on a wide-native target (machine word >= 4) sub-4 widths raise to 4 and 4 / 8
# pass through unchanged; on a narrow-word target (the 8-bit 6502, word 1) the
# floor drops to the word width so a byte op stays a byte op
test "mach.lang.be.codegen.mir.context.clamp_alu_width" {
    if (clamp_alu_width(8, 1) != 4) { ret 1; }
    if (clamp_alu_width(8, 2) != 4) { ret 1; }
    if (clamp_alu_width(8, 3) != 4) { ret 1; }
    if (clamp_alu_width(8, 4) != 4) { ret 1; }
    if (clamp_alu_width(8, 8) != 8) { ret 1; }
    # a 1-byte machine word floors at 1: byte arithmetic is not widened.
    if (clamp_alu_width(1, 1) != 1) { ret 1; }
    if (clamp_alu_width(1, 2) != 2) { ret 1; }
    ret 0;
}

# the float bank is found by RC_FLOAT kind, not a width threshold: a 64-bit float
# bank (rv64d's f-registers) resolves just like the 128-bit XMM / V bank (x64 /
# arm64 shape)
test "mach.lang.be.codegen.mir.context.fp_class_index" {
    var classes: [2]isa.RegClass;
    classes[0].kind = isa.RC_GENERAL;
    classes[1].kind = isa.RC_FLOAT;

    var tgt: target.Target;
    tgt.model.reg_classes   = ?classes[0];
    tgt.model.reg_class_len = 2;

    # a sub-128-bit float bank (rv64d shape) is found by kind.
    classes[1].bit_width = 64;
    if (fp_class_index(?tgt) != 1) { ret 1; }

    # a 128-bit float bank (x64 / arm64 shape) resolves to the same index.
    classes[1].bit_width = 128;
    if (fp_class_index(?tgt) != 1) { ret 1; }

    ret 0;
}

# shared vector scaffolding (#1965): a 128-bit vector routes to the FP/vector bank
# (like a float) and preserves its 16-byte operand width, while value_is_vector
# distinguishes it from a scalar; a GP scalar keeps its own bank and width
test "mach.lang.be.codegen.mir.context.vector_scaffolding" {
    var alloc: A.Allocator;
    page.make(?alloc);
    var types: ir_type.IrTypeTable;
    if (O.is_some[str](ir_type.init(?types, ?alloc))) { ret 1; }

    var classes: [2]isa.RegClass;
    classes[0].kind = isa.RC_GENERAL;
    classes[1].kind = isa.RC_FLOAT;
    classes[1].bit_width = 128;
    var tgt: target.Target;
    tgt.model.reg_classes   = ?classes[0];
    tgt.model.reg_class_len = 2;
    tgt.model.gpr_width     = 8;

    var ctx: LowerCtx;
    ctx.types = ?types;
    ctx.tgt   = ?tgt;

    # f32x4 IR vector and an i32 scalar.
    val ef: R.Result[ir_type.IrTypeId, str] = ir_type.intern_float(?types, 32);
    if (R.is_err[ir_type.IrTypeId, str](ef)) { ir_type.dnit(?types); ret 1; }
    val vr: R.Result[ir_type.IrTypeId, str] = ir_type.intern_vector(?types, R.unwrap_ok[ir_type.IrTypeId, str](ef), 4);
    if (R.is_err[ir_type.IrTypeId, str](vr)) { ir_type.dnit(?types); ret 1; }
    val vecty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](vr);

    val ir: R.Result[ir_type.IrTypeId, str] = ir_type.intern_int(?types, 32);
    if (R.is_err[ir_type.IrTypeId, str](ir)) { ir_type.dnit(?types); ret 1; }
    val i32ty: ir_type.IrTypeId = R.unwrap_ok[ir_type.IrTypeId, str](ir);

    # a vector routes to the FP bank at its full 16-byte width; value_is_vector true.
    if (reg_class_of(?ctx, ?tgt, vecty) != fp_class_index(?tgt)) { ir_type.dnit(?types); ret 1; }
    if (op_width_of(?ctx, vecty) != 16)                          { ir_type.dnit(?types); ret 1; }
    if (!value_is_vector(?ctx, vecty))                           { ir_type.dnit(?types); ret 1; }

    # a GP scalar keeps the general bank, its own 4-byte width, and is not a vector.
    if (reg_class_of(?ctx, ?tgt, i32ty) != gp_class_index(?tgt)) { ir_type.dnit(?types); ret 1; }
    if (op_width_of(?ctx, i32ty) != 4)                           { ir_type.dnit(?types); ret 1; }
    if (value_is_vector(?ctx, i32ty))                           { ir_type.dnit(?types); ret 1; }

    ir_type.dnit(?types);
    ret 0;
}
