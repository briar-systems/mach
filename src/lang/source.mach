# mach.lang.source: source-file registry mapping `FileId` handles to loaded path + text.
#
# resolves byte offsets to 1-based `(line, column)` positions. used by
# diagnostics for span rendering and by every phase that reports source
# locations. each file carries the `query.Revision` at which its text
# was last set; the `Q_FILE_TEXT` metadata source reads it directly so
# derived queries depending on a file revalidate when it is reloaded.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.option.Option;
use std.types.option.some;
use std.types.option.none;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_dup;
use std.types.string.str_free;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use query: mach.lang.query;

# FileId: stable handle into a SourceMap's file array.
pub def FileId: u32;

# Position: a 1-based line and column within a source file.
# ---
# line: line number, 1-based
# col:  column number, 1-based
pub rec Position {
    line: usize;
    col:  usize;
}

# SourceFile: a loaded source file with a precomputed newline index.
# ---
# path:        owned file path as known to the loader
# text:        owned source text; text.data[text.len] is 0 for FFI-friendliness
# line_starts: byte offset of the start of each line
# line_len:    number of entries in line_starts
# revision:    QueryDb revision at which this file's text was last set; the Q_FILE_TEXT metadata source reads this directly during dep revalidation
pub rec SourceFile {
    path:        str;
    text:        str;
    line_starts: *usize;
    line_len:    usize;
    revision:    query.Revision;
}

# SourceMap: registry of loaded source files indexed by FileId.
# ---
# alloc: allocator used for all owned storage in this map
# files: contiguous array of SourceFile records
# len:   number of files currently stored
# cap:   allocated slots in files
pub rec SourceMap {
    alloc: *Allocator;
    files: *SourceFile;
    len:   usize;
    cap:   usize;
}

val INITIAL_MAP_CAP: usize = 8;

# init: construct an empty source map backed by the given allocator.
# ---
# alloc: allocator used for path, text, line index, and file array storage
# ret:   a new empty SourceMap
pub fun init(alloc: *Allocator) SourceMap {
    var m: SourceMap;
    m.alloc = alloc;
    m.files = nil;
    m.len   = 0;
    m.cap   = 0;
    ret m;
}

# dnit: release every loaded file and clear the map.
# ---
# m: the map to tear down; all fields are zeroed
pub fun dnit(m: *SourceMap) {
    if (m == nil) { ret; }

    var i: usize = 0;
    for (i < m.len) {
        val file: *SourceFile = ?m.files[i];
        str_free(m.alloc, file.path);
        str_free(m.alloc, file.text);
        if (file.line_starts != nil && file.line_len > 0) {
            deallocate[usize](m.alloc, file.line_starts, file.line_len);
        }
        i = i + 1;
    }

    if (m.files != nil && m.cap > 0) {
        deallocate[SourceFile](m.alloc, m.files, m.cap);
    }
    m.files = nil;
    m.len   = 0;
    m.cap   = 0;
}

# add: register a source file, copying its path and text into the map's allocator.
# ---
# m:    the source map
# db:   query database whose revision is bumped so derived entries depending on this file invalidate
# path: file path to associate with this file
# text: source text to index and store; the stored copy is null-terminated
# ret:  FileId of the newly added file, or an allocation error
pub fun add(m: *SourceMap, db: *query.QueryDb, path: str, text: str) Result[FileId, str] {
    val text_len: usize = text.len::usize;

    var line_len: usize = 1;
    var i: usize = 0;
    for (i < text_len) {
        if (text.data[i] == '\n') { line_len = line_len + 1; }
        i = i + 1;
    }

    val r_starts: Result[*usize, str] = allocate[usize](m.alloc, line_len);
    if (is_err[*usize, str](r_starts)) {
        ret err[FileId, str](unwrap_err[*usize, str](r_starts));
    }
    val starts: *usize = unwrap_ok[*usize, str](r_starts);

    starts[0] = 0;
    var idx: usize = 1;
    i = 0;
    for (i < text_len) {
        if (text.data[i] == '\n') {
            starts[idx] = i + 1;
            idx = idx + 1;
        }
        i = i + 1;
    }

    val r_path: Result[str, str] = str_dup(m.alloc, path);
    if (is_err[str, str](r_path)) {
        deallocate[usize](m.alloc, starts, line_len);
        ret err[FileId, str](unwrap_err[str, str](r_path));
    }
    val path_copy: str = unwrap_ok[str, str](r_path);

    val r_text: Result[str, str] = str_dup(m.alloc, text);
    if (is_err[str, str](r_text)) {
        str_free(m.alloc, path_copy);
        deallocate[usize](m.alloc, starts, line_len);
        ret err[FileId, str](unwrap_err[str, str](r_text));
    }
    val text_copy: str = unwrap_ok[str, str](r_text);

    if (m.files == nil) {
        val r: Result[*SourceFile, str] = allocate[SourceFile](m.alloc, INITIAL_MAP_CAP);
        if (is_err[*SourceFile, str](r)) {
            str_free(m.alloc, text_copy);
            str_free(m.alloc, path_copy);
            deallocate[usize](m.alloc, starts, line_len);
            ret err[FileId, str](unwrap_err[*SourceFile, str](r));
        }
        m.files = unwrap_ok[*SourceFile, str](r);
        m.cap   = INITIAL_MAP_CAP;
    }
    or (m.len == m.cap) {
        val new_cap: usize = m.cap * 2;
        val r: Result[*SourceFile, str] = reallocate[SourceFile](m.alloc, m.files, m.cap, new_cap);
        if (is_err[*SourceFile, str](r)) {
            str_free(m.alloc, text_copy);
            str_free(m.alloc, path_copy);
            deallocate[usize](m.alloc, starts, line_len);
            ret err[FileId, str](unwrap_err[*SourceFile, str](r));
        }
        m.files = unwrap_ok[*SourceFile, str](r);
        m.cap   = new_cap;
    }

    val new_rev: query.Revision = db.revision + 1;
    db.revision = new_rev;

    var file: SourceFile;
    file.path        = path_copy;
    file.text        = text_copy;
    file.line_starts = starts;
    file.line_len    = line_len;
    file.revision    = new_rev;

    val id: FileId = m.len::u32;
    m.files[m.len] = file;
    m.len = m.len + 1;

    ret ok[FileId, str](id);
}

# update: replace the text of an already-registered file, rebuilding its
# newline index and bumping the QueryDb revision so derived entries
# depending on the file invalidate. used for editor/LSP reloads.
# ---
# m:    the source map
# db:   query database whose revision is bumped on a successful update
# id:   identifier of the file to replace
# text: new source text to index and store; the stored copy is null-terminated
# ret:  true on success, or an allocation error; out-of-range id returns false
pub fun update(m: *SourceMap, db: *query.QueryDb, id: FileId, text: str) Result[bool, str] {
    if (id::usize >= m.len) { ret ok[bool, str](false); }

    val text_len: usize = text.len::usize;

    var line_len: usize = 1;
    var i: usize = 0;
    for (i < text_len) {
        if (text.data[i] == '\n') { line_len = line_len + 1; }
        i = i + 1;
    }

    val r_starts: Result[*usize, str] = allocate[usize](m.alloc, line_len);
    if (is_err[*usize, str](r_starts)) {
        ret err[bool, str](unwrap_err[*usize, str](r_starts));
    }
    val starts: *usize = unwrap_ok[*usize, str](r_starts);

    starts[0] = 0;
    var idx: usize = 1;
    i = 0;
    for (i < text_len) {
        if (text.data[i] == '\n') {
            starts[idx] = i + 1;
            idx = idx + 1;
        }
        i = i + 1;
    }

    val r_text: Result[str, str] = str_dup(m.alloc, text);
    if (is_err[str, str](r_text)) {
        deallocate[usize](m.alloc, starts, line_len);
        ret err[bool, str](unwrap_err[str, str](r_text));
    }
    val text_copy: str = unwrap_ok[str, str](r_text);

    val file: *SourceFile = ?m.files[id];
    str_free(m.alloc, file.text);
    if (file.line_starts != nil && file.line_len > 0) {
        deallocate[usize](m.alloc, file.line_starts, file.line_len);
    }

    val new_rev: query.Revision = db.revision + 1;
    db.revision = new_rev;

    file.text        = text_copy;
    file.line_starts = starts;
    file.line_len    = line_len;
    file.revision    = new_rev;

    ret ok[bool, str](true);
}

# get: return a pointer to the SourceFile for a given FileId.
# ---
# m:   the source map
# id:  identifier of the file to look up
# ret: some(*SourceFile) into the map's files array (invalidated by a later add() that grows the array), or none when id is out of range
pub fun get(m: *SourceMap, id: FileId) Option[*SourceFile] {
    if (id::usize >= m.len) { ret none[*SourceFile](); }
    ret some[*SourceFile](?m.files[id]);
}

# position: convert a byte offset in a file to a 1-based Position.
# ---
# file:   the source file being queried
# offset: byte offset into file.text
# ret:    a 1-based (line, col) Position
pub fun position(file: *SourceFile, offset: usize) Position {
    var lo: usize = 0;
    var hi: usize = file.line_len;
    for (lo < hi) {
        val mid: usize = lo + (hi - lo) / 2;
        if (file.line_starts[mid] <= offset) {
            lo = mid + 1;
        } or {
            hi = mid;
        }
    }

    var p: Position;
    p.line = lo;
    p.col  = offset - file.line_starts[lo - 1] + 1;
    ret p;
}

# line_start: return the byte offset where a 1-based line begins, or none
# when line is outside [1, line_len].
# ---
# file: the source file being queried
# line: 1-based line number
# ret:  some(offset) for a valid line, none otherwise
pub fun line_start(file: *SourceFile, line: usize) Option[usize] {
    if (line == 0 || line > file.line_len) { ret none[usize](); }
    ret some[usize](file.line_starts[line - 1]);
}
