# source-file registry mapping FileId handles to loaded path and text
#
# Resolves byte offsets to 1-based (line, column) positions, used by diagnostics
# for span rendering and by every phase that reports a source location. Each file
# carries the query.Revision at which its text was last set; an identical-text
# reload is an early cutoff that leaves the revision in place, mirroring the
# Q_FILE_TEXT query input that load_source also maintains, so derived queries
# depending on a file revalidate only on a real edit.

use std.allocator.page;
use std.collections.map;
use std.text.string.str_dup;
use std.text.string.str_free;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.intern;
use mach.lang.query;

# stable handle into a SourceMap's file array
pub def FileId: u32;

# sentinel FileId naming no source file, carried by a synthesized or as-yet-unset
# location. it is 0, and the SourceMap assigns real FileIds from 1, so zero-initialized
# memory (a SrcLoc left `{0, 0}`) reads as loc_nil BY CONSTRUCTION -- a synthesized
# instruction that forgets to stamp a location can never masquerade as file 0 / line 1
pub val FILE_NIL: FileId = 0;

# a source location: a file handle plus a byte offset into that file's text
#
# The offset resolves to a 1-based line/column via `position` on the named file.
# A loc whose file is FILE_NIL has no source origin (compiler-synthesized IR).
# ---
# file:   owning source file, or FILE_NIL when unknown
# offset: byte offset into the file's text
pub rec SrcLoc {
    file:   FileId;
    offset: usize;
}

# construct a source location from a file handle and a byte offset
# ---
# file:   the owning source file
# offset: byte offset into the file's text
# ret:    the SrcLoc
pub fun loc(file: FileId, offset: usize) SrcLoc {
    var l: SrcLoc;
    l.file   = file;
    l.offset = offset;
    ret l;
}

# the empty source location, naming no file
# ---
# ret: a SrcLoc whose file is FILE_NIL
pub fun loc_nil() SrcLoc {
    ret loc(FILE_NIL, 0);
}

# whether a location names a real source file (not FILE_NIL)
# ---
# l:   the location to test
# ret: true when l.file is not FILE_NIL
pub fun loc_is_valid(l: SrcLoc) bool {
    ret l.file != FILE_NIL;
}

# a 1-based line and column within a source file
# ---
# line: line number, 1-based
# col:  column number, 1-based
pub rec Position {
    line: usize;
    col:  usize;
}

# the byte range of a single source line, trailing newline excluded
# ---
# start: byte offset where the line begins
# end:   byte offset just past the last non-newline byte of the line
pub rec LineSpan {
    start: usize;
    end:   usize;
}

# a loaded source file with a precomputed newline index
# ---
# path:        owned file path as known to the loader
# text:        owned source text; text[str_len(text)] is 0 for FFI-friendliness
# line_starts: byte offset of the start of each line
# line_len:    number of entries in line_starts
# revision:    QueryDb revision at which this file's text was last set, advanced
#              only when the text actually changes (an identical-text reload is an
#              early cutoff that leaves it in place)
pub rec SourceFile {
    path:        str;
    text:        str;
    line_starts: *usize;
    line_len:    usize;
    revision:    query.Revision;
}

# registry of loaded source files indexed by FileId
# ---
# a:       allocator used for all owned storage in this map
# files:   contiguous array of SourceFile records
# len:     number of files currently stored
# cap:     allocated slots in files
# by_path: interned path StrId -> FileId index, maintained by load so a path
#          re-loaded in a long-lived session reuses its FileId instead of appending
pub rec SourceMap {
    a:       *A.Allocator;
    files:   *SourceFile;
    len:     usize;
    cap:     usize;
    by_path: map.Map[intern.StrId, FileId];
}

# initial capacity of the file array on its first growth
val INITIAL_FILE_CAP: usize = 8;

# construct an empty source map backed by the given allocator
# ---
# a:   allocator used for path, text, line index, and file array storage
# ret: a new empty SourceMap
pub fun init(a: *A.Allocator) SourceMap {
    var m: SourceMap;
    m.a       = a;
    m.files   = nil;
    m.len     = 0;
    m.cap     = 0;
    m.by_path = map.init[intern.StrId, FileId](a, map.hash_u32, map.eq_u32);
    ret m;
}

# release every loaded file and clear the map
# ---
# m: the map to tear down; all fields are zeroed
pub fun dnit(m: *SourceMap) {
    if (m == nil) { ret; }

    # slot 0 is the FILE_NIL sentinel (reserved by add, never populated); real files
    # occupy 1..len, so free from index 1.
    var i: usize = 1;
    for (i < m.len) {
        val file: *SourceFile = ?m.files[i];
        str_free(m.a, file.path);
        str_free(m.a, file.text);
        line_index_free(m.a, file.line_starts, file.line_len);
        i = i + 1;
    }

    if (m.files != nil && m.cap > 0) {
        A.deallocate[SourceFile](m.a, m.files, m.cap);
    }
    map.dnit[intern.StrId, FileId](?m.by_path);

    m.files = nil;
    m.len   = 0;
    m.cap   = 0;
}

# register a source file, copying its path and text into the map's allocator
# ---
# m:    the source map
# db:   query database whose revision is bumped so derived entries depending on
#       this file invalidate
# path: file path to associate with this file
# text: source text to index and store; the stored copy is null-terminated
# ret:  FileId of the newly added file, or an allocation error
pub fun add(m: *SourceMap, db: *query.QueryDb, path: str, text: str) R.Result[FileId, str] {
    # reserve FileId 0 as the FILE_NIL sentinel so real ids start at 1 (see FILE_NIL).
    # slot 0 is never read (get rejects it) or freed (dnit skips it).
    if (m.len == 0) {
        val res_sentinel: R.Result[bool, str] = files_reserve(m);
        if (R.is_err[bool, str](res_sentinel)) { ret R.err[FileId, str](R.unwrap_err[bool, str](res_sentinel)); }
        m.len = 1;
    }
    var line_len: usize = 0;
    val res_starts: R.Result[*usize, str] = line_index_build(m.a, text, ?line_len);
    if (R.is_err[*usize, str](res_starts)) {
        ret R.err[FileId, str](R.unwrap_err[*usize, str](res_starts));
    }
    val starts: *usize = R.unwrap_ok[*usize, str](res_starts);

    val res_path: R.Result[str, str] = str_dup(m.a, path);
    if (R.is_err[str, str](res_path)) {
        line_index_free(m.a, starts, line_len);
        ret R.err[FileId, str](R.unwrap_err[str, str](res_path));
    }
    val path_copy: str = R.unwrap_ok[str, str](res_path);

    val res_text: R.Result[str, str] = str_dup(m.a, text);
    if (R.is_err[str, str](res_text)) {
        str_free(m.a, path_copy);
        line_index_free(m.a, starts, line_len);
        ret R.err[FileId, str](R.unwrap_err[str, str](res_text));
    }
    val text_copy: str = R.unwrap_ok[str, str](res_text);

    val res_reserve: R.Result[bool, str] = files_reserve(m);
    if (R.is_err[bool, str](res_reserve)) {
        str_free(m.a, text_copy);
        str_free(m.a, path_copy);
        line_index_free(m.a, starts, line_len);
        ret R.err[FileId, str](R.unwrap_err[bool, str](res_reserve));
    }

    val new_rev: query.Revision = db.revision + 1;
    db.revision = new_rev;

    var file: SourceFile;
    file.path        = path_copy;
    file.text        = text_copy;
    file.line_starts = starts;
    file.line_len    = line_len;
    file.revision    = new_rev;

    val id: FileId = m.len::u32;
    m.files[m.len] = file;
    m.len = m.len + 1;

    ret R.ok[FileId, str](id);
}

# replace the text of an already-registered file, rebuilding its newline index
# and bumping the QueryDb revision so derived entries depending on the file
# invalidate; used for editor / LSP reloads
#
# New text byte-for-byte equal to the stored text is an early cutoff: the file's
# text, line index, and revision are left untouched and the revision does NOT
# advance, mirroring query.set_input's equality cutoff, so an unchanged file
# reloaded across rebuilds keeps its revision and its revision-keyed derived
# caches (the session AST cache) hit.
# ---
# m:    the source map
# db:   query database whose revision is bumped on a changing update
# id:   identifier of the file to replace
# text: new source text to index and store; the stored copy is null-terminated
# ret:  true on success (including a no-op identical-text update), false when id
#       is out of range, or an allocation error
pub fun update(m: *SourceMap, db: *query.QueryDb, id: FileId, text: str) R.Result[bool, str] {
    if (id::usize >= m.len) { ret R.ok[bool, str](false); }

    val file: *SourceFile = ?m.files[id];

    # identical text keeps the prior text, line index, and revision (no bump)
    if (str_equals(file.text, text)) { ret R.ok[bool, str](true); }

    var line_len: usize = 0;
    val res_starts: R.Result[*usize, str] = line_index_build(m.a, text, ?line_len);
    if (R.is_err[*usize, str](res_starts)) {
        ret R.err[bool, str](R.unwrap_err[*usize, str](res_starts));
    }
    val starts: *usize = R.unwrap_ok[*usize, str](res_starts);

    val res_text: R.Result[str, str] = str_dup(m.a, text);
    if (R.is_err[str, str](res_text)) {
        line_index_free(m.a, starts, line_len);
        ret R.err[bool, str](R.unwrap_err[str, str](res_text));
    }
    val text_copy: str = R.unwrap_ok[str, str](res_text);

    str_free(m.a, file.text);
    line_index_free(m.a, file.line_starts, file.line_len);

    val new_rev: query.Revision = db.revision + 1;
    db.revision = new_rev;

    file.text        = text_copy;
    file.line_starts = starts;
    file.line_len    = line_len;
    file.revision    = new_rev;

    ret R.ok[bool, str](true);
}

# register a source file deduped by path
#
# A path seen for the first time appends a new file via add; a path already
# known is text-swapped in place via update (id-stable, revision-bumping), so a
# long-lived session (an LSP reloading project graphs on save) does not grow on
# reload. The by_path index is maintained only here; add and update remain raw
# primitives.
# ---
# m:        the source map
# db:       query database whose revision is bumped so derived entries invalidate
# interner: interner the path is interned into for the by_path lookup key
# path:     file path to load
# text:     source text to index and store; the stored copy is null-terminated
# ret:      the FileId the path is registered under (stable across reloads of the
#           same path), or an error
pub fun load(m: *SourceMap, db: *query.QueryDb, interner: *intern.Interner, path: str, text: str) R.Result[FileId, str] {
    val res_pid: R.Result[intern.StrId, str] = intern.intern(interner, path);
    if (R.is_err[intern.StrId, str](res_pid)) {
        ret R.err[FileId, str](R.unwrap_err[intern.StrId, str](res_pid));
    }
    val pid: intern.StrId = R.unwrap_ok[intern.StrId, str](res_pid);

    # known path: swap text in place under its existing FileId
    val res_existing: R.Result[*FileId, str] = map.get[intern.StrId, FileId](?m.by_path, ?pid);
    if (R.is_ok[*FileId, str](res_existing)) {
        val fid: FileId = @R.unwrap_ok[*FileId, str](res_existing);
        val res_update: R.Result[bool, str] = update(m, db, fid, text);
        if (R.is_err[bool, str](res_update)) {
            ret R.err[FileId, str](R.unwrap_err[bool, str](res_update));
        }
        ret R.ok[FileId, str](fid);
    }

    # new path: append a file and record its FileId in the by_path index
    val res_add: R.Result[FileId, str] = add(m, db, path, text);
    if (R.is_err[FileId, str](res_add)) { ret res_add; }
    val fid: FileId = R.unwrap_ok[FileId, str](res_add);

    val res_insert: R.Result[bool, str] = map.insert[intern.StrId, FileId](?m.by_path, pid, fid);
    if (R.is_err[bool, str](res_insert)) {
        ret R.err[FileId, str](R.unwrap_err[bool, str](res_insert));
    }
    ret R.ok[FileId, str](fid);
}

# return a pointer to the SourceFile for a given FileId
# ---
# m:   the source map
# id:  identifier of the file to look up
# ret: some(*SourceFile) into the map's files array (invalidated by a later add
#      that grows the array), or none when id is out of range
pub fun get(m: *SourceMap, id: FileId) O.Option[*SourceFile] {
    if (id == FILE_NIL || id::usize >= m.len) { ret O.none[*SourceFile](); }
    ret O.some[*SourceFile](?m.files[id]);
}

# convert a byte offset in a file to a 1-based Position
# ---
# file:   the source file being queried
# offset: byte offset into file.text
# ret:    a 1-based (line, col) Position
pub fun position(file: *SourceFile, offset: usize) Position {
    var lo: usize = 0;
    var hi: usize = file.line_len;
    for (lo < hi) {
        val mid: usize = lo + (hi - lo) / 2;
        if (file.line_starts[mid] <= offset) {
            lo = mid + 1;
        }
        or {
            hi = mid;
        }
    }

    var p: Position;
    p.line = lo;
    p.col  = offset - file.line_starts[lo - 1] + 1;
    ret p;
}

# return the byte offset where a 1-based line begins, or none when line is
# outside [1, line_len]
# ---
# file: the source file being queried
# line: 1-based line number
# ret:  some(offset) for a valid line, none otherwise
pub fun line_start(file: *SourceFile, line: usize) O.Option[usize] {
    if (line == 0 || line > file.line_len) { ret O.none[usize](); }
    ret O.some[usize](file.line_starts[line - 1]);
}

# return the [start, end) byte range of a 1-based line, with any trailing '\n'
# or '\r' excluded so callers can render the line verbatim
# ---
# file: the source file being queried
# line: 1-based line number
# ret:  some(LineSpan) for a valid line, none when line is outside [1, line_len]
pub fun line_bounds(file: *SourceFile, line: usize) O.Option[LineSpan] {
    if (line == 0 || line > file.line_len) { ret O.none[LineSpan](); }

    val start:    usize = file.line_starts[line - 1];
    val text_len: usize = str_len(file.text);

    var end: usize = text_len;
    if (line < file.line_len) { end = file.line_starts[line]; }

    for (end > start && (file.text[end - 1] == '\n' || file.text[end - 1] == '\r')) {
        end = end - 1;
    }

    var ls: LineSpan;
    ls.start = start;
    ls.end   = end;
    ret O.some[LineSpan](ls);
}

# build a line-start index for `text`: entry k is the byte offset where line
# k+1 begins. line 1 starts at byte 0, and every '\n' opens the next line
# ---
# a:       allocator backing the index array
# text:    source text to scan
# out_len: receives the number of lines (length of the returned array)
# ret:     the owned line-start array, or an allocation error
fun line_index_build(a: *A.Allocator, text: str, out_len: *usize) R.Result[*usize, str] {
    val text_len: usize = str_len(text);

    var line_len: usize = 1;
    var i:        usize = 0;
    for (i < text_len) {
        if (text[i] == '\n') { line_len = line_len + 1; }
        i = i + 1;
    }

    val res_starts: R.Result[*usize, str] = A.allocate[usize](a, line_len);
    if (R.is_err[*usize, str](res_starts)) {
        ret R.err[*usize, str](R.unwrap_err[*usize, str](res_starts));
    }
    val starts: *usize = R.unwrap_ok[*usize, str](res_starts);

    starts[0] = 0;
    var idx: usize = 1;
    i = 0;
    for (i < text_len) {
        if (text[i] == '\n') {
            starts[idx] = i + 1;
            idx = idx + 1;
        }
        i = i + 1;
    }

    @out_len = line_len;
    ret R.ok[*usize, str](starts);
}

# free a line-start index, tolerating the empty (nil / zero-length) case
# ---
# a:      allocator the index was built with
# starts: the line-start array to free
# len:    number of entries in starts
fun line_index_free(a: *A.Allocator, starts: *usize, len: usize) {
    if (starts != nil && len > 0) {
        A.deallocate[usize](a, starts, len);
    }
}

# ensure the file array has room for one more SourceFile, growing it by doubling
# (seeded at INITIAL_FILE_CAP on the first allocation)
# ---
# m:   the source map
# ret: true once a slot is available, or an allocation error
fun files_reserve(m: *SourceMap) R.Result[bool, str] {
    if (m.len < m.cap) { ret R.ok[bool, str](true); }

    var new_cap: usize = m.cap * 2;
    if (new_cap == 0) { new_cap = INITIAL_FILE_CAP; }

    var res_files: R.Result[*SourceFile, str];
    if (m.files == nil) {
        res_files = A.allocate[SourceFile](m.a, new_cap);
    }
    or {
        res_files = A.reallocate[SourceFile](m.a, m.files, m.cap, new_cap);
    }
    if (R.is_err[*SourceFile, str](res_files)) {
        ret R.err[bool, str](R.unwrap_err[*SourceFile, str](res_files));
    }

    m.files = R.unwrap_ok[*SourceFile, str](res_files);
    m.cap   = new_cap;
    ret R.ok[bool, str](true);
}

# load dedups by path: a re-loaded path reuses its FileId and swaps text in
# place without growing the map, while a fresh path appends a distinct FileId
test "mach.lang.source.load:dedup_by_path" {
    var a: A.Allocator;
    page.make(?a);

    val res_db: R.Result[query.QueryDb, str] = query.init(?a);
    if (R.is_err[query.QueryDb, str](res_db)) { ret 1; }
    var db: query.QueryDb   = R.unwrap_ok[query.QueryDb, str](res_db);
    var ix: intern.Interner = intern.init(?a);
    var m:  SourceMap       = init(?a);

    val res1: R.Result[FileId, str] = load(?m, ?db, ?ix, "p1.mach", "a");
    if (R.is_err[FileId, str](res1)) { ret 1; }
    val fid1: FileId = R.unwrap_ok[FileId, str](res1);

    # re-loading the same path returns the same FileId and updates the text
    val res2: R.Result[FileId, str] = load(?m, ?db, ?ix, "p1.mach", "b");
    if (R.is_err[FileId, str](res2)) { ret 1; }
    val fid2: FileId = R.unwrap_ok[FileId, str](res2);

    if (fid1 != fid2)       { ret 1; }
    if (m.by_path.len != 1) { ret 1; }
    # m.len counts the reserved FILE_NIL sentinel (slot 0) plus the one real file.
    if (m.len != 2)         { ret 1; }

    val file1: *SourceFile = ?m.files[fid1::usize];
    if (str_len(file1.text) != 1) { ret 1; }
    if (file1.text[0] != 'b')     { ret 1; }

    # a different path appends a distinct new FileId, growing the map
    val res3: R.Result[FileId, str] = load(?m, ?db, ?ix, "p2.mach", "c");
    if (R.is_err[FileId, str](res3)) { ret 1; }
    val fid3: FileId = R.unwrap_ok[FileId, str](res3);
    if (fid3 == fid1)       { ret 1; }
    if (m.by_path.len != 2) { ret 1; }
    # sentinel slot 0 plus the two distinct real files.
    if (m.len != 3)         { ret 1; }

    dnit(?m);
    intern.dnit(?ix);
    query.dnit(?db);
    ret 0;
}

# update's early cutoff: reloading byte-identical text leaves the file's
# revision in place (so a revision-keyed derived cache hits), while changed
# text advances the revision and is stored
test "mach.lang.source.update:revision_cutoff_on_identical_text" {
    var a: A.Allocator;
    page.make(?a);

    val res_db: R.Result[query.QueryDb, str] = query.init(?a);
    if (R.is_err[query.QueryDb, str](res_db)) { ret 1; }
    var db: query.QueryDb   = R.unwrap_ok[query.QueryDb, str](res_db);
    var ix: intern.Interner = intern.init(?a);
    var m:  SourceMap       = init(?a);

    # first load establishes the file at some revision r0
    val res1: R.Result[FileId, str] = load(?m, ?db, ?ix, "p.mach", "hello\nworld");
    if (R.is_err[FileId, str](res1)) { ret 1; }
    val fid: FileId        = R.unwrap_ok[FileId, str](res1);
    val r0:  query.Revision = (?m.files[fid::usize]).revision;

    # byte-identical reload must not advance the revision
    val res2: R.Result[FileId, str] = load(?m, ?db, ?ix, "p.mach", "hello\nworld");
    if (R.is_err[FileId, str](res2))           { ret 1; }
    if ((?m.files[fid::usize]).revision != r0) { ret 1; }

    # changed text advances the revision and is stored
    val res3: R.Result[FileId, str] = load(?m, ?db, ?ix, "p.mach", "hello\nthere");
    if (R.is_err[FileId, str](res3))           { ret 1; }
    if ((?m.files[fid::usize]).revision == r0) { ret 1; }
    if ((?m.files[fid::usize]).text[6] != 't') { ret 1; }

    dnit(?m);
    intern.dnit(?ix);
    query.dnit(?db);
    ret 0;
}

# a SrcLoc's byte offset round-trips to a 1-based line/column via position, the
# nil location is distinguishable from a real one, and loc preserves its fields
test "mach.lang.source.srcloc:offset_roundtrips_to_line_col" {
    var a: A.Allocator;
    page.make(?a);

    val res_db: R.Result[query.QueryDb, str] = query.init(?a);
    if (R.is_err[query.QueryDb, str](res_db)) { ret 1; }
    var db: query.QueryDb = R.unwrap_ok[query.QueryDb, str](res_db);
    var m:  SourceMap     = init(?a);

    val res_fid: R.Result[FileId, str] = add(?m, ?db, "p.mach", "ab\ncde\nf");
    if (R.is_err[FileId, str](res_fid)) { ret 1; }
    val fid: FileId = R.unwrap_ok[FileId, str](res_fid);

    # a real location names its file and preserves its offset; the nil one does not
    val l: SrcLoc = loc(fid, 4);
    if (!loc_is_valid(l))        { ret 1; }
    if (l.file != fid)           { ret 1; }
    if (l.offset != 4)           { ret 1; }
    if (loc_is_valid(loc_nil())) { ret 1; }

    # offset 4 ('d' on the second line of "ab\ncde\nf") is line 2, column 2
    val file: *SourceFile = ?m.files[fid::usize];
    val p: Position = position(file, l.offset);
    if (p.line != 2) { ret 1; }
    if (p.col != 2)  { ret 1; }

    dnit(?m);
    query.dnit(?db);
    ret 0;
}
