# demand-driven incremental memoization database.
#
# Maps `(QueryKind, key)` pairs to cached byte buffers, records the
# inter-query dependencies that produced each value, and recomputes only the
# entries whose transitive inputs have changed. It lives on the `Session`;
# every phase reaches the compiler's cached artifacts through `get`, never by
# calling another phase directly.
#
# A `QueryKind` selects a per-kind `QueryShard`; the shard's role decides
# whether `get` returns a stored input value, runs a derived `ComputeFn`, or
# rejects the call (metadata kinds carry no value, only an external revision
# source). Validation is revision-based: an entry is valid iff every recorded
# dependency's current `last_changed` still equals the value captured when the
# entry was computed. A recompute that reproduces identical bytes leaves
# `last_changed` untouched (early cutoff), so `last_changed` tracks when an
# entry's bytes actually changed, not when it was last revalidated.

use std.allocator.page;
use std.memory;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;

use A: std.allocator;
use R: std.types.result;

# discriminator identifying a particular query function. one kind maps to
# exactly one pure `key -> value` function and selects the QueryDb's per-kind
# storage shard. stable for the lifetime of a build.
pub def QueryKind: u16;

# the fixed compiler query catalog. each kind's value equals its shard index in
# QueryDb.storage, so the catalog is registered in this exact order: the three
# inputs first (registered by session.init), then the derived pipeline stages in
# pipeline order (each reserved by its owning phase module, which binds the
# compute fn). the driver and CLI set the inputs and request the top derived
# artifact; every other stage is reached transitively through get.

# input: project configuration bytes for the root project
pub val Q_PROJECT_ROOT: QueryKind = 0;
# input: selected target description bytes
pub val Q_TARGET: QueryKind = 1;
# input: per-file source text, keyed on source.FileId.
#
# Set by session.load_source. set_input's byte-equality cutoff is what keeps an
# unchanged file's Q_PARSE entry valid across rebuilds.
pub val Q_FILE_TEXT: QueryKind = 2;
# derived: TokenStream for a file, keyed on source.FileId
pub val Q_TOKENIZE: QueryKind = 3;
# derived: parsed Ast for a file, keyed on source.FileId
pub val Q_PARSE: QueryKind = 4;
# derived: sess.ModuleId for an interned FQN, keyed on intern.StrId
pub val Q_MODULE_ID_FOR_FQN: QueryKind = 5;
# derived: a module's seeded ComptimeCtx, keyed on sess.ModuleId.
#
# Reserved; the driver's load walk currently rebuilds a full, identically-seeded
# comptime ctx every build, so a reused Q_RESOLVE sees a consistent ctx without a
# separate cache (see run_resolve_one / register_val_for_load).
pub val Q_COMPTIME_CTX: QueryKind = 6;
# derived (owned handle): a module's ResolveResult, keyed on sess.StableModuleId
# so an unchanged module's result is reused across rebuilds even when a graph
# reshape renumbers per-build ModuleIds.
#
# Reads Q_PARSE(file), Q_TARGET, and Q_EXPORTS(dep) per import; the result's
# ModuleId-valued fields are remapped into each build's numbering on reuse.
pub val Q_RESOLVE: QueryKind = 7;
# derived: a byte fingerprint of a module's RESOLVED public surface, keyed on
# sess.StableModuleId.
#
# Its OUTPUT early-cutoff is the firewall that stops a private edit from
# cascading to importers: a private-only change re-resolves the module but
# reproduces an identical pub-surface fingerprint, so importers depending on
# Q_EXPORTS stay valid; a change to the visible surface (including a re-exported
# dep's resolved identity) advances it and re-resolves importers (#1581/#1582).
pub val Q_EXPORTS: QueryKind = 8;
# derived (owned handle): a module's SemaResult, keyed on sess.StableModuleId so
# an unchanged module's type-checking is reused across rebuilds.
#
# Reads Q_RESOLVE(module), Q_TARGET, Q_MODULE_NUMBER(module), and
# Q_TYPED_EXPORTS(dep) per import. a reused result's interned TypeIds stay valid
# because the session type interner is monotonic; a graph reshape that renumbers
# a module's ModuleId-embedding type identities re-checks it via Q_MODULE_NUMBER.
pub val Q_SEMA: QueryKind = 9;
# derived (owned handle): a module's optimized ir.Module, keyed on
# sess.StableModuleId in the low 32 bits with the test-mode flag in bit 32, so an
# unchanged module's lowered IR is reused across rebuilds even when a graph reshape
# renumbers per-build ModuleIds. mangled linkage names are FQN-derived, so a cached
# module stays valid across a reshape. the test-mode variant neutralizes the module's
# `main` on its own freshly-lowered IR, so a test build and a normal build of the same
# module cache independently and query-owned IR is never mutated in place (#1858).
#
# Reads Q_SEMA(module), Q_TARGET, Q_LOWER_FLAGS, and Q_SEMA of every module in this
# module's transitive import closure: a generic/comptime instance declared in
# another module is monomorphized into THIS module's IR, so that module's typing
# feeds this lowered output and a change there must re-lower this module (#1618).
pub val Q_LOWER: QueryKind = 10;
# derived (owned handle): a module's of.ObjectImage, keyed on sess.StableModuleId
# packed with the test-mode flag (the same key as Q_LOWER), so an unchanged module's
# codegen output is reused across rebuilds and a test build codegens the neutralized
# variant independently of the normal build (#1858).
#
# Reads Q_LOWER(module) and Q_TARGET. an unchanged lowered IR reuses the cached
# image (and its on-disk `.o`) instead of re-emitting - the per-module
# hash-and-skip that also lets codegen run per module in parallel (#1618).
pub val Q_CODEGEN: QueryKind = 11;
# derived: the project's link fingerprint, keyed on unit (0).
#
# Reads Q_TARGET, Q_LINK_CONFIG, and Q_CODEGEN of every module in the product's
# link set. its value folds each dependency's revision, so the entry's
# last_changed advances iff a link input changed - an object (Q_CODEGEN), the
# target/profile/pie (Q_TARGET), or a link-only input like the output path or an
# external library (Q_LINK_CONFIG). run_link_pass compares this last_changed to
# the prior build's to decide whether the link must re-run (#1618).
pub val Q_LINK: QueryKind = 12;
# derived: a byte fingerprint of a module's TYPED public surface (the resolved
# types of its locally-declared pub symbols plus the field tables of pub
# nominals), keyed on sess.StableModuleId.
#
# The SEMA-level twin of Q_EXPORTS: its OUTPUT early-cutoff is the firewall that
# stops a private edit from re-type-checking importers. An impl-only edit
# (signatures unchanged) reproduces identical bytes, so type-dependents stay
# valid; a pub TYPE change advances it and re-checks the dependents (#1583).
pub val Q_TYPED_EXPORTS: QueryKind = 13;
# input: a module's current per-build discovery-order ModuleId, keyed on
# sess.StableModuleId and set each build by the driver.
#
# Q_SEMA records a dep on its own module's number so a graph reshape that
# renumbers a module (changing the ModuleId embedded in its nominal/instance type
# identities) re-type-checks it rather than reusing a result whose interned
# TypeIds went stale; set_input's early-cutoff leaves it untouched when the number
# is unchanged, so a content-only edit keeps reuse valid (#1583).
pub val Q_MODULE_NUMBER: QueryKind = 14;
# input: the link-only build configuration, keyed on unit (0) and set each build
# by the CLI before the link.
#
# Carries the link inputs that do NOT flow through a module's Q_CODEGEN - the
# output path and product name, the output kind, the pie flag, and the external
# link inputs. static external inputs (`.o` / `.a` baked into the output) are folded
# by path AND by content hash, so a same-path rebuild of a vendored archive
# invalidates; dynamic dependencies (sonames, loaded at run time) are folded by
# identity. Q_LINK depends on it so a change to any of them re-links even when every
# module's object is unchanged; set_input's early-cutoff keeps the link reused when
# the config is byte-identical (#1618).
pub val Q_LINK_CONFIG: QueryKind = 15;
# input: the lowering diagnostic flags, keyed on unit (0) and set each build by the
# driver before the lower pass.
#
# Carries the flags that change what lowering DOES without changing the IR it
# produces - currently the IR-verifier toggle. Q_LOWER depends on it so a warm
# session that cached a module with verification off re-lowers (and re-runs the
# verifier) when a later build requests it on; set_input's early-cutoff keeps the
# lowering reused when the flags are unchanged (#1618).
pub val Q_LOWER_FLAGS: QueryKind = 16;

# monotonic counter owned by the QueryDb, bumped on every set_input. cached
# entries record the revision at which they were computed and the revision at
# which their bytes last changed.
pub def Revision: u64;

# discriminator for a shard's storage and lookup behaviour
pub def ShardRole: u8;

# externally-set source-of-truth value; get returns the cached value
pub val SHARD_INPUT:    ShardRole = 0;
# value computed on demand; get revalidates deps and recomputes if stale
pub val SHARD_DERIVED:  ShardRole = 1;
# no stored value; get is an error. only reached through a Dep, whose revision
# is read from the shard's RevisionFn
pub val SHARD_METADATA: ShardRole = 2;

# the signature every derived query's compute function shares: a pure function
# from `(db, key, allocator)` to a produced byte buffer.
#
# Uniform across all derived kinds, so it is a real typed function pointer with
# no erasure. The function records its inter-query deps via record_dep and
# reaches the compiler's services (sources, interner, diagnostics) through the
# opaque `db.ctx` the owner installs with set_ctx.
pub def ComputeFn: fun(*QueryDb, u64, *A.Allocator) R.Result[QueryOutput, str];

# releases the heavy artifact a derived query's opaque-handle value refers to
# (an AST / resolve graph the handle bytes point at).
#
# Called by the engine just before it frees the handle buffer itself: on a
# recompute that replaces the handle, on invalidate/remove, and in dnit. it must
# not free the handle buffer; the engine does that. Bound by
# register_derived_owned; absent (nil) for plain byte-valued derived kinds.
pub def FinalizeFn: fun(*u8, u32, *A.Allocator);

# the signature every metadata source's revision-lookup shares: maps a key to
# that source's current revision. invoked by the validator when a Dep names a
# metadata kind.
pub def RevisionFn: fun(u64) Revision;

# the diagnostics-as-query-output hooks (#1586). a derived compute emits
# diagnostics as a side effect onto the owner's sink; a reused `get` must replay
# them so a warm session surfaces the same diagnostics a cold compute would. the
# engine stays diagnostic-agnostic - the owner installs these through
# set_diag_hooks, and the engine calls them only around a top-level compute or
# reuse. all four nil leaves the engine capturing nothing.
#
# mark reads the sink's current length before a compute; capture snapshots
# everything appended since that mark into an owned opaque handle stored on the
# entry (nil when nothing was appended or on allocation failure - diagnostics are
# advisory, so a failed capture degrades to no replay rather than aborting the
# build); replay re-emits a handle's diagnostics into the sink on a reused get;
# free releases a handle. the ctx passed to mark/capture/replay is db.ctx.
pub def DiagMarkFn:    fun(ptr) u64;
pub def DiagCaptureFn: fun(ptr, u64, *A.Allocator) ptr;
pub def DiagReplayFn:  fun(ptr, ptr);
pub def DiagFreeFn:    fun(ptr, *A.Allocator);

# bytes produced by a derived ComputeFn; ownership transfers into the cache entry
# on a successful compute
# ---
# bytes: heap-allocated value buffer allocated with the compute allocator
# len:   number of valid bytes
pub rec QueryOutput {
    bytes: *u8;
    len:   u32;
}

# one recorded dependency of a cached entry
#
# The validator compares last_changed against the dep entry's current
# last_changed; equality means the dep is unchanged.
# ---
# kind:         the dependency's kind
# key:          the dependency's hashed key
# last_changed: the dep's last_changed at the time the owning entry was computed
pub rec Dep {
    kind:         QueryKind;
    key:          u64;
    last_changed: Revision;
}

# one cached `(key, value)` plus the metadata needed to validate it
# ---
# key:          hashed key; the kind-key-type -> u64 mapping is the registrar's responsibility
# value:        owned opaque value buffer (layout is the registered query's responsibility)
# value_len:    length of value in bytes
# last_changed: revision at which value's bytes last actually changed
# deps:         queries read while computing value
# dep_len:      number of entries in deps
# dep_cap:      allocated slots in deps
# diags:        owned opaque handle to the diagnostics this entry's compute emitted,
#               replayed on a reused get and freed through the owner's DiagFreeFn;
#               nil when the compute emitted none or no diag hooks are installed
pub rec QueryEntry {
    key:          u64;
    value:        *u8;
    value_len:    u32;
    last_changed: Revision;
    deps:         *Dep;
    dep_len:      u32;
    dep_cap:      u32;
    diags:        ptr;
}

# per-kind storage; the kind equals the shard's index in QueryDb.storage
#
# Entries are scanned by key (linear); inputs and derived kinds populate
# entries, metadata kinds never do.
# ---
# kind:       self-identifying kind; equals this shard's storage index
# role:       input / derived / metadata discriminator
# compute:    compute function for derived kinds; nil otherwise
# revisions:  revision-lookup function for metadata kinds; nil otherwise
# finalize:   releases the heavy artifact behind an opaque-handle value
#             (register_derived_owned); nil for plain byte-valued kinds. a
#             non-nil finalize also marks the shard as never early-cutting: its
#             handle differs every compute, so the value always replaces and the
#             old handle is finalized
# registered: whether a register_* call has claimed this shard
# entries:    cached entries keyed by QueryEntry.key
# len:        number of entries
# cap:        allocated capacity in entries
pub rec QueryShard {
    kind:       QueryKind;
    role:       ShardRole;
    compute:    ComputeFn;
    revisions:  RevisionFn;
    finalize:   FinalizeFn;
    registered: bool;
    entries:    *QueryEntry;
    len:        u32;
    cap:        u32;
}

# the full query database; owns one shard per registered kind, indexed by kind
# value, plus a monotonic revision counter
# ---
# a:        backing allocator for shard storage and per-entry buffers
# revision: current revision; bumped by set_input
# storage:  shard array indexed by kind
# kinds:    number of shard slots allocated (length of storage)
# ctx:      opaque context handle a derived ComputeFn casts back to reach the
#           compiler's services (e.g. the Session); installed by set_ctx, nil
#           until then
# diag_mark:    diagnostics-as-query-output hook: reads the sink length before a
#               compute (#1586); nil until set_diag_hooks, which disables capture
# diag_capture: hook that snapshots a compute's emitted diagnostics; nil until set
# diag_replay:  hook that replays a snapshot on a reused get; nil until set
# diag_free:    hook that releases a captured snapshot handle; nil until set
# compute_depth: number of derived computes currently on the stack. reuse replays
#           an entry's cached diagnostics only at depth 0 (a top-level get), so a
#           nested reuse reached from inside another compute does not double-emit
#           diagnostics the driver already surfaced by driving that phase directly
pub rec QueryDb {
    a:            *A.Allocator;
    revision:     Revision;
    storage:      *QueryShard;
    kinds:        u32;
    ctx:          ptr;
    diag_mark:    DiagMarkFn;
    diag_capture: DiagCaptureFn;
    diag_replay:  DiagReplayFn;
    diag_free:    DiagFreeFn;
    compute_depth: u32;
}

# initial capacities for a shard's entries array and an entry's deps array
val INITIAL_ENTRY_CAP: u32 = 8;
val INITIAL_DEP_CAP:   u32 = 4;

# construct an empty database
#
# The shard array grows lazily as kinds register; revision starts at 0.
# ---
# a:   allocator used for shard storage and every entry's value/deps buffer
# ret: a new empty QueryDb, or an allocation error
pub fun init(a: *A.Allocator) R.Result[QueryDb, str] {
    var db: QueryDb;
    db.a             = a;
    db.revision      = 0;
    db.storage       = nil;
    db.kinds         = 0;
    db.ctx           = nil;
    db.diag_mark     = nil::DiagMarkFn;
    db.diag_capture  = nil::DiagCaptureFn;
    db.diag_replay   = nil::DiagReplayFn;
    db.diag_free     = nil::DiagFreeFn;
    db.compute_depth = 0;
    ret R.ok[QueryDb, str](db);
}

# release every shard, every entry, and every entry's value and deps buffers
#
# nil is a no-op.
# ---
# db: the database to tear down; storage and counters are zeroed
pub fun dnit(db: *QueryDb) {
    if (db == nil) { ret; }

    if (db.storage != nil && db.kinds > 0) {
        var i: u32 = 0;
        for (i < db.kinds) {
            shard_entries_free(db, ?db.storage[i]);
            i = i + 1;
        }
        A.deallocate[QueryShard](db.a, db.storage, db.kinds::usize);
    }

    db.storage  = nil;
    db.kinds    = 0;
    db.revision = 0;
}

# reserve shard `kind` as an input query
#
# set_input calls with this kind are then accepted, and get returns the stored
# value directly.
# ---
# db:   the database
# kind: kind value to claim as an input shard
# ret:  true on success, or an allocation error from growing the shard array
pub fun register_input(db: *QueryDb, kind: QueryKind) R.Result[bool, str] {
    ret register(db, kind, SHARD_INPUT, nil::ComputeFn, nil::RevisionFn);
}

# reserve shard `kind` as a derived query and bind its compute function
# ---
# db:      the database
# kind:    kind value to claim as a derived shard
# compute: the pure ComputeFn invoked by get when the entry is stale or absent
# ret:     true on success, or an allocation error from growing the shard array
pub fun register_derived(db: *QueryDb, kind: QueryKind, compute: ComputeFn) R.Result[bool, str] {
    ret register(db, kind, SHARD_DERIVED, compute, nil::RevisionFn);
}

# reserve shard `kind` as a derived query whose value is an opaque handle onto a
# heavy heap artifact (a parsed AST, a resolve graph) rather than the artifact's
# own bytes
#
# The engine owns the artifact through `finalize`, which it calls before freeing
# each handle, and never applies output early-cutoff to the shard: the handle
# differs every compute and the artifact propagates to consumers purely by input
# change. This is the convention for pointer-graph artifacts in the byte-buffer
# DB; early cutoff lives only at fingerprint queries (Q_EXPORTS).
# ---
# db:       the database
# kind:     kind value to claim as a derived shard
# compute:  the ComputeFn that produces the handle (and owns the artifact it points at)
# finalize: releases the artifact a handle refers to; invoked by the engine on every free
# ret:      true on success, or an allocation error from growing the shard array
pub fun register_derived_owned(db: *QueryDb, kind: QueryKind, compute: ComputeFn, finalize: FinalizeFn) R.Result[bool, str] {
    val res_register: R.Result[bool, str] = register(db, kind, SHARD_DERIVED, compute, nil::RevisionFn);
    if (R.is_err[bool, str](res_register)) { ret res_register; }

    val sh: *QueryShard = ?db.storage[kind::u32];
    sh.finalize = finalize;
    ret R.ok[bool, str](true);
}

# reserve shard `kind` as a metadata source
#
# No value is stored; `lookup` is the external owner's revision function, invoked
# by the validator when a dependent's Dep names this kind. get on a metadata kind
# is an error.
# ---
# db:     the database
# kind:   kind value to claim as a metadata shard
# lookup: the RevisionFn that maps a key to its current revision
# ret:    true on success, or an allocation error from growing the shard array
pub fun register_metadata(db: *QueryDb, kind: QueryKind, lookup: RevisionFn) R.Result[bool, str] {
    ret register(db, kind, SHARD_METADATA, nil::ComputeFn, lookup);
}

# install the opaque context handle derived compute functions read back through
# `db.ctx` to reach the compiler's services
#
# The owner calls this once the context (e.g. the Session) sits at its final
# address.
# ---
# db:  the database
# ctx: opaque handle stored verbatim and never dereferenced by the engine
pub fun set_ctx(db: *QueryDb, ctx: ptr) {
    db.ctx = ctx;
}

# install the diagnostics-as-query-output hooks the engine uses to capture the
# diagnostics a derived compute emits and replay them on a reused get (#1586)
#
# The owner (which knows about its diagnostic sink) installs all four together;
# passing nil for any disables capture/replay entirely. Idempotent across
# rebuilds - the owner re-installs each build, as it does set_ctx.
# ---
# db:      the database
# mark:    reads the sink's current length before a compute
# capture: snapshots the diagnostics appended since a mark into an owned handle
# replay:  re-emits a captured handle's diagnostics into the sink
# free:    releases a captured handle
pub fun set_diag_hooks(db: *QueryDb, mark: DiagMarkFn, capture: DiagCaptureFn, replay: DiagReplayFn, free: DiagFreeFn) {
    db.diag_mark    = mark;
    db.diag_capture = capture;
    db.diag_replay  = replay;
    db.diag_free    = free;
}

# whether shard `kind` has been claimed by a register_* call
#
# Lets an owner lazily register a derived kind exactly once across rebuilds.
# ---
# db:   the database
# kind: kind value to test
# ret:  true when the shard is in range and registered
pub fun is_registered(db: *QueryDb, kind: QueryKind) bool {
    if (kind::u32 >= db.kinds) { ret false; }
    ret (?db.storage[kind::u32]).registered;
}

# store a value under an input shard
#
# Bumps the database revision; if the new bytes differ from the existing entry's
# value, the entry's last_changed is set to the new revision (otherwise the entry
# is left untouched).
# ---
# db:        the database
# kind:      an input kind previously claimed by register_input
# key:       hashed key for this input
# value:     pointer to the value bytes to store (copied into an owned buffer)
# value_len: number of bytes in value
# ret:       true on success, or an error if kind is not an input shard / on alloc failure
pub fun set_input(db: *QueryDb, kind: QueryKind, key: u64, value: *u8, value_len: u32) R.Result[bool, str] {
    val res_shard: R.Result[*QueryShard, str] = shard_get(db, kind);
    if (R.is_err[*QueryShard, str](res_shard)) {
        ret R.err[bool, str](R.unwrap_err[*QueryShard, str](res_shard));
    }
    val sh: *QueryShard = R.unwrap_ok[*QueryShard, str](res_shard);

    if (sh.role != SHARD_INPUT) {
        ret R.err[bool, str]("set_input: kind is not an input query");
    }

    db.revision = db.revision + 1;

    val existing: *QueryEntry = entry_find(sh, key);
    if (existing != nil) {
        val same: bool = existing.value_len == value_len
            && memory.raw_equal(existing.value::ptr, value::ptr, value_len::usize);
        # identical bytes are an early cutoff: keep the existing buffer and leave
        # last_changed in place, so a dependent sees no change.
        if (same) { ret R.ok[bool, str](true); }

        val res_copy: R.Result[*u8, str] = bytes_dup(db.a, value, value_len);
        if (R.is_err[*u8, str](res_copy)) {
            ret R.err[bool, str](R.unwrap_err[*u8, str](res_copy));
        }
        if (existing.value != nil && existing.value_len > 0) {
            A.deallocate[u8](db.a, existing.value, existing.value_len::usize);
        }
        existing.value        = R.unwrap_ok[*u8, str](res_copy);
        existing.value_len    = value_len;
        existing.last_changed = db.revision;
        ret R.ok[bool, str](true);
    }

    val res_copy: R.Result[*u8, str] = bytes_dup(db.a, value, value_len);
    if (R.is_err[*u8, str](res_copy)) {
        ret R.err[bool, str](R.unwrap_err[*u8, str](res_copy));
    }

    val res_entry: R.Result[*QueryEntry, str] = entry_append(db, sh, key);
    if (R.is_err[*QueryEntry, str](res_entry)) {
        val buf: *u8 = R.unwrap_ok[*u8, str](res_copy);
        if (buf != nil && value_len > 0) { A.deallocate[u8](db.a, buf, value_len::usize); }
        ret R.err[bool, str](R.unwrap_err[*QueryEntry, str](res_entry));
    }
    val entry: *QueryEntry = R.unwrap_ok[*QueryEntry, str](res_entry);
    entry.value        = R.unwrap_ok[*u8, str](res_copy);
    entry.value_len    = value_len;
    entry.last_changed = db.revision;
    ret R.ok[bool, str](true);
}

# drop the cached entry for `(kind, key)` regardless of validity
#
# Used to force a derived query's recompute (e.g. exercising the compute path in
# a test). a no-op when no such entry exists.
# ---
# db:   the database
# kind: the entry's kind
# key:  the entry's hashed key
# ret:  true on success, or an error when kind is out of range
pub fun invalidate(db: *QueryDb, kind: QueryKind, key: u64) R.Result[bool, str] {
    val res_shard: R.Result[*QueryShard, str] = shard_get(db, kind);
    if (R.is_err[*QueryShard, str](res_shard)) {
        ret R.err[bool, str](R.unwrap_err[*QueryShard, str](res_shard));
    }

    entry_remove(db, R.unwrap_ok[*QueryShard, str](res_shard), key);
    ret R.ok[bool, str](true);
}

# the single public lookup: return the cached entry for `(kind, key)`
#
# Revalidates dependencies recursively and recomputes through the derived shard's
# compute function when the entry is stale or absent. get on a metadata kind is
# an error; get on an input kind with no stored value is an error.
# ---
# db:   the database
# kind: the queried kind
# key:  the hashed key
# ret:  a pointer to the (fresh-or-current) QueryEntry, or an error
pub fun get(db: *QueryDb, kind: QueryKind, key: u64) R.Result[*QueryEntry, str] {
    val res_shard: R.Result[*QueryShard, str] = shard_get(db, kind);
    if (R.is_err[*QueryShard, str](res_shard)) {
        ret R.err[*QueryEntry, str](R.unwrap_err[*QueryShard, str](res_shard));
    }
    val sh: *QueryShard = R.unwrap_ok[*QueryShard, str](res_shard);

    if (sh.role == SHARD_METADATA) {
        ret R.err[*QueryEntry, str]("get: metadata kinds have no stored value");
    }

    if (sh.role == SHARD_INPUT) {
        val entry: *QueryEntry = entry_find(sh, key);
        if (entry == nil) {
            ret R.err[*QueryEntry, str]("get: input query has no value for key");
        }
        ret R.ok[*QueryEntry, str](entry);
    }

    val existing: *QueryEntry = entry_find(sh, key);
    if (existing != nil) {
        if (is_entry_valid(db, existing)) {
            # reuse: the compute did not run, so replay its cached diagnostics into
            # the sink. only at depth 0 (a top-level get) - a nested reuse reached
            # from inside another compute is one the driver drives directly at depth
            # 0 too, so replaying here as well would double-emit (#1586).
            if (db.compute_depth == 0 && existing.diags != nil && db.diag_replay != nil::DiagReplayFn) {
                db.diag_replay(db.ctx, existing.diags);
            }
            ret R.ok[*QueryEntry, str](existing);
        }
        ret recompute(db, sh, existing, key);
    }

    val res_entry: R.Result[*QueryEntry, str] = entry_append(db, sh, key);
    if (R.is_err[*QueryEntry, str](res_entry)) { ret res_entry; }
    ret recompute(db, sh, R.unwrap_ok[*QueryEntry, str](res_entry), key);
}

# record that the entry currently being computed for `(owner_kind, owner_key)`
# read `(dep_kind, dep_key)`
#
# Appends a Dep capturing the dep's current last_changed. Invoked by a ComputeFn
# (through get) to wire the dependency graph; the owner entry always exists,
# because get creates it before calling compute.
# ---
# db:         the database
# owner_kind: kind of the entry being computed
# owner_key:  key of the entry being computed
# dep_kind:   kind that was read
# dep_key:    key that was read
# ret:        true on success, or an allocation error from growing the dep list
pub fun record_dep(db: *QueryDb, owner_kind: QueryKind, owner_key: u64, dep_kind: QueryKind, dep_key: u64) R.Result[bool, str] {
    val r: R.Result[Revision, str] = record_dep_rev(db, owner_kind, owner_key, dep_kind, dep_key);
    if (R.is_err[Revision, str](r)) { ret R.err[bool, str](R.unwrap_err[Revision, str](r)); }
    ret R.ok[bool, str](true);
}

# record_dep, returning the dep's captured last_changed revision
#
# Same as record_dep, but hands back the revision it looked up for the dep, so a
# ComputeFn that also folds that revision into its own value (Q_LINK) avoids a
# second shard scan via peek_revision.
# ---
# ret: the dep's captured last_changed revision, or an allocation error
pub fun record_dep_rev(db: *QueryDb, owner_kind: QueryKind, owner_key: u64, dep_kind: QueryKind, dep_key: u64) R.Result[Revision, str] {
    if (owner_kind::u32 >= db.kinds) {
        ret R.err[Revision, str]("record_dep: owner kind out of range");
    }
    val sh: *QueryShard = ?db.storage[owner_kind::u32];
    val entry: *QueryEntry = entry_find(sh, owner_key);
    if (entry == nil) {
        ret R.err[Revision, str]("record_dep: owner entry not found");
    }

    val res_reserve: R.Result[bool, str] = deps_reserve(db, entry, 1);
    if (R.is_err[bool, str](res_reserve)) { ret R.err[Revision, str](R.unwrap_err[bool, str](res_reserve)); }

    val rev: Revision = last_changed_get(db, dep_kind, dep_key);
    val dep: *Dep = ?entry.deps[entry.dep_len];
    dep.kind         = dep_kind;
    dep.key          = dep_key;
    dep.last_changed = rev;
    entry.dep_len = entry.dep_len + 1;
    ret R.ok[Revision, str](rev);
}

# the stored last_changed revision for `(kind, key)` WITHOUT validating or
# recomputing - a read-only peek at the cached state
#
# Returns 0 when the kind is out of range or has no stored entry. Lets a caller
# capture an entry's revision before a `get` and compare afterward to learn whether
# that get advanced it (the "did this input change since I last observed it" signal
# run_link_pass uses). Metadata kinds resolve through their RevisionFn.
# ---
# db:   the database
# kind: the queried kind
# key:  the hashed key
# ret:  the stored last_changed, or 0 when absent
pub fun peek_revision(db: *QueryDb, kind: QueryKind, key: u64) Revision {
    ret last_changed_get(db, kind, key);
}

# claim a shard for a kind, growing the shard array to cover that index when
# needed. fresh slots default to unregistered; rejects double-claims.
fun register(db: *QueryDb, kind: QueryKind, role: ShardRole, compute: ComputeFn, revisions: RevisionFn) R.Result[bool, str] {
    val need: u32 = kind::u32 + 1;
    if (need > db.kinds) {
        val res_grow: R.Result[bool, str] = storage_grow(db, need);
        if (R.is_err[bool, str](res_grow)) { ret res_grow; }
    }

    val sh: *QueryShard = ?db.storage[kind::u32];
    if (sh.registered) {
        ret R.err[bool, str]("register: kind already registered");
    }
    sh.kind       = kind;
    sh.role       = role;
    sh.compute    = compute;
    sh.revisions  = revisions;
    sh.registered = true;
    ret R.ok[bool, str](true);
}

# grow the shard array to at least `need` slots, initializing new shards as empty
# and unregistered.
fun storage_grow(db: *QueryDb, need: u32) R.Result[bool, str] {
    var new_cap: u32 = db.kinds;
    if (new_cap == 0) { new_cap = need; }
    for (new_cap < need) { new_cap = new_cap * 2; }

    if (db.storage == nil) {
        val res_alloc: R.Result[*QueryShard, str] = A.allocate[QueryShard](db.a, new_cap::usize);
        if (R.is_err[*QueryShard, str](res_alloc)) {
            ret R.err[bool, str](R.unwrap_err[*QueryShard, str](res_alloc));
        }
        db.storage = R.unwrap_ok[*QueryShard, str](res_alloc);
    }
    or {
        val res_alloc: R.Result[*QueryShard, str] = A.reallocate[QueryShard](db.a, db.storage, db.kinds::usize, new_cap::usize);
        if (R.is_err[*QueryShard, str](res_alloc)) {
            ret R.err[bool, str](R.unwrap_err[*QueryShard, str](res_alloc));
        }
        db.storage = R.unwrap_ok[*QueryShard, str](res_alloc);
    }

    var i: u32 = db.kinds;
    for (i < new_cap) {
        val sh: *QueryShard = ?db.storage[i];
        sh.kind       = i::QueryKind;
        sh.role       = SHARD_INPUT;
        sh.compute    = nil::ComputeFn;
        sh.revisions  = nil::RevisionFn;
        sh.finalize   = nil::FinalizeFn;
        sh.registered = false;
        sh.entries    = nil;
        sh.len        = 0;
        sh.cap        = 0;
        i = i + 1;
    }

    db.kinds = new_cap;
    ret R.ok[bool, str](true);
}

# resolve a kind to its shard, erroring when the kind is out of range or
# unregistered.
fun shard_get(db: *QueryDb, kind: QueryKind) R.Result[*QueryShard, str] {
    if (kind::u32 >= db.kinds) {
        ret R.err[*QueryShard, str]("query: kind out of range");
    }
    val sh: *QueryShard = ?db.storage[kind::u32];
    if (!sh.registered) {
        ret R.err[*QueryShard, str]("query: kind not registered");
    }
    ret R.ok[*QueryShard, str](sh);
}

# linear scan for an entry by key; nil when absent.
fun entry_find(sh: *QueryShard, key: u64) *QueryEntry {
    var i: u32 = 0;
    for (i < sh.len) {
        val entry: *QueryEntry = ?sh.entries[i];
        if (entry.key == key) { ret entry; }
        i = i + 1;
    }
    ret nil;
}

# append a fresh zeroed entry with the given key and return a pointer to it.
# growing the entries array may move earlier entries, so callers must not hold
# entry pointers across an append.
fun entry_append(db: *QueryDb, sh: *QueryShard, key: u64) R.Result[*QueryEntry, str] {
    if (sh.entries == nil) {
        val res_alloc: R.Result[*QueryEntry, str] = A.allocate[QueryEntry](db.a, INITIAL_ENTRY_CAP::usize);
        if (R.is_err[*QueryEntry, str](res_alloc)) { ret res_alloc; }
        sh.entries = R.unwrap_ok[*QueryEntry, str](res_alloc);
        sh.cap     = INITIAL_ENTRY_CAP;
    }
    or (sh.len == sh.cap) {
        val new_cap: u32 = sh.cap * 2;
        val res_alloc: R.Result[*QueryEntry, str] = A.reallocate[QueryEntry](db.a, sh.entries, sh.cap::usize, new_cap::usize);
        if (R.is_err[*QueryEntry, str](res_alloc)) { ret res_alloc; }
        sh.entries = R.unwrap_ok[*QueryEntry, str](res_alloc);
        sh.cap     = new_cap;
    }

    val entry: *QueryEntry = ?sh.entries[sh.len];
    entry.key          = key;
    entry.value        = nil;
    entry.value_len    = 0;
    entry.last_changed = 0;
    entry.deps         = nil;
    entry.dep_len      = 0;
    entry.dep_cap      = 0;
    entry.diags        = nil;
    sh.len = sh.len + 1;
    ret R.ok[*QueryEntry, str](entry);
}

# free and swap-remove the entry keyed by `key` from `sh`, if present. a no-op
# when absent. swap-remove leaves entry order unspecified, so callers must not
# hold entry pointers across it.
fun entry_remove(db: *QueryDb, sh: *QueryShard, key: u64) {
    var i: u32 = 0;
    for (i < sh.len) {
        val entry: *QueryEntry = ?sh.entries[i];
        if (entry.key == key) {
            entry_free(db, sh, entry);
            val last: u32 = sh.len - 1;
            if (i != last) { sh.entries[i] = sh.entries[last]; }
            sh.len = last;
            ret;
        }
        i = i + 1;
    }
}

# free an entry's owned value and deps buffers and zero their slots. on an
# owned-handle shard the value's artifact is finalized before the handle buffer
# itself is freed.
fun entry_free(db: *QueryDb, sh: *QueryShard, entry: *QueryEntry) {
    if (entry.value != nil && entry.value_len > 0) {
        if (sh.finalize != nil) { sh.finalize(entry.value, entry.value_len, db.a); }
        A.deallocate[u8](db.a, entry.value, entry.value_len::usize);
    }
    if (entry.deps != nil && entry.dep_cap > 0) {
        A.deallocate[Dep](db.a, entry.deps, entry.dep_cap::usize);
    }
    if (entry.diags != nil && db.diag_free != nil::DiagFreeFn) {
        db.diag_free(entry.diags, db.a);
    }
    entry.value     = nil;
    entry.value_len = 0;
    entry.deps      = nil;
    entry.dep_len   = 0;
    entry.dep_cap   = 0;
    entry.diags     = nil;
}

# free every entry in a shard plus the entries array itself.
fun shard_entries_free(db: *QueryDb, sh: *QueryShard) {
    if (sh.entries == nil) { ret; }
    var i: u32 = 0;
    for (i < sh.len) {
        entry_free(db, sh, ?sh.entries[i]);
        i = i + 1;
    }
    if (sh.cap > 0) {
        A.deallocate[QueryEntry](db.a, sh.entries, sh.cap::usize);
    }
    sh.entries = nil;
    sh.len     = 0;
    sh.cap     = 0;
}

# an entry is valid iff every dep's current last_changed equals the value
# captured when the entry was computed. input deps read their stored entry's
# last_changed; metadata deps read the source's RevisionFn.
fun is_entry_valid(db: *QueryDb, entry: *QueryEntry) bool {
    var i: u32 = 0;
    for (i < entry.dep_len) {
        val dep: *Dep = ?entry.deps[i];
        if (last_changed_get(db, dep.kind, dep.key) != dep.last_changed) {
            ret false;
        }
        i = i + 1;
    }
    ret true;
}

# the current last_changed revision for `(kind, key)`. metadata kinds resolve
# through their RevisionFn; input and derived kinds read their stored entry (0
# when absent, so an unset dependency reads as never-changed at revision 0, which
# forces a recompute once it is set).
fun last_changed_get(db: *QueryDb, kind: QueryKind, key: u64) Revision {
    if (kind::u32 >= db.kinds) { ret 0; }
    val sh: *QueryShard = ?db.storage[kind::u32];
    if (sh.role == SHARD_METADATA) {
        if (sh.revisions == nil) { ret 0; }
        ret sh.revisions(key);
    }
    val entry: *QueryEntry = entry_find(sh, key);
    if (entry == nil) { ret 0; }
    ret entry.last_changed;
}

# recompute a derived entry: clear its dep list, run the shard's compute fn
# (which re-records deps via record_dep), and apply early cutoff. identical bytes
# leave value/last_changed unchanged; differing bytes replace value and bump
# last_changed.
fun recompute(db: *QueryDb, sh: *QueryShard, entry: *QueryEntry, key: u64) R.Result[*QueryEntry, str] {
    if (sh.compute == nil) {
        ret R.err[*QueryEntry, str]("recompute: derived kind has no compute function");
    }

    entry.dep_len = 0;

    # mark the sink before the compute so its emitted diagnostics can be captured;
    # bump the depth so a nested reuse the compute reaches does not replay (#1586).
    var diag_mark: u64 = 0;
    if (db.diag_mark != nil::DiagMarkFn) { diag_mark = db.diag_mark(db.ctx); }

    db.compute_depth = db.compute_depth + 1;
    val res_output: R.Result[QueryOutput, str] = sh.compute(db, key, db.a);
    db.compute_depth = db.compute_depth - 1;

    if (R.is_err[QueryOutput, str](res_output)) {
        # a failed compute must not leave a poisoned entry behind: it now has zero
        # deps, which is_entry_valid reads as vacuously valid, so the next get would
        # return its stale (or never-computed nil) bytes as a success. drop it so
        # the next get re-runs compute. `entry` may dangle after this.
        entry_remove(db, sh, key);
        ret R.err[*QueryEntry, str](R.unwrap_err[QueryOutput, str](res_output));
    }
    val out: QueryOutput = R.unwrap_ok[QueryOutput, str](res_output);

    # capture the diagnostics this compute emitted so a later reused get can replay
    # them (#1586). done before the early-cutoff return so an entry whose bytes are
    # unchanged still refreshes its cached diagnostics. a nil snapshot (nothing
    # emitted, or an advisory allocation failure) leaves the entry with none.
    if (db.diag_capture != nil::DiagCaptureFn) {
        val snap: ptr = db.diag_capture(db.ctx, diag_mark, db.a);
        if (entry.diags != nil && db.diag_free != nil::DiagFreeFn) { db.diag_free(entry.diags, db.a); }
        entry.diags = snap;
    }

    # owned-handle shards never early-cut: the handle differs every compute and
    # the artifact behind it propagates by input change, so skip the byte
    # comparison and always replace, finalizing the prior handle's artifact.
    val owned: bool = sh.finalize != nil;
    if (!owned) {
        val same: bool = entry.value_len == out.len
            && memory.raw_equal(entry.value::ptr, out.bytes::ptr, out.len::usize);
        if (same) {
            if (out.bytes != nil && out.len > 0) {
                A.deallocate[u8](db.a, out.bytes, out.len::usize);
            }
            ret R.ok[*QueryEntry, str](entry);
        }
    }

    if (entry.value != nil && entry.value_len > 0) {
        if (owned) { sh.finalize(entry.value, entry.value_len, db.a); }
        A.deallocate[u8](db.a, entry.value, entry.value_len::usize);
    }
    entry.value        = out.bytes;
    entry.value_len    = out.len;
    entry.last_changed = db.revision;
    ret R.ok[*QueryEntry, str](entry);
}

# ensure the entry's dep array has room for `need` more deps.
fun deps_reserve(db: *QueryDb, entry: *QueryEntry, need: u32) R.Result[bool, str] {
    if (entry.deps == nil) {
        var cap: u32 = INITIAL_DEP_CAP;
        for (cap < need) { cap = cap * 2; }
        val res_alloc: R.Result[*Dep, str] = A.allocate[Dep](db.a, cap::usize);
        if (R.is_err[*Dep, str](res_alloc)) {
            ret R.err[bool, str](R.unwrap_err[*Dep, str](res_alloc));
        }
        entry.deps    = R.unwrap_ok[*Dep, str](res_alloc);
        entry.dep_cap = cap;
        ret R.ok[bool, str](true);
    }
    if (entry.dep_len + need <= entry.dep_cap) { ret R.ok[bool, str](true); }

    var new_cap: u32 = entry.dep_cap;
    for (entry.dep_len + need > new_cap) { new_cap = new_cap * 2; }
    val res_alloc: R.Result[*Dep, str] = A.reallocate[Dep](db.a, entry.deps, entry.dep_cap::usize, new_cap::usize);
    if (R.is_err[*Dep, str](res_alloc)) {
        ret R.err[bool, str](R.unwrap_err[*Dep, str](res_alloc));
    }
    entry.deps    = R.unwrap_ok[*Dep, str](res_alloc);
    entry.dep_cap = new_cap;
    ret R.ok[bool, str](true);
}

# allocate an owned copy of `len` bytes from `src`. a zero-length copy yields a
# nil buffer (no allocation).
fun bytes_dup(a: *A.Allocator, src: *u8, len: u32) R.Result[*u8, str] {
    if (len == 0) { ret R.ok[*u8, str](nil); }
    val res_alloc: R.Result[*u8, str] = A.allocate[u8](a, len::usize);
    if (R.is_err[*u8, str](res_alloc)) { ret res_alloc; }
    val dst: *u8 = R.unwrap_ok[*u8, str](res_alloc);
    memory.raw_copy(dst::ptr, src::ptr, len::usize);
    ret R.ok[*u8, str](dst);
}

# a derived compute that always fails, to exercise the failed-recompute path.
fun t_always_fail(db: *QueryDb, key: u64, a: *A.Allocator) R.Result[QueryOutput, str] {
    ret R.err[QueryOutput, str]("compute always fails");
}

# record a dep on Q_FILE_TEXT and return a fixed single byte, for early-cutoff
# testing. always produces the same output, so last_changed is never bumped by
# the compute itself.
fun t_tok_compute(db: *QueryDb, key: u64, a: *A.Allocator) R.Result[QueryOutput, str] {
    val res_dep: R.Result[bool, str] = record_dep(db, Q_TOKENIZE, key, Q_FILE_TEXT, key);
    if (R.is_err[bool, str](res_dep)) {
        ret R.err[QueryOutput, str](R.unwrap_err[bool, str](res_dep));
    }
    val res_buf: R.Result[*u8, str] = A.allocate[u8](a, 1);
    if (R.is_err[*u8, str](res_buf)) {
        ret R.err[QueryOutput, str](R.unwrap_err[*u8, str](res_buf));
    }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);
    buf[0] = 42;

    var out: QueryOutput;
    out.bytes = buf;
    out.len   = 1;
    ret R.ok[QueryOutput, str](out);
}

# live count of artifacts the owned-handle finalizer test tracks; the compute
# bumps it, the finalizer drops it, so a balanced 0 at teardown means every
# handle's artifact was finalized exactly once (no leak, no double-free).
var t_live: i64 = 0;

# decode the opaque artifact pointer an owned-handle entry stores.
fun t_handle_ptr(entry: *QueryEntry) ptr {
    if (entry.value == nil || entry.value_len::usize < $size_of(ptr)) { ret nil; }
    val slot: *ptr = entry.value::ptr::*ptr;
    ret slot[0];
}

# allocate a heap artifact, bump the live count, and return its pointer as an
# opaque handle. records a dep on Q_FILE_TEXT so an input change recomputes.
fun t_owned_compute(db: *QueryDb, key: u64, a: *A.Allocator) R.Result[QueryOutput, str] {
    val res_dep: R.Result[bool, str] = record_dep(db, Q_PARSE, key, Q_FILE_TEXT, key);
    if (R.is_err[bool, str](res_dep)) {
        ret R.err[QueryOutput, str](R.unwrap_err[bool, str](res_dep));
    }
    val res_art: R.Result[*u64, str] = A.allocate[u64](a, 1::usize);
    if (R.is_err[*u64, str](res_art)) {
        ret R.err[QueryOutput, str](R.unwrap_err[*u64, str](res_art));
    }
    val art: *u64 = R.unwrap_ok[*u64, str](res_art);
    art[0] = key;
    t_live = t_live + 1;

    val n: u32 = $size_of(ptr)::u32;
    val res_buf: R.Result[*u8, str] = A.allocate[u8](a, n::usize);
    if (R.is_err[*u8, str](res_buf)) {
        A.deallocate[u64](a, art, 1::usize);
        t_live = t_live - 1;
        ret R.err[QueryOutput, str](R.unwrap_err[*u8, str](res_buf));
    }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);
    val slot: *ptr = buf::ptr::*ptr;
    slot[0] = art::ptr;

    var out: QueryOutput;
    out.bytes = buf;
    out.len   = n;
    ret R.ok[QueryOutput, str](out);
}

# release a handle's artifact and drop the live count.
fun t_owned_finalize(value: *u8, value_len: u32, a: *A.Allocator) {
    if (value == nil || value_len::usize < $size_of(ptr)) { ret; }
    val slot: *ptr = value::ptr::*ptr;
    val art: *u64 = slot[0]::*u64;
    if (art == nil) { ret; }
    A.deallocate[u64](a, art, 1::usize);
    t_live = t_live - 1;
}

# a failed compute must not be laundered into a cached, vacuously-valid success;
# the next get must re-run compute and fail again (#1249).
test "mach.lang.query.recompute:failed_not_cached_as_success" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val res_db: R.Result[QueryDb, str] = init(?alloc);
    if (R.is_err[QueryDb, str](res_db)) { ret 1; }
    var db: QueryDb = R.unwrap_ok[QueryDb, str](res_db);

    if (R.is_err[bool, str](register_derived(?db, Q_TOKENIZE, t_always_fail))) { dnit(?db); ret 1; }

    # first get: compute fails, so get errs.
    if (!R.is_err[*QueryEntry, str](get(?db, Q_TOKENIZE, 42))) { dnit(?db); ret 1; }
    # second get: the failed entry must not be cached as a vacuously-valid (zero-
    # dep) success; get must re-run compute and err again rather than return the
    # poisoned nil value.
    if (!R.is_err[*QueryEntry, str](get(?db, Q_TOKENIZE, 42))) { dnit(?db); ret 1; }

    dnit(?db);
    ret 0;
}

# repeated identical input bytes leave last_changed untouched; only a real byte
# change advances it (#1242).
test "mach.lang.query.set_input:identical_bytes_early_cutoff" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val res_db: R.Result[QueryDb, str] = init(?alloc);
    if (R.is_err[QueryDb, str](res_db)) { ret 1; }
    var db: QueryDb = R.unwrap_ok[QueryDb, str](res_db);

    if (R.is_err[bool, str](register_input(?db, Q_PROJECT_ROOT))) { dnit(?db); ret 1; }

    # first write: entry created, last_changed set
    if (R.is_err[bool, str](set_input(?db, Q_PROJECT_ROOT, 1, "hello"::*u8, 5))) { dnit(?db); ret 1; }
    val res_entry_a: R.Result[*QueryEntry, str] = get(?db, Q_PROJECT_ROOT, 1);
    if (R.is_err[*QueryEntry, str](res_entry_a)) { dnit(?db); ret 1; }
    val lc_a: Revision = R.unwrap_ok[*QueryEntry, str](res_entry_a).last_changed;

    # same bytes again: early cutoff, last_changed must not advance
    if (R.is_err[bool, str](set_input(?db, Q_PROJECT_ROOT, 1, "hello"::*u8, 5))) { dnit(?db); ret 1; }
    val res_entry_b: R.Result[*QueryEntry, str] = get(?db, Q_PROJECT_ROOT, 1);
    if (R.is_err[*QueryEntry, str](res_entry_b)) { dnit(?db); ret 1; }
    val lc_b: Revision = R.unwrap_ok[*QueryEntry, str](res_entry_b).last_changed;
    if (lc_b != lc_a) { dnit(?db); ret 1; }

    # different bytes: last_changed must advance
    if (R.is_err[bool, str](set_input(?db, Q_PROJECT_ROOT, 1, "world"::*u8, 5))) { dnit(?db); ret 1; }
    val res_entry_c: R.Result[*QueryEntry, str] = get(?db, Q_PROJECT_ROOT, 1);
    if (R.is_err[*QueryEntry, str](res_entry_c)) { dnit(?db); ret 1; }
    val lc_c: Revision = R.unwrap_ok[*QueryEntry, str](res_entry_c).last_changed;
    if (lc_c <= lc_a) { dnit(?db); ret 1; }

    dnit(?db);
    ret 0;
}

# a derived entry tracks its input dep and early-cuts when a recompute reproduces
# identical output bytes across input changes (#1242).
test "mach.lang.query.get:derived_dep_tracking_early_cutoff" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val res_db: R.Result[QueryDb, str] = init(?alloc);
    if (R.is_err[QueryDb, str](res_db)) { ret 1; }
    var db: QueryDb = R.unwrap_ok[QueryDb, str](res_db);

    if (R.is_err[bool, str](register_input(?db, Q_FILE_TEXT)))                 { dnit(?db); ret 1; }
    if (R.is_err[bool, str](register_derived(?db, Q_TOKENIZE, t_tok_compute))) { dnit(?db); ret 1; }

    # warm the derived cache with input "v1"
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 7, "v1"::*u8, 2))) { dnit(?db); ret 1; }
    val res_warm: R.Result[*QueryEntry, str] = get(?db, Q_TOKENIZE, 7);
    if (R.is_err[*QueryEntry, str](res_warm)) { dnit(?db); ret 1; }
    val lc_warm: Revision = R.unwrap_ok[*QueryEntry, str](res_warm).last_changed;

    # change input to "v2": dep stale, recompute runs, same output bytes -> early cutoff
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 7, "v2"::*u8, 2))) { dnit(?db); ret 1; }
    val res_v2: R.Result[*QueryEntry, str] = get(?db, Q_TOKENIZE, 7);
    if (R.is_err[*QueryEntry, str](res_v2)) { dnit(?db); ret 1; }
    val lc_v2: Revision = R.unwrap_ok[*QueryEntry, str](res_v2).last_changed;

    # restore "v1": dep stale again, recompute, same output bytes -> early cutoff again
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 7, "v1"::*u8, 2))) { dnit(?db); ret 1; }
    val res_v1: R.Result[*QueryEntry, str] = get(?db, Q_TOKENIZE, 7);
    if (R.is_err[*QueryEntry, str](res_v1)) { dnit(?db); ret 1; }
    val lc_v1: Revision = R.unwrap_ok[*QueryEntry, str](res_v1).last_changed;

    # early cutoff on the derived side: compute always returns the same bytes, so
    # last_changed must never have advanced across any recompute
    if (lc_v2 != lc_warm) { dnit(?db); ret 1; }
    if (lc_v1 != lc_warm) { dnit(?db); ret 1; }

    dnit(?db);
    ret 0;
}

# an owned-handle finalizer releases each heavy artifact exactly once, on
# recompute and on dnit, leaving a balanced live count (#1580).
test "mach.lang.query.register_derived_owned:finalizer_frees_artifacts" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val res_db: R.Result[QueryDb, str] = init(?alloc);
    if (R.is_err[QueryDb, str](res_db)) { ret 1; }
    var db: QueryDb = R.unwrap_ok[QueryDb, str](res_db);
    t_live = 0;

    if (R.is_err[bool, str](register_input(?db, Q_FILE_TEXT)))                                        { dnit(?db); ret 1; }
    if (R.is_err[bool, str](register_derived_owned(?db, Q_PARSE, t_owned_compute, t_owned_finalize))) { dnit(?db); ret 1; }

    # first get computes exactly one artifact behind the handle.
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 1, "a"::*u8, 1))) { dnit(?db); ret 1; }
    val res_g1: R.Result[*QueryEntry, str] = get(?db, Q_PARSE, 1);
    if (R.is_err[*QueryEntry, str](res_g1)) { dnit(?db); ret 1; }
    if (t_live != 1)                        { dnit(?db); ret 1; }
    val p1: ptr = t_handle_ptr(R.unwrap_ok[*QueryEntry, str](res_g1));

    # unchanged input: entry stays valid, no recompute, no new artifact, same handle.
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 1, "a"::*u8, 1))) { dnit(?db); ret 1; }
    val res_g2: R.Result[*QueryEntry, str] = get(?db, Q_PARSE, 1);
    if (R.is_err[*QueryEntry, str](res_g2))                        { dnit(?db); ret 1; }
    if (t_live != 1)                                               { dnit(?db); ret 1; }
    if (t_handle_ptr(R.unwrap_ok[*QueryEntry, str](res_g2)) != p1) { dnit(?db); ret 1; }

    # changed input: recompute replaces the handle and finalizes the prior artifact,
    # so the live count stays balanced and the handle is a fresh pointer.
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 1, "b"::*u8, 1))) { dnit(?db); ret 1; }
    val res_g3: R.Result[*QueryEntry, str] = get(?db, Q_PARSE, 1);
    if (R.is_err[*QueryEntry, str](res_g3))                        { dnit(?db); ret 1; }
    if (t_live != 1)                                               { dnit(?db); ret 1; }
    if (t_handle_ptr(R.unwrap_ok[*QueryEntry, str](res_g3)) == p1) { dnit(?db); ret 1; }

    # a second key adds a second live artifact.
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 2, "c"::*u8, 1))) { dnit(?db); ret 1; }
    if (R.is_err[*QueryEntry, str](get(?db, Q_PARSE, 2)))                 { dnit(?db); ret 1; }
    if (t_live != 2)                                                      { dnit(?db); ret 1; }

    # dnit finalizes every live handle; a balanced count proves no leak / double-free.
    dnit(?db);
    if (t_live != 0) { ret 1; }
    ret 0;
}

# mock diagnostic sink for the capture/replay hook tests: a length counter a
# compute "emits" into, that the hooks snapshot and replay. a scalar stands in for
# the real DiagList so the engine test stays free of the diagnostic module.
var t_diag_count: usize = 0;

# reset the mock sink between phases of the test.
fun t_diag_reset() { t_diag_count = 0; }

# a captured run of emitted diagnostics: just how many, since order/content is the
# driver test's concern; this engine test asserts replay and depth suppression.
rec TDiagSnap { n: usize; }

# mark hook: the mock sink's current length.
fun t_diag_mark(ctx: ptr) u64 { ret t_diag_count::u64; }

# capture hook: snapshot the count of diagnostics appended since `mark`, or nil
# when none were.
fun t_diag_capture(ctx: ptr, mark: u64, a: *A.Allocator) ptr {
    if (t_diag_count <= mark::usize) { ret nil; }
    val sr: R.Result[*TDiagSnap, str] = A.allocate[TDiagSnap](a, 1::usize);
    if (R.is_err[*TDiagSnap, str](sr)) { ret nil; }
    val snap: *TDiagSnap = R.unwrap_ok[*TDiagSnap, str](sr);
    snap.n = t_diag_count - mark::usize;
    ret snap::ptr;
}

# replay hook: re-append a snapshot's diagnostics onto the mock sink.
fun t_diag_replay(ctx: ptr, handle: ptr) {
    val snap: *TDiagSnap = handle::*TDiagSnap;
    t_diag_count = t_diag_count + snap.n;
}

# free hook: release a snapshot handle.
fun t_diag_free(handle: ptr, a: *A.Allocator) {
    A.deallocate[TDiagSnap](a, handle::*TDiagSnap, 1::usize);
}

# an inner derived compute that "emits" one diagnostic and returns a fixed byte, so
# its entry is reused on an unchanged input.
fun t_inner_diag_compute(db: *QueryDb, key: u64, a: *A.Allocator) R.Result[QueryOutput, str] {
    val rd: R.Result[bool, str] = record_dep(db, Q_TOKENIZE, key, Q_FILE_TEXT, key);
    if (R.is_err[bool, str](rd)) { ret R.err[QueryOutput, str](R.unwrap_err[bool, str](rd)); }
    t_diag_count = t_diag_count + 1;
    val rb: R.Result[*u8, str] = A.allocate[u8](a, 1);
    if (R.is_err[*u8, str](rb)) { ret R.err[QueryOutput, str](R.unwrap_err[*u8, str](rb)); }
    val buf: *u8 = R.unwrap_ok[*u8, str](rb);
    buf[0] = 1;
    var out: QueryOutput;
    out.bytes = buf;
    out.len   = 1;
    ret R.ok[QueryOutput, str](out);
}

# an outer derived compute that "emits" one diagnostic then reads the inner query,
# so the test can observe that the nested reuse it triggers does not replay.
fun t_outer_diag_compute(db: *QueryDb, key: u64, a: *A.Allocator) R.Result[QueryOutput, str] {
    val rd: R.Result[bool, str] = record_dep(db, Q_PARSE, key, Q_FILE_TEXT, key);
    if (R.is_err[bool, str](rd)) { ret R.err[QueryOutput, str](R.unwrap_err[bool, str](rd)); }
    t_diag_count = t_diag_count + 1;
    val g: R.Result[*QueryEntry, str] = get(db, Q_TOKENIZE, key);
    if (R.is_err[*QueryEntry, str](g)) { ret R.err[QueryOutput, str](R.unwrap_err[*QueryEntry, str](g)); }
    val rb: R.Result[*u8, str] = A.allocate[u8](a, 1);
    if (R.is_err[*u8, str](rb)) { ret R.err[QueryOutput, str](R.unwrap_err[*u8, str](rb)); }
    val buf: *u8 = R.unwrap_ok[*u8, str](rb);
    buf[0] = 2;
    var out: QueryOutput;
    out.bytes = buf;
    out.len   = 1;
    ret R.ok[QueryOutput, str](out);
}

# a reused entry replays its captured diagnostics on a top-level get, and a nested
# reuse reached from inside another compute is suppressed so it does not
# double-emit what the driver drives directly (#1586).
test "mach.lang.query.get:reused_entry_replays_diagnostics" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val res_db: R.Result[QueryDb, str] = init(?alloc);
    if (R.is_err[QueryDb, str](res_db)) { ret 1; }
    var db: QueryDb = R.unwrap_ok[QueryDb, str](res_db);

    if (R.is_err[bool, str](register_input(?db, Q_FILE_TEXT)))                        { dnit(?db); ret 1; }
    if (R.is_err[bool, str](register_derived(?db, Q_TOKENIZE, t_inner_diag_compute))) { dnit(?db); ret 1; }
    if (R.is_err[bool, str](register_derived(?db, Q_PARSE, t_outer_diag_compute)))    { dnit(?db); ret 1; }
    set_diag_hooks(?db, t_diag_mark, t_diag_capture, t_diag_replay, t_diag_free);
    if (R.is_err[bool, str](set_input(?db, Q_FILE_TEXT, 1, "x"::*u8, 1)))             { dnit(?db); ret 1; }

    # cold inner compute emits its diagnostic directly.
    t_diag_reset();
    if (R.is_err[*QueryEntry, str](get(?db, Q_TOKENIZE, 1))) { dnit(?db); ret 1; }
    if (t_diag_count != 1)                                   { dnit(?db); ret 1; }

    # reused inner replays its one diagnostic.
    t_diag_reset();
    if (R.is_err[*QueryEntry, str](get(?db, Q_TOKENIZE, 1))) { dnit(?db); ret 1; }
    if (t_diag_count != 1)                                   { dnit(?db); ret 1; }

    # cold outer compute emits its own diagnostic; the nested reused inner is
    # suppressed at depth > 0, so exactly one lands - not two.
    t_diag_reset();
    if (R.is_err[*QueryEntry, str](get(?db, Q_PARSE, 1))) { dnit(?db); ret 1; }
    if (t_diag_count != 1)                                { dnit(?db); ret 1; }

    # reused outer replays exactly its own captured diagnostic.
    t_diag_reset();
    if (R.is_err[*QueryEntry, str](get(?db, Q_PARSE, 1))) { dnit(?db); ret 1; }
    if (t_diag_count != 1)                                { dnit(?db); ret 1; }

    # invalidate drops the snapshot; a re-get recomputes and re-emits directly.
    if (R.is_err[bool, str](invalidate(?db, Q_PARSE, 1))) { dnit(?db); ret 1; }
    t_diag_reset();
    if (R.is_err[*QueryEntry, str](get(?db, Q_PARSE, 1))) { dnit(?db); ret 1; }
    if (t_diag_count != 1)                                { dnit(?db); ret 1; }

    dnit(?db);
    ret 0;
}
