# the `mach.toml` schema model, parser, validator, template engine, and
# build-unit resolver.
#
# This module is the single owner of the manifest format. It reads an
# already-parsed `std.data.toml` table into a `Manifest` value, validating
# loudly (unknown keys, missing required keys, reserved names, `\` in paths),
# then resolves a build selection - a target (with `native` host resolution), a
# profile, and one artifact - into a `BuildUnit` whose output paths come only
# from the declared `out`/`obj`/`ir`/`asm` templates expanded over
# `{target} {profile} {name} {ext}`. Nothing is inferred: every value resolves
# from a stanza present in the file.

use std.allocator.arena;
use std.allocator.page;
use std.data.toml;
use std.text.string.str_free;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.char.char;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_contains;
use std.types.string.str_empty;
use std.types.string.str_equals;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.intern;
use tgt: mach.lang.target;
use mach.lang.target.isa;
use mach.lang.target.os;

# a profile's declared optimization level
#
# Mirrors the driver's TargetOpt values so the driver maps one to the other by
# identity.
pub def MOpt: u8;

pub val MOPT_DEFAULT: MOpt = 0;  # no `opt` key - the build's own default (debug)
pub val MOPT_DEBUG:   MOpt = 1;  # `opt = 0` - no optimization beyond the always-on pipeline
pub val MOPT_RELEASE: MOpt = 2;  # `opt = 1` (standard) / `opt = 2` (aggressive)

# a `[lib.*]` artifact's link kind
pub def LibKind: u8;

pub val LIBKIND_STATIC: LibKind = 0;  # `kind = "static"` - the default; objects are the deliverable
pub val LIBKIND_SHARED: LibKind = 1;  # `kind = "shared"` - a shared library

# which stanza a key-allowlist check is validating against
def TableKind: u8;

val TK_PROJECT: TableKind = 0;  # the `[project]` table
val TK_TARGET:  TableKind = 1;  # a `[target.<name>]` table
val TK_BIN:     TableKind = 2;  # a `[bin.<name>]` table
val TK_LIB:     TableKind = 3;  # a `[lib.<name>]` table
val TK_PROFILE: TableKind = 4;  # a `[profile.<name>]` table
val TK_DEP:     TableKind = 5;  # a `[deps.<name>]` table
val TK_CELL:    TableKind = 6;  # a `[*.target.<name>]` per-cell table
val TK_OS:      TableKind = 7;  # an `[os.<name>]` table

# one `[target.<name>]` platform stanza
#
# Tuples are fully spelled; nothing is inferred. `ext` defaults to the empty
# string. `libs`/`defines` are the per-target overlay applied over an artifact's
# own fields.
# ---
# name:         interned target selector (e.g. "linux")
# isa:          interned instruction-set architecture (required)
# os:           interned operating system (required)
# abi:          interned ABI (required)
# ext:          interned artifact extension, "" when omitted
# libs:         interned platform link overlay; nil when none
# lib_count:    number of entries in libs
# defines:      interned per-target comptime defines; nil when none
# define_count: number of entries in defines
pub rec TargetDef {
    name:         intern.StrId;
    isa:          intern.StrId;
    os:           intern.StrId;
    abi:          intern.StrId;
    ext:          intern.StrId;
    libs:         *intern.StrId;
    lib_count:    u32;
    defines:      *intern.StrId;
    define_count: u32;
}

# one `[bin.<a>.target.<t>]` per-cell exception refining an artifact for a single
# target
#
# An unset override (STR_NIL) inherits the artifact field.
# ---
# target:       interned name of the target this cell refines
# entry:        interned entry-file override, STR_NIL to inherit
# out:          interned `out` template override, STR_NIL to inherit
# libs:         interned per-cell link inputs appended to the merge; nil when none
# lib_count:    number of entries in libs
# defines:      interned per-cell comptime defines, the highest precedence level; nil when none
# define_count: number of entries in defines
pub rec CellDef {
    target:       intern.StrId;
    entry:        intern.StrId;
    out:          intern.StrId;
    libs:         *intern.StrId;
    lib_count:    u32;
    defines:      *intern.StrId;
    define_count: u32;
}

# one `[bin.<name>]` or `[lib.<name>]` artifact
#
# Every artifact is declared explicitly and named by its table key.
# ---
# name:         interned artifact name
# is_lib:       true for `[lib.*]`, false for `[bin.*]`
# entry:        interned entry-source path, relative to the project src dir (required)
# kind:         link kind for a lib (LIBKIND_STATIC default); ignored for a bin
# out:          interned per-artifact `out` template override, STR_NIL to inherit
# libs:         interned per-artifact link inputs; nil when none
# lib_count:    number of entries in libs
# defines:      interned per-artifact defines; nil when none
# define_count: number of entries in defines
# cells:        per-cell `[*.target.*]` exceptions; nil when none
# cell_count:   number of entries in cells
pub rec ArtifactDef {
    name:         intern.StrId;
    is_lib:       bool;
    entry:        intern.StrId;
    kind:         LibKind;
    out:          intern.StrId;
    libs:         *intern.StrId;
    lib_count:    u32;
    defines:      *intern.StrId;
    define_count: u32;
    cells:        *CellDef;
    cell_count:   u32;
}

# one `[profile.<name>]` build variant
#
# Emission toggles live here because emission is a build-variant concern.
# ---
# name:     interned profile name
# opt:      declared optimization level
# emit_ir:  default `--emit-ir` for this profile
# emit_asm: default `--emit-asm` for this profile
pub rec ProfileDef {
    name:     intern.StrId;
    opt:      MOpt;
    emit_ir:  bool;
    emit_asm: bool;
}

# one `[os.<name>] libs = [...]` link overlay scoped to a single tuple component
#
# A consumer's selected tuple matches the overlay iff its os equals `<name>`, so
# a platform link requirement lives once and cascades like a target lib without
# re-enumerating every isa/abi tuple it applies to.
# ---
# name:      interned os name this overlay gates on (e.g. "windows")
# libs:      interned link inputs; nil when none
# lib_count: number of entries in libs
pub rec OsDef {
    name:      intern.StrId;
    libs:      *intern.StrId;
    lib_count: u32;
}

# one `[deps.<name>]` dependency
#
# Exactly one source key - `git` or `path` - plus an optional `ref` for git.
# Registry `version =` is reserved and rejected at parse time.
# ---
# name: interned dependency alias
# git:  interned git url, STR_NIL when path-sourced
# path: interned local path, STR_NIL when git-sourced
# ref:  interned git ref, STR_NIL when omitted
pub rec DepDef {
    name: intern.StrId;
    git:  intern.StrId;
    path: intern.StrId;
    ref:  intern.StrId;
}

# a fully parsed and validated v2 manifest
# ---
# id:               interned `[project].id` (required)
# version:          interned `[project].version` (required)
# name:             interned `[project].name` metadata, STR_NIL when omitted
# description:      interned `[project].description` metadata, STR_NIL when omitted
# license:          interned `[project].license` metadata, STR_NIL when omitted
# module:           interned `[project].module` - the src-relative module file a
#                   bare project-id `use`/`fwd` path resolves to; STR_NIL when none
# src:              interned source dir (default "src")
# dep:              interned vendored-dependency dir (default "dep")
# default_target:   interned `[project].target` default selector (default "native")
# out_tmpl:         interned artifact path template
# obj_tmpl:         interned intermediate-object dir template
# ir_tmpl:          interned IR-dump dir template
# asm_tmpl:         interned ASM-dump dir template
# tests_tmpl:       interned per-test executable path template; its `{name}` is the
#                   sanitized test name, expanded per test by `mach test`
# targets:          declared `[target.*]` platforms
# target_count:     number of targets
# artifacts:        declared `[bin.*]`/`[lib.*]` artifacts
# artifact_count:   number of artifacts
# profiles:         declared `[profile.*]` variants
# profile_count:    number of profiles
# deps:             declared `[deps.*]` dependencies
# dep_count:        number of deps
# os_overlays:      declared `[os.*]` link overlays
# os_overlay_count: number of os overlays
pub rec Manifest {
    id:               intern.StrId;
    version:          intern.StrId;
    name:             intern.StrId;
    description:      intern.StrId;
    license:          intern.StrId;
    module:           intern.StrId;
    src:              intern.StrId;
    dep:              intern.StrId;
    default_target:   intern.StrId;
    out_tmpl:         intern.StrId;
    obj_tmpl:         intern.StrId;
    ir_tmpl:          intern.StrId;
    asm_tmpl:         intern.StrId;
    tests_tmpl:       intern.StrId;
    targets:          *TargetDef;
    target_count:     u32;
    artifacts:        *ArtifactDef;
    artifact_count:   u32;
    profiles:         *ProfileDef;
    profile_count:    u32;
    deps:             *DepDef;
    dep_count:        u32;
    os_overlays:      *OsDef;
    os_overlay_count: u32;
}

pub val DEFAULT_OUT:   str = "out/{target}/{profile}/bin/{name}{ext}";  # init-written artifact path template
pub val DEFAULT_OBJ:   str = "out/{target}/{profile}/obj";             # init-written intermediate-object dir template
pub val DEFAULT_IR:    str = "out/{target}/{profile}/ir";              # init-written IR-dump dir template
pub val DEFAULT_ASM:   str = "out/{target}/{profile}/asm";             # init-written ASM-dump dir template
pub val DEFAULT_TESTS: str = "out/{target}/{profile}/test/{name}";     # init-written per-test executable path template

# the build selection a CLI invocation narrows the manifest with
#
# Every field is optional; an unset value resolves to the manifest default.
# ---
# target:       declared target name, "native"/"host", or nil for the manifest default
# profile:      declared profile name, or nil for the default profile
# artifact:     a `[bin.*]`/`[lib.*]` name, or nil for the default artifact
# want_lib:     the artifact selector came from `--lib` (disambiguates a name)
# has_artifact: whether an artifact selector was given
pub rec Selection {
    target:       str;
    profile:      str;
    artifact:     str;
    want_lib:     bool;
    has_artifact: bool;
}

# one fully-resolved (artifact, target, profile) cell with concrete,
# template-expanded output paths
#
# `{target}` is the resolved name, never the literal `native`. `libs` is the
# merged target+artifact+cell link overlay, owned by the resolving allocator.
# ---
# target:       the resolved target stanza
# artifact:     the selected artifact stanza
# target_name:  interned resolved target name (drives `{target}`)
# profile_name: interned resolved profile name (drives `{profile}`)
# entry:        interned effective entry-source path
# bin_path:     interned expanded artifact path
# obj_root:     interned expanded intermediate-object dir
# ir_root:      interned expanded IR-dump dir
# asm_root:     interned expanded ASM-dump dir
# test_root:    interned per-test executable path template with `{target}`/`{profile}`/
#               `{ext}` expanded and a literal `{name}` placeholder left for `mach
#               test` to fill with each sanitized test name
# opt:          resolved optimization level
# emit_ir:      profile default for IR emission
# emit_asm:     profile default for ASM emission
# is_lib:       whether the artifact is a library
# kind:         library link kind (meaningful when is_lib)
# libs:         merged interned link overlay; nil when none
# lib_count:    number of entries in libs
# defines:      merged interned comptime-define overlay (artifact < target < cell,
#               override by name); nil when none
# define_count: number of entries in defines
# warned:       native resolution found no host match and fell back to the first target
pub rec BuildUnit {
    target:       *TargetDef;
    artifact:     *ArtifactDef;
    target_name:  intern.StrId;
    profile_name: intern.StrId;
    entry:        intern.StrId;
    bin_path:     intern.StrId;
    obj_root:     intern.StrId;
    ir_root:      intern.StrId;
    asm_root:     intern.StrId;
    test_root:    intern.StrId;
    opt:          MOpt;
    emit_ir:      bool;
    emit_asm:     bool;
    is_lib:       bool;
    kind:         LibKind;
    libs:         *intern.StrId;
    lib_count:    u32;
    defines:      *intern.StrId;
    define_count: u32;
    warned:       bool;
}

# a resolved target plus the native no-match warning flag
# ---
# target: the resolved target stanza
# warned: native resolution found no host match and fell back to the first target
pub rec ResolvedTarget {
    target: *TargetDef;
    warned: bool;
}

# a resolved (or implicit-default) profile's effective fields
# ---
# name:     interned profile name
# opt:      resolved optimization level
# emit_ir:  profile default for IR emission
# emit_asm: profile default for ASM emission
pub rec ResolvedProfile {
    name:     intern.StrId;
    opt:      MOpt;
    emit_ir:  bool;
    emit_asm: bool;
}

# an interned string array carved from a TOML array of strings
# ---
# items: interned StrId array; nil when empty
# count: number of entries in items
rec StrArr {
    items: *intern.StrId;
    count: u32;
}

# concatenate two strings into a freshly-allocated owned string
#
# Used to build span-free diagnostic messages with dynamic names. On allocation
# failure the second part is returned as a best-effort fragment, since the build
# is already failing on OOM.
# ---
# alloc: allocator owning the result
# a:     left operand
# b:     right operand
# ret:   owned "a" ++ "b", or "b" on allocation failure
fun cc(alloc: *A.Allocator, a: str, b: str) str {
    val la: usize = str_len(a);
    val lb: usize = str_len(b);
    val res_buf: R.Result[*u8, str] = A.allocate[u8](alloc, la + lb + 1);
    if (R.is_err[*u8, str](res_buf)) { ret b; }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);
    var w: usize = 0;
    var i: usize = 0;
    for (i < la) { buf[w] = a[i]; w = w + 1; i = i + 1; }
    i = 0;
    for (i < lb) { buf[w] = b[i]; w = w + 1; i = i + 1; }
    buf[w] = 0;
    ret buf::str;
}

# concatenate three strings into one owned string
# ---
# alloc: allocator owning the result
# a:     first operand
# b:     second operand
# c:     third operand
# ret:   owned "a" ++ "b" ++ "c"
fun cc3(alloc: *A.Allocator, a: str, b: str, c: str) str {
    ret cc(alloc, cc(alloc, a, b), c);
}

# concatenate five strings into one owned string
# ---
# alloc: allocator owning the result
# a:     first operand
# b:     second operand
# c:     third operand
# d:     fourth operand
# e:     fifth operand
# ret:   owned concatenation of all five
fun cc5(alloc: *A.Allocator, a: str, b: str, c: str, d: str, e: str) str {
    ret cc(alloc, cc3(alloc, a, b, c), cc(alloc, d, e));
}

# the build host's isa name
# ---
# ret: the host architecture's isa name
fun host_isa_name() str {
    ret isa.arch_name_for(tgt.host_arch_id());
}

# the build host's os name
# ---
# ret: the host operating system's name
fun host_os_name() str {
    ret os.os_name_for(tgt.host_os_id());
}

# the build host's `<isa>-<os>` tuple string, for the native no-match warning
# ---
# alloc: allocator owning the result
# ret:   owned "<isa>-<os>" host tuple
pub fun host_tuple(alloc: *A.Allocator) str {
    ret cc3(alloc, host_isa_name(), "-", host_os_name());
}

# whether `s` is acceptable as a `[project].id`
#
# A project id heads every module FQN (`use <id>...`) and names the
# `[bin.<id>]`/`[lib.<id>]` artifact table, so it must be a non-empty run of TOML
# bare-key characters: ASCII letters, digits, `_`, or `-`. Anything the grammar
# would reject as a bare key (`.`, path separators, spaces, empty) is refused
# here. This is the single authoritative notion of a valid id; `mach init` reuses
# it to reject bad input before scaffolding.
# ---
# s:   candidate project id
# ret: true when `s` is non-empty and every byte is a legal bare-key character
pub fun is_valid_id(s: str) bool {
    if (str_empty(s)) { ret false; }
    val n: usize = str_len(s);
    var i: usize = 0;
    for (i < n) {
        val c: u8 = s[i];
        if (!((c >= 'A' && c <= 'Z')
           || (c >= 'a' && c <= 'z')
           || (c >= '0' && c <= '9')
           || c == '_' || c == '-')) { ret false; }
        i = i + 1;
    }
    ret true;
}

# whether a path/template contains a literal `\`
#
# Manifest paths are `/`-separated; a `\` is rejected so the same manifest is
# portable across hosts.
# ---
# s:   path or template text
# ret: true when `s` holds a backslash
fun has_backslash(s: str) bool {
    if (str_empty(s)) { ret false; }
    val n: usize = str_len(s);
    var i: usize = 0;
    for (i < n) {
        if (s[i] == '\\') { ret true; }
        i = i + 1;
    }
    ret false;
}

# intern `text`, or STR_NIL when it is empty (an absent optional)
# ---
# itn:  interner to intern into
# text: value to intern, possibly empty
# ret:  ok(StrId) - STR_NIL when empty - or err on intern failure
fun intern_opt(itn: *intern.Interner, text: str) R.Result[intern.StrId, str] {
    if (str_empty(text)) { ret R.ok[intern.StrId, str](intern.STR_NIL); }
    ret intern.intern(itn, text);
}

# intern `text`, returning STR_NIL on failure
#
# Used for values already validated non-empty (project dirs and templates), so a
# failure here is an allocator fault surfaced later as a lookup miss rather than
# silently swallowed.
# ---
# itn:  interner to intern into
# text: value to intern
# ret:  the StrId, or STR_NIL on intern failure
fun intern_unwrap(itn: *intern.Interner, text: str) intern.StrId {
    val res_id: R.Result[intern.StrId, str] = intern.intern(itn, text);
    if (R.is_err[intern.StrId, str](res_id)) { ret intern.STR_NIL; }
    ret R.unwrap_ok[intern.StrId, str](res_id);
}

# intern an optional value, STR_NIL when empty or on failure
# ---
# itn:  interner to intern into
# text: value to intern, possibly empty
# ret:  the StrId, or STR_NIL when empty or on failure
fun intern_opt_unwrap(itn: *intern.Interner, text: str) intern.StrId {
    if (str_empty(text)) { ret intern.STR_NIL; }
    ret intern_unwrap(itn, text);
}

# read a TOML string array into an interned StrArr
#
# A nil array yields an empty StrArr. A non-string element fails with `elem_err`.
# ---
# alloc:    allocator owning the result array
# itn:      interner for element strings
# arr:      source TOML array, nil for none
# elem_err: diagnostic returned when an element is not a string
# ret:      ok(StrArr) on success, err on a bad element or allocation failure
fun parse_str_array(alloc: *A.Allocator, itn: *intern.Interner, arr: *toml.Array, elem_err: str) R.Result[StrArr, str] {
    var out: StrArr;
    out.items = nil;
    out.count = 0;
    if (arr == nil) { ret R.ok[StrArr, str](out); }

    val n: usize = toml.array_len(arr);
    if (n == 0) { ret R.ok[StrArr, str](out); }

    val res_items: R.Result[*intern.StrId, str] = A.allocate[intern.StrId](alloc, n);
    if (R.is_err[*intern.StrId, str](res_items)) { ret R.err[StrArr, str](R.unwrap_err[*intern.StrId, str](res_items)); }
    out.items = R.unwrap_ok[*intern.StrId, str](res_items);
    out.count = n::u32;

    var i: usize = 0;
    for (i < n) {
        val v: *toml.Value = toml.array_get(arr, i);
        if (v == nil || v.tag != toml.TYPE_STRING) {
            A.deallocate[intern.StrId](alloc, out.items, n);
            ret R.err[StrArr, str](elem_err);
        }
        val res_elem: R.Result[intern.StrId, str] = intern.intern(itn, v.data.string);
        if (R.is_err[intern.StrId, str](res_elem)) {
            A.deallocate[intern.StrId](alloc, out.items, n);
            ret R.err[StrArr, str](R.unwrap_err[intern.StrId, str](res_elem));
        }
        out.items[i] = R.unwrap_ok[intern.StrId, str](res_elem);
        i = i + 1;
    }
    ret R.ok[StrArr, str](out);
}

# map a profile's integer `opt` level to an MOpt
#
# An absent key is MOPT_DEFAULT; `0` is MOPT_DEBUG; `1`/`2` are MOPT_RELEASE (1
# and 2 currently select the same pass set). A non-integer or out-of-range value
# is a manifest error naming the profile.
# ---
# alloc: allocator for the diagnostic
# name:  profile name, for the diagnostic
# sub:   the `[profile.<name>]` table
# ret:   ok(MOpt) on success, err naming the profile otherwise
fun parse_opt_level(alloc: *A.Allocator, name: str, sub: *toml.Table) R.Result[MOpt, str] {
    val v: *toml.Value = toml.get(sub, "opt");
    if (v == nil)                   { ret R.ok[MOpt, str](MOPT_DEFAULT); }
    if (v.tag != toml.TYPE_INTEGER) { ret R.err[MOpt, str](opt_err(alloc, name, v)); }
    val n: i64 = v.data.integer;
    if (n == 0)           { ret R.ok[MOpt, str](MOPT_DEBUG); }
    if (n == 1 || n == 2) { ret R.ok[MOpt, str](MOPT_RELEASE); }
    ret R.err[MOpt, str](opt_err(alloc, name, v));
}

# the `profile '<name>': opt must be 0, 1, or 2 (got <value>)` diagnostic
#
# Names the offending value so the user sees exactly what was rejected.
# ---
# alloc: allocator owning the message
# name:  profile name
# v:     the rejected `opt` value
# ret:   owned diagnostic string
fun opt_err(alloc: *A.Allocator, name: str, v: *toml.Value) str {
    ret cc5(alloc, "mach.toml: profile '", name, "': opt must be 0, 1, or 2 (got ",
        opt_value_text(alloc, v), ")");
}

# a human reading of an offending `opt` value for the diagnostic
# ---
# alloc: allocator owning any dynamic text
# v:     the value to describe
# ret:   a printable description of `v`
fun opt_value_text(alloc: *A.Allocator, v: *toml.Value) str {
    if (v.tag == toml.TYPE_INTEGER) { ret int_to_str(alloc, v.data.integer); }
    if (v.tag == toml.TYPE_STRING)  { ret cc3(alloc, "\"", v.data.string, "\""); }
    if (v.tag == toml.TYPE_BOOL) {
        if (v.data.boolean) { ret "true"; }
        ret "false";
    }
    if (v.tag == toml.TYPE_FLOAT) { ret "a float"; }
    if (v.tag == toml.TYPE_ARRAY) { ret "an array"; }
    if (v.tag == toml.TYPE_TABLE) { ret "a table"; }
    ret "a value";
}

# the decimal text of an i64, freshly allocated and owned by `alloc`
# ---
# alloc: allocator owning the result
# n:     value to render
# ret:   owned decimal string, or "?" on allocation failure
fun int_to_str(alloc: *A.Allocator, n: i64) str {
    if (n == 0) { ret "0"; }
    var neg: bool = false;
    var u: u64 = n::u64;
    if (n < 0) { neg = true; u = (0 - n)::u64; }

    var digits: [24]char;
    var len: usize = 0;
    for (u > 0) { digits[len] = (u % 10)::char + '0'; u = u / 10; len = len + 1; }

    var total: usize = len;
    if (neg) { total = total + 1; }
    val res_buf: R.Result[*u8, str] = A.allocate[u8](alloc, total + 1);
    if (R.is_err[*u8, str](res_buf)) { ret "?"; }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);
    var w: usize = 0;
    if (neg) { buf[0] = '-'; w = 1; }
    var i: usize = len;
    for (i > 0) { i = i - 1; buf[w] = digits[i]::u8; w = w + 1; }
    buf[w] = 0;
    ret buf::str;
}

# the "unknown key" diagnostic for `key` under `label`
# ---
# alloc: allocator owning the message
# key:   the offending key
# label: the table label it appeared in
# ret:   owned diagnostic string
fun unknown_key_msg(alloc: *A.Allocator, key: str, label: str) str {
    ret cc(alloc, cc3(alloc, "mach.toml: unknown key '", key, "' in "), label);
}

# whether `k` is an allowed key for the given table kind
# ---
# kind: the stanza kind being validated
# k:    the key to test
# ret:  true when `k` is in `kind`'s allowlist
fun key_known(kind: TableKind, k: str) bool {
    if (kind == TK_PROJECT) {
        ret str_equals(k, "id") || str_equals(k, "version") || str_equals(k, "name")
            || str_equals(k, "description") || str_equals(k, "license") || str_equals(k, "authors")
            || str_equals(k, "module") || str_equals(k, "src") || str_equals(k, "dep")
            || str_equals(k, "target") || str_equals(k, "out") || str_equals(k, "obj")
            || str_equals(k, "ir") || str_equals(k, "asm") || str_equals(k, "tests");
    }
    if (kind == TK_OS) {
        ret str_equals(k, "libs");
    }
    if (kind == TK_TARGET) {
        ret str_equals(k, "isa") || str_equals(k, "os") || str_equals(k, "abi")
            || str_equals(k, "ext") || str_equals(k, "libs") || str_equals(k, "defines");
    }
    if (kind == TK_BIN) {
        ret str_equals(k, "entry") || str_equals(k, "out") || str_equals(k, "libs")
            || str_equals(k, "defines") || str_equals(k, "target");
    }
    if (kind == TK_LIB) {
        ret str_equals(k, "entry") || str_equals(k, "kind") || str_equals(k, "out")
            || str_equals(k, "libs") || str_equals(k, "defines") || str_equals(k, "target");
    }
    if (kind == TK_PROFILE) {
        ret str_equals(k, "opt") || str_equals(k, "emit_ir") || str_equals(k, "emit_asm");
    }
    if (kind == TK_DEP) {
        ret str_equals(k, "git") || str_equals(k, "path") || str_equals(k, "ref");
    }
    if (kind == TK_CELL) {
        ret str_equals(k, "entry") || str_equals(k, "out") || str_equals(k, "libs") || str_equals(k, "defines");
    }
    ret false;
}

# reject the first unknown key in `tab` for the given table kind
# ---
# alloc: allocator for the diagnostic
# tab:   table whose keys to validate
# label: stanza label for the diagnostic
# kind:  the stanza kind being validated
# ret:   ok(true) when every key is known, err naming the first unknown key
fun check_keys(alloc: *A.Allocator, tab: *toml.Table, label: str, kind: TableKind) R.Result[bool, str] {
    val n: usize = toml.table_len(tab);
    var i: usize = 0;
    for (i < n) {
        val k: str = toml.table_key(tab, i);
        if (!key_known(kind, k)) { ret R.err[bool, str](unknown_key_msg(alloc, k, label)); }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# reject a `\` in a path/template field, naming the offending value
# ---
# alloc: allocator for the diagnostic
# value: the path or template text
# field: field label for the diagnostic
# ret:   ok(true) when clean, err when `value` holds a backslash
fun check_path(alloc: *A.Allocator, value: str, field: str) R.Result[bool, str] {
    if (has_backslash(value)) {
        ret R.err[bool, str](cc3(alloc, "mach.toml: ", field, " contains a '\\'; manifest paths use '/'"));
    }
    ret R.ok[bool, str](true);
}

# `a` when it is non-empty, else `b`
# ---
# a:   preferred value
# b:   fallback value
# ret: `a` if non-empty, otherwise `b`
fun first_nonempty(a: str, b: str) str {
    if (str_empty(a)) { ret b; }
    ret a;
}

# the boolean value, or `default` when absent/mistyped
# ---
# o:       the optional boolean
# default: value when `o` is absent
# ret:     the boolean in `o`, or `default`
fun bool_or(o: O.Option[bool], default: bool) bool {
    if (O.is_some[bool](o)) { ret O.unwrap[bool](o); }
    ret default;
}

# the string in `o`, or "" when absent
# ---
# o:   the optional string
# ret: the string in `o`, or ""
fun first_nonempty_opt(o: O.Option[str]) str {
    if (O.is_some[str](o)) { ret O.unwrap[str](o); }
    ret "";
}

# read a v2 manifest from an already-parsed TOML table
#
# Validates loudly (unknown keys, missing required keys, reserved names, `\` in
# paths) and returns a fully populated Manifest, or the first diagnostic.
# ---
# alloc: allocator owning the Manifest's arrays and any diagnostics
# itn:   interner for every stored string
# t:     the parsed top-level TOML table
# ret:   ok(Manifest) on success, err with the first diagnostic
pub fun parse(alloc: *A.Allocator, itn: *intern.Interner, t: *toml.Table) R.Result[Manifest, str] {
    var m: Manifest;
    m.targets          = nil;
    m.target_count     = 0;
    m.artifacts        = nil;
    m.artifact_count   = 0;
    m.profiles         = nil;
    m.profile_count    = 0;
    m.deps             = nil;
    m.dep_count        = 0;
    m.os_overlays      = nil;
    m.os_overlay_count = 0;

    val proj: *toml.Table = toml.get_table(t, "project");
    if (proj == nil) { ret R.err[Manifest, str]("mach.toml: missing [project] table"); }
    val res_project_keys: R.Result[bool, str] = check_keys(alloc, proj, "[project]", TK_PROJECT);
    if (R.is_err[bool, str](res_project_keys)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_project_keys)); }

    val id_str: str = toml.get_str(proj, "id");
    if (str_empty(id_str)) { ret R.err[Manifest, str]("mach.toml: [project] is missing required key 'id'"); }
    val ver_str: str = toml.get_str(proj, "version");
    if (str_empty(ver_str)) { ret R.err[Manifest, str]("mach.toml: [project] is missing required key 'version'"); }

    val src_str:   str = first_nonempty(toml.get_str(proj, "src"), "src");
    val dep_str:   str = first_nonempty(toml.get_str(proj, "dep"), "dep");
    val out_str:   str = first_nonempty(toml.get_str(proj, "out"), DEFAULT_OUT);
    val obj_str:   str = first_nonempty(toml.get_str(proj, "obj"), DEFAULT_OBJ);
    val ir_str:    str = first_nonempty(toml.get_str(proj, "ir"),  DEFAULT_IR);
    val asm_str:   str = first_nonempty(toml.get_str(proj, "asm"), DEFAULT_ASM);
    val tests_str: str = first_nonempty(toml.get_str(proj, "tests"), DEFAULT_TESTS);

    val res_check_src: R.Result[bool, str] = check_path(alloc, src_str, "[project].src");
    if (R.is_err[bool, str](res_check_src)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_src)); }
    val res_check_dep: R.Result[bool, str] = check_path(alloc, dep_str, "[project].dep");
    if (R.is_err[bool, str](res_check_dep)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_dep)); }
    val res_check_out: R.Result[bool, str] = check_path(alloc, out_str, "[project].out");
    if (R.is_err[bool, str](res_check_out)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_out)); }
    val res_check_obj: R.Result[bool, str] = check_path(alloc, obj_str, "[project].obj");
    if (R.is_err[bool, str](res_check_obj)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_obj)); }
    val res_check_ir: R.Result[bool, str] = check_path(alloc, ir_str, "[project].ir");
    if (R.is_err[bool, str](res_check_ir)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_ir)); }
    val res_check_asm: R.Result[bool, str] = check_path(alloc, asm_str, "[project].asm");
    if (R.is_err[bool, str](res_check_asm)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_asm)); }
    val res_check_tests: R.Result[bool, str] = check_path(alloc, tests_str, "[project].tests");
    if (R.is_err[bool, str](res_check_tests)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_tests)); }

    val res_id: R.Result[intern.StrId, str] = intern.intern(itn, id_str);
    if (R.is_err[intern.StrId, str](res_id)) { ret R.err[Manifest, str](R.unwrap_err[intern.StrId, str](res_id)); }
    m.id = R.unwrap_ok[intern.StrId, str](res_id);
    val res_version: R.Result[intern.StrId, str] = intern.intern(itn, ver_str);
    if (R.is_err[intern.StrId, str](res_version)) { ret R.err[Manifest, str](R.unwrap_err[intern.StrId, str](res_version)); }
    m.version = R.unwrap_ok[intern.StrId, str](res_version);

    val res_name: R.Result[intern.StrId, str] = intern_opt(itn, toml.get_str(proj, "name"));
    if (R.is_err[intern.StrId, str](res_name)) { ret R.err[Manifest, str](R.unwrap_err[intern.StrId, str](res_name)); }
    m.name = R.unwrap_ok[intern.StrId, str](res_name);
    val res_description: R.Result[intern.StrId, str] = intern_opt(itn, toml.get_str(proj, "description"));
    if (R.is_err[intern.StrId, str](res_description)) { ret R.err[Manifest, str](R.unwrap_err[intern.StrId, str](res_description)); }
    m.description = R.unwrap_ok[intern.StrId, str](res_description);
    val res_license: R.Result[intern.StrId, str] = intern_opt(itn, toml.get_str(proj, "license"));
    if (R.is_err[intern.StrId, str](res_license)) { ret R.err[Manifest, str](R.unwrap_err[intern.StrId, str](res_license)); }
    m.license = R.unwrap_ok[intern.StrId, str](res_license);

    val module_str: str = toml.get_str(proj, "module");
    val res_check_module: R.Result[bool, str] = check_path(alloc, module_str, "[project].module");
    if (R.is_err[bool, str](res_check_module)) { ret R.err[Manifest, str](R.unwrap_err[bool, str](res_check_module)); }
    val res_module: R.Result[intern.StrId, str] = intern_opt(itn, module_str);
    if (R.is_err[intern.StrId, str](res_module)) { ret R.err[Manifest, str](R.unwrap_err[intern.StrId, str](res_module)); }
    m.module = R.unwrap_ok[intern.StrId, str](res_module);

    m.src            = intern_unwrap(itn, src_str);
    m.dep            = intern_unwrap(itn, dep_str);
    m.out_tmpl       = intern_unwrap(itn, out_str);
    m.obj_tmpl       = intern_unwrap(itn, obj_str);
    m.ir_tmpl        = intern_unwrap(itn, ir_str);
    m.asm_tmpl       = intern_unwrap(itn, asm_str);
    m.tests_tmpl     = intern_unwrap(itn, tests_str);
    m.default_target = intern_unwrap(itn, first_nonempty(toml.get_str(proj, "target"), "native"));

    val res_targets: R.Result[bool, str] = parse_targets(alloc, itn, t, ?m);
    if (R.is_err[bool, str](res_targets)) { dnit(?m, alloc); ret R.err[Manifest, str](R.unwrap_err[bool, str](res_targets)); }

    val res_artifacts: R.Result[bool, str] = parse_artifacts(alloc, itn, t, ?m);
    if (R.is_err[bool, str](res_artifacts)) { dnit(?m, alloc); ret R.err[Manifest, str](R.unwrap_err[bool, str](res_artifacts)); }

    val res_profiles: R.Result[bool, str] = parse_profiles(alloc, itn, t, ?m);
    if (R.is_err[bool, str](res_profiles)) { dnit(?m, alloc); ret R.err[Manifest, str](R.unwrap_err[bool, str](res_profiles)); }

    val res_deps: R.Result[bool, str] = parse_deps(alloc, itn, t, ?m);
    if (R.is_err[bool, str](res_deps)) { dnit(?m, alloc); ret R.err[Manifest, str](R.unwrap_err[bool, str](res_deps)); }

    # `[isa.*]`/`[abi.*]` single-component overlays are reserved until a real case
    # demands them; only `[os.*]` is implemented today.
    if (toml.get_table(t, "isa") != nil) { dnit(?m, alloc); ret R.err[Manifest, str]("mach.toml: [isa.*] overlays are reserved"); }
    if (toml.get_table(t, "abi") != nil) { dnit(?m, alloc); ret R.err[Manifest, str]("mach.toml: [abi.*] overlays are reserved"); }

    val res_os_overlays: R.Result[bool, str] = parse_os_overlays(alloc, itn, t, ?m);
    if (R.is_err[bool, str](res_os_overlays)) { dnit(?m, alloc); ret R.err[Manifest, str](R.unwrap_err[bool, str](res_os_overlays)); }

    ret R.ok[Manifest, str](m);
}

# read every `[target.<name>]` stanza
#
# Declaring `[target.native]` is a hard error - `native` is the reserved
# host-resolution selector.
# ---
# alloc: allocator owning the target array
# itn:   interner for stored strings
# t:     the top-level TOML table
# m:     the manifest being populated
# ret:   ok(true) on success, err with the first diagnostic
fun parse_targets(alloc: *A.Allocator, itn: *intern.Interner, t: *toml.Table, m: *Manifest) R.Result[bool, str] {
    val tab: *toml.Table = toml.get_table(t, "target");
    if (tab == nil) { ret R.ok[bool, str](true); }
    val n: usize = toml.table_len(tab);
    if (n == 0) { ret R.ok[bool, str](true); }

    val res_targets: R.Result[*TargetDef, str] = A.allocate[TargetDef](alloc, n);
    if (R.is_err[*TargetDef, str](res_targets)) { ret R.err[bool, str](R.unwrap_err[*TargetDef, str](res_targets)); }
    m.targets      = R.unwrap_ok[*TargetDef, str](res_targets);
    m.target_count = n::u32;

    var i: usize = 0;
    for (i < n) {
        val name: str = toml.table_key(tab, i);
        if (str_equals(name, "native")) {
            ret R.err[bool, str]("mach.toml: [target.native] is reserved; 'native' resolves to a declared target");
        }
        val v: *toml.Value = toml.table_value(tab, i);
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: [target.", name, "] must be a table"));
        }
        val sub: *toml.Table = ?v.data.table;
        val label: str = cc3(alloc, "[target.", name, "]");
        val res_keys: R.Result[bool, str] = check_keys(alloc, sub, label, TK_TARGET);
        if (R.is_err[bool, str](res_keys)) { ret res_keys; }

        var d: TargetDef;
        d.libs         = nil;
        d.lib_count    = 0;
        d.defines      = nil;
        d.define_count = 0;
        d.name = intern_unwrap(itn, name);

        val isa_s: str = toml.get_str(sub, "isa");
        if (str_empty(isa_s)) { ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " is missing required key 'isa'")); }
        val os_s: str = toml.get_str(sub, "os");
        if (str_empty(os_s)) { ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " is missing required key 'os'")); }
        val abi_s: str = toml.get_str(sub, "abi");
        if (str_empty(abi_s)) { ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " is missing required key 'abi'")); }
        d.isa = intern_unwrap(itn, isa_s);
        d.os  = intern_unwrap(itn, os_s);
        d.abi = intern_unwrap(itn, abi_s);
        d.ext = intern_unwrap(itn, first_nonempty(toml.get_str(sub, "ext"), ""));

        val res_libs: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(sub, "libs"),
            cc3(alloc, "mach.toml: ", label, ".libs must be an array of strings"));
        if (R.is_err[StrArr, str](res_libs)) { ret R.err[bool, str](R.unwrap_err[StrArr, str](res_libs)); }
        val libs: StrArr = R.unwrap_ok[StrArr, str](res_libs);
        d.libs      = libs.items;
        d.lib_count = libs.count;

        val res_defines: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(sub, "defines"),
            cc3(alloc, "mach.toml: ", label, ".defines must be an array of strings"));
        if (R.is_err[StrArr, str](res_defines)) { ret R.err[bool, str](R.unwrap_err[StrArr, str](res_defines)); }
        val defines: StrArr = R.unwrap_ok[StrArr, str](res_defines);
        d.defines      = defines.items;
        d.define_count = defines.count;

        m.targets[i] = d;
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# read every `[bin.<name>]` and `[lib.<name>]` stanza
#
# Both kinds land in the single artifact array, bins first then libs, in
# declaration order.
# ---
# alloc: allocator owning the artifact array
# itn:   interner for stored strings
# t:     the top-level TOML table
# m:     the manifest being populated
# ret:   ok(true) on success, err with the first diagnostic
fun parse_artifacts(alloc: *A.Allocator, itn: *intern.Interner, t: *toml.Table, m: *Manifest) R.Result[bool, str] {
    val bins: *toml.Table = toml.get_table(t, "bin");
    val libs: *toml.Table = toml.get_table(t, "lib");
    var bn: usize = 0;
    var ln: usize = 0;
    if (bins != nil) { bn = toml.table_len(bins); }
    if (libs != nil) { ln = toml.table_len(libs); }
    val total: usize = bn + ln;
    if (total == 0) { ret R.ok[bool, str](true); }

    val res_artifacts: R.Result[*ArtifactDef, str] = A.allocate[ArtifactDef](alloc, total);
    if (R.is_err[*ArtifactDef, str](res_artifacts)) { ret R.err[bool, str](R.unwrap_err[*ArtifactDef, str](res_artifacts)); }
    m.artifacts      = R.unwrap_ok[*ArtifactDef, str](res_artifacts);
    m.artifact_count = total::u32;

    var w: usize = 0;
    if (bins != nil) {
        var i: usize = 0;
        for (i < bn) {
            val res_artifact: R.Result[ArtifactDef, str] = parse_one_artifact(alloc, itn, bins, i, false);
            if (R.is_err[ArtifactDef, str](res_artifact)) { ret R.err[bool, str](R.unwrap_err[ArtifactDef, str](res_artifact)); }
            m.artifacts[w] = R.unwrap_ok[ArtifactDef, str](res_artifact);
            w = w + 1;
            i = i + 1;
        }
    }
    if (libs != nil) {
        var i: usize = 0;
        for (i < ln) {
            val res_artifact: R.Result[ArtifactDef, str] = parse_one_artifact(alloc, itn, libs, i, true);
            if (R.is_err[ArtifactDef, str](res_artifact)) { ret R.err[bool, str](R.unwrap_err[ArtifactDef, str](res_artifact)); }
            m.artifacts[w] = R.unwrap_ok[ArtifactDef, str](res_artifact);
            w = w + 1;
            i = i + 1;
        }
    }
    ret R.ok[bool, str](true);
}

# read one artifact stanza at index `k` of its `[bin]`/`[lib]` container table
# ---
# alloc:  allocator owning the artifact's owned arrays
# itn:    interner for stored strings
# tab:    the `[bin]` or `[lib]` container table
# k:      index of the artifact within `tab`
# is_lib: true for a `[lib.*]` stanza, false for `[bin.*]`
# ret:    ok(ArtifactDef) on success, err with the first diagnostic
fun parse_one_artifact(alloc: *A.Allocator, itn: *intern.Interner, tab: *toml.Table, k: usize, is_lib: bool) R.Result[ArtifactDef, str] {
    val name: str = toml.table_key(tab, k);
    val v: *toml.Value = toml.table_value(tab, k);
    var kind_tag: str = "bin";
    if (is_lib) { kind_tag = "lib"; }
    val label: str = cc5(alloc, "[", kind_tag, ".", name, "]");
    if (v == nil || v.tag != toml.TYPE_TABLE) {
        ret R.err[ArtifactDef, str](cc3(alloc, "mach.toml: ", label, " must be a table"));
    }
    val sub: *toml.Table = ?v.data.table;

    var tk: TableKind = TK_BIN;
    if (is_lib) { tk = TK_LIB; }
    val res_keys: R.Result[bool, str] = check_keys(alloc, sub, label, tk);
    if (R.is_err[bool, str](res_keys)) { ret R.err[ArtifactDef, str](R.unwrap_err[bool, str](res_keys)); }

    var a: ArtifactDef;
    a.libs         = nil;
    a.lib_count    = 0;
    a.defines      = nil;
    a.define_count = 0;
    a.cells        = nil;
    a.cell_count   = 0;
    a.name   = intern_unwrap(itn, name);
    a.is_lib = is_lib;
    a.kind   = LIBKIND_STATIC;

    val entry_s: str = toml.get_str(sub, "entry");
    if (str_empty(entry_s)) { ret R.err[ArtifactDef, str](cc3(alloc, "mach.toml: ", label, " is missing required key 'entry'")); }
    val res_check_entry: R.Result[bool, str] = check_path(alloc, entry_s, cc(alloc, label, ".entry"));
    if (R.is_err[bool, str](res_check_entry)) { ret R.err[ArtifactDef, str](R.unwrap_err[bool, str](res_check_entry)); }
    a.entry = intern_unwrap(itn, entry_s);

    if (is_lib) {
        val kind_s: str = toml.get_str(sub, "kind");
        if (!str_empty(kind_s)) {
            if (str_equals(kind_s, "static")) { a.kind = LIBKIND_STATIC; }
            or (str_equals(kind_s, "shared")) { a.kind = LIBKIND_SHARED; }
            or {
                ret R.err[ArtifactDef, str](cc3(alloc, "mach.toml: ", label, ".kind must be \"static\" or \"shared\""));
            }
        }
    }

    val out_s: str = toml.get_str(sub, "out");
    if (!str_empty(out_s)) {
        val res_check_out: R.Result[bool, str] = check_path(alloc, out_s, cc(alloc, label, ".out"));
        if (R.is_err[bool, str](res_check_out)) { ret R.err[ArtifactDef, str](R.unwrap_err[bool, str](res_check_out)); }
        a.out = intern_unwrap(itn, out_s);
    }
    or { a.out = intern.STR_NIL; }

    val res_libs: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(sub, "libs"),
        cc3(alloc, "mach.toml: ", label, ".libs must be an array of strings"));
    if (R.is_err[StrArr, str](res_libs)) { ret R.err[ArtifactDef, str](R.unwrap_err[StrArr, str](res_libs)); }
    val libs: StrArr = R.unwrap_ok[StrArr, str](res_libs);
    a.libs      = libs.items;
    a.lib_count = libs.count;

    val res_defines: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(sub, "defines"),
        cc3(alloc, "mach.toml: ", label, ".defines must be an array of strings"));
    if (R.is_err[StrArr, str](res_defines)) { ret R.err[ArtifactDef, str](R.unwrap_err[StrArr, str](res_defines)); }
    val defines: StrArr = R.unwrap_ok[StrArr, str](res_defines);
    a.defines      = defines.items;
    a.define_count = defines.count;

    val res_cells: R.Result[bool, str] = parse_cells(alloc, itn, sub, kind_tag, name, ?a);
    if (R.is_err[bool, str](res_cells)) { ret R.err[ArtifactDef, str](R.unwrap_err[bool, str](res_cells)); }

    ret R.ok[ArtifactDef, str](a);
}

# read an artifact's `[<kind>.<name>.target.<t>]` per-cell stanzas
# ---
# alloc:    allocator owning the cell array
# itn:      interner for stored strings
# sub:      the artifact's own table
# kind_tag: "bin" or "lib", for cell labels
# art_name: the artifact name, for cell labels
# a:        the artifact being populated
# ret:      ok(true) on success, err with the first diagnostic
fun parse_cells(alloc: *A.Allocator, itn: *intern.Interner, sub: *toml.Table, kind_tag: str, art_name: str, a: *ArtifactDef) R.Result[bool, str] {
    val ct: *toml.Table = toml.get_table(sub, "target");
    if (ct == nil) { ret R.ok[bool, str](true); }
    val n: usize = toml.table_len(ct);
    if (n == 0) { ret R.ok[bool, str](true); }

    val res_cells: R.Result[*CellDef, str] = A.allocate[CellDef](alloc, n);
    if (R.is_err[*CellDef, str](res_cells)) { ret R.err[bool, str](R.unwrap_err[*CellDef, str](res_cells)); }
    a.cells      = R.unwrap_ok[*CellDef, str](res_cells);
    a.cell_count = n::u32;

    var i: usize = 0;
    for (i < n) {
        val tname: str = toml.table_key(ct, i);
        val v: *toml.Value = toml.table_value(ct, i);
        val label: str = cc5(alloc, cc3(alloc, "[", kind_tag, "."), art_name, ".target.", tname, "]");
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " must be a table"));
        }
        val cs: *toml.Table = ?v.data.table;
        val res_keys: R.Result[bool, str] = check_keys(alloc, cs, label, TK_CELL);
        if (R.is_err[bool, str](res_keys)) { ret res_keys; }

        var c: CellDef;
        c.libs         = nil;
        c.lib_count    = 0;
        c.defines      = nil;
        c.define_count = 0;
        c.target = intern_unwrap(itn, tname);
        c.entry  = intern_opt_unwrap(itn, toml.get_str(cs, "entry"));
        c.out    = intern_opt_unwrap(itn, toml.get_str(cs, "out"));

        val res_libs: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(cs, "libs"),
            cc3(alloc, "mach.toml: ", label, ".libs must be an array of strings"));
        if (R.is_err[StrArr, str](res_libs)) { ret R.err[bool, str](R.unwrap_err[StrArr, str](res_libs)); }
        val libs: StrArr = R.unwrap_ok[StrArr, str](res_libs);
        c.libs      = libs.items;
        c.lib_count = libs.count;

        val res_defines: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(cs, "defines"),
            cc3(alloc, "mach.toml: ", label, ".defines must be an array of strings"));
        if (R.is_err[StrArr, str](res_defines)) { ret R.err[bool, str](R.unwrap_err[StrArr, str](res_defines)); }
        val defines: StrArr = R.unwrap_ok[StrArr, str](res_defines);
        c.defines      = defines.items;
        c.define_count = defines.count;

        a.cells[i] = c;
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# read every `[profile.<name>]` build variant
# ---
# alloc: allocator owning the profile array
# itn:   interner for stored strings
# t:     the top-level TOML table
# m:     the manifest being populated
# ret:   ok(true) on success, err with the first diagnostic
fun parse_profiles(alloc: *A.Allocator, itn: *intern.Interner, t: *toml.Table, m: *Manifest) R.Result[bool, str] {
    val tab: *toml.Table = toml.get_table(t, "profile");
    if (tab == nil) { ret R.ok[bool, str](true); }
    val n: usize = toml.table_len(tab);
    if (n == 0) { ret R.ok[bool, str](true); }

    val res_profiles: R.Result[*ProfileDef, str] = A.allocate[ProfileDef](alloc, n);
    if (R.is_err[*ProfileDef, str](res_profiles)) { ret R.err[bool, str](R.unwrap_err[*ProfileDef, str](res_profiles)); }
    m.profiles      = R.unwrap_ok[*ProfileDef, str](res_profiles);
    m.profile_count = n::u32;

    var i: usize = 0;
    for (i < n) {
        val name: str = toml.table_key(tab, i);
        val v: *toml.Value = toml.table_value(tab, i);
        val label: str = cc3(alloc, "[profile.", name, "]");
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " must be a table"));
        }
        val sub: *toml.Table = ?v.data.table;
        val res_keys: R.Result[bool, str] = check_keys(alloc, sub, label, TK_PROFILE);
        if (R.is_err[bool, str](res_keys)) { ret res_keys; }

        var pf: ProfileDef;
        pf.name = intern_unwrap(itn, name);
        val res_opt: R.Result[MOpt, str] = parse_opt_level(alloc, name, sub);
        if (R.is_err[MOpt, str](res_opt)) { ret R.err[bool, str](R.unwrap_err[MOpt, str](res_opt)); }
        pf.opt      = R.unwrap_ok[MOpt, str](res_opt);
        pf.emit_ir  = bool_or(toml.get_bool(sub, "emit_ir"), false);
        pf.emit_asm = bool_or(toml.get_bool(sub, "emit_asm"), false);

        m.profiles[i] = pf;
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# read every `[deps.<name>]` dependency
#
# Exactly one of `git`/`path` is required; a registry-style `version =` is
# reserved and rejected.
# ---
# alloc: allocator owning the dep array
# itn:   interner for stored strings
# t:     the top-level TOML table
# m:     the manifest being populated
# ret:   ok(true) on success, err with the first diagnostic
fun parse_deps(alloc: *A.Allocator, itn: *intern.Interner, t: *toml.Table, m: *Manifest) R.Result[bool, str] {
    val tab: *toml.Table = toml.get_table(t, "deps");
    if (tab == nil) { ret R.ok[bool, str](true); }
    val n: usize = toml.table_len(tab);
    if (n == 0) { ret R.ok[bool, str](true); }

    val res_deps: R.Result[*DepDef, str] = A.allocate[DepDef](alloc, n);
    if (R.is_err[*DepDef, str](res_deps)) { ret R.err[bool, str](R.unwrap_err[*DepDef, str](res_deps)); }
    m.deps      = R.unwrap_ok[*DepDef, str](res_deps);
    m.dep_count = n::u32;

    var i: usize = 0;
    for (i < n) {
        val name: str = toml.table_key(tab, i);
        val v: *toml.Value = toml.table_value(tab, i);
        val label: str = cc3(alloc, "[deps.", name, "]");
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " must be a table"));
        }
        val sub: *toml.Table = ?v.data.table;

        if (toml.get(sub, "version") != nil) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, ".version is reserved for the registry era"));
        }
        val res_keys: R.Result[bool, str] = check_keys(alloc, sub, label, TK_DEP);
        if (R.is_err[bool, str](res_keys)) { ret res_keys; }

        var d: DepDef;
        d.name = intern_unwrap(itn, name);
        val git_s:  str = toml.get_str(sub, "git");
        val path_s: str = toml.get_str(sub, "path");
        val has_git:  bool = !str_empty(git_s);
        val has_path: bool = !str_empty(path_s);
        if (has_git == has_path) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " needs exactly one source key: 'git' or 'path'"));
        }
        d.git  = intern_opt_unwrap(itn, git_s);
        d.path = intern_opt_unwrap(itn, path_s);
        d.ref  = intern_opt_unwrap(itn, toml.get_str(sub, "ref"));

        m.deps[i] = d;
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# read every `[os.<name>] libs = [...]` link overlay
#
# Each stanza accepts only the `libs` key; the os name is the table key and gates
# the overlay by tuple-component (os) equality.
# ---
# alloc: allocator owning the overlay array
# itn:   interner for stored strings
# t:     the top-level TOML table
# m:     the manifest being populated
# ret:   ok(true) on success, err with the first diagnostic
fun parse_os_overlays(alloc: *A.Allocator, itn: *intern.Interner, t: *toml.Table, m: *Manifest) R.Result[bool, str] {
    val tab: *toml.Table = toml.get_table(t, "os");
    if (tab == nil) { ret R.ok[bool, str](true); }
    val n: usize = toml.table_len(tab);
    if (n == 0) { ret R.ok[bool, str](true); }

    val res_overlays: R.Result[*OsDef, str] = A.allocate[OsDef](alloc, n);
    if (R.is_err[*OsDef, str](res_overlays)) { ret R.err[bool, str](R.unwrap_err[*OsDef, str](res_overlays)); }
    m.os_overlays      = R.unwrap_ok[*OsDef, str](res_overlays);
    m.os_overlay_count = n::u32;

    var i: usize = 0;
    for (i < n) {
        val name: str = toml.table_key(tab, i);
        val v: *toml.Value = toml.table_value(tab, i);
        val label: str = cc3(alloc, "[os.", name, "]");
        if (v == nil || v.tag != toml.TYPE_TABLE) {
            ret R.err[bool, str](cc3(alloc, "mach.toml: ", label, " must be a table"));
        }
        val sub: *toml.Table = ?v.data.table;
        val res_keys: R.Result[bool, str] = check_keys(alloc, sub, label, TK_OS);
        if (R.is_err[bool, str](res_keys)) { ret res_keys; }

        var d: OsDef;
        d.libs      = nil;
        d.lib_count = 0;
        d.name = intern_unwrap(itn, name);

        val res_libs: R.Result[StrArr, str] = parse_str_array(alloc, itn, toml.get_array(sub, "libs"),
            cc3(alloc, "mach.toml: ", label, ".libs must be an array of strings"));
        if (R.is_err[StrArr, str](res_libs)) { ret R.err[bool, str](R.unwrap_err[StrArr, str](res_libs)); }
        val libs: StrArr = R.unwrap_ok[StrArr, str](res_libs);
        d.libs      = libs.items;
        d.lib_count = libs.count;

        m.os_overlays[i] = d;
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# release every owned array on a Manifest (and its nested overlays)
# ---
# m:     the manifest to tear down
# alloc: the allocator its arrays were allocated from
pub fun dnit(m: *Manifest, alloc: *A.Allocator) {
    if (m.targets != nil && m.target_count > 0) {
        var i: u32 = 0;
        for (i < m.target_count) {
            free_strarr(alloc, m.targets[i].libs, m.targets[i].lib_count);
            free_strarr(alloc, m.targets[i].defines, m.targets[i].define_count);
            i = i + 1;
        }
        A.deallocate[TargetDef](alloc, m.targets, m.target_count::usize);
        m.targets = nil;
        m.target_count = 0;
    }
    if (m.artifacts != nil && m.artifact_count > 0) {
        var i: u32 = 0;
        for (i < m.artifact_count) {
            val a: *ArtifactDef = ?m.artifacts[i];
            free_strarr(alloc, a.libs, a.lib_count);
            free_strarr(alloc, a.defines, a.define_count);
            if (a.cells != nil && a.cell_count > 0) {
                var ii: u32 = 0;
                for (ii < a.cell_count) {
                    free_strarr(alloc, a.cells[ii].libs, a.cells[ii].lib_count);
                    free_strarr(alloc, a.cells[ii].defines, a.cells[ii].define_count);
                    ii = ii + 1;
                }
                A.deallocate[CellDef](alloc, a.cells, a.cell_count::usize);
            }
            i = i + 1;
        }
        A.deallocate[ArtifactDef](alloc, m.artifacts, m.artifact_count::usize);
        m.artifacts = nil;
        m.artifact_count = 0;
    }
    if (m.profiles != nil && m.profile_count > 0) {
        A.deallocate[ProfileDef](alloc, m.profiles, m.profile_count::usize);
        m.profiles = nil;
        m.profile_count = 0;
    }
    if (m.deps != nil && m.dep_count > 0) {
        A.deallocate[DepDef](alloc, m.deps, m.dep_count::usize);
        m.deps = nil;
        m.dep_count = 0;
    }
    if (m.os_overlays != nil && m.os_overlay_count > 0) {
        var i: u32 = 0;
        for (i < m.os_overlay_count) {
            free_strarr(alloc, m.os_overlays[i].libs, m.os_overlays[i].lib_count);
            i = i + 1;
        }
        A.deallocate[OsDef](alloc, m.os_overlays, m.os_overlay_count::usize);
        m.os_overlays = nil;
        m.os_overlay_count = 0;
    }
}

# release an interned string array, if any
# ---
# alloc: the allocator it was allocated from
# items: the array, nil for none
# count: number of entries in items
fun free_strarr(alloc: *A.Allocator, items: *intern.StrId, count: u32) {
    if (items != nil && count > 0) {
        A.deallocate[intern.StrId](alloc, items, count::usize);
    }
}

# whether the byte range tmpl[start, end) equals `lit`
# ---
# tmpl:  the template text
# start: inclusive start of the range
# end:   exclusive end of the range
# lit:   the literal to compare against
# ret:   true when the range equals `lit`
fun seg_eq(tmpl: str, start: usize, end: usize, lit: str) bool {
    val ll: usize = str_len(lit);
    if (end - start != ll) { ret false; }
    var i: usize = 0;
    for (i < ll) {
        if (tmpl[start + i] != lit[i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

# an owned copy of the byte range tmpl[start, end)
# ---
# alloc: allocator owning the copy
# tmpl:  the template text
# start: inclusive start of the range
# end:   exclusive end of the range
# ret:   owned copy of the range, or "" on allocation failure
fun seg_dup(alloc: *A.Allocator, tmpl: str, start: usize, end: usize) str {
    val n: usize = end - start;
    val res_buf: R.Result[*u8, str] = A.allocate[u8](alloc, n + 1);
    if (R.is_err[*u8, str](res_buf)) { ret ""; }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);
    var i: usize = 0;
    for (i < n) { buf[i] = tmpl[start + i]; i = i + 1; }
    buf[n] = 0;
    ret buf::str;
}

# the substitution string for the variable named by tmpl[start, end)
#
# Only `{target} {profile} {name} {ext}` are valid; anything else is an error.
# ---
# alloc:        allocator for the diagnostic
# tmpl:         the template text
# start:        inclusive start of the variable name
# end:          exclusive end of the variable name
# target_name:  value for `{target}`
# profile_name: value for `{profile}`
# art_name:     value for `{name}`
# ext:          value for `{ext}`
# ret:          ok(substitution) for a known variable, err otherwise
fun tmpl_value(alloc: *A.Allocator, tmpl: str, start: usize, end: usize,
               target_name: str, profile_name: str, art_name: str, ext: str) R.Result[str, str] {
    if (seg_eq(tmpl, start, end, "target"))  { ret R.ok[str, str](target_name); }
    if (seg_eq(tmpl, start, end, "profile")) { ret R.ok[str, str](profile_name); }
    if (seg_eq(tmpl, start, end, "name"))    { ret R.ok[str, str](art_name); }
    if (seg_eq(tmpl, start, end, "ext"))     { ret R.ok[str, str](ext); }
    ret R.err[str, str](cc3(alloc, "mach.toml: unknown template variable '{", seg_dup(alloc, tmpl, start, end), "}'"));
}

# expand a `/`-canonical path template over `{target} {profile} {name} {ext}`
#
# Paths stay `/`-separated (the canonical form, accepted on every host); the
# filesystem layer normalizes to the host separator at the boundary, so a
# template is never partially converted to mix separators.
# ---
# alloc:        allocator owning the result
# tmpl:         the template text
# target_name:  value for `{target}`
# profile_name: value for `{profile}`
# art_name:     value for `{name}`
# ext:          value for `{ext}`
# ret:          ok(owned expanded path) on success, err on a bad variable or unterminated `{`
pub fun expand(alloc: *A.Allocator, tmpl: str,
               target_name: str, profile_name: str, art_name: str, ext: str) R.Result[str, str] {
    val n: usize = str_len(tmpl);

    # pass 1: measure the expanded length.
    var total: usize = 0;
    var i: usize = 0;
    for (i < n) {
        if (tmpl[i] == '{') {
            var ii: usize = i + 1;
            for (ii < n && tmpl[ii] != '}') { ii = ii + 1; }
            if (ii >= n) { ret R.err[str, str]("mach.toml: unterminated '{' in a path template"); }
            val res_value: R.Result[str, str] = tmpl_value(alloc, tmpl, i + 1, ii, target_name, profile_name, art_name, ext);
            if (R.is_err[str, str](res_value)) { ret R.err[str, str](R.unwrap_err[str, str](res_value)); }
            total = total + str_len(R.unwrap_ok[str, str](res_value));
            i = ii + 1;
        }
        or {
            total = total + 1;
            i = i + 1;
        }
    }

    val res_buf: R.Result[*u8, str] = A.allocate[u8](alloc, total + 1);
    if (R.is_err[*u8, str](res_buf)) { ret R.err[str, str](R.unwrap_err[*u8, str](res_buf)); }
    val buf: *u8 = R.unwrap_ok[*u8, str](res_buf);

    # pass 2: fill, keeping the template's `/`-canonical separators. every
    # variable validated in pass 1, so the substitution lookups cannot fail here.
    var w: usize = 0;
    i = 0;
    for (i < n) {
        if (tmpl[i] == '{') {
            var ii: usize = i + 1;
            for (ii < n && tmpl[ii] != '}') { ii = ii + 1; }
            val res_value: R.Result[str, str] = tmpl_value(alloc, tmpl, i + 1, ii, target_name, profile_name, art_name, ext);
            val value: str = R.unwrap_ok[str, str](res_value);
            val vl: usize = str_len(value);
            var iii: usize = 0;
            for (iii < vl) {
                buf[w] = value[iii];
                w = w + 1;
                iii = iii + 1;
            }
            i = ii + 1;
        }
        or {
            buf[w] = tmpl[i];
            w = w + 1;
            i = i + 1;
        }
    }
    buf[w] = 0;
    ret R.ok[str, str](buf::str);
}

# look up an interned StrId, erroring on a miss
#
# A miss is a parser invariant break rather than a user error.
# ---
# itn: interner holding the id
# id:  the StrId to resolve
# ret: ok(str) for an interned id, err on a miss
fun must_lookup(itn: *intern.Interner, id: intern.StrId) R.Result[str, str] {
    val opt_str: O.Option[str] = intern.lookup(itn, id);
    if (O.is_none[str](opt_str)) { ret R.err[str, str]("internal: manifest StrId not interned"); }
    ret R.ok[str, str](O.unwrap[str](opt_str));
}

# the declared target whose name equals `name`, or nil
# ---
# itn:  interner for the name
# m:    the manifest
# name: target name to match
# ret:  the matching TargetDef, or nil
fun find_target_by_name(itn: *intern.Interner, m: *Manifest, name: str) *TargetDef {
    val res_id: R.Result[intern.StrId, str] = intern.intern(itn, name);
    if (R.is_err[intern.StrId, str](res_id)) { ret nil; }
    val id: intern.StrId = R.unwrap_ok[intern.StrId, str](res_id);
    var i: u32 = 0;
    for (i < m.target_count) {
        if (m.targets[i].name == id) { ret ?m.targets[i]; }
        i = i + 1;
    }
    ret nil;
}

# whether a target's (isa, os) tuple equals the build host's
# ---
# itn:       interner for the target's strings
# d:         the target to test
# host_os:   the host os id
# host_arch: the host architecture id
# ret:       true when the target's tuple matches the host
fun target_matches_host(itn: *intern.Interner, d: *TargetDef, host_os: u32, host_arch: u32) bool {
    val opt_os:  O.Option[str] = intern.lookup(itn, d.os);
    val opt_isa: O.Option[str] = intern.lookup(itn, d.isa);
    if (O.is_none[str](opt_os) || O.is_none[str](opt_isa)) { ret false; }
    ret os.os_id_for(O.unwrap[str](opt_os)) == host_os && isa.arch_id_for(O.unwrap[str](opt_isa)) == host_arch;
}

# resolve a target selector to a declared target
#
# An empty selector defers to `[project].target`; `native`/`host` resolve the
# host tuple against the declared set only (ambiguity is an error; no match warns
# and falls back to the first declared target). A named selector must match a
# stanza.
# ---
# alloc: allocator for diagnostics and the native scan
# itn:   interner for stored strings
# m:     the manifest
# sel:   the target selector
# ret:   ok(ResolvedTarget) on success, err with a diagnostic
pub fun resolve_target(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest, sel: str) R.Result[ResolvedTarget, str] {
    if (m.target_count == 0) { ret R.err[ResolvedTarget, str]("mach.toml: no [target.*] declared"); }

    var name: str = sel;
    if (str_empty(name)) {
        val res_default: R.Result[str, str] = must_lookup(itn, m.default_target);
        if (R.is_err[str, str](res_default)) { ret R.err[ResolvedTarget, str](R.unwrap_err[str, str](res_default)); }
        name = R.unwrap_ok[str, str](res_default);
    }

    if (str_equals(name, "native") || str_equals(name, "host")) {
        ret resolve_native(alloc, itn, m);
    }

    val d: *TargetDef = find_target_by_name(itn, m, name);
    if (d == nil) { ret R.err[ResolvedTarget, str](cc3(alloc, "mach.toml: no target named '", name, "'")); }
    var rt: ResolvedTarget;
    rt.target = d;
    rt.warned = false;
    ret R.ok[ResolvedTarget, str](rt);
}

# the host-resolution rule
#
# Exactly one host-tuple match wins; several is an ambiguity error naming the
# candidates; none warns (via the `warned` flag) and falls back to the first
# declared target.
# ---
# alloc: allocator for diagnostics and candidate names
# itn:   interner for stored strings
# m:     the manifest
# ret:   ok(ResolvedTarget) on a unique match or fallback, err on ambiguity
fun resolve_native(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest) R.Result[ResolvedTarget, str] {
    val host_os:   u32 = tgt.host_os_id();
    val host_arch: u32 = tgt.host_arch_id();

    var first_match: *TargetDef = nil;
    var match_count: u32 = 0;
    var names: str = "";
    var i: u32 = 0;
    for (i < m.target_count) {
        if (target_matches_host(itn, ?m.targets[i], host_os, host_arch)) {
            val opt_name: O.Option[str] = intern.lookup(itn, m.targets[i].name);
            val name: str = first_nonempty_opt(opt_name);
            if (match_count == 0) { first_match = ?m.targets[i]; names = name; }
            or                    { names = cc3(alloc, names, ", ", name); }
            match_count = match_count + 1;
        }
        i = i + 1;
    }

    if (match_count > 1) {
        ret R.err[ResolvedTarget, str](cc3(alloc, "mach.toml: 'native' matches multiple targets for the host (", names, ")"));
    }
    var rt: ResolvedTarget;
    if (match_count == 1) {
        rt.target = first_match;
        rt.warned = false;
        ret R.ok[ResolvedTarget, str](rt);
    }
    rt.target = ?m.targets[0];
    rt.warned = true;
    ret R.ok[ResolvedTarget, str](rt);
}

# project a declared profile onto a ResolvedProfile
# ---
# pf:  the declared profile
# ret: a ResolvedProfile carrying its name, opt, and emission flags
fun profile_resolved(pf: *ProfileDef) ResolvedProfile {
    var rp: ResolvedProfile;
    rp.name     = pf.name;
    rp.opt      = pf.opt;
    rp.emit_ir  = pf.emit_ir;
    rp.emit_asm = pf.emit_asm;
    ret rp;
}

# resolve a profile selector
#
# A named selector must match a `[profile.*]`; an empty selector takes the first
# declared profile, or - when none are declared - an implicit `debug` profile
# (default opt, emission off).
# ---
# alloc: allocator for diagnostics
# itn:   interner for stored strings
# m:     the manifest
# sel:   the profile selector
# ret:   ok(ResolvedProfile) on success, err naming an unknown selector
pub fun resolve_profile(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest, sel: str) R.Result[ResolvedProfile, str] {
    if (!str_empty(sel)) {
        val res_id: R.Result[intern.StrId, str] = intern.intern(itn, sel);
        if (R.is_err[intern.StrId, str](res_id)) { ret R.err[ResolvedProfile, str](R.unwrap_err[intern.StrId, str](res_id)); }
        val id: intern.StrId = R.unwrap_ok[intern.StrId, str](res_id);
        var i: u32 = 0;
        for (i < m.profile_count) {
            if (m.profiles[i].name == id) { ret R.ok[ResolvedProfile, str](profile_resolved(?m.profiles[i])); }
            i = i + 1;
        }
        ret R.err[ResolvedProfile, str](cc3(alloc, "mach.toml: no profile named '", sel, "'"));
    }

    if (m.profile_count > 0) {
        ret R.ok[ResolvedProfile, str](profile_resolved(?m.profiles[0]));
    }

    val res_debug: R.Result[intern.StrId, str] = intern.intern(itn, "debug");
    if (R.is_err[intern.StrId, str](res_debug)) { ret R.err[ResolvedProfile, str](R.unwrap_err[intern.StrId, str](res_debug)); }
    var rp: ResolvedProfile;
    rp.name     = R.unwrap_ok[intern.StrId, str](res_debug);
    rp.opt      = MOPT_DEFAULT;
    rp.emit_ir  = false;
    rp.emit_asm = false;
    ret R.ok[ResolvedProfile, str](rp);
}

# resolve an artifact selector
#
# With a `--bin`/`--lib` selector, the named artifact of that kind must exist;
# without one, a single declared artifact is taken, and several is left
# unresolved (nil) so the caller can raise the ambiguity diagnostic. The
# multi-artifact matrix is a later phase.
# ---
# itn: interner for the selector name
# m:   the manifest
# sel: the build selection
# ret: the resolved ArtifactDef, or nil when none or ambiguous
fun resolve_artifact(itn: *intern.Interner, m: *Manifest, sel: Selection) *ArtifactDef {
    if (m.artifact_count == 0) { ret nil; }

    if (sel.has_artifact) {
        val res_id: R.Result[intern.StrId, str] = intern.intern(itn, sel.artifact);
        if (R.is_err[intern.StrId, str](res_id)) { ret nil; }
        val id: intern.StrId = R.unwrap_ok[intern.StrId, str](res_id);
        var i: u32 = 0;
        for (i < m.artifact_count) {
            if (m.artifacts[i].name == id && m.artifacts[i].is_lib == sel.want_lib) { ret ?m.artifacts[i]; }
            i = i + 1;
        }
        ret nil;
    }

    if (m.artifact_count == 1) { ret ?m.artifacts[0]; }
    ret nil;
}

# the `[os.<name>]` overlay whose name equals the resolved target's os id, or nil
# ---
# m:     the manifest
# os_id: interned os name to match
# ret:   the matching OsDef, or nil when none matches
fun find_os_overlay(m: *Manifest, os_id: intern.StrId) *OsDef {
    var i: u32 = 0;
    for (i < m.os_overlay_count) {
        if (m.os_overlays[i].name == os_id) { ret ?m.os_overlays[i]; }
        i = i + 1;
    }
    ret nil;
}

# the per-cell override for `art` matching the target named `tname`, or nil
# ---
# art:   the artifact whose cells to search
# tname: interned target name to match
# ret:   the matching CellDef, or nil when none refines that target
fun find_cell(art: *ArtifactDef, tname: intern.StrId) *CellDef {
    var i: u32 = 0;
    for (i < art.cell_count) {
        if (art.cells[i].target == tname) { ret ?art.cells[i]; }
        i = i + 1;
    }
    ret nil;
}

# finish a merged StrId buffer
#
# Frees it when empty, shrinks it to `used` when it came up short, else hands it
# over as-is.
# ---
# alloc: allocator owning buf
# buf:   the over-allocated StrId buffer
# used:  entries actually written
# cap:   buf's allocated capacity
# ret:   ok(StrArr) owning the right-sized array (empty when used == 0)
fun strarr_finish(alloc: *A.Allocator, buf: *intern.StrId, used: u32, cap: u32) R.Result[StrArr, str] {
    var out: StrArr;
    out.items = nil;
    out.count = 0;
    if (used == 0) {
        A.deallocate[intern.StrId](alloc, buf, cap::usize);
        ret R.ok[StrArr, str](out);
    }
    if (used < cap) {
        val res_shrink: R.Result[*intern.StrId, str] = A.reallocate[intern.StrId](alloc, buf, cap::usize, used::usize);
        if (R.is_ok[*intern.StrId, str](res_shrink)) {
            out.items = R.unwrap_ok[*intern.StrId, str](res_shrink);
            out.count = used;
            ret R.ok[StrArr, str](out);
        }
    }
    out.items = buf;
    out.count = used;
    ret R.ok[StrArr, str](out);
}

# the deduplicated os-overlay + target + artifact + cell link overlay
#
# Precedence order is os overlay, then target, then artifact, then cell, matching
# the cascade's merge law. Owned by `alloc`; empty when no level contributes.
# ---
# alloc: allocator owning the merged array
# os_ov: matching os overlay, or nil
# t:     the resolved target
# a:     the selected artifact
# cell:  the per-cell override, or nil
# ret:   ok(StrArr) with the merged libs, err on allocation failure
fun merge_libs(alloc: *A.Allocator, os_ov: *OsDef, t: *TargetDef, a: *ArtifactDef, cell: *CellDef) R.Result[StrArr, str] {
    var cell_n: u32 = 0;
    if (cell != nil) { cell_n = cell.lib_count; }
    var os_n: u32 = 0;
    if (os_ov != nil) { os_n = os_ov.lib_count; }
    val cap: u32 = os_n + t.lib_count + a.lib_count + cell_n;
    if (cap == 0) {
        var out: StrArr;
        out.items = nil;
        out.count = 0;
        ret R.ok[StrArr, str](out);
    }

    val res_buf: R.Result[*intern.StrId, str] = A.allocate[intern.StrId](alloc, cap::usize);
    if (R.is_err[*intern.StrId, str](res_buf)) { ret R.err[StrArr, str](R.unwrap_err[*intern.StrId, str](res_buf)); }
    val buf: *intern.StrId = R.unwrap_ok[*intern.StrId, str](res_buf);
    var c: u32 = 0;
    if (os_ov != nil) { c = append_unique(buf, c, os_ov.libs, os_ov.lib_count); }
    c = append_unique(buf, c, t.libs, t.lib_count);
    c = append_unique(buf, c, a.libs, a.lib_count);
    if (cell != nil) { c = append_unique(buf, c, cell.libs, cell.lib_count); }

    ret strarr_finish(alloc, buf, c, cap);
}

# append each id in `src` not already in buf[0, c) and return the new count
# ---
# buf: destination buffer with at least `c` + `n` slots
# c:   current entry count
# src: source ids
# n:   number of source ids
# ret: the entry count after appending the not-yet-present ids
fun append_unique(buf: *intern.StrId, c: u32, src: *intern.StrId, n: u32) u32 {
    var i: u32 = 0;
    var w: u32 = c;
    for (i < n) {
        val id: intern.StrId = src[i];
        var seen: bool = false;
        var ii: u32 = 0;
        for (ii < w) {
            if (buf[ii] == id) { seen = true; }
            ii = ii + 1;
        }
        if (!seen) { buf[w] = id; w = w + 1; }
        i = i + 1;
    }
    ret w;
}

# the length of a define's NAME part - every byte before the first `=`
#
# A define is `NAME` (a comptime flag) or `NAME=VALUE`; the merge keys on the
# NAME alone, so the whole string is the name when no `=` is present.
# ---
# s:   the define string
# ret: byte length of the NAME part
fun define_name_len(s: str) usize {
    val n: usize = str_len(s);
    var i: usize = 0;
    for (i < n) {
        if (s[i] == '=') { ret i; }
        i = i + 1;
    }
    ret n;
}

# whether two define strings name the same constant
#
# Equality is on the NAME part (up to the first `=`). A later precedence level
# redefining a NAME shadows an earlier one, so the merge dedups on the NAME, not
# the full `NAME=VALUE`.
# ---
# itn: interner holding both strings
# a:   first define id
# b:   second define id
# ret: true when both name the same constant
fun define_name_eq(itn: *intern.Interner, a: intern.StrId, b: intern.StrId) bool {
    if (a == b) { ret true; }
    val opt_a: O.Option[str] = intern.lookup(itn, a);
    val opt_b: O.Option[str] = intern.lookup(itn, b);
    if (O.is_none[str](opt_a) || O.is_none[str](opt_b)) { ret false; }
    val as_: str = O.unwrap[str](opt_a);
    val bs:  str = O.unwrap[str](opt_b);
    val an: usize = define_name_len(as_);
    if (an != define_name_len(bs)) { ret false; }
    var i: usize = 0;
    for (i < an) {
        if (as_[i] != bs[i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

# merge each define in `src` into buf[0, c), overriding by NAME
#
# An entry whose NAME already appears is replaced in place (a later precedence
# level wins); a new NAME is appended in first-seen position.
# ---
# itn: interner for NAME comparison
# buf: destination buffer with at least `c` + `n` slots
# c:   current entry count
# src: source defines
# n:   number of source defines
# ret: the entry count after merging
fun append_override(itn: *intern.Interner, buf: *intern.StrId, c: u32, src: *intern.StrId, n: u32) u32 {
    var w: u32 = c;
    var i: u32 = 0;
    for (i < n) {
        val id: intern.StrId = src[i];
        var found: bool = false;
        var ii: u32 = 0;
        for (ii < w) {
            if (define_name_eq(itn, buf[ii], id)) { buf[ii] = id; found = true; }
            ii = ii + 1;
        }
        if (!found) { buf[w] = id; w = w + 1; }
        i = i + 1;
    }
    ret w;
}

# the target + artifact + cell comptime-define overlay
#
# Resolved with the spec precedence artifact < target < per-cell. A later level's
# `NAME=VALUE` overrides an earlier level's same NAME, so each named constant
# appears once with its highest-precedence value, in first-seen order. Owned by
# `alloc`; empty when no level contributes.
# ---
# alloc: allocator owning the merged array
# itn:   interner for NAME comparison
# t:     the resolved target
# a:     the selected artifact
# cell:  the per-cell override, or nil
# ret:   ok(StrArr) with the merged defines, err on allocation failure
fun merge_defines(alloc: *A.Allocator, itn: *intern.Interner, t: *TargetDef, a: *ArtifactDef, cell: *CellDef) R.Result[StrArr, str] {
    var cell_n: u32 = 0;
    var cell_items: *intern.StrId = nil;
    if (cell != nil) { cell_n = cell.define_count; cell_items = cell.defines; }
    val cap: u32 = t.define_count + a.define_count + cell_n;
    if (cap == 0) {
        var out: StrArr;
        out.items = nil;
        out.count = 0;
        ret R.ok[StrArr, str](out);
    }

    val res_buf: R.Result[*intern.StrId, str] = A.allocate[intern.StrId](alloc, cap::usize);
    if (R.is_err[*intern.StrId, str](res_buf)) { ret R.err[StrArr, str](R.unwrap_err[*intern.StrId, str](res_buf)); }
    val buf: *intern.StrId = R.unwrap_ok[*intern.StrId, str](res_buf);
    var c: u32 = 0;
    c = append_override(itn, buf, c, a.defines, a.define_count);
    c = append_override(itn, buf, c, t.defines, t.define_count);
    c = append_override(itn, buf, c, cell_items, cell_n);

    ret strarr_finish(alloc, buf, c, cap);
}

# the effective `out` template for an artifact under a cell
#
# Cell override, else artifact override, else the project template.
# ---
# m:    the manifest
# a:    the artifact
# cell: the per-cell override, or nil
# ret:  the interned template id to expand
fun effective_out(m: *Manifest, a: *ArtifactDef, cell: *CellDef) intern.StrId {
    if (cell != nil && cell.out != intern.STR_NIL) { ret cell.out; }
    if (a.out != intern.STR_NIL)                   { ret a.out; }
    ret m.out_tmpl;
}

# resolve a Selection into one BuildUnit
#
# Produces concrete template-expanded output paths and the merged link overlay.
# ---
# alloc: allocator owning the unit's owned arrays and paths
# itn:   interner for stored strings
# m:     the manifest
# sel:   the build selection
# ret:   ok(BuildUnit) on success, err with the first diagnostic
pub fun resolve_build_unit(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest, sel: Selection) R.Result[BuildUnit, str] {
    val res_target: R.Result[ResolvedTarget, str] = resolve_target(alloc, itn, m, sel.target);
    if (R.is_err[ResolvedTarget, str](res_target)) { ret R.err[BuildUnit, str](R.unwrap_err[ResolvedTarget, str](res_target)); }
    val rt: ResolvedTarget = R.unwrap_ok[ResolvedTarget, str](res_target);

    val res_profile: R.Result[ResolvedProfile, str] = resolve_profile(alloc, itn, m, sel.profile);
    if (R.is_err[ResolvedProfile, str](res_profile)) { ret R.err[BuildUnit, str](R.unwrap_err[ResolvedProfile, str](res_profile)); }
    val rp: ResolvedProfile = R.unwrap_ok[ResolvedProfile, str](res_profile);

    val a: *ArtifactDef = resolve_artifact(itn, m, sel);
    if (a == nil) { ret R.err[BuildUnit, str](artifact_err(alloc, itn, m, sel)); }

    val cell: *CellDef = find_cell(a, rt.target.name);
    val os_ov: *OsDef = find_os_overlay(m, rt.target.os);

    var u: BuildUnit;
    u.target       = rt.target;
    u.artifact     = a;
    u.target_name  = rt.target.name;
    u.profile_name = rp.name;
    u.opt          = rp.opt;
    u.emit_ir      = rp.emit_ir;
    u.emit_asm     = rp.emit_asm;
    u.is_lib       = a.is_lib;
    u.kind         = a.kind;
    u.warned       = rt.warned;

    u.entry = a.entry;
    if (cell != nil && cell.entry != intern.STR_NIL) { u.entry = cell.entry; }

    val res_libs: R.Result[StrArr, str] = merge_libs(alloc, os_ov, rt.target, a, cell);
    if (R.is_err[StrArr, str](res_libs)) { ret R.err[BuildUnit, str](R.unwrap_err[StrArr, str](res_libs)); }
    val merged_libs: StrArr = R.unwrap_ok[StrArr, str](res_libs);
    u.libs      = merged_libs.items;
    u.lib_count = merged_libs.count;

    val res_defines: R.Result[StrArr, str] = merge_defines(alloc, itn, rt.target, a, cell);
    if (R.is_err[StrArr, str](res_defines)) { ret R.err[BuildUnit, str](R.unwrap_err[StrArr, str](res_defines)); }
    val merged_defines: StrArr = R.unwrap_ok[StrArr, str](res_defines);
    u.defines      = merged_defines.items;
    u.define_count = merged_defines.count;

    # expansion variables, all from stanzas present in the file.
    val res_target_name: R.Result[str, str] = must_lookup(itn, rt.target.name);
    if (R.is_err[str, str](res_target_name)) { ret R.err[BuildUnit, str](R.unwrap_err[str, str](res_target_name)); }
    val res_profile_name: R.Result[str, str] = must_lookup(itn, rp.name);
    if (R.is_err[str, str](res_profile_name)) { ret R.err[BuildUnit, str](R.unwrap_err[str, str](res_profile_name)); }
    val res_art_name: R.Result[str, str] = must_lookup(itn, a.name);
    if (R.is_err[str, str](res_art_name)) { ret R.err[BuildUnit, str](R.unwrap_err[str, str](res_art_name)); }
    val res_ext: R.Result[str, str] = must_lookup(itn, rt.target.ext);
    if (R.is_err[str, str](res_ext)) { ret R.err[BuildUnit, str](R.unwrap_err[str, str](res_ext)); }
    val tn: str = R.unwrap_ok[str, str](res_target_name);
    val pn: str = R.unwrap_ok[str, str](res_profile_name);
    val an: str = R.unwrap_ok[str, str](res_art_name);
    val ex: str = R.unwrap_ok[str, str](res_ext);

    val out_tmpl: intern.StrId = effective_out(m, a, cell);
    val res_bin: R.Result[intern.StrId, str] = expand_intern(alloc, itn, out_tmpl, tn, pn, an, ex);
    if (R.is_err[intern.StrId, str](res_bin)) { ret R.err[BuildUnit, str](R.unwrap_err[intern.StrId, str](res_bin)); }
    u.bin_path = R.unwrap_ok[intern.StrId, str](res_bin);

    val res_obj: R.Result[intern.StrId, str] = expand_intern(alloc, itn, m.obj_tmpl, tn, pn, an, ex);
    if (R.is_err[intern.StrId, str](res_obj)) { ret R.err[BuildUnit, str](R.unwrap_err[intern.StrId, str](res_obj)); }
    u.obj_root = R.unwrap_ok[intern.StrId, str](res_obj);

    val res_ir: R.Result[intern.StrId, str] = expand_intern(alloc, itn, m.ir_tmpl, tn, pn, an, ex);
    if (R.is_err[intern.StrId, str](res_ir)) { ret R.err[BuildUnit, str](R.unwrap_err[intern.StrId, str](res_ir)); }
    u.ir_root = R.unwrap_ok[intern.StrId, str](res_ir);

    val res_asm: R.Result[intern.StrId, str] = expand_intern(alloc, itn, m.asm_tmpl, tn, pn, an, ex);
    if (R.is_err[intern.StrId, str](res_asm)) { ret R.err[BuildUnit, str](R.unwrap_err[intern.StrId, str](res_asm)); }
    u.asm_root = R.unwrap_ok[intern.StrId, str](res_asm);

    val res_test: R.Result[intern.StrId, str] = expand_test_root(alloc, itn, m.tests_tmpl, tn, pn, ex);
    if (R.is_err[intern.StrId, str](res_test)) { ret R.err[BuildUnit, str](R.unwrap_err[intern.StrId, str](res_test)); }
    u.test_root = R.unwrap_ok[intern.StrId, str](res_test);

    ret R.ok[BuildUnit, str](u);
}

# expand the `tests` template's `{target}`/`{profile}`/`{ext}` while leaving
# `{name}` a literal placeholder
#
# The per-test name is unknown until `mach test` enumerates the build's tests, so
# the runner substitutes `{name}` itself. Implemented by expanding with the
# `{name}` variable mapped to the literal string "{name}".
# ---
# alloc:   allocator owning the result
# itn:     interner for the template and result
# tmpl_id: interned `tests` template
# tn:      value for `{target}`
# pn:      value for `{profile}`
# ex:      value for `{ext}`
# ret:     ok(interned partially-expanded template) on success, err otherwise
fun expand_test_root(alloc: *A.Allocator, itn: *intern.Interner, tmpl_id: intern.StrId,
                     tn: str, pn: str, ex: str) R.Result[intern.StrId, str] {
    ret expand_intern(alloc, itn, tmpl_id, tn, pn, "{name}", ex);
}

# the diagnostic for a failed artifact selection
#
# An ambiguous default (several artifacts, none selected) names every candidate
# so `mach run` and `mach test`, which build exactly one artifact, point straight
# at the choice.
# ---
# alloc: allocator owning the message
# itn:   interner for artifact names
# m:     the manifest
# sel:   the build selection
# ret:   owned diagnostic string
fun artifact_err(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest, sel: Selection) str {
    if (m.artifact_count == 0) { ret "mach.toml: no [bin.*] or [lib.*] artifacts declared"; }
    if (sel.has_artifact) {
        if (sel.want_lib) { ret cc3(alloc, "mach.toml: no lib named '", sel.artifact, "'"); }
        ret cc3(alloc, "mach.toml: no bin named '", sel.artifact, "'");
    }
    ret cc3(alloc, "mach.toml: multiple artifacts declared; select one with --bin/--lib (",
        artifact_candidates(alloc, itn, m), ")");
}

# a comma-separated `bin <name>`/`lib <name>` list of every declared artifact
#
# In declaration order, for the ambiguous-selection diagnostic.
# ---
# alloc: allocator owning the message
# itn:   interner for artifact names
# m:     the manifest
# ret:   owned candidate list
fun artifact_candidates(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest) str {
    var s: str = "";
    var i: u32 = 0;
    for (i < m.artifact_count) {
        if (i > 0) { s = cc(alloc, s, ", "); }
        var label: str = "bin ";
        if (m.artifacts[i].is_lib) { label = "lib "; }
        var name: str = "?";
        val opt_name: O.Option[str] = intern.lookup(itn, m.artifacts[i].name);
        if (O.is_some[str](opt_name)) { name = O.unwrap[str](opt_name); }
        s = cc(alloc, s, cc(alloc, label, name));
        i = i + 1;
    }
    ret s;
}

# expand a template then intern the result
# ---
# alloc:   allocator for the transient expansion
# itn:     interner for the template and result
# tmpl_id: interned template to expand
# tn:      value for `{target}`
# pn:      value for `{profile}`
# an:      value for `{name}`
# ex:      value for `{ext}`
# ret:     ok(interned expanded path) on success, err otherwise
fun expand_intern(alloc: *A.Allocator, itn: *intern.Interner, tmpl_id: intern.StrId,
                  tn: str, pn: str, an: str, ex: str) R.Result[intern.StrId, str] {
    val res_tmpl: R.Result[str, str] = must_lookup(itn, tmpl_id);
    if (R.is_err[str, str](res_tmpl)) { ret R.err[intern.StrId, str](R.unwrap_err[str, str](res_tmpl)); }
    val res_expand: R.Result[str, str] = expand(alloc, R.unwrap_ok[str, str](res_tmpl), tn, pn, an, ex);
    if (R.is_err[str, str](res_expand)) { ret R.err[intern.StrId, str](R.unwrap_err[str, str](res_expand)); }
    val s: str = R.unwrap_ok[str, str](res_expand);
    val res_id: R.Result[intern.StrId, str] = intern.intern(itn, s);
    str_free(alloc, s);
    ret res_id;
}

# reject two artifacts that resolve to the same `out` path for the selected
# target and profile
#
# The honest "build start" guard against a degenerate template.
# ---
# alloc:        allocator for the transient expansions and diagnostic
# itn:          interner for stored strings
# m:            the manifest
# t:            the resolved target
# profile_name: the resolved profile name (drives `{profile}`)
# ret:          ok(true) when no two artifacts collide, err naming the pair otherwise
pub fun check_collisions(alloc: *A.Allocator, itn: *intern.Interner, m: *Manifest,
                         t: *TargetDef, profile_name: str) R.Result[bool, str] {
    if (m.artifact_count < 2) { ret R.ok[bool, str](true); }

    val res_target_name: R.Result[str, str] = must_lookup(itn, t.name);
    if (R.is_err[str, str](res_target_name)) { ret R.err[bool, str](R.unwrap_err[str, str](res_target_name)); }
    val tn: str = R.unwrap_ok[str, str](res_target_name);
    val res_ext: R.Result[str, str] = must_lookup(itn, t.ext);
    if (R.is_err[str, str](res_ext)) { ret R.err[bool, str](R.unwrap_err[str, str](res_ext)); }
    val ex: str = R.unwrap_ok[str, str](res_ext);

    val res_paths: R.Result[*str, str] = A.allocate[str](alloc, m.artifact_count::usize);
    if (R.is_err[*str, str](res_paths)) { ret R.err[bool, str](R.unwrap_err[*str, str](res_paths)); }
    val paths: *str = R.unwrap_ok[*str, str](res_paths);

    var i: u32 = 0;
    for (i < m.artifact_count) {
        val a: *ArtifactDef = ?m.artifacts[i];
        val res_art_name: R.Result[str, str] = must_lookup(itn, a.name);
        if (R.is_err[str, str](res_art_name)) { ret R.err[bool, str](R.unwrap_err[str, str](res_art_name)); }
        val cell: *CellDef = find_cell(a, t.name);
        val res_out_tmpl: R.Result[str, str] = must_lookup(itn, effective_out(m, a, cell));
        if (R.is_err[str, str](res_out_tmpl)) { ret R.err[bool, str](R.unwrap_err[str, str](res_out_tmpl)); }
        val res_expand: R.Result[str, str] = expand(alloc, R.unwrap_ok[str, str](res_out_tmpl), tn, profile_name, R.unwrap_ok[str, str](res_art_name), ex);
        if (R.is_err[str, str](res_expand)) { ret R.err[bool, str](R.unwrap_err[str, str](res_expand)); }
        paths[i] = R.unwrap_ok[str, str](res_expand);
        i = i + 1;
    }

    i = 0;
    for (i < m.artifact_count) {
        var ii: u32 = i + 1;
        for (ii < m.artifact_count) {
            if (str_equals(paths[i], paths[ii])) {
                val nx: str = first_nonempty_opt(intern.lookup(itn, m.artifacts[i].name));
                val ny: str = first_nonempty_opt(intern.lookup(itn, m.artifacts[ii].name));
                ret R.err[bool, str](cc5(alloc, cc3(alloc, "mach.toml: artifacts '", nx, "' and '"), ny, "' both build to '", paths[i], "'"));
            }
            ii = ii + 1;
        }
        i = i + 1;
    }
    ret R.ok[bool, str](true);
}

# stand up a page-backed arena allocator and a fresh interner for a test
#
# `backing`/`ar` are owned by the caller's frame so the arena outlives the test.
# ---
# backing: page allocator stood up in place
# ar:      arena stood up over `backing`
# alloc:   arena allocator handle filled in place
# itn:     interner filled in place
# ret:     true on success, false if any setup step fails
fun tinit(backing: *A.Allocator, ar: *arena.Arena, alloc: *A.Allocator, itn: *intern.Interner) bool {
    if (O.is_some[str](page.make(backing)))         { ret false; }
    if (O.is_some[str](arena.init(ar, backing, 0))) { ret false; }
    if (O.is_some[str](arena.make(alloc, ar)))      { ret false; }
    @itn = intern.init(alloc);
    ret true;
}

# parse a manifest from TOML source text for a test
# ---
# alloc:  allocator for the parse
# itn:    interner for stored strings
# source: the manifest source text
# ret:    ok(Manifest) on success, err with the first diagnostic
fun tparse(alloc: *A.Allocator, itn: *intern.Interner, source: str) R.Result[Manifest, str] {
    val res_table: R.Result[toml.Table, str] = toml.parse(alloc, source);
    if (R.is_err[toml.Table, str](res_table)) { ret R.err[Manifest, str](R.unwrap_err[toml.Table, str](res_table)); }
    var t: toml.Table = R.unwrap_ok[toml.Table, str](res_table);
    ret parse(alloc, itn, ?t);
}

# the interned string behind a StrId, or "" on a miss
# ---
# itn: interner holding the id
# id:  the StrId to resolve
# ret: the interned string, or "" on a miss
fun idstr(itn: *intern.Interner, id: intern.StrId) str {
    ret first_nonempty_opt(intern.lookup(itn, id));
}

# build a Selection for a test
# ---
# target:       the target selector
# profile:      the profile selector
# artifact:     the artifact selector
# want_lib:     whether the artifact selector came from `--lib`
# has_artifact: whether an artifact selector was given
# ret:          the assembled Selection
fun mk_sel(target: str, profile: str, artifact: str, want_lib: bool, has_artifact: bool) Selection {
    var s: Selection;
    s.target       = target;
    s.profile      = profile;
    s.artifact     = artifact;
    s.want_lib     = want_lib;
    s.has_artifact = has_artifact;
    ret s;
}

# a representative two-bin, two-target, two-profile manifest
# ---
# ret: the demo manifest source text
fun demo_src() str {
    ret "[project]\nid = \"demo\"\nversion = \"0.1.0\"\nsrc = \"src\"\ndep = \"dep\"\ntarget = \"native\"\n\n[target.linux]\nisa = \"x86_64\"\nos = \"linux\"\nabi = \"sysv64\"\n\n[target.windows]\nisa = \"x86_64\"\nos = \"windows\"\nabi = \"win64\"\next = \".exe\"\n\n[bin.ls]\nentry = \"bin/ls.mach\"\n\n[bin.cat]\nentry = \"bin/cat.mach\"\n\n[profile.debug]\nopt = 0\n\n[profile.release]\nopt = 2\nemit_ir = true\n\n[deps.mach-std]\ngit = \"https://github.com/octalide/mach-std\"\nref = \"v0.4.0\"\n";
}

# a `[target.<name>]` whose isa/os are the build host's, so `native` matches it
# on any host
#
# Lets the native-resolution tests assert host behavior without hardcoding a
# single platform's tuple.
# ---
# alloc: allocator owning the stanza text
# name:  the target name to emit
# ret:   owned `[target.<name>]` stanza text
fun host_target_stanza(alloc: *A.Allocator, name: str) str {
    ret cc5(alloc, cc3(alloc, "[target.", name, "]\nisa = \""), host_isa_name(), "\"\nos = \"", host_os_name(), "\"\nabi = \"sysv64\"\n");
}

# whether the interned StrId array holds an entry equal to `lit`
# ---
# itn:   interner for the entries
# items: the StrId array
# count: number of entries in items
# lit:   the literal to find
# ret:   true when an entry equals `lit`
fun strarr_has(itn: *intern.Interner, items: *intern.StrId, count: u32, lit: str) bool {
    var i: u32 = 0;
    for (i < count) {
        if (str_equals(idstr(itn, items[i]), lit)) { ret true; }
        i = i + 1;
    }
    ret false;
}

test "mach.lang.manifest.is_valid_id" {
    var code: i32 = 0;
    if (!is_valid_id("foo"))    { code = 1; }
    if (!is_valid_id("my_app")) { code = 1; }
    if (!is_valid_id("my-app")) { code = 1; }
    if (!is_valid_id("Proj2"))  { code = 1; }
    if (!is_valid_id("9"))      { code = 1; }
    if (is_valid_id(""))        { code = 1; }
    if (is_valid_id("."))       { code = 1; }
    if (is_valid_id(".."))      { code = 1; }
    if (is_valid_id("foo/bar")) { code = 1; }
    if (is_valid_id("foo.bar")) { code = 1; }
    if (is_valid_id("a b"))     { code = 1; }
    if (is_valid_id("name!"))   { code = 1; }
    ret code;
}

# a full manifest parses every stanza
test "mach.lang.manifest.parse:full" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, demo_src());
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        if (!str_equals(idstr(?itn, m.id), "demo"))                                          { code = 1; }
        if (!str_equals(idstr(?itn, m.version), "0.1.0"))                                    { code = 1; }
        if (m.target_count != 2)                                                             { code = 1; }
        if (m.artifact_count != 2)                                                           { code = 1; }
        if (m.profile_count != 2)                                                            { code = 1; }
        if (m.dep_count != 1)                                                                { code = 1; }
        if (!str_equals(idstr(?itn, m.out_tmpl), DEFAULT_OUT))                               { code = 1; }
        if (!str_equals(idstr(?itn, m.targets[1].ext), ".exe"))                              { code = 1; }
        if (!str_equals(idstr(?itn, m.deps[0].git), "https://github.com/octalide/mach-std")) { code = 1; }
    }
    arena.dnit(?ar);
    ret code;
}

# missing required project keys are rejected by name
test "mach.lang.manifest.parse:missing_required_keys" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val a: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nversion=\"1\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n");
    if (R.is_ok[Manifest, str](a) || !str_equals(R.unwrap_err[Manifest, str](a), "mach.toml: [project] is missing required key 'id'")) { code = 1; }

    val b: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n");
    if (R.is_ok[Manifest, str](b) || !str_equals(R.unwrap_err[Manifest, str](b), "mach.toml: [project] is missing required key 'version'")) { code = 1; }
    arena.dnit(?ar);
    ret code;
}

