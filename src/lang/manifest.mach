        val pf: R.Result[ResolvedProfile, str] = resolve_profile(?alloc, ?itn, ?m, "fast");
        if (R.is_ok[ResolvedProfile, str](pf) || !str_equals(R.unwrap_err[ResolvedProfile, str](pf), "mach.toml: no profile named 'fast'")) { code = 1; }
    }
    arena.dnit(?ar);
    ret code;
}

# a build unit resolves concrete paths from the templates
#
# an explicit target keeps the expanded paths host-independent - native
# resolution is exercised by the dedicated tests above.
test "mach.lang.manifest.resolve_build_unit:concrete_paths" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, demo_src());
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val u: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("linux", "", "ls", false, true));
        if (R.is_err[BuildUnit, str](u)) { code = 1; }
        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](u);
            if (!str_equals(idstr(?itn, bu.target_name), "linux"))               { code = 1; }
            if (!str_equals(idstr(?itn, bu.profile_name), "debug"))              { code = 1; }
            if (!str_equals(idstr(?itn, bu.entry), "bin/ls.mach"))               { code = 1; }
            if (!str_equals(idstr(?itn, bu.bin_path), "out/linux/debug/bin/ls")) { code = 1; }
            if (!str_equals(idstr(?itn, bu.obj_root), "out/linux/debug/obj"))    { code = 1; }
            if (bu.opt != MOPT_DEBUG)                                            { code = 1; }
            if (bu.is_lib)                                                       { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# a release profile selection switches opt and emission
#
# explicit target so the release-path assertion is host-independent.
test "mach.lang.manifest.resolve_build_unit:release_profile" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, demo_src());
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val u: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("linux", "release", "cat", false, true));
        if (R.is_err[BuildUnit, str](u)) { code = 1; }
        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](u);
            if (bu.opt != MOPT_RELEASE)                                             { code = 1; }
            if (!bu.emit_ir)                                                        { code = 1; }
            if (!str_equals(idstr(?itn, bu.bin_path), "out/linux/release/bin/cat")) { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# a profile opt outside 0..2 is rejected naming the profile
test "mach.lang.manifest.parse:bad_opt_level" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val a: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[bin.app]\nentry=\"main.mach\"\n[profile.debug]\nopt = 9\n");
    if (R.is_ok[Manifest, str](a) || !str_equals(R.unwrap_err[Manifest, str](a), "mach.toml: profile 'debug': opt must be 0, 1, or 2 (got 9)")) { code = 1; }

    # a string opt is the old form and is no longer accepted; the error names it.
    val b: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[bin.app]\nentry=\"main.mach\"\n[profile.release]\nopt = \"O2\"\n");
    if (R.is_ok[Manifest, str](b) || !str_equals(R.unwrap_err[Manifest, str](b), "mach.toml: profile 'release': opt must be 0, 1, or 2 (got \"O2\")")) { code = 1; }
    arena.dnit(?ar);
    ret code;
}

# two artifacts resolving to the same path collide at build start
test "mach.lang.manifest.check_collisions" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\nout=\"bin/app\"\n[target.linux]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[bin.a]\nentry=\"a.mach\"\n[bin.b]\nentry=\"b.mach\"\n");
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val cr: R.Result[bool, str] = check_collisions(?alloc, ?itn, ?m, ?m.targets[0], "debug");
        if (R.is_ok[bool, str](cr) || !str_equals(R.unwrap_err[bool, str](cr), "mach.toml: artifacts 'a' and 'b' both build to 'bin/app'")) { code = 1; }
    }
    arena.dnit(?ar);
    ret code;
}

# defines merge with precedence artifact < target < per-cell
#
# plat resolves once at its first-seen position, with the cell value.
test "mach.lang.manifest.merge_defines:precedence" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\ntarget=\"windows\"\n[target.windows]\nisa=\"x86_64\"\nos=\"windows\"\nabi=\"win64\"\ndefines=[\"plat=win\",\"shared_flag\"]\n[bin.app]\nentry=\"main.mach\"\ndefines=[\"plat=app\",\"art_flag\"]\n[bin.app.target.windows]\ndefines=[\"plat=cell\"]\n");
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val u: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("windows", "", "app", false, true));
        if (R.is_err[BuildUnit, str](u)) { code = 1; }
        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](u);
            if (bu.define_count != 3)                                          { code = 1; }
            if (!strarr_has(?itn, bu.defines, bu.define_count, "plat=cell"))   { code = 1; }
            if (strarr_has(?itn, bu.defines, bu.define_count, "plat=win"))     { code = 1; }
            if (strarr_has(?itn, bu.defines, bu.define_count, "plat=app"))     { code = 1; }
            if (!strarr_has(?itn, bu.defines, bu.define_count, "shared_flag")) { code = 1; }
            if (!strarr_has(?itn, bu.defines, bu.define_count, "art_flag"))    { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# an ambiguous artifact selection errors naming every candidate
#
# no artifact selector with two bins is ambiguous; the error names both.
test "mach.lang.manifest.resolve_build_unit:ambiguous_artifact" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, demo_src());
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val u: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("", "", "", false, false));
        if (R.is_ok[BuildUnit, str](u)) { code = 1; }
        or {
            val msg: str = R.unwrap_err[BuildUnit, str](u);
            if (!str_contains(msg, "bin ls"))  { code = 1; }
            if (!str_contains(msg, "bin cat")) { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# a per-cell [bin.X.target.Y] override refines entry and merges libs
test "mach.lang.manifest.resolve_build_unit:cell_override" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\ntarget=\"windows\"\n[target.windows]\nisa=\"x86_64\"\nos=\"windows\"\nabi=\"win64\"\next=\".exe\"\nlibs=[\"kernel32.dll\"]\n[bin.app]\nentry=\"main.mach\"\nlibs=[\"base.o\"]\n[bin.app.target.windows]\nentry=\"win.mach\"\nlibs=[\"user32.dll\"]\n");
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val u: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("windows", "", "app", false, true));
        if (R.is_err[BuildUnit, str](u)) { code = 1; }
        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](u);
            if (!str_equals(idstr(?itn, bu.entry), "win.mach"))                         { code = 1; }
            if (!str_equals(idstr(?itn, bu.bin_path), "out/windows/debug/bin/app.exe")) { code = 1; }
            if (bu.lib_count != 3)                                                      { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# a project module key parses, absent yields STR_NIL
test "mach.lang.manifest.parse:project_module" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val a: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"glfw\"\nversion=\"1\"\nmodule=\"glfw.mach\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[lib.glfw]\nentry=\"glfw.mach\"\n");
    if (R.is_err[Manifest, str](a)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](a);
        if (!str_equals(idstr(?itn, m.module), "glfw.mach")) { code = 1; }
    }

    val b: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[lib.x]\nentry=\"lib.mach\"\n");
    if (R.is_err[Manifest, str](b)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](b);
        if (m.module != intern.STR_NIL) { code = 1; }
    }
    arena.dnit(?ar);
    ret code;
}

# an [os.<name>] overlay merges into a matching os build only
#
# a windows build inherits the overlay; a linux build does not.
test "mach.lang.manifest.resolve_build_unit:os_overlay" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val src: str = "[project]\nid=\"x\"\nversion=\"1\"\n[target.linux]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[target.windows]\nisa=\"x86_64\"\nos=\"windows\"\nabi=\"win64\"\n[os.windows]\nlibs=[\"user32.dll\"]\n[bin.app]\nentry=\"main.mach\"\n";
    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, src);
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        if (m.os_overlay_count != 1) { code = 1; }

        val uw: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("windows", "", "app", false, true));
        if (R.is_err[BuildUnit, str](uw)) { code = 1; }
        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](uw);
            if (!strarr_has(?itn, bu.libs, bu.lib_count, "user32.dll")) { code = 1; }
        }
        val ul: R.Result[BuildUnit, str] = resolve_build_unit(?alloc, ?itn, ?m, mk_sel("linux", "", "app", false, true));
        if (R.is_err[BuildUnit, str](ul)) { code = 1; }
        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](ul);
            if (strarr_has(?itn, bu.libs, bu.lib_count, "user32.dll")) { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# [isa.*] and [abi.*] overlays are reserved
test "mach.lang.manifest.parse:reserved_isa_abi_overlays" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val a: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[isa.x86_64]\nlibs=[\"a.o\"]\n");
    if (R.is_ok[Manifest, str](a) || !str_equals(R.unwrap_err[Manifest, str](a), "mach.toml: [isa.*] overlays are reserved")) { code = 1; }

    val b: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\n[target.l]\nisa=\"x86_64\"\nos=\"linux\"\nabi=\"sysv64\"\n[abi.sysv64]\nlibs=[\"a.o\"]\n");
    if (R.is_ok[Manifest, str](b) || !str_equals(R.unwrap_err[Manifest, str](b), "mach.toml: [abi.*] overlays are reserved")) { code = 1; }
    arena.dnit(?ar);
    ret code;
}

# an [os.<name>] overlay rejects an unknown key
test "mach.lang.manifest.parse:os_overlay_unknown_key" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
