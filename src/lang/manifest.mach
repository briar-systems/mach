    if (R.is_ok[Manifest, str](b) || !str_equals(R.unwrap_err[Manifest, str](b), "mach.toml: [deps.std] needs exactly one source key: 'git' or 'path'")) { code = 1; }
    arena.dnit(?ar);
    ret code;
}

