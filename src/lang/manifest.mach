        or {
            val bu: BuildUnit = R.unwrap_ok[BuildUnit, str](u);
            if (bu.define_count != 2)                                          { code = 1; }
            if (!strarr_has(?itn, bu.defines, bu.define_count, "plat=cell"))   { code = 1; }
            if (!strarr_has(?itn, bu.defines, bu.define_count, "art_flag"))    { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

