# template expansion substitutes the four variables and nothing else
test "mach.lang.manifest.expand" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val a: R.Result[str, str] = expand(?alloc, DEFAULT_OUT, "linux", "debug", "ls", "");
    if (R.is_err[str, str](a) || !str_equals(R.unwrap_ok[str, str](a), "out/linux/debug/bin/ls")) { code = 1; }

    val b: R.Result[str, str] = expand(?alloc, "{name}{ext}", "windows", "release", "cat", ".exe");
    if (R.is_err[str, str](b) || !str_equals(R.unwrap_ok[str, str](b), "cat.exe")) { code = 1; }

    val c: R.Result[str, str] = expand(?alloc, "out/{flavor}", "linux", "debug", "ls", "");
    if (R.is_ok[str, str](c) || !str_equals(R.unwrap_err[str, str](c), "mach.toml: unknown template variable '{flavor}'")) { code = 1; }
    arena.dnit(?ar);
    ret code;
}

# native resolves the host tuple against declared targets only
#
# a non-host target declared first proves native selects by the host tuple, not
# by declaration order; the host-matching stanza follows it.
test "mach.lang.manifest.resolve_target:native_host_tuple" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val src: str = cc5(?alloc,
        "[project]\nid = \"x\"\nversion = \"1\"\n[target.foreign]\nisa = \"nonesuch\"\nos = \"nonesuch\"\nabi = \"x\"\n",
        host_target_stanza(?alloc, "hosttgt"),
        "[bin.app]\nentry = \"main.mach\"\n", "", "");
    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, src);
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val rt: R.Result[ResolvedTarget, str] = resolve_target(?alloc, ?itn, ?m, "native");
        if (R.is_err[ResolvedTarget, str](rt)) { code = 1; }
        or {
            val r: ResolvedTarget = R.unwrap_ok[ResolvedTarget, str](rt);
            if (r.warned)                                           { code = 1; }
            if (!str_equals(idstr(?itn, r.target.name), "hosttgt")) { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# native with no host match warns and falls back to the first target
#
# neither target can match any real host, so native warns and falls back to the
# first declared target regardless of which host runs the test.
test "mach.lang.manifest.resolve_target:native_no_match" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, "[project]\nid=\"x\"\nversion=\"1\"\n[target.alpha]\nisa=\"nonesuch\"\nos=\"nonesuch\"\nabi=\"x\"\n[target.beta]\nisa=\"nonesuch\"\nos=\"nonesuch\"\nabi=\"x\"\n[bin.app]\nentry=\"main.mach\"\n");
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val rt: R.Result[ResolvedTarget, str] = resolve_target(?alloc, ?itn, ?m, "native");
        if (R.is_err[ResolvedTarget, str](rt)) { code = 1; }
        or {
            val r: ResolvedTarget = R.unwrap_ok[ResolvedTarget, str](rt);
            if (!r.warned)                                        { code = 1; }
            if (!str_equals(idstr(?itn, r.target.name), "alpha")) { code = 1; }
        }
    }
    arena.dnit(?ar);
    ret code;
}

# native ambiguity among host-matching targets is an error naming candidates
#
# both targets carry the host tuple, so native is ambiguous on any host and the
# error must name both candidates in declaration order.
test "mach.lang.manifest.resolve_target:native_ambiguous" {
    var backing: A.Allocator; var ar: arena.Arena; var alloc: A.Allocator; var itn: intern.Interner;
    if (!tinit(?backing, ?ar, ?alloc, ?itn)) { ret 1; }
    var code: i32 = 0;

    val src: str = cc5(?alloc,
        "[project]\nid = \"x\"\nversion = \"1\"\n",
        host_target_stanza(?alloc, "a1"),
        host_target_stanza(?alloc, "a2"),
        "[bin.app]\nentry = \"main.mach\"\n", "");
    val res_manifest: R.Result[Manifest, str] = tparse(?alloc, ?itn, src);
    if (R.is_err[Manifest, str](res_manifest)) { code = 1; }
    or {
        var m: Manifest = R.unwrap_ok[Manifest, str](res_manifest);
        val rt: R.Result[ResolvedTarget, str] = resolve_target(?alloc, ?itn, ?m, "native");
        if (R.is_ok[ResolvedTarget, str](rt) || !str_equals(R.unwrap_err[ResolvedTarget, str](rt), "mach.toml: 'native' matches multiple targets for the host (a1, a2)")) { code = 1; }
    }
    arena.dnit(?ar);
    ret code;
}

