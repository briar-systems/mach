# mach.lang.diagnostic: severity-tagged diagnostic sink shared by every phase.
#
# a single list of records that every phase appends to. render time is
# decoupled: diagnostics carry `(FileId, Span)` for source location and
# an owned message; rendering to text happens through the source registry.

use std.types.bool.bool;
use std.types.bool.true;
use std.types.bool.false;
use std.types.size.usize;
use std.types.char.char;
use std.types.string.str;
use std.types.string.str_len;
use std.text.string.str_dup;
use std.text.string.str_free;
use std.types.result.Result;
use std.types.result.ok;
use std.types.result.err;
use std.types.result.is_err;
use std.types.result.unwrap_ok;
use std.types.result.unwrap_err;

use std.allocator.Allocator;
use std.allocator.allocate;
use std.allocator.deallocate;
use std.allocator.reallocate;

use mem: std.memory;

use token: mach.lang.fe.token;
use src:   mach.lang.source;

# Severity: severity level of a Diagnostic, ordered most-to-least urgent.
pub def Severity: u8;

# SEVERITY_ERROR: an error; the most urgent severity.
pub val SEVERITY_ERROR:   Severity = 0;
# SEVERITY_WARNING: a warning that does not stop the build.
pub val SEVERITY_WARNING: Severity = 1;
# SEVERITY_INFO: an informational note.
pub val SEVERITY_INFO:    Severity = 2;
# SEVERITY_HELP: a help hint attached to another diagnostic.
pub val SEVERITY_HELP:    Severity = 3;

# Diagnostic: a single reported diagnostic tied to a span in a source file.
# ---
# severity: severity level of the diagnostic
# file_id:  identifier of the file the span points into
# span:     byte range being reported on
# message:  owned human-readable message
# note:     owned secondary "note:" line, or nil when absent
pub rec Diagnostic {
    severity: Severity;
    file_id:  src.FileId;
    span:     token.Span;
    message:  str;
    note:     str;
}

# DiagList: owning list of diagnostics collected during one or more phases.
# ---
# alloc: allocator used for the items array and every owned message
# items: contiguous array of Diagnostic records
# len:   number of diagnostics currently stored
# cap:   allocated slots in items
pub rec DiagList {
    alloc: *Allocator;
    items: *Diagnostic;
    len:   usize;
    cap:   usize;
}

val INITIAL_CAP: usize = 16;

# init: construct an empty diagnostic list backed by the given allocator.
# ---
# alloc: allocator used for the items array and owned messages
# ret:   a new empty DiagList
pub fun init(alloc: *Allocator) DiagList {
    var d: DiagList;
    d.alloc = alloc;
    d.items = nil;
    d.len   = 0;
    d.cap   = 0;
    ret d;
}

# dnit: free every diagnostic's message and the list's backing array.
# ---
# list: the list to tear down; all fields are zeroed
pub fun dnit(list: *DiagList) {
    if (list == nil) { ret; }

    var i: usize = 0;
    for (i < list.len) {
        val d: *Diagnostic = ?list.items[i];
        str_free(list.alloc, d.message);
        if (d.note != nil) { str_free(list.alloc, d.note); }
        i = i + 1;
    }

    if (list.items != nil && list.cap > 0) {
        deallocate[Diagnostic](list.alloc, list.items, list.cap);
    }
    list.items = nil;
    list.len   = 0;
    list.cap   = 0;
}

# error: record an error-severity diagnostic, duplicating the message into the list's allocator.
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun error(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_ERROR, file_id, span, message);
}

# warning: record a warning-severity diagnostic, duplicating the message into the list's allocator.
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun warning(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_WARNING, file_id, span, message);
}

# info: record an info-severity diagnostic, duplicating the message into the list's allocator.
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun info(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_INFO, file_id, span, message);
}

# help: record a help-severity diagnostic, duplicating the message into the list's allocator.
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun help(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_HELP, file_id, span, message);
}

# has_errors: report whether the list contains at least one error-severity diagnostic.
# ---
# list: the list to scan
# ret:  true if any entry has SEVERITY_ERROR
pub fun has_errors(list: *DiagList) bool {
    var i: usize = 0;
    for (i < list.len) {
        if (list.items[i].severity == SEVERITY_ERROR) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# emit: append a diagnostic of the given severity, growing the list and duplicating the message.
fun emit(list: *DiagList, severity: Severity, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    val r_msg: Result[str, str] = str_dup(list.alloc, message);
    if (is_err[str, str](r_msg)) {
        ret err[bool, str](unwrap_err[str, str](r_msg));
    }
    val owned: str = unwrap_ok[str, str](r_msg);

    if (list.items == nil) {
        val r: Result[*Diagnostic, str] = allocate[Diagnostic](list.alloc, INITIAL_CAP);
        if (is_err[*Diagnostic, str](r)) {
            str_free(list.alloc, owned);
            ret err[bool, str](unwrap_err[*Diagnostic, str](r));
        }
        list.items = unwrap_ok[*Diagnostic, str](r);
        list.cap   = INITIAL_CAP;
    }
    or (list.len == list.cap) {
        val new_cap: usize = list.cap * 2;
        val r: Result[*Diagnostic, str] = reallocate[Diagnostic](list.alloc, list.items, list.cap, new_cap);
        if (is_err[*Diagnostic, str](r)) {
            str_free(list.alloc, owned);
            ret err[bool, str](unwrap_err[*Diagnostic, str](r));
        }
        list.items = unwrap_ok[*Diagnostic, str](r);
        list.cap   = new_cap;
    }

    var d: Diagnostic;
    d.severity = severity;
    d.file_id  = file_id;
    d.span     = span;
    d.message  = owned;
    d.note     = nil;
    list.items[list.len] = d;
    list.len = list.len + 1;

    ret ok[bool, str](true);
}

# attach_note: attach an owned secondary "note:" line to the most recently
# recorded diagnostic. a no-op when the list is empty or the last diagnostic
# already carries a note. allocation failures are swallowed so a missing note
# never aborts a pass.
# ---
# list: diagnostic list whose last entry receives the note
# note: human-readable secondary message (copied)
pub fun attach_note(list: *DiagList, note: str) {
    if (list == nil || list.len == 0) { ret; }
    val d: *Diagnostic = ?list.items[list.len - 1];
    if (d.note != nil) { ret; }
    val r: Result[str, str] = str_dup(list.alloc, note);
    if (is_err[str, str](r)) { ret; }
    d.note = unwrap_ok[str, str](r);
}

# build_suggestion: allocate an owned `did you mean `<name>`?` note string,
# returning nil on allocation failure (the caller treats nil as "no note").
# the result is owned by `alloc`; the caller frees the temporary with str_free
# after passing it to attach_note (which dups it into the list allocator).
# ---
# alloc: allocator backing the returned string
# name:  candidate identifier to suggest
# ret:   the owned note string, or nil on failure
pub fun build_suggestion(alloc: *Allocator, name: str) str {
    val prefix: str = "did you mean `";
    val suffix: str = "`?";
    val pn: usize = str_len(prefix);
    val nn: usize = str_len(name);
    val sn: usize = str_len(suffix);
    val total: usize = pn + nn + sn;

    val r: Result[*char, str] = allocate[char](alloc, total + 1);
    if (is_err[*char, str](r)) { ret nil; }
    val buf: str = unwrap_ok[*char, str](r);

    mem.raw_copy(buf::ptr, prefix::ptr, pn);
    mem.raw_copy((buf::usize + pn)::ptr, name::ptr, nn);
    mem.raw_copy((buf::usize + pn + nn)::ptr, suffix::ptr, sn);
    buf[total] = 0;
    ret buf;
}
