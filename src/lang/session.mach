# top-level service container shared across every compilation phase
#
# Owns the source registry, diagnostic sink, string interner, type interner,
# and query database, plus the per-build module registries the incremental
# engine remaps against. Every phase takes a `*Session` and routes its service
# interactions through it.

use std.allocator.page;
use std.collections.map;
use std.text.string.str_dup;
use std.text.string.str_free;
use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;
use std.types.size.usize;
use std.types.string.str;
use std.types.string.str_equals;
use std.types.string.str_len;

use A: std.allocator;
use O: std.types.option;
use R: std.types.result;

use mach.lang.diagnostic;
use mach.lang.fe.ast;
use mach.lang.intern;
use mach.lang.module;
use mach.lang.query;
use mach.lang.source;
use mach.lang.target;
use mach.lang.type;

# re-export the project-wide module identity so consumers can spell it
# `session.ModuleId` / `session.MODULE_NIL` without importing mach.lang.module.
fwd module.ModuleId;
fwd module.MODULE_NIL;
fwd module.StableModuleId;
fwd module.STABLE_MODULE_NIL;

# an in-memory source overlay: unsaved buffer `text` shadowing the on-disk content
# of the file at `path` as the query engine's source input (#1588)
#
# The driver's parse read consults the overlay before touching disk, so a
# long-lived session (an LSP) can drive builds over live, unsaved edits. Both
# strings are owned by the session.
# ---
# path: the on-disk path the overlay shadows (owned)
# text: the live buffer text to use instead of the file's content (owned)
pub rec Overlay {
    path: str;
    text: str;
}

# top-level driver state shared across every compilation phase
#
# Built once over an Allocator and threaded through the pipeline as `*Session`.
# Owns the allocator-backed services every phase reads or writes plus the
# per-build module registries the incremental engine remaps against.
# ---
# alloc:            allocator used for all owned storage on the session
# sources:          registry of loaded source files
# diags:            diagnostic sink shared by every phase
# interner:         shared string interner used by sema and downstream phases
# types:            shared type universe used by sema, middle end, and backend
# module_asts:      ModuleId-indexed array of borrowed module ASTs, grown on demand
# module_ast_count: number of registered module ASTs (the registry's length)
# module_ast_cap:   allocated capacity of the module-AST registry
# module_fqns:      ModuleId -> the module's fully-qualified path StrId, read by the
#                    back-end mangler to name a cross-module symbol against its module
# export_names:     (ModuleId << 32 | DeclId) -> a literal link-name override from a
#                    `#[symbol(...)]` decorator or an `ext fun`; a registered decl keeps
#                    its literal name instead of being mangled
# export_libraries: (ModuleId << 32 | DeclId) -> the dynamic library a `#[library(...)]`
#                    decorator pins an `ext` import to (e.g. "ws2_32.dll")
# type_aligns:      nominal TypeId -> the explicit byte alignment an `#[align(...)]`
#                    decorator pins it to, folded by sema and read by the middle end
# import_libraries: link-name StrId -> the library StrId an import is pinned to, the
#                    link-name-keyed projection of export_libraries the linker consults
# module_sema:      ModuleId -> its *sema.SemaResult, stored opaque as `ptr` to keep
#                    this leaf module free of a front-end import cycle
# module_resolve:   ModuleId -> its *resolve.ResolveResult, stored opaque like module_sema
# module_comptime:  ModuleId -> its *comptime.ComptimeCtx, stored opaque like module_sema
# registry:         owned target registry (isa/os/abi/of vtables), zeroed at init and
#                    populated by the owner's target.register_all call
pub rec Session {
    alloc:    *A.Allocator;
    sources:  source.SourceMap;
    diags:    diagnostic.DiagList;
    interner: intern.Interner;
    types:    type.TypeInterner;

    # the memoization database every consumer (CLI, LSP, tests) drives the
    # compiler through. owns parsed ASTs as opaque Q_PARSE handles, so a
    # long-lived session reuses an unchanged module's AST across rebuilds
    # instead of re-parsing it.
    queries: query.QueryDb;

    module_asts:      **ast.Ast;
    module_ast_count: u32;
    module_ast_cap:   u32;

    module_fqns:      map.Map[module.ModuleId, intern.StrId];
    export_names:     map.Map[u64, intern.StrId];
    export_libraries: map.Map[u64, intern.StrId];
    type_aligns:      map.Map[u32, u32];
    import_libraries: map.Map[intern.StrId, intern.StrId];

    module_sema:     map.Map[module.ModuleId, ptr];
    module_resolve:  map.Map[module.ModuleId, ptr];
    module_comptime: map.Map[module.ModuleId, ptr];

    # persistent FQN StrId -> StableModuleId, assigned in first-seen order and
    # never renumbered, so a module keeps one identity across rebuilds even as
    # discovery-order ModuleIds are reassigned. deliberately NOT cleared by
    # reset_module_registry - it must outlive a build to serve the next one.
    # stable_id_next is the monotonic source of the next id to hand out.
    stable_ids:     map.Map[intern.StrId, module.StableModuleId];
    stable_id_next: module.StableModuleId;

    # the PER-BUILD inverse of the active build's identity assignment:
    # StableModuleId -> the discovery-order ModuleId it holds this build.
    # populated alongside register_module_ast and cleared each build, it is the
    # table a reused ResolveResult is remapped through (resolve.remap_result).
    stable_to_mid: map.Map[module.StableModuleId, module.ModuleId];

    registry: target.TargetRegistry;

    # in-memory source overlays keyed by path (#1588): live unsaved buffer text a
    # long-lived session's parse read uses instead of the file on disk. a small
    # owned array scanned by path - the open-buffer set is tiny - grown on demand
    # and freed in dnit. deliberately NOT cleared by reset_module_registry: an
    # overlay must outlive a build to shadow the file on the next one.
    overlays:    *Overlay;
    overlay_len: u32;
    overlay_cap: u32;
}

# seed capacity of the module-AST registry, doubled on demand from there
val MODULE_AST_SEED_CAP: u32 = 16;

# seed capacity of the source-overlay array, doubled on demand from there
val OVERLAY_SEED_CAP: u32 = 4;

# construct an empty Session backed by the given allocator
#
# Sub-services are built in order: sources, diags, interner (infallible), then
# types and queries (fallible), and finally the session-owned query catalog. The
# target registry is zeroed here but its vtables are NOT installed: the owner
# calls target.register_all on the returned session so the vtable name strings
# intern into the session's final interner. On any failure the prior sub-services
# are torn down in reverse construction order.
# ---
# alloc: allocator used for all session-owned storage
# ret:   a new empty Session, or an allocation error from a fallible sub-service
pub fun init(alloc: *A.Allocator) R.Result[Session, str] {
    var s: Session;
    s.alloc            = alloc;
    s.sources          = source.init(alloc);
    s.diags            = diagnostic.init(alloc);
    s.interner         = intern.init(alloc);
    s.module_asts      = nil;
    s.module_ast_count = 0;
    s.module_ast_cap   = 0;
    s.module_fqns      = map.init[module.ModuleId, intern.StrId](alloc, map.hash_u32, map.eq_u32);
    s.export_names     = map.init[u64, intern.StrId](alloc, map.hash_u64, map.eq_u64);
    s.export_libraries = map.init[u64, intern.StrId](alloc, map.hash_u64, map.eq_u64);
    s.type_aligns      = map.init[u32, u32](alloc, map.hash_u32, map.eq_u32);
    s.import_libraries = map.init[intern.StrId, intern.StrId](alloc, map.hash_u32, map.eq_u32);
    s.module_sema      = map.init[module.ModuleId, ptr](alloc, map.hash_u32, map.eq_u32);
    s.module_resolve   = map.init[module.ModuleId, ptr](alloc, map.hash_u32, map.eq_u32);
    s.module_comptime  = map.init[module.ModuleId, ptr](alloc, map.hash_u32, map.eq_u32);
    s.stable_ids       = map.init[intern.StrId, module.StableModuleId](alloc, map.hash_u32, map.eq_u32);
    s.stable_id_next   = 0;
    s.stable_to_mid    = map.init[module.StableModuleId, module.ModuleId](alloc, map.hash_u32, map.eq_u32);
    s.registry         = target.registry_init();
    s.overlays         = nil;
    s.overlay_len      = 0;
    s.overlay_cap      = 0;

    val opt_types: O.Option[str] = type.init(?s.types, alloc);
    if (O.is_some[str](opt_types)) {
        intern.dnit(?s.interner);
        diagnostic.dnit(?s.diags);
        source.dnit(?s.sources);
        ret R.err[Session, str](O.unwrap[str](opt_types));
    }

    val res_queries: R.Result[query.QueryDb, str] = query.init(alloc);
    if (R.is_err[query.QueryDb, str](res_queries)) {
        type.dnit(?s.types);
        intern.dnit(?s.interner);
        diagnostic.dnit(?s.diags);
        source.dnit(?s.sources);
        ret R.err[Session, str](R.unwrap_err[query.QueryDb, str](res_queries));
    }
    s.queries = R.unwrap_ok[query.QueryDb, str](res_queries);

    val res_catalog: R.Result[bool, str] = register_catalog(?s.queries);
    if (R.is_err[bool, str](res_catalog)) {
        query.dnit(?s.queries);
        type.dnit(?s.types);
        intern.dnit(?s.interner);
        diagnostic.dnit(?s.diags);
        source.dnit(?s.sources);
        ret R.err[Session, str](R.unwrap_err[bool, str](res_catalog));
    }

    ret R.ok[Session, str](s);
}

# register the catalog input kinds owned by the session
#
# The input queries (project root, target, per-file text, per-module number) are
# self-contained and bound here. Derived kinds are reserved by their owning phase
# modules (e.g. the driver registers Q_PARSE), which bind the compute functions
# the database invokes. Q_FILE_TEXT holds each file's source text, set by
# load_source; its byte-equality cutoff is what keeps an unchanged file's Q_PARSE
# entry valid across rebuilds.
# ---
# db:  the freshly constructed query database
# ret: true once every session-owned input kind is registered, or the first error
fun register_catalog(db: *query.QueryDb) R.Result[bool, str] {
    val res_root: R.Result[bool, str] = query.register_input(db, query.Q_PROJECT_ROOT);
    if (R.is_err[bool, str](res_root)) { ret res_root; }

    val res_target: R.Result[bool, str] = query.register_input(db, query.Q_TARGET);
    if (R.is_err[bool, str](res_target)) { ret res_target; }

    val res_text: R.Result[bool, str] = query.register_input(db, query.Q_FILE_TEXT);
    if (R.is_err[bool, str](res_text)) { ret res_text; }

    # Q_MODULE_NUMBER carries each module's current per-build ModuleId so Q_SEMA
    # can detect a graph reshape that renumbers a module's interned type
    # identities. its early cutoff keeps a content-only edit's sema reuse valid.
    val res_number: R.Result[bool, str] = query.register_input(db, query.Q_MODULE_NUMBER);
    if (R.is_err[bool, str](res_number)) { ret res_number; }

    # Q_LINK_CONFIG carries the link-only build configuration (output path/product,
    # output kind, pie, external link inputs) so Q_LINK re-links on a change to any
    # of them; its early cutoff keeps the link reused when the config is unchanged.
    val res_link_cfg: R.Result[bool, str] = query.register_input(db, query.Q_LINK_CONFIG);
    if (R.is_err[bool, str](res_link_cfg)) { ret res_link_cfg; }

    # Q_LOWER_FLAGS carries the lowering diagnostic flags (the IR-verifier toggle) so
    # Q_LOWER re-lowers when they change; its early cutoff keeps lowering reused when
    # they are unchanged.
    val res_lower_flags: R.Result[bool, str] = query.register_input(db, query.Q_LOWER_FLAGS);
    if (R.is_err[bool, str](res_lower_flags)) { ret res_lower_flags; }

    ret R.ok[bool, str](true);
}

# release every resource held by the session
# ---
# s: session to tear down; sub-structures are dnit'd in reverse construction order
pub fun dnit(s: *Session) {
    if (s == nil) { ret; }

    if (s.overlays != nil && s.overlay_cap > 0) {
        var oi: u32 = 0;
        for (oi < s.overlay_len) {
            str_free(s.alloc, s.overlays[oi].path);
            str_free(s.alloc, s.overlays[oi].text);
            oi = oi + 1;
        }
        A.deallocate[Overlay](s.alloc, s.overlays, s.overlay_cap::usize);
        s.overlays    = nil;
        s.overlay_len = 0;
        s.overlay_cap = 0;
    }

    if (s.module_asts != nil && s.module_ast_cap > 0) {
        A.deallocate[*ast.Ast](s.alloc, s.module_asts, s.module_ast_cap::usize);
        s.module_asts      = nil;
        s.module_ast_count = 0;
        s.module_ast_cap   = 0;
    }

    map.dnit[module.ModuleId, intern.StrId](?s.module_fqns);
    map.dnit[u64, intern.StrId](?s.export_names);
    map.dnit[u64, intern.StrId](?s.export_libraries);
    map.dnit[u32, u32](?s.type_aligns);
    map.dnit[intern.StrId, intern.StrId](?s.import_libraries);
    map.dnit[module.ModuleId, ptr](?s.module_sema);
    map.dnit[module.ModuleId, ptr](?s.module_resolve);
    map.dnit[module.ModuleId, ptr](?s.module_comptime);
    map.dnit[intern.StrId, module.StableModuleId](?s.stable_ids);
    map.dnit[module.StableModuleId, module.ModuleId](?s.stable_to_mid);

    query.dnit(?s.queries);
    type.dnit(?s.types);
    intern.dnit(?s.interner);
    diagnostic.dnit(?s.diags);
    source.dnit(?s.sources);
}

# clear the per-build module registries so the session can be reused for a fresh
# build
#
# Frees the module-AST array (reallocated lazily on the next register_module_ast)
# and empties every per-build map. The module_sema/resolve/comptime maps hold
# BORROWED pointers into Project-owned storage the driver frees in dnit_project,
# and the FQN / export / import maps hold persistent StrIds or per-build keys, so
# map.clear is used throughout - it empties the slots while leaving value storage
# untouched, never freeing a borrowed pointer or a live interned string. Call this
# at the END of a project teardown (after the Project frees) so the next build
# starts from a clean registry rather than entries pointing at freed storage.
#
# The FQN -> StableModuleId registry (`stable_ids`) is deliberately NOT cleared:
# its whole purpose is to outlive a build so a module keeps one identity across
# rebuilds, the key future resolve/sema reuse remaps against.
# ---
# s: the session whose per-build module registries are emptied
pub fun reset_module_registry(s: *Session) {
    if (s == nil) { ret; }

    if (s.module_asts != nil && s.module_ast_cap > 0) {
        A.deallocate[*ast.Ast](s.alloc, s.module_asts, s.module_ast_cap::usize);
    }
    s.module_asts      = nil;
    s.module_ast_count = 0;
    s.module_ast_cap   = 0;

    map.clear[module.ModuleId, intern.StrId](?s.module_fqns);
    map.clear[u64, intern.StrId](?s.export_names);
    map.clear[u64, intern.StrId](?s.export_libraries);
    map.clear[u32, u32](?s.type_aligns);
    map.clear[intern.StrId, intern.StrId](?s.import_libraries);
    map.clear[module.ModuleId, ptr](?s.module_sema);
    map.clear[module.ModuleId, ptr](?s.module_resolve);
    map.clear[module.ModuleId, ptr](?s.module_comptime);

    # the per-build StableModuleId -> ModuleId inverse is rebuilt from scratch
    # each build; clear it so a reshape's new numbering never collides with a
    # stale entry.
    map.clear[module.StableModuleId, module.ModuleId](?s.stable_to_mid);
}

# record `a` as the AST of module `mid`, growing the registry to cover `mid` and
# zero-filling any gap
#
# The registry borrows `a`; the caller (the driver) owns the storage and must
# keep it alive for the registry's lifetime. Registering the same id overwrites.
# ---
# s:   the session
# mid: project-wide ModuleId the AST belongs to
# a:   borrowed pointer to the module's parsed AST
# ret: true on success, or an allocation error
pub fun register_module_ast(s: *Session, mid: module.ModuleId, a: *ast.Ast) R.Result[bool, str] {
    val needed: u32 = mid::u32 + 1;
    if (needed > s.module_ast_cap) {
        var new_cap: u32 = s.module_ast_cap;
        if (new_cap == 0) { new_cap = MODULE_AST_SEED_CAP; }
        for (new_cap < needed) { new_cap = new_cap * 2; }

        if (s.module_asts == nil) {
            val res_alloc: R.Result[**ast.Ast, str] = A.allocate[*ast.Ast](s.alloc, new_cap::usize);
            if (R.is_err[**ast.Ast, str](res_alloc)) {
                ret R.err[bool, str](R.unwrap_err[**ast.Ast, str](res_alloc));
            }
            s.module_asts = R.unwrap_ok[**ast.Ast, str](res_alloc);
        } or {
            val res_realloc: R.Result[**ast.Ast, str] = A.reallocate[*ast.Ast](s.alloc, s.module_asts, s.module_ast_cap::usize, new_cap::usize);
            if (R.is_err[**ast.Ast, str](res_realloc)) {
                ret R.err[bool, str](R.unwrap_err[**ast.Ast, str](res_realloc));
            }
            s.module_asts = R.unwrap_ok[**ast.Ast, str](res_realloc);
        }

        var i: u32 = s.module_ast_cap;
        for (i < new_cap) {
            s.module_asts[i] = nil;
            i = i + 1;
        }
        s.module_ast_cap = new_cap;
    }

    s.module_asts[mid::u32] = a;
    if (needed > s.module_ast_count) { s.module_ast_count = needed; }
    ret R.ok[bool, str](true);
}

# the registered AST of module `mid`, or nil when the id is out of range or no AST
# was registered for it
# ---
# s:   the session
# mid: project-wide ModuleId to look up
# ret: borrowed pointer to the module's AST, or nil
pub fun module_ast(s: *Session, mid: module.ModuleId) *ast.Ast {
    if (mid == module.MODULE_NIL)                               { ret nil; }
    if (s.module_asts == nil || mid::u32 >= s.module_ast_count) { ret nil; }
    ret s.module_asts[mid::u32];
}

# the number of registered modules - the dense upper bound on ModuleIds
# (`0 .. module_count`)
#
# Lets a phase enumerate every loaded module, e.g. to assemble a typing-snapshot
# set for cross-module lookups.
# ---
# s:   the session
# ret: the registered module count
pub fun module_count(s: *Session) u32 {
    ret s.module_ast_count;
}

# record `fqn` as the fully-qualified path of module `mid`
#
# Read by the back-end mangler to name a cross-module symbol against its defining
# module. Populated by the driver alongside register_module_ast. Registering the
# same id overwrites.
# ---
# s:   the session
# mid: project-wide ModuleId the fqn belongs to
# fqn: interned FQN StrId (e.g. "std.allocator")
# ret: true on success, or an allocation error from the registry map
pub fun register_module_fqn(s: *Session, mid: module.ModuleId, fqn: intern.StrId) R.Result[bool, str] {
    ret map.insert[module.ModuleId, intern.StrId](?s.module_fqns, mid, fqn);
}

# the registered FQN of module `mid`, or STR_NIL when the id is MODULE_NIL or no
# FQN was registered for it
# ---
# s:   the session
# mid: project-wide ModuleId to look up
# ret: the module's FQN StrId, or intern.STR_NIL
pub fun module_fqn(s: *Session, mid: module.ModuleId) intern.StrId {
    if (mid == module.MODULE_NIL) { ret intern.STR_NIL; }
    val res_get: R.Result[*intern.StrId, str] = map.get[module.ModuleId, intern.StrId](?s.module_fqns, ?mid);
    if (R.is_ok[*intern.StrId, str](res_get)) {
        ret @R.unwrap_ok[*intern.StrId, str](res_get);
    }
    ret intern.STR_NIL;
}

# the build-stable identity of the module named by `fqn`, assigning the next id on
# first sight and returning the existing one on every later request
#
# This is the cross-build identity the discovery-order ModuleId is not: the same
# FQN keeps the same StableModuleId even when a changed graph shape renumbers
# ModuleIds, since the registry persists across rebuilds.
# ---
# s:   the session
# fqn: interned fully-qualified module path
# ret: the module's StableModuleId, or an allocation error from the registry map
pub fun stable_module_id(s: *Session, fqn: intern.StrId) R.Result[module.StableModuleId, str] {
    val res_get: R.Result[*module.StableModuleId, str] = map.get[intern.StrId, module.StableModuleId](?s.stable_ids, ?fqn);
    if (R.is_ok[*module.StableModuleId, str](res_get)) {
        ret R.ok[module.StableModuleId, str](@R.unwrap_ok[*module.StableModuleId, str](res_get));
    }

    val id: module.StableModuleId = s.stable_id_next;
    val res_insert: R.Result[bool, str] = map.insert[intern.StrId, module.StableModuleId](?s.stable_ids, fqn, id);
    if (R.is_err[bool, str](res_insert)) {
        ret R.err[module.StableModuleId, str](R.unwrap_err[bool, str](res_insert));
    }
    s.stable_id_next = s.stable_id_next + 1;
    ret R.ok[module.StableModuleId, str](id);
}

# the StableModuleId already assigned to `fqn`, or STABLE_MODULE_NIL when the
# module has never been seen
#
# A read-only probe that, unlike stable_module_id, never assigns a new id.
# ---
# s:   the session
# fqn: interned fully-qualified module path
# ret: the module's StableModuleId, or STABLE_MODULE_NIL
pub fun stable_module_id_lookup(s: *Session, fqn: intern.StrId) module.StableModuleId {
    val res_get: R.Result[*module.StableModuleId, str] = map.get[intern.StrId, module.StableModuleId](?s.stable_ids, ?fqn);
    if (R.is_ok[*module.StableModuleId, str](res_get)) {
        ret @R.unwrap_ok[*module.StableModuleId, str](res_get);
    }
    ret module.STABLE_MODULE_NIL;
}

# record that StableModuleId `stable` holds discovery-order ModuleId `mid` in the
# build currently running
#
# The driver calls this once per module each build (alongside register_module_ast);
# reset_module_registry clears the table so each build's numbering stands alone.
# Registering the same key overwrites.
# ---
# s:      the session
# stable: the module's build-stable identity
# mid:    the per-build ModuleId it holds this build
# ret:    true on success, or an allocation error from the registry map
pub fun register_stable_mid(s: *Session, stable: module.StableModuleId, mid: module.ModuleId) R.Result[bool, str] {
    ret map.insert[module.StableModuleId, module.ModuleId](?s.stable_to_mid, stable, mid);
}

# the current build's ModuleId for StableModuleId `stable`, or MODULE_NIL when
# `stable` is STABLE_MODULE_NIL or names no module loaded this build
#
# The lookup resolve.remap_result drives to translate a reused result's stale
# ModuleIds into the active build's numbering.
# ---
# s:      the session
# stable: a build-stable module identity
# ret:    the per-build ModuleId, or MODULE_NIL
pub fun module_id_for_stable(s: *Session, stable: module.StableModuleId) module.ModuleId {
    if (stable == module.STABLE_MODULE_NIL) { ret module.MODULE_NIL; }
    val res_get: R.Result[*module.ModuleId, str] = map.get[module.StableModuleId, module.ModuleId](?s.stable_to_mid, ?stable);
    if (R.is_ok[*module.ModuleId, str](res_get)) {
        ret @R.unwrap_ok[*module.ModuleId, str](res_get);
    }
    ret module.MODULE_NIL;
}

# record a literal link-name override for decl `did` in module `mid`
#
# A registered decl keeps its literal name through lowering instead of being
# mangled - the exemption mechanism for `#[symbol(...)]` entry / runtime
# decorators and `ext fun` foreign symbols. Registering the same key overwrites.
# ---
# s:    the session
# mid:  ModuleId owning the decl
# did:  DeclId of the overridden function / global in `mid`'s AST
# name: the literal symbol name to emit
# ret:  true on success, or an allocation error from the registry map
pub fun register_export_name(s: *Session, mid: module.ModuleId, did: u32, name: intern.StrId) R.Result[bool, str] {
    val key: u64 = (mid::u64 << 32) | did::u64;
    ret map.insert[u64, intern.StrId](?s.export_names, key, name);
}

# the literal link-name override registered for decl `did` in module `mid`, or
# none when the decl is to be mangled normally
# ---
# s:   the session
# mid: ModuleId owning the decl
# did: DeclId to look up
# ret: some(name) when an override is registered, none otherwise
pub fun export_name(s: *Session, mid: module.ModuleId, did: u32) O.Option[intern.StrId] {
    var key: u64 = (mid::u64 << 32) | did::u64;
    val res_get: R.Result[*intern.StrId, str] = map.get[u64, intern.StrId](?s.export_names, ?key);
    if (R.is_ok[*intern.StrId, str](res_get)) {
        ret O.some[intern.StrId](@R.unwrap_ok[*intern.StrId, str](res_get));
    }
    ret O.none[intern.StrId]();
}

# record the dynamic library a `#[library(...)]` decorator pins decl `did` (an
# `ext` import) to, keyed by (ModuleId, DeclId)
#
# The driver later projects this onto import_libraries by the decl's final link
# name so the linker can attribute the import to a specific dependency.
# Registering the same key overwrites.
# ---
# s:   the session
# mid: ModuleId owning the decl
# did: DeclId of the `ext` import named by the directive
# lib: the library name to pin the import to (e.g. "ws2_32.dll")
# ret: true on success, or an allocation error from the registry map
pub fun register_export_library(s: *Session, mid: module.ModuleId, did: u32, lib: intern.StrId) R.Result[bool, str] {
    val key: u64 = (mid::u64 << 32) | did::u64;
    ret map.insert[u64, intern.StrId](?s.export_libraries, key, lib);
}

# the library decl `did` in module `mid` is pinned to by a `#[library(...)]`
# decorator, or none when the import is unattributed
# ---
# s:   the session
# mid: ModuleId owning the decl
# did: DeclId to look up
# ret: some(lib) when a library directive is registered, none otherwise
pub fun export_library(s: *Session, mid: module.ModuleId, did: u32) O.Option[intern.StrId] {
    var key: u64 = (mid::u64 << 32) | did::u64;
    val res_get: R.Result[*intern.StrId, str] = map.get[u64, intern.StrId](?s.export_libraries, ?key);
    if (R.is_ok[*intern.StrId, str](res_get)) {
        ret O.some[intern.StrId](@R.unwrap_ok[*intern.StrId, str](res_get));
    }
    ret O.none[intern.StrId]();
}

# record the explicit alignment an `#[align(...)]` decorator pins nominal TypeId
# `tid` to
#
# Folded once by sema; the middle end reads it when lowering the nominal so its IR
# struct carries the override. Registering the same key overwrites.
# ---
# s:     the session
# tid:   nominal TypeId (a `type.TypeId`, cast to u32)
# align: the byte alignment (a power of two)
# ret:   true on success, or an allocation error from the registry map
pub fun register_type_align(s: *Session, tid: u32, align: u32) R.Result[bool, str] {
    ret map.insert[u32, u32](?s.type_aligns, tid, align);
}

# the explicit alignment registered for nominal TypeId `tid`, or none when the
# type uses its natural alignment
# ---
# s:   the session
# tid: nominal TypeId (cast to u32)
# ret: some(align) when an override is registered, none otherwise
pub fun type_align(s: *Session, tid: u32) O.Option[u32] {
    val res_get: R.Result[*u32, str] = map.get[u32, u32](?s.type_aligns, ?tid);
    if (R.is_ok[*u32, str](res_get)) {
        ret O.some[u32](@R.unwrap_ok[*u32, str](res_get));
    }
    ret O.none[u32]();
}

# pin the import emitted under link name `name` to library `lib`
#
# The driver builds this link-name-keyed projection of the per-decl
# export_libraries once link names are final; the linker reads it to route each
# import to its dependency. Registering the same key overwrites.
# ---
# s:    the session
# name: the import's final link symbol name (the object symbol the linker sees)
# lib:  the library name to pin it to
# ret:  true on success, or an allocation error from the registry map
pub fun register_import_library(s: *Session, name: intern.StrId, lib: intern.StrId) R.Result[bool, str] {
    ret map.insert[intern.StrId, intern.StrId](?s.import_libraries, name, lib);
}

# the library the import emitted under link symbol `name` is pinned to, or none
# when the import is unattributed (binds to the first dependency)
# ---
# s:    the session
# name: the import's link symbol name
# ret:  some(lib) when the import is pinned, none otherwise
pub fun import_library(s: *Session, name: intern.StrId) O.Option[intern.StrId] {
    val res_get: R.Result[*intern.StrId, str] = map.get[intern.StrId, intern.StrId](?s.import_libraries, ?name);
    if (R.is_ok[*intern.StrId, str](res_get)) {
        ret O.some[intern.StrId](@R.unwrap_ok[*intern.StrId, str](res_get));
    }
    ret O.none[intern.StrId]();
}

# record module `mid`'s `*sema.SemaResult` (passed as an opaque `ptr`)
#
# Lets the back-end monomorphizer lower a generic template body against the
# declaring module's typing. The caller owns the storage and must keep it alive
# for the build's lifetime.
# ---
# s:   the session
# mid: ModuleId the result belongs to
# p:   the module's SemaResult, cast to `ptr`
# ret: true on success, or an allocation error from the registry map
pub fun register_module_sema(s: *Session, mid: module.ModuleId, p: ptr) R.Result[bool, str] {
    ret map.insert[module.ModuleId, ptr](?s.module_sema, mid, p);
}

# module `mid`'s registered SemaResult as an opaque `ptr`, or nil when none is
# registered
#
# The caller casts it back to *sema.SemaResult.
# ---
# s:   the session
# mid: ModuleId to look up
# ret: the SemaResult `ptr`, or nil
pub fun module_sema_ptr(s: *Session, mid: module.ModuleId) ptr {
    val res_get: R.Result[*ptr, str] = map.get[module.ModuleId, ptr](?s.module_sema, ?mid);
    if (R.is_ok[*ptr, str](res_get)) {
        ret @R.unwrap_ok[*ptr, str](res_get);
    }
    ret nil;
}

# record module `mid`'s `*resolve.ResolveResult` as an opaque `ptr`, the
# name-resolution twin of register_module_sema
# ---
# s:   the session
# mid: ModuleId the result belongs to
# p:   the module's ResolveResult, cast to `ptr`
# ret: true on success, or an allocation error from the registry map
pub fun register_module_resolve(s: *Session, mid: module.ModuleId, p: ptr) R.Result[bool, str] {
    ret map.insert[module.ModuleId, ptr](?s.module_resolve, mid, p);
}

# module `mid`'s registered ResolveResult as an opaque `ptr`, or nil
#
# The caller casts it back to *resolve.ResolveResult.
# ---
# s:   the session
# mid: ModuleId to look up
# ret: the ResolveResult `ptr`, or nil
pub fun module_resolve_ptr(s: *Session, mid: module.ModuleId) ptr {
    val res_get: R.Result[*ptr, str] = map.get[module.ModuleId, ptr](?s.module_resolve, ?mid);
    if (R.is_ok[*ptr, str](res_get)) {
        ret @R.unwrap_ok[*ptr, str](res_get);
    }
    ret nil;
}

# record module `mid`'s `*comptime.ComptimeCtx` as an opaque `ptr`, the comptime
# twin of register_module_sema
#
# The back-end value-parameter monomorphizer casts it back to bind `$param ->
# CTValue` and fold a value-instance body's `$if` gates against the comptime
# constants of the module that declared the function, not the calling module's.
# ---
# s:   the session
# mid: ModuleId the context belongs to
# p:   the module's ComptimeCtx, cast to `ptr`
# ret: true on success, or an allocation error from the registry map
pub fun register_module_comptime(s: *Session, mid: module.ModuleId, p: ptr) R.Result[bool, str] {
    ret map.insert[module.ModuleId, ptr](?s.module_comptime, mid, p);
}

# module `mid`'s registered ComptimeCtx as an opaque `ptr`, or nil
#
# The caller casts it back to *comptime.ComptimeCtx.
# ---
# s:   the session
# mid: ModuleId to look up
# ret: the ComptimeCtx `ptr`, or nil
pub fun module_comptime_ptr(s: *Session, mid: module.ModuleId) ptr {
    val res_get: R.Result[*ptr, str] = map.get[module.ModuleId, ptr](?s.module_comptime, ?mid);
    if (R.is_ok[*ptr, str](res_get)) {
        ret @R.unwrap_ok[*ptr, str](res_get);
    }
    ret nil;
}

# register a source file with the session and return its FileId
#
# Delegates to source.load, which dedups by path: a first-seen path is appended, a
# known path reuses its FileId and is text-swapped in place, so a long-lived
# session (an LSP reloading on save) does not grow on reload. The loaded text is
# then mirrored into the Q_FILE_TEXT query input keyed by FileId; set_input's
# byte-equality cutoff leaves the input unchanged on an identical reload (so a
# dependent Q_PARSE entry stays valid and the AST is reused) and advances it on a
# real edit (so Q_PARSE recomputes).
# ---
# s:    the session
# path: file path to associate with this file
# text: null-terminated source text to index and store
# ret:  FileId the path is registered under (stable across reloads), or an allocation error
pub fun load_source(s: *Session, path: str, text: str) R.Result[source.FileId, str] {
    val res_fid: R.Result[source.FileId, str] = source.load(?s.sources, ?s.queries, ?s.interner, path, text);
    if (R.is_err[source.FileId, str](res_fid)) {
        ret res_fid;
    }
    val fid: source.FileId = R.unwrap_ok[source.FileId, str](res_fid);

    val res_input: R.Result[bool, str] = query.set_input(?s.queries, query.Q_FILE_TEXT, fid::u64, text::*u8, str_len(text)::u32);
    if (R.is_err[bool, str](res_input)) {
        ret R.err[source.FileId, str](R.unwrap_err[bool, str](res_input));
    }
    ret R.ok[source.FileId, str](fid);
}

# set (or replace) the in-memory source overlay for `path`
#
# `text` shadows the on-disk content of the file at `path` as the query engine's
# source input the next build reads: the driver's parse read consults the overlay
# before touching disk. The LSP feeds live unsaved buffer text this way, keyed by
# path to sidestep its URI-keyed editor FileIds. Both strings are copied into the
# session; replacing an existing overlay frees its prior text. An unchanged overlay
# reused across builds keeps the module's Q_PARSE valid (load_source's Q_FILE_TEXT
# byte cutoff); a changed one re-parses exactly the overlaid module (#1588).
# ---
# s:    the session
# path: the on-disk path to shadow
# text: the live buffer text to use instead of the file's content
# ret:  true on success, or an allocation error
pub fun set_overlay(s: *Session, path: str, text: str) R.Result[bool, str] {
    val dup_text_r: R.Result[str, str] = str_dup(s.alloc, text);
    if (R.is_err[str, str](dup_text_r)) { ret R.err[bool, str](R.unwrap_err[str, str](dup_text_r)); }
    val dup_text: str = R.unwrap_ok[str, str](dup_text_r);

    # replace an existing overlay's text in place, keeping its path key.
    var i: u32 = 0;
    for (i < s.overlay_len) {
        if (str_equals(s.overlays[i].path, path)) {
            str_free(s.alloc, s.overlays[i].text);
            s.overlays[i].text = dup_text;
            ret R.ok[bool, str](true);
        }
        i = i + 1;
    }

    # append a new overlay, growing the array on demand.
    val dup_path_r: R.Result[str, str] = str_dup(s.alloc, path);
    if (R.is_err[str, str](dup_path_r)) {
        str_free(s.alloc, dup_text);
        ret R.err[bool, str](R.unwrap_err[str, str](dup_path_r));
    }
    val dup_path: str = R.unwrap_ok[str, str](dup_path_r);

    val res_grow: R.Result[bool, str] = overlays_reserve(s, s.overlay_len + 1);
    if (R.is_err[bool, str](res_grow)) {
        str_free(s.alloc, dup_text);
        str_free(s.alloc, dup_path);
        ret res_grow;
    }
    s.overlays[s.overlay_len].path = dup_path;
    s.overlays[s.overlay_len].text = dup_text;
    s.overlay_len = s.overlay_len + 1;
    ret R.ok[bool, str](true);
}

# drop the overlay for `path`, so the next build reads the on-disk content again
# ---
# s:    the session
# path: the overlaid path to clear
# ret:  true when an overlay was present and removed, false when none matched
pub fun clear_overlay(s: *Session, path: str) bool {
    var i: u32 = 0;
    for (i < s.overlay_len) {
        if (str_equals(s.overlays[i].path, path)) {
            str_free(s.alloc, s.overlays[i].path);
            str_free(s.alloc, s.overlays[i].text);
            val last: u32 = s.overlay_len - 1;
            if (i != last) { s.overlays[i] = s.overlays[last]; }
            s.overlay_len = last;
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# the overlay text registered for `path`, or none
#
# The returned text is borrowed from the session, valid until the overlay is
# replaced or cleared. The driver's parse read uses it in place of the file.
# ---
# s:    the session
# path: the path to look up
# ret:  some(text) when an overlay is set for path, none otherwise
pub fun overlay_get(s: *Session, path: str) O.Option[str] {
    var i: u32 = 0;
    for (i < s.overlay_len) {
        if (str_equals(s.overlays[i].path, path)) {
            ret O.some[str](s.overlays[i].text);
        }
        i = i + 1;
    }
    ret O.none[str]();
}

# grow the overlay array to at least `need` slots, doubling from the seed capacity
fun overlays_reserve(s: *Session, need: u32) R.Result[bool, str] {
    if (need <= s.overlay_cap) { ret R.ok[bool, str](true); }

    var new_cap: u32 = s.overlay_cap;
    if (new_cap == 0) { new_cap = OVERLAY_SEED_CAP; }
    for (new_cap < need) { new_cap = new_cap * 2; }

    if (s.overlays == nil) {
        val res_alloc: R.Result[*Overlay, str] = A.allocate[Overlay](s.alloc, new_cap::usize);
        if (R.is_err[*Overlay, str](res_alloc)) { ret R.err[bool, str](R.unwrap_err[*Overlay, str](res_alloc)); }
        s.overlays = R.unwrap_ok[*Overlay, str](res_alloc);
    }
    or {
        val res_realloc: R.Result[*Overlay, str] = A.reallocate[Overlay](s.alloc, s.overlays, s.overlay_cap::usize, new_cap::usize);
        if (R.is_err[*Overlay, str](res_realloc)) { ret R.err[bool, str](R.unwrap_err[*Overlay, str](res_realloc)); }
        s.overlays = R.unwrap_ok[*Overlay, str](res_realloc);
    }
    s.overlay_cap = new_cap;
    ret R.ok[bool, str](true);
}

# overlays set, read back, replace text in place, and clear exactly one entry;
# an absent path reads as none and clears false (#1588)
test "mach.lang.session.overlay:set_get_replace_clear" {
    var alloc: A.Allocator;
    page.make(?alloc);
    val sr: R.Result[Session, str] = init(?alloc);
    if (R.is_err[Session, str](sr)) { ret 1; }
    var s: Session = R.unwrap_ok[Session, str](sr);

    var bad: i32 = 0;

    # absent overlay reads as none; clearing an absent path is false.
    if (O.is_some[str](overlay_get(?s, "/x/a.mach"))) { bad = 1; }
    if (clear_overlay(?s, "/x/a.mach"))               { bad = 1; }

    # set two overlays; each reads back its own text.
    if (R.is_err[bool, str](set_overlay(?s, "/x/a.mach", "AAA"))) { dnit(?s); ret 1; }
    if (R.is_err[bool, str](set_overlay(?s, "/x/b.mach", "BBB"))) { dnit(?s); ret 1; }
    if (s.overlay_len != 2) { bad = 1; }
    val ga: O.Option[str] = overlay_get(?s, "/x/a.mach");
    val gb: O.Option[str] = overlay_get(?s, "/x/b.mach");
    if (O.is_none[str](ga) || !str_equals(O.unwrap[str](ga), "AAA")) { bad = 1; }
    if (O.is_none[str](gb) || !str_equals(O.unwrap[str](gb), "BBB")) { bad = 1; }

    # replacing an existing path swaps text in place, adding no new slot.
    if (R.is_err[bool, str](set_overlay(?s, "/x/a.mach", "A2"))) { dnit(?s); ret 1; }
    if (s.overlay_len != 2) { bad = 1; }
    val ga2: O.Option[str] = overlay_get(?s, "/x/a.mach");
    if (O.is_none[str](ga2) || !str_equals(O.unwrap[str](ga2), "A2")) { bad = 1; }

    # clearing removes exactly one; the sibling survives.
    if (!clear_overlay(?s, "/x/a.mach"))              { bad = 1; }
    if (s.overlay_len != 1)                           { bad = 1; }
    if (O.is_some[str](overlay_get(?s, "/x/a.mach"))) { bad = 1; }
    val gb2: O.Option[str] = overlay_get(?s, "/x/b.mach");
    if (O.is_none[str](gb2) || !str_equals(O.unwrap[str](gb2), "BBB")) { bad = 1; }

    # dnit frees the remaining overlay's owned strings; a clean teardown is the
    # observable (the page allocator faults a leak/double-free).
    dnit(?s);
    ret bad;
}
