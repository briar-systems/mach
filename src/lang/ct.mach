# mach.lang.ct: the constant-time leakage model's op -> required-capability table
#
# The single source of truth for which operations are variable-latency, and under
# what target capability each becomes constant-time (#1646). Both the front end
# (sema, over source `BinOp`s) and the back end (MIR lowering, over IR opcodes)
# classify an operation to a `CtOp` and read its required `CtCap` here, so the two
# enforcement points never drift and a newly-recognized variable-latency op is one
# table row, not new bespoke gate code.
#
# A leaf module (no compiler-internal dependencies) so both fe.sema and be.codegen
# import it without a cycle.
#
# Enforcement split (both driven by this one table):
#   - a CT_CAP_ALWAYS op is variable-latency on every target, so a secret operand is
#     rejected at SEMA (target-independent).
#   - a CT_CAP_* target-capability op is rejected at MIR lowering iff the resolved
#     target lacks the capability (target-dependent), where the capability is known.
# The leakage model gates a secret OPERAND: for a shift it is specifically the shift
# COUNT (a secret value shifted by a public count is constant-time), reported by
# `ct_op_gates_count_only`.

use std.types.bool.bool;
use std.types.bool.false;
use std.types.bool.true;

# an abstract constant-time operation class, the table key both enforcement points
# map their concrete op to
pub def CtOp: u8;

# not a leakage-observable operation (add / sub / bitwise / integer compare / move /
# load / store / sign-zero-extend / truncate): constant-time on every target
pub val CT_OP_NONE:       CtOp = 0;
# integer division or remainder: variable-latency on every target
pub val CT_OP_INT_DIVMOD: CtOp = 1;
# any floating-point arithmetic, comparison, or conversion: variable-latency on
# every target by default (subnormal / NaN handling), so gated regardless of target
pub val CT_OP_FLOAT:      CtOp = 2;
# integer multiplication: variable-latency unless the target documents a
# data-independent multiply (Arm PSTATE.DIT / Intel DOITM)
pub val CT_OP_INT_MUL:    CtOp = 3;
# a shift by a variable (secret) count: variable-latency unless the target has a
# barrel shifter (constant-time variable shift)
pub val CT_OP_VAR_SHIFT:  CtOp = 4;

# the target capability an operation requires to be constant-time on a secret operand
pub def CtCap: u8;

# constant-time on every target; never gated
pub val CT_CAP_OK:        CtCap = 0;
# never constant-time on a secret operand on any target; gated at sema
pub val CT_CAP_ALWAYS:    CtCap = 1;
# constant-time only under the target's data-independent-multiply capability
pub val CT_CAP_MUL:       CtCap = 2;
# constant-time only on a target with a barrel shifter (constant-time variable shift)
pub val CT_CAP_VAR_SHIFT: CtCap = 3;

# the capability a CtOp requires to be constant-time on a secret operand
#
# The table itself: the single mapping every gate reads. Adding a variable-latency
# op is one arm here plus a one-line classification at each enforcement point.
# ---
# op:  the abstract operation class
# ret: the required capability
pub fun ct_cap(op: CtOp) CtCap {
    if (op == CT_OP_INT_DIVMOD) { ret CT_CAP_ALWAYS; }
    if (op == CT_OP_FLOAT)      { ret CT_CAP_ALWAYS; }
    if (op == CT_OP_INT_MUL)    { ret CT_CAP_MUL; }
    if (op == CT_OP_VAR_SHIFT)  { ret CT_CAP_VAR_SHIFT; }
    ret CT_CAP_OK;
}

# whether a capability is enforced at sema (target-independent), i.e. no target
# provides it so a secret operand is always a leak
# ---
# cap: the required capability
# ret: true for CT_CAP_ALWAYS
pub fun cap_at_sema(cap: CtCap) bool {
    ret cap == CT_CAP_ALWAYS;
}

# whether a capability is a target-dependent one enforced at MIR lowering
# ---
# cap: the required capability
# ret: true for CT_CAP_MUL / CT_CAP_VAR_SHIFT
pub fun cap_at_mir(cap: CtCap) bool {
    ret cap == CT_CAP_MUL || cap == CT_CAP_VAR_SHIFT;
}

# whether a target with the given capability flags provides `cap`
#
# CT_CAP_OK is always provided; CT_CAP_ALWAYS never; the target flags decide the rest.
# The one place a target's constant-time capability set is consulted.
# ---
# trust_mul:       the target's ct_trust_mul flag
# trust_var_shift: the target's ct_trust_var_shift flag
# cap:             the required capability
# ret:             true when the target makes an op requiring `cap` constant-time
pub fun target_provides(trust_mul: bool, trust_var_shift: bool, cap: CtCap) bool {
    if (cap == CT_CAP_OK)        { ret true; }
    if (cap == CT_CAP_ALWAYS)    { ret false; }
    if (cap == CT_CAP_MUL)       { ret trust_mul; }
    if (cap == CT_CAP_VAR_SHIFT) { ret trust_var_shift; }
    ret false;
}

# whether the gate for `op` observes only the shift-COUNT operand rather than every
# operand: a shift leaks through its variable count, not the value being shifted
# ---
# op:  the abstract operation class
# ret: true for CT_OP_VAR_SHIFT
pub fun ct_op_gates_count_only(op: CtOp) bool {
    ret op == CT_OP_VAR_SHIFT;
}

test "mach.lang.ct.ct_cap:table" {
    if (ct_cap(CT_OP_NONE)       != CT_CAP_OK)        { ret 1; }
    if (ct_cap(CT_OP_INT_DIVMOD) != CT_CAP_ALWAYS)    { ret 1; }
    if (ct_cap(CT_OP_FLOAT)      != CT_CAP_ALWAYS)    { ret 1; }
    if (ct_cap(CT_OP_INT_MUL)    != CT_CAP_MUL)       { ret 1; }
    if (ct_cap(CT_OP_VAR_SHIFT)  != CT_CAP_VAR_SHIFT) { ret 1; }

    # sema enforces the always-unsafe ops; MIR enforces the target-dependent ones.
    if (!cap_at_sema(ct_cap(CT_OP_INT_DIVMOD)))  { ret 1; }
    if (!cap_at_sema(ct_cap(CT_OP_FLOAT)))       { ret 1; }
    if (!cap_at_mir(ct_cap(CT_OP_INT_MUL)))      { ret 1; }
    if (!cap_at_mir(ct_cap(CT_OP_VAR_SHIFT)))    { ret 1; }

    # a target that trusts multiply but not variable shift provides one, not the other.
    if (!target_provides(true, false, CT_CAP_MUL))        { ret 1; }
    if (target_provides(true, false, CT_CAP_VAR_SHIFT))   { ret 1; }
    if (target_provides(false, false, CT_CAP_ALWAYS))     { ret 1; }
    if (!target_provides(false, false, CT_CAP_OK))        { ret 1; }

    # only a shift observes the count operand alone.
    if (!ct_op_gates_count_only(CT_OP_VAR_SHIFT)) { ret 1; }
    if (ct_op_gates_count_only(CT_OP_INT_MUL))    { ret 1; }
    ret 0;
}
