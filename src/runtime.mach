# minimal runtime for x86_64 linux
# provides _start entrypoint and calls user main(argc, argv)

ext "C:main" main: fun(i64, **u8) i64;

pub fun _start() {
    # x86_64 SysV linux: stack = [argc][argv0][argv1]...[0][envp...]
    masm {
        mov rax, rsp      # rax = stack base
        mov rdi, [rax]    # argc -> rdi
        lea rsi, [rax+8]  # argv -> rsi (pointer to first arg pointer)

        and rsp, -16      # align
        sub rsp, 8        # make room for return address to keep callee rsp aligned
        call main

        mov rdi, rax      # exit code from main
        mov rax, 60       # sys_exit
        syscall
    }
}
