use assert: mach.tests.assert;

var global_counter: i64 = 0;
val global_const: i64 = 42;

rec Point {
    x: i64;
    y: i64;
}

var global_point: Point = Point{x: 1, y: 2};

fun increment_global() {
    global_counter = global_counter + 1;
}

test "globals: read constant" {
    ret assert.assert_eq_i64(global_const, 42);
}

test "globals: read and modify" {
    global_counter = 10;
    increment_global();
    ret assert.assert_eq_i64(global_counter, 11);
}

test "globals: aggregate read" {
    ret assert.assert_eq_i64(global_point.x + global_point.y, 3);
}

test "globals: aggregate write" {
    global_point.x = 10;
    global_point.y = 20;
    ret assert.assert_eq_i64(global_point.x + global_point.y, 30);
}
