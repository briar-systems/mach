# Assertion helpers for Mach tests.
#
# Each helper returns 0 on success, 1 on failure.

pub fun ok() i64 {
    ret 0;
}

pub fun fail() i64 {
    ret 1;
}

pub fun assert_true(cond: u8) i64 {
    if (cond == 0) {
        ret 1;
    }
    ret 0;
}

pub fun assert_false(cond: u8) i64 {
    if (cond != 0) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_i64(a: i64, b: i64) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_ne_i64(a: i64, b: i64) i64 {
    if (a == b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_i32(a: i32, b: i32) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_ne_i32(a: i32, b: i32) i64 {
    if (a == b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_i8(a: i8, b: i8) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_ne_i8(a: i8, b: i8) i64 {
    if (a == b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_u64(a: u64, b: u64) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_ne_u64(a: u64, b: u64) i64 {
    if (a == b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_u32(a: u32, b: u32) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_ne_u32(a: u32, b: u32) i64 {
    if (a == b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_u8(a: u8, b: u8) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_f64(a: f64, b: f64) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}

pub fun assert_eq_ptr(a: ptr, b: ptr) i64 {
    if (a != b) {
        ret 1;
    }
    ret 0;
}
