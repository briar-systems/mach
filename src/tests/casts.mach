# Cast and reinterpretation tests.

test "casts: i64 <-> u64 roundtrip" {
    val x: i64 = -123456789;
    val y: u64 = x::u64;
    val z: i64 = y::i64;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: u64 <-> i64 roundtrip" {
    val x: u64 = 9223372036854775808;
    val y: i64 = x::i64;
    val z: u64 = y::u64;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: i32 <-> u32 roundtrip" {
    val x: i32 = -12345;
    val y: u32 = x::u32;
    val z: i32 = y::i32;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: u32 <-> i32 roundtrip" {
    val x: u32 = 4000000000;
    val y: i32 = x::i32;
    val z: u32 = y::u32;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: f64 <-> i64 roundtrip" {
    val x: f64 = 1.5;
    val y: i64 = x::i64;
    val z: f64 = y::f64;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: f64 <-> u64 roundtrip" {
    val x: f64 = -2.25;
    val y: u64 = x::u64;
    val z: f64 = y::f64;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: ptr <-> u64 roundtrip" {
    var x: i64 = 42;
    val p: ptr = (?x)::ptr;
    val bits: u64 = p::u64;
    val p2: ptr = bits::ptr;
    if (p != p2) { ret 1; }
    ret 0;
}

test "casts: ptr <-> i64 roundtrip" {
    var x: i64 = -7;
    val p: ptr = (?x)::ptr;
    val bits: i64 = p::i64;
    val p2: ptr = bits::ptr;
    if (p != p2) { ret 1; }
    ret 0;
}

test "casts: byte width roundtrip" {
    val x: i8 = -5;
    val y: u8 = x::u8;
    val z: i8 = y::i8;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: u8 to i8 and back preserves bits" {
    val x: u8 = 255;
    val y: i8 = x::i8;
    val z: u8 = y::u8;
    if (z != x) { ret 1; }
    ret 0;
}
