# Cast and reinterpretation tests.

test "casts: i64 <-> u64 roundtrip" {
    val x: i64 = -123456789;
    val y: u64 = x::u64;
    val z: i64 = y::i64;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: u64 <-> i64 roundtrip" {
    val x: u64 = 9223372036854775808;
    val y: i64 = x::i64;
    val z: u64 = y::u64;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: i32 <-> u32 roundtrip" {
    val x: i32 = -12345;
    val y: u32 = x::u32;
    val z: i32 = y::i32;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: u32 <-> i32 roundtrip" {
    val x: u32 = 4000000000;
    val y: i32 = x::i32;
    val z: u32 = y::u32;
    if (z != x) { ret 1; }
    ret 0;
}

# f64 <-> int casts perform VALUE conversion (truncation), not bit reinterpretation.
# This matches C semantics: (int64_t)1.5 == 1, (double)42 == 42.0

test "casts: f64 to i64 truncates" {
    val x: f64 = 1.5;
    val y: i64 = x::i64;
    # 1.5 truncates to 1
    if (y != 1) { ret 1; }
    ret 0;
}

test "casts: i64 to f64 converts" {
    val x: i64 = 42;
    val y: f64 = x::f64;
    # 42 converts exactly to 42.0
    if (y != 42.0) { ret 1; }
    ret 0;
}

test "casts: f64 negative to i64 truncates toward zero" {
    val x: f64 = -2.75;
    val y: i64 = x::i64;
    # -2.75 truncates toward zero to -2
    if (y != -2) { ret 1; }
    ret 0;
}

test "casts: f64 to u64 truncates" {
    val x: f64 = 100.9;
    val y: u64 = x::u64;
    # 100.9 truncates to 100
    if (y != 100) { ret 1; }
    ret 0;
}

test "casts: ptr <-> u64 roundtrip" {
    var x: i64 = 42;
    val p: ptr = (?x)::ptr;
    val bits: u64 = p::u64;
    val p2: ptr = bits::ptr;
    if (p != p2) { ret 1; }
    ret 0;
}

test "casts: ptr <-> i64 roundtrip" {
    var x: i64 = -7;
    val p: ptr = (?x)::ptr;
    val bits: i64 = p::i64;
    val p2: ptr = bits::ptr;
    if (p != p2) { ret 1; }
    ret 0;
}

test "casts: byte width roundtrip" {
    val x: i8 = -5;
    val y: u8 = x::u8;
    val z: i8 = y::i8;
    if (z != x) { ret 1; }
    ret 0;
}

test "casts: u8 to i8 and back preserves bits" {
    val x: u8 = 255;
    val y: i8 = x::i8;
    val z: u8 = y::u8;
    if (z != x) { ret 1; }
    ret 0;
}
