# minimal variadic function: extract first vararg and return it
fun first_arg(dummy: i64, ...) i64 {
    var ap: va_list;
    va_start(?ap);
    var v: i64 = va_arg[i64](?ap);
    va_end(?ap);
    ret v;
}

# sum variadic i64 values
fun sum(count: i64, ...) i64 {
    var ap: va_list;
    va_start(?ap);

    var total: i64 = 0;
    var i: i64 = 0;
    for (i < count) {
        total = total + va_arg[i64](?ap);
        i = i + 1;
    }

    va_end(?ap);
    ret total;
}

# variadic with prefix args
fun sum_with_prefix(a: i64, b: i64, count: i64, ...) i64 {
    var ap: va_list;
    va_start(?ap);

    var total: i64 = a + b;
    var i: i64 = 0;
    for (i < count) {
        total = total + va_arg[i64](?ap);
        i = i + 1;
    }

    va_end(?ap);
    ret total;
}

test "variadics: extract first arg" {
    var v: i64 = first_arg(0, 42i64);
    if (v != 42) { ret 1; }
    ret 0;
}

test "variadics: sum zero" {
    var s: i64 = sum(0);
    if (s != 0) { ret 1; }
    ret 0;
}

test "variadics: sum one" {
    var s: i64 = sum(1, 10i64);
    if (s != 10) { ret 1; }
    ret 0;
}

test "variadics: sum two" {
    var s: i64 = sum(2, 10i64, 20i64);
    if (s != 30) { ret 1; }
    ret 0;
}

test "variadics: sum five" {
    var s: i64 = sum(5, 1i64, 2i64, 3i64, 4i64, 5i64);
    if (s != 15) { ret 1; }
    ret 0;
}

test "variadics: prefix args no varargs" {
    var s: i64 = sum_with_prefix(1, 2, 0);
    if (s != 3) { ret 1; }
    ret 0;
}

test "variadics: prefix args with varargs" {
    var s: i64 = sum_with_prefix(1, 2, 2, 10i64, 20i64);
    if (s != 33) { ret 1; }
    ret 0;
}

# --- f64 varargs tests ---

# sum variadic f64 values
fun sum_f64(count: i64, ...) f64 {
    var ap: va_list;
    va_start(?ap);

    var total: f64 = 0.0;
    var i: i64 = 0;
    for (i < count) {
        total = total + va_arg[f64](?ap);
        i = i + 1;
    }

    va_end(?ap);
    ret total;
}

test "variadics: f64 single arg" {
    var s: f64 = sum_f64(1, 3.5f64);
    if (s != 3.5) { ret 1; }
    ret 0;
}

test "variadics: f64 two args" {
    var s: f64 = sum_f64(2, 1.5f64, 2.5f64);
    if (s != 4.0) { ret 1; }
    ret 0;
}

test "variadics: f64 five args" {
    var s: f64 = sum_f64(5, 1.0f64, 2.0f64, 3.0f64, 4.0f64, 5.0f64);
    if (s != 15.0) { ret 1; }
    ret 0;
}

test "variadics: nine f64 args (FP stack overflow)" {
    var s: f64 = sum_f64(9, 1.0f64, 2.0f64, 3.0f64, 4.0f64, 5.0f64, 6.0f64, 7.0f64, 8.0f64, 9.0f64);
    if (s != 45.0) { ret 1; }
    ret 0;
}

# --- many args tests (overflow to stack) ---

# sum more than 6 i64 args (exceeds GP register count)
fun sum_many(count: i64, ...) i64 {
    var ap: va_list;
    va_start(?ap);

    var total: i64 = 0;
    var i: i64 = 0;
    for (i < count) {
        total = total + va_arg[i64](?ap);
        i = i + 1;
    }

    va_end(?ap);
    ret total;
}

test "variadics: seven i64 args (stack overflow)" {
    # count=7 uses RDI, then 7 varargs: RSI, RDX, RCX, R8, R9, stack, stack
    var s: i64 = sum_many(7, 1i64, 2i64, 3i64, 4i64, 5i64, 6i64, 7i64);
    if (s != 28) { ret 1; }
    ret 0;
}

test "variadics: ten i64 args (more stack overflow)" {
    var s: i64 = sum_many(10, 1i64, 2i64, 3i64, 4i64, 5i64, 6i64, 7i64, 8i64, 9i64, 10i64);
    if (s != 55) { ret 1; }
    ret 0;
}

# --- mixed GP/FP varargs ---

# alternate between i64 and f64 args
fun mixed_sum(count: i64, ...) i64 {
    var ap: va_list;
    va_start(?ap);

    var int_total: i64 = 0;
    var float_total: f64 = 0.0;
    var i: i64 = 0;
    for (i < count) {
        # even indices are i64, odd indices are f64
        if ((i % 2) == 0) {
            int_total = int_total + va_arg[i64](?ap);
        } or {
            float_total = float_total + va_arg[f64](?ap);
        }
        i = i + 1;
    }

    # return sum as i64 (truncate float part)
    ret int_total + (float_total :: i64);
}

test "variadics: mixed i64 and f64 args" {
    # i64=10, f64=1.5, i64=20, f64=2.5 -> int_total=30, float_total=4.0 -> 34
    var s: i64 = mixed_sum(4, 10i64, 1.5f64, 20i64, 2.5f64);
    if (s != 34) { ret 1; }
    ret 0;
}

test "variadics: mixed six args" {
    # i64=1, f64=2.0, i64=3, f64=4.0, i64=5, f64=6.0 -> int=9, float=12.0 -> 21
    var s: i64 = mixed_sum(6, 1i64, 2.0f64, 3i64, 4.0f64, 5i64, 6.0f64);
    if (s != 21) { ret 1; }
    ret 0;
}
