# --- multiple tokens ---

test "lexer: multiple tokens sequence" {
    var lex: lexer.Lexer = lexer.init("val x: i32");

    val t1: token.Token = lex.next();
    if (t1.tag != token.TAG_KW_VAL) { ret 0; }

    val t2: token.Token = lex.next();
    if (t2.tag != token.TAG_IDENT) { ret 0; }

    val t3: token.Token = lex.next();
    if (t3.tag != token.TAG_COLON) { ret 0; }

    val t4: token.Token = lex.next();
    if (t4.tag != token.TAG_IDENT) { ret 0; }

    val t5: token.Token = lex.next();
    if (t5.tag != token.TAG_EOF) { ret 0; }

    ret 1;
}

test "lexer: function signature tokens" {
    var lex: lexer.Lexer = lexer.init("pub fun main()");

    val t1: token.Token = lex.next();
    if (t1.tag != token.TAG_KW_PUB) { ret 0; }

    val t2: token.Token = lex.next();
    if (t2.tag != token.TAG_KW_FUN) { ret 0; }

    val t3: token.Token = lex.next();
    if (t3.tag != token.TAG_IDENT) { ret 0; }

    val t4: token.Token = lex.next();
    if (t4.tag != token.TAG_LPAREN) { ret 0; }

    val t5: token.Token = lex.next();
    if (t5.tag != token.TAG_RPAREN) { ret 0; }

    ret 1;
}

# --- precedence tests ---

test "token: precedence of + is term" {
    val prec: u8 = token.get_infix_precedence(token.TAG_PLUS);
    if (prec != token.PREC_TERM) { ret 0; }
    ret 1;
}

test "token: precedence of - is term" {
    val prec: u8 = token.get_infix_precedence(token.TAG_MINUS);
    if (prec != token.PREC_TERM) { ret 0; }
    ret 1;
}

test "token: precedence of * is factor" {
    val prec: u8 = token.get_infix_precedence(token.TAG_STAR);
    if (prec != token.PREC_FACTOR) { ret 0; }
    ret 1;
}

test "token: precedence of / is factor" {
    val prec: u8 = token.get_infix_precedence(token.TAG_SLASH);
    if (prec != token.PREC_FACTOR) { ret 0; }
    ret 1;
}

test "token: precedence of % is factor" {
    val prec: u8 = token.get_infix_precedence(token.TAG_PERCENT);
    if (prec != token.PREC_FACTOR) { ret 0; }
    ret 1;
}

test "token: precedence of == is equality" {
    val prec: u8 = token.get_infix_precedence(token.TAG_EQ_EQ);
    if (prec != token.PREC_EQUALITY) { ret 0; }
    ret 1;
}

test "token: precedence of != is equality" {
    val prec: u8 = token.get_infix_precedence(token.TAG_BANG_EQ);
    if (prec != token.PREC_EQUALITY) { ret 0; }
    ret 1;
}

test "token: precedence of < is comparison" {
    val prec: u8 = token.get_infix_precedence(token.TAG_LT);
    if (prec != token.PREC_COMPARISON) { ret 0; }
    ret 1;
}

test "token: precedence of && is and" {
    val prec: u8 = token.get_infix_precedence(token.TAG_AMP_AMP);
    if (prec != token.PREC_AND) { ret 0; }
    ret 1;
}

test "token: precedence of || is or" {
    val prec: u8 = token.get_infix_precedence(token.TAG_PIPE_PIPE);
    if (prec != token.PREC_OR) { ret 0; }
    ret 1;
}

test "token: * has higher precedence than +" {
    val plus_prec: u8 = token.get_infix_precedence(token.TAG_PLUS);
    val star_prec: u8 = token.get_infix_precedence(token.TAG_STAR);
    if (star_prec <= plus_prec) { ret 0; }
    ret 1;
}

test "token: && has higher precedence than ||" {
    val and_prec: u8 = token.get_infix_precedence(token.TAG_AMP_AMP);
    val or_prec: u8 = token.get_infix_precedence(token.TAG_PIPE_PIPE);
    if (and_prec <= or_prec) { ret 0; }
    ret 1;
}

test "token: == has higher precedence than &&" {
    val eq_prec: u8 = token.get_infix_precedence(token.TAG_EQ_EQ);
    val and_prec: u8 = token.get_infix_precedence(token.TAG_AMP_AMP);
    if (eq_prec <= and_prec) { ret 0; }
    ret 1;
}

test "token: < has higher precedence than ==" {
    val lt_prec: u8 = token.get_infix_precedence(token.TAG_LT);
    val eq_prec: u8 = token.get_infix_precedence(token.TAG_EQ_EQ);
    if (lt_prec <= eq_prec) { ret 0; }
    ret 1;
}

# --- associativity tests ---

test "token: assignment is right-associative" {
    if (!token.is_right_associative(token.TAG_EQ)) { ret 0; }
    ret 1;
}

test "token: + is left-associative" {
    if (token.is_right_associative(token.TAG_PLUS)) { ret 0; }
    ret 1;
}

test "token: * is left-associative" {
    if (token.is_right_associative(token.TAG_STAR)) { ret 0; }
    ret 1;
}

test "token: == is left-associative" {
    if (token.is_right_associative(token.TAG_EQ_EQ)) { ret 0; }
    ret 1;
}
