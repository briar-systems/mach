}

test "lexer: float literal longer" {
    var lex: lexer.Lexer = lexer.init("3.14159");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_FLOAT) { ret 0; }
    if (tok.len != 7) { ret 0; }
