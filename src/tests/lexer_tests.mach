# --- numeric literals ---

test "lexer: integer literal" {
    var lex: lexer.Lexer = lexer.init("12345");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_INT) { ret 0; }
    if (tok.len != 5) { ret 0; }
    ret 1;
}

test "lexer: single digit" {
    var lex: lexer.Lexer = lexer.init("7");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_INT) { ret 0; }
    if (tok.len != 1) { ret 0; }
    ret 1;
}

test "lexer: hex literal lowercase" {
    var lex: lexer.Lexer = lexer.init("0xff");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_INT) { ret 0; }
    if (tok.len != 4) { ret 0; }
    ret 1;
}

test "lexer: hex literal uppercase" {
    var lex: lexer.Lexer = lexer.init("0XFF");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_INT) { ret 0; }
    if (tok.len != 4) { ret 0; }
    ret 1;
}

test "lexer: binary literal" {
    var lex: lexer.Lexer = lexer.init("0b1010");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_INT) { ret 0; }
    if (tok.len != 6) { ret 0; }
    ret 1;
}

test "lexer: integer with underscores" {
    var lex: lexer.Lexer = lexer.init("1_000_000");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_INT) { ret 0; }
    if (tok.len != 9) { ret 0; }
    ret 1;
}

test "lexer: float literal simple" {
    var lex: lexer.Lexer = lexer.init("3.14");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_LIT_FLOAT) { ret 0; }
