    var lex: lexer.Lexer = lexer.init("==");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_EQ_EQ) { ret 0; }
    if (tok.len != 2) { ret 0; }
    ret 1;
}

test "lexer: not equals" {
    var lex: lexer.Lexer = lexer.init("!=");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_BANG_EQ) { ret 0; }
    if (tok.len != 2) { ret 0; }
