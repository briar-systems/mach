# Lexer tests to verify keyword recognition and token scanning.

use lexer: mach.compiler.lexer;
use token: mach.compiler.token;

# --- basic tokenization tests ---

test "lexer: eof on empty input" {
    var lex: lexer.Lexer = lexer.init("");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_EOF) { ret 0; }
    ret 1;
}

test "lexer: simple identifier" {
    var lex: lexer.Lexer = lexer.init("foo");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_IDENT) { ret 0; }
    if (tok.len != 3) { ret 0; }
    ret 1;
}

test "lexer: identifier with underscore" {
    var lex: lexer.Lexer = lexer.init("my_var");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_IDENT) { ret 0; }
    if (tok.len != 6) { ret 0; }
    ret 1;
}

test "lexer: identifier starting with underscore" {
    var lex: lexer.Lexer = lexer.init("_private");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_IDENT) { ret 0; }
    if (tok.len != 8) { ret 0; }
    ret 1;
}

test "lexer: skips whitespace" {
    var lex: lexer.Lexer = lexer.init("   x");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_IDENT) { ret 0; }
    if (tok.pos != 3) { ret 0; }
    ret 1;
}

test "lexer: skips tabs" {
    var lex: lexer.Lexer = lexer.init("\t\ty");
    val tok: token.Token = lex.next();
    if (tok.tag != token.TAG_IDENT) { ret 0; }
    if (tok.pos != 2) { ret 0; }
    ret 1;
}

