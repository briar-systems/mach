use assert: mach.tests.assert;

# Control flow tests for conditionals and loops.

test "control: if/or chain chooses first branch" {
    var x: i64 = 5;
    var y: i64 = 0;

    if (x == 5) {
        y = 1;
    }
    or (x == 6) {
        y = 2;
    }
    or {
        y = 3;
    }

    ret assert.assert_eq_i64(y, 1);
}

test "control: if/or chain chooses middle branch" {
    var x: i64 = 6;
    var y: i64 = 0;

    if (x == 5) {
        y = 1;
    }
    or (x == 6) {
        y = 2;
    }
    or {
        y = 3;
    }

    ret assert.assert_eq_i64(y, 2);
}

test "control: if/or chain chooses else branch" {
    var x: i64 = 7;
    var y: i64 = 0;

    if (x == 5) {
        y = 1;
    }
    or (x == 6) {
        y = 2;
    }
    or {
        y = 3;
    }

    ret assert.assert_eq_i64(y, 3);
}

test "control: loop increments and breaks" {
    var i: i64 = 0;
    var sum: i64 = 0;

    for (i < 10) {
        i = i + 1;
        if (i == 7) {
            brk;
        }
        sum = sum + i;
    }

    ret assert.assert_eq_i64(sum, 21);
}

test "control: continue skips work" {
    var i: i64 = 0;
    var sum: i64 = 0;

    for (i < 6) {
        i = i + 1;
        if (i % 2 == 0) {
            cnt;
        }
        sum = sum + i;
    }

    ret assert.assert_eq_i64(sum, 9);
}

test "control: early return exits test" {
    var x: i64 = 1;
    if (x == 1) {
        ret assert.assert_eq_i64(x, 1);
    }
    ret assert.fail();
}

test "control: nested loops update counters" {
    var outer: i64 = 0;
    var inner: i64 = 0;
    var sum: i64 = 0;

    for (outer < 3) {
        outer = outer + 1;
        inner = 0;
        for (inner < 2) {
            inner = inner + 1;
            sum = sum + 1;
        }
    }

    ret assert.assert_eq_i64(sum, 6);
}
