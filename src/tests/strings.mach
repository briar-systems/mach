# String literal and str type tests.

test "strings: empty literal length" {
    var s: ptr = "";
    var len: i64 = 0;
    var p: *u8 = s;
    for (@p != 0u8) {
        len = len + 1;
        p = p + 1i64;
    }
    if (len != 0) { ret 0; }
    ret 1;
}

test "strings: simple literal length" {
    var s: ptr = "hello";
    var len: i64 = 0;
    var p: *u8 = s;
    for (@p != 0u8) {
        len = len + 1;
        p = p + 1i64;
    }
    if (len != 5) { ret 0; }
    ret 1;
}

test "strings: first char access" {
    var s: *u8 = "abc";
    var c: u8 = @s;
    if (c != 97) { ret 0; }
    ret 1;
}

test "strings: index via pointer arithmetic 1" {
    var s: *u8 = "abcd";
    var p: *u8 = s + 1i64;
    var c: u8 = @p;
    if (c != 98) { ret 0; }
    ret 1;
}

test "strings: index via pointer arithmetic 2" {
    var s: *u8 = "abcd";
    var p: *u8 = s + 2i64;
    var c: u8 = @p;
    if (c != 99) { ret 0; }
    ret 1;
}

test "strings: index via pointer arithmetic 3" {
    var s: *u8 = "abcd";
    var p: *u8 = s + 3i64;
    var c: u8 = @p;
    if (c != 100) { ret 0; }
    ret 1;
}

test "strings: null terminator present" {
    var s: *u8 = "hi";
    var p: *u8 = s + 2i64;
    var c: u8 = @p;
    if (c != 0) { ret 0; }
    ret 1;
}

test "strings: escape newline" {
    var s: *u8 = "a\nb";
    var p: *u8 = s + 1i64;
    var c: u8 = @p;
    if (c != 10) { ret 0; }
    ret 1;
}

test "strings: escape tab" {
    var s: *u8 = "a\tb";
    var p: *u8 = s + 1i64;
    var c: u8 = @p;
    if (c != 9) { ret 0; }
    ret 1;
}
