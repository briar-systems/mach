# String literal and str type tests.

use assert: mach.tests.assert;

test "strings: empty literal length" {
    var s: ptr = "";
    var len: i64 = 0;
    var p: *u8 = s;
    for (@p != 0u8) {
        len = len + 1;
        p = p + 1i64;
    }
    ret assert.assert_eq_i64(len, 0);
}

test "strings: simple literal length" {
    var s: ptr = "hello";
    var len: i64 = 0;
    var p: *u8 = s;
    for (@p != 0u8) {
        len = len + 1;
        p = p + 1i64;
    }
    ret assert.assert_eq_i64(len, 5);
}

test "strings: first char access" {
    var s: *u8 = "abc";
    var c: u8 = @s;
    ret assert.assert_eq_u8(c, 97);
}

test "strings: index via pointer arithmetic 1" {
    var s: *u8 = "abcd";
    var p: *u8 = s + 1i64;
    var c: u8 = @p;
    ret assert.assert_eq_u8(c, 98);
}

test "strings: index via pointer arithmetic 2" {
    var s: *u8 = "abcd";
    var p: *u8 = s + 2i64;
    var c: u8 = @p;
    ret assert.assert_eq_u8(c, 99);
}

test "strings: index via pointer arithmetic 3" {
    var s: *u8 = "abcd";
    var p: *u8 = s + 3i64;
    var c: u8 = @p;
    ret assert.assert_eq_u8(c, 100);
}

test "strings: null terminator present" {
    var s: *u8 = "hi";
    var p: *u8 = s + 2i64;
    var c: u8 = @p;
    ret assert.assert_eq_u8(c, 0);
}

test "strings: escape newline" {
    var s: *u8 = "a\nb";
    var p: *u8 = s + 1i64;
    var c: u8 = @p;
    ret assert.assert_eq_u8(c, 10);
}

test "strings: escape tab" {
    var s: *u8 = "a\tb";
    var p: *u8 = s + 1i64;
    var c: u8 = @p;
    ret assert.assert_eq_u8(c, 9);
}
