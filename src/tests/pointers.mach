use assert: mach.tests.assert;

# Pointer and dereference tests.

test "pointers: address-of and deref reads value" {
    var x: i64 = 10;
    var p: *i64 = ?x;
    ret assert.assert_eq_i64(@p, 10);
}

test "pointers: write through pointer" {
    var x: i64 = 5;
    var p: *i64 = ?x;
    @p = 25;
    ret assert.assert_eq_i64(x, 25);
}

test "pointers: pointer-to-pointer write" {
    var x: i64 = 3;
    var p: *i64 = ?x;
    var pp: **i64 = ?p;
    @(@pp) = 9;
    ret assert.assert_eq_i64(x, 9);
}

test "pointers: cast to ptr and back preserves address" {
    var x: i64 = 1;
    var p: *i64 = ?x;
    val raw: ptr = p::ptr;
    val p2: *i64 = raw::*i64;
    @p2 = 13;
    ret assert.assert_eq_i64(x, 13);
}

test "pointers: distinct addresses differ" {
    var a: i64 = 1;
    var b: i64 = 2;
    val pa: u64 = ((?a)::ptr)::u64;
    val pb: u64 = ((?b)::ptr)::u64;
    ret assert.assert_ne_u64(pa, pb);
}

test "pointers: nil is zero" {
    ret assert.assert_eq_u64(nil::u64, 0);
}
