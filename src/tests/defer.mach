fun defer_return_helper(out: *i64) {
    fin @out = 2;
    @out = 1;
    ret;
}

test "fin: execution on return" {
    var x: i64 = 0;
    defer_return_helper(?x);
    if (x != 2) { ret 1; }
    ret 0;
}

test "fin: LIFO order" {
    var x: i64 = 1;
    {
        fin x = x * 2;
        fin x = x + 5;
    }
    if (x != 12) { ret 1; }
    ret 0;
}

test "fin: block scope" {
    var x: i64 = 0;
    if (1::i64 == 1) {
        fin x = 1;
        if (x != 0) { ret 1; }
    }
    if (x != 1) { ret 1; }
    ret 0;
}

test "fin: loop scope" {
    var x: i64 = 0;
    var i: i64 = 0;
    for (i < 3) {
        fin x = x + 1;
        i = i + 1;
    }
    if (x != 3) { ret 1; }
    ret 0;
}
