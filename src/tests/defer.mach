use assert: mach.tests.assert;

fun defer_return_helper(out: *i64) {
    fin @out = 2;
    @out = 1;
    ret;
}

test "fin: execution on return" {
    var x: i64 = 0;
    defer_return_helper(?x);
    ret assert.assert_eq_i64(x, 2);
}

test "fin: LIFO order" {
    var x: i64 = 1;
    {
        fin x = x * 2;
        fin x = x + 5;
    }
    ret assert.assert_eq_i64(x, 12);
}

test "fin: block scope" {
    var x: i64 = 0;
    if (1::i64 == 1) {
        fin x = 1;
        assert.assert_eq_i64(x, 0);
    }
    ret assert.assert_eq_i64(x, 1);
}

test "fin: loop scope" {
    var x: i64 = 0;
    var i: i64 = 0;
    for (i < 3) {
        fin x = x + 1;
        i = i + 1;
    }
    ret assert.assert_eq_i64(x, 3);
}
