use assert: mach.tests.assert;

# Smoke tests for the test harness itself.

test "smoke: pass returns 0" {
    ret assert.ok();
}

test "smoke: fail returns 1" {
    var rc: i64 = assert.fail();
    ret assert.assert_eq_i64(rc, 1);
}

test "smoke: assert_true accepts non-zero" {
    ret assert.assert_true(1);
}

test "smoke: assert_true rejects zero" {
    var rc: i64 = assert.assert_true(0);
    ret assert.assert_eq_i64(rc, 1);
}

test "smoke: assert_false accepts zero" {
    ret assert.assert_false(0);
}

test "smoke: assert_false rejects non-zero" {
    var rc: i64 = assert.assert_false(2);
    ret assert.assert_eq_i64(rc, 1);
}

test "smoke: assert_eq_i64 matches" {
    ret assert.assert_eq_i64(42, 42);
}

test "smoke: assert_eq_i64 mismatches" {
    var rc: i64 = assert.assert_eq_i64(1, 2);
    ret assert.assert_eq_i64(rc, 1);
}

test "smoke: arithmetic sanity" {
    var sum: i64 = 10 + 20;
    ret assert.assert_eq_i64(sum, 30);
}
