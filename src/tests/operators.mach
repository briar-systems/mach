# Bitwise, shift, arithmetic, and modulo operator tests.

use assert: mach.tests.assert;

# --- Bitwise AND ---

test "operators: bitwise and" {
    var a: u64 = 0xFF00;
    var b: u64 = 0x0FF0;
    var c: u64 = a & b;
    ret assert.assert_eq_u64(c, 0x0F00);
}

test "operators: bitwise and zero" {
    var a: u64 = 0xFFFF;
    var b: u64 = 0x0000;
    var c: u64 = a & b;
    ret assert.assert_eq_u64(c, 0);
}

test "operators: bitwise and identity" {
    var a: u64 = 0xABCD;
    var b: u64 = 0xFFFFFFFFFFFFFFFF;
    var c: u64 = a & b;
    ret assert.assert_eq_u64(c, 0xABCD);
}

# --- Bitwise OR ---

test "operators: bitwise or" {
    var a: u64 = 0xFF00;
    var b: u64 = 0x00FF;
    var c: u64 = a | b;
    ret assert.assert_eq_u64(c, 0xFFFF);
}

test "operators: bitwise or zero" {
    var a: u64 = 0xABCD;
    var b: u64 = 0x0000;
    var c: u64 = a | b;
    ret assert.assert_eq_u64(c, 0xABCD);
}

test "operators: bitwise or accumulate" {
    var rc: i64 = 0;
    rc = rc | 1;
    rc = rc | 2;
    rc = rc | 4;
    ret assert.assert_eq_i64(rc, 7);
}

fun returns_zero() i64 {
    ret 0;
}

fun returns_one() i64 {
    ret 1;
}

test "operators: bitwise or with local fn intermediate" {
    var rc: i64 = 0;
    var tmp: i64 = returns_zero();
    rc = rc | tmp;
    ret assert.assert_eq_i64(rc, 0);
}

test "operators: bitwise or with cross-module call intermediate" {
    var rc: i64 = 0;
    var result: i64 = assert.assert_eq_i64(1, 1);
    rc = rc | result;
    ret assert.assert_eq_i64(rc, 0);
}

# NOTE: Inline function call in binary expression is broken (see BROKEN.md #1)
# Local function calls may work, but cross-module and recursive calls fail.
test "operators: bitwise or with inline call" {
    var rc: i64 = 0;
    rc = rc | returns_one();  # produces wrong result
    ret assert.assert_eq_i64(rc, 1);
}

# BUG: Cross-module inline call in binary expression
test "operators: bitwise or with cross-module inline call" {
    var rc: i64 = 0;
    rc = rc | assert.assert_eq_i64(1, 1);  # returns 0, so rc should be 0
    rc = rc | assert.assert_eq_i64(2, 3);  # returns 1, so rc should be 1
    ret assert.assert_eq_i64(rc, 1);
}

# BUG: Multiplication with inline recursive call
fun factorial_inline(n: i64) i64 {
    if (n <= 1) {
        ret 1;
    }
    ret n * factorial_inline(n - 1);  # inline recursive call
}

test "operators: multiply with inline recursive call" {
    var f: i64 = factorial_inline(5);
    ret assert.assert_eq_i64(f, 120);
}

# BUG: Addition with inline recursive calls (fibonacci pattern)
fun fib_inline(n: i64) i64 {
    if (n <= 1) {
        ret n;
    }
    ret fib_inline(n - 1) + fib_inline(n - 2);  # two inline recursive calls
}

test "operators: add with inline recursive calls" {
    var f: i64 = fib_inline(10);
    ret assert.assert_eq_i64(f, 55);
}

# --- Bitwise XOR ---

test "operators: bitwise xor" {
    var a: u64 = 0xFF00;
    var b: u64 = 0xF0F0;
    var c: u64 = a ^ b;
    ret assert.assert_eq_u64(c, 0x0FF0);
}

test "operators: bitwise xor self is zero" {
    var a: u64 = 0xABCD1234;
    var c: u64 = a ^ a;
    ret assert.assert_eq_u64(c, 0);
}

test "operators: bitwise xor toggle" {
    var a: u64 = 0x00FF;
    var mask: u64 = 0xFFFF;
    var c: u64 = a ^ mask;
    ret assert.assert_eq_u64(c, 0xFF00);
}

# --- Bitwise NOT ---

test "operators: bitwise not u8" {
    var a: u8 = 0x0F;
    var b: u8 = ~a;
    ret assert.assert_eq_u8(b, 0xF0);
}

test "operators: bitwise not u8 zero" {
    var a: u8 = 0x00;
    var b: u8 = ~a;
    ret assert.assert_eq_u8(b, 0xFF);
}

test "operators: bitwise not u8 max" {
    var a: u8 = 0xFF;
    var b: u8 = ~a;
    ret assert.assert_eq_u8(b, 0x00);
}

# --- Left Shift ---

test "operators: left shift" {
    var a: u64 = 1;
    var b: u64 = a << 4;
    ret assert.assert_eq_u64(b, 16);
}

test "operators: left shift by zero" {
    var a: u64 = 0xABCD;
    var b: u64 = a << 0;
    ret assert.assert_eq_u64(b, 0xABCD);
}

test "operators: left shift multiple bits" {
    var a: u64 = 0x01;
    var b: u64 = a << 8;
    ret assert.assert_eq_u64(b, 0x100);
}

test "operators: left shift overflow discards high bits" {
    var a: u8 = 0x80;
    var b: u8 = a << 1;
    ret assert.assert_eq_u8(b, 0x00);
}

# --- Right Shift (unsigned) ---

test "operators: right shift unsigned" {
    var a: u64 = 0x80;
    var b: u64 = a >> 4;
    ret assert.assert_eq_u64(b, 0x08);
}

test "operators: right shift by zero" {
    var a: u64 = 0xABCD;
    var b: u64 = a >> 0;
    ret assert.assert_eq_u64(b, 0xABCD);
}

test "operators: right shift multiple bits" {
    var a: u64 = 0x100;
    var b: u64 = a >> 8;
    ret assert.assert_eq_u64(b, 0x01);
}

test "operators: right shift discards low bits" {
    var a: u8 = 0x01;
    var b: u8 = a >> 1;
    ret assert.assert_eq_u8(b, 0x00);
}

# BUG: Signed right shift uses logical shift instead of arithmetic (see BROKEN.md #3)
test "operators: right shift signed" {
    var a: i64 = 0 - 16;
    var b: i64 = a >> 2;
    ret assert.assert_eq_i64(b, 0 - 4);
}

# --- Combined bitwise ---

test "operators: combined bitwise" {
    var a: u64 = 0xABCD;
    var mask: u64 = 0x00FF;
    var low: u64 = a & mask;
    var high: u64 = (a >> 8) & mask;
    ret assert.assert_eq_u64(low + high, 0xCD + 0xAB);
}

test "operators: shift and mask pattern" {
    var flags: u64 = 0;
    flags = flags | (1 << 0);
    flags = flags | (1 << 3);
    flags = flags | (1 << 7);
    var has_bit_0: u64 = (flags >> 0) & 1;
    var has_bit_3: u64 = (flags >> 3) & 1;
    var has_bit_5: u64 = (flags >> 5) & 1;
    var has_bit_7: u64 = (flags >> 7) & 1;
    ret assert.assert_eq_u64(has_bit_0 + has_bit_3 + has_bit_5 + has_bit_7, 3);
}

test "operators: extract nibbles" {
    var x: u64 = 0x1234;
    var n0: u64 = (x >> 0) & 0xF;
    var n1: u64 = (x >> 4) & 0xF;
    var n2: u64 = (x >> 8) & 0xF;
    var n3: u64 = (x >> 12) & 0xF;
    ret assert.assert_eq_u64(n0 + n1 + n2 + n3, 4 + 3 + 2 + 1);
}

# --- Modulo ---

test "operators: modulo i64 positive" {
    var a: i64 = 17;
    var b: i64 = 5;
    var c: i64 = a % b;
    ret assert.assert_eq_i64(c, 2);
}

test "operators: modulo i64 exact division" {
    var a: i64 = 20;
    var b: i64 = 5;
    var c: i64 = a % b;
    ret assert.assert_eq_i64(c, 0);
}

test "operators: modulo i64 smaller dividend" {
    var a: i64 = 3;
    var b: i64 = 7;
    var c: i64 = a % b;
    ret assert.assert_eq_i64(c, 3);
}

test "operators: modulo u64 positive" {
    var a: u64 = 17;
    var b: u64 = 5;
    var c: u64 = a % b;
    ret assert.assert_eq_u64(c, 2);
}

test "operators: modulo u64 large values" {
    var a: u64 = 1000000007;
    var b: u64 = 1000000;
    var c: u64 = a % b;
    ret assert.assert_eq_u64(c, 7);
}

test "operators: modulo power of two" {
    var a: u64 = 123;
    var b: u64 = a % 16;
    ret assert.assert_eq_u64(b, 11);
}

test "operators: modulo in loop" {
    var count: i64 = 0;
    var i: i64 = 0;
    for (i < 20) {
        if (i % 3 == 0) {
            count = count + 1;
        }
        i = i + 1;
    }
    ret assert.assert_eq_i64(count, 7);
}

# --- Arithmetic ---

test "operators: addition i64" {
    var a: i64 = 100;
    var b: i64 = 200;
    var c: i64 = a + b;
    ret assert.assert_eq_i64(c, 300);
}

test "operators: subtraction i64" {
    var a: i64 = 500;
    var b: i64 = 300;
    var c: i64 = a - b;
    ret assert.assert_eq_i64(c, 200);
}

test "operators: multiplication i64" {
    var a: i64 = 12;
    var b: i64 = 11;
    var c: i64 = a * b;
    ret assert.assert_eq_i64(c, 132);
}

test "operators: division i64" {
    var a: i64 = 100;
    var b: i64 = 4;
    var c: i64 = a / b;
    ret assert.assert_eq_i64(c, 25);
}

test "operators: division truncates" {
    var a: i64 = 7;
    var b: i64 = 2;
    var c: i64 = a / b;
    ret assert.assert_eq_i64(c, 3);
}

test "operators: arithmetic precedence" {
    var result: i64 = 2 + 3 * 4;
    ret assert.assert_eq_i64(result, 14);
}

test "operators: arithmetic parentheses" {
    var result: i64 = (2 + 3) * 4;
    ret assert.assert_eq_i64(result, 20);
}

test "operators: arithmetic chain" {
    var result: i64 = 10 + 20 - 5 + 15;
    ret assert.assert_eq_i64(result, 40);
}

test "operators: arithmetic with negatives" {
    var a: i64 = 0 - 10;
    var b: i64 = 25;
    var c: i64 = a + b;
    ret assert.assert_eq_i64(c, 15);
}

test "operators: multiply by zero" {
    var a: i64 = 999999;
    var b: i64 = 0;
    var c: i64 = a * b;
    ret assert.assert_eq_i64(c, 0);
}
