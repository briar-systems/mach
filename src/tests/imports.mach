# Cross-module import tests.
# Verifies that `use` and `pub` work correctly across module boundaries.

use h: mach.tests.helpers;

test "imports: call public function" {
    var result: i64 = h.add(10, 20);
    if (result != 30) { ret 1; }
    ret 0;
}

test "imports: call multiple public functions" {
    var a: i64 = h.add(5, 3);
    var b: i64 = h.mul(4, 2);
    var c: i64 = h.negate(10);
    if ((a + b + c) != 6) { ret 1; }
    ret 0;
}

test "imports: read public constant" {
    if (h.CONSTANT != 42) { ret 1; }
    ret 0;
}

test "imports: use public record type" {
    var p: h.Point = h.Point { x: 3, y: 7 };
    if ((p.x + p.y) != 10) { ret 1; }
    ret 0;
}

test "imports: call public constructor function" {
    var p: h.Point = h.make_point(5, 15);
    if ((p.x + p.y) != 20) { ret 1; }
    ret 0;
}

test "imports: call method on imported record" {
    var p: h.Point = h.make_point(11, 22);
    var s: i64 = h.sum(?p);
    if (s != 33) { ret 1; }
    ret 0;
}
