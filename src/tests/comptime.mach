test "comptime: true branch" {
    $if (1 == 1) {
        var x: i64 = 1;
    }
    ret 0;
}

test "comptime: false branch" {
    $if (1 == 0) {
        masm { "ud2" }
    }
    ret 0;
}

test "comptime: else branch" {
    $if (1 == 0) {
        masm { "ud2" }
    } $or {
        var x: i64 = 2;
    }
    ret 0;
}

test "comptime: nested" {
    $if (1 == 1) {
        $if (1 == 1) {
            var x: i64 = 1;
        }
    }
    ret 0;
}
