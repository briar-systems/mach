use assert: mach.tests.assert;

# Minimal repros for aggregate copy, nested arrays/records, and generics.

rec Point {
    x: i64;
    y: i64;
}

rec Pair {
    a: i64;
    b: i64;
}

rec Wrap[T] {
    value: T;
}

fun make_wrap[T](value: T) Wrap[T] {
    var w: Wrap[T];
    w.value = value;
    ret w;
}

fun wrap_get[T](this: Wrap[T]) T {
    ret this.value;
}

fun wrap_set[T](this: *Wrap[T], value: T) {
    this.value = value;
}

test "repro: record by-value copy preserves fields" {
    val p1: Point = Point{x: 2, y: 5};
    val p2: Point = p1;
    ret assert.assert_eq_i64(p2.x + p2.y, 7);
}

test "repro: array by-value copy preserves elements" {
    val a: [2]i64 = [2]i64{8, 9};
    val b: [2]i64 = a;
    ret assert.assert_eq_i64(b[0] + b[1], 17);
}

test "repro: nested arrays layout" {
    val row0: [2]i64 = [2]i64{1, 2};
    val row1: [2]i64 = [2]i64{3, 4};
    val grid: [2][2]i64 = [2][2]i64{row0, row1};
    val sum: i64 = grid[0][0] + grid[0][1] + grid[1][0] + grid[1][1];
    ret assert.assert_eq_i64(sum, 10);
}

test "repro: array of records read" {
    val p0: Pair = Pair{a: 1, b: 2};
    val p1: Pair = Pair{a: 3, b: 4};
    val items: [2]Pair = [2]Pair{p0, p1};
    ret assert.assert_eq_i64(items[0].a + items[1].b, 5);
}

test "repro: generic wrap get" {
    val w: Wrap[i64] = make_wrap[i64](55);
    ret assert.assert_eq_i64(wrap_get[i64](w), 55);
}

test "repro: generic wrap set" {
    var w: Wrap[i64] = make_wrap[i64](1);
    wrap_set[i64](?w, 99);
    ret assert.assert_eq_i64(wrap_get[i64](w), 99);
}
