# Type alias (def) tests.

use assert: mach.tests.assert;

def Age: i64;
def Count: u64;
def Byte: u8;

test "typedefs: alias for i64" {
    var a: Age = 25;
    ret assert.assert_eq_i64(a, 25);
}

test "typedefs: alias for u64" {
    var c: Count = 100;
    ret assert.assert_eq_u64(c, 100);
}

test "typedefs: alias for u8" {
    var b: Byte = 255;
    ret assert.assert_eq_u8(b, 255);
}

test "typedefs: alias in arithmetic" {
    var a: Age = 30;
    var b: Age = 12;
    var sum: Age = a + b;
    ret assert.assert_eq_i64(sum, 42);
}

test "typedefs: alias assignment from literal" {
    var x: Age = 0;
    x = 99;
    ret assert.assert_eq_i64(x, 99);
}

def Ptr: ptr;

test "typedefs: alias for ptr" {
    var x: i64 = 123;
    var p: Ptr = ?x;
    var q: *i64 = p;
    ret assert.assert_eq_i64(@q, 123);
}

def IntPair: rec { a: i64; b: i64; };

test "typedefs: alias for record" {
    var p: IntPair = IntPair { a: 10, b: 20 };
    ret assert.assert_eq_i64(p.a + p.b, 30);
}
