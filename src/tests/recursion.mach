# Recursion tests for recursive functions and mutual recursion.

# --- Simple recursion ---

# Factorial using intermediate variable workaround.
# NOTE: Direct inline recursive call in binary expression is broken (see BROKEN.md #1).
fun factorial(n: i64) i64 {
    if (n <= 1) {
        ret 1;
    }
    var sub: i64 = factorial(n - 1);
    ret n * sub;
}

test "recursion: factorial of 0" {
    if (factorial(0) != 1) { ret 1; }
    ret 0;
}

test "recursion: factorial of 1" {
    if (factorial(1) != 1) { ret 1; }
    ret 0;
}

test "recursion: factorial of 5" {
    if (factorial(5) != 120) { ret 1; }
    ret 0;
}

test "recursion: factorial of 10" {
    if (factorial(10) != 3628800) { ret 1; }
    ret 0;
}

# Simple countdown that returns depth.
fun countdown(n: i64) i64 {
    if (n <= 0) {
        ret 0;
    }
    var sub: i64 = countdown(n - 1);
    ret 1 + sub;
}

test "recursion: countdown from 0" {
    if (countdown(0) != 0) { ret 1; }
    ret 0;
}

test "recursion: countdown from 5" {
    if (countdown(5) != 5) { ret 1; }
    ret 0;
}

test "recursion: countdown from 100" {
    if (countdown(100) != 100) { ret 1; }
    ret 0;
}

# Fibonacci using intermediate variable workaround.
# NOTE: Direct inline addition of two recursive calls is broken (see BROKEN.md #1).
fun fibonacci(n: i64) i64 {
    if (n <= 1) {
        ret n;
    }
    var a: i64 = fibonacci(n - 1);
    var b: i64 = fibonacci(n - 2);
    ret a + b;
}

test "recursion: fibonacci of 0" {
    if (fibonacci(0) != 0) { ret 1; }
    ret 0;
}

test "recursion: fibonacci of 1" {
    if (fibonacci(1) != 1) { ret 1; }
    ret 0;
}

test "recursion: fibonacci of 10" {
    if (fibonacci(10) != 55) { ret 1; }
    ret 0;
}

test "recursion: fibonacci of 15" {
    if (fibonacci(15) != 610) { ret 1; }
    ret 0;
}

# --- Mutual recursion ---

fun is_even(n: i64) u8 {
    if (n == 0) {
        ret 1;
    }
    ret is_odd(n - 1);
}

fun is_odd(n: i64) u8 {
    if (n == 0) {
        ret 0;
    }
    ret is_even(n - 1);
}

test "recursion: mutual is_even 0" {
    if (is_even(0) != 1) { ret 1; }
    ret 0;
}

test "recursion: mutual is_even 10" {
    if (is_even(10) != 1) { ret 1; }
    ret 0;
}

test "recursion: mutual is_even 7 is false" {
    if (is_even(7) != 0) { ret 1; }
    ret 0;
}

test "recursion: mutual is_odd 0 is false" {
    if (is_odd(0) != 0) { ret 1; }
    ret 0;
}

test "recursion: mutual is_odd 7" {
    if (is_odd(7) != 1) { ret 1; }
    ret 0;
}

test "recursion: mutual is_odd 10 is false" {
    if (is_odd(10) != 0) { ret 1; }
    ret 0;
}

# --- Multiple return paths ---

fun abs_val(x: i64) i64 {
    if (x < 0) {
        ret 0 - x;
    }
    ret x;
}

test "recursion: abs_val positive" {
    if (abs_val(5) != 5) { ret 1; }
    ret 0;
}

test "recursion: abs_val negative" {
    if (abs_val(0 - 5) != 5) { ret 1; }
    ret 0;
}

test "recursion: abs_val zero" {
    if (abs_val(0) != 0) { ret 1; }
    ret 0;
}

test "recursion: abs_val large negative" {
    if (abs_val(0 - 1000000) != 1000000) { ret 1; }
    ret 0;
}

# --- Recursive sum ---

fun sum_to(n: i64) i64 {
    if (n <= 0) {
        ret 0;
    }
    var sub: i64 = sum_to(n - 1);
    ret n + sub;
}

test "recursion: sum_to 0" {
    if (sum_to(0) != 0) { ret 1; }
    ret 0;
}

test "recursion: sum_to 10" {
    if (sum_to(10) != 55) { ret 1; }
    ret 0;
}

test "recursion: sum_to 100" {
    if (sum_to(100) != 5050) { ret 1; }
    ret 0;
}

# --- Recursive power ---

fun power(base: i64, exp: i64) i64 {
    if (exp == 0) {
        ret 1;
    }
    var sub: i64 = power(base, exp - 1);
    ret base * sub;
}

test "recursion: power 2^0" {
    if (power(2, 0) != 1) { ret 1; }
    ret 0;
}

test "recursion: power 2^10" {
    if (power(2, 10) != 1024) { ret 1; }
    ret 0;
}

test "recursion: power 3^5" {
    if (power(3, 5) != 243) { ret 1; }
    ret 0;
}

# --- GCD (Euclidean algorithm) ---

fun gcd(a: i64, b: i64) i64 {
    if (b == 0) {
        ret a;
    }
    ret gcd(b, a % b);
}

test "recursion: gcd 48 and 18" {
    if (gcd(48, 18) != 6) { ret 1; }
    ret 0;
}

test "recursion: gcd 100 and 25" {
    if (gcd(100, 25) != 25) { ret 1; }
    ret 0;
}

test "recursion: gcd 17 and 13 (coprime)" {
    if (gcd(17, 13) != 1) { ret 1; }
    ret 0;
}
