# Literal syntax tests for various numeric literal forms and overflow behavior.

use assert: mach.tests.assert;

# --- Negative literals ---

test "literals: negative i64 literal" {
    var x: i64 = -42;
    ret assert.assert_eq_i64(x, 0 - 42);
}

test "literals: negative i64 large" {
    var x: i64 = -1000000;
    ret assert.assert_eq_i64(x, 0 - 1000000);
}

test "literals: negative in expression" {
    var x: i64 = 10 + -5;
    ret assert.assert_eq_i64(x, 5);
}

test "literals: negative subtract negative" {
    var x: i64 = -10 - -5;
    ret assert.assert_eq_i64(x, 0 - 5);
}

test "literals: negative multiply" {
    var x: i64 = -3 * 4;
    ret assert.assert_eq_i64(x, 0 - 12);
}

test "literals: negative multiply negative" {
    var x: i64 = -3 * -4;
    ret assert.assert_eq_i64(x, 12);
}

test "literals: negative in comparison" {
    var x: i64 = -5;
    var y: i64 = 5;
    if (x < y) {
        ret 0;
    }
    ret 1;
}

# --- Hex literals ---

test "literals: hex simple" {
    var x: u64 = 0xFF;
    ret assert.assert_eq_u64(x, 255);
}

test "literals: hex uppercase" {
    var x: u64 = 0xABCD;
    ret assert.assert_eq_u64(x, 43981);
}

test "literals: hex lowercase" {
    var x: u64 = 0xabcd;
    ret assert.assert_eq_u64(x, 43981);
}

test "literals: hex mixed case" {
    var x: u64 = 0xAbCd;
    ret assert.assert_eq_u64(x, 43981);
}

test "literals: hex large" {
    var x: u64 = 0xDEADBEEF;
    ret assert.assert_eq_u64(x, 3735928559);
}

test "literals: hex full 64-bit" {
    var x: u64 = 0xFFFFFFFFFFFFFFFF;
    ret assert.assert_eq_u64(x, 18446744073709551615);
}

test "literals: hex in arithmetic" {
    var x: u64 = 0x10 + 0x20;
    ret assert.assert_eq_u64(x, 0x30);
}

test "literals: hex byte mask" {
    var x: u64 = 0x12345678;
    var low_byte: u64 = x & 0xFF;
    ret assert.assert_eq_u64(low_byte, 0x78);
}

# --- Typed literals with suffix ---

test "literals: i64 suffix" {
    var x: i64 = 42i64;
    ret assert.assert_eq_i64(x, 42);
}

test "literals: u8 suffix" {
    var x: u8 = 255u8;
    ret assert.assert_eq_u8(x, 255);
}

test "literals: i8 suffix" {
    var x: i8 = 127i8;
    ret assert.assert_eq_i8(x, 127);
}

test "literals: negative i8 suffix" {
    var x: i8 = -128i8;
    ret assert.assert_eq_i8(x, 0 - 128);
}

# --- Integer overflow wrapping ---

test "literals: u8 overflow wraps to zero" {
    var x: u8 = 255;
    x = x + 1;
    ret assert.assert_eq_u8(x, 0);
}

test "literals: u8 underflow wraps to max" {
    var x: u8 = 0;
    x = x - 1;
    ret assert.assert_eq_u8(x, 255);
}

test "literals: i8 overflow wraps to negative" {
    var x: i8 = 127;
    x = x + 1;
    ret assert.assert_eq_i8(x, -128);
}

test "literals: i8 underflow wraps to positive" {
    var x: i8 = -128;
    x = x - 1;
    ret assert.assert_eq_i8(x, 127);
}

test "literals: u32 overflow wraps" {
    var x: u32 = 4294967295;
    x = x + 1;
    ret assert.assert_eq_u32(x, 0);
}

test "literals: i32 overflow wraps" {
    var x: i32 = 2147483647;
    x = x + 1;
    ret assert.assert_eq_i32(x, 0 - 2147483648);
}

# --- Zero ---

test "literals: zero i64" {
    var x: i64 = 0;
    ret assert.assert_eq_i64(x, 0);
}

test "literals: zero u64" {
    var x: u64 = 0;
    ret assert.assert_eq_u64(x, 0);
}

test "literals: hex zero" {
    var x: u64 = 0x0;
    ret assert.assert_eq_u64(x, 0);
}

# --- Boundary values ---

test "literals: u8 max" {
    var x: u8 = 255;
    ret assert.assert_eq_u8(x, 255);
}

test "literals: u8 min" {
    var x: u8 = 0;
    ret assert.assert_eq_u8(x, 0);
}

test "literals: i8 max" {
    var x: i8 = 127;
    ret assert.assert_eq_i8(x, 127);
}

test "literals: i8 min" {
    var x: i8 = -128;
    ret assert.assert_eq_i8(x, 0 - 128);
}

test "literals: u64 max" {
    var x: u64 = 18446744073709551615;
    ret assert.assert_eq_u64(x, 18446744073709551615);
}

test "literals: i64 max" {
    var x: i64 = 9223372036854775807;
    ret assert.assert_eq_i64(x, 9223372036854775807);
}

# --- Literal in different contexts ---

test "literals: literal as array index" {
    var arr: [5]i64;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    ret assert.assert_eq_i64(arr[2], 30);
}

test "literals: literal as function argument" {
    ret assert.assert_eq_i64(42, 42);
}

test "literals: hex literal as mask" {
    var value: u64 = 0xABCDEF12;
    var masked: u64 = value & 0x0000FFFF;
    ret assert.assert_eq_u64(masked, 0xEF12);
}
