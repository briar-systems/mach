uni IntOrFloat {
    i: i64;
    f: f64;
}

uni WordBytes {
    value: u32;
    bytes: [4]u8;
}

uni Mixed {
    small: u8;
    large: u64;
}

test "unions: simple read write" {
    var u: WordBytes;
    u.value = 123456;
    if (u.value != 123456) { ret 1; }
    ret 0;
}

test "unions: partial write affects overlapping read" {
    var u: Mixed;
    u.large = 0;
    u.small = 255;

    if (u.large != 255) { ret 1; }
    ret 0;
}

test "unions: literal initialization" {
    val u: IntOrFloat = IntOrFloat{ i: 12345 };
    if (u.i != 12345) { ret 1; }
    ret 0;
}
