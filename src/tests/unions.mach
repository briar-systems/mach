use assert: mach.tests.assert;

uni IntOrFloat {
    i: i64;
    f: f64;
}

uni WordBytes {
    value: u32;
    bytes: [4]u8;
}

uni Mixed {
    small: u8;
    large: u64;
}

test "unions: simple read write" {
    var u: WordBytes;
    u.value = 123456;
    ret assert.assert_true(u.value == 123456);
}

test "unions: partial write affects overlapping read" {
    var u: Mixed;
    u.large = 0;
    u.small = 255;

    ret assert.assert_eq_u64(u.large, 255);
}

test "unions: literal initialization" {
    val u: IntOrFloat = IntOrFloat{ i: 12345 };
    ret assert.assert_eq_i64(u.i, 12345);
}
