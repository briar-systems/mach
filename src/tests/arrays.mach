# Array and indexing tests.

rec Pair {
    a: i64;
    b: i64;
}

test "arrays: read/write via index" {
    var arr: [4]i64 = [4]i64{1, 2, 3, 4};
    arr[2] = 9;
    if (arr[2] != 9) { ret 0; }
    ret 1;
}

test "arrays: sum elements" {
    val arr: [3]i64 = [3]i64{10, 20, 30};
    val sum: i64 = arr[0] + arr[1] + arr[2];
    if (sum != 60) { ret 0; }
    ret 1;
}

test "arrays: nested arrays" {
    val row0: [2]i64 = [2]i64{1, 2};
    val row1: [2]i64 = [2]i64{3, 4};
    val grid: [2][2]i64 = [2][2]i64{row0, row1};
    val sum: i64 = grid[0][0] + grid[0][1] + grid[1][0] + grid[1][1];
    if (sum != 10) { ret 0; }
    ret 1;
}

test "arrays: array of records" {
    val p0: Pair = Pair{a: 1, b: 2};
    val p1: Pair = Pair{a: 3, b: 4};
    val items: [2]Pair = [2]Pair{p0, p1};

    if ((items[0].a + items[1].b) != 5) { ret 0; }
    ret 1;
}

test "arrays: pointer indexing" {
    var arr: [3]i64 = [3]i64{5, 6, 7};
    val p: *i64 = ?arr[0];
    if (p[1] != 6) { ret 0; }
    ret 1;
}

test "arrays: pointer write via index" {
    var arr: [3]i64 = [3]i64{5, 6, 7};
    val p: *i64 = ?arr[0];
    p[1] = 12;
    if (arr[1] != 12) { ret 0; }
    ret 1;
}

test "arrays: assign array value copy" {
    val a: [2]i64 = [2]i64{8, 9};
    val b: [2]i64 = a;
    if ((b[0] + b[1]) != 17) { ret 0; }
    ret 1;
}
