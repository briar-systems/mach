# function pointer tests
# tests function pointers stored in records, passed as parameters, and returned via sret

use std.types.bool;

# --- test helper functions ---

fun fn_hash(p: ptr) u64 {
    val n: &i64 = p::&i64;
    ret (@n)::u64;
}

fun fn_eq(a: ptr, b: ptr) bool {
    val x: &i64 = a::&i64;
    val y: &i64 = b::&i64;
    ret @x == @y;
}

fun fn_const(p: ptr) u64 {
    ret 42;
}

# --- plain record with function pointers ---

rec FnHolder {
    hash_fn: fun(ptr) u64;
    eq_fn: fun(ptr, ptr) bool;
}

test "fnptr: plain record hash_fn call" {
    var h: FnHolder;
    h.hash_fn = fn_hash;
    h.eq_fn = fn_eq;

    val x: i64 = 123;
    if (h.hash_fn((?x)::ptr) != 123) { ret 0; }
    ret 1;
}

test "fnptr: plain record eq_fn call" {
    var h: FnHolder;
    h.hash_fn = fn_hash;
    h.eq_fn = fn_eq;

    val x: i64 = 123;
    val y: i64 = 123;
    if (!h.eq_fn((?x)::ptr, (?y)::ptr)) { ret 0; }
    ret 1;
}

# --- generic record with function pointers ---

rec Container[T] {
    data: T;
    hash_fn: fun(ptr) u64;
    eq_fn: fun(ptr, ptr) bool;
}

test "fnptr: generic record hash_fn call" {
    var c: Container[i64];
    c.data = 100;
    c.hash_fn = fn_hash;
    c.eq_fn = fn_eq;

    val x: i64 = 42;
    if (c.hash_fn((?x)::ptr) != 42) { ret 0; }
    ret 1;
}

test "fnptr: generic record eq_fn call" {
    var c: Container[i64];
    c.data = 100;
    c.hash_fn = fn_hash;
    c.eq_fn = fn_eq;

    val x: i64 = 42;
    val y: i64 = 42;
    if (!c.eq_fn((?x)::ptr, (?y)::ptr)) { ret 0; }
    ret 1;
}

# --- generic record returned via sret ---

fun make_container[T](data: T, hfn: fun(ptr) u64, efn: fun(ptr, ptr) bool) Container[T] {
    var c: Container[T];
    c.data = data;
    c.hash_fn = hfn;
    c.eq_fn = efn;
    ret c;
}

test "fnptr: generic init returns hash_fn correctly" {
    val c: Container[i64] = make_container[i64](0, fn_hash, fn_eq);

    val x: i64 = 99;
    if (c.hash_fn((?x)::ptr) != 99) { ret 0; }
    ret 1;
}

test "fnptr: generic init returns eq_fn correctly" {
    val c: Container[i64] = make_container[i64](0, fn_hash, fn_eq);

    val x: i64 = 99;
    val y: i64 = 99;
    if (!c.eq_fn((?x)::ptr, (?y)::ptr)) { ret 0; }
    ret 1;
}

# --- nested struct with function pointer (sret regression) ---
# this pattern triggered a parameter register clobbering bug:
# large aggregate param + scalar fnptr param + sret return

rec Inner {
    a: u64;
    b: u64;
}

rec Outer[T] {
    inner: Inner;
    data: T;
    fn1: fun(ptr) u64;
}

fun make_inner(a: u64, b: u64) Inner {
    var i: Inner;
    i.a = a;
    i.b = b;
    ret i;
}

fun make_outer[T](inner: Inner, data: T, f: fun(ptr) u64) Outer[T] {
    var o: Outer[T];
    o.inner = inner;
    o.data = data;
    o.fn1 = f;
    ret o;
}

# non-generic version to test both paths
fun make_outer_i64(inner: Inner, data: i64, f: fun(ptr) u64) Outer[i64] {
    var o: Outer[i64];
    o.inner = inner;
    o.data = data;
    o.fn1 = f;
    ret o;
}

test "fnptr: nested struct direct assignment fn1 call" {
    val inner: Inner = make_inner(1, 2);

    var o: Outer[i64];
    o.inner = inner;
    o.data = 100;
    o.fn1 = fn_const;

    if (o.fn1(nil) != 42) { ret 0; }
    ret 1;
}

test "fnptr: nested struct direct assignment inner.a" {
    val inner: Inner = make_inner(1, 2);

    var o: Outer[i64];
    o.inner = inner;
    o.data = 100;
    o.fn1 = fn_const;

    if (o.inner.a != 1) { ret 0; }
    ret 1;
}

test "fnptr: nested struct direct assignment inner.b" {
    val inner: Inner = make_inner(1, 2);

    var o: Outer[i64];
    o.inner = inner;
    o.data = 100;
    o.fn1 = fn_const;

    if (o.inner.b != 2) { ret 0; }
    ret 1;
}

test "fnptr: nested struct direct assignment data" {
    val inner: Inner = make_inner(1, 2);

    var o: Outer[i64];
    o.inner = inner;
    o.data = 100;
    o.fn1 = fn_const;

    if (o.data != 100) { ret 0; }
    ret 1;
}

test "fnptr: nested struct non-generic sret fn1 call" {
    val inner: Inner = make_inner(10, 20);
    val o: Outer[i64] = make_outer_i64(inner, 200, fn_const);

    if (o.fn1(nil) != 42) { ret 0; }
    ret 1;
}

test "fnptr: nested struct non-generic sret inner.a" {
    val inner: Inner = make_inner(10, 20);
    val o: Outer[i64] = make_outer_i64(inner, 200, fn_const);

    if (o.inner.a != 10) { ret 0; }
    ret 1;
}

test "fnptr: nested struct non-generic sret inner.b" {
    val inner: Inner = make_inner(10, 20);
    val o: Outer[i64] = make_outer_i64(inner, 200, fn_const);

    if (o.inner.b != 20) { ret 0; }
    ret 1;
}

test "fnptr: nested struct non-generic sret data" {
    val inner: Inner = make_inner(10, 20);
    val o: Outer[i64] = make_outer_i64(inner, 200, fn_const);

    if (o.data != 200) { ret 0; }
    ret 1;
}

test "fnptr: nested struct generic sret fn1 call" {
    val inner: Inner = make_inner(100, 200);
    val o: Outer[i64] = make_outer[i64](inner, 300, fn_const);

    if (o.fn1(nil) != 42) { ret 0; }
    ret 1;
}

test "fnptr: nested struct generic sret inner.a" {
    val inner: Inner = make_inner(100, 200);
    val o: Outer[i64] = make_outer[i64](inner, 300, fn_const);

    if (o.inner.a != 100) { ret 0; }
    ret 1;
}

test "fnptr: nested struct generic sret inner.b" {
    val inner: Inner = make_inner(100, 200);
    val o: Outer[i64] = make_outer[i64](inner, 300, fn_const);

    if (o.inner.b != 200) { ret 0; }
    ret 1;
}

test "fnptr: nested struct generic sret data" {
    val inner: Inner = make_inner(100, 200);
    val o: Outer[i64] = make_outer[i64](inner, 300, fn_const);

    if (o.data != 300) { ret 0; }
    ret 1;
}

# --- multi-type-param generic with fnptr ---

rec Pair[K, V] {
    key: K;
    val_: V;
    hash_fn: fun(ptr) u64;
}

fun make_pair[K, V](k: K, v: V, hfn: fun(ptr) u64) Pair[K, V] {
    var p: Pair[K, V];
    p.key = k;
    p.val_ = v;
    p.hash_fn = hfn;
    ret p;
}

test "fnptr: multi-type-param generic sret hash_fn call" {
    val p: Pair[i64, u64] = make_pair[i64, u64](42, 100, fn_hash);

    val k: i64 = p.key;
    if (p.hash_fn((?k)::ptr) != 42) { ret 0; }
    ret 1;
}

test "fnptr: multi-type-param generic sret key" {
    val p: Pair[i64, u64] = make_pair[i64, u64](42, 100, fn_hash);

    if (p.key != 42) { ret 0; }
    ret 1;
}

test "fnptr: multi-type-param generic sret val" {
    val p: Pair[i64, u64] = make_pair[i64, u64](42, 100, fn_hash);

    if (p.val_ != 100) { ret 0; }
    ret 1;
}
