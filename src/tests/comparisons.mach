# Type-specific comparison tests for various integer and pointer types.

use assert: mach.tests.assert;

# --- u8 comparisons ---

test "comparisons: u8 less than true" {
    var a: u8 = 100;
    var b: u8 = 200;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u8 less than false" {
    var a: u8 = 200;
    var b: u8 = 100;
    if (a < b) {
        ret 1;
    }
    ret 0;
}

test "comparisons: u8 greater than true" {
    var a: u8 = 200;
    var b: u8 = 100;
    if (a > b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u8 equal" {
    var a: u8 = 42;
    var b: u8 = 42;
    if (a == b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u8 not equal" {
    var a: u8 = 42;
    var b: u8 = 43;
    if (a != b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u8 boundary values" {
    var min: u8 = 0;
    var max: u8 = 255;
    if (min < max) {
        ret 0;
    }
    ret 1;
}

# --- u32 comparisons ---

test "comparisons: u32 less than" {
    var a: u32 = 1000;
    var b: u32 = 2000;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u32 greater than" {
    var a: u32 = 3000000000;
    var b: u32 = 1000000000;
    if (a > b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u32 equal" {
    var a: u32 = 4000000000;
    var b: u32 = 4000000000;
    if (a == b) {
        ret 0;
    }
    ret 1;
}

# --- i32 comparisons (positive values only - negative is broken, see BROKEN.md #4) ---

test "comparisons: i32 less than positive" {
    var a: i32 = 5;
    var b: i32 = 10;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i32 greater than positive" {
    var a: i32 = 100;
    var b: i32 = 50;
    if (a > b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i32 equal positive" {
    var a: i32 = 12345;
    var b: i32 = 12345;
    if (a == b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i32 less than or equal positive" {
    var a: i32 = 10;
    var b: i32 = 10;
    if (a <= b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i32 greater than or equal positive" {
    var a: i32 = 20;
    var b: i32 = 15;
    if (a >= b) {
        ret 0;
    }
    ret 1;
}

# BUG: i32 signed comparison with negative values fails (see BROKEN.md #4)
test "comparisons: i32 negative vs positive" {
    var a: i32 = 0 - 10;
    var b: i32 = 10;
    if (a < b) { ret 0; }
    ret 1;
}

# --- u64 comparisons ---

test "comparisons: u64 less than" {
    var a: u64 = 1000000;
    var b: u64 = 2000000;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u64 greater than" {
    var a: u64 = 5000000000;
    var b: u64 = 1000000;
    if (a > b) {
        ret 0;
    }
    ret 1;
}

# BUG: u64 greater than with values above i64 max fails (treated as signed, see BROKEN.md)
test "comparisons: u64 greater than large" {
    var a: u64 = 9223372036854775808;  # 2^63, just above i64 max
    var b: u64 = 1000000;
    if (a > b) { ret 0; }
    ret 1;
}

test "comparisons: u64 equal" {
    var a: u64 = 18446744073709551615;
    var b: u64 = 18446744073709551615;
    if (a == b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: u64 not equal" {
    var a: u64 = 100;
    var b: u64 = 200;
    if (a != b) {
        ret 0;
    }
    ret 1;
}

# --- i64 comparisons (including negative values) ---

test "comparisons: i64 less than positive" {
    var a: i64 = 100;
    var b: i64 = 200;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 greater than positive" {
    var a: i64 = 500;
    var b: i64 = 100;
    if (a > b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 negative less than positive" {
    var a: i64 = 0 - 10;
    var b: i64 = 10;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 negative less than zero" {
    var a: i64 = 0 - 100;
    var b: i64 = 0;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 compare two negatives" {
    var a: i64 = 0 - 100;
    var b: i64 = 0 - 50;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 negative greater than more negative" {
    var a: i64 = 0 - 5;
    var b: i64 = 0 - 100;
    if (a > b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 equal negative" {
    var a: i64 = 0 - 42;
    var b: i64 = 0 - 42;
    if (a == b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 not equal different signs" {
    var a: i64 = 0 - 10;
    var b: i64 = 10;
    if (a != b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 less than or equal true (less)" {
    var a: i64 = 0 - 5;
    var b: i64 = 5;
    if (a <= b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 less than or equal true (equal)" {
    var a: i64 = 0 - 5;
    var b: i64 = 0 - 5;
    if (a <= b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 greater than or equal true (greater)" {
    var a: i64 = 100;
    var b: i64 = 0 - 100;
    if (a >= b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i64 greater than or equal true (equal)" {
    var a: i64 = 0;
    var b: i64 = 0;
    if (a >= b) {
        ret 0;
    }
    ret 1;
}

# --- Pointer comparisons ---

test "comparisons: pointer equal to self" {
    var x: i64 = 42;
    var p: *i64 = ?x;
    if (p == p) {
        ret 0;
    }
    ret 1;
}

test "comparisons: pointer not equal different addresses" {
    var x: i64 = 1;
    var y: i64 = 2;
    var px: *i64 = ?x;
    var py: *i64 = ?y;
    if (px != py) {
        ret 0;
    }
    ret 1;
}

test "comparisons: pointer equal same address" {
    var x: i64 = 42;
    var p1: *i64 = ?x;
    var p2: *i64 = ?x;
    if (p1 == p2) {
        ret 0;
    }
    ret 1;
}

test "comparisons: pointer to nil" {
    var p: *i64 = nil;
    if (p == nil) {
        ret 0;
    }
    ret 1;
}

test "comparisons: pointer not nil" {
    var x: i64 = 42;
    var p: *i64 = ?x;
    if (p != nil) {
        ret 0;
    }
    ret 1;
}

# --- i8 comparisons ---

test "comparisons: i8 less than positive" {
    var a: i8 = 10;
    var b: i8 = 100;
    if (a < b) {
        ret 0;
    }
    ret 1;
}

test "comparisons: i8 equal" {
    var a: i8 = 42;
    var b: i8 = 42;
    if (a == b) {
        ret 0;
    }
    ret 1;
}

# --- Comparison chains ---

fun in_range(x: i64, min: i64, max: i64) u8 {
    if (x >= min) {
        if (x <= max) {
            ret 1;
        }
    }
    ret 0;
}

test "comparisons: in_range true" {
    ret assert.assert_true(in_range(5, 0, 10));
}

test "comparisons: in_range false below" {
    ret assert.assert_false(in_range(0 - 1, 0, 10));
}

test "comparisons: in_range false above" {
    ret assert.assert_false(in_range(11, 0, 10));
}

test "comparisons: in_range boundary min" {
    ret assert.assert_true(in_range(0, 0, 10));
}

test "comparisons: in_range boundary max" {
    ret assert.assert_true(in_range(10, 0, 10));
}
