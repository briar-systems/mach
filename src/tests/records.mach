# Record and method tests.

rec Point {
    x: i64;
    y: i64;
}

# Large struct with 8+ fields
rec BigStruct {
    a: i64;
    b: i64;
    c: i64;
    d: i64;
    e: i64;
    f: i64;
    g: i64;
    h: i64;
}

# Inner/Outer for nested record tests
rec Inner {
    x: i64;
    y: i64;
}

rec Outer {
    inner: Inner;
    z: i64;
}

rec Line {
    a: Point;
    b: Point;
}

fun (this: Point) sum() i64 {
    ret this.x + this.y;
}

fun (this: *Point) move(dx: i64, dy: i64) {
    this.x = this.x + dx;
    this.y = this.y + dy;
}

rec Pair[T] {
    left:  T;
    right: T;
}

fun make_pair[T](a: T, b: T) Pair[T] {
    var p: Pair[T];
    p.left = a;
    p.right = b;
    ret p;
}

rec Box[T] {
    value: T;
}

fun box_set[T](this: *Box[T], v: T) {
    this.value = v;
}

fun box_get[T](this: Box[T]) T {
    ret this.value;
}

fun take_ptr[T](p: *T) i64 {
    if (p == nil) { ret 1; }
    ret 0;
}

test "records: field access and sum method" {
    val p: Point = Point{x: 3, y: 4};
    if (p.sum() != 7) { ret 1; }
    ret 0;
}

test "records: pointer receiver method updates fields" {
    var p: Point = Point{x: 1, y: 2};
    p.move(5, -1);
    if (p.sum() != 7) { ret 1; }
    ret 0;
}

test "records: assign fields directly" {
    var p: Point = Point{x: 0, y: 0};
    p.x = 9;
    p.y = -3;
    if (p.sum() != 6) { ret 1; }
    ret 0;
}

test "records: by-value copy preserves values" {
    val p1: Point = Point{x: 2, y: 5};
    val p2: Point = p1;
    if (p2.sum() != 7) { ret 1; }
    ret 0;
}

test "records: generic record literal" {
    val p: Pair[i64] = Pair[i64]{left: 11, right: 22};
    if ((p.left + p.right) != 33) { ret 1; }
    ret 0;
}

test "records: generic constructor function" {
    val p: Pair[i64] = make_pair[i64](7, 8);
    if ((p.left * 10 + p.right) != 78) { ret 1; }
    ret 0;
}

test "records: generic method on pointer receiver" {
    var b: Box[i64];
    box_set[i64](?b, 42);
    if (box_get[i64](b) != 42) { ret 1; }
    ret 0;
}

test "records: pass record pointer to generic function" {
    var p: Point = Point{x: 1, y: 2};
    ret take_ptr[Point](?p);
}

test "records: nested record types" {
    val line: Line = Line{
        a: Point{x: 1, y: 2},
        b: Point{x: 3, y: 4}
    };

    val sum: i64 = line.a.x + line.a.y + line.b.x + line.b.y;
    if (sum != 10) { ret 1; }
    ret 0;
}

test "records: pointer field access and mutation" {
    var p: Point = Point{x: 2, y: 3};
    var pp: *Point = ?p;
    pp.x = pp.x + 1;
    pp.y = pp.y + 2;
    if (p.sum() != 8) { ret 1; }
    ret 0;
}

# --- Large struct tests ---

test "records: large struct all fields" {
    var s: BigStruct = BigStruct {
        a: 1, b: 2, c: 3, d: 4,
        e: 5, f: 6, g: 7, h: 8
    };
    var sum: i64 = s.a + s.b + s.c + s.d + s.e + s.f + s.g + s.h;
    if (sum != 36) { ret 1; }
    ret 0;
}

test "records: large struct field mutation" {
    var s: BigStruct = BigStruct {
        a: 0, b: 0, c: 0, d: 0,
        e: 0, f: 0, g: 0, h: 0
    };
    s.a = 10;
    s.d = 20;
    s.h = 30;
    if ((s.a + s.d + s.h) != 60) { ret 1; }
    ret 0;
}

test "records: large struct pass by value copy" {
    var s: BigStruct = BigStruct {
        a: 10, b: 20, c: 30, d: 40,
        e: 50, f: 60, g: 70, h: 80
    };
    var copy: BigStruct = s;
    s.a = 0;
    if (copy.a != 10) { ret 1; }
    ret 0;
}

test "records: large struct pointer access" {
    var s: BigStruct = BigStruct {
        a: 1, b: 2, c: 3, d: 4,
        e: 5, f: 6, g: 7, h: 8
    };
    var p: *BigStruct = ?s;
    if (p.h != 8) { ret 1; }
    ret 0;
}

# --- Deep nesting tests ---

test "records: nested record access" {
    var o: Outer = Outer {
        inner: Inner { x: 5, y: 10 },
        z: 15
    };
    if ((o.inner.x + o.inner.y + o.z) != 30) { ret 1; }
    ret 0;
}

test "records: nested record mutation" {
    var o: Outer = Outer {
        inner: Inner { x: 1, y: 2 },
        z: 3
    };
    o.inner.x = 100;
    if (o.inner.x != 100) { ret 1; }
    ret 0;
}

test "records: pointer to nested field" {
    var o: Outer = Outer {
        inner: Inner { x: 7, y: 8 },
        z: 9
    };
    var p: *Outer = ?o;
    if ((p.inner.x + p.inner.y) != 15) { ret 1; }
    ret 0;
}

test "records: mutate through pointer chain" {
    var o: Outer = Outer {
        inner: Inner { x: 1, y: 2 },
        z: 3
    };
    var p: *Outer = ?o;
    p.inner.x = 50;
    if (o.inner.x != 50) { ret 1; }
    ret 0;
}

# --- Manual equality comparison ---

fun points_equal(a: *Point, b: *Point) u8 {
    if (a.x != b.x) {
        ret 0;
    }
    if (a.y != b.y) {
        ret 0;
    }
    ret 1;
}

test "records: manual equality equal" {
    var a: Point = Point { x: 5, y: 10 };
    var b: Point = Point { x: 5, y: 10 };
    if (points_equal(?a, ?b) != 1) { ret 1; }
    ret 0;
}

test "records: manual equality not equal" {
    var a: Point = Point { x: 5, y: 10 };
    var b: Point = Point { x: 5, y: 11 };
    if (points_equal(?a, ?b) == 1) { ret 1; }
    ret 0;
}

test "records: manual equality different x" {
    var a: Point = Point { x: 1, y: 10 };
    var b: Point = Point { x: 2, y: 10 };
    if (points_equal(?a, ?b) == 1) { ret 1; }
    ret 0;
}

# --- Explicit initialization ---

test "records: explicit zero init" {
    var p: Point = Point { x: 0, y: 0 };
    if ((p.x + p.y) != 0) { ret 1; }
    ret 0;
}
