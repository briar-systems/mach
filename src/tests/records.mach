use assert: mach.tests.assert;

# Record and method tests.

rec Point {
    x: i64;
    y: i64;
}

rec Line {
    a: Point;
    b: Point;
}

fun (this: Point) sum() i64 {
    ret this.x + this.y;
}

fun (this: *Point) move(dx: i64, dy: i64) {
    this.x = this.x + dx;
    this.y = this.y + dy;
}

rec Pair[T] {
    left:  T;
    right: T;
}

fun make_pair[T](a: T, b: T) Pair[T] {
    var p: Pair[T];
    p.left = a;
    p.right = b;
    ret p;
}

rec Box[T] {
    value: T;
}

fun box_set[T](this: *Box[T], v: T) {
    this.value = v;
}

fun box_get[T](this: Box[T]) T {
    ret this.value;
}

fun take_ptr[T](p: *T) i64 {
    ret assert.assert_true(p != nil);
}

test "records: field access and sum method" {
    val p: Point = Point{x: 3, y: 4};
    ret assert.assert_eq_i64(p.sum(), 7);
}

test "records: pointer receiver method updates fields" {
    var p: Point = Point{x: 1, y: 2};
    p.move(5, -1);
    ret assert.assert_eq_i64(p.sum(), 7);
}

test "records: assign fields directly" {
    var p: Point = Point{x: 0, y: 0};
    p.x = 9;
    p.y = -3;
    ret assert.assert_eq_i64(p.sum(), 6);
}

test "records: by-value copy preserves values" {
    val p1: Point = Point{x: 2, y: 5};
    val p2: Point = p1;
    ret assert.assert_eq_i64(p2.sum(), 7);
}

test "records: generic record literal" {
    val p: Pair[i64] = Pair[i64]{left: 11, right: 22};
    ret assert.assert_eq_i64(p.left + p.right, 33);
}

test "records: generic constructor function" {
    val p: Pair[i64] = make_pair[i64](7, 8);
    ret assert.assert_eq_i64(p.left * 10 + p.right, 78);
}

test "records: generic method on pointer receiver" {
    var b: Box[i64];
    box_set[i64](?b, 42);
    ret assert.assert_eq_i64(box_get[i64](b), 42);
}

test "records: pass record pointer to generic function" {
    var p: Point = Point{x: 1, y: 2};
    ret take_ptr[Point](?p);
}

test "records: nested record types" {
    val line: Line = Line{
        a: Point{x: 1, y: 2},
        b: Point{x: 3, y: 4}
    };

    val sum: i64 = line.a.x + line.a.y + line.b.x + line.b.y;
    ret assert.assert_eq_i64(sum, 10);
}

test "records: pointer field access and mutation" {
    var p: Point = Point{x: 2, y: 3};
    var pp: *Point = ?p;
    pp.x = pp.x + 1;
    pp.y = pp.y + 2;
    ret assert.assert_eq_i64(p.sum(), 8);
}
