$main.symbol = "main";
fun main() i64 {
    ret 42;
}

mir {
    pub _start:
        xor.i64 rbp, rbp, rbp;
        mov.i64 %0, rsp;
        and.i64 %0, %0, -16;
        mov.i64 rsp, %0;
        jmp mach_runtime_entry;

    pub mach_runtime_entry:
        mov.i64 %exit_code, 42;
        mov.i64 rdi, %exit_code;
        jmp mach_runtime_exit;

    pub mach_runtime_exit:
        mov.i64 rax, 60;
        x86.syscall;
        unreachable;
}
