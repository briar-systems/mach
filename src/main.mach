# main: mach compiler entry point

use std.runtime;
use std.types.bool;
use std.types.size;
use std.types.string;

use print: std.print;

use cmd_build: mach.cmd.build;
use cmd_run:   mach.cmd.run;
use cmd_test:  mach.cmd.testing;
use cmd_dep:   mach.cmd.dep;
use cmd_init:  mach.cmd.init;
use cmd_help:  mach.cmd.help;

# main: dispatch command-line subcommands.
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
$main.symbol = "main";
fun main(argc: i64, argv: &*u8) i64 {
    if (argc < 2) {
        cmd_help.run(argc, argv);
        ret 1;
    }

    val command: str = argv[1]::str;

    if (str_equals(command, "build")) { ret cmd_build.run(argc, argv); }
    if (str_equals(command, "run"))   { ret cmd_run.run(argc, argv); }
    if (str_equals(command, "test"))  { ret cmd_test.run(argc, argv); }
    if (str_equals(command, "dep"))   { ret cmd_dep.run(argc, argv); }
    if (str_equals(command, "init"))  { ret cmd_init.run(argc, argv); }
    if (str_equals(command, "help"))  { ret cmd_help.run(argc, argv); }

    print.eprintlnf("error: unknown command '%s'", command);
    cmd_help.run(argc, argv);
    ret 1;
}
