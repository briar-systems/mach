use        std.runtime;
use print: std.print;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    var a: i64 = 10;
    var b: i64 = 20;

    # Test Addition
    var c: i64 = a + b;
    if (c != 30) {
        # print.println("Add failed");
        ret 1;
    }

    # Test Subtraction
    var d: i64 = b - a;
    if (d != 10) {
        # print.println("Sub failed");
        ret 1;
    }

    # Test Multiplication
    var e: i64 = a * b;
    if (e != 200) {
        # print.println("Mul failed");
        ret 1;
    }

    # Test Division (Signed)
    var f: i64 = b / a;
    if (f != 2) {
        # print.println("Div failed");
        ret 1;
    }

    # Test Remainder
    var g: i64 = 21 % 10;
    if (g != 1) {
        # print.println("Rem failed");
        ret 1;
    }

    # Test Shift Left
    var h: i64 = 1 << 4;
    if (h != 16) {
        # print.println("Shl failed");
        ret 1;
    }

    # Test Shift Right
    var i: i64 = 16 >> 2;
    if (i != 4) {
        # print.println("Shr failed");
        ret 1;
    }

    # Test Float Addition
    var fa: f64 = 1.5;
    var fb: f64 = 2.5;
    var fc: f64 = fa + fb;
    if (fc != 4.0) {
        # print.println("FAdd failed");
        ret fc::i64;
    }

    # Test Float Subtraction
    var fd: f64 = fb - fa;
    if (fd != 1.0) {
        # print.println("FSub failed");
        ret 3;
    }

    # Test Float Multiplication
    var fe: f64 = fa * 2.0;
    if (fe != 3.0) {
        # print.println("FMul failed");
        ret 4;
    }

    # Test Float Division
    var ff: f64 = 5.0 / 2.0;
    if (ff != 2.5) {
        # print.println("FDiv failed");
        ret 5;
    }

    # print.println("All arithmetic tests passed!");
    ret 0;
}
