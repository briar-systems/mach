# Hello World and Fibonacci Example

val msg: *u8 = "Hello, World!\n";
val fib_msg: *u8 = "Fibonacci(20) = ";
val newline: *u8 = "\n";

fun print(fd: i64, text: *u8, len: i64) {
    mir {
        syscall(1, %0, %1, %2)
    }
}

fun print_int(n: i64) {
    # Copy n to local variable to preserve it across recursive call
    # (Compiler bug: parameters in caller-saved regs are clobbered)
    var local_n: i64 = n;

    # Handle negative numbers
    if (local_n < 0) {
        print(1, "-", 1);
        local_n = 0 - local_n;
    }
    
    # Recursive call for multi-digit numbers
    if (local_n > 9) {
        print_int(local_n / 10);
    }
    
    # Convert digit to ASCII character (0-9 -> 48-57)
    # We need to be careful with types here
    var d: i64 = local_n % 10;
    var digit: u8 = (d + 48) :: u8;
    
    # Print the single character
    print(1, ?digit, 1);
}

fun fib(n: i64) i64 {
    if (n <= 1) {
        ret n;
    }
    # Use local variables to preserve values across calls
    var a: i64 = fib(n - 1);
    var b: i64 = fib(n - 2);
    ret a + b;
}

pub fun _start() {
    # Print greeting
    print(1, msg, 14);
    
    # Calculate and print Fibonacci result
    print(1, fib_msg, 16);
    var result: i64 = fib(20);
    print_int(result);
    print(1, newline, 1);
    
    # Exit
    mir {
        syscall(60, 0)
    }
}

$_start.name = "_start";
