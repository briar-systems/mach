use std.runtime;
use memory: std.memory;
use std.types.size;
use std.types.option;

fun write_buf(ptr: &u8, len: usize) {
    masm {
        # sysv: ptr in rdi, len in rsi
        # linux syscall: fd in rdi, buf in rsi, count in rdx
        mov rdx, rsi
        mov rsi, rdi
        mov rdi, 1    # stdout
        mov rax, 1    # sys_write
        syscall
    }
}

fun write_newline() {
    write_buf("\n", 1::usize);
}

fun write_str(s: &u8) {
    # c-string write
    if (s == nil) { ret; }
    var i: usize = 0;
    for {
        if (s[i] == 0) { brk; }
        i = i + 1;
    }
    write_buf(s, i);
}

fun write_u64(n: u64) {
    var buf: [32]u8;
    var idx: usize = 32;
    var x:   u64 = n;
    var len: usize = 0;

    if (x == 0) {
        idx = idx - 1;
        buf[idx] = 48; # '0'
        len = 1;
    } or {
        for (x > 0) {
            var digit: u8 = (x % 10)::u8 + 48;
            x = x / 10;
            idx = idx - 1;
            buf[idx] = digit;
            len = len + 1;
        }
    }

    var start: *u8 = ?buf[idx];
    write_buf(start, len);
}

fun parse_u64(ptr: &u8) u64 {
    if (ptr == nil) { ret 0; }
    var i: i64 = 0;
    var v: u64 = 0;

    for {
        var ch: u8 = ptr[i];
        if (ch == 0) { brk; }
        if (ch < 48) { brk; }
        if (ch > 57) { brk; }
        v = v * 10 + (ch - 48)::u64;
        i = i + 1;
    }

    ret v;
}

fun fib(n: u64) u64 {
    if (n < 2) { ret n; }

    var a: u64 = 0;
    var b: u64 = 1;
    var i: u64 = 1;

    for (i < n) {
        var tmp: u64 = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }

    ret b;
}

fun memory_smoke_test() bool {
    write_str("== std.memory smoke test ==\n");

    val count0: usize = 64;
    val a0: Option[*u8] = memory.allocate[u8](count0);
    if (a0.is_none()) {
        write_str("alloc 64 bytes: failed\n");
        ret false;
    }

    var p: *u8 = a0.unwrap();
    write_str("alloc 64 bytes: ok (ptr=");
    write_u64(p::usize::u64);
    write_str(")\n");

    # fill with a pattern and checksum
    var i: usize = 0;
    var sum: u64 = 0;
    for (i < count0) {
        p[i] = (i & 0xff)::u8;
        sum = sum + p[i]::u64;
        i = i + 1;
    }

    write_str("pattern checksum: ");
    write_u64(sum);
    write_newline();

    # realloc to a bigger buffer
    val count1: usize = 128;
    val a1: Option[*u8] = memory.reallocate[u8](p, count0, count1);
    if (a1.is_none()) {
        write_str("realloc 64 -> 128 bytes: failed\n");
        val ok0: bool = memory.deallocate[u8](p, count0);
        ret false;
    }

    p = a1.unwrap();
    write_str("realloc 64 -> 128 bytes: ok (ptr=");
    write_u64(p::usize::u64);
    write_str(")\n");

    # ensure the original pattern is still present in the first 64 bytes
    i = 0;
    for (i < count0) {
        if (p[i] != (i & 0xff)::u8) {
            write_str("pattern check: failed\n");
            val ok1: bool = memory.deallocate[u8](p, count1);
            ret false;
        }
        i = i + 1;
    }
    write_str("pattern check: ok\n");

    val ok2: bool = memory.deallocate[u8](p, count1);
    if (!ok2) {
        write_str("free: failed\n");
        ret false;
    }

    write_str("free: ok\n");
    write_newline();
    ret true;
}

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val ok: bool = memory_smoke_test();
    if (!ok) { ret 1; }

    var n: u64 = 10;
    if (argc > 1) {
        n = parse_u64(argv[1]);
    }

    var result: u64 = fib(n);
    write_buf("fib ", 4::usize);
    write_u64(n);
    write_buf(" -> ", 4::usize);
    write_u64(result);
    write_newline();

    ret 0;
}
