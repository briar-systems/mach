use std.io.console;
use std.io.fs;
use std.text.ascii;
use std.text.parse;
use std.system.memory;
use std.system.time;
use std.types.string;

fun sum_variadic(base: i64, ...) i64 {
    var total: i64 = base;
    val extra: u64 = va_count();
    var idx: u64 = 0;
    for (idx < extra) {
        val value_ptr: *i64 = va_arg(idx)::*i64;
        total = total + @value_ptr;
        idx = idx + (1::u64);
    }
    ret total;
}

fun avg_variadic(first: f64, ...) f64 {
    var total: f64 = first;
    val extra: u64 = va_count();
    var idx: u64 = 0;
    for (idx < extra) {
        val value_ptr: *f64 = va_arg(idx)::*f64;
        total = total + @value_ptr;
        idx = idx + (1::u64);
    }
    val count: f64 = (extra::f64) + 1.0;
    ret total / count;
}

fun test_variadics() {
    val total: i64 = sum_variadic(10::i64, 20::i64, 30::i64, 40::i64);
    if (total == 100) { print("variadic sum ok\n"); }
    or { print("variadic sum fail\n"); }

    val empty: i64 = sum_variadic(5::i64);
    if (empty == 5) { print("variadic zero ok\n"); }
    or              { print("variadic zero fail\n"); }

    val avg: f64 = avg_variadic(2.0, 4.0, 6.0, 8.0);
    if ((avg > 4.9) && (avg < 5.1)) { print("variadic avg ok\n"); }
    or                              { print("variadic avg fail\n"); }

    ret;
}

fun smoke_stdin() {
    val prompt: string = "stdin smoke > ";
    print(prompt);

    val size: u64 = 128;
    val buffer: *u8 = allocate(size);
    if (buffer == nil) {
        print("stdin smoke skipped alloc fail\n");
        ret;
    }

    memory_zero(buffer, size);

    val got: i64 = read_stdin(buffer, size - 1);
    if (got <= 0) {
        print("stdin smoke no input\n");
        deallocate(buffer, size);
        ret;
    }

    val captured: string = []u8{ buffer, got };

    val summary: string = format("stdin smoke got %u bytes: %s\n", captured.length, captured);
    print(summary);
    string_free(summary);

    deallocate(buffer, size);
    ret;
}

fun main() i32 {
    print("hello, world\n");

    test_variadics();

    smoke_stdin();

    # time smoke
    val ns: u64 = now();
    if (ns == 0) {print("time.now returned 0 (ok on unsupported)\n"); }

    print("after variadics\n");

    # ascii/parse
    val d: i32 = digit_val('A');
    if (d < 10) { print("ascii/digit ok\n"); }
    val dec: u64 = parse_u64_dec("12345");
    val hex: u64 = parse_u64_hex("1a2b");
    if (dec > 0 && hex > 0) {
        val summary: string = format("parse ok dec=%u hex=%x\n", dec, hex);
        print("got summary\n");
        print(summary);
        string_free(summary);
        print("freed summary\n");
    }

    # fs roundtrip
    val data: []u8 = "hi";
    fs_write_all("/tmp/mach_std_test.txt", data);
    
    val rd: []u8 = fs_read_all("/tmp/mach_std_test.txt");
    if (rd.length == 2) {
    val tag: string = "read/write";
    val note: string = format("fs ok (%s)\n", tag);
    print(note);
    string_free(note);
    }

    ret 0;
}
