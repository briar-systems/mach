# mach.main: program entry point.
#
# linked under the symbol `main` and forwards the raw argument vector
# straight to the CLI dispatcher, returning its exit code.

use std.runtime;
use std.types.size.usize;

use cmd: mach.cli.cmd;

# main: process entry; dispatch the CLI invocation.
# ---
# argc: argument count including argv[0]
# argv: the argument vector (argc null-terminated byte pointers)
# ret:  the process exit code from the dispatched subcommand
$main.symbol = "main";
fun main(argc: usize, argv: **u8) i64 {
    ret cmd.dispatch(argc, argv);
}
