use mach.runtime;

fun write_buf(ptr: *u8, len: i64) {
    masm {
        mov rax, 1    # sys_write
        mov rdi, 1    # stdout
        mov rsi, ptr
        mov rdx, len
        syscall
    }
}

fun write_newline() {
    write_buf("\n", 1i64);
}

fun write_u64(n: u64) {
    var buf: [32]u8;
    var idx: i64 = 32i64;
    var x: u64 = n;
    var len: i64 = 0i64;

    if (x == 0u64) {
        idx = idx - 1i64;
        buf[idx] = 48u8; # '0'
        len = 1i64;
    } or {
        for (x > 0u64) {
            var digit: u8 = (x % 10u64)::u8 + 48u8;
            x = x / 10u64;
            idx = idx - 1i64;
            buf[idx] = digit;
            len = len + 1i64;
        }
    }

    var start: *u8 = ?buf[idx];
    write_buf(start, len);
}

fun parse_u64(ptr: *u8) u64 {
    if (ptr == nil) { ret 0u64; }
    var i: i64 = 0i64;
    var v: u64 = 0u64;

    for {
        var ch: u8 = ptr[i];
        if (ch == 0u8) { brk; }
        if (ch < 48u8) { brk; }
        if (ch > 57u8) { brk; }
        v = v * 10u64 + (ch - 48u8)::u64;
        i = i + 1i64;
    }

    ret v;
}

fun fib(n: u64) u64 {
    if (n < 2u64) { ret n; }

    var a: u64 = 0u64;
    var b: u64 = 1u64;
    var i: u64 = 1u64;

    for (i < n) {
        var tmp: u64 = a + b;
        a = b;
        b = tmp;
        i = i + 1u64;
    }

    ret b;
}

fun main(argc: i64, argv: **u8) i64 {
    var n: u64 = 10u64;
    if (argc > 1i64) {
        n = parse_u64(argv[1i64]);
    }

    var result: u64 = fib(n);
    write_buf("fib ", 4i64);
    write_u64(n);
    write_buf(" -> ", 4i64);
    write_u64(result);
    write_newline();

    ret 0i64;
}
