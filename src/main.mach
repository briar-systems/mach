use mach.runtime;

fun write_buf(ptr: *u8, len: i64) {
    masm {
        mov rax, 1    # sys_write
        mov rdi, 1    # stdout
        mov rsi, ptr
        mov rdx, len
        syscall
    }
}

fun write_newline() {
    write_buf("\n", 1i64);
}

fun write_u64(n: u64) {
    var buf: [32]u8;
    var idx: i64 = 32i64;
    var x: u64 = n;

    if (x == 0u64) {
        idx = idx - 1i64;
        buf[idx] = 48u8; # '0'
    } or {
        for (x > 0u64) {
            var digit: u8 = (x % 10u64)::u8 + 48u8;
            x = x / 10u64;
            idx = idx - 1i64;
            buf[idx] = digit;
        }
    }

    var len: i64 = 32i64 - idx;
    var start: *u8 = ?buf[idx];
    write_buf(start, len);
}

fun parse_u64(ptr: *u8) u64 {
    if (ptr == nil) { ret 0u64; }
    var i: i64 = 0i64;
    var v: u64 = 0u64;

    for {
        var ch: u8 = ptr[i];
        if (ch == 0u8) { brk; }
        if (ch < 48u8) { brk; }
        if (ch > 57u8) { brk; }
        v = v * 10u64 + (ch - 48u8)::u64;
        i = i + 1i64;
    }

    ret v;
}

fun main(argc: i64, argv: **u8) i64 {
    write_buf("start\n", 6i64);
    ret 0i64;
}
