use         std.runtime;
use         std.types.bool;
use         std.types.size;
use         std.types.option;
use int:    std.types.int;
use memory: std.memory;
use ascii:  std.text.ascii;
use         std.types.result;
use stream: std.stream;
use fmt:    std.fmt;
use print:  std.print;
use stdio:  std.system.stdio;

fun to_i64(r: Result[usize, stream.Error]) i64 {
    if (r.is_err()) { ret r.unwrap_err(); }
    ret r.unwrap_ok()::i64;
}

fun write_buf(buf: &u8, len: usize) i64 {
    var w: stream.Writer = stdio.stdout();
    ret to_i64(fmt.write_bytes(?w, buf, len));
}

fun write_newline() i64 {
    var w: stream.Writer = stdio.stdout();
    ret to_i64(fmt.write_newline(?w));
}

fun write_str(s: &u8) i64 {
    var w: stream.Writer = stdio.stdout();
    ret to_i64(fmt.write_str(?w, s));
}

fun write_u64(n: u64) i64 {
    var w: stream.Writer = stdio.stdout();
    ret to_i64(fmt.write_u64(?w, n));
}

fun parse_u64(ptr: &u8) u64 {
    if (ptr == nil) { ret 0::u64; }
    var i: usize = 0;
    var v: u64 = 0;

    for {
        var ch: u8 = ptr[i];
        if (ch == 0) { brk; }
        if (ch < 48) { brk; }
        if (ch > 57) { brk; }
        v = v * 10 + int.zext_u8_to_u64(ch - 48);
        i = i + 1;
    }

    ret v;
}

fun fib(n: u64) u64 {
    if (n < 2) { ret n; }

    var a: u64 = 0;
    var b: u64 = 1;
    var i: u64 = 1;

    for (i < n) {
        var tmp: u64 = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }

    ret b;
}

fun abi_sum_regs(a: u8, b: u8, c: u8, d: u8, e: u8, f: u8) u64 {
    ret int.zext_u8_to_u64(a) + int.zext_u8_to_u64(b) + int.zext_u8_to_u64(c) + int.zext_u8_to_u64(d) + int.zext_u8_to_u64(e) + int.zext_u8_to_u64(f);
}

fun memory_smoke_test() bool {
    write_str("== std.memory smoke test ==\n");

    val count0: usize = 64;
    val a0: Option[*u8] = memory.allocate[u8](count0);
    if (a0.is_none()) {
        write_str("alloc 64 bytes: failed\n");
        ret false;
    }

    var p: *u8 = a0.unwrap();
    write_str("alloc 64 bytes: ok (ptr=");
    write_u64(p::usize::u64);
    write_str(")\n");

    # fill with a pattern and checksum
    var i: usize = 0;
    var sum: u64 = 0;
    for (i < count0) {
        p[i] = int.trunc_usize_to_u8(i & 0xff);
        sum = sum + int.zext_u8_to_u64(p[i]);
        i = i + 1;
    }

    write_str("pattern checksum: ");
    write_u64(sum);
    write_newline();

    # realloc to a bigger buffer
    val count1: usize = 128;
    val a1: Option[*u8] = memory.reallocate[u8](p, count0, count1);
    if (a1.is_none()) {
        write_str("realloc 64 -> 128 bytes: failed\n");
        val ok0: bool = memory.deallocate[u8](p, count0);
        ret false;
    }

    p = a1.unwrap();
    write_str("realloc 64 -> 128 bytes: ok (ptr=");
    write_u64(p::usize::u64);
    write_str(")\n");

    # ensure the original pattern is still present in the first 64 bytes
    i = 0;
    for (i < count0) {
        if (p[i] != int.trunc_usize_to_u8(i & 0xff)) {
            write_str("pattern check: failed\n");
            val ok1: bool = memory.deallocate[u8](p, count1);
            ret false;
        }
        i = i + 1;
    }
    write_str("pattern check: ok\n");

    val ok2: bool = memory.deallocate[u8](p, count1);
    if (!ok2) {
        write_str("free: failed\n");
        ret false;
    }

    write_str("free: ok\n");
    write_newline();
    ret true;
}

fun operator_smoke_test() bool {
    write_str("== operators smoke test ==\n");

    val lo: u8 = ascii.to_lower('A');
    if (lo != 'a') {
        write_str("ascii.to_lower: failed (got='");
        write_buf(?lo, 1::usize);
        write_str("')\n");

        val c0: u8 = 'A';
        val c1: u8 = 65u8;
        val cond0: u8 = (c0 >= 'A' && c0 <= 'Z');
        val sh0: u8 = cond0 << 5u8;
        val manual0: u8 = c0 | sh0;
        write_str("manual to_lower('A'): got='");
        write_buf(?manual0, 1::usize);
        write_str("' (c0='");
        write_buf(?c0, 1::usize);
        write_str("', c1='");
        write_buf(?c1, 1::usize);
        write_str("')\n");
        ret false;
    }

    val up: u8 = ascii.to_upper('z');
    if (up != 'Z') {
        write_str("ascii.to_upper: failed\n");
        ret false;
    }

    val shl0: u8 = 1u8 << 5u8;
    if (shl0 != 32u8) {
        write_str("shl: failed\n");
        ret false;
    }

    val shr0: u8 = shl0 >> 4u8;
    if (shr0 != 2u8) {
        write_str("shr: failed\n");
        ret false;
    }

    val not0: u8 = ~1u8;
    if (not0 != 254u8) {
        write_str("bitwise not: failed\n");
        ret false;
    }

    val xor0: u8 = 15u8 ^ 240u8;
    if (xor0 != 255u8) {
        write_str("xor: failed\n");
        ret false;
    }

    write_str("operators: ok\n");
    write_newline();
    ret true;
}

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val ok: bool = memory_smoke_test();
    if (!ok) { ret 1; }

    # exercise std.print
    print.println("std.print: ok");

    val ok_ops: bool = operator_smoke_test();
    if (!ok_ops) { ret 1; }

    # ABI smoke test (sum bytes passed in SysV int registers)
    val abi_res: u64 = abi_sum_regs(1::u8, 2::u8, 3::u8, 4::u8, 5::u8, 6::u8);
    write_str("== abi-smoke ==\n");
    if (abi_res != 21) {
        write_str("abi-smoke: failed (got=");
        write_u64(abi_res);
        write_str(")\n");
    } or {
        write_str("abi-smoke: ok\n");
    }



    var n: u64 = 10;
    if (argc > 1) {
        n = parse_u64(argv[1]);
    }

    var result: u64 = fib(n);
    write_buf("fib ", 4::usize);
    write_u64(n);
    write_buf(" -> ", 4::usize);
    write_u64(result);
    write_newline();

    ret 0;
}
