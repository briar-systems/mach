# Hello World and Fibonacci Example
use mach.types;

val msg: str = "Hello, World!\n";
val fib_msg: str = "Fibonacci(20) = ";
val newline: str = "\n";

fun print_int(n: i64) {
    # Copy n to local variable to preserve it across recursive call
    var local_n: i64 = n;

    # Handle negative numbers
    if (local_n < 0) {
        sys_write(1, "-", 1);
        local_n = 0 - local_n;
    }
    
    # Recursive call for multi-digit numbers
    if (local_n > 9) {
        print_int(local_n / 10);
    }
    
    # Convert digit to ASCII character (0-9 -> 48-57)
    var d: i64 = local_n % 10;
    var digit: u8 = (d + 48) :: u8;
    
    # Print the single character
    sys_write(1, ?digit, 1);
}

fun fib(n: i64) i64 {
    if (n <= 1) {
        ret n;
    }
    # Use local variables to preserve values across calls
    var a: i64 = fib(n - 1);
    var b: i64 = fib(n - 2);
    ret a + b;
}

pub fun _start() {
    # Print greeting using imported function
    sys_write(1, msg, 14);
    
    # Calculate and print Fibonacci result
    sys_write(1, fib_msg, 16);
    var result: i64 = fib(20);
    print_int(result);
    sys_write(1, newline, 1);
    
    # Exit
    mir {
        syscall(60, 0)
    }
}

$_start.name = "_start";
