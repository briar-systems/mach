# mach compiler entry point
# ---
# initializes the process environment, then delegates to cli.run
# for command parsing and dispatch.

use std.runtime;
use std.types.size;
use std.types.string;

use print: std.print;

use cmd_build: mach.commands.build;
use cmd_run:   mach.commands.run;
use cmd_init:  mach.commands.init;
use cmd_test:  mach.commands.testing;
use cmd_dep:   mach.commands.dep;
use cmd_help:  mach.commands.help;

use proc: mach.util.process;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    proc.init_env(argc, argv);

    # no args, print help and exit
    if (argc < 2) {
        cmd_help.print_general();
        ret 1;
    }

    val command: str = argv[1];

    if (str_equals(command, "init"))  { ret cmd_init.handle(argc, argv); }
    if (str_equals(command, "build")) { ret cmd_build.handle(argc, argv); }
    if (str_equals(command, "run"))   { ret cmd_run.handle(argc, argv); }
    if (str_equals(command, "test"))  { ret cmd_test.handle(argc, argv); }
    if (str_equals(command, "dep"))   { ret cmd_dep.handle(argc, argv); }
    if (str_equals(command, "help"))  { ret cmd_help.handle(argc, argv); }

    # unknown command, print error and help
    print.eprintlnf("error: unknown command '%s'", command);
    cmd_help.print_general();
    ret 1;
}
