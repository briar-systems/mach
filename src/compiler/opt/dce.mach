# mach.compiler.opt.dce: dead code elimination
#
# removes instructions that produce values never consumed by any other
# instruction. walks all blocks to build a use set, then marks producers
# whose destination vreg has zero uses as dead. dead instructions are
# replaced with no-op mov instructions (mov r0, r0, size=1) to avoid
# shifting indices in flat block arrays.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use op:      masm.op;
use inst:    masm.inst;
use masm_fn: masm.function;

val MAX_VREGS: i32 = 4096;

# run: eliminate dead code from a function
# ---
# alloc: backing allocator
# func:  function to optimize
# ret:   true if the pass succeeded
pub fun run(alloc: *allocator.Allocator, func: *masm_fn.Function) bool {
    if (func == nil) { ret true; }
    if (func.blocks.len == 0) { ret true; }

    val res_uses: Result[*i32, str] = allocator.allocate[i32](alloc, MAX_VREGS::usize);
    if (!res_uses.tag) { ret true; }
    val uses: *i32 = res_uses.value.ok;

    var vi: i32 = 0;
    for (vi < MAX_VREGS) {
        uses[vi] = 0;
        vi = vi + 1;
    }

    # pass 1: count uses of each vreg across all blocks
    var bi: usize = 0;
    for (bi < func.blocks.len) {
        val blk: *masm_fn.Block = func.blocks.data[bi];
        if (blk == nil) {
            bi = bi + 1;
            cnt;
        }

        var ii: i32 = 0;
        for (ii < blk.inst_count) {
            val i: *inst.Instruction = ?blk.insts[ii];
            mark_uses(uses, i);
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    # pass 2: replace dead producers with nop
    bi = 0;
    for (bi < func.blocks.len) {
        val blk: *masm_fn.Block = func.blocks.data[bi];
        if (blk == nil) {
            bi = bi + 1;
            cnt;
        }

        var ii: i32 = 0;
        for (ii < blk.inst_count) {
            val i: *inst.Instruction = ?blk.insts[ii];
            if (is_dead_producer(uses, i)) {
                @i = inst.make_mov_reg(0, 0, 1);
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    allocator.deallocate[i32](alloc, uses, MAX_VREGS::usize);
    ret true;
}

fun mark_uses(uses: *i32, i: *inst.Instruction) {
    val o: u8 = i.op;

    if (is_src1_reg(o)) {
        val r1: i32 = i.f1::i32;
        if (r1 >= inst.VREG_START && r1 < MAX_VREGS) {
            uses[r1] = uses[r1] + 1;
        }
    }

    if (is_src2_reg(o, i.meta)) {
        val r2: i32 = i.f2::i32;
        if (r2 >= inst.VREG_START && r2 < MAX_VREGS) {
            uses[r2] = uses[r2] + 1;
        }
    }

    if (is_f0_source(o)) {
        val r0: i32 = i.f0::i32;
        if (r0 >= inst.VREG_START && r0 < MAX_VREGS) {
            uses[r0] = uses[r0] + 1;
        }
    }
}

fun is_dead_producer(uses: *i32, i: *inst.Instruction) bool {
    val o: u8 = i.op;
    if (!produces_value(o)) { ret false; }
    # never eliminate calls — they have side effects
    if (o == op.OP_CALL) { ret false; }
    if (o == op.OP_ATOMIC_LOAD) { ret false; }
    if (o == op.OP_ATOMIC_CAS) { ret false; }
    if (o == op.OP_ATOMIC_RMW) { ret false; }

    val dst: i32 = i.f0::i32;
    if (dst < inst.VREG_START || dst >= MAX_VREGS) { ret false; }
    ret uses[dst] == 0;
}

fun is_src1_reg(o: u8) bool {
    if (o == op.OP_LOAD)    { ret true; }
    if (o == op.OP_STORE)   { ret true; }
    if (o == op.OP_ADDR)    { ret true; }
    if (o == op.OP_ADD)     { ret true; }
    if (o == op.OP_SUB)     { ret true; }
    if (o == op.OP_MUL)     { ret true; }
    if (o == op.OP_DIV)     { ret true; }
    if (o == op.OP_AND)     { ret true; }
    if (o == op.OP_OR)      { ret true; }
    if (o == op.OP_XOR)     { ret true; }
    if (o == op.OP_SHL)     { ret true; }
    if (o == op.OP_SHR)     { ret true; }
    if (o == op.OP_CMP)     { ret true; }
    if (o == op.OP_MOVE)     { ret true; }
    if (o == op.OP_CONV)    { ret true; }
    if (o == op.OP_CALL)    { ret true; }
    if (o == op.OP_ARG)     { ret true; }
    if (o == op.OP_ATOMIC_LOAD)  { ret true; }
    if (o == op.OP_ATOMIC_STORE) { ret true; }
    if (o == op.OP_ATOMIC_CAS)   { ret true; }
    if (o == op.OP_ATOMIC_RMW)   { ret true; }
    ret false;
}

fun is_src2_reg(o: u8, meta: u8) bool {
    val flg: u8 = meta & 1;
    if (o >= op.OP_ADD && o <= op.OP_SHR) {
        ret flg == 0;
    }
    if (o == op.OP_CMP) { ret true; }
    if (o == op.OP_DIV) { ret true; }
    ret false;
}

fun is_f0_source(o: u8) bool {
    if (o == op.OP_STORE)        { ret true; }
    if (o == op.OP_ATOMIC_STORE) { ret true; }
    if (o == op.OP_BRANCH)       { ret true; }
    if (o == op.OP_RET)          { ret true; }
    ret false;
}

fun produces_value(o: u8) bool {
    if (o == op.OP_MOVE)   { ret true; }
    if (o == op.OP_LOAD)  { ret true; }
    if (o == op.OP_ADDR)  { ret true; }
    if (o == op.OP_ADD)   { ret true; }
    if (o == op.OP_SUB)   { ret true; }
    if (o == op.OP_MUL)   { ret true; }
    if (o == op.OP_DIV)   { ret true; }
    if (o == op.OP_AND)   { ret true; }
    if (o == op.OP_OR)    { ret true; }
    if (o == op.OP_XOR)   { ret true; }
    if (o == op.OP_SHL)   { ret true; }
    if (o == op.OP_SHR)   { ret true; }
    if (o == op.OP_CMP)   { ret true; }
    if (o == op.OP_CONV)  { ret true; }
    if (o == op.OP_CALL)  { ret true; }
    if (o == op.OP_ATOMIC_LOAD)  { ret true; }
    if (o == op.OP_ATOMIC_CAS)   { ret true; }
    if (o == op.OP_ATOMIC_RMW)   { ret true; }
    ret false;
}
