# compiler.opt.pass: optimization pass interface and pipeline
#
# provides a generic pipeline for running named optimization passes on MASM IR
# functions. passes are registered as function pointers and executed in order.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use masm_fn:   masm.function;

use dce_mod:       compiler.opt.dce;
use constfold_mod: compiler.opt.constfold;

pub def PassFn: fun(&allocator.Allocator, *masm_fn.Function) bool;

# a single named optimization pass
# ---
# name: human-readable name for diagnostics
# run:  pass entry point
pub rec PassDesc {
    name: str;
    run:  PassFn;
}

# ordered sequence of optimization passes
# ---
# alloc:  backing allocator
# passes: array of pass descriptors
# count:  number of registered passes
# cap:    allocated capacity
pub rec PassPipeline {
    alloc:  &allocator.Allocator;
    passes: *PassDesc;
    count:  u32;
    cap:    u32;
}

val INITIAL_CAP: u32 = 4;

# init: create an empty pass pipeline.
# ---
# alloc: allocator for internal storage
# ret:   initialized pipeline
pub fun init(alloc: &allocator.Allocator) PassPipeline {
    var p: PassPipeline;
    p.alloc  = alloc;
    p.passes = nil;
    p.count  = 0;
    p.cap    = 0;
    ret p;
}

# add: append a pass to the pipeline, growing the array if needed.
# ---
# p:    pipeline to add to
# name: pass name
# run:  pass function pointer
pub fun add(p: *PassPipeline, name: str, run: PassFn) {
    if (p == nil) { ret; }

    if (p.count >= p.cap) {
        var new_cap: u32 = INITIAL_CAP;
        if (p.cap > 0) {
            new_cap = p.cap * 2;
        }

        val res_reallocate: Result[*PassDesc, str] = allocator.reallocate[PassDesc](
            p.alloc, p.passes, p.cap::usize, new_cap::usize
        );
        if (is_err[*PassDesc, str](res_reallocate)) { ret; }
        p.passes = unwrap_ok[*PassDesc, str](res_reallocate);
        p.cap = new_cap;
    }

    p.passes[p.count].name = name;
    p.passes[p.count].run  = run;
    p.count = p.count + 1;
}

# run: run all passes in order on a function.
#
# stops early and returns false if any pass fails.
# ---
# p:    pipeline to execute
# func: function to optimize
# ret:  true if all passes succeeded
pub fun run(p: &PassPipeline, func: *masm_fn.Function) bool {
    if (p == nil || func == nil) { ret true; }
    if (p.passes == nil || p.count == 0) { ret true; }

    var i: u32 = 0;
    for (i < p.count) {
        val pass_fn: PassFn = p.passes[i].run;
        if (pass_fn != nil) {
            if (!pass_fn(p.alloc, func)) {
                ret false;
            }
        }
        i = i + 1;
    }

    ret true;
}

# dnit: free the passes array.
# ---
# p: pipeline to destroy
pub fun dnit(p: *PassPipeline) {
    if (p == nil) { ret; }
    if (p.passes != nil && p.cap > 0) {
        allocator.deallocate[PassDesc](p.alloc, p.passes, p.cap::usize);
        p.passes = nil;
    }
    p.count = 0;
    p.cap   = 0;
}

# default_pipeline: build a default pipeline for the given optimization level.
#
# opt_level 0 returns an empty pipeline. opt_level >= 1 includes DCE and
# constant folding.
# ---
# alloc:     allocator for pipeline storage
# opt_level: optimization level (0-3)
# ret:       configured pipeline
pub fun default_pipeline(alloc: &allocator.Allocator, opt_level: u8) PassPipeline {
    var p: PassPipeline = init(alloc);

    if (opt_level >= 1) {
        add(?p, "dce", dce_mod.run);
        add(?p, "constfold", constfold_mod.run);
    }

    ret p;
}
