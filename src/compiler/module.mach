use std.types.list;
use std.types.size;
use std.types.option;
use std.types.result;
use std.types.string;

use std.lang.frontend.lexical.tokens;
use std.lang.frontend.syntax.ast;

use mem: std.system.memory;

val MODULE_IMPORT_EXTRACT_INITIAL_CAP: usize = 4;

## Represents a module in the Mach programming language.
pub rec Module {
    id:     String;
    path:   String;
    source: String;

    tokens: Option[List[Token]]; ## token list after lexical analysis
    ast:    Option[AST];         ## AST after syntax analysis
}

## Initializes a Module record.
##
## id:     fully qualified module ID (e.g "std.types.bool")
## path:   filesystem path to module root
## source: source code of the module
## ret:    optional error message
pub fun (this: *Module) init(id: str, path: str, source: str) Option[str] {
    mem.zero[Module](this, 1);

    val res_clone_id: Result[String, str] = id.clone();
    if (res_clone_id.is_err()) {
        ret some[str]("failed to clone module ID");
    }
    this.id = res_clone_id.unwrap_ok();

    val res_clone_path: Result[String, str] = path.clone();
    if (res_clone_path.is_err()) {
        this.id.dnit();
        ret some[str]("failed to clone module path");
    }
    this.path = res_clone_path.unwrap_ok();

    val res_clone_source: Result[String, str] = source.clone();
    if (res_clone_source.is_err()) {
        this.path.dnit();
        this.id.dnit();
        ret some[str]("failed to clone module source");
    }
    this.source = res_clone_source.unwrap_ok();

    this.tokens = none[List[Token]]();
    this.ast    = none[AST]();

    ret none[str]();
}

## Deinitializes a Module record.
pub fun (this: *Module) dnit() {
    this.id.dnit();
    this.path.dnit();
    this.source.dnit();

    if (this.tokens.is_some()) {
        var tokens: List[Token] = this.tokens.unwrap();
        tokens.dnit();
        this.tokens = none[List[Token]]();
    }

    if (this.ast.is_some()) {
        var ast: AST = this.ast.unwrap();
        ast.dnit();
        this.ast = none[AST]();
    }

    mem.zero[Module](this, 1);
}

## Extract a module's `use` statements from its AST.
## Only available if the module has been successfully parsed.
##
## ret: list of module paths or an error message
pub fun (this: *Module) extract_imports() Result[List[str], str] {
    if (this.ast.is_none()) {
        ret err[List[str], str]("AST is not available");
    }

    var imports:  List[str];
    val opt_init: Option[str] = imports.init(MODULE_IMPORT_EXTRACT_INITIAL_CAP);
    if (opt_init.is_some()) {
        ret err[List[str], str]("failed to initialize imports list");
    }

    # find all `use` nodes in the AST
    var opt_find: Option[List[*Node]] = this.ast.unwrap().find(NODE_USE);
    if (opt_find.is_none()) {
        # NOT a failure -- modules may not have any imports
        ret ok[List[str], str](imports);
    }

    var use_nodes: List[*Node] = opt_find.unwrap();

    # iterate over use nodes and extract paths
    var i: usize = 0;
    for (i < use_nodes.len) {
        val opt_node: Option[*Node] = use_nodes.get(i);
        if (opt_node.is_none()) {
            imports.dnit();
            use_nodes.dnit();
            ret err[List[str], str]("failed to get use node from list");
        }
        
        val use_node: *Node = opt_node.unwrap();

        val opt_push: Option[str] = imports.push(use_node.data.decl_use.path);
        if (opt_push.is_some()) {
            imports.dnit();
            use_nodes.dnit();
            ret err[List[str], str]("failed to push module import to list");
        }
        i = i + 1;
    }

    use_nodes.dnit();

    ret ok[List[str], str](imports);
}
