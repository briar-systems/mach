use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use ir:        mach.compiler.masm.ir;
use section:   mach.compiler.masm.section;

# mach.compiler.isa: instruction set architecture interface.
# ---
# abstracts all ISA-specific operations behind function pointers.
# consumers interact with ISA only through this interface —
# no ISA-specific types leak to the rest of the compiler.
#
# the Target composition root selects the ISA implementation
# and passes it to pipeline stages that need it.

# RegClass: category of hardware register.
pub def RegClass: u8;

pub val REG_GP:  RegClass = 0;   # general purpose
pub val REG_FP:  RegClass = 1;   # floating point / SSE
pub val REG_VEC: RegClass = 2;   # vector / SIMD

# Register: hardware register descriptor.
pub rec Register {
    id:    i32;       # register number (ISA-specific)
    name:  str;       # display name
    class: RegClass;  # register class
    width: u8;        # width in bytes (1, 2, 4, 8, 16)
}

# RegisterFile: an ordered set of registers.
pub rec RegisterFile {
    regs:  *Register;
    count: i32;
}

# MachInst: a single machine instruction.
# ---
# opcode and flags are ISA-specific. consumers do not interpret
# these fields — they pass MachInst through ISA interface functions.
# operands use the same representation as IR operands (reg/imm/mem/label).
pub rec MachInst {
    opcode: i32;
    dst:    ir.Operand;
    src1:   ir.Operand;
    src2:   ir.Operand;
    size:   u8;
    flags:  u32;
}

# MachInstBuf: growable buffer of machine instructions.
pub rec MachInstBuf {
    insts: *MachInst;
    count: i32;
    cap:   i32;
    alloc: *allocator.Allocator;
}

# AsmInst: a single IR instruction produced by inline asm parsing.
# ---
# ISA-specific asm parsers fill an AsmInstBuf with these.
# the lowering layer drains the buffer into its IR emitter.
pub rec AsmInst {
    op:   ir.Operator;
    dst:  ir.Operand;
    src1: ir.Operand;
    src2: ir.Operand;
    cc:   ir.Cond;
}

# AsmInstBuf: growable buffer of inline asm IR instructions.
pub rec AsmInstBuf {
    insts: *AsmInst;
    count: i32;
    cap:   i32;
    alloc: *allocator.Allocator;
}

val ASM_BUF_INITIAL_CAP: i32 = 32;

# asm_buf_create: allocate a new inline asm instruction buffer.
pub fun asm_buf_create(alloc: *allocator.Allocator) AsmInstBuf {
    var buf: AsmInstBuf;
    buf.insts = nil;
    buf.count = 0;
    buf.cap = 0;
    buf.alloc = alloc;
    ret buf;
}

# asm_buf_append: append an inline asm instruction to the buffer.
pub fun asm_buf_append(buf: *AsmInstBuf, op: ir.Operator, dst: ir.Operand,
                       src1: ir.Operand, src2: ir.Operand, cc: ir.Cond) bool {
    if (buf == nil || buf.alloc == nil) { ret false; }

    if (buf.count >= buf.cap) {
        var new_cap: i32 = ASM_BUF_INITIAL_CAP;
        if (buf.cap > 0) {
            new_cap = buf.cap * 2;
        }

        val r: Result[*AsmInst, allocator.AllocError] = allocator.allocator_resize[AsmInst](
            buf.alloc, buf.insts, buf.cap::usize, new_cap::usize
        );
        if (result_is_err[*AsmInst, allocator.AllocError](r)) {
            ret false;
        }

        buf.insts = result_unwrap_ok[*AsmInst, allocator.AllocError](r);
        buf.cap = new_cap;
    }

    buf.insts[buf.count].op = op;
    buf.insts[buf.count].dst = dst;
    buf.insts[buf.count].src1 = src1;
    buf.insts[buf.count].src2 = src2;
    buf.insts[buf.count].cc = cc;
    buf.count = buf.count + 1;
    ret true;
}

# asm_buf_clear: reset the buffer count without freeing memory.
pub fun asm_buf_clear(buf: *AsmInstBuf) {
    if (buf == nil) { ret; }
    buf.count = 0;
}

# asm_buf_destroy: free the buffer's instruction array.
pub fun asm_buf_destroy(buf: *AsmInstBuf) {
    if (buf == nil || buf.alloc == nil) { ret; }
    if (buf.insts != nil) {
        allocator.allocator_free[AsmInst](buf.alloc, buf.insts, buf.cap::usize);
    }
    buf.insts = nil;
    buf.count = 0;
    buf.cap = 0;
}

# ISA: instruction set architecture interface.
# ---
# function pointer record. each ISA implementation provides a
# constructor that populates all fields.
pub rec ISA {
    ctx: ptr;

    # --- register queries ---

    # all GP registers available on this ISA.
    gp_regs: fun(ptr) RegisterFile;

    # all FP registers available on this ISA.
    fp_regs: fun(ptr) RegisterFile;

    # --- instruction selection ---

    # select machine instruction(s) for an IR instruction.
    # appends results to `out`. returns true on success.
    isel: fun(ptr, *ir.Inst, *MachInstBuf) bool;

    # --- encoding ---

    # encode a machine instruction into a section.
    # returns number of bytes emitted, or -1 on error.
    encode: fun(ptr, *MachInst, *section.Section,
                *allocator.Allocator) i32;

    # encode a NOP sequence of exactly `size` bytes.
    # returns bytes emitted, or -1 on error.
    encode_nop: fun(ptr, i32, *section.Section,
                    *allocator.Allocator) i32;

    # --- optimization ---

    # ISA-specific peephole optimization on machine instruction buffer.
    peephole: fun(ptr, *MachInstBuf);

    # --- relocation ---

    # size in bytes of a relocation for a given abstract relocation type.
    reloc_size: fun(ptr, section.RelocKind) u8;

    # apply a resolved relocation: compute the patched value and write it.
    # rtype:      abstract relocation kind
    # sym_addr:   resolved virtual address of the target symbol
    # reloc_addr: virtual address of the relocation site
    # addend:     relocation addend
    # dest:       pointer into section data at the relocation offset
    # returns bytes written (0 on error).
    resolve_reloc: fun(ptr, section.RelocKind, u64, u64, i64, *u8) i32;

    # emit function prologue: save frame pointer, establish new frame,
    # allocate local stack space.
    # frame_size is the total bytes needed for locals (will be 16-byte aligned).
    prologue: fun(ptr, usize, *section.Section, *allocator.Allocator);

    # emit function epilogue: restore stack pointer from frame pointer,
    # restore saved frame pointer. called before each RET instruction.
    epilogue: fun(ptr, *section.Section, *allocator.Allocator);

    # --- inline asm support ---

    # parse an ISA-specific inline asm block and produce IR instructions.
    # content[start..end] is the text inside the ISA's { } block.
    # the ISA parses its own mnemonics, registers, and operand syntax,
    # appending target-independent IR instructions to buf.
    # alloc is for temporary allocations (e.g., label strings).
    lower_asm: fun(ptr, *AsmInstBuf, *allocator.Allocator, str, usize, usize);
}

# --- buffer operations ---

val BUF_INITIAL_CAP: i32 = 64;

# buf_create: allocate a new machine instruction buffer.
pub fun buf_create(alloc: *allocator.Allocator) MachInstBuf {
    var buf: MachInstBuf;
    buf.insts = nil;
    buf.count = 0;
    buf.cap = 0;
    buf.alloc = alloc;
    ret buf;
}

# buf_append: append a machine instruction to the buffer.
pub fun buf_append(buf: *MachInstBuf, inst: MachInst) bool {
    if (buf == nil || buf.alloc == nil) { ret false; }

    if (buf.count >= buf.cap) {
        var new_cap: i32 = BUF_INITIAL_CAP;
        if (buf.cap > 0) {
            new_cap = buf.cap * 2;
        }

        val r: Result[*MachInst, allocator.AllocError] = allocator.allocator_resize[MachInst](
            buf.alloc, buf.insts, buf.cap::usize, new_cap::usize
        );
        if (result_is_err[*MachInst, allocator.AllocError](r)) {
            ret false;
        }

        buf.insts = result_unwrap_ok[*MachInst, allocator.AllocError](r);
        buf.cap = new_cap;
    }

    buf.insts[buf.count] = inst;
    buf.count = buf.count + 1;
    ret true;
}

# buf_get: get a pointer to a machine instruction by index.
pub fun buf_get(buf: *MachInstBuf, index: i32) *MachInst {
    if (buf == nil || buf.insts == nil) { ret nil; }
    if (index < 0 || index >= buf.count) { ret nil; }
    ret ?buf.insts[index];
}

# buf_clear: reset the buffer count without freeing memory.
pub fun buf_clear(buf: *MachInstBuf) {
    if (buf == nil) { ret; }
    buf.count = 0;
}

# buf_mark_nop: mark an instruction as NOP for later removal.
pub fun buf_mark_nop(buf: *MachInstBuf, index: i32) {
    if (buf == nil || buf.insts == nil) { ret; }
    if (index < 0 || index >= buf.count) { ret; }
    buf.insts[index].opcode = 0;
    buf.insts[index].size = 0;
    buf.insts[index].flags = 0;
}

# buf_compact: remove NOP instructions (opcode == 0 && size == 0).
pub fun buf_compact(buf: *MachInstBuf) {
    if (buf == nil || buf.insts == nil || buf.count == 0) { ret; }

    var write: i32 = 0;
    var read: i32 = 0;
    for (read < buf.count) {
        if (buf.insts[read].opcode == 0 && buf.insts[read].size == 0) {
            read = read + 1;
            cnt;
        }
        if (write != read) {
            buf.insts[write] = buf.insts[read];
        }
        write = write + 1;
        read = read + 1;
    }
    buf.count = write;
}

# buf_destroy: free the buffer's instruction array.
pub fun buf_destroy(buf: *MachInstBuf) {
    if (buf == nil || buf.alloc == nil) { ret; }
    if (buf.insts != nil) {
        allocator.allocator_free[MachInst](buf.alloc, buf.insts, buf.cap::usize);
    }
    buf.insts = nil;
    buf.count = 0;
    buf.cap = 0;
}
