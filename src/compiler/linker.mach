# compiler.linker: static linker
#
# format-agnostic linker that reads relocatable object files, merges
# sections, resolves symbols, applies relocations, and emits a linked
# binary via the target's ExecFormat interface.
#
# stub -- returns an error until the implementation is complete.

use std.types.bool;
use std.types.size;
use std.types.string;

use allocator: std.allocator;

use target: compiler.target.target;

# result of a link operation
# ---
# output_path: path to the emitted binary (or nil on failure)
# ok:          true if linking succeeded
# error:       error message on failure (nil on success)
pub rec LinkResult {
    output_path: str;
    ok:          bool;
    error:       str;
}

# link object files into a final binary.
#
# reads each object file, merges like-named sections, resolves global
# symbols, applies relocations, and writes the executable via the
# target's ExecFormat.
# ---
# alloc:       backing allocator
# obj_paths:   array of object file paths to link
# obj_count:   number of object files
# output_path: path for the output binary
# target:      target descriptor (ISA, ABI, OS, object format)
# ret:         link result
pub fun link(alloc: &allocator.Allocator, obj_paths: *str, obj_count: i32,
             output_path: str, target: *target.Target) LinkResult {
    var result: LinkResult;
    result.output_path = nil;
    result.ok          = false;
    result.error       = "linker not yet implemented";
    ret result;
}
