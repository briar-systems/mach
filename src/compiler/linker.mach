# mach.compiler.linker: format-agnostic static linker
#
# reads relocatable object files via the target's parse_object callback,
# merges sections, resolves symbols, applies relocations via the target's
# apply_reloc callback, and emits a linked binary via ExecFormat.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;
use fs:        std.filesystem;
use map:       std.collections.map;

use diag:   mach.compiler.diag;
use target: mach.compiler.target.target;
use of:     mach.compiler.target.of;

val MAX_SECTIONS:  i32 = 256;
val MAX_SYMBOLS:   i32 = 131072;
val MAX_RELOCS:    i32 = 262144;
val PAGE_SIZE:     usize = 4096;

pub rec LinkResult {
    output_path: str;
    ok:          bool;
    error:       str;
}

fun build_symbol_map(alloc: *allocator.Allocator, syms: *of.LinkSymbol, sym_count: i32) map.Map[str, i32] {
    var m: map.Map[str, i32] = map.init[str, i32](alloc, map.hash_str, map.eq_str);
    var si: i32 = 0;
    for (si < sym_count) {
        if (syms[si].name != nil && syms[si].is_defined) {
            map.insert[str, i32](?m, syms[si].name, si);
        }
        si = si + 1;
    }
    ret m;
}

fun find_symbol_map(sym_map: *map.Map[str, i32], name: str) i32 {
    if (name == nil) { ret -1; }
    val res: Result[*i32, str] = map.get[str, i32](sym_map, ?name);
    if (is_ok[*i32, str](res)) {
        val p: *i32 = unwrap_ok[*i32, str](res);
        ret @p;
    }
    ret -1;
}

fun align_up_64(value: u64, alignment: u64) u64 {
    if (alignment == 0) { ret value; }
    ret (value + alignment - 1) & ~(alignment - 1);
}

fun apply_relocations(sections: *of.LinkSection, sec_count: i32,
                      symbols: *of.LinkSymbol, sym_count: i32,
                      relocs: *of.LinkReloc, reloc_count: i32,
                      tgt: *target.Target,
                      dl: *diag.DiagList,
                      sym_map: *map.Map[str, i32]) bool {
    var has_unresolved: bool = false;
    var ri: i32 = 0;
    for (ri < reloc_count) {
        val r: *of.LinkReloc = ?relocs[ri];
        if (r.section < 0 || r.section >= sec_count) { ri = ri + 1; cnt; }

        val sec: *of.LinkSection = ?sections[r.section];
        if (sec.data == nil || r.offset >= sec.size) { ri = ri + 1; cnt; }
        if (r.sym_idx < 0 || r.sym_idx >= sym_count) { ri = ri + 1; cnt; }

        var sym: *of.LinkSymbol = ?symbols[r.sym_idx];
        if (!sym.is_defined && sym.name != nil) {
            val resolved: i32 = find_symbol_map(sym_map, sym.name);
            if (resolved >= 0) { sym = ?symbols[resolved]; }
        }
        if (!sym.is_defined || sym.section < 0 || sym.section >= sec_count) {
            if (sym.name != nil) {
                diag.emit(dl, diag.SEV_ERROR, diag.make_loc(nil, 0, 0), sym.name);
            } or {
                diag.emit(dl, diag.SEV_ERROR, diag.make_loc(nil, 0, 0), "unresolved symbol");
            }
            has_unresolved = true;
            ri = ri + 1;
            cnt;
        }

        val sym_addr: u64 = sections[sym.section].vaddr + sym.offset::u64;
        val patch_addr: u64 = sec.vaddr + r.offset::u64;

        if (tgt.of.apply_reloc != nil) {
            tgt.of.apply_reloc(sec, patch_addr, sym_addr, r);
        }

        ri = ri + 1;
    }
    if (has_unresolved) { ret false; }
    ret true;
}

pub fun link(alloc: *allocator.Allocator, obj_paths: *str, obj_count: i32,
             output_path: str, tgt: *target.Target, dl: *diag.DiagList) LinkResult {
    var result: LinkResult;
    result.output_path = nil;
    result.ok          = false;
    result.error       = nil;

    if (tgt == nil) {
        result.error = "nil target";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }

    if (output_path == nil) {
        result.error = "nil output path";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }

    val res_sections: Result[*of.LinkSection, str] = allocator.zallocate[of.LinkSection](alloc, MAX_SECTIONS::usize);
    if (is_err[*of.LinkSection, str](res_sections)) {
        result.error = "failed to allocate sections";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }
    var sections: *of.LinkSection = unwrap_ok[*of.LinkSection, str](res_sections);
    var sec_count: i32 = 0;

    val res_symbols: Result[*of.LinkSymbol, str] = allocator.zallocate[of.LinkSymbol](alloc, MAX_SYMBOLS::usize);
    if (is_err[*of.LinkSymbol, str](res_symbols)) {
        allocator.deallocate[of.LinkSection](alloc, sections, MAX_SECTIONS::usize);
        result.error = "failed to allocate symbols";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }
    var symbols: *of.LinkSymbol = unwrap_ok[*of.LinkSymbol, str](res_symbols);
    var sym_count: i32 = 0;

    val res_relocs: Result[*of.LinkReloc, str] = allocator.zallocate[of.LinkReloc](alloc, MAX_RELOCS::usize);
    if (is_err[*of.LinkReloc, str](res_relocs)) {
        allocator.deallocate[of.LinkSymbol](alloc, symbols, MAX_SYMBOLS::usize);
        allocator.deallocate[of.LinkSection](alloc, sections, MAX_SECTIONS::usize);
        result.error = "failed to allocate relocs";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }
    var relocs: *of.LinkReloc = unwrap_ok[*of.LinkReloc, str](res_relocs);
    var reloc_count: i32 = 0;

    val res_secmap: Result[*i32, str] = allocator.allocate[i32](alloc, 256);
    if (is_err[*i32, str](res_secmap)) {
        allocator.deallocate[of.LinkReloc](alloc, relocs, MAX_RELOCS::usize);
        allocator.deallocate[of.LinkSymbol](alloc, symbols, MAX_SYMBOLS::usize);
        allocator.deallocate[of.LinkSection](alloc, sections, MAX_SECTIONS::usize);
        result.error = "failed to allocate sec_map";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }
    var sec_map: *i32 = unwrap_ok[*i32, str](res_secmap);

    if (obj_paths != nil && obj_count > 0 && tgt.of.parse_object != nil) {
        var oi: i32 = 0;
        for (oi < obj_count) {
            val obj_path: str = obj_paths[oi];
            if (obj_path == nil) { oi = oi + 1; cnt; }

            val res_info: Result[fs.FileInfo, str] = fs.info_path(obj_path);
            if (is_err[fs.FileInfo, str](res_info)) {
                diag.error(dl, diag.make_loc(obj_path, 0, 0), "cannot stat object file");
                oi = oi + 1;
                cnt;
            }
            val fi: fs.FileInfo = unwrap_ok[fs.FileInfo, str](res_info);

            val res_read: Result[str, str] = fs.read_all(alloc, obj_path);
            if (is_err[str, str](res_read)) {
                diag.error(dl, diag.make_loc(obj_path, 0, 0), "cannot read object file");
                oi = oi + 1;
                cnt;
            }
            val file_data: str = unwrap_ok[str, str](res_read);

            tgt.of.parse_object(alloc, file_data::*u8, fi.size,
                               sections, ?sec_count,
                               symbols, ?sym_count,
                               relocs, ?reloc_count,
                               sec_map);

            oi = oi + 1;
        }
    }

    var sym_map: map.Map[str, i32] = build_symbol_map(alloc, symbols, sym_count);

    val base_addr: u64 = tgt.os.base_addr;
    var vaddr: u64 = base_addr;

    var si: i32 = 0;
    for (si < sec_count) {
        var sec_align: u64 = sections[si].align::u64;
        if (sec_align < PAGE_SIZE::u64) { sec_align = PAGE_SIZE::u64; }
        vaddr = align_up_64(vaddr, sec_align);
        sections[si].vaddr = vaddr;
        vaddr = vaddr + sections[si].size::u64;
        si = si + 1;
    }

    if (!apply_relocations(sections, sec_count, symbols, sym_count, relocs, reloc_count, tgt, dl, ?sym_map)) {
        allocator.deallocate[i32](alloc, sec_map, 256);
        allocator.deallocate[of.LinkReloc](alloc, relocs, MAX_RELOCS::usize);
        allocator.deallocate[of.LinkSymbol](alloc, symbols, MAX_SYMBOLS::usize);
        var ci: i32 = 0;
        for (ci < sec_count) {
            if (sections[ci].data != nil) {
                allocator.deallocate[u8](alloc, sections[ci].data, sections[ci].cap);
            }
            ci = ci + 1;
        }
        allocator.deallocate[of.LinkSection](alloc, sections, MAX_SECTIONS::usize);
        map.dnit[str, i32](?sym_map);
        result.error = "unresolved symbols";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        ret result;
    }

    var entry_addr: u64 = base_addr;
    val entry_name: str = tgt.os.entry_symbol;
    if (entry_name != nil) {
        val entry_idx: i32 = find_symbol_map(?sym_map, entry_name);
        if (entry_idx >= 0 && symbols[entry_idx].section >= 0) {
            entry_addr = sections[symbols[entry_idx].section].vaddr + symbols[entry_idx].offset::u64;
        }
    }

    if (tgt.of.exec.add_load == nil || tgt.of.exec.set_entry == nil || tgt.of.exec.finalize == nil) {
        if (sec_count == 0 && obj_count == 0) {
            result.ok = true;
            result.output_path = output_path;
        } or {
            result.error = "exec format not initialized";
            diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
        }
        allocator.deallocate[i32](alloc, sec_map, 256);
        allocator.deallocate[of.LinkReloc](alloc, relocs, MAX_RELOCS::usize);
        allocator.deallocate[of.LinkSymbol](alloc, symbols, MAX_SYMBOLS::usize);
        var di: i32 = 0;
        for (di < sec_count) {
            if (sections[di].data != nil) {
                allocator.deallocate[u8](alloc, sections[di].data, sections[di].cap);
            }
            di = di + 1;
        }
        allocator.deallocate[of.LinkSection](alloc, sections, MAX_SECTIONS::usize);
        ret result;
    }

    tgt.of.exec.set_entry(tgt.of.exec.ctx, entry_addr);

    val PF_R: u32 = 4;
    val PF_W: u32 = 2;
    val PF_X: u32 = 1;

    si = 0;
    for (si < sec_count) {
        if (sections[si].kind == of.SK_DEBUG) {
            if (tgt.of.exec.add_debug_sec != nil && sections[si].data != nil && sections[si].size > 0) {
                tgt.of.exec.add_debug_sec(tgt.of.exec.ctx, sections[si].name, sections[si].data, sections[si].size);
            }
            si = si + 1;
            cnt;
        }

        var pflags: u32 = PF_R;
        if (sections[si].kind == of.SK_TEXT) {
            pflags = PF_R | PF_X;
        } or (sections[si].kind == of.SK_DATA || sections[si].kind == of.SK_BSS) {
            pflags = PF_R | PF_W;
        }

        var filesz: usize = sections[si].size;
        if (sections[si].kind == of.SK_BSS) { filesz = 0; }

        val seg_idx: i32 = tgt.of.exec.add_load(tgt.of.exec.ctx, sections[si].vaddr, filesz, sections[si].size, pflags);

        if (seg_idx >= 0 && sections[si].data != nil && tgt.of.exec.set_data != nil) {
            tgt.of.exec.set_data(tgt.of.exec.ctx, seg_idx, sections[si].data, sections[si].size);
        }

        si = si + 1;
    }

    val finalize_ok: bool = tgt.of.exec.finalize(tgt.of.exec.ctx, output_path);

    allocator.deallocate[i32](alloc, sec_map, 256);
    allocator.deallocate[of.LinkReloc](alloc, relocs, MAX_RELOCS::usize);
    allocator.deallocate[of.LinkSymbol](alloc, symbols, MAX_SYMBOLS::usize);
    var di: i32 = 0;
    for (di < sec_count) {
        if (sections[di].data != nil) {
            allocator.deallocate[u8](alloc, sections[di].data, sections[di].cap);
        }
        di = di + 1;
    }
    allocator.deallocate[of.LinkSection](alloc, sections, MAX_SECTIONS::usize);

    if (finalize_ok) {
        result.ok = true;
        result.output_path = output_path;
    } or {
        result.error = "finalize failed";
        diag.error(dl, diag.make_loc(nil, 0, 0), result.error);
    }

    map.dnit[str, i32](?sym_map);
    ret result;
}
