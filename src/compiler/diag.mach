# compiler.diag: structured diagnostic collection and formatting.
#
# self-contained diagnostic infrastructure with no dependency on sema, module,
# or session. collects errors/warnings/notes with source locations and renders
# them to the terminal.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use heap:      std.allocator.heap;
use print:     std.print;

pub def Severity: u8;
pub val SEV_ERROR:   Severity = 0;
pub val SEV_WARNING: Severity = 1;
pub val SEV_NOTE:    Severity = 2;
pub val SEV_HINT:    Severity = 3;

# source location for a diagnostic
# ---
# file:   file path
# line:   1-based line number
# col:    1-based column number
# offset: byte offset into the source
# len:    length of the span in bytes
pub rec SourceLoc {
    file:   str;
    line:   u32;
    col:    u32;
    offset: u32;
    len:    u16;
}

# a single diagnostic entry
# ---
# severity: SEV_ERROR, SEV_WARNING, SEV_NOTE, or SEV_HINT
# loc:      source location
# message:  human-readable message
# notes:    linked list of attached notes
pub rec Diagnostic {
    severity: Severity;
    loc:      SourceLoc;
    message:  str;
    notes:    *Diagnostic;
}

# growable list of diagnostics
# ---
# alloc:     backing allocator
# items:     array of diagnostics
# count:     number of diagnostics in the list
# cap:       allocated capacity
# err_count: number of SEV_ERROR diagnostics
pub rec DiagList {
    alloc:     *allocator.Allocator;
    items:     *Diagnostic;
    count:     u32;
    cap:       u32;
    err_count: u32;
}

# callback type for retrieving source text given a file path.
# returns the source text, or nil if the file is not available.
pub def SourceFn: fun(str) str;

val INITIAL_CAP: u32 = 16;

# init: create an empty diagnostic list.
# ---
# alloc: allocator for internal storage
# ret:   initialized DiagList
pub fun init(alloc: *allocator.Allocator) DiagList {
    var dl: DiagList;
    dl.alloc = alloc;
    dl.items = nil;
    dl.count = 0;
    dl.cap = 0;
    dl.err_count = 0;
    ret dl;
}

# dnit: free the items array.
# ---
# dl: diagnostic list to clean up
pub fun dnit(dl: *DiagList) {
    if (dl == nil) { ret; }
    if (dl.items != nil && dl.alloc != nil) {
        allocator.deallocate[Diagnostic](dl.alloc, dl.items, dl.cap::usize);
        dl.items = nil;
    }
    dl.count = 0;
    dl.cap = 0;
    dl.err_count = 0;
}

fun grow(dl: *DiagList) bool {
    var new_cap: u32 = INITIAL_CAP;
    if (dl.cap > 0) {
        new_cap = dl.cap * 2;
    }

    val res_reallocate: Result[*Diagnostic, str] = allocator.reallocate[Diagnostic](
        dl.alloc, dl.items, dl.cap::usize, new_cap::usize
    );
    if (!res_reallocate.tag) {
        ret false;
    }

    dl.items = res_reallocate.value.ok;
    dl.cap = new_cap;
    ret true;
}

# emit: append a diagnostic to the list.
# ---
# dl:  diagnostic list
# sev: severity level
# loc: source location
# msg: diagnostic message
pub fun emit(dl: *DiagList, sev: Severity, loc: SourceLoc, msg: str) {
    if (dl == nil) { ret; }

    if (dl.count >= dl.cap) {
        if (!grow(dl)) { ret; }
    }

    val idx: u32 = dl.count;
    dl.items[idx].severity = sev;
    dl.items[idx].loc = loc;
    dl.items[idx].message = msg;
    dl.items[idx].notes = nil;
    dl.count = dl.count + 1;

    if (sev == SEV_ERROR) {
        dl.err_count = dl.err_count + 1;
    }
}

# emit_note: append a note to a parent diagnostic's notes chain.
# ---
# dl:     diagnostic list (for allocation)
# parent: diagnostic to attach the note to
# loc:    source location of the note
# msg:    note message
pub fun emit_note(dl: *DiagList, parent: *Diagnostic, loc: SourceLoc, msg: str) {
    if (dl == nil || parent == nil || dl.alloc == nil) { ret; }

    val res_zallocate: Result[*Diagnostic, str] = allocator.zallocate[Diagnostic](dl.alloc, 1);
    if (!res_zallocate.tag) { ret; }

    val note: *Diagnostic = res_zallocate.value.ok;
    note.severity = SEV_NOTE;
    note.loc = loc;
    note.message = msg;
    note.notes = nil;

    if (parent.notes == nil) {
        parent.notes = note;
        ret;
    }

    var tail: *Diagnostic = parent.notes;
    for (tail.notes != nil) {
        tail = tail.notes;
    }
    tail.notes = note;
}

# error: emit an error diagnostic.
# ---
# dl:  diagnostic list
# loc: source location
# msg: error message
pub fun error(dl: *DiagList, loc: SourceLoc, msg: str) {
    emit(dl, SEV_ERROR, loc, msg);
}

# warning: emit a warning diagnostic.
# ---
# dl:  diagnostic list
# loc: source location
# msg: warning message
pub fun warning(dl: *DiagList, loc: SourceLoc, msg: str) {
    emit(dl, SEV_WARNING, loc, msg);
}

# had_errors: check whether any errors have been recorded.
# ---
# dl:  diagnostic list
# ret: true if at least one error was emitted
pub fun had_errors(dl: &DiagList) bool {
    if (dl == nil) { ret false; }
    ret dl.err_count > 0;
}

# error_count: return the number of errors recorded.
# ---
# dl:  diagnostic list
# ret: error count
pub fun error_count(dl: &DiagList) u32 {
    if (dl == nil) { ret 0; }
    ret dl.err_count;
}

fun severity_label(sev: Severity) str {
    if (sev == SEV_ERROR)   { ret "error"; }
    if (sev == SEV_WARNING) { ret "warning"; }
    if (sev == SEV_NOTE)    { ret "note"; }
    if (sev == SEV_HINT)    { ret "hint"; }
    ret "unknown";
}

fun print_source_line(source: str, line: u32, col: u32) {
    if (source == nil || line < 1) { ret; }

    var current_line: u32 = 1;
    var line_start: u32 = 0;
    var i: u32 = 0;
    val len: u32 = str_len(source)::u32;

    for (i < len && current_line < line) {
        if (source[i] == '\n') {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) { ret; }

    var line_end: u32 = line_start;
    for (line_end < len && source[line_end] != '\n') {
        line_end = line_end + 1;
    }

    print.eprintf("  %d | ", line::i64);
    i = line_start;
    for (i < line_end) {
        var ch: [2]u8;
        ch[0] = source[i];
        ch[1] = 0;
        print.eprint((?ch[0])::str);
        i = i + 1;
    }
    print.eprintln("");

    var digits: u32 = 1;
    var tmp: u32 = line;
    for (tmp >= 10) {
        digits = digits + 1;
        tmp = tmp / 10;
    }
    var pad: u32 = 0;
    for (pad < digits + 2) {
        print.eprint(" ");
        pad = pad + 1;
    }
    print.eprint(" | ");
    var c: u32 = 1;
    for (c < col) {
        print.eprint(" ");
        c = c + 1;
    }
    print.eprintln("^");
}

fun print_one(diag: &Diagnostic, get_source: SourceFn) {
    val label: str = severity_label(diag.severity);
    print.eprintf("%s: %s\n", label, diag.message);
    print.eprintf(" --> %s:%d:%d\n", diag.loc.file, diag.loc.line::i64, diag.loc.col::i64);

    if (get_source != nil) {
        val source: str = get_source(diag.loc.file);
        if (source != nil) {
            print_source_line(source, diag.loc.line, diag.loc.col);
        }
    }

    var note: *Diagnostic = diag.notes;
    for (note != nil) {
        print.eprintf("%s: %s\n", severity_label(note.severity), note.message);
        print.eprintf(" --> %s:%d:%d\n", note.loc.file, note.loc.line::i64, note.loc.col::i64);

        if (get_source != nil) {
            val nsource: str = get_source(note.loc.file);
            if (nsource != nil) {
                print_source_line(nsource, note.loc.line, note.loc.col);
            }
        }

        note = note.notes;
    }
}

# print_terminal: print all diagnostics to stderr in human-readable format.
# ---
# dl:         diagnostic list
# get_source: callback to retrieve source text for a file path (may be nil)
pub fun print_terminal(dl: &DiagList, get_source: SourceFn) {
    if (dl == nil) { ret; }

    var i: u32 = 0;
    for (i < dl.count) {
        print_one(?dl.items[i], get_source);
        i = i + 1;
    }
}

test "diag: emit error and check counts" {
    var hs: heap.HeapState;
    var alloc: allocator.Allocator;
    heap.make(?alloc, ?hs);

    var dl: DiagList = init(?alloc);

    if (had_errors(?dl)) { ret 0; }
    if (error_count(?dl) != 0) { ret 0; }

    var loc: SourceLoc;
    loc.file = "test.mach";
    loc.line = 1;
    loc.col = 5;
    loc.offset = 4;
    loc.len = 3;

    error(?dl, loc, "unexpected token");

    if (!had_errors(?dl)) { ret 0; }
    if (error_count(?dl) != 1) { ret 0; }
    if (dl.count != 1) { ret 0; }

    dnit(?dl);
    ret 1;
}
