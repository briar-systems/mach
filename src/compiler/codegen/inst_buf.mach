use std.types.bool;
use std.types.size;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.codegen.inst_buf: generic growable instruction buffer.
# ---
# provides InstructionBuffer[T] used by all ISA backends.
# each backend instantiates with its own instruction type.
# mark-nop and compact operations are ISA-specific (require
# opcode field knowledge) and implemented as thin wrappers
# in each backend's inst.mach.

val INITIAL_CAP: i32 = 64;

pub rec InstructionBuffer[T] {
    insts: *T;
    count: i32;
    cap:   i32;
    alloc: *allocator.Allocator;
}

pub fun buf_create[T](alloc: *allocator.Allocator) InstructionBuffer[T] {
    var buf: InstructionBuffer[T];
    buf.insts = nil;
    buf.count = 0;
    buf.cap = 0;
    buf.alloc = alloc;
    ret buf;
}

pub fun buf_append[T](buf: *InstructionBuffer[T], inst: T) bool {
    if (buf == nil || buf.alloc == nil) { ret false; }

    if (buf.count >= buf.cap) {
        var new_cap: i32 = INITIAL_CAP;
        if (buf.cap > 0) {
            new_cap = buf.cap * 2;
        }

        val r: Result[*T, allocator.AllocError] = allocator.allocator_resize[T](
            buf.alloc, buf.insts, buf.cap::usize, new_cap::usize
        );
        if (result_is_err[*T, allocator.AllocError](r)) {
            ret false;
        }

        buf.insts = result_unwrap_ok[*T, allocator.AllocError](r);
        buf.cap = new_cap;
    }

    buf.insts[buf.count] = inst;
    buf.count = buf.count + 1;
    ret true;
}

pub fun buf_get[T](buf: *InstructionBuffer[T], index: i32) *T {
    if (buf == nil || buf.insts == nil) { ret nil; }
    if (index < 0 || index >= buf.count) { ret nil; }
    ret ?buf.insts[index];
}

pub fun buf_clear[T](buf: *InstructionBuffer[T]) {
    if (buf == nil) { ret; }
    buf.count = 0;
}

pub fun buf_destroy[T](buf: *InstructionBuffer[T]) {
    if (buf == nil || buf.alloc == nil) { ret; }
    if (buf.insts != nil) {
        allocator.allocator_free[T](buf.alloc, buf.insts, buf.cap::usize);
    }
    buf.insts = nil;
    buf.count = 0;
    buf.cap = 0;
}
