# mach.compiler.codegen.assemble: merge FunctionObjects into an ObjectFile.
#
# takes an array of FunctionObjects (from compile_function) and the
# Module's data declarations, produces a single ObjectFile with
# merged sections, symbols, and debug info.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use section:   mach.compiler.codegen.section;
use sym:       masm.symbol;
use data:      masm.data;
use cg:        mach.compiler.codegen;

# ObjectFile: assembled output ready for object format emission.
# contains all sections, symbols, and debug info needed to write
# a relocatable object file.
# ---
# sections:      array of section pointers (.text, .data, .rodata, .bss)
# section_count: number of sections
# symbols:       array of symbol pointers
# sym_count:     number of symbols
# debug_lines:   source location mappings (section-absolute offsets)
# line_count:    number of debug entries
pub rec ObjectFile {
    sections:      **section.Section;
    section_count: i32;
    section_cap:   i32;
    symbols:       **sym.Symbol;
    sym_count:     i32;
    sym_cap:       i32;
    debug_lines:   *cg.DebugLoc;
    line_count:    i32;
    line_cap:      i32;
}

val INITIAL_SEC_CAP:  i32 = 8;
val INITIAL_SYM_CAP:  i32 = 64;
val INITIAL_LINE_CAP: i32 = 128;

# assemble: merge FunctionObjects and data declarations into an ObjectFile.
# ---
# funcs:      array of FunctionObject pointers
# func_count: number of functions
# data_decls: module data declarations
# alloc:      allocator
# ret:        assembled object file
pub fun assemble(funcs: *cg.FunctionObject, func_count: i32,
                 data_decls: *data.DataDeclList,
                 alloc: *allocator.Allocator) ObjectFile {
    var obj: ObjectFile;
    obj.sections = nil;
    obj.section_count = 0;
    obj.section_cap = 0;
    obj.symbols = nil;
    obj.sym_count = 0;
    obj.sym_cap = 0;
    obj.debug_lines = nil;
    obj.line_count = 0;
    obj.line_cap = 0;

    if (alloc == nil) { ret obj; }

    # allocate arrays
    obj.section_cap = INITIAL_SEC_CAP;
    val sec_r: Result[**section.Section, str] =
        allocator.zallocate[*section.Section](alloc, obj.section_cap::usize);
    if (!sec_r.tag) { ret obj; }
    obj.sections = sec_r.value.ok;

    obj.sym_cap = INITIAL_SYM_CAP;
    val sym_r: Result[**sym.Symbol, str] =
        allocator.zallocate[*sym.Symbol](alloc, obj.sym_cap::usize);
    if (!sym_r.tag) { ret obj; }
    obj.symbols = sym_r.value.ok;

    obj.line_cap = INITIAL_LINE_CAP;
    val line_r: Result[*cg.DebugLoc, str] =
        allocator.zallocate[cg.DebugLoc](alloc, obj.line_cap::usize);
    if (!line_r.tag) { ret obj; }
    obj.debug_lines = line_r.value.ok;

    # create .text section
    val text_r: Result[*section.Section, str] =
        section.create(alloc, ".text", sym.SEC_TEXT, sym.ENDIAN_LITTLE);
    if (!text_r.tag) { ret obj; }
    val text_sec: *section.Section = text_r.value.ok;
    obj.sections[0] = text_sec;
    obj.section_count = 1;

    # merge FunctionObjects into .text
    if (funcs != nil && func_count > 0) {
        var fi: i32 = 0;
        for (fi < func_count) {
            val fo: *cg.FunctionObject = ?funcs[fi];
            if (!fo.ok) { fi = fi + 1; cnt; }

            val func_start: usize = section.current_offset(text_sec);

            # copy code bytes
            if (fo.code != nil && fo.code_len > 0) {
                section.emit_bytes(alloc, text_sec, fo.code::&u8, fo.code_len);
            }

            # merge relocations
            var ri: i32 = 0;
            for (ri < fo.reloc_count) {
                section.add_relocation(alloc, text_sec,
                    fo.relocs[ri].offset + func_start,
                    fo.relocs[ri].symbol_name,
                    fo.relocs[ri].rtype, fo.relocs[ri].addend);
                ri = ri + 1;
            }

            # merge symbols
            var si: i32 = 0;
            for (si < fo.sym_count) {
                add_symbol(?obj, alloc, ?fo.symbols[si], func_start, 0);
                si = si + 1;
            }

            # merge debug lines
            var li: i32 = 0;
            for (li < fo.line_count) {
                add_debug_line(?obj, alloc,
                    fo.lines[li].code_offset + func_start,
                    fo.lines[li].file_idx, fo.lines[li].line);
                li = li + 1;
            }

            fi = fi + 1;
        }
    }

    # materialize data declarations into sections
    if (data_decls != nil) {
        emit_data_decls(?obj, data_decls, alloc);
    }

    ret obj;
}

# find_symbol: find a symbol by name in the ObjectFile.
pub fun find_symbol(obj: *ObjectFile, name: str) *sym.Symbol {
    if (obj == nil || name == nil) { ret nil; }
    var i: i32 = 0;
    for (i < obj.sym_count) {
        if (obj.symbols[i] != nil && obj.symbols[i].name != nil
            && str_equals(obj.symbols[i].name, name)) {
            ret obj.symbols[i];
        }
        i = i + 1;
    }
    ret nil;
}

# add_symbol: add a symbol to the ObjectFile, adjusting offset by base.
pub fun add_symbol(obj: *ObjectFile, alloc: *allocator.Allocator,
               src: *sym.Symbol, base_offset: usize, sec_idx: i32) {
    if (obj == nil || src == nil) { ret; }

    if (obj.sym_count >= obj.sym_cap) {
        val new_cap: i32 = obj.sym_cap * 2;
        val r: Result[**sym.Symbol, str] =
            allocator.reallocate[*sym.Symbol](alloc, obj.symbols,
                obj.sym_cap::usize, new_cap::usize);
        if (!r.tag) { ret; }
        obj.symbols = r.value.ok;
        obj.sym_cap = new_cap;
    }

    val sr: Result[*sym.Symbol, str] =
        allocator.zallocate[sym.Symbol](alloc, 1);
    if (!sr.tag) { ret; }

    val s: *sym.Symbol = sr.value.ok;
    s.name = src.name;
    s.binding = src.binding;
    s.sym_type = src.sym_type;
    s.offset = src.offset + base_offset;
    s.size = src.size;
    s.defined = src.defined;
    s.section = sec_idx::u64;
    s.src_file = src.src_file;
    s.src_line = src.src_line;

    obj.symbols[obj.sym_count] = s;
    obj.sym_count = obj.sym_count + 1;
}

# add_debug_line: record a debug line entry with section-absolute offset.
pub fun add_debug_line(obj: *ObjectFile, alloc: *allocator.Allocator,
                   code_offset: usize, file_idx: u16, line: i32) {
    if (obj == nil || file_idx == 0 || line <= 0) { ret; }

    if (obj.line_count >= obj.line_cap) {
        val new_cap: i32 = obj.line_cap * 2;
        val r: Result[*cg.DebugLoc, str] =
            allocator.reallocate[cg.DebugLoc](alloc, obj.debug_lines,
                obj.line_cap::usize, new_cap::usize);
        if (!r.tag) { ret; }
        obj.debug_lines = r.value.ok;
        obj.line_cap = new_cap;
    }

    val idx: i32 = obj.line_count;
    obj.debug_lines[idx].code_offset = code_offset;
    obj.debug_lines[idx].file_idx = file_idx;
    obj.debug_lines[idx].line = line;
    obj.line_count = obj.line_count + 1;
}

# get_or_create_section: find or create a section in the ObjectFile.
pub fun get_or_create_section(obj: *ObjectFile, alloc: *allocator.Allocator,
                          name: str, kind: sym.SectionKind) *section.Section {
    if (obj == nil) { ret nil; }

    # search existing
    var i: i32 = 0;
    for (i < obj.section_count) {
        if (obj.sections[i] != nil && str_equals(obj.sections[i].name, name)) {
            ret obj.sections[i];
        }
        i = i + 1;
    }

    # create new
    if (obj.section_count >= obj.section_cap) {
        val new_cap: i32 = obj.section_cap * 2;
        val r: Result[**section.Section, str] =
            allocator.reallocate[*section.Section](alloc, obj.sections,
                obj.section_cap::usize, new_cap::usize);
        if (!r.tag) { ret nil; }
        obj.sections = r.value.ok;
        obj.section_cap = new_cap;
    }

    val sec_r: Result[*section.Section, str] =
        section.create(alloc, name, kind, sym.ENDIAN_LITTLE);
    if (!sec_r.tag) { ret nil; }

    val sec: *section.Section = sec_r.value.ok;
    obj.sections[obj.section_count] = sec;
    obj.section_count = obj.section_count + 1;
    ret sec;
}

# get_section_index: find the index of a section by name.
pub fun get_section_index(obj: *ObjectFile, name: str) i32 {
    if (obj == nil) { ret -1; }
    var i: i32 = 0;
    for (i < obj.section_count) {
        if (obj.sections[i] != nil && str_equals(obj.sections[i].name, name)) {
            ret i;
        }
        i = i + 1;
    }
    ret -1;
}

# emit_data_decls: materialize data declarations into ObjectFile sections.
fun emit_data_decls(obj: *ObjectFile, decls: *data.DataDeclList,
                    alloc: *allocator.Allocator) {
    if (obj == nil || decls == nil) { ret; }

    val count: usize = decls.decls.len;
    var di: usize = 0;
    for (di < count) {
        val decl: *data.DataDecl = ?decls.decls.data[di];

        # determine target section
        var sec_name: str = ".data";
        var sec_kind: sym.SectionKind = sym.SEC_DATA;
        if (decl.section == sym.SEC_RODATA) {
            sec_name = ".rodata";
            sec_kind = sym.SEC_RODATA;
        } or (decl.section == sym.SEC_BSS) {
            sec_name = ".bss";
            sec_kind = sym.SEC_BSS;
        }

        val sec: *section.Section = get_or_create_section(obj, alloc, sec_name, sec_kind);
        if (sec == nil) { di = di + 1; cnt; }

        val sec_idx: i32 = get_section_index(obj, sec_name);

        # align section offset
        if (decl.align > 1) {
            val cur: usize = section.current_offset(sec);
            val al: usize = decl.align::usize;
            val rem: usize = cur & (al - 1);
            if (rem != 0) {
                val pad: usize = al - rem;
                var pi: usize = 0;
                for (pi < pad) {
                    section.emit_byte(alloc, sec, 0);
                    pi = pi + 1;
                }
            }
        }

        val decl_offset: usize = section.current_offset(sec);

        # emit data bytes or zero-fill
        if (decl.kind == data.DATA_BYTES && decl.data != nil && decl.data_len > 0) {
            section.emit_bytes(alloc, sec, decl.data::&u8, decl.data_len::usize);
        } or (decl.kind == data.DATA_ZERO && decl.data_len > 0) {
            var zi: u32 = 0;
            for (zi < decl.data_len) {
                section.emit_byte(alloc, sec, 0);
                zi = zi + 1;
            }
        }

        # emit relocations within data
        if (decl.reloc_count > 0 && decl.relocs != nil) {
            var ri: i32 = 0;
            for (ri < decl.reloc_count) {
                section.add_relocation(alloc, sec,
                    decl_offset + decl.relocs[ri].offset::usize,
                    decl.relocs[ri].target,
                    decl.relocs[ri].kind, decl.relocs[ri].addend);
                ri = ri + 1;
            }
        }

        # create symbol for data declaration
        val sym_r: Result[*sym.Symbol, str] =
            allocator.zallocate[sym.Symbol](alloc, 1);
        if (sym_r.tag) {
            val s: *sym.Symbol = sym_r.value.ok;
            s.name = decl.name;
            s.binding = decl.binding;
            s.sym_type = decl.sym_type;
            s.offset = decl_offset;
            s.size = decl.data_len::usize;
            s.defined = true;
            s.section = sec_idx::u64;
            s.src_file = decl.src_file;
            s.src_line = decl.src_line;
            add_symbol(obj, alloc, s, 0, sec_idx);
            allocator.deallocate[sym.Symbol](alloc, s, 1);
        }

        di = di + 1;
    }
}

# object_dnit: free all memory owned by an ObjectFile.
pub fun object_dnit(alloc: *allocator.Allocator, obj: *ObjectFile) {
    if (alloc == nil || obj == nil) { ret; }

    var si: i32 = 0;
    for (si < obj.section_count) {
        if (obj.sections[si] != nil) {
            section.destroy(alloc, obj.sections[si]);
        }
        si = si + 1;
    }
    if (obj.sections != nil) {
        allocator.deallocate[*section.Section](alloc, obj.sections, obj.section_cap::usize);
    }

    var syi: i32 = 0;
    for (syi < obj.sym_count) {
        if (obj.symbols[syi] != nil) {
            allocator.deallocate[sym.Symbol](alloc, obj.symbols[syi], 1);
        }
        syi = syi + 1;
    }
    if (obj.symbols != nil) {
        allocator.deallocate[*sym.Symbol](alloc, obj.symbols, obj.sym_cap::usize);
    }

    if (obj.debug_lines != nil) {
        allocator.deallocate[cg.DebugLoc](alloc, obj.debug_lines, obj.line_cap::usize);
    }
}
