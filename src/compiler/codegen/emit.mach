# mach.compiler.codegen.emit: object emission and data materialization.
# ---
# bridges ObjState to the ObjectFormat interface for .o emission.
# also materializes DataDecls into sections (absorbed from data_emit).

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;

use data:      masm.data;
use msym:      masm.symbol;
use objstate:  mach.compiler.codegen.objstate;
use section:   mach.compiler.target.of.section;
use target:    mach.compiler.target;
use of:        mach.compiler.target.of;
use obuf:      mach.compiler.target.of.buf;

# emit: write an ObjState to an object file.
# returns 0 on success, nonzero on failure.
pub fun emit(obj: *objstate.ObjState, tgt: *target.Target,
             output_path: str, alloc: *allocator.Allocator) i64 {
    if (obj == nil || tgt == nil || output_path == nil || alloc == nil) {
        ret 1;
    }

    val fmt_r: Result[of.ObjWriter, str] = target.create_object_format(tgt, alloc);
    if (result_is_err[of.ObjWriter, str](fmt_r)) { ret 1; }
    var fmt_val: of.ObjWriter = result_unwrap_ok[of.ObjWriter, str](fmt_r);
    val fmt: *of.ObjWriter = ?fmt_val;

    var sec_indices: *u64 = nil;
    if (obj.section_count > 0) {
        val r: Result[*u64, allocator.AllocError] =
            allocator.allocator_zalloc[u64](alloc, obj.section_count::usize);
        if (result_is_err[*u64, allocator.AllocError](r)) { ret 2; }
        sec_indices = result_unwrap_ok[*u64, allocator.AllocError](r);
    }

    var si: i32 = 0;
    for (si < obj.section_count) {
        val sec: *section.Section = obj.sections[si];
        if (sec != nil) {
            val idx: u64 = fmt.add_section(fmt.ctx, sec.name,
                sec.kind, sec.flags, sec.align);
            sec_indices[si] = idx;

            if (sec.data != nil && sec.size > 0) {
                fmt.write(fmt.ctx, idx, sec.data, sec.size);
            } or (sec.size > 0) {
                fmt.set_size(fmt.ctx, idx, sec.size);
            }
        }
        si = si + 1;
    }

    var sym_indices: *u64 = nil;
    if (obj.symbol_count > 0) {
        val r: Result[*u64, allocator.AllocError] =
            allocator.allocator_zalloc[u64](alloc, obj.symbol_count::usize);
        if (result_is_err[*u64, allocator.AllocError](r)) { ret 3; }
        sym_indices = result_unwrap_ok[*u64, allocator.AllocError](r);
    }

    var syi: i32 = 0;
    for (syi < obj.symbol_count) {
        val s: *msym.Symbol = obj.symbols[syi];
        if (s != nil) {
            var of_sym: of.OFSymbol;
            of_sym.name = s.name;
            of_sym.binding = s.binding;
            of_sym.kind = s.sym_type;
            of_sym.offset = s.offset;
            of_sym.size = s.size;

            if (s.defined && s.section < obj.section_count::u64 && sec_indices != nil) {
                of_sym.section = sec_indices[s.section];
            } or {
                of_sym.section = 0;
            }

            val idx: u64 = fmt.add_symbol(fmt.ctx, ?of_sym);
            sym_indices[syi] = idx;
        }
        syi = syi + 1;
    }

    var ri: i32 = 0;
    for (ri < obj.section_count) {
        val sec: *section.Section = obj.sections[ri];
        if (sec != nil && sec.reloc_count > 0) {
            val of_sec_idx: u64 = sec_indices[ri];

            var rj: i32 = 0;
            for (rj < sec.reloc_count) {
                var of_reloc: of.OFReloc;
                of_reloc.section = of_sec_idx;
                of_reloc.offset = sec.relocs[rj].offset;
                of_reloc.rtype = sec.relocs[rj].rtype::u32;
                of_reloc.addend = sec.relocs[rj].addend;

                of_reloc.symbol = resolve_sym_index(obj, sym_indices,
                    sec.relocs[rj].symbol_name);

                fmt.add_reloc(fmt.ctx, ?of_reloc);
                rj = rj + 1;
            }
        }
        ri = ri + 1;
    }

    var buf: obuf.OutputBuffer;
    obuf.buf_init(?buf, alloc, tgt.isa.endian);

    fmt.finalize(fmt.ctx, ?buf);

    val result: i64 = write_output(?buf, output_path);

    obuf.buf_destroy(?buf);
    fmt.destroy(fmt.ctx);

    if (sec_indices != nil) {
        allocator.allocator_free[u64](alloc, sec_indices, obj.section_count::usize);
    }
    if (sym_indices != nil) {
        allocator.allocator_free[u64](alloc, sym_indices, obj.symbol_count::usize);
    }

    ret result;
}

fun resolve_sym_index(obj: *objstate.ObjState, sym_indices: *u64, name: str) u64 {
    if (obj == nil || sym_indices == nil || name == nil) { ret 0; }

    val found: *msym.Symbol = objstate.get_symbol(obj, name);
    if (found == nil) { ret 0; }

    var i: i32 = 0;
    for (i < obj.symbol_count) {
        if (obj.symbols[i] == found) {
            ret sym_indices[i];
        }
        i = i + 1;
    }
    ret 0;
}

fun write_output(buf: *obuf.OutputBuffer, path: str) i64 {
    if (buf == nil || buf.data == nil || buf.size == 0) { ret 1; }

    val file_r: Result[fs.File, str] = fs.create(path, 420);
    if (result_is_err[fs.File, str](file_r)) { ret 2; }

    var file: fs.File = result_unwrap_ok[fs.File, str](file_r);
    val write_r: Result[usize, str] = fs.file_write(?file, buf.data, buf.size);
    fs.file_close(?file);

    if (result_is_err[usize, str](write_r)) { ret 3; }
    ret 0;
}

fun section_name(kind: msym.SectionKind) str {
    if (kind == msym.SEC_TEXT)   { ret ".text"; }
    if (kind == msym.SEC_DATA)   { ret ".data"; }
    if (kind == msym.SEC_RODATA) { ret ".rodata"; }
    if (kind == msym.SEC_BSS)    { ret ".bss"; }
    ret ".data";
}

fun align_padding(offset: usize, align: usize) usize {
    if (align <= 1) { ret 0; }
    val rem: usize = offset % align;
    if (rem == 0) { ret 0; }
    ret align - rem;
}

# emit_data_decls: materialize all data declarations into sections.
pub fun emit_data_decls(dl: *data.DataDeclList, obj: *objstate.ObjState,
                        alloc: *allocator.Allocator) {
    if (dl == nil || obj == nil || alloc == nil) { ret; }
    if (dl.decls.len == 0) { ret; }

    var i: i32 = 0;
    for (i < dl.decls.len::i32) {
        val d: *data.DataDecl = data.list_get(dl, i);
        if (d != nil && d.name != nil) {
            emit_one(obj, alloc, d);
        }
        i = i + 1;
    }
}

fun emit_one(obj: *objstate.ObjState, alloc: *allocator.Allocator, d: *data.DataDecl) {
    val sec_name: str = section_name(d.section);

    if (d.sym_type == msym.SYM_FUNC) {
        register_data_sym(obj, alloc, d, sec_name, 0, 0);
        ret;
    }

    if (d.kind == data.DATA_ZERO) {
        val sec_r: Result[*section.Section, str] =
            objstate.get_or_create_section(obj, sec_name, d.section);
        if (result_is_err[*section.Section, str](sec_r)) { ret; }

        val sec: *section.Section = result_unwrap_ok[*section.Section, str](sec_r);

        val pad: usize = align_padding(sec.size, d.align::usize);
        sec.size = sec.size + pad;

        val offset: usize = section.current_offset(sec);
        sec.size = sec.size + d.data_len::usize;

        if (d.align::usize > sec.align) {
            section.set_align(sec, d.align::usize);
        }

        register_data_sym(obj, alloc, d, sec_name, offset, d.data_len::usize);
        ret;
    }

    val sec_r: Result[*section.Section, str] =
        objstate.get_or_create_section(obj, sec_name, d.section);
    if (result_is_err[*section.Section, str](sec_r)) { ret; }

    val sec: *section.Section = result_unwrap_ok[*section.Section, str](sec_r);

    val pad: usize = align_padding(sec.size, d.align::usize);
    var pi: usize = 0;
    for (pi < pad) {
        section.emit_byte(alloc, sec, 0);
        pi = pi + 1;
    }

    val offset: usize = section.current_offset(sec);

    if (d.data != nil && d.data_len > 0) {
        section.emit_bytes(alloc, sec, d.data, d.data_len::usize);
    }

    if (d.align::usize > sec.align) {
        section.set_align(sec, d.align::usize);
    }

    var ri: i32 = 0;
    for (ri < d.reloc_count) {
        val r: *data.DeclReloc = ?d.relocs[ri];
        section.add_relocation(alloc, sec, offset + r.offset::usize,
                               r.target, r.kind, r.addend);
        ri = ri + 1;
    }

    register_data_sym(obj, alloc, d, sec_name, offset, d.data_len::usize);
}

fun register_data_sym(obj: *objstate.ObjState, alloc: *allocator.Allocator,
                      d: *data.DataDecl, sec_name: str,
                      offset: usize, size: usize) {
    val alloc_r: Result[*msym.Symbol, allocator.AllocError] =
        allocator.allocator_alloc[msym.Symbol](alloc, 1);
    if (result_is_err[*msym.Symbol, allocator.AllocError](alloc_r)) { ret; }

    val s: *msym.Symbol = result_unwrap_ok[*msym.Symbol, allocator.AllocError](alloc_r);
    @s = msym.init(d.name);
    s.binding = d.binding;
    s.sym_type = d.sym_type;
    s.offset = offset;
    s.size = size;
    s.defined = true;
    s.src_file = d.src_file;
    s.src_line = d.src_line;

    val sec_idx: i32 = objstate.get_section_index(obj, sec_name);
    if (sec_idx >= 0) {
        s.section = sec_idx::u64;
    }

    objstate.add_symbol(obj, s);
}
