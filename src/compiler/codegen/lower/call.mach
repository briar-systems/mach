use std.types.bool;
use std.types.size;
use std.types.string;

use ast:    mach.compiler.frontend.ast;
use type:     mach.compiler.frontend.type;
use op:      masm.op;
use operand: mach.compiler.masm.operand;
use abi:    mach.compiler.target.abi;

use mach.compiler.codegen.lower;

# mach.compiler.codegen.lower.call: ABI-driven call lowering.
# ---
# translates function call AST nodes into IR instructions.
# emits OP_ARG for each argument and an extended OP_CALL with return type
# metadata. the ABI lowering pass expands these to physical register MOVs.

# emit_call: lower a function call.
# callee: call target operand (label for direct calls, register for indirect)
# args: array of already-lowered argument operands
# arg_types: corresponding types for each argument
# arg_count: number of arguments
# ret_type: return type (nil for void)
# is_variadic: true if the callee is variadic
pub fun emit_call(ctx: *LowerContext, callee: operand.Operand,
                  args: *operand.Operand, arg_types: **type.Type,
                  arg_count: i32, ret_type: *type.Type,
                  is_variadic: bool) operand.Operand {
    if (ctx == nil) { ret operand.make_none(); }

    val a: *abi.ABI = ?ctx.target.abi;
    val psz: u8 = ctx.ptr_size;

    # --- classify return value (sret detection only) ---
    var sret_mem: operand.Operand = operand.make_none();
    var has_sret: bool = false;
    var ret_size: usize = 0;
    var ret_align: usize = 0;
    var ret_is_float: bool = false;
    var ret_is_agg: bool = false;

    if (ret_type != nil && !type.type_is_void(ret_type)) {
        ret_size = type_size(ctx, ret_type);
        ret_align = type.type_align(ret_type);
        ret_is_float = is_float_type(ret_type);
        ret_is_agg = type.type_is_record(ret_type) || type.type_is_union(ret_type);

        val ret_slot: abi.ParamSlot = a.classify_return(a.ctx, ret_size, ret_align,
                                                          ret_is_float, ret_is_agg);

        if (ret_slot.class == abi.CLASS_SRET) {
            # allocate stack space for struct return
            val lv: *LocalVar = local_add(ctx, ".sret_tmp", ret_type, ret_size);
            if (lv != nil) {
                sret_mem = local_operand(lv, psz);
                val sret_ptr: operand.Operand = new_vreg(ctx, psz);
                emit(ctx, op.OP_ADDR, sret_ptr, sret_mem, operand.make_none(), op.CC_NONE);

                # emit sret as hidden argument at index -1
                emit(ctx, op.OP_ARG,
                     operand.make_imm(psz::i64, psz),
                     operand.make_imm(-1, 0),
                     sret_ptr, op.CC_NONE);

                has_sret = true;
            }
        }
    }

    # --- emit OP_ARG for each argument ---
    var i: i32 = 0;
    for (i < arg_count) {
        val arg_type: *type.Type = arg_types[i];
        val arg_size: usize = type_size(ctx, arg_type);
        val arg_align: usize = type.type_align(arg_type);
        val af: bool = is_float_type(arg_type);
        val aa: bool = type.type_is_record(arg_type) || type.type_is_union(arg_type);

        var flags: u8 = 0;
        if (af) { flags = flags | operand.ABI_FLAG_FLOAT; }
        if (aa) { flags = flags | operand.ABI_FLAG_AGG; }

        var arg_op: operand.Operand = args[i];
        if (aa && arg_op.kind == operand.OPK_MEM) {
            if (arg_size <= psz::usize) {
                val tmp: operand.Operand = new_vreg(ctx, arg_size::u8);
                emit_load(ctx, tmp, arg_op);
                arg_op = tmp;
            } or {
                val tmp: operand.Operand = new_vreg(ctx, psz);
                emit(ctx, op.OP_ADDR, tmp, arg_op, operand.make_none(), op.CC_NONE);
                arg_op = tmp;
            }
        }

        emit(ctx, op.OP_ARG,
             operand.make_imm(arg_size::i64, arg_align::u8),
             operand.make_imm(i::i64, flags),
             arg_op, op.CC_NONE);

        i = i + 1;
    }

    # --- emit OP_CALL ---
    var call_flags: u8 = 0;
    if (is_variadic) { call_flags = call_flags | operand.CALL_VARIADIC; }

    # void or sret return: no return value to extract
    if (ret_type == nil || type.type_is_void(ret_type) || has_sret) {
        emit(ctx, op.OP_CALL, callee, operand.make_none(), operand.make_none(), call_flags);
        if (has_sret) { ret sret_mem; }
        ret operand.make_none();
    }

    # encode return type info for ABI pass
    if (ret_is_float) { call_flags = call_flags | operand.CALL_RET_FLOAT; }
    if (ret_is_agg)   { call_flags = call_flags | operand.CALL_RET_AGG; }
    val ret_info: operand.Operand = operand.make_imm(ret_size::i64, ret_align::u8);

    if (ret_is_agg) {
        # aggregate return: allocate local for ABI pass to store into
        val lv: *LocalVar = local_add(ctx, ".agg_ret", ret_type, ret_size);
        if (lv == nil) { ret operand.make_none(); }
        val dst_mem: operand.Operand = local_operand(lv, psz);
        if (ret_size <= psz::usize) {
            val result: operand.Operand = new_vreg(ctx, ret_size::u8);
            emit(ctx, op.OP_CALL, callee, ret_info, result, call_flags);
            emit_store(ctx, dst_mem, result);
            ret dst_mem;
        }
        val dst_ptr: operand.Operand = new_vreg(ctx, psz);
        emit(ctx, op.OP_ADDR, dst_ptr, dst_mem, operand.make_none(), op.CC_NONE);
        emit(ctx, op.OP_CALL, callee, ret_info, dst_ptr, call_flags);
        ret dst_mem;
    }

    # scalar/float return: allocate vreg
    val result: operand.Operand = new_vreg(ctx, type_size_u8(ctx, ret_type));
    emit(ctx, op.OP_CALL, callee, ret_info, result, call_flags);
    ret result;
}
