use std.types.bool;
use std.types.size;

# mach.compiler.codegen.lower.operand: lowering-local value representation.
# ---
# tagged value type used exclusively by lowering code to represent
# intermediate results (register values, immediates, memory locations,
# labels) before they are encoded into compact IR instructions.
# this type does not leak to the ISA layer or any other pipeline stage.

pub def ValueKind: u8;

pub val OPK_NONE:   ValueKind = 0;
pub val OPK_REG:    ValueKind = 1;
pub val OPK_IMM:    ValueKind = 2;
pub val OPK_MEM:    ValueKind = 3;
pub val OPK_LABEL:  ValueKind = 4;
pub val OPK_SYM:    ValueKind = 5;

pub rec Operand {
    kind:   ValueKind;
    size:   u8;
    reg:    i32;
    imm:    i64;
    base:   i32;
    index:  i32;
    scale:  i32;
    disp:   i64;
    sym_id: u64;
    label:  str;
}

pub fun make_none() Operand {
    var o: Operand;
    o.kind = OPK_NONE;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = -1;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_reg(reg: i32, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_REG;
    o.size = size;
    o.reg = reg;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_imm(imm: i64, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_IMM;
    o.size = size;
    o.reg = 0;
    o.imm = imm;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_mem(base: i32, index: i32, scale: i32, disp: i64, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_MEM;
    o.size = size;
    o.reg = 0;
    o.imm = 0;
    o.base = base;
    o.index = index;
    o.scale = scale;
    o.disp = disp;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_label(label: str) Operand {
    var o: Operand;
    o.kind = OPK_LABEL;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = label;
    ret o;
}

pub fun make_sym(sym_id: u64) Operand {
    var o: Operand;
    o.kind = OPK_SYM;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = sym_id;
    o.label = nil;
    ret o;
}

pub fun none() Operand  { ret make_none(); }
pub fun reg(r: i32, size: u8) Operand { ret make_reg(r, size); }
pub fun imm(value: i64, size: u8) Operand { ret make_imm(value, size); }

pub fun mem(base: i32, disp: i64, size: u8) Operand {
    ret make_mem(base, -1, 1, disp, size);
}

pub fun mem_idx(base: i32, index: i32, scale: i32, disp: i64, size: u8) Operand {
    ret make_mem(base, index, scale, disp, size);
}

pub fun label(name: str) Operand { ret make_label(name); }
pub fun sym(id: u64) Operand { ret make_sym(id); }

pub fun is_none(o: *Operand) bool {
    if (o == nil) { ret true; }
    ret o.kind == OPK_NONE;
}

pub fun is_reg(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_REG;
}

pub fun is_imm(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_IMM;
}

pub fun is_mem(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_MEM;
}

pub fun is_label(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_LABEL;
}

pub fun is_sym(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_SYM;
}

pub fun kind_name(kind: ValueKind) str {
    if (kind == OPK_NONE)  { ret "none"; }
    if (kind == OPK_REG)   { ret "reg"; }
    if (kind == OPK_IMM)   { ret "imm"; }
    if (kind == OPK_MEM)   { ret "mem"; }
    if (kind == OPK_LABEL) { ret "label"; }
    if (kind == OPK_SYM)   { ret "sym"; }
    ret "unknown";
}
