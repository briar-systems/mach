use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.codegen.mangle: name mangling for symbol linkage.
# ---
# computes mangled symbol names for module-level linkage.
# scheme: _M<encoded_module_path>N<name_len><name>
# where encoded_module_path has length-prefixed segments.
# e.g., module_path="std.print", name="eprintln" -> "_M3std5printN8eprintln"

fun digits_len(n: usize) usize {
    if (n == 0) { ret 1; }
    var count: usize = 0;
    var v: usize = n;
    for (v > 0) {
        count = count + 1;
        v = v / 10;
    }
    ret count;
}

fun write_digits(buf: *u8, pos: usize, n: usize) usize {
    if (n == 0) {
        buf[pos] = '0';
        ret pos + 1;
    }
    val dlen: usize = digits_len(n);
    var i: usize = pos + dlen;
    var v: usize = n;
    for (v > 0) {
        i = i - 1;
        buf[i] = (v % 10)::u8 + '0';
        v = v / 10;
    }
    ret pos + dlen;
}

# compute the mangled name for a symbol.
# ---
# alloc:       allocator for the result string
# module_path: dot-separated module path (e.g. "std.print")
# name:        symbol name (e.g. "eprintln")
# ret:         mangled name, or name if module_path is nil
pub fun mangle(alloc: *allocator.Allocator, module_path: str, name: str) str {
    if (alloc == nil || name == nil) {
        ret nil;
    }

    if (module_path == nil) {
        ret name;
    }

    val name_len: usize = str_len(name);

    var total: usize = 2;  # "_M"

    val path_len: usize = str_len(module_path);
    var seg_start: usize = 0;
    var pi: usize = 0;
    for (pi <= path_len) {
        if (pi == path_len || module_path[pi] == '.') {
            val seg_len: usize = pi - seg_start;
            if (seg_len > 0) {
                total = total + digits_len(seg_len) + seg_len;
            }
            seg_start = pi + 1;
        }
        pi = pi + 1;
    }

    total = total + 1;  # "N"
    total = total + digits_len(name_len) + name_len;
    total = total + 1;  # null terminator

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret name;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    buf[0] = '_';
    buf[1] = 'M';
    var pos: usize = 2;

    seg_start = 0;
    pi = 0;
    for (pi <= path_len) {
        if (pi == path_len || module_path[pi] == '.') {
            val seg_len: usize = pi - seg_start;
            if (seg_len > 0) {
                pos = write_digits(buf, pos, seg_len);
                var si: usize = 0;
                for (si < seg_len) {
                    buf[pos] = module_path[seg_start + si];
                    pos = pos + 1;
                    si = si + 1;
                }
            }
            seg_start = pi + 1;
        }
        pi = pi + 1;
    }

    buf[pos] = 'N';
    pos = pos + 1;

    pos = write_digits(buf, pos, name_len);
    var ni: usize = 0;
    for (ni < name_len) {
        buf[pos] = name[ni];
        pos = pos + 1;
        ni = ni + 1;
    }

    buf[pos] = 0;

    ret buf::str;
}

# determine the linkage name for a symbol.
# ---
# returns the appropriate name for use in object files:
# - export_name if set (explicit override)
# - unmangled name if is_external (external symbols are never mangled)
# - mangled name if module_path is set
# - bare name otherwise
pub fun linkage_name(alloc: *allocator.Allocator, name: str, module_path: str,
                     export_name: str, is_external: bool) str {
    if (name == nil) {
        ret nil;
    }
    if (export_name != nil) {
        ret export_name;
    }
    if (is_external) {
        ret name;
    }
    if (module_path != nil && alloc != nil) {
        ret mangle(alloc, module_path, name);
    }
    ret name;
}
