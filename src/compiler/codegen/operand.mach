use std.types.bool;
use std.types.size;
use std.types.string;

use op:   masm.op;
use inst: masm.inst;
use fn:   masm.function;
use pool: masm.pool;
use ir:   mach.compiler.codegen.ir;

# mach.compiler.codegen.operand: operand constructors, query helpers, and
# compact-IR-to-Operand reconstruction.
# ---
# the Operand record lives in ir.mach (compiler-internal); everything that
# builds or queries one lives here.

pub fun make_none() ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_NONE;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = -1;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_reg(reg: i32, size: u8) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_REG;
    o.size = size;
    o.reg = reg;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_imm(imm: i64, size: u8) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_IMM;
    o.size = size;
    o.reg = 0;
    o.imm = imm;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_mem(base: i32, index: i32, scale: i32, disp: i64, size: u8) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_MEM;
    o.size = size;
    o.reg = 0;
    o.imm = 0;
    o.base = base;
    o.index = index;
    o.scale = scale;
    o.disp = disp;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_label(label: str) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_LABEL;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = label;
    ret o;
}

pub fun make_sym(sym_id: u64) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_SYM;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = sym_id;
    o.label = nil;
    ret o;
}

pub fun none() ir.Operand  { ret make_none(); }
pub fun reg(r: i32, size: u8) ir.Operand { ret make_reg(r, size); }
pub fun imm(value: i64, size: u8) ir.Operand { ret make_imm(value, size); }

pub fun mem(base: i32, disp: i64, size: u8) ir.Operand {
    ret make_mem(base, -1, 1, disp, size);
}

pub fun mem_idx(base: i32, index: i32, scale: i32, disp: i64, size: u8) ir.Operand {
    ret make_mem(base, index, scale, disp, size);
}

pub fun label(name: str) ir.Operand { ret make_label(name); }
pub fun sym(id: u64) ir.Operand { ret make_sym(id); }

pub fun is_none(o: *ir.Operand) bool {
    if (o == nil) { ret true; }
    ret o.kind == ir.OPK_NONE;
}

pub fun is_reg(o: *ir.Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == ir.OPK_REG;
}

pub fun is_imm(o: *ir.Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == ir.OPK_IMM;
}

pub fun is_mem(o: *ir.Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == ir.OPK_MEM;
}

pub fun is_label(o: *ir.Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == ir.OPK_LABEL;
}

pub fun is_sym(o: *ir.Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == ir.OPK_SYM;
}

pub fun kind_name(kind: ir.ValueKind) str {
    if (kind == ir.OPK_NONE)  { ret "none"; }
    if (kind == ir.OPK_REG)   { ret "reg"; }
    if (kind == ir.OPK_IMM)   { ret "imm"; }
    if (kind == ir.OPK_MEM)   { ret "mem"; }
    if (kind == ir.OPK_LABEL) { ret "label"; }
    if (kind == ir.OPK_SYM)   { ret "sym"; }
    ret "unknown";
}

# pool-resolved accessors (f2 is DataPool byte offset)
pub fun imm32(i: *inst.Instruction, func: *fn.Function) i32 {
    ret pool.data_get_i32(?func.data_pool, i.f2::i32);
}
pub fun disp(i: *inst.Instruction, func: *fn.Function) i32 {
    ret pool.data_get_i32(?func.data_pool, i.f2::i32);
}

# indexed memory unpacking (flag=1)
pub fun mem_index(i: *inst.Instruction, func: *fn.Function) u16 {
    val packed: i32 = pool.data_get_i32(?func.data_pool, i.f2::i32);
    ret (packed >> 16)::u16;
}
pub fun mem_scale(i: *inst.Instruction) u8  { ret 1 << (inst.cc(i) & 3); }
pub fun mem_disp16(i: *inst.Instruction, func: *fn.Function) i16 {
    val packed: i32 = pool.data_get_i32(?func.data_pool, i.f2::i32);
    ret packed::i16;
}

# inst_to_dst_operand: reconstruct destination Operand from compact Instruction.
pub fun inst_to_dst_operand(i: *inst.Instruction, func: *fn.Function) ir.Operand {
    val o: u8 = i.op;
    val sz: u8 = inst.size(i);

    if (o == op.OP_STORE) {
        if (inst.flag(i) != 0) {
            ret make_mem(i.f1::i32, mem_index(i, func)::i32,
                         mem_scale(i)::i32, mem_disp16(i, func)::i64, sz);
        }
        ret make_mem(i.f1::i32, -1, 1, disp(i, func)::i64, sz);
    }

    if (o == op.OP_JMP || o == op.OP_BRANCH || o == op.OP_LABEL) {
        val name: str = pool.label_get(?func.labels, i.f2::i32);
        ret make_label(name);
    }

    if (o == op.OP_CALL) {
        if (inst.flag(i) == 0) {
            val name: str = pool.label_get(?func.labels, i.f2::i32);
            ret make_label(name);
        }
        ret make_reg(i.f1::i32, 8);
    }

    if (o == op.OP_CMP) {
        ret make_reg(i.f0::i32, 1);
    }

    ret make_reg(i.f0::i32, sz);
}

# inst_to_src1_operand: reconstruct src1 Operand from compact Instruction.
pub fun inst_to_src1_operand(i: *inst.Instruction, func: *fn.Function) ir.Operand {
    val o: u8 = i.op;
    val sz: u8 = inst.size(i);

    if (o == op.OP_ADDR && inst.cc(i) == 1) {
        val name: str = pool.label_get(?func.labels, i.f2::i32);
        ret make_label(name);
    }

    if (o == op.OP_LOAD || o == op.OP_ADDR) {
        if (inst.flag(i) != 0) {
            ret make_mem(i.f1::i32, mem_index(i, func)::i32,
                         mem_scale(i)::i32, mem_disp16(i, func)::i64, sz);
        }
        ret make_mem(i.f1::i32, -1, 1, disp(i, func)::i64, sz);
    }

    if (o == op.OP_MOV && inst.flag(i) != 0) {
        val value: u64 = pool.const_get(?func.const_pool, i.f2::i32);
        ret make_imm(value::i64, sz);
    }

    if (o == op.OP_MOV && inst.cc(i) == 1) {
        ret make_imm(imm32(i, func)::i64, sz);
    }

    if (o == op.OP_BRANCH) {
        ret make_reg(i.f0::i32, 1);
    }

    if (o == op.OP_STORE) {
        ret make_reg(i.f0::i32, sz);
    }

    if (o == op.OP_CONV && inst.cc(i) == op.CONV_FTOI) {
        var src_sz: u8 = i.f2::u8;
        if (src_sz == 0) { src_sz = sz; }
        ret make_reg(i.f1::i32, src_sz);
    }

    ret make_reg(i.f1::i32, sz);
}

# inst_to_src2_operand: reconstruct src2 Operand from compact Instruction.
pub fun inst_to_src2_operand(i: *inst.Instruction) ir.Operand {
    val o: u8 = i.op;
    val sz: u8 = inst.size(i);

    if (o >= op.OP_ADD && o <= op.OP_SHR) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }
    if (o == op.OP_CMP) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }
    if (o == ir.OP_MEMSET) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }

    ret make_none();
}
