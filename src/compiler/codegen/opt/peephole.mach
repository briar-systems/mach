use std.types.bool;
use std.types.size;

use allocator: std.allocator;
use inst:      masm.inst;
use op:        masm.op;
use fn:        masm.function;

# mach.compiler.codegen.opt.peephole: IR-level peephole optimizer.
# ---
# runs pattern-matching rules over compact 8-byte IR instructions to eliminate
# redundancy before instruction selection. operates in-place on Block instruction
# arrays, marking eliminated instructions as NOP then compacting.

pub rec OptContext {
    alloc:      *allocator.Allocator;
    eliminated: i32;
}

pub fun init(alloc: *allocator.Allocator) OptContext {
    var ctx: OptContext;
    ctx.alloc = alloc;
    ctx.eliminated = 0;
    ret ctx;
}

pub fun optimize_function(ctx: *OptContext, func: *fn.Function) {
    if (ctx == nil || func == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < func.blocks.len::i32) {
        val block: *fn.Block = func.blocks.data[i];
        if (block != nil) {
            optimize_block(ctx, block);
        }
        i = i + 1;
    }
}

fun optimize_block(ctx: *OptContext, block: *fn.Block) {
    if (block == nil || block.insts == nil || block.inst_count == 0) {
        ret;
    }

    var changed: bool = true;
    for (changed) {
        changed = false;
        if (rule_self_move(ctx, block))            { changed = true; }
        if (rule_redundant_store_load(ctx, block)) { changed = true; }
    }

    compact_block(block);
}

fun is_mov_reg_reg(ir: *inst.Instruction) bool {
    if (ir.op != op.OP_MOV) { ret false; }
    ret inst.cc(ir) == 0 && inst.flag(ir) == 0;
}

fun mark_nop(ctx: *OptContext, ir: *inst.Instruction) {
    ir.op = op.OP_NOP;
    ir.meta = 0;
    ir.f0 = 0;
    ir.f1 = 0;
    ir.f2 = 0;
    ctx.eliminated = ctx.eliminated + 1;
}

# rule_self_move: eliminate MOV rX, rX (register to itself).
fun rule_self_move(ctx: *OptContext, block: *fn.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val ir: *inst.Instruction = ?block.insts[i];
        if (is_mov_reg_reg(ir) && ir.f0 == ir.f1) {
            mark_nop(ctx, ir);
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_redundant_store_load: eliminate LOAD after STORE to the same address.
# pattern: STORE [base+disp], rX followed by LOAD rY, [base+disp]
# replace LOAD with MOV rY, rX (or NOP if rY == rX).
fun rule_redundant_store_load(ctx: *OptContext, block: *fn.Block) bool {
    var changed: bool = false;
    if (block.inst_count < 2) { ret false; }

    var i: i32 = 0;
    for (i < block.inst_count - 1) {
        val store: *inst.Instruction = ?block.insts[i];
        val load:  *inst.Instruction = ?block.insts[i + 1];

        if (store.op == op.OP_STORE && load.op == op.OP_LOAD
            && store.f1 == load.f1 && store.f2 == load.f2
            && (store.meta & 0x0F) == (load.meta & 0x0F)) {
            if (load.f0 == store.f0) {
                mark_nop(ctx, load);
            } or {
                val sz: u8 = inst.size(store);
                @load = inst.make_unary(op.OP_MOV, load.f0, store.f0, sz);
            }
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

fun compact_block(block: *fn.Block) {
    if (block == nil || block.insts == nil) { ret; }

    var write: i32 = 0;
    var read: i32 = 0;
    for (read < block.inst_count) {
        if (block.insts[read].op != op.OP_NOP) {
            if (write != read) {
                block.insts[write] = block.insts[read];
                if (block.debug_locs != nil) {
                    block.debug_locs[write] = block.debug_locs[read];
                }
            }
            write = write + 1;
        }
        read = read + 1;
    }
    block.inst_count = write;
}
