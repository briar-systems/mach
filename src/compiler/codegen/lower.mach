use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;

use ast:     mach.compiler.frontend.ast;
use symbol:  mach.compiler.frontend.symbol;
use type:      mach.compiler.frontend.type;
use target:  mach.compiler.target;
use op:      masm.op;
use inst:    masm.inst;
use ir:      mach.compiler.codegen.ir;
use fn:      mach.compiler.masm.function;
use pools:   mach.compiler.masm.pools;
use operand: mach.compiler.codegen.operand;
use module:  mach.compiler.masm.module;
use section: mach.compiler.codegen.section;
use sym:     masm.symbol;
use mangle:  mach.compiler.codegen.mangle;
use abi:      mach.compiler.target.abi;
use typedesc: masm.typedesc;
use vec:      std.collections.vector;

# mach.compiler.codegen.lower: AST → MASM IR lowering.
# ---
# transforms typed AST (sema output) into target-independent MASM IR.
# all target-dependent decisions go through *target.Target interfaces.
# lowering NEVER produces ISA-specific instructions — ISel does that.

# --- local variable tracking ---

pub rec LocalVar {
    name:     str;
    type:       *type.Type;
    offset:   i64;       # stack offset from frame pointer
    is_param: bool;
    size:     usize;
}

val INITIAL_LOCAL_CAP: i32 = 32;
val INITIAL_DEFER_CAP: i32 = 8;

# --- lowering context ---

pub rec LoopState {
    start: str;
    end:   str;
}

pub rec DeferState {
    stmts: **ast.Node;
    count: i32;
    cap:   i32;
    mark:  i32;
}

pub rec ReturnState {
    type:       *type.Type;
    has_sret:   bool;
    sret_slot:  ir.Operand;
    is_variadic: bool;
    va_reg_save_off: i64;
    va_named_gp:     i32;
    va_named_fp:     i32;
    va_named_stack:  i32;
}

pub rec LowerContext {
    alloc:          *allocator.Allocator;
    target:         *target.Target;
    builder:        *module.ModuleBuilder;

    # input
    symbols:        *symbol.Table;

    # current function state
    current_fn:     *fn.Function;
    current_block:  *fn.Block;

    # virtual register allocation
    vreg_next:      i32;

    # counters
    label_counter:  i32;
    str_counter:    i32;

    # local variables
    local_vars:     *LocalVar;
    local_count:    i32;
    local_cap:      i32;
    stack_offset:   i64;

    # per-function local_size accumulator (shared across contexts)
    local_sizes:    *vec.Vector[usize];

    # function return state
    rs: ReturnState;

    # loop state
    ls: LoopState;

    # deferred statements
    ds: DeferState;

    # debug info
    current_file:   u16;
    current_line:   i32;
    debug_file_path: str;
    debug_source:    str;

    # pointer size cache (from target)
    ptr_size:       u8;
}

# --- context lifecycle ---

pub fun create(alloc: *allocator.Allocator, tgt: *target.Target,
               builder: *module.ModuleBuilder, symbols: *symbol.Table,
               file_path: str, source: str,
               local_sizes: *vec.Vector[usize]) Result[LowerContext, str] {
    if (alloc == nil || tgt == nil || builder == nil) {
        ret err[LowerContext, str]("invalid arguments");
    }

    var ctx: LowerContext;
    ctx.alloc = alloc;
    ctx.target = tgt;
    ctx.builder = builder;
    ctx.symbols = symbols;
    ctx.current_fn = nil;
    ctx.current_block = nil;
    ctx.vreg_next = inst.VREG_START;
    ctx.label_counter = 0;
    ctx.str_counter = 0;
    ctx.stack_offset = 0;
    ctx.rs.type = nil;
    ctx.rs.has_sret = false;
    ctx.rs.is_variadic = false;
    ctx.rs.va_reg_save_off = 0;
    ctx.rs.va_named_gp = 0;
    ctx.rs.va_named_fp = 0;
    ctx.rs.va_named_stack = 0;
    ctx.ls.start = nil;
    ctx.ls.end = nil;
    ctx.ds.count = 0;
    ctx.ds.mark = 0;
    ctx.current_file = 0;
    ctx.current_line = 0;
    ctx.debug_file_path = file_path;
    ctx.debug_source = source;
    ctx.ptr_size = tgt.isa.ptr_size::u8;
    ctx.local_sizes = local_sizes;

    # register debug file with module builder
    if (file_path != nil) {
        ctx.current_file = module.builder_add_debug_file(builder, file_path);
    }

    # allocate local vars array
    val lv_r: Result[*LocalVar, allocator.AllocError] =
        allocator.allocator_zalloc[LocalVar](alloc, INITIAL_LOCAL_CAP::usize);
    if (!lv_r.tag) {
        ret err[LowerContext, str]("out of memory");
    }
    ctx.local_vars = lv_r.value.ok;
    ctx.local_count = 0;
    ctx.local_cap = INITIAL_LOCAL_CAP;

    # allocate deferred array
    val df_r: Result[**ast.Node, allocator.AllocError] =
        allocator.allocator_zalloc[*ast.Node](alloc, INITIAL_DEFER_CAP::usize);
    if (!df_r.tag) {
        ret err[LowerContext, str]("out of memory");
    }
    ctx.ds.stmts = df_r.value.ok;
    ctx.ds.cap = INITIAL_DEFER_CAP;

    ret ok[LowerContext, str](ctx);
}

# --- virtual register allocation ---

pub fun new_vreg(ctx: *LowerContext, size: u8) ir.Operand {
    val id: i32 = ctx.vreg_next;
    ctx.vreg_next = ctx.vreg_next + 1;
    ret operand.make_reg(id, size);
}

# --- label generation ---

pub fun new_label(ctx: *LowerContext, prefix: str) str {
    ctx.label_counter = ctx.label_counter + 1;
    # format: "<prefix>_<counter>" — unique per lowering context
    val buf_r: Result[*u8, allocator.AllocError] =
        allocator.allocator_alloc[u8](ctx.alloc, 64);
    if (!buf_r.tag) { ret prefix; }
    val buf: *u8 = buf_r.value.ok;

    # copy prefix
    var pos: usize = 0;
    if (prefix != nil) {
        var pi: usize = 0;
        for (prefix[pi] != 0 && pos < 50) {
            buf[pos] = prefix[pi];
            pos = pos + 1;
            pi = pi + 1;
        }
    }

    # append underscore separator
    buf[pos] = '_';
    pos = pos + 1;

    # append counter digits
    val counter: i32 = ctx.label_counter;
    if (counter == 0) {
        buf[pos] = '0';
        pos = pos + 1;
    } or {
        var dlen: usize = 0;
        var tmp: i32 = counter;
        for (tmp > 0) { dlen = dlen + 1; tmp = tmp / 10; }
        var i: usize = pos + dlen;
        tmp = counter;
        for (tmp > 0) {
            i = i - 1;
            buf[i] = (tmp % 10)::u8 + '0';
            tmp = tmp / 10;
        }
        pos = pos + dlen;
    }

    buf[pos] = 0;
    ret buf::str;
}

pub fun new_label_id(ctx: *LowerContext) i32 {
    ctx.label_counter = ctx.label_counter + 1;
    ret ctx.label_counter;
}

# --- instruction emission ---

# emit_inst: append a pre-built compact instruction to the current block.
pub fun emit_inst(ctx: *LowerContext, inst: inst.Instruction) {
    if (ctx == nil || ctx.current_block == nil) { ret; }
    val idx: i32 = fn.block_append(ctx.alloc, ctx.current_block, inst);
    if (idx >= 0 && ctx.current_line > 0) {
        fn.block_set_debug(ctx.current_block, idx,
                           ctx.current_line, ctx.current_file);
    }
}

# intern_label: intern a label string in the current function's label table.
pub fun intern_label(ctx: *LowerContext, name: str) i32 {
    if (ctx == nil || ctx.current_fn == nil) { ret -1; }
    ret pools.label_intern(ctx.alloc, ?ctx.current_fn.labels, name);
}

# intern_const: intern a value in the current function's constant pool.
pub fun intern_const(ctx: *LowerContext, value: i64) i32 {
    if (ctx == nil || ctx.current_fn == nil) { ret -1; }
    ret pools.const_intern(ctx.alloc, ?ctx.current_fn.const_pool, value::u64);
}

# intern_data_i32: intern an i32 value in the current function's data pool.
pub fun intern_data_i32(ctx: *LowerContext, value: i32) u16 {
    if (ctx == nil || ctx.current_fn == nil) { ret 0; }
    ret pools.data_intern_i32(ctx.alloc, ?ctx.current_fn.data_pool, value)::u16;
}

# intern_type_desc: create and intern a type descriptor for ABI classification.
fun intern_td(ctx: *LowerContext, byte_size: usize, align: u8,
              is_float: bool, is_agg: bool) u16 {
    if (ctx == nil || ctx.current_fn == nil) { ret ir.TD_NONE; }
    var desc: typedesc.TypeDesc;
    if (is_agg) {
        desc = typedesc.make_agg(byte_size::u16, align, nil, 0);
    } or (is_float) {
        desc = typedesc.make_float(byte_size::u16, align);
    } or {
        desc = typedesc.make_int(byte_size::u16, align);
    }
    val idx: i32 = typedesc.intern(?ctx.current_fn.type_descs, desc);
    if (idx < 0) { ret ir.TD_NONE; }
    ret idx::u16;
}

# --- Operand→compact Inst conversion ---
# lowering files continue to use Operand-based interface; conversion
# to compact 8-byte Inst happens here at the emit boundary.

# operand_to_reg: extract u16 register ID from an Operand.
# caller must ensure operand is OPK_REG; non-register operands return 0.
fun operand_to_reg(op: &ir.Operand) u16 {
    if (op.kind == ir.OPK_REG) { ret op.reg::u16; }
    ret 0;
}

# materialize_to_reg: ensure an operand is in a virtual register.
# ABI-abstract opcodes pack only a register ID into the compact Inst,
# so non-REG operands must be materialized first:
#   OPK_REG  -> returned as-is
#   OPK_IMM  -> OP_MOV imm -> vreg
#   OPK_MEM  -> OP_LOAD mem -> vreg (loads value from memory)
#   OPK_NONE -> returns reg 0 (caller should handle)
fun materialize_to_reg(ctx: *LowerContext, op: ir.Operand, size: u8) u16 {
    if (op.kind == ir.OPK_REG) { ret op.reg::u16; }
    if (op.kind == ir.OPK_IMM) {
        val tmp: ir.Operand = new_vreg(ctx, size);
        emit_mov(ctx, tmp, op);
        ret tmp.reg::u16;
    }
    if (op.kind == ir.OPK_MEM) {
        val tmp: ir.Operand = new_vreg(ctx, size);
        emit(ctx, op.OP_LOAD, tmp, op, operand.make_none(), op.CC_NONE);
        ret tmp.reg::u16;
    }
    ret 0;
}

# emit_mem_inst: emit a memory instruction (LOAD, STORE, ADDR) from Operands.
fun emit_mem_inst(ctx: *LowerContext, op: u8, reg: u16,
                  mem: &ir.Operand, size: u8) {
    var inst: inst.Instruction;
    if (mem.index >= 0) {
        val pi: u16 = intern_data_i32(ctx, inst.pack_indexed(mem.index::u16, mem.disp::i16));
        if (op == op.OP_STORE) {
            inst = inst.make_store_indexed(reg, mem.base::u16, pi, mem.scale::u8, size);
        } or (op == op.OP_ADDR) {
            inst = inst.make_addr_indexed(reg, mem.base::u16, pi, mem.scale::u8, size);
        } or {
            inst = inst.make_load_indexed(reg, mem.base::u16, pi, mem.scale::u8, size);
        }
    } or {
        val di: u16 = intern_data_i32(ctx, mem.disp::i32);
        if (op == op.OP_STORE) {
            inst = inst.make_store(reg, mem.base::u16, di, size);
        } or (op == op.OP_ADDR) {
            inst = inst.make_addr(reg, mem.base::u16, di, size);
        } or {
            inst = inst.make_load(reg, mem.base::u16, di, size);
        }
    }
    emit_inst(ctx, inst);
}

# emit: Operand-based emit — converts to compact Inst at the boundary.
# this is the main entry point for lowering files.
pub fun emit(ctx: *LowerContext, op: op.Operator, dst: ir.Operand,
             src1: ir.Operand, src2: ir.Operand, cc: op.Cond) {
    if (ctx == nil || ctx.current_block == nil) { ret; }

    # determine effective size
    var sz: u8 = dst.size;
    if (sz == 0) { sz = src1.size; }
    if (sz == 0) { sz = src2.size; }

    # --- control flow ---
    if (op == op.OP_LABEL) {
        val li: u16 = intern_label(ctx, dst.label)::u16;
        emit_inst(ctx, inst.make_label(li));
        ret;
    }
    if (op == op.OP_JMP) {
        val li: u16 = intern_label(ctx, dst.label)::u16;
        emit_inst(ctx, inst.make_jmp(li));
        ret;
    }
    if (op == ir.OP_BRCOND) {
        val li: u16 = intern_label(ctx, dst.label)::u16;
        val cond_reg: u16 = materialize_to_reg(ctx, src1, sz);
        emit_inst(ctx, inst.make_branch(cond_reg, li, cc));
        ret;
    }
    if (op == op.OP_RET) {
        emit_inst(ctx, inst.make_ret());
        ret;
    }
    if (op == op.OP_SYSCALL) {
        if (dst.kind == ir.OPK_MEM) {
            val tmp: ir.Operand = new_vreg(ctx, sz);
            emit_inst(ctx, inst.make_syscall(tmp.reg::u16));
            emit_mem_inst(ctx, op.OP_STORE, tmp.reg::u16, ?dst, sz);
        } or {
            val result_reg: u16 = operand_to_reg(?dst);
            emit_inst(ctx, inst.make_syscall(result_reg));
        }
        ret;
    }
    if (op == ir.OP_NOP) {
        emit_inst(ctx, ir.mk_nop());
        ret;
    }

    # --- CALL ---
    if (op == op.OP_CALL) {
        # pre-ABI CALL: dst=callee, src1=ret type info or none, src2=result
        # direct (flag=0): f0=result, f1=ret TypeDesc idx, f2=label idx
        # indirect (flag=1): f0=result, f1=callee reg, f2=ret TypeDesc idx
        val result_reg: u16 = materialize_to_reg(ctx, src2, ctx.ptr_size);
        if (dst.kind == ir.OPK_LABEL) {
            val li: u16 = intern_label(ctx, dst.label)::u16;
            var ret_td: u16 = ir.TD_NONE;
            if (src1.kind != ir.OPK_NONE) {
                val ret_fl: bool = (cc & ir.CALL_RET_FLOAT) != 0;
                val ret_ag: bool = (cc & ir.CALL_RET_AGG) != 0;
                ret_td = intern_td(ctx, src1.imm::usize, src1.size, ret_fl, ret_ag);
            }
            var ci: inst.Instruction;
            ci.op = op.OP_CALL;
            ci.meta = inst.make_meta(cc, sz, 0);
            ci.f0 = result_reg;
            ci.f1 = ret_td;
            ci.f2 = li;
            emit_inst(ctx, ci);
        } or (dst.kind == ir.OPK_REG) {
            var ret_td: u16 = ir.TD_NONE;
            if (src1.kind != ir.OPK_NONE) {
                val ret_fl: bool = (cc & ir.CALL_RET_FLOAT) != 0;
                val ret_ag: bool = (cc & ir.CALL_RET_AGG) != 0;
                ret_td = intern_td(ctx, src1.imm::usize, src1.size, ret_fl, ret_ag);
            }
            var ci: inst.Instruction;
            ci.op = op.OP_CALL;
            ci.meta = inst.make_meta(cc, sz, 1);
            ci.f0 = result_reg;
            ci.f1 = dst.reg::u16;
            ci.f2 = ret_td;
            emit_inst(ctx, ci);
        }
        ret;
    }

    # --- ABI-abstract ops ---
    if (op == op.OP_ARG) {
        val arg_idx: u8 = src1.imm::u8;
        val value_reg: u16 = materialize_to_reg(ctx, src2, sz);
        val byte_size: usize = dst.imm::usize;
        val flags: u8 = src1.size;
        val align: u8 = dst.size;
        val is_float: bool = (flags & ir.ABI_FLAG_FLOAT) != 0;
        val is_agg: bool = (flags & ir.ABI_FLAG_AGG) != 0;
        val td: u16 = intern_td(ctx, byte_size, align, is_float, is_agg);
        emit_inst(ctx, inst.make_arg(arg_idx, value_reg, td, sz));
        ret;
    }
    if (op == op.OP_PARAM) {
        var param_idx: u8 = src1.imm::u8;
        if (src1.imm == -1) { param_idx = ir.PARAM_SRET; }
        or (src1.imm == -2) { param_idx = ir.PARAM_VARARGS; }
        val byte_size: usize = dst.imm::usize;
        val align: u8 = dst.size;
        val flags: u8 = src1.size;
        val is_float: bool = (flags & ir.ABI_FLAG_FLOAT) != 0;
        val is_agg: bool = (flags & ir.ABI_FLAG_AGG) != 0;
        var displacement: i32 = 0;
        if (src2.kind == ir.OPK_MEM) { displacement = src2.disp::i32; }
        val di: u16 = intern_data_i32(ctx, displacement);
        val td: u16 = intern_td(ctx, byte_size, align, is_float, is_agg);
        var pi: inst.Instruction;
        pi.op = op.OP_PARAM;
        pi.meta = 0;
        pi.f0 = param_idx::u16;
        pi.f1 = td;
        pi.f2 = di;
        emit_inst(ctx, pi);
        ret;
    }
    if (op == ir.OP_RETVAL) {
        val value_reg: u16 = materialize_to_reg(ctx, src2, sz);
        val byte_size: usize = dst.imm::usize;
        val flags: u8 = src1.size;
        val align: u8 = dst.size;
        val is_float: bool = (flags & ir.ABI_FLAG_FLOAT) != 0;
        val is_agg: bool = (flags & ir.ABI_FLAG_AGG) != 0;
        val td: u16 = intern_td(ctx, byte_size, align, is_float, is_agg);
        emit_inst(ctx, inst.make_ret_value(value_reg, td, sz));
        ret;
    }
    if (op == ir.OP_SCARG) {
        val arg_idx: u8 = src1.imm::u8;
        val value_reg: u16 = materialize_to_reg(ctx, src2, sz);
        emit_inst(ctx, inst.make_scarg(arg_idx, value_reg, sz));
        ret;
    }

    # --- LOAD ---
    if (op == op.OP_LOAD) {
        if (src1.kind == ir.OPK_MEM) {
            emit_mem_inst(ctx, op.OP_LOAD, operand_to_reg(?dst), ?src1, sz);
        } or {
            # fallback: reg-reg MOV (shouldn't happen for LOAD but safety)
            emit_inst(ctx, inst.make_unary(op.OP_MOV, operand_to_reg(?dst),
                                         operand_to_reg(?src1), sz));
        }
        ret;
    }

    # --- STORE ---
    if (op == op.OP_STORE) {
        if (dst.kind == ir.OPK_MEM) {
            var store_src: ir.Operand = src1;
            if (store_src.kind == ir.OPK_IMM) {
                val tmp: ir.Operand = new_vreg(ctx, sz);
                emit_mov(ctx, tmp, store_src);
                store_src = tmp;
            } or (store_src.kind == ir.OPK_MEM) {
                val tmp: ir.Operand = new_vreg(ctx, sz);
                emit_mem_inst(ctx, op.OP_LOAD, tmp.reg::u16, ?store_src, sz);
                store_src = tmp;
            }
            emit_mem_inst(ctx, op.OP_STORE, operand_to_reg(?store_src), ?dst, sz);
        }
        ret;
    }

    # --- ADDR ---
    if (op == op.OP_ADDR) {
        if (src1.kind == ir.OPK_MEM) {
            emit_mem_inst(ctx, op.OP_ADDR, operand_to_reg(?dst), ?src1, sz);
        } or (src1.kind == ir.OPK_LABEL) {
            val li: u16 = intern_label(ctx, src1.label)::u16;
            emit_inst(ctx, inst.make_addr_label(operand_to_reg(?dst), li, sz));
        }
        ret;
    }

    # --- MOV ---
    if (op == op.OP_MOV) {
        val dr: u16 = operand_to_reg(?dst);
        if (src1.kind == ir.OPK_REG) {
            emit_inst(ctx, inst.make_unary(op.OP_MOV, dr, src1.reg::u16, sz));
        } or (src1.kind == ir.OPK_IMM) {
            if (src1.imm >= -2147483648 && src1.imm <= 2147483647) {
                val ii: u16 = intern_data_i32(ctx, src1.imm::i32);
                emit_inst(ctx, inst.make_mov_imm32(dr, ii, sz));
            } or {
                val ci: u16 = intern_const(ctx, src1.imm)::u16;
                emit_inst(ctx, inst.make_mov_imm64(dr, ci, sz));
            }
        } or (src1.kind == ir.OPK_MEM) {
            # MOV from memory = LOAD
            emit_mem_inst(ctx, op.OP_LOAD, dr, ?src1, sz);
        } or (src1.kind == ir.OPK_LABEL) {
            val li: u16 = intern_label(ctx, src1.label)::u16;
            emit_inst(ctx, inst.make_addr_label(dr, li, sz));
        }
        ret;
    }

    # compact IR stores only register IDs for remaining ops (CMP, conversions, ALU).
    # materialize non-REG source operands into vregs upfront.
    var ms1: ir.Operand = src1;
    var ms2: ir.Operand = src2;
    if (ms1.kind == ir.OPK_MEM) {
        val msz: u8 = ms1.size;
        val tmp: ir.Operand = new_vreg(ctx, msz);
        emit_mem_inst(ctx, op.OP_LOAD, tmp.reg::u16, ?ms1, msz);
        ms1 = tmp;
    } or (ms1.kind == ir.OPK_IMM) {
        var msz: u8 = ms1.size;
        if (msz == 0) { msz = sz; }
        val tmp: ir.Operand = new_vreg(ctx, msz);
        emit_mov(ctx, tmp, ms1);
        ms1 = tmp;
    }
    if (ms2.kind == ir.OPK_MEM) {
        val msz: u8 = ms2.size;
        val tmp: ir.Operand = new_vreg(ctx, msz);
        emit_mem_inst(ctx, op.OP_LOAD, tmp.reg::u16, ?ms2, msz);
        ms2 = tmp;
    } or (ms2.kind == ir.OPK_IMM) {
        var msz: u8 = ms2.size;
        if (msz == 0) { msz = sz; }
        val tmp: ir.Operand = new_vreg(ctx, msz);
        emit_mov(ctx, tmp, ms2);
        ms2 = tmp;
    }

    if (op == ir.OP_ICMP) {
        var cmp_sz: u8 = ms1.size;
        if (cmp_sz == 0) { cmp_sz = ms2.size; }
        if (cmp_sz == 0) { cmp_sz = sz; }
        emit_inst(ctx, inst.make_cmp(operand_to_reg(?dst),
                                     operand_to_reg(?ms1),
                                     operand_to_reg(?ms2), cc, cmp_sz));
        ret;
    }
    if (op == ir.OP_FCMP) {
        var cmp_sz: u8 = ms1.size;
        if (cmp_sz == 0) { cmp_sz = ms2.size; }
        if (cmp_sz == 0) { cmp_sz = sz; }
        emit_inst(ctx, inst.make_cmp_float(operand_to_reg(?dst),
                                           operand_to_reg(?ms1),
                                           operand_to_reg(?ms2), cc, cmp_sz));
        ret;
    }

    if (op == ir.OP_FTOI) {
        emit_inst(ctx, inst.make_conv_ftoi(operand_to_reg(?dst),
                                           operand_to_reg(?ms1), sz, ms1.size));
        ret;
    }

    if (op == ir.OP_ZEXT) {
        emit_inst(ctx, inst.make_conv(operand_to_reg(?dst), operand_to_reg(?ms1), op.CONV_ZEXT, sz));
        ret;
    }
    if (op == ir.OP_SEXT) {
        emit_inst(ctx, inst.make_conv(operand_to_reg(?dst), operand_to_reg(?ms1), op.CONV_SEXT, sz));
        ret;
    }
    if (op == ir.OP_TRUNC) {
        emit_inst(ctx, inst.make_conv(operand_to_reg(?dst), operand_to_reg(?ms1), op.CONV_TRUNC, sz));
        ret;
    }
    if (op == ir.OP_ITOF) {
        emit_inst(ctx, inst.make_conv(operand_to_reg(?dst), operand_to_reg(?ms1), op.CONV_ITOF, sz));
        ret;
    }
    if (op == ir.OP_FEXT) {
        emit_inst(ctx, inst.make_conv(operand_to_reg(?dst), operand_to_reg(?ms1), op.CONV_FEXT, sz));
        ret;
    }
    if (op == ir.OP_FTRUNC) {
        emit_inst(ctx, inst.make_conv(operand_to_reg(?dst), operand_to_reg(?ms1), op.CONV_FTRUNC, sz));
        ret;
    }

    # 3-register ALU: handle 2-operand form (dst op= src)
    var alu_s1: ir.Operand = ms1;
    var alu_s2: ir.Operand = ms2;
    if (ms2.kind == ir.OPK_NONE && ms1.kind != ir.OPK_NONE) {
        alu_s1 = dst;
        alu_s2 = ms1;
    }

    if (op == ir.OP_FADD || op == ir.OP_FSUB || op == ir.OP_FMUL) {
        var real_op: op.Operator = op.OP_ADD;
        if (op == ir.OP_FSUB) { real_op = op.OP_SUB; }
        or (op == ir.OP_FMUL) { real_op = op.OP_MUL; }
        emit_inst(ctx, inst.make_alu_float(real_op, operand_to_reg(?dst), operand_to_reg(?alu_s1), operand_to_reg(?alu_s2), sz));
        ret;
    }
    if (op == ir.OP_FDIV) {
        emit_inst(ctx, inst.make_div(operand_to_reg(?dst), operand_to_reg(?alu_s1), operand_to_reg(?alu_s2), op.DIV_FLOAT, sz));
        ret;
    }
    if (op == ir.OP_MOD) {
        emit_inst(ctx, inst.make_div(operand_to_reg(?dst), operand_to_reg(?alu_s1), operand_to_reg(?alu_s2), op.DIV_REM, sz));
        ret;
    }
    if (op == ir.OP_DIVU) {
        emit_inst(ctx, inst.make_div(operand_to_reg(?dst), operand_to_reg(?alu_s1), operand_to_reg(?alu_s2), op.DIV_UQUOT, sz));
        ret;
    }
    if (op == ir.OP_MODU) {
        emit_inst(ctx, inst.make_div(operand_to_reg(?dst), operand_to_reg(?alu_s1), operand_to_reg(?alu_s2), op.DIV_UREM, sz));
        ret;
    }
    if (op == ir.OP_SAR) {
        emit_inst(ctx, inst.make_shr(operand_to_reg(?dst), operand_to_reg(?alu_s1), operand_to_reg(?alu_s2), op.SHR_ARITHMETIC, sz));
        ret;
    }

    emit_inst(ctx, inst.make_alu(op, operand_to_reg(?dst),
                                 operand_to_reg(?alu_s1),
                                 operand_to_reg(?alu_s2), sz));
}

# emit_mov: emit a MOV instruction.
pub fun emit_mov(ctx: *LowerContext, dst: ir.Operand, src: ir.Operand) {
    emit(ctx, op.OP_MOV, dst, src, operand.make_none(), op.CC_NONE);
}

# emit_store: emit a STORE instruction.
# for mem-to-mem copies wider than a register, automatically splits into
# word-by-word loads+stores so that all bytes are transferred.
pub fun emit_store(ctx: *LowerContext, dst: ir.Operand, src: ir.Operand) {
    val psz: u8 = ctx.ptr_size;
    if (dst.kind == ir.OPK_MEM && src.kind == ir.OPK_MEM
        && dst.size > psz && src.size <= dst.size) {
        val total: usize = dst.size::usize;
        val word: usize = psz::usize;
        var off: usize = 0;
        for (off < total) {
            var chunk: u8 = psz;
            if (off + word > total) { chunk = (total - off)::u8; }
            val s: ir.Operand = operand.make_mem(src.base, src.index, src.scale,
                                              src.disp + off::i64, chunk);
            val tmp: ir.Operand = new_vreg(ctx, chunk);
            emit_load(ctx, tmp, s);
            val d: ir.Operand = operand.make_mem(dst.base, dst.index, dst.scale,
                                              dst.disp + off::i64, chunk);
            emit(ctx, op.OP_STORE, d, tmp, operand.make_none(), op.CC_NONE);
            off = off + word;
        }
        ret;
    }
    emit(ctx, op.OP_STORE, dst, src, operand.make_none(), op.CC_NONE);
}

# emit_load: emit a LOAD instruction.
pub fun emit_load(ctx: *LowerContext, dst: ir.Operand, src: ir.Operand) {
    emit(ctx, op.OP_LOAD, dst, src, operand.make_none(), op.CC_NONE);
}

# emit_memcpy: emit a word-by-word memory copy from src to dst for size bytes.
# ---
# ctx:  lowering context
# dst:  destination memory base operand
# src:  source memory base operand
# size: total bytes to copy
pub fun emit_memcpy(ctx: *LowerContext, dst: ir.Operand, src: ir.Operand, size: usize) {
    val psz: u8 = ctx.ptr_size;
    val word: usize = psz::usize;
    var off: usize = 0;
    for (off < size) {
        var chunk: u8 = psz;
        if (off + word > size) { chunk = (size - off)::u8; }
        val s: ir.Operand = operand.make_mem(src.base, src.index, src.scale,
                                          src.disp + off::i64, chunk);
        val tmp: ir.Operand = new_vreg(ctx, chunk);
        emit_load(ctx, tmp, s);
        val d: ir.Operand = operand.make_mem(dst.base, dst.index, dst.scale,
                                          dst.disp + off::i64, chunk);
        emit_store(ctx, d, tmp);
        off = off + word;
    }
}

# emit_zero: zero-fill a memory region word-by-word.
# ---
# ctx:  lowering context
# dst:  destination memory base operand
# size: total bytes to zero
pub fun emit_zero(ctx: *LowerContext, dst: ir.Operand, size: usize) {
    val psz: u8 = ctx.ptr_size;
    val word: usize = psz::usize;
    var off: usize = 0;
    for (off < size) {
        var chunk: u8 = psz;
        if (off + word > size) { chunk = (size - off)::u8; }
        val d: ir.Operand = operand.make_mem(dst.base, dst.index, dst.scale,
                                          dst.disp + off::i64, chunk);
        emit_store(ctx, d, operand.make_imm(0, chunk));
        off = off + word;
    }
}

# emit_label: emit a label pseudo-instruction.
pub fun emit_label(ctx: *LowerContext, label: str) {
    if (ctx == nil || ctx.current_block == nil) { ret; }
    val li: u16 = intern_label(ctx, label)::u16;
    emit_inst(ctx, inst.make_label(li));
}

# emit_jmp: emit an unconditional jump.
pub fun emit_jmp(ctx: *LowerContext, label: str) {
    if (ctx == nil || ctx.current_block == nil) { ret; }
    val li: u16 = intern_label(ctx, label)::u16;
    emit_inst(ctx, inst.make_jmp(li));
}

# emit_brcond: emit a conditional branch.
pub fun emit_brcond(ctx: *LowerContext, cond: ir.Operand, label: str, cc: op.Cond) {
    if (ctx == nil || ctx.current_block == nil) { ret; }
    val li: u16 = intern_label(ctx, label)::u16;
    var csz: u8 = cond.size;
    if (csz == 0) { csz = ctx.ptr_size; }
    val cond_reg: u16 = materialize_to_reg(ctx, cond, csz);
    emit_inst(ctx, inst.make_branch(cond_reg, li, cc));
}

# emit_ret: emit a return instruction.
pub fun emit_ret(ctx: *LowerContext) {
    emit_inst(ctx, inst.make_ret());
}

# --- basic block management ---

# start_block: create and switch to a new basic block.
pub fun start_block(ctx: *LowerContext, label: str) {
    if (ctx == nil || ctx.current_fn == nil) { ret; }

    val r: Result[*fn.Block, str] = fn.create_block(ctx.alloc, label);
    if (!r.tag) { ret; }

    val block: *fn.Block = r.value.ok;
    fn.func_add_block(ctx.alloc, ctx.current_fn, block);
    ctx.current_block = block;
}

# --- local variable management ---

pub fun local_add(ctx: *LowerContext, name: str, t: *type.Type, size: usize) *LocalVar {
    if (ctx == nil) { ret nil; }

    # grow if needed
    if (ctx.local_count >= ctx.local_cap) {
        val new_cap: i32 = ctx.local_cap * 2;
        val r: Result[*LocalVar, allocator.AllocError] =
            allocator.allocator_resize[LocalVar](ctx.alloc, ctx.local_vars,
                ctx.local_cap::usize, new_cap::usize);
        if (!r.tag) { ret nil; }
        ctx.local_vars = r.value.ok;
        ctx.local_cap = new_cap;
    }

    # align and allocate stack space
    var align: usize = type.type_align(t);
    if (align < 1) { align = 1; }
    val mask: i64 = align::i64 - 1;
    ctx.stack_offset = (ctx.stack_offset + size::i64 + mask) & ~mask;

    val idx: i32 = ctx.local_count;
    ctx.local_vars[idx].name = name;
    ctx.local_vars[idx].type = t;
    ctx.local_vars[idx].offset = -ctx.stack_offset;
    ctx.local_vars[idx].is_param = false;
    ctx.local_vars[idx].size = size;
    ctx.local_count = ctx.local_count + 1;

    ret ?ctx.local_vars[idx];
}

pub fun local_lookup(ctx: *LowerContext, name: str) *LocalVar {
    if (ctx == nil || name == nil) { ret nil; }
    var i: i32 = ctx.local_count - 1;
    for (i >= 0) {
        if (str_equals(ctx.local_vars[i].name, name)) {
            ret ?ctx.local_vars[i];
        }
        i = i - 1;
    }
    ret nil;
}

# local_operand: get a memory operand for a local variable.
# for aggregates larger than 255 bytes, the size field is capped to ptr_size
# since the operand represents access width, not total type size.
pub fun local_operand(lv: *LocalVar, ptr_size: u8) ir.Operand {
    if (lv == nil) { ret operand.make_none(); }
    var sz: u8 = lv.size::u8;
    if (lv.size > 255) { sz = ptr_size; }
    ret operand.make_mem(inst.VREG_FP, -1, 1, lv.offset, sz);
}

# --- function state management ---

pub fun reset_function_state(ctx: *LowerContext) {
    ctx.current_fn = nil;
    ctx.current_block = nil;
    ctx.vreg_next = inst.VREG_START;
    ctx.local_count = 0;
    ctx.stack_offset = 0;
    ctx.rs.type = nil;
    ctx.rs.has_sret = false;
    ctx.rs.is_variadic = false;
    ctx.rs.va_reg_save_off = 0;
    ctx.rs.va_named_gp = 0;
    ctx.rs.va_named_fp = 0;
    ctx.rs.va_named_stack = 0;
    ctx.ls.start = nil;
    ctx.ls.end = nil;
    ctx.ds.count = 0;
    ctx.ds.mark = 0;
}

# --- deferred statement management ---

pub fun defer_push(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil) { ret; }

    if (ctx.ds.count >= ctx.ds.cap) {
        val new_cap: i32 = ctx.ds.cap * 2;
        val r: Result[**ast.Node, allocator.AllocError] =
            allocator.allocator_resize[*ast.Node](ctx.alloc, ctx.ds.stmts,
                ctx.ds.cap::usize, new_cap::usize);
        if (!r.tag) { ret; }
        ctx.ds.stmts = r.value.ok;
        ctx.ds.cap = new_cap;
    }

    ctx.ds.stmts[ctx.ds.count] = node;
    ctx.ds.count = ctx.ds.count + 1;
}

pub fun defer_get_mark(ctx: *LowerContext) i32 {
    ret ctx.ds.count;
}

# --- type size helpers ---

pub fun type_size(ctx: *LowerContext, t: *type.Type) usize {
    if (t == nil) { ret 0; }
    if (type.type_is_pointer(t) || t.kind == type.TYPE_PTR) {
        ret ctx.target.isa.ptr_size;
    }
    ret type.type_size(t);
}

pub fun type_size_u8(ctx: *LowerContext, t: *type.Type) u8 {
    ret type_size(ctx, t)::u8;
}

# --- debug info helpers ---

# pos_to_line: convert byte offset to 1-based line number.
pub fun pos_to_line(source: str, pos: i32) i32 {
    if (source == nil || pos <= 0) { ret 1; }
    var line: i32 = 1;
    var i: i32 = 0;
    for (i < pos) {
        if (source[i] == '\n') { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

# update_source_loc: set current_line from an AST node's token position.
pub fun update_source_loc(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) { ret; }
    if (ctx.debug_source == nil) { ret; }
    val pos: i32 = node.tok.pos;
    if (pos > 0) {
        ctx.current_line = pos_to_line(ctx.debug_source, pos);
    }
}

# --- float detection ---

pub fun is_float_type(t: *type.Type) bool {
    if (t == nil) { ret false; }
    ret type.type_is_float(t);
}

# --- string label generation ---

pub fun make_str_label(alloc: *allocator.Allocator, counter: i32) str {
    # build ".Ls<counter>" label (max 14 bytes: ".Ls" + 10 digits + null)
    val buf_r: Result[*u8, allocator.AllocError] =
        allocator.allocator_alloc[u8](alloc, 14);
    if (!buf_r.tag) { ret nil; }
    val buf: *u8 = buf_r.value.ok;

    buf[0] = '.';
    buf[1] = 'L';
    buf[2] = 's';
    var pos: usize = 3;

    if (counter == 0) {
        buf[pos] = '0';
        pos = pos + 1;
    } or {
        var dlen: usize = 0;
        var tmp: i32 = counter;
        for (tmp > 0) { dlen = dlen + 1; tmp = tmp / 10; }
        var i: usize = pos + dlen;
        tmp = counter;
        for (tmp > 0) {
            i = i - 1;
            buf[i] = (tmp % 10)::u8 + '0';
            tmp = tmp / 10;
        }
        pos = pos + dlen;
    }

    buf[pos] = 0;
    ret buf::str;
}

# --- escape parsing ---

# parse_escape: map a single escape character to its byte value.
# ---
# c: the character after the backslash
# ret: the unescaped byte value
pub fun parse_escape(c: u8) u8 {
    if (c == 'n')  { ret '\n'; }
    if (c == 't')  { ret '\t'; }
    if (c == 'r')  { ret '\r'; }
    if (c == '0')  { ret 0; }
    if (c == '\\') { ret '\\'; }
    if (c == '"')  { ret '"'; }
    if (c == '\'') { ret '\''; }
    ret c;
}

# count_string_bytes: count unescaped bytes in a quoted string literal.
# text must start with '"'; returns byte count including null terminator.
pub fun count_string_bytes(text: str) u32 {
    if (text == nil || text[0] != '"') { ret 1; }
    var count: u32 = 0;
    var i: usize = 1;
    for (text[i] != 0 && text[i] != '"') {
        if (text[i] == '\\' && text[i + 1] != 0) { i = i + 2; }
        or { i = i + 1; }
        count = count + 1;
    }
    ret count + 1;
}

# fill_string_bytes: fill a buffer with unescaped bytes from a quoted string.
# text must start with '"'; writes up to buf_size bytes including null terminator.
# returns the number of content bytes written (excluding null terminator).
pub fun fill_string_bytes(text: str, buf: *u8, buf_size: u32) u32 {
    if (text == nil || buf == nil || buf_size == 0) { ret 0; }
    var pos: u32 = 0;
    if (text[0] == '"') {
        var i: usize = 1;
        for (text[i] != 0 && text[i] != '"' && pos + 1 < buf_size) {
            if (text[i] == '\\' && text[i + 1] != 0) {
                buf[pos] = parse_escape(text[i + 1]);
                i = i + 2;
            } or {
                buf[pos] = text[i];
                i = i + 1;
            }
            pos = pos + 1;
        }
    }
    buf[pos] = 0;
    ret pos;
}

# --- string helpers ---

pub fun is_space_u8(c: u8) bool {
    ret c == ' ' || c == '\t' || c == '\n' || c == '\r';
}

pub fun is_digit_u8(c: u8) bool {
    ret c >= '0' && c <= '9';
}

pub fun parse_int_str(s: str) i64 {
    if (s == nil) { ret 0; }
    var i: usize = 0;
    for (is_space_u8(s[i])) { i = i + 1; }

    var neg: bool = false;
    if (s[i] == '-') { neg = true; i = i + 1; }

    var base: i64 = 10;
    if (s[i] == '0' && (s[i+1] == 'x' || s[i+1] == 'X')) {
        base = 16; i = i + 2;
    } or (s[i] == '0' && (s[i+1] == 'b' || s[i+1] == 'B')) {
        base = 2; i = i + 2;
    } or (s[i] == '0' && (s[i+1] == 'o' || s[i+1] == 'O')) {
        base = 8; i = i + 2;
    }

    var value: i64 = 0;
    for (s[i] != 0) {
        if (s[i] == '_') { i = i + 1; cnt; } # skip underscores
        var digit: i64 = -1;
        if (s[i] >= '0' && s[i] <= '9') { digit = (s[i] - '0')::i64; }
        or (s[i] >= 'a' && s[i] <= 'f') { digit = (s[i] - 'a' + 10)::i64; }
        or (s[i] >= 'A' && s[i] <= 'F') { digit = (s[i] - 'A' + 10)::i64; }
        if (digit < 0 || digit >= base) { brk; }
        value = value * base + digit;
        i = i + 1;
    }

    if (neg) { value = -value; }
    ret value;
}

pub fun parse_float(s: str) f64 {
    if (s == nil) { ret 0.0; }
    var i: usize = 0;
    for (is_space_u8(s[i])) { i = i + 1; }

    var neg: bool = false;
    if (s[i] == '-') { neg = true; i = i + 1; }

    var value: f64 = 0.0;
    for (s[i] != 0 && is_digit_u8(s[i])) {
        value = value * 10.0 + (s[i] - '0')::f64;
        i = i + 1;
    }

    if (s[i] == '.') {
        i = i + 1;
        var frac: f64 = 0.0;
        var div: f64 = 1.0;
        for (s[i] != 0 && is_digit_u8(s[i])) {
            frac = frac * 10.0 + (s[i] - '0')::f64;
            div = div * 10.0;
            i = i + 1;
        }
        value = value + frac / div;
    }

    if (neg) { value = -value; }
    ret value;
}

