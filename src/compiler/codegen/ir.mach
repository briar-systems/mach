use std.types.bool;
use std.types.size;
use std.types.string;

use op:   masm.op;
use inst: masm.inst;

# mach.compiler.codegen.ir: compiler-internal IR extensions.
# ---
# the core IR (opcodes, instruction format, constructors, pools, functions)
# lives in the external masm library (masm.op, masm.inst, masm.pool,
# masm.function). this file provides only compiler-internal additions:
#
#   - OP_NOP, OP_MEMSET: peephole/ISel-only tombstone and optimization ops
#   - Operand, ValueKind, OPK_*: ISA-layer operand representation
#   - ABI flag/sentinel constants for pre-ABI operand encoding
#   - TD_NONE: sentinel for absent TypeDescTable entries

# compiler-internal opcodes (never emitted by lowering, never serialized)
pub val OP_NOP:    op.Operator = 40;
pub val OP_MEMSET: op.Operator = 41;

pub val OP_RETVAL: op.Operator = 42;
pub val OP_SCARG:  op.Operator = 43;
pub val OP_ZEXT:   op.Operator = 44;
pub val OP_SEXT:   op.Operator = 45;
pub val OP_TRUNC:  op.Operator = 46;
pub val OP_ITOF:   op.Operator = 47;
pub val OP_FTOI:   op.Operator = 48;
pub val OP_FEXT:   op.Operator = 49;
pub val OP_FTRUNC: op.Operator = 50;
pub val OP_ICMP:   op.Operator = 51;
pub val OP_FCMP:   op.Operator = 52;
pub val OP_BRCOND: op.Operator = 53;
pub val OP_FADD:   op.Operator = 54;
pub val OP_FSUB:   op.Operator = 55;
pub val OP_FMUL:   op.Operator = 56;
pub val OP_FDIV:   op.Operator = 57;
pub val OP_MOD:    op.Operator = 58;
pub val OP_DIVU:   op.Operator = 59;
pub val OP_MODU:   op.Operator = 60;
pub val OP_SAR:    op.Operator = 61;

# compiler-internal instruction constructors

pub fun mk_nop() inst.Instruction {
    var i: inst.Instruction;
    i.op = OP_NOP;
    i.meta = 0;
    i.f0 = 0;
    i.f1 = 0;
    i.f2 = 0;
    ret i;
}

# operand kinds (for MachInst/AsmInst, ISA layer only)
pub def ValueKind: u8;

pub val OPK_NONE:   ValueKind = 0;
pub val OPK_REG:    ValueKind = 1;
pub val OPK_IMM:    ValueKind = 2;
pub val OPK_MEM:    ValueKind = 3;
pub val OPK_LABEL:  ValueKind = 4;
pub val OPK_SYM:    ValueKind = 5;

# Operand: an operand in a MachInst or AsmInst.
# ---
# flat record with a kind discriminant. fields are interpreted based on kind:
#   OPK_REG:   reg, size
#   OPK_IMM:   imm, size
#   OPK_MEM:   base, index, scale, disp, size
#   OPK_LABEL: label
#   OPK_SYM:   sym_id
pub rec Operand {
    kind:   ValueKind;
    size:   u8;
    reg:    i32;
    imm:    i64;
    base:   i32;
    index:  i32;
    scale:  i32;
    disp:   i64;
    sym_id: u64;
    label:  str;
}

# ABI operand flags (used by call.mach/decl.mach/stmt.mach to pass type
# classification through the operand-based emit() interface)

pub val ABI_FLAG_FLOAT: u8 = 1;
pub val ABI_FLAG_AGG:   u8 = 2;

pub val CALL_VARIADIC:  u8 = 1;
pub val CALL_RET_FLOAT: u8 = 2;
pub val CALL_RET_AGG:   u8 = 4;

# param index sentinels
pub val PARAM_SRET:    u8 = 254;
pub val PARAM_VARARGS: u8 = 255;
pub val ARG_SRET:      u8 = 254;

# TypeDescTable sentinel: no type descriptor
pub val TD_NONE: u16 = 0xFFFF;
