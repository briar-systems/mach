use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use dbg:       std.print;
use inst:      masm.inst;
use ir:        mach.compiler.codegen.ir;
use isa:       mach.compiler.target.isa;
use abi:       mach.compiler.target.abi;

# mach.compiler.codegen.regalloc: target-agnostic linear scan register allocator.
# ---
# sits between ISel and encoding. rewrites virtual register operands
# to physical registers, inserting spills/reloads as needed.
# imports only isa.mach (abstract interface) and masm/ir.mach (operand types).

# --- constants ---

val MAX_POOL_REGS:   i32 = 16;
val ALIGN:           i64 = 8;
val SCRATCH_RESERVE: i32 = 2;  # pool registers reserved for spill scratch in rewrite pass

# --- records ---

rec PhysWrite {
    pos: i32;   # instruction index
    reg: i32;   # physical register ID
}

rec LiveRange {
    vreg:      i32;    # virtual register ID
    start:     i32;    # first instruction index (def)
    end_pos:   i32;    # last instruction index (use)
    size:      u8;     # operand size in bytes
    preg:      i32;    # assigned physical register (-1 = unassigned)
    spill_off: i64;    # spill slot frame offset (negative, 0 = not spilled)
    spilled:   bool;
}

pub rec RegAllocResult {
    out:         isa.MachInstBuf;   # rewritten instructions (vregs → physical)
    spill_size:  usize;             # total spill frame bytes needed
    callee_mask: u32;               # bitmask of callee-saved regs used (bit N = reg ID N)
    ok:          bool;
}

# --- public API ---

pub fun alloc_function(alloc: *allocator.Allocator, i: *isa.ISA, a: *abi.ABI,
                       insts: *isa.MachInstBuf, local_size: usize) RegAllocResult {
    var result: RegAllocResult;
    result.out = isa.buf_create(alloc);
    result.spill_size = 0;
    result.callee_mask = 0;
    result.ok = false;

    if (alloc == nil || i == nil || a == nil || insts == nil) { ret result; }
    if (insts.count == 0) {
        result.ok = true;
        ret result;
    }

    # --- build allocable register pool ---
    var gp: isa.RegisterFile = i.gp_regs(i.ctx);
    var reserved: isa.RegisterFile = i.reserved_regs(i.ctx);
    var callee: isa.RegisterFile = a.callee_saved(a.ctx);

    # allocate pool array
    val pool_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, MAX_POOL_REGS::usize);
    if (!pool_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: pool allocation failed");
        ret result;
    }
    val pool: *i32 = pool_r.value.ok;
    var pool_count: i32 = 0;

    # first: caller-saved registers (not reserved AND not callee-saved)
    var gi: i32 = 0;
    for (gi < gp.count) {
        val rid: i32 = gp.regs[gi].id;
        if (!is_in_file(rid, ?reserved) && !is_in_file(rid, ?callee)) {
            if (pool_count < MAX_POOL_REGS) {
                pool[pool_count] = rid;
                pool_count = pool_count + 1;
            }
        }
        gi = gi + 1;
    }
    val caller_count: i32 = pool_count;

    # then: callee-saved registers (not reserved AND in callee-saved file)
    gi = 0;
    for (gi < gp.count) {
        val rid: i32 = gp.regs[gi].id;
        if (!is_in_file(rid, ?reserved) && is_in_file(rid, ?callee)) {
            if (pool_count < MAX_POOL_REGS) {
                pool[pool_count] = rid;
                pool_count = pool_count + 1;
            }
        }
        gi = gi + 1;
    }

    val n: i32 = insts.count;

    # --- collect call instruction positions ---

    val calls_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, n::usize);
    if (!calls_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: calls array allocation failed");
        ret result;
    }
    val calls: *i32 = calls_r.value.ok;
    var call_count: i32 = 0;

    var ci: i32 = 0;
    for (ci < n) {
        val cinst: *isa.MachInst = isa.buf_get(insts, ci);
        if (cinst != nil && i.is_call(i.ctx, cinst)) {
            calls[call_count] = ci;
            call_count = call_count + 1;
        }
        ci = ci + 1;
    }

    # --- allocate physical register use tracking ---

    val pw_r: Result[*PhysWrite, allocator.AllocError] =
        allocator.allocator_zalloc[PhysWrite](alloc, n::usize);
    if (!pw_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: phys_writes allocation failed");
        ret result;
    }
    val phys_writes: *PhysWrite = pw_r.value.ok;
    var pw_count: i32 = 0;

    val pr_r: Result[*PhysWrite, allocator.AllocError] =
        allocator.allocator_zalloc[PhysWrite](alloc, n::usize);
    if (!pr_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: phys_reads allocation failed");
        ret result;
    }
    val phys_reads: *PhysWrite = pr_r.value.ok;
    var pr_count: i32 = 0;

    # --- Pass 1: build live ranges ---

    val ranges_r: Result[*LiveRange, allocator.AllocError] =
        allocator.allocator_zalloc[LiveRange](alloc, n::usize);
    if (!ranges_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: live ranges allocation failed");
        ret result;
    }
    val ranges: *LiveRange = ranges_r.value.ok;
    var range_count: i32 = 0;

    var idx: i32 = 0;
    for (idx < insts.count) {
        val inst: *isa.MachInst = isa.buf_get(insts, idx);
        if (inst == nil) { idx = idx + 1; cnt; }

        # skip label pseudo-instructions
        if (inst.opcode == isa.MACHINST_LABEL) { idx = idx + 1; cnt; }

        scan_operand(?inst.dst,  idx, ranges, ?range_count);
        scan_operand(?inst.src1, idx, ranges, ?range_count);
        scan_operand(?inst.src2, idx, ranges, ?range_count);

        # collect explicit physical register writes for interference checking
        if (inst.dst.kind == ir.OPK_REG && !inst.is_vreg(inst.dst.reg) &&
            inst.dst.reg >= 0 && pw_count < n) {
            phys_writes[pw_count].pos = idx;
            phys_writes[pw_count].reg = inst.dst.reg;
            pw_count = pw_count + 1;
        }

        # collect physical register reads: a phys reg read at position P
        # means the register is implicitly live from function entry to P.
        # assigning a vreg to that register before P would clobber it.
        if (inst.src1.kind == ir.OPK_REG && !inst.is_vreg(inst.src1.reg) &&
            inst.src1.reg >= 0 && pr_count < n) {
            phys_reads[pr_count].pos = idx;
            phys_reads[pr_count].reg = inst.src1.reg;
            pr_count = pr_count + 1;
        }
        if (inst.src2.kind == ir.OPK_REG && !inst.is_vreg(inst.src2.reg) &&
            inst.src2.reg >= 0 && pr_count < n) {
            phys_reads[pr_count].pos = idx;
            phys_reads[pr_count].reg = inst.src2.reg;
            pr_count = pr_count + 1;
        }

        idx = idx + 1;
    }

    # sort by start ascending (insertion sort)
    sort_ranges(ranges, range_count);

    # --- precompute parameter register liveness ---

    val PARAM_REG_MAX: i32 = 16; # covers all x86_64 GP register IDs
    val plr_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, PARAM_REG_MAX::usize);
    if (!plr_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: param_last_read allocation failed");
        ret result;
    }
    val param_last_read: *i32 = plr_r.value.ok;
    build_param_live(param_last_read, PARAM_REG_MAX,
                     phys_reads, pr_count,
                     phys_writes, pw_count,
                     calls, call_count);

    # --- Pass 2: linear scan allocation ---

    # track which pool registers are free
    val free_r: Result[*bool, allocator.AllocError] =
        allocator.allocator_alloc[bool](alloc, pool_count::usize);
    if (!free_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: reg_free allocation failed");
        ret result;
    }
    val reg_free: *bool = free_r.value.ok;
    var fi: i32 = 0;
    for (fi < pool_count) { reg_free[fi] = true; fi = fi + 1; }

    # active list: indices into ranges[] of currently active (non-spilled) intervals
    val active_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, n::usize);
    if (!active_r.tag) {
        dbg.eprintln("[regalloc] alloc_function: active list allocation failed");
        ret result;
    }
    val active: *i32 = active_r.value.ok;
    var active_count: i32 = 0;

    var spill_offset: i64 = -(local_size::i64);
    var callee_mask: u64 = 0;

    var ri: i32 = 0;
    for (ri < range_count) {
        val cur: *LiveRange = ?ranges[ri];

        # expire old intervals
        var ai: i32 = 0;
        for (ai < active_count) {
            val act: *LiveRange = ?ranges[active[ai]];
            if (act.end_pos < cur.start) {
                # free the register
                free_pool_reg(reg_free, pool, pool_count, act.preg);
                # remove from active by swapping with last
                active_count = active_count - 1;
                if (ai < active_count) {
                    active[ai] = active[active_count];
                }
                cnt; # re-check at same index
            }
            ai = ai + 1;
        }

        val cross_call: bool = spans_call(cur.start, cur.end_pos,
                                          calls, call_count);

        if (cross_call) {
            # range spans a call: must use callee-saved register or spill.
            # caller-saved registers would be clobbered by the call.
            # (reserve SCRATCH_RESERVE pool registers for spill scratch in rewrite)
            val callee_idx: i32 = find_free_reg_range_excl(reg_free,
                caller_count, pool_count, pool,
                cur.start, cur.end_pos, phys_writes, pw_count,
                param_last_read, PARAM_REG_MAX,
                calls, call_count);
            if (callee_idx >= 0 && active_count < pool_count - SCRATCH_RESERVE) {
                cur.preg = pool[callee_idx];
                reg_free[callee_idx] = false;
                callee_mask = callee_mask | (1::u64 << pool[callee_idx]::u64);
                active[active_count] = ri;
                active_count = active_count + 1;
            } or {
                # no free callee-saved: try evicting a non-call-spanning range
                # from a callee-saved register (it can be spilled safely)
                var victim_ai: i32 = -1;
                var victim_end: i32 = -1;
                var vi: i32 = 0;
                for (vi < active_count) {
                    val act: *LiveRange = ?ranges[active[vi]];
                    if (is_in_pool_range(act.preg, pool,
                                         caller_count, pool_count) &&
                        act.end_pos > victim_end &&
                        !is_phys_excluded(act.preg, cur.start, cur.end_pos,
                                          phys_writes, pw_count,
                                          calls, call_count) &&
                        !has_param_conflict(act.preg, cur.start,
                                            param_last_read, PARAM_REG_MAX)) {
                        victim_end = act.end_pos;
                        victim_ai = vi;
                    }
                    vi = vi + 1;
                }

                if (victim_ai >= 0 && victim_end > cur.end_pos) {
                    val victim: *LiveRange = ?ranges[active[victim_ai]];
                    cur.preg = victim.preg;
                    callee_mask = callee_mask | (1::u64 << cur.preg::u64);
                    victim.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    victim.spill_off = spill_offset;
                    active[victim_ai] = ri;
                } or {
                    # spill current range
                    cur.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    cur.spill_off = spill_offset;
                    cur.preg = -1;
                }
            }
        } or {
            # range does not span a call: use any free register
            # (reserve SCRATCH_RESERVE pool registers for spill scratch in rewrite)
            val free_idx: i32 = find_free_reg_excl(reg_free, pool, pool_count,
                cur.start, cur.end_pos, phys_writes, pw_count,
                param_last_read, PARAM_REG_MAX,
                calls, call_count);
            if (free_idx >= 0 && active_count < pool_count - SCRATCH_RESERVE) {
                cur.preg = pool[free_idx];
                reg_free[free_idx] = false;
                if (free_idx >= caller_count) {
                    callee_mask = callee_mask | (1::u64 << pool[free_idx]::u64);
                }
                active[active_count] = ri;
                active_count = active_count + 1;
            } or {
                # spill: evict the active interval with farthest end_pos,
                # or spill current if it ends latest
                var victim_ai: i32 = -1;
                var victim_end: i32 = -1;
                var vi: i32 = 0;
                for (vi < active_count) {
                    val act: *LiveRange = ?ranges[active[vi]];
                    if (act.end_pos > victim_end &&
                        !is_phys_excluded(act.preg, cur.start, cur.end_pos,
                                          phys_writes, pw_count,
                                          calls, call_count) &&
                        !has_param_conflict(act.preg, cur.start,
                                            param_last_read, PARAM_REG_MAX)) {
                        victim_end = act.end_pos;
                        victim_ai = vi;
                    }
                    vi = vi + 1;
                }

                if (victim_ai >= 0 && victim_end > cur.end_pos) {
                    val victim: *LiveRange = ?ranges[active[victim_ai]];
                    cur.preg = victim.preg;
                    if (is_in_pool_range(cur.preg, pool,
                                         caller_count, pool_count)) {
                        callee_mask = callee_mask | (1::u64 << cur.preg::u64);
                    }
                    victim.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    victim.spill_off = spill_offset;
                    active[victim_ai] = ri;
                } or {
                    # spill current
                    cur.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    cur.spill_off = spill_offset;
                    cur.preg = -1;
                }
            }
        }

        ri = ri + 1;
    }

    result.callee_mask = callee_mask::u32;
    result.spill_size = (-(spill_offset + local_size::i64))::usize;

    # --- Pass 3: rewrite ---

    val fp_reg: i32 = i.frame_reg(i.ctx);

    idx = 0;
    for (idx < insts.count) {
        val inst: *isa.MachInst = isa.buf_get(insts, idx);
        if (inst == nil) { idx = idx + 1; cnt; }

        # label pseudo-instructions pass through unchanged
        if (inst.opcode == isa.MACHINST_LABEL) {
            isa.buf_append(?result.out, @inst);
            idx = idx + 1;
            cnt;
        }

        # determine which physical registers are occupied at this instruction
        # and find temp registers for spilled operands
        var dst_range:  *LiveRange = find_range_for_operand(?inst.dst,  ranges, range_count);
        var src1_range: *LiveRange = find_range_for_operand(?inst.src1, ranges, range_count);
        var src2_range: *LiveRange = find_range_for_operand(?inst.src2, ranges, range_count);

        # also check memory base/index for spilled ranges
        var dst_base_range:  *LiveRange = find_mem_base_range(?inst.dst,  ranges, range_count);
        var dst_idx_range:   *LiveRange = find_mem_idx_range(?inst.dst,   ranges, range_count);
        var src1_base_range: *LiveRange = find_mem_base_range(?inst.src1, ranges, range_count);
        var src1_idx_range:  *LiveRange = find_mem_idx_range(?inst.src1,  ranges, range_count);
        var src2_base_range: *LiveRange = find_mem_base_range(?inst.src2, ranges, range_count);
        var src2_idx_range:  *LiveRange = find_mem_idx_range(?inst.src2,  ranges, range_count);

        # assign temp registers to spilled operands that need one
        if (!assign_spill_temps(ranges, range_count, idx, pool, pool_count,
                                dst_range, src1_range, src2_range,
                                dst_base_range, dst_idx_range,
                                src1_base_range, src1_idx_range,
                                src2_base_range, src2_idx_range)) {
            dbg.eprintln("[regalloc] scratch register exhaustion, aborting codegen");
            ret result;
        }

        # emit reloads for spilled sources
        emit_reload_if_spilled(i, ?result.out, src1_range, fp_reg);
        emit_reload_if_spilled(i, ?result.out, src2_range, fp_reg);
        emit_reload_if_spilled(i, ?result.out, src1_base_range, fp_reg);
        emit_reload_if_spilled(i, ?result.out, src1_idx_range, fp_reg);
        emit_reload_if_spilled(i, ?result.out, src2_base_range, fp_reg);
        emit_reload_if_spilled(i, ?result.out, src2_idx_range, fp_reg);
        # reload dst memory base/index (for stores: mov [vreg+disp], src)
        emit_reload_if_spilled(i, ?result.out, dst_base_range, fp_reg);
        emit_reload_if_spilled(i, ?result.out, dst_idx_range, fp_reg);

        # rewrite the instruction operands
        var rewritten: isa.MachInst = @inst;
        rewrite_operand(?rewritten.dst,  ranges, range_count, fp_reg);
        rewrite_operand(?rewritten.src1, ranges, range_count, fp_reg);
        rewrite_operand(?rewritten.src2, ranges, range_count, fp_reg);
        isa.buf_append(?result.out, rewritten);

        # emit spills for spilled dests
        emit_spill_if_spilled(i, ?result.out, dst_range, fp_reg);

        idx = idx + 1;
    }

    result.ok = true;
    ret result;
}

# --- internal helpers ---

# is_in_file: check if a register ID is in a register file.
fun is_in_file(reg_id: i32, file: *isa.RegisterFile) bool {
    if (file == nil || file.regs == nil) { ret false; }
    var i: i32 = 0;
    for (i < file.count) {
        if (file.regs[i].id == reg_id) { ret true; }
        i = i + 1;
    }
    ret false;
}

# scan_operand: record/extend live range for virtual registers in an operand.
fun scan_operand(op: *ir.Operand, idx: i32, ranges: *LiveRange, count: *i32) {
    if (op == nil) { ret; }

    if (op.kind == ir.OPK_REG) {
        if (inst.is_vreg(op.reg)) {
            record_use(op.reg, idx, op.size, ranges, count);
        }
    } or (op.kind == ir.OPK_MEM) {
        if (inst.is_vreg(op.base)) {
            record_use(op.base, idx, 8, ranges, count);
        }
        if (op.index >= 0 && inst.is_vreg(op.index)) {
            record_use(op.index, idx, 8, ranges, count);
        }
    }
}

# record_use: create or extend a live range for a virtual register.
fun record_use(vreg: i32, idx: i32, size: u8, ranges: *LiveRange, count: *i32) {
    # search for existing range
    var i: i32 = 0;
    for (i < @count) {
        if (ranges[i].vreg == vreg) {
            if (idx < ranges[i].start) { ranges[i].start = idx; }
            if (idx > ranges[i].end_pos) { ranges[i].end_pos = idx; }
            if (size > ranges[i].size) { ranges[i].size = size; }
            ret;
        }
        i = i + 1;
    }

    # create new range
    val n: i32 = @count;
    ranges[n].vreg = vreg;
    ranges[n].start = idx;
    ranges[n].end_pos = idx;
    ranges[n].size = size;
    ranges[n].preg = -1;
    ranges[n].spill_off = 0;
    ranges[n].spilled = false;
    @count = n + 1;
}

# sort_ranges: insertion sort by start ascending.
fun sort_ranges(ranges: *LiveRange, count: i32) {
    var i: i32 = 1;
    for (i < count) {
        var tmp: LiveRange = ranges[i];
        var j: i32 = i - 1;
        for (j >= 0 && ranges[j].start > tmp.start) {
            ranges[j + 1] = ranges[j];
            j = j - 1;
        }
        ranges[j + 1] = tmp;
        i = i + 1;
    }
}

# find_free_reg: find index of first free register in pool.
fun find_free_reg(reg_free: *bool, pool_count: i32) i32 {
    var i: i32 = 0;
    for (i < pool_count) {
        if (reg_free[i]) { ret i; }
        i = i + 1;
    }
    ret -1;
}

# find_free_reg_range: find first free register in pool[from..to).
fun find_free_reg_range(reg_free: *bool, from: i32, to: i32) i32 {
    var i: i32 = from;
    for (i < to) {
        if (reg_free[i]) { ret i; }
        i = i + 1;
    }
    ret -1;
}

# is_in_pool_range: check if preg is in pool[from..to).
fun is_in_pool_range(preg: i32, pool: *i32, from: i32, to: i32) bool {
    var i: i32 = from;
    for (i < to) {
        if (pool[i] == preg) { ret true; }
        i = i + 1;
    }
    ret false;
}

# is_phys_excluded: check if assigning preg to a live range [start, end_pos]
# would conflict with an explicit physical register write or a call-arg-live zone.
# returns true if:
#   (a) preg is written at any position strictly between start and end_pos, OR
#   (b) preg was written at position W <= start and is call-arg-live through a
#       CALL at position C > start (with no intervening rewrite of preg).
fun is_phys_excluded(preg: i32, start: i32, end_pos: i32,
                     pw: *PhysWrite, pw_count: i32,
                     calls: *i32, call_count: i32) bool {
    if (pw == nil || pw_count == 0) { ret false; }
    var i: i32 = 0;
    for (i < pw_count) {
        val w: i32 = pw[i].pos;
        if (pw[i].reg == preg) {
            # (a) original check: write strictly inside the vreg range
            if (w > start && w < end_pos) {
                ret true;
            }
            # (b) write before vreg range but call-arg-live through it
            if (w <= start) {
                val c: i32 = next_call_after(w, calls, call_count);
                if (c > start && !has_rewrite(preg, w, c, pw, pw_count)) {
                    ret true;
                }
            }
        }
        i = i + 1;
    }
    ret false;
}

# build_param_live: precompute per-register last unclobbered read position.
# for each physical register, finds the latest read that has no prior
# explicit write or call clobber (i.e., a read of the parameter value
# live from function entry). stores the result in param_last_read[reg_id]:
#   > 0 means the register is parameter-live until that position.
#   0 means no parameter read (safe to allocate freely).
fun build_param_live(param_last_read: *i32, max_regs: i32,
                     pr: *PhysWrite, pr_count: i32,
                     pw: *PhysWrite, pw_count: i32,
                     calls: *i32, call_count: i32) {
    # zero-init
    var ri: i32 = 0;
    for (ri < max_regs) { param_last_read[ri] = 0; ri = ri + 1; }

    if (pr == nil || pr_count == 0) { ret; }

    # find earliest clobber per register (write or call)
    # for call clobber: find earliest call position (all caller-saved regs)
    var first_call: i32 = 0x7fffffff;
    if (calls != nil && call_count > 0) {
        first_call = calls[0]; # calls are sorted in ascending order
    }

    var i: i32 = 0;
    for (i < pr_count) {
        val reg: i32 = pr[i].reg;
        val read_pos: i32 = pr[i].pos;
        if (reg < 0 || reg >= max_regs) { i = i + 1; cnt; }

        # skip if clobbered by a call before this read
        if (read_pos > first_call) { i = i + 1; cnt; }

        # skip if clobbered by an explicit write before this read
        var clobbered: bool = false;
        var j: i32 = 0;
        for (j < pw_count) {
            if (pw[j].reg == reg && pw[j].pos < read_pos) {
                clobbered = true;
                brk;
            }
            j = j + 1;
        }
        if (clobbered) { i = i + 1; cnt; }

        # unclobbered read: track the latest position
        if (read_pos > param_last_read[reg]) {
            param_last_read[reg] = read_pos;
        }

        i = i + 1;
    }
}

# has_param_conflict: O(1) check using precomputed param_last_read table.
# returns true if preg holds a parameter value that is still live at vreg_start.
fun has_param_conflict(preg: i32, vreg_start: i32,
                       param_last_read: *i32, max_regs: i32) bool {
    if (param_last_read == nil || preg < 0 || preg >= max_regs) { ret false; }
    ret param_last_read[preg] > vreg_start;
}

# find_free_reg_excl: find first free register not physically excluded.
fun find_free_reg_excl(reg_free: *bool, pool: *i32, pool_count: i32,
                       start: i32, end_pos: i32,
                       pw: *PhysWrite, pw_count: i32,
                       plr: *i32, plr_max: i32,
                       calls: *i32, call_count: i32) i32 {
    var i: i32 = 0;
    for (i < pool_count) {
        if (reg_free[i] &&
            !is_phys_excluded(pool[i], start, end_pos, pw, pw_count,
                              calls, call_count) &&
            !has_param_conflict(pool[i], start, plr, plr_max)) {
            ret i;
        }
        i = i + 1;
    }
    ret -1;
}

# find_free_reg_range_excl: find first free register in pool[from..to)
# not physically excluded.
fun find_free_reg_range_excl(reg_free: *bool, from: i32, to: i32,
                             pool: *i32, start: i32, end_pos: i32,
                             pw: *PhysWrite, pw_count: i32,
                             plr: *i32, plr_max: i32,
                             calls: *i32, call_count: i32) i32 {
    var i: i32 = from;
    for (i < to) {
        if (reg_free[i] &&
            !is_phys_excluded(pool[i], start, end_pos, pw, pw_count,
                              calls, call_count) &&
            !has_param_conflict(pool[i], start, plr, plr_max)) {
            ret i;
        }
        i = i + 1;
    }
    ret -1;
}

# spans_call: check if a live range [start, end_pos] spans any call instruction.
# returns true if any call occurs strictly between start and end_pos.
fun spans_call(start: i32, end_pos: i32, calls: *i32, call_count: i32) bool {
    if (calls == nil || call_count == 0) { ret false; }
    var i: i32 = 0;
    for (i < call_count) {
        if (calls[i] > start && calls[i] < end_pos) { ret true; }
        # calls are in order; if past end_pos, no need to continue
        if (calls[i] >= end_pos) { ret false; }
        i = i + 1;
    }
    ret false;
}

# next_call_after: find the first call position strictly after pos.
# returns -1 if no such call exists.
fun next_call_after(pos: i32, calls: *i32, call_count: i32) i32 {
    var i: i32 = 0;
    for (i < call_count) {
        if (calls[i] > pos) { ret calls[i]; }
        i = i + 1;
    }
    ret -1;
}

# has_rewrite: check if preg is written between positions (from, to) exclusive.
fun has_rewrite(preg: i32, from: i32, to: i32,
                pw: *PhysWrite, pw_count: i32) bool {
    var i: i32 = 0;
    for (i < pw_count) {
        if (pw[i].reg == preg && pw[i].pos > from && pw[i].pos < to) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

# free_pool_reg: mark a physical register as free in the pool.
fun free_pool_reg(reg_free: *bool, pool: *i32, pool_count: i32, preg: i32) {
    var i: i32 = 0;
    for (i < pool_count) {
        if (pool[i] == preg) { reg_free[i] = true; ret; }
        i = i + 1;
    }
}

# find_range: find the live range for a given virtual register.
fun find_range(vreg: i32, ranges: *LiveRange, count: i32) *LiveRange {
    var i: i32 = 0;
    for (i < count) {
        if (ranges[i].vreg == vreg) { ret ?ranges[i]; }
        i = i + 1;
    }
    ret nil;
}

# find_range_for_operand: find live range for the register in an OPK_REG operand.
fun find_range_for_operand(op: *ir.Operand, ranges: *LiveRange, count: i32) *LiveRange {
    if (op == nil) { ret nil; }
    if (op.kind == ir.OPK_REG && inst.is_vreg(op.reg)) {
        ret find_range(op.reg, ranges, count);
    }
    ret nil;
}

# find_mem_base_range: find live range for a memory operand's base register.
fun find_mem_base_range(op: *ir.Operand, ranges: *LiveRange, count: i32) *LiveRange {
    if (op == nil) { ret nil; }
    if (op.kind == ir.OPK_MEM && inst.is_vreg(op.base)) {
        ret find_range(op.base, ranges, count);
    }
    ret nil;
}

# find_mem_idx_range: find live range for a memory operand's index register.
fun find_mem_idx_range(op: *ir.Operand, ranges: *LiveRange, count: i32) *LiveRange {
    if (op == nil) { ret nil; }
    if (op.kind == ir.OPK_MEM && op.index >= 0 && inst.is_vreg(op.index)) {
        ret find_range(op.index, ranges, count);
    }
    ret nil;
}

# assign_spill_temps: assign temporary physical registers to spilled operands.
# finds registers not occupied by any non-spilled interval at this instruction.
# returns false if any spilled operand could not be assigned a scratch register.
fun assign_spill_temps(ranges: *LiveRange, range_count: i32, idx: i32,
                       pool: *i32, pool_count: i32,
                       dst_r: *LiveRange, src1_r: *LiveRange, src2_r: *LiveRange,
                       dst_base_r: *LiveRange, dst_idx_r: *LiveRange,
                       src1_base_r: *LiveRange, src1_idx_r: *LiveRange,
                       src2_base_r: *LiveRange, src2_idx_r: *LiveRange) bool {
    # collect all spilled ranges that need a temp at this instruction
    # (max ~8 operand slots, but in practice 1-2)

    # build occupancy bitmap for pool registers at this instruction
    # a register is occupied if a non-spilled interval with that preg is live here
    var occupied: u64 = 0; # bitmask, bit i = pool[i] is occupied
    var ri: i32 = 0;
    for (ri < range_count) {
        if (!ranges[ri].spilled && ranges[ri].preg >= 0 &&
            ranges[ri].start <= idx && ranges[ri].end_pos >= idx) {
            # mark this preg as occupied
            var pi: i32 = 0;
            for (pi < pool_count) {
                if (pool[pi] == ranges[ri].preg) {
                    occupied = occupied | (1::u64 << pi::u64);
                }
                pi = pi + 1;
            }
        }
        ri = ri + 1;
    }

    # assign temps to each spilled range from unoccupied pool regs
    if (!assign_one_temp(src1_r,      idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src2_r,      idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src1_base_r, idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src1_idx_r,  idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src2_base_r, idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src2_idx_r,  idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(dst_base_r,  idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(dst_idx_r,   idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(dst_r,       idx, pool, pool_count, ?occupied)) { ret false; }
    ret true;
}

# assign_one_temp: assign a temp register to a single spilled range if needed.
# returns true on success (or if no assignment needed), false if all pool
# registers are occupied and the spilled operand cannot be given a scratch.
fun assign_one_temp(lr: *LiveRange, idx: i32, pool: *i32, pool_count: i32,
                    occupied: *u64) bool {
    if (lr == nil || !lr.spilled) { ret true; }

    # find first unoccupied pool register
    var pi: i32 = 0;
    for (pi < pool_count) {
        if ((@occupied & (1::u64 << pi::u64)) == 0) {
            lr.preg = pool[pi];
            @occupied = @occupied | (1::u64 << pi::u64);
            ret true;
        }
        pi = pi + 1;
    }
    # all pool registers occupied — no scratch available
    dbg.eprint("regalloc: error: all pool registers occupied at instruction ");
    dbg.eu64(idx::u64);
    dbg.eprint(", cannot assign scratch for spilled operand\n");
    lr.preg = -1;
    ret false;
}

# emit_reload_if_spilled: emit a reload for a spilled live range.
fun emit_reload_if_spilled(i: *isa.ISA, out: *isa.MachInstBuf,
                           lr: *LiveRange, fp_reg: i32) {
    if (lr == nil || !lr.spilled || lr.preg < 0) { ret; }
    i.emit_reload(i.ctx, out, lr.preg, lr.spill_off, lr.size, fp_reg);
}

# emit_spill_if_spilled: emit a spill for a spilled live range.
fun emit_spill_if_spilled(i: *isa.ISA, out: *isa.MachInstBuf,
                          lr: *LiveRange, fp_reg: i32) {
    if (lr == nil || !lr.spilled || lr.preg < 0) { ret; }
    i.emit_spill(i.ctx, out, lr.preg, lr.spill_off, lr.size, fp_reg);
}

# rewrite_operand: replace virtual registers with physical registers.
fun rewrite_operand(op: *ir.Operand, ranges: *LiveRange, count: i32, fp_reg: i32) {
    if (op == nil) { ret; }

    if (op.kind == ir.OPK_REG) {
        if (inst.is_vreg(op.reg)) {
            val lr: *LiveRange = find_range(op.reg, ranges, count);
            if (lr != nil && lr.preg >= 0) {
                op.reg = lr.preg;
            }
        }
    } or (op.kind == ir.OPK_MEM) {
        # resolve virtual frame pointer
        if (op.base == inst.VREG_FP) {
            op.base = fp_reg;
        } or (op.base == inst.VREG_SP) {
            # leave VREG_SP unchanged — pipeline resolves after total_frame is known
        } or (inst.is_vreg(op.base)) {
            val lr: *LiveRange = find_range(op.base, ranges, count);
            if (lr != nil && lr.preg >= 0) {
                op.base = lr.preg;
            }
        }
        if (op.index >= 0 && inst.is_vreg(op.index)) {
            val lr: *LiveRange = find_range(op.index, ranges, count);
            if (lr != nil && lr.preg >= 0) {
                op.index = lr.preg;
            }
        }
    }
}
