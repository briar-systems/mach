use std.types.bool;
use std.types.size;
use std.types.string;

use ir:    mach.compiler.masm.ir;
use fn:    mach.compiler.masm.function;
use pools: mach.compiler.masm.pools;

# mach.compiler.masm.operand: operand constructors, query helpers, and
# compact-IR-to-Operand reconstruction.
# ---
# this is the single source of truth for creating and inspecting Operand
# values. the Operand record itself lives in ir.mach; everything that
# builds or queries one lives here.

# ================================================================
# constructors
# ================================================================

pub fun make_none() ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_NONE;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = -1;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_reg(reg: i32, size: u8) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_REG;
    o.size = size;
    o.reg = reg;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_imm(imm: i64, size: u8) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_IMM;
    o.size = size;
    o.reg = 0;
    o.imm = imm;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_mem(base: i32, index: i32, scale: i32, disp: i64, size: u8) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_MEM;
    o.size = size;
    o.reg = 0;
    o.imm = 0;
    o.base = base;
    o.index = index;
    o.scale = scale;
    o.disp = disp;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_label(label: str) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_LABEL;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = label;
    ret o;
}

pub fun make_sym(sym_id: u64) ir.Operand {
    var o: ir.Operand;
    o.kind = ir.OPK_SYM;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = sym_id;
    o.label = nil;
    ret o;
}

# --- shorthand aliases (same semantics, shorter names) ---

pub fun none() ir.Operand  { ret make_none(); }
pub fun reg(r: i32, size: u8) ir.Operand { ret make_reg(r, size); }
pub fun imm(value: i64, size: u8) ir.Operand { ret make_imm(value, size); }

pub fun mem(base: i32, disp: i64, size: u8) ir.Operand {
    ret make_mem(base, -1, 1, disp, size);
}

pub fun mem_idx(base: i32, index: i32, scale: i32, disp: i64, size: u8) ir.Operand {
    ret make_mem(base, index, scale, disp, size);
}

pub fun label(name: str) ir.Operand { ret make_label(name); }
pub fun sym(id: u64) ir.Operand { ret make_sym(id); }

# ================================================================
# query helpers
# ================================================================

pub fun is_none(op: *ir.Operand) bool {
    if (op == nil) { ret true; }
    ret op.kind == ir.OPK_NONE;
}

pub fun is_reg(op: *ir.Operand) bool {
    if (op == nil) { ret false; }
    ret op.kind == ir.OPK_REG;
}

pub fun is_imm(op: *ir.Operand) bool {
    if (op == nil) { ret false; }
    ret op.kind == ir.OPK_IMM;
}

pub fun is_mem(op: *ir.Operand) bool {
    if (op == nil) { ret false; }
    ret op.kind == ir.OPK_MEM;
}

pub fun is_label(op: *ir.Operand) bool {
    if (op == nil) { ret false; }
    ret op.kind == ir.OPK_LABEL;
}

pub fun is_sym(op: *ir.Operand) bool {
    if (op == nil) { ret false; }
    ret op.kind == ir.OPK_SYM;
}

pub fun kind_name(kind: ir.ValueKind) str {
    if (kind == ir.OPK_NONE)  { ret "none"; }
    if (kind == ir.OPK_REG)   { ret "reg"; }
    if (kind == ir.OPK_IMM)   { ret "imm"; }
    if (kind == ir.OPK_MEM)   { ret "mem"; }
    if (kind == ir.OPK_LABEL) { ret "label"; }
    if (kind == ir.OPK_SYM)   { ret "sym"; }
    ret "unknown";
}

# ================================================================
# compact-IR → Operand reconstruction helpers (for ISel bridge)
# ================================================================

# pool-resolved accessors (f2 is DataPool index)
pub fun imm32(inst: *ir.Inst, func: *fn.Function) i32 {
    ret pools.data_get_i32(?func.data_pool, inst.f2::i32);
}
pub fun disp(inst: *ir.Inst, func: *fn.Function) i32 {
    ret pools.data_get_i32(?func.data_pool, inst.f2::i32);
}

# memory operand unpacking (indexed mode, flag=1)
# f2 = DataPool index -> packed i32: index:u16 (bits 31-16) | disp:i16 (bits 15-0)
# scale is stored in meta cc field as log2 (0=1, 1=2, 2=4, 3=8)
pub fun mem_index(inst: *ir.Inst, func: *fn.Function) u16 {
    val packed: i32 = pools.data_get_i32(?func.data_pool, inst.f2::i32);
    ret (packed >> 16)::u16;
}
pub fun mem_scale(inst: *ir.Inst) u8  { ret 1 << (ir.inst_cc(inst) & 3); }
pub fun mem_disp16(inst: *ir.Inst, func: *fn.Function) i16 {
    val packed: i32 = pools.data_get_i32(?func.data_pool, inst.f2::i32);
    ret packed::i16;
}

# inst_to_dst_operand: reconstruct destination Operand from compact Inst.
# used by ISel to bridge compact IR -> Operand-based MachInst.
pub fun inst_to_dst_operand(inst: *ir.Inst, func: *fn.Function) ir.Operand {
    val op: u8 = inst.op;
    val sz: u8 = ir.inst_size(inst);

    if (op == ir.OP_STORE) {
        if (ir.inst_flag(inst) != 0) {
            ret make_mem(inst.f1::i32, mem_index(inst, func)::i32,
                         mem_scale(inst)::i32, mem_disp16(inst, func)::i64, sz);
        }
        ret make_mem(inst.f1::i32, -1, 1, disp(inst, func)::i64, sz);
    }

    if (op == ir.OP_JMP || op == ir.OP_BRCOND || op == ir.OP_LABEL) {
        val name: str = pools.label_get(?func.labels, inst.f2::i32);
        ret make_label(name);
    }

    if (op == ir.OP_CALL) {
        if (ir.inst_flag(inst) == 0) {
            val name: str = pools.label_get(?func.labels, inst.f2::i32);
            ret make_label(name);
        }
        ret make_reg(inst.f1::i32, 8);
    }

    if (op == ir.OP_ICMP || op == ir.OP_FCMP) {
        ret make_reg(inst.f0::i32, 1);
    }

    ret make_reg(inst.f0::i32, sz);
}

# inst_to_src1_operand: reconstruct src1 Operand from compact Inst.
pub fun inst_to_src1_operand(inst: *ir.Inst, func: *fn.Function) ir.Operand {
    val op: u8 = inst.op;
    val sz: u8 = ir.inst_size(inst);

    if (op == ir.OP_ADDR && ir.inst_cc(inst) == 1) {
        val name: str = pools.label_get(?func.labels, inst.f2::i32);
        ret make_label(name);
    }

    if (op == ir.OP_LOAD || op == ir.OP_ADDR) {
        if (ir.inst_flag(inst) != 0) {
            ret make_mem(inst.f1::i32, mem_index(inst, func)::i32,
                         mem_scale(inst)::i32, mem_disp16(inst, func)::i64, sz);
        }
        ret make_mem(inst.f1::i32, -1, 1, disp(inst, func)::i64, sz);
    }

    if (op == ir.OP_MOV && ir.inst_flag(inst) != 0) {
        val value: u64 = pools.const_get(?func.const_pool, inst.f2::i32);
        ret make_imm(value::i64, sz);
    }

    if (op == ir.OP_MOV && ir.inst_cc(inst) == 1) {
        ret make_imm(imm32(inst, func)::i64, sz);
    }

    if (op == ir.OP_BRCOND) {
        ret make_reg(inst.f0::i32, 1);
    }

    if (op == ir.OP_STORE) {
        ret make_reg(inst.f0::i32, sz);
    }

    if (op == ir.OP_FTOI) {
        var src_sz: u8 = inst.f2::u8;
        if (src_sz == 0) { src_sz = sz; }
        ret make_reg(inst.f1::i32, src_sz);
    }

    ret make_reg(inst.f1::i32, sz);
}

# inst_to_src2_operand: reconstruct src2 Operand from compact Inst.
pub fun inst_to_src2_operand(inst: *ir.Inst) ir.Operand {
    val op: u8 = inst.op;
    val sz: u8 = ir.inst_size(inst);

    if (op >= ir.OP_ADD && op <= ir.OP_SAR) {
        ret make_reg(ir.src2_reg(inst)::i32, sz);
    }
    if (op >= ir.OP_FADD && op <= ir.OP_FDIV) {
        ret make_reg(ir.src2_reg(inst)::i32, sz);
    }
    if (op == ir.OP_ICMP || op == ir.OP_FCMP) {
        ret make_reg(ir.src2_reg(inst)::i32, sz);
    }
    if (op == ir.OP_MEMSET) {
        ret make_reg(ir.src2_reg(inst)::i32, sz);
    }

    ret make_none();
}
