use std.types.bool;
use std.types.size;
use std.types.string;

# tag constants for OperandKind
pub val OP_NONE:  u8 = 0;
pub val OP_REG:   u8 = 1;
pub val OP_IMM:   u8 = 2;
pub val OP_MEM:   u8 = 3;
pub val OP_LABEL: u8 = 4;

# mach.compiler.masm.operand: operand types for machine code emission.
# ---
# provides operand representations for x86-64 and other ISAs.

# OperandKind: the kind of operand.
# ---
# op_none:     no operand
# op_reg:      register operand
# op_imm:      immediate value
# op_mem:      memory operand
# op_label:    label reference
pub uni OperandKind {
    op_none:  u8;
    op_reg:   u8;
    op_imm:   u8;
    op_mem:   u8;
    op_label: u8;
}

# get_tag: get the tag value from an OperandKind.
# ---
# kind: operand kind
# ret:  tag value (OP_NONE, OP_REG, etc.)
pub fun get_tag(kind: OperandKind) u8 {
    ret kind.tag;
}

# Operand: a machine-level operand.
# ---
# kind:      operand kind
# reg:       register number
# imm:       immediate value
# base:      base register (for memory)
# index:     index register (for memory)
# scale:     scale factor (1, 2, 4, 8)
# disp:      displacement (for memory)
# label:     label name (for label operands)
# size:      operand size in bytes
pub rec Operand {
    kind:  OperandKind;
    reg:   i32;
    imm:   i64;
    base:  i32;
    index: i32;
    scale: i32;
    disp:  i64;
    label: str;
    size:  usize;
}

# none: create a "no operand" value.
# ---
# ret: empty Operand
pub fun none() Operand {
    var op: Operand;
    op.kind = OperandKind { op_none: 0 };
    op.reg = 0;
    op.imm = 0;
    op.base = -1;
    op.index = -1;
    op.scale = 1;
    op.disp = 0;
    op.label = nil;
    op.size = 0;
    ret op;
}

# reg: create a register operand.
# ---
# r:    register number
# size: operand size in bytes
# ret:  Operand for the register
pub fun reg(r: i32, size: usize) Operand {
    var op: Operand = none();
    op.kind = OperandKind { op_reg: 0 };
    op.reg = r;
    op.size = size;
    ret op;
}

# imm: create an immediate operand.
# ---
# val:  immediate value
# size: operand size in bytes
# ret:  Operand for the immediate
pub fun imm(value: i64, size: usize) Operand {
    var op: Operand = none();
    op.kind = OperandKind { op_imm: 0 };
    op.imm = value;
    op.size = size;
    ret op;
}

# mem: create a memory operand with base register and displacement.
# ---
# base: base register number
# disp: displacement from base
# size: operand size in bytes
# ret:  Operand for the memory reference
pub fun mem(base: i32, disp: i64, size: usize) Operand {
    var op: Operand = none();
    op.kind = OperandKind { op_mem: 0 };
    op.base = base;
    op.disp = disp;
    op.size = size;
    ret op;
}

# mem_sib: create a memory operand with base, index, scale, and displacement.
# ---
# base:  base register number (-1 for none)
# index: index register number (-1 for none)
# scale: scale factor (1, 2, 4, 8)
# disp:  displacement
# size:  operand size in bytes
# ret:   Operand for the memory reference
pub fun mem_sib(base: i32, index: i32, scale: i32, disp: i64, size: usize) Operand {
    var op: Operand = none();
    op.kind = OperandKind { op_mem: 0 };
    op.base = base;
    op.index = index;
    op.scale = scale;
    op.disp = disp;
    op.size = size;
    ret op;
}

# label: create a label operand.
# ---
# name: label name
# ret:  Operand for the label
pub fun label(name: str) Operand {
    var op: Operand = none();
    op.kind = OperandKind { op_label: 0 };
    op.label = name;
    ret op;
}

# is_none: check if operand is empty/none.
# ---
# op: operand to check
# ret: true if no operand
pub fun is_none(op: *Operand) bool {
    if (op == nil) {
        ret true;
    }
    ret op.kind.tag == OP_NONE;
}

# is_reg: check if operand is a register.
# ---
# op: operand to check
# ret: true if register operand
pub fun is_reg(op: *Operand) bool {
    if (op == nil) {
        ret false;
    }
    ret op.kind.tag == OP_REG;
}

# is_mem: check if operand is a memory reference.
# ---
# op: operand to check
# ret: true if memory operand
pub fun is_mem(op: *Operand) bool {
    if (op == nil) {
        ret false;
    }
    ret op.kind.tag == OP_MEM;
}

# is_imm: check if operand is an immediate.
# ---
# op: operand to check
# ret: true if immediate operand
pub fun is_imm(op: *Operand) bool {
    if (op == nil) {
        ret false;
    }
    ret op.kind.tag == OP_IMM;
}

# is_label: check if operand is a label.
# ---
# op: operand to check
# ret: true if label operand
pub fun is_label(op: *Operand) bool {
    if (op == nil) {
        ret false;
    }
    ret op.kind.tag == OP_LABEL;
}

# kind_name: get a string name for an operand kind.
# ---
# kind: operand kind
# ret:  string name
pub fun kind_name(kind: OperandKind) str {
    val tag: u8 = kind.tag;
    if (tag == OP_NONE)  { ret "none"; }
    if (tag == OP_REG)   { ret "reg"; }
    if (tag == OP_IMM)   { ret "imm"; }
    if (tag == OP_MEM)   { ret "mem"; }
    if (tag == OP_LABEL) { ret "label"; }
    ret "unknown";
}
