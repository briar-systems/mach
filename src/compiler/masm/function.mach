use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use dbg:       std.print;

use ir:    mach.compiler.masm.ir;
use pools: mach.compiler.masm.pools;

# mach.compiler.masm.function: IR function and block records.
# ---
# provides the Function and Block types for the compact IR, along with
# creation, block management, and destruction functions.

# DebugLoc: source location for one instruction (parallel array in Block).
pub rec DebugLoc {
    src_line: i32;
    src_file: u16;
    pad:      u16;
}

# Block: a basic block in the IR.
pub rec Block {
    label:      str;
    insts:      *ir.Inst;
    debug_locs: *DebugLoc;
    inst_count: i32;
    inst_cap:   i32;
}

# Function: a function in the IR.
pub rec Function {
    name:           str;
    blocks:         **Block;
    block_count:    i32;
    block_cap:      i32;
    param_count:    i32;
    local_size:     usize;
    call_area_size: usize;
    const_pool:     pools.ConstPool;
    labels:         pools.LabelTable;
    data_pool:      pools.DataPool;
}

# --- block operations ---

pub fun create_block(alloc: *allocator.Allocator, lbl: str) Result[*Block, str] {
    if (alloc == nil) {
        ret err[*Block, str]("allocator is nil");
    }

    val r: Result[*Block, allocator.AllocError] = allocator.allocator_zalloc[Block](alloc, 1);
    if (result_is_err[*Block, allocator.AllocError](r)) {
        ret err[*Block, str]("out of memory");
    }

    val b: *Block = result_unwrap_ok[*Block, allocator.AllocError](r);
    b.label = lbl;
    b.insts = nil;
    b.debug_locs = nil;
    b.inst_count = 0;
    b.inst_cap = 0;

    ret ok[*Block, str](b);
}

# block_append: append a compact instruction to a block.
# returns the index of the appended instruction, or -1 on failure.
pub fun block_append(alloc: *allocator.Allocator, block: *Block, inst: ir.Inst) i32 {
    if (block == nil || alloc == nil) {
        ret -1;
    }

    if (block.inst_count >= block.inst_cap) {
        var new_cap: i32 = 8;
        if (block.inst_cap > 0) {
            new_cap = block.inst_cap * 2;
        }

        val r: Result[*ir.Inst, allocator.AllocError] = allocator.allocator_resize[ir.Inst](
            alloc, block.insts, block.inst_cap::usize, new_cap::usize
        );
        if (result_is_err[*ir.Inst, allocator.AllocError](r)) {
            dbg.eprintln("[masm] block_append: instruction buffer allocation failed");
            ret -1;
        }
        block.insts = result_unwrap_ok[*ir.Inst, allocator.AllocError](r);

        val dr: Result[*DebugLoc, allocator.AllocError] = allocator.allocator_resize[DebugLoc](
            alloc, block.debug_locs, block.inst_cap::usize, new_cap::usize
        );
        if (result_is_err[*DebugLoc, allocator.AllocError](dr)) {
            dbg.eprintln("[masm] block_append: debug_locs allocation failed");
            ret -1;
        }
        block.debug_locs = result_unwrap_ok[*DebugLoc, allocator.AllocError](dr);

        block.inst_cap = new_cap;
    }

    val idx: i32 = block.inst_count;
    block.insts[idx] = inst;
    block.debug_locs[idx].src_line = 0;
    block.debug_locs[idx].src_file = 0;
    block.debug_locs[idx].pad = 0;

    block.inst_count = block.inst_count + 1;

    ret idx;
}

# block_set_debug: set debug info for an instruction by index.
pub fun block_set_debug(block: *Block, idx: i32, line: i32, file: u16) {
    if (block == nil || block.debug_locs == nil) { ret; }
    if (idx < 0 || idx >= block.inst_count) { ret; }
    block.debug_locs[idx].src_line = line;
    block.debug_locs[idx].src_file = file;
}

# block_destroy: free all memory owned by a block.
pub fun block_destroy(alloc: *allocator.Allocator, block: *Block) {
    if (alloc == nil || block == nil) { ret; }
    if (block.insts != nil) {
        allocator.allocator_free[ir.Inst](alloc, block.insts, block.inst_cap::usize);
        block.insts = nil;
    }
    if (block.debug_locs != nil) {
        allocator.allocator_free[DebugLoc](alloc, block.debug_locs, block.inst_cap::usize);
        block.debug_locs = nil;
    }
    block.inst_count = 0;
    block.inst_cap = 0;
    allocator.allocator_free[Block](alloc, block, 1);
}

# --- function operations ---

pub fun create_function(alloc: *allocator.Allocator, name: str) Result[*Function, str] {
    if (alloc == nil) {
        ret err[*Function, str]("allocator is nil");
    }

    val r: Result[*Function, allocator.AllocError] = allocator.allocator_zalloc[Function](alloc, 1);
    if (result_is_err[*Function, allocator.AllocError](r)) {
        ret err[*Function, str]("out of memory");
    }

    val f: *Function = result_unwrap_ok[*Function, allocator.AllocError](r);
    f.name = name;
    f.blocks = nil;
    f.block_count = 0;
    f.block_cap = 0;
    f.param_count = 0;
    f.local_size = 0;
    f.call_area_size = 0;
    f.const_pool = pools.const_pool_init(alloc);
    f.labels = pools.label_table_init(alloc);
    f.data_pool = pools.data_pool_init(alloc);

    ret ok[*Function, str](f);
}

pub fun func_add_block(alloc: *allocator.Allocator, func: *Function, block: *Block) i32 {
    if (func == nil || block == nil || alloc == nil) {
        ret -1;
    }

    if (func.block_count >= func.block_cap) {
        var new_cap: i32 = 8;
        if (func.block_cap > 0) {
            new_cap = func.block_cap * 2;
        }

        val r: Result[**Block, allocator.AllocError] = allocator.allocator_resize[*Block](
            alloc, func.blocks, func.block_cap::usize, new_cap::usize
        );
        if (result_is_err[**Block, allocator.AllocError](r)) {
            dbg.eprintln("[masm] func_add_block: allocation failed");
            ret -1;
        }

        func.blocks = result_unwrap_ok[**Block, allocator.AllocError](r);
        func.block_cap = new_cap;
    }

    val idx: i32 = func.block_count;
    func.blocks[idx] = block;
    func.block_count = func.block_count + 1;

    ret idx;
}

# func_destroy: free all memory owned by a function, including blocks and pools.
pub fun func_destroy(alloc: *allocator.Allocator, func: *Function) {
    if (alloc == nil || func == nil) { ret; }

    var bi: i32 = 0;
    for (bi < func.block_count) {
        if (func.blocks[bi] != nil) {
            block_destroy(alloc, func.blocks[bi]);
        }
        bi = bi + 1;
    }
    if (func.blocks != nil) {
        allocator.allocator_free[*Block](alloc, func.blocks, func.block_cap::usize);
        func.blocks = nil;
    }

    pools.const_pool_destroy(alloc, ?func.const_pool);
    pools.label_table_destroy(alloc, ?func.labels);
    pools.data_pool_destroy(alloc, ?func.data_pool);

    func.block_count = 0;
    func.block_cap = 0;
    allocator.allocator_free[Function](alloc, func, 1);
}
