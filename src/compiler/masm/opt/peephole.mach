use std.types.bool;
use std.types.size;

use allocator: std.allocator;
use ir:        mach.compiler.masm.ir;
use fn:        mach.compiler.masm.function;

# mach.compiler.masm.opt.peephole: IR-level peephole optimizer.
# ---
# runs pattern-matching rules over compact 8-byte IR instructions to eliminate
# redundancy before instruction selection. operates in-place on Block instruction
# arrays, marking eliminated instructions as NOP then compacting.

# OptContext: peephole optimizer state.
pub rec OptContext {
    alloc:      *allocator.Allocator;
    eliminated: i32;
}

# init: create a new optimizer context.
pub fun init(alloc: *allocator.Allocator) OptContext {
    var ctx: OptContext;
    ctx.alloc = alloc;
    ctx.eliminated = 0;
    ret ctx;
}

# optimize_function: run peephole optimization on all blocks in a function.
pub fun optimize_function(ctx: *OptContext, func: *fn.Function) {
    if (ctx == nil || func == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < func.block_count) {
        val block: *fn.Block = func.blocks[i];
        if (block != nil) {
            optimize_block(ctx, block);
        }
        i = i + 1;
    }
}

# optimize_block: run peephole rules on a single block in a fixed-point loop.
fun optimize_block(ctx: *OptContext, block: *fn.Block) {
    if (block == nil || block.insts == nil || block.inst_count == 0) {
        ret;
    }

    var changed: bool = true;
    for (changed) {
        changed = false;
        if (rule_self_move(ctx, block))               { changed = true; }
        if (rule_redundant_store_load(ctx, block))    { changed = true; }
    }

    compact_block(block);
}

# --- compact format helpers ---

# is_mov_reg_reg: check if instruction is MOV reg-reg (cc=0, flag=0).
fun is_mov_reg_reg(inst: *ir.Inst) bool {
    if (inst.op != ir.OP_MOV) { ret false; }
    ret ir.inst_cc(inst) == 0 && ir.inst_flag(inst) == 0;
}

# mark_nop: mark an instruction as eliminated.
fun mark_nop(ctx: *OptContext, inst: *ir.Inst) {
    inst.op = ir.OP_NOP;
    inst.meta = 0;
    inst.f0 = 0;
    inst.f1 = 0;
    inst.f2 = 0;
    ctx.eliminated = ctx.eliminated + 1;
}

# --- peephole rules ---

# rule_self_move: eliminate MOV rX, rX (register to itself).
# compact MOV reg-reg: cc=0, flag=0, f0=dst, f1=src.
fun rule_self_move(ctx: *OptContext, block: *fn.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val inst: *ir.Inst = ?block.insts[i];
        if (is_mov_reg_reg(inst) && inst.f0 == inst.f1) {
            mark_nop(ctx, inst);
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_redundant_store_load: eliminate LOAD after STORE to the same address.
# pattern: STORE [base+disp], rX followed by LOAD rY, [base+disp]
# the LOAD is redundant because rX already holds the value.
# replace LOAD with MOV rY, rX (or NOP if rY == rX).
fun rule_redundant_store_load(ctx: *OptContext, block: *fn.Block) bool {
    var changed: bool = false;
    if (block.inst_count < 2) { ret false; }

    var i: i32 = 0;
    for (i < block.inst_count - 1) {
        val store: *ir.Inst = ?block.insts[i];
        val load:  *ir.Inst = ?block.insts[i + 1];

        # match STORE followed by LOAD with same memory operand
        # STORE: f0=src_reg, f1=base, f2=disp, flag+size in meta
        # LOAD:  f0=dst_reg, f1=base, f2=disp, flag+size in meta
        if (store.op == ir.OP_STORE && load.op == ir.OP_LOAD
            && store.f1 == load.f1 && store.f2 == load.f2
            && (store.meta & 0x0F) == (load.meta & 0x0F)) {
            # STORE src is f0, LOAD dst is f0
            if (load.f0 == store.f0) {
                # same register: just eliminate the LOAD
                mark_nop(ctx, load);
            } or {
                # different register: replace LOAD with MOV reg-reg
                val sz: u8 = ir.inst_size(store);
                @load = ir.mk_unary(ir.OP_MOV, load.f0, store.f0, sz);
            }
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# --- block compaction ---

# compact_block: remove all OP_NOP instructions by shifting remaining
# instructions down. also shifts debug_locs in parallel.
fun compact_block(block: *fn.Block) {
    if (block == nil || block.insts == nil) { ret; }

    var write: i32 = 0;
    var read: i32 = 0;
    for (read < block.inst_count) {
        if (block.insts[read].op != ir.OP_NOP) {
            if (write != read) {
                block.insts[write] = block.insts[read];
                if (block.debug_locs != nil) {
                    block.debug_locs[write] = block.debug_locs[read];
                }
            }
            write = write + 1;
        }
        read = read + 1;
    }
    block.inst_count = write;
}
