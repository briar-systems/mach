use std.types.bool;
use std.types.size;

use allocator: std.allocator;
use ir:        mach.compiler.masm.ir;

# mach.compiler.masm.opt.peephole: IR-level peephole optimizer.
# ---
# runs pattern-matching rules over IR instructions to eliminate redundancy
# before instruction selection. operates in-place on Block instruction
# arrays, marking eliminated instructions as NOP then compacting.

# OptContext: peephole optimizer state.
pub rec OptContext {
    alloc:      *allocator.Allocator;
    eliminated: i32;
}

# init: create a new optimizer context.
pub fun init(alloc: *allocator.Allocator) OptContext {
    var ctx: OptContext;
    ctx.alloc = alloc;
    ctx.eliminated = 0;
    ret ctx;
}

# optimize_function: run peephole optimization on all blocks in a function.
pub fun optimize_function(ctx: *OptContext, func: *ir.Function) {
    if (ctx == nil || func == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < func.block_count) {
        val block: *ir.Block = func.blocks[i];
        if (block != nil) {
            optimize_block(ctx, block);
        }
        i = i + 1;
    }
}

# optimize_block: run peephole rules on a single block in a fixed-point loop.
# each rule marks eliminated instructions as OP_NOP. after convergence,
# compact_block removes the NOPs and shifts remaining instructions down.
fun optimize_block(ctx: *OptContext, block: *ir.Block) {
    if (block == nil || block.insts == nil || block.inst_count == 0) {
        ret;
    }

    var changed: bool = true;
    for (changed) {
        changed = false;
        if (rule_nop_elimination(ctx, block))        { changed = true; }
        if (rule_self_move(ctx, block))               { changed = true; }
        if (rule_identity_add_sub(ctx, block))        { changed = true; }
        if (rule_identity_mul(ctx, block))            { changed = true; }
        if (rule_strength_reduction_mul(ctx, block))  { changed = true; }
        if (rule_constant_fold(ctx, block))           { changed = true; }
        if (rule_redundant_store_load(ctx, block))    { changed = true; }
    }

    compact_block(block);
}

# --- helper predicates ---

# is_reg: check if an operand is a register.
fun is_reg(op: *ir.Operand) bool {
    ret op.kind == ir.OPK_REG;
}

# is_imm: check if an operand is an immediate.
fun is_imm(op: *ir.Operand) bool {
    ret op.kind == ir.OPK_IMM;
}

# is_mem: check if an operand is a memory reference.
fun is_mem(op: *ir.Operand) bool {
    ret op.kind == ir.OPK_MEM;
}

# same_reg: check if two operands are the same register.
fun same_reg(a: *ir.Operand, b: *ir.Operand) bool {
    if (a.kind != ir.OPK_REG || b.kind != ir.OPK_REG) { ret false; }
    ret a.reg == b.reg;
}

# same_mem: check if two memory operands reference the same location.
fun same_mem(a: *ir.Operand, b: *ir.Operand) bool {
    if (a.kind != ir.OPK_MEM || b.kind != ir.OPK_MEM) { ret false; }
    ret a.base == b.base && a.index == b.index
        && a.scale == b.scale && a.disp == b.disp;
}

# mark_nop: mark an instruction as eliminated.
fun mark_nop(ctx: *OptContext, inst: *ir.Inst) {
    inst.op = ir.OP_NOP;
    inst.dst = ir.make_none();
    inst.src1 = ir.make_none();
    inst.src2 = ir.make_none();
    inst.cc = ir.CC_NONE;
    ctx.eliminated = ctx.eliminated + 1;
}

# is_power_of_two: check if a positive value is a power of two.
fun is_power_of_two(v: i64) bool {
    if (v <= 0) { ret false; }
    ret (v & (v - 1)) == 0;
}

# log2: compute floor(log2(v)) for a positive power-of-two value.
fun log2(v: i64) i64 {
    var n: i64 = 0;
    var x: i64 = v;
    for (x > 1) {
        x = x >> 1;
        n = n + 1;
    }
    ret n;
}

# --- peephole rules ---
# each rule scans the block, marks eliminated instructions as OP_NOP,
# and returns true if any transformation was applied.

# rule_nop_elimination: remove existing OP_NOP instructions.
# NOPs may exist from previous passes or from lowering.
fun rule_nop_elimination(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        if (block.insts[i].op == ir.OP_NOP) {
            # already a NOP, will be removed by compact_block.
            # only count as changed if this is a "new" NOP we haven't processed.
            # since compact_block runs after convergence, any NOP here means
            # we should signal compaction is needed (but not re-trigger rules).
        }
        i = i + 1;
    }
    ret changed;
}

# rule_self_move: eliminate MOV rX, rX (register to itself).
fun rule_self_move(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val inst: *ir.Inst = ?block.insts[i];
        if (inst.op == ir.OP_MOV && same_reg(?inst.dst, ?inst.src1)) {
            mark_nop(ctx, inst);
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_identity_add_sub: eliminate ADD rX, 0 and SUB rX, 0.
# these produce the same value as the input, so replace with a MOV
# if dst != src1, or NOP if dst == src1.
fun rule_identity_add_sub(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val inst: *ir.Inst = ?block.insts[i];
        if ((inst.op == ir.OP_ADD || inst.op == ir.OP_SUB)
            && is_imm(?inst.src2) && inst.src2.imm == 0) {
            if (same_reg(?inst.dst, ?inst.src1)) {
                mark_nop(ctx, inst);
            } or {
                inst.op = ir.OP_MOV;
                inst.src2 = ir.make_none();
                inst.cc = ir.CC_NONE;
            }
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_identity_mul: eliminate MUL rX, 1.
# multiplying by 1 is an identity operation.
fun rule_identity_mul(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val inst: *ir.Inst = ?block.insts[i];
        if (inst.op == ir.OP_MUL && is_imm(?inst.src2) && inst.src2.imm == 1) {
            if (same_reg(?inst.dst, ?inst.src1)) {
                mark_nop(ctx, inst);
            } or {
                inst.op = ir.OP_MOV;
                inst.src2 = ir.make_none();
                inst.cc = ir.CC_NONE;
            }
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_strength_reduction_mul: replace MUL rX, 2^n with SHL rX, n.
# shifting is cheaper than multiplication. only applies to power-of-two
# immediates > 1 (mul by 1 is handled by rule_identity_mul).
fun rule_strength_reduction_mul(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val inst: *ir.Inst = ?block.insts[i];
        if (inst.op == ir.OP_MUL && is_imm(?inst.src2)
            && inst.src2.imm > 1 && is_power_of_two(inst.src2.imm)) {
            val shift: i64 = log2(inst.src2.imm);
            inst.op = ir.OP_SHL;
            inst.src2.imm = shift;
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_constant_fold: fold binary ops where both sources are immediates.
# replaces the instruction with a MOV of the computed result.
fun rule_constant_fold(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < block.inst_count) {
        val inst: *ir.Inst = ?block.insts[i];
        if (!is_imm(?inst.src1) || !is_imm(?inst.src2)) {
            i = i + 1;
            cnt;
        }

        val a: i64 = inst.src1.imm;
        val b: i64 = inst.src2.imm;
        var result: i64 = 0;
        var folded: bool = false;

        if (inst.op == ir.OP_ADD) {
            result = a + b;
            folded = true;
        } or (inst.op == ir.OP_SUB) {
            result = a - b;
            folded = true;
        } or (inst.op == ir.OP_MUL) {
            result = a * b;
            folded = true;
        } or (inst.op == ir.OP_AND) {
            result = a & b;
            folded = true;
        } or (inst.op == ir.OP_OR) {
            result = a | b;
            folded = true;
        } or (inst.op == ir.OP_XOR) {
            result = a ^ b;
            folded = true;
        } or (inst.op == ir.OP_SHL) {
            result = a << b;
            folded = true;
        } or (inst.op == ir.OP_SHR) {
            # logical shift right: cast to unsigned, shift, cast back
            result = (a::u64 >> b::u64)::i64;
            folded = true;
        } or (inst.op == ir.OP_SAR) {
            # arithmetic shift right: signed shift
            result = a >> b;
            folded = true;
        }

        if (folded) {
            inst.op = ir.OP_MOV;
            inst.src1 = ir.make_imm(result, inst.dst.size);
            inst.src2 = ir.make_none();
            inst.cc = ir.CC_NONE;
            changed = true;
        }

        i = i + 1;
    }
    ret changed;
}

# rule_redundant_store_load: eliminate LOAD after STORE to the same address.
# pattern: STORE [mem], rX  followed by  LOAD rY, [mem]
# the LOAD is redundant because rX already holds the value.
# replace the LOAD with MOV rY, rX (or NOP if rY == rX).
fun rule_redundant_store_load(ctx: *OptContext, block: *ir.Block) bool {
    var changed: bool = false;
    if (block.inst_count < 2) { ret false; }

    var i: i32 = 0;
    for (i < block.inst_count - 1) {
        val store: *ir.Inst = ?block.insts[i];
        val load:  *ir.Inst = ?block.insts[i + 1];

        # match STORE [mem], rX followed by LOAD rY, [mem]
        if (store.op == ir.OP_STORE && load.op == ir.OP_LOAD
            && is_mem(?store.dst) && is_mem(?load.src1)
            && same_mem(?store.dst, ?load.src1)
            && is_reg(?store.src1)) {
            # replace LOAD with MOV rY, rX (or NOP if same reg)
            if (is_reg(?load.dst) && same_reg(?load.dst, ?store.src1)) {
                mark_nop(ctx, load);
            } or {
                load.op = ir.OP_MOV;
                load.src1 = store.src1;
                load.src2 = ir.make_none();
                load.cc = ir.CC_NONE;
            }
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# --- block compaction ---

# compact_block: remove all OP_NOP instructions by shifting remaining
# instructions down. updates inst_count to reflect the new size.
fun compact_block(block: *ir.Block) {
    if (block == nil || block.insts == nil) { ret; }

    var write: i32 = 0;
    var read: i32 = 0;
    for (read < block.inst_count) {
        if (block.insts[read].op != ir.OP_NOP) {
            if (write != read) {
                block.insts[write] = block.insts[read];
            }
            write = write + 1;
        }
        read = read + 1;
    }
    block.inst_count = write;
}
