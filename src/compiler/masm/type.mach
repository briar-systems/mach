use std.types.bool;
use std.types.size;
use std.types.string;

# mach.compiler.masm.type: machine-level type representation for MASM.
# ---
# provides size and alignment information for types at the machine level.

# MasmType: machine-level type information.
# ---
# size:  size in bytes
# align: alignment in bytes
# kind:  type category
pub rec MasmType {
    size:  usize;
    align: usize;
    kind:  MasmTypeKind;
}

# MasmTypeKind: category of machine type.
# ---
# mt_void:    no type
# mt_int:     integer type
# mt_float:   floating point type
# mt_ptr:     pointer type
# mt_array:   array type
# mt_struct:  struct/record type
pub uni MasmTypeKind {
    mt_void:   u8;
    mt_int:    u8;
    mt_float:  u8;
    mt_ptr:    u8;
    mt_array:  u8;
    mt_struct: u8;
}

# void_type: create a void type.
# ---
# ret: MasmType with size 0
pub fun void_type() MasmType {
    var t: MasmType;
    t.size = 0;
    t.align = 1;
    t.kind = MasmTypeKind { mt_void: 0 };
    ret t;
}

# int_type: create an integer type.
# ---
# size: size in bytes (1, 2, 4, 8)
# ret:  MasmType for the integer
pub fun int_type(size: usize) MasmType {
    var t: MasmType;
    t.size = size;
    t.align = size;
    t.kind = MasmTypeKind { mt_int: 0 };
    ret t;
}

# float_type: create a floating point type.
# ---
# size: size in bytes (4 for f32, 8 for f64)
# ret:  MasmType for the float
pub fun float_type(size: usize) MasmType {
    var t: MasmType;
    t.size = size;
    t.align = size;
    t.kind = MasmTypeKind { mt_float: 0 };
    ret t;
}

# ptr_type: create a pointer type.
# ---
# ptr_size: pointer size in bytes (typically 8 for 64-bit)
# ret:      MasmType for the pointer
pub fun ptr_type(ptr_size: usize) MasmType {
    var t: MasmType;
    t.size = ptr_size;
    t.align = ptr_size;
    t.kind = MasmTypeKind { mt_ptr: 0 };
    ret t;
}

# array_type: create an array type.
# ---
# elem_size:  size of each element
# elem_align: alignment of elements
# count:      number of elements
# ret:        MasmType for the array
pub fun array_type(elem_size: usize, elem_align: usize, count: usize) MasmType {
    var t: MasmType;
    t.size = elem_size * count;
    t.align = elem_align;
    t.kind = MasmTypeKind { mt_array: 0 };
    ret t;
}

# struct_type: create a struct type.
# ---
# size:  total size in bytes
# align: alignment requirement
# ret:   MasmType for the struct
pub fun struct_type(size: usize, align: usize) MasmType {
    var t: MasmType;
    t.size = size;
    t.align = align;
    t.kind = MasmTypeKind { mt_struct: 0 };
    ret t;
}

# i8: 8-bit signed integer type.
# ---
# ret: MasmType for i8
pub fun i8() MasmType {
    ret int_type(1);
}

# i16: 16-bit signed integer type.
# ---
# ret: MasmType for i16
pub fun i16() MasmType {
    ret int_type(2);
}

# i32: 32-bit signed integer type.
# ---
# ret: MasmType for i32
pub fun i32() MasmType {
    ret int_type(4);
}

# i64: 64-bit signed integer type.
# ---
# ret: MasmType for i64
pub fun i64() MasmType {
    ret int_type(8);
}

# f32: 32-bit floating point type.
# ---
# ret: MasmType for f32
pub fun f32() MasmType {
    ret float_type(4);
}

# f64: 64-bit floating point type.
# ---
# ret: MasmType for f64
pub fun f64() MasmType {
    ret float_type(8);
}

# align_to: align a size to the given alignment.
# ---
# size:  size to align
# align: alignment requirement (must be power of 2)
# ret:   aligned size
pub fun align_to(size: usize, align: usize) usize {
    if (align == 0 || align == 1) {
        ret size;
    }

    val mask: usize = align - 1;
    ret (size + mask) & ~mask;
}
