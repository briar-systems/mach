use std.types.bool;
use std.types.size;

# mach.compiler.masm.type: machine-level type representation.
# ---
# maps mach language types to machine sizes and alignments.

# TypeKind: category of machine type.
pub def TypeKind: u8;

pub val TK_VOID:   TypeKind = 0;
pub val TK_INT:    TypeKind = 1;
pub val TK_FLOAT:  TypeKind = 2;
pub val TK_PTR:    TypeKind = 3;
pub val TK_ARRAY:  TypeKind = 4;
pub val TK_STRUCT: TypeKind = 5;

# Type: machine-level type information.
pub rec Type {
    size:  usize;
    align: usize;
    kind:  TypeKind;
}

# --- constructors ---

pub fun void_type() Type {
    var t: Type;
    t.size = 0;
    t.align = 1;
    t.kind = TK_VOID;
    ret t;
}

pub fun int_type(size: usize) Type {
    var t: Type;
    t.size = size;
    t.align = size;
    t.kind = TK_INT;
    ret t;
}

pub fun float_type(size: usize) Type {
    var t: Type;
    t.size = size;
    t.align = size;
    t.kind = TK_FLOAT;
    ret t;
}

pub fun ptr_type(ptr_size: usize) Type {
    var t: Type;
    t.size = ptr_size;
    t.align = ptr_size;
    t.kind = TK_PTR;
    ret t;
}

pub fun array_type(elem_size: usize, elem_align: usize, count: usize) Type {
    var t: Type;
    t.size = elem_size * count;
    t.align = elem_align;
    t.kind = TK_ARRAY;
    ret t;
}

pub fun struct_type(size: usize, align: usize) Type {
    var t: Type;
    t.size = size;
    t.align = align;
    t.kind = TK_STRUCT;
    ret t;
}

# --- convenience constructors ---

pub fun i8() Type  { ret int_type(1); }
pub fun i16() Type { ret int_type(2); }
pub fun i32() Type { ret int_type(4); }
pub fun i64() Type { ret int_type(8); }
pub fun f32() Type { ret float_type(4); }
pub fun f64() Type { ret float_type(8); }

# --- utilities ---

# align_to: round `size` up to the nearest multiple of `align`.
# ---
# align must be a power of 2.
pub fun align_to(size: usize, align: usize) usize {
    if (align == 0 || align == 1) {
        ret size;
    }
    val mask: usize = align - 1;
    ret (size + mask) & ~mask;
}

# is_float: check if a type is floating point.
pub fun is_float(t: *Type) bool {
    if (t == nil) { ret false; }
    ret t.kind == TK_FLOAT;
}

# is_aggregate: check if a type is a struct or array.
pub fun is_aggregate(t: *Type) bool {
    if (t == nil) { ret false; }
    ret t.kind == TK_STRUCT || t.kind == TK_ARRAY;
}
