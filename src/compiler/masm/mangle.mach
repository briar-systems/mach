use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;

# mach.compiler.masm.mangle: name mangling for linkage and type encoding.
# ---
# provides symbol name mangling and type mangling for codegen and sema.

# digits_len: get the number of decimal digits needed to represent a number.
# ---
# n: number to measure
# ret: number of digits
fun digits_len(n: usize) usize {
    if (n == 0) { ret 1; }
    var count: usize = 0;
    var v: usize = n;
    for (v > 0) {
        count = count + 1;
        v = v / 10;
    }
    ret count;
}

# write_digits: write a number as decimal digits into a buffer.
# ---
# buf: destination buffer
# pos: starting position
# n: number to write
# ret: position after the written digits
fun write_digits(buf: *u8, pos: usize, n: usize) usize {
    if (n == 0) {
        buf[pos] = 48;  # '0'
        ret pos + 1;
    }
    val dlen: usize = digits_len(n);
    var i: usize = pos + dlen;
    var v: usize = n;
    for (v > 0) {
        i = i - 1;
        buf[i] = (v % 10)::u8 + 48;  # + '0'
        v = v / 10;
    }
    ret pos + dlen;
}

# mangle: compute the mangled name for a symbol.
# ---
# uses the scheme: _M<encoded_module_path>N<name_len><name>
# where encoded_module_path has length-prefixed segments.
# e.g., module_path="std.print", name="eprintln" -> "_M3std5printN8eprintln"
# alloc: allocator for the mangled name
# sym: symbol to mangle
# ret: mangled name or nil
pub fun mangle(alloc: *allocator.Allocator, sym: *symbol.Symbol) str {
    if (sym == nil || sym.name == nil || alloc == nil) {
        ret nil;
    }

    val path: str = sym.module_path;
    if (path == nil) {
        ret sym.name;
    }

    val name: str = sym.name;
    val name_len: usize = str_len(name);

    # calculate total mangled name length
    # prefix: "_M" (2 bytes)
    # module path segments: for each segment, digits_len(seg_len) + seg_len
    # separator: "N" (1 byte)
    # name part: digits_len(name_len) + name_len
    # null terminator: 1 byte
    var total: usize = 2;  # "_M"

    # count path segments and their encoded lengths
    val path_len: usize = str_len(path);
    var seg_start: usize = 0;
    var pi: usize = 0;
    for (pi <= path_len) {
        if (pi == path_len || path[pi] == 46) {  # '.'
            val seg_len: usize = pi - seg_start;
            if (seg_len > 0) {
                total = total + digits_len(seg_len) + seg_len;
            }
            seg_start = pi + 1;
        }
        pi = pi + 1;
    }

    total = total + 1;  # "N"
    total = total + digits_len(name_len) + name_len;
    total = total + 1;  # null terminator

    # allocate buffer
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret sym.name;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    # write "_M"
    buf[0] = 95;   # '_'
    buf[1] = 77;   # 'M'
    var pos: usize = 2;

    # write encoded module path segments
    seg_start = 0;
    pi = 0;
    for (pi <= path_len) {
        if (pi == path_len || path[pi] == 46) {  # '.'
            val seg_len: usize = pi - seg_start;
            if (seg_len > 0) {
                pos = write_digits(buf, pos, seg_len);
                var si: usize = 0;
                for (si < seg_len) {
                    buf[pos] = path[seg_start + si];
                    pos = pos + 1;
                    si = si + 1;
                }
            }
            seg_start = pi + 1;
        }
        pi = pi + 1;
    }

    # write "N"
    buf[pos] = 78;  # 'N'
    pos = pos + 1;

    # write name length and name
    pos = write_digits(buf, pos, name_len);
    var ni: usize = 0;
    for (ni < name_len) {
        buf[pos] = name[ni];
        pos = pos + 1;
        ni = ni + 1;
    }

    # null terminator
    buf[pos] = 0;

    ret buf::str;
}

# linkage_name: get the linkage name for a symbol.
# ---
# sym:   symbol to query
# alloc: allocator for mangled name computation
# ret:   export_name if set, mangled name if module_path set, otherwise name
pub fun linkage_name(sym: *symbol.Symbol, alloc: *allocator.Allocator) str {
    if (sym == nil) {
        ret nil;
    }
    if (sym.export_name != nil) {
        ret sym.export_name;
    }
    # external symbols should not be mangled
    if (sym.kind == symbol.SYM_EXT) {
        ret sym.name;
    }
    if (sym.module_path != nil && alloc != nil) {
        ret mangle(alloc, sym);
    }
    ret sym.name;
}

# type_mangle: write a mangled representation of a type to a buffer.
# ---
# t:        type to mangle
# buf:      output buffer
# buf_size: size of buffer in bytes
# ret:      number of bytes written
pub fun type_mangle(t: *ty.Type, buf: *u8, buf_size: usize) i32 {
    if (t == nil || buf == nil || buf_size == 0) {
        ret 0;
    }

    var written: i32 = 0;

    # primitives - length-prefixed type names
    if (t.kind == ty.TY_BOOL) {
        if (buf_size >= 5) { buf[0] = '4'; buf[1] = 'b'; buf[2] = 'o'; buf[3] = 'o'; buf[4] = 'l'; written = 5; }
        ret written;
    }
    if (t.kind == ty.TY_U8) {
        if (buf_size >= 3) { buf[0] = '2'; buf[1] = 'u'; buf[2] = '8'; written = 3; }
        ret written;
    }
    if (t.kind == ty.TY_U16) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'u'; buf[2] = '1'; buf[3] = '6'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_U32) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'u'; buf[2] = '3'; buf[3] = '2'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_U64) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'u'; buf[2] = '6'; buf[3] = '4'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_I8) {
        if (buf_size >= 3) { buf[0] = '2'; buf[1] = 'i'; buf[2] = '8'; written = 3; }
        ret written;
    }
    if (t.kind == ty.TY_I16) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'i'; buf[2] = '1'; buf[3] = '6'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_I32) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'i'; buf[2] = '3'; buf[3] = '2'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_I64) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'i'; buf[2] = '6'; buf[3] = '4'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_F32) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'f'; buf[2] = '3'; buf[3] = '2'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_F64) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'f'; buf[2] = '6'; buf[3] = '4'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_PTR) {
        if (buf_size >= 4) { buf[0] = '3'; buf[1] = 'p'; buf[2] = 't'; buf[3] = 'r'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_USIZE) {
        if (buf_size >= 6) { buf[0] = '5'; buf[1] = 'u'; buf[2] = 's'; buf[3] = 'i'; buf[4] = 'z'; buf[5] = 'e'; written = 6; }
        ret written;
    }
    if (t.kind == ty.TY_ISIZE) {
        if (buf_size >= 6) { buf[0] = '5'; buf[1] = 'i'; buf[2] = 's'; buf[3] = 'i'; buf[4] = 'z'; buf[5] = 'e'; written = 6; }
        ret written;
    }
    if (t.kind == ty.TY_STR) {
        # str is an alias for &u8 — mangle as K2u8 (const pointer to u8)
        if (buf_size >= 4) { buf[0] = 'K'; buf[1] = '2'; buf[2] = 'u'; buf[3] = '8'; written = 4; }
        ret written;
    }
    if (t.kind == ty.TY_VOID) {
        if (buf_size >= 1) { buf[0] = 'v'; written = 1; }
        ret written;
    }

    # pointer type: P<base> for mutable, K<base> for const/readonly
    if (t.kind == ty.TY_POINTER) {
        if (t.is_mutable) {
            if (buf_size >= 1) { buf[0] = 'P'; written = 1; }
        } or {
            if (buf_size >= 1) { buf[0] = 'K'; written = 1; }
        }
        if (t.inner != nil && written > 0) {
            val inner_written: i32 = type_mangle(t.inner, ?buf[written::usize], buf_size - written::usize);
            written = written + inner_written;
        }
        ret written;
    }

    # record type: length-prefixed name
    if (t.kind == ty.TY_RECORD) {
        var rname: str = t.name;
        if (rname == nil) { rname = "anon"; }
        val rname_len: usize = str_len(rname);
        # write length digits then name
        written = write_length_prefixed(rname, rname_len, buf, buf_size);
        ret written;
    }

    # union type: length-prefixed name
    if (t.kind == ty.TY_UNION) {
        var uname: str = t.name;
        if (uname == nil) { uname = "anon"; }
        val uname_len: usize = str_len(uname);
        written = write_length_prefixed(uname, uname_len, buf, buf_size);
        ret written;
    }

    # array type: A<count>_<elem_type>
    if (t.kind == ty.TY_ARRAY) {
        if (buf_size >= 1) {
            buf[0] = 'A';
            written = 1;
            # write array length digits
            val len_written: i32 = write_usize_digits(t.array_len, ?buf[written::usize], buf_size - written::usize);
            written = written + len_written;
            if (written::usize < buf_size) {
                buf[written::usize] = '_';
                written = written + 1;
            }
            if (t.inner != nil) {
                val elem_written: i32 = type_mangle(t.inner, ?buf[written::usize], buf_size - written::usize);
                written = written + elem_written;
            }
        }
        ret written;
    }

    # function type: F<return><params>E
    if (t.kind == ty.TY_FUN) {
        if (buf_size >= 1) {
            buf[0] = 'F';
            written = 1;
            if (t.ret_type != nil) {
                val ret_written: i32 = type_mangle(t.ret_type, ?buf[written::usize], buf_size - written::usize);
                written = written + ret_written;
            } or {
                if (written::usize < buf_size) { buf[written::usize] = 'v'; written = written + 1; }
            }
            var pi: i32 = 0;
            for (pi < t.param_count) {
                if (t.params[pi] != nil) {
                    val p_written: i32 = type_mangle(t.params[pi], ?buf[written::usize], buf_size - written::usize);
                    written = written + p_written;
                }
                pi = pi + 1;
            }
            if (written::usize < buf_size) { buf[written::usize] = 'E'; written = written + 1; }
        }
        ret written;
    }

    # generic param: length-prefixed name
    if (t.kind == ty.TY_GENERIC) {
        var gname: str = t.name;
        if (gname == nil) { gname = "T"; }
        val gname_len: usize = str_len(gname);
        written = write_length_prefixed(gname, gname_len, buf, buf_size);
        ret written;
    }

    ret written;
}

# write_length_prefixed: write a length-prefixed string to buffer.
# ---
# s:        string to write
# s_len:    length of string
# buf:      output buffer
# buf_size: size of buffer
# ret:      bytes written
fun write_length_prefixed(s: str, s_len: usize, buf: *u8, buf_size: usize) i32 {
    var written: i32 = 0;
    # write length digits
    val len_written: i32 = write_usize_digits(s_len, buf, buf_size);
    written = written + len_written;
    # write name characters
    var ci: usize = 0;
    for (ci < s_len && written::usize < buf_size) {
        buf[written::usize] = s[ci];
        written = written + 1;
        ci = ci + 1;
    }
    ret written;
}

# write_usize_digits: write a usize as decimal digits to buffer.
# ---
# v:        value to write
# buf:      output buffer
# buf_size: size of buffer
# ret:      bytes written
fun write_usize_digits(v: usize, buf: *u8, buf_size: usize) i32 {
    if (buf_size == 0) { ret 0; }
    if (v == 0) {
        buf[0] = '0';
        ret 1;
    }
    # write digits in reverse then reverse
    var digits: [20]u8;
    var digit_count: i32 = 0;
    var tmp: usize = v;
    for (tmp > 0 && digit_count < 20) {
        digits[digit_count] = ('0' + (tmp % 10)::u8)::u8;
        tmp = tmp / 10;
        digit_count = digit_count + 1;
    }
    # copy in reverse
    var written: i32 = 0;
    var di: i32 = digit_count - 1;
    for (di >= 0 && written::usize < buf_size) {
        buf[written::usize] = digits[di];
        written = written + 1;
        di = di - 1;
    }
    ret written;
}
