use std.types.bool;
use std.types.size;
use std.types.string;

use spec: mach.compiler.masm.os.spec;

# mach.compiler.masm.os.linux: Linux-specific code generation details.
# ---
# provides Linux-specific constants and helpers for code generation.

# linux syscall numbers (x86-64)
pub val SYS_READ:      i64 = 0;
pub val SYS_WRITE:     i64 = 1;
pub val SYS_OPEN:      i64 = 2;
pub val SYS_CLOSE:     i64 = 3;
pub val SYS_STAT:      i64 = 4;
pub val SYS_FSTAT:     i64 = 5;
pub val SYS_LSTAT:     i64 = 6;
pub val SYS_POLL:      i64 = 7;
pub val SYS_LSEEK:     i64 = 8;
pub val SYS_MMAP:      i64 = 9;
pub val SYS_MPROTECT:  i64 = 10;
pub val SYS_MUNMAP:    i64 = 11;
pub val SYS_BRK:       i64 = 12;
pub val SYS_IOCTL:     i64 = 16;
pub val SYS_ACCESS:    i64 = 21;
pub val SYS_PIPE:      i64 = 22;
pub val SYS_DUP:       i64 = 32;
pub val SYS_DUP2:      i64 = 33;
pub val SYS_NANOSLEEP: i64 = 35;
pub val SYS_GETPID:    i64 = 39;
pub val SYS_FORK:      i64 = 57;
pub val SYS_EXECVE:    i64 = 59;
pub val SYS_EXIT:      i64 = 60;
pub val SYS_WAIT4:     i64 = 61;
pub val SYS_KILL:      i64 = 62;
pub val SYS_UNAME:     i64 = 63;
pub val SYS_FCNTL:     i64 = 72;
pub val SYS_GETCWD:    i64 = 79;
pub val SYS_CHDIR:     i64 = 80;
pub val SYS_MKDIR:     i64 = 83;
pub val SYS_RMDIR:     i64 = 84;
pub val SYS_UNLINK:    i64 = 87;
pub val SYS_READLINK:  i64 = 89;
pub val SYS_GETUID:    i64 = 102;
pub val SYS_GETGID:    i64 = 104;
pub val SYS_GETEUID:   i64 = 107;
pub val SYS_GETEGID:   i64 = 108;
pub val SYS_GETPPID:   i64 = 110;
pub val SYS_ARCH_PRCTL: i64 = 158;
pub val SYS_CLOCK_GETTIME: i64 = 228;
pub val SYS_EXIT_GROUP: i64 = 231;
pub val SYS_OPENAT:    i64 = 257;
pub val SYS_MKDIRAT:   i64 = 258;
pub val SYS_FSTATAT:   i64 = 262;
pub val SYS_UNLINKAT:  i64 = 263;
pub val SYS_RENAMEAT:  i64 = 264;
pub val SYS_FACCESSAT: i64 = 269;

# file descriptor constants
pub val STDIN:  i32 = 0;
pub val STDOUT: i32 = 1;
pub val STDERR: i32 = 2;

# open flags
pub val O_RDONLY:    i32 = 0;
pub val O_WRONLY:    i32 = 1;
pub val O_RDWR:      i32 = 2;
pub val O_CREAT:     i32 = 64;
pub val O_EXCL:      i32 = 128;
pub val O_TRUNC:     i32 = 512;
pub val O_APPEND:    i32 = 1024;
pub val O_NONBLOCK:  i32 = 2048;
pub val O_DIRECTORY: i32 = 65536;
pub val O_CLOEXEC:   i32 = 524288;

# mmap protection flags
pub val PROT_NONE:  i32 = 0;
pub val PROT_READ:  i32 = 1;
pub val PROT_WRITE: i32 = 2;
pub val PROT_EXEC:  i32 = 4;

# mmap flags
pub val MAP_SHARED:    i32 = 1;
pub val MAP_PRIVATE:   i32 = 2;
pub val MAP_FIXED:     i32 = 16;
pub val MAP_ANONYMOUS: i32 = 32;

# seek constants
pub val SEEK_SET: i32 = 0;
pub val SEEK_CUR: i32 = 1;
pub val SEEK_END: i32 = 2;

# clock IDs
pub val CLOCK_REALTIME:  i32 = 0;
pub val CLOCK_MONOTONIC: i32 = 1;

# AT_* constants for *at syscalls
pub val AT_FDCWD:            i32 = -100;
pub val AT_REMOVEDIR:        i32 = 512;
pub val AT_SYMLINK_NOFOLLOW: i32 = 256;

# get: get the Linux OS specification.
# ---
# ret: OS specification for Linux
pub fun get() spec.OS {
    var os: spec.OS;
    os.kind = spec.OSKind { os_linux: 0 };
    os.name = "linux";
    os.default_exe_ext = "";
    os.default_obj_ext = ".o";
    os.default_lib_ext = ".a";
    os.default_dll_ext = ".so";
    os.path_separator = 47; # '/'
    os.uses_underscore = false;
    ret os;
}

# get_dynamic_linker: get the path to the dynamic linker.
# ---
# ret: path to ld-linux
pub fun get_dynamic_linker() str {
    ret "/lib64/ld-linux-x86-64.so.2";
}

# get_libc_path: get the default libc search path.
# ---
# ret: libc search path
pub fun get_libc_path() str {
    ret "/lib/x86_64-linux-gnu";
}

# get_crt_path: get the path to C runtime startup files.
# ---
# ret: CRT path
pub fun get_crt_path() str {
    ret "/usr/lib/x86_64-linux-gnu";
}

# crt_files: list of CRT files needed for linking an executable.
# ---
# note: typical order is: crt1.o crti.o <user objects> crtn.o
pub val CRT1: str = "crt1.o";
pub val CRTI: str = "crti.o";
pub val CRTN: str = "crtn.o";

# is_pic_default: check if position-independent code is default.
# ---
# ret: true (PIC is default on modern Linux)
pub fun is_pic_default() bool {
    ret true;
}

# supports_execstack: check if executable stack is supported.
# ---
# ret: true (Linux supports executable stacks, though discouraged)
pub fun supports_execstack() bool {
    ret true;
}

# default_stack_size: get the default stack size.
# ---
# ret: default stack size in bytes (8 MB)
pub fun default_stack_size() usize {
    ret 8388608;
}

# page_size: get the system page size.
# ---
# ret: page size in bytes (4 KB on x86-64)
pub fun page_size() usize {
    ret 4096;
}

# max_path_length: get the maximum path length.
# ---
# ret: PATH_MAX value
pub fun max_path_length() usize {
    ret 4096;
}
