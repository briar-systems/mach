use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use masm:    mach.compiler.masm.masm;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;
use target:  mach.compiler.masm.target;

# mach.compiler.masm.emit: emit MASM to object file.
# ---
# handles the final stage of code generation, converting MASM sections and
# symbols into an object file format (ELF, Mach-O, etc.).

# EmitContext: context for object file emission.
# ---
# alloc:       allocator for emission
# m:           masm context to emit
# output_path: path to output file
pub rec EmitContext {
    alloc:       *allocator.Allocator;
    m:           *masm.Masm;
    output_path: str;
}

# init: create a new emit context.
# ---
# alloc:       allocator to use
# m:           masm context to emit
# output_path: path for output file
# ret:         initialized EmitContext
pub fun init(alloc: *allocator.Allocator, m: *masm.Masm, output_path: str) EmitContext {
    var ctx: EmitContext;
    ctx.alloc = alloc;
    ctx.m = m;
    ctx.output_path = output_path;
    ret ctx;
}

# emit_object: emit the MASM context to an object file.
# ---
# m:           masm context to emit
# output_path: path for output file
# ret:         Ok(true) on success, Err(str) on failure
pub fun emit_object(m: *masm.Masm, output_path: str) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("masm context is nil");
    }

    if (output_path == nil) {
        ret err[bool, str]("output path is nil");
    }

    # TODO: determine output format based on target
