# link_objects: link multiple object files into an executable.
# ---
# alloc:       allocator to use
# objects:     array of object file paths
# count:       number of object files
# output_path: path for output executable
# ret:         Ok(true) on success, Err(str) on failure
pub fun link_objects(alloc: *allocator.Allocator, objects: *str, count: i32, output_path: str) Result[bool, str] {
    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    if (objects == nil || count == 0) {
        ret err[bool, str]("no objects to link");
    }

    if (output_path == nil) {
        ret err[bool, str]("output path is nil");
    }

    # TODO: build linker command
    # TODO: execute linker (ld or platform equivalent)
    # TODO: check exit status

    ret err[bool, str]("link_objects not yet implemented");
}

# compute_section_offsets: compute file offsets for all sections.
# ---
# m:            masm context
# base_offset:  starting offset after headers
# ret:          total size of all sections
pub fun compute_section_offsets(m: *masm.Masm, base_offset: usize) usize {
    if (m == nil) {
        ret 0;
    }

    var offset: usize = base_offset;
    var i: i32 = 0;
    for (i < m.section_count) {
        val sec: *section.Section = m.sections[i];
        if (sec != nil) {
            # align offset
            if (sec.align > 1) {
                val mask: usize = sec.align - 1;
                offset = (offset + mask) & ~mask;
            }

            # TODO: store offset in section
            offset = offset + sec.size;
        }
        i = i + 1;
    }

    ret offset;
}

# compute_symbol_indices: assign indices to all symbols.
# ---
# m: masm context
# ret: number of symbols
pub fun compute_symbol_indices(m: *masm.Masm) i32 {
    if (m == nil) {
        ret 0;
    }

    var idx: i32 = 0;
    var i: i32 = 0;
    for (i < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil) {
            # TODO: assign index to symbol
            idx = idx + 1;
        }
        i = i + 1;
    }

    ret idx;
}
