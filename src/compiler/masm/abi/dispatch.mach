use target: mach.compiler.masm.target;
use spec:   mach.compiler.masm.abi.spec;
use sysv64: mach.compiler.masm.abi.sysv64;

# mach.compiler.masm.abi.dispatch: ABI dispatch layer.
# ---
# returns the correct ABI specification based on the target configuration.
# to add a new ABI: import the new module and add a dispatch case.

# for_target: get the ABI specification for the given target.
# ---
# tgt: target configuration
# ret: ABI specification for the target's calling convention
pub fun for_target(tgt: *target.Target) spec.ABI {
    if (tgt != nil && tgt.abi.tag == target.ABI_WIN64) {
        # future: ret win64.get();
    }

    # default to SysV AMD64
    ret sysv64.get();
}
