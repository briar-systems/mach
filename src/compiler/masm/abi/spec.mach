use std.types.bool;
use std.types.size;
use std.types.string;

use ir: mach.compiler.masm.ir;
use ty: mach.compiler.type;

# mach.compiler.masm.abi.spec: ABI specification interface.
# ---
# defines the interface for calling conventions and ABI implementations.

# ABI: calling convention specification.
# ---
# name:              ABI name (e.g. "sysv64", "win64")
# arg_regs:          registers used for integer/pointer arguments
# arg_reg_count:     number of argument registers
# float_arg_regs:    registers used for floating point arguments
# float_arg_count:   number of float argument registers
# ret_reg:           register for integer return values
# float_ret_reg:     register for floating point return values
# callee_saved:      registers that must be preserved across calls
# callee_saved_count: number of callee-saved registers
# stack_align:       required stack alignment in bytes
# red_zone_size:     size of red zone below stack pointer (0 if none)
# shadow_space:      shadow space required before call (for win64)
# max_ret_size:      max return size in registers (types larger need sret)
# va_save_size:      register save area size for variadic functions
# stack_reg:         stack pointer register
# frame_reg:         frame pointer register
# slot_size:         stack slot width in bytes (8 for 64-bit targets)
# first_stack_param_offset: frame pointer to first stack-passed parameter
#                           (16 for SysV64 = saved_rbp + return_addr)
# syscall_regs:      registers for syscall arguments (in order)
# syscall_reg_count: number of syscall argument registers
# syscall_num_reg:   register for syscall number
pub rec ABI {
    name:               str;
    arg_regs:           *i32;
    arg_reg_count:      i32;
    float_arg_regs:     *i32;
    float_arg_count:    i32;
    ret_reg:            i32;
    float_ret_reg:      i32;
    callee_saved:       *i32;
    callee_saved_count: i32;
    stack_align:        usize;
    red_zone_size:      usize;
    shadow_space:       usize;
    max_ret_size:       i32;
    va_save_size:       i32;
    stack_reg:          i32;
    frame_reg:          i32;
    slot_size:          usize;
    first_stack_param_offset: i32;
    syscall_regs:       *i32;
    syscall_reg_count:  i32;
    syscall_num_reg:    i32;
}

# ArgLocation: where an argument is passed.
# ---
# in_reg:   argument is in a register
# on_stack: argument is on the stack
pub uni ArgLocationKind {
    in_reg:   u8;
    on_stack: u8;
}

# ArgInfo: information about how an argument is passed.
# ---
# kind:        where the argument is located
# reg:         register number (if in register)
# stack_offset: offset from stack pointer (if on stack)
# size:        size of the argument in bytes
pub rec ArgInfo {
    kind:         ArgLocationKind;
    reg:          i32;
    stack_offset: usize;
    size:         usize;
}

# get_arg_location: determine where an argument should be passed.
# ---
# abi:       ABI specification
# arg_index: zero-based argument index
# is_float:  true if argument is floating point
# size:      size of argument in bytes
# ret:       ArgInfo describing where to pass the argument
pub fun get_arg_location(abi: *ABI, arg_index: i32, is_float: bool, size: usize) ArgInfo {
    var info: ArgInfo;
    info.kind = ArgLocationKind { on_stack: 0 };
    info.reg = -1;
    info.stack_offset = 0;
    info.size = size;

    if (abi == nil) {
        ret info;
    }

    if (is_float) {
        if (arg_index < abi.float_arg_count && abi.float_arg_regs != nil) {
            info.kind = ArgLocationKind { in_reg: 0 };
            info.reg = abi.float_arg_regs[arg_index];
        } or {
            # overflow float arg: passed on stack
            val overflow_idx: i32 = arg_index - abi.float_arg_count;
            info.kind = ArgLocationKind { on_stack: 0 };
            info.stack_offset = (overflow_idx::usize) * abi.slot_size;
        }
    } or {
        if (arg_index < abi.arg_reg_count && abi.arg_regs != nil) {
            info.kind = ArgLocationKind { in_reg: 0 };
            info.reg = abi.arg_regs[arg_index];
        } or {
            # overflow integer arg: passed on stack in order after register args
            val overflow_idx: i32 = arg_index - abi.arg_reg_count;
            info.kind = ArgLocationKind { on_stack: 0 };
            info.stack_offset = (overflow_idx::usize) * abi.slot_size;
        }
    }

    ret info;
}

# get_return_reg: get the register for return values.
# ---
# abi:      ABI specification
# is_float: true if return value is floating point
# ret:      register number
pub fun get_return_reg(abi: *ABI, is_float: bool) i32 {
    if (abi == nil) {
        ret 0;
    }

    if (is_float) {
        ret abi.float_ret_reg;
    }

    ret abi.ret_reg;
}

# is_callee_saved: check if a register is callee-saved.
# ---
# abi: ABI specification
# reg: register number
# ret: true if the register must be preserved by the callee
pub fun is_callee_saved(abi: *ABI, reg: i32) bool {
    if (abi == nil || abi.callee_saved == nil) {
        ret false;
    }

    var i: i32 = 0;
    for (i < abi.callee_saved_count) {
        if (abi.callee_saved[i] == reg) {
            ret true;
        }
        i = i + 1;
    }

    ret false;
}

# compute_frame_size: compute the stack frame size for a function.
# ---
# abi:          ABI specification
# local_size:   size of local variables
# spill_count:  number of spilled registers
# ret:          total frame size (aligned)
pub fun compute_frame_size(abi: *ABI, local_size: usize, spill_count: i32) usize {
    if (abi == nil) {
        ret local_size;
    }

    var size: usize = local_size + (spill_count::usize * 8);

    # align to stack alignment
    if (abi.stack_align > 1) {
        val mask: usize = abi.stack_align - 1;
        size = (size + mask) & ~mask;
    }

    ret size;
}

# get_arg_reg: get the integer argument register for the given index.
# ---
# a:     ABI specification
# index: zero-based argument index
# ret:   register number, or -1 if out of range
pub fun get_arg_reg(a: *ABI, index: i32) i32 {
    if (a == nil || a.arg_regs == nil || index < 0 || index >= a.arg_reg_count) {
        ret -1;
    }
    ret a.arg_regs[index];
}

# get_float_arg_reg: get the float argument register for the given index.
# ---
# a:     ABI specification
# index: zero-based argument index
# ret:   register number, or -1 if out of range
pub fun get_float_arg_reg(a: *ABI, index: i32) i32 {
    if (a == nil || a.float_arg_regs == nil || index < 0 || index >= a.float_arg_count) {
        ret -1;
    }
    ret a.float_arg_regs[index];
}

# is_sret_type: check if a return type needs a hidden struct-return pointer.
# ---
# abi:      ABI specification
# ret_type: the return type to check
# ret:      true if the type is too large for register return
pub fun is_sret_type(abi: *ABI, ret_type: *ty.Type) bool {
    if (abi == nil || ret_type == nil) {
        ret false;
    }

    val k: ty.TypeKind = ret_type.kind;
    if (k != ty.TY_RECORD && k != ty.TY_UNION && k != ty.TY_ARRAY) {
        ret false;
    }

    ret ret_type.size > abi.max_ret_size::usize;
}

# variadic_save_size: get the register save area size for variadic functions.
# ---
# abi: ABI specification
# ret: size in bytes of the variadic register save area
pub fun variadic_save_size(abi: *ABI) i32 {
    if (abi == nil) {
        ret 0;
    }

    ret abi.va_save_size;
}
