use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.masm.ir: intermediate representation for code generation.
# ---
# provides IR types used between AST lowering and machine code emission.
# all types here are target-independent. ISA-specific behavior is accessed
# through the ISA interface, not through MASM.
#
# compact 8-byte instruction format. fields f0, f1, f2 are reinterpreted
# per opcode — no Operand abstraction at the IR level. debug info lives
# in a parallel DebugLoc array per block. labels and large constants use
# per-function index tables.
#
# the Operand type is retained for MachInst and AsmInst (ISA layer).

# --- type aliases ---

# Operator: IR instruction opcode.
pub def Operator: u8;

# Cond: condition code for comparisons and conditional branches.
pub def Cond: u8;

# ValueKind: discriminant for Operand (MachInst/AsmInst only).
pub def ValueKind: u8;

# --- opcodes ---
# target-independent abstract operations.
# ISel lowers these to machine instructions.

# data movement
pub val OP_MOV:     Operator = 0;    # move/copy
pub val OP_LOAD:    Operator = 1;    # load from memory
pub val OP_STORE:   Operator = 2;    # store to memory
pub val OP_ADDR:    Operator = 3;    # compute effective address (no memory access)

# integer arithmetic
pub val OP_ADD:     Operator = 4;
pub val OP_SUB:     Operator = 5;
pub val OP_MUL:     Operator = 6;
pub val OP_DIV:     Operator = 7;    # signed division
pub val OP_MOD:     Operator = 8;    # signed modulo
pub val OP_DIVU:    Operator = 9;    # unsigned division
pub val OP_MODU:    Operator = 10;   # unsigned modulo

# bitwise
pub val OP_AND:     Operator = 11;
pub val OP_OR:      Operator = 12;
pub val OP_XOR:     Operator = 13;
pub val OP_SHL:     Operator = 14;
pub val OP_SHR:     Operator = 15;   # logical shift right
pub val OP_SAR:     Operator = 16;   # arithmetic shift right

# comparison — value-producing, NOT flag-setting
# dst = (src1 CC src2) ? 1 : 0
pub val OP_ICMP:    Operator = 17;   # integer compare
pub val OP_FCMP:    Operator = 18;   # float compare

# control flow
pub val OP_JMP:     Operator = 19;   # unconditional jump
pub val OP_BRCOND:  Operator = 20;   # branch if src1 is nonzero
pub val OP_CALL:    Operator = 21;   # function call
pub val OP_RET:     Operator = 22;   # return

# conversions
pub val OP_ZEXT:    Operator = 23;   # zero extend
pub val OP_SEXT:    Operator = 24;   # sign extend
pub val OP_TRUNC:   Operator = 25;   # truncate
pub val OP_ITOF:    Operator = 26;   # integer to float
pub val OP_FTOI:    Operator = 27;   # float to integer
pub val OP_FEXT:    Operator = 28;   # float extend (f32 -> f64)
pub val OP_FTRUNC:  Operator = 29;   # float truncate (f64 -> f32)

# float arithmetic
pub val OP_FADD:    Operator = 30;
pub val OP_FSUB:    Operator = 31;
pub val OP_FMUL:    Operator = 32;
pub val OP_FDIV:    Operator = 33;

# misc
pub val OP_LABEL:   Operator = 34;   # pseudo-instruction: label definition
pub val OP_SYSCALL: Operator = 35;   # system call

# ABI-abstract operations (lowering emits these; ABI lowering pass expands)
#
# OP_ARG:    f0=arg_idx, f1=value_reg, f2=packed(byte_size:u16|flags:u8|align:u8)
# OP_PARAM:  f0=param_idx, f1=abi_meta, f2=disp:i32 (FP-relative destination)
#   abi_meta = size_log2:3 | align_log2:3 | agg:1 | float:1
#   param_idx 254=sret, 255=vararg_save
# OP_RETVAL: f0=value_reg, f1=0, f2=packed(byte_size:u16|flags:u8|align:u8)
# OP_SCARG:  f0=arg_idx, f1=value_reg, f2=0
#
# OP_CALL pre-ABI: f0=result_reg, f1=ret_meta, f2=label_idx
#   ret_meta = size_log2:3 | align_log2:3 | ret_agg:1 | ret_float:1
#   meta.cc = call_flags (bit0=variadic), meta.flag = 0=direct/1=indirect
#   indirect: f1=target_reg, f2=ret_meta_packed
# OP_CALL post-ABI: f0=0, f1=0, f2=label_idx (or f1=target_reg if indirect)
#
pub val OP_ARG:     Operator = 36;   # place call argument
pub val OP_PARAM:   Operator = 37;   # receive parameter at function entry
pub val OP_RETVAL:  Operator = 38;   # produce return value at function exit
pub val OP_SCARG:   Operator = 39;   # place syscall argument

# internal (peephole/ISel only, never emitted by lowering)
pub val OP_NOP:     Operator = 40;   # tombstone for peephole elimination
pub val OP_MEMSET:  Operator = 41;   # peephole loop-to-memset optimization

# --- condition codes ---

pub val CC_NONE: Cond = 0;
pub val CC_EQ:   Cond = 1;
pub val CC_NE:   Cond = 2;
pub val CC_LT:   Cond = 3;    # signed less than
pub val CC_LE:   Cond = 4;    # signed less or equal
pub val CC_GT:   Cond = 5;    # signed greater than
pub val CC_GE:   Cond = 6;    # signed greater or equal
pub val CC_ULT:  Cond = 7;    # unsigned less than
pub val CC_ULE:  Cond = 8;    # unsigned less or equal
pub val CC_UGT:  Cond = 9;    # unsigned greater than
pub val CC_UGE:  Cond = 10;   # unsigned greater or equal

# --- ABI-abstract type flags ---

pub val ABI_FLAG_FLOAT: u8 = 1;   # bit 0: operand is floating-point
pub val ABI_FLAG_AGG:   u8 = 2;   # bit 1: operand is aggregate (record/union)

# --- OP_CALL return flags ---
# used in meta.cc for pre-ABI CALL instructions

pub val CALL_VARIADIC:  u8 = 1;   # bit 0: callee is variadic
pub val CALL_RET_FLOAT: u8 = 2;   # bit 1: return type is float
pub val CALL_RET_AGG:   u8 = 4;   # bit 2: return type is aggregate

# --- virtual registers ---
# u8 register IDs, per-function windowed.
# physical registers (ISA-specific): 0-29
# special virtual registers: VREG_SP=30, VREG_FP=31
# user virtual registers: 32-255 (224 per function)

pub val VREG_START: i32 = 32;
pub val VREG_FP:    i32 = 31;   # VREG_START - 1
pub val VREG_SP:    i32 = 30;   # VREG_START - 2

# REG_NONE: sentinel for "no register" in u8 fields.
pub val REG_NONE: u8 = 0;

# --- param index sentinels ---

pub val PARAM_SRET:    u8 = 254;   # sret hidden pointer
pub val PARAM_VARARGS: u8 = 255;   # variadic register save area
pub val ARG_SRET:      u8 = 254;   # sret pointer argument

# ================================================================
# compact 8-byte instruction format
# ================================================================

# meta byte layout: cc:4 | size:3 | flag:1
#   cc   = (meta >> 4) & 0xF     — condition code or call flags
#   size = 1 << ((meta >> 1) & 7) — operation size in bytes (1,2,4,8,16,32,64,128)
#   flag = meta & 1               — context-dependent flag bit

# Inst: a single IR instruction (8 bytes).
# ---
# op:   opcode
# meta: packed cc:4 | size_log2:3 | flag:1
# f0:   field 0 (register, index, etc. — per opcode)
# f1:   field 1 (register, base, etc. — per opcode)
# f2:   field 2 (immediate, displacement, packed — per opcode)
pub rec Inst {
    op:   u8;
    meta: u8;
    f0:   u8;
    f1:   u8;
    f2:   i32;
}

# --- meta byte helpers ---

# encode_size: convert byte size (1,2,4,8,...) to 3-bit log2 encoding.
pub fun encode_size(size: u8) u8 {
    if (size <= 1) { ret 0; }
    if (size <= 2) { ret 1; }
    if (size <= 4) { ret 2; }
    if (size <= 8) { ret 3; }
    if (size <= 16) { ret 4; }
    if (size <= 32) { ret 5; }
    if (size <= 64) { ret 6; }
    ret 7;
}

# decode_size: convert 3-bit log2 encoding to byte size.
pub fun decode_size(enc: u8) u8 {
    ret 1 << (enc & 7);
}

# make_meta: construct a meta byte.
pub fun make_meta(cc: u8, size: u8, flag: u8) u8 {
    ret ((cc & 0xF) << 4) | ((encode_size(size) & 0x7) << 1) | (flag & 1);
}

# inst_cc: extract condition code from meta byte.
pub fun inst_cc(inst: *Inst) u8 {
    ret (inst.meta >> 4) & 0xF;
}

# inst_size: extract operation size in bytes from meta byte.
pub fun inst_size(inst: *Inst) u8 {
    ret decode_size((inst.meta >> 1) & 0x7);
}

# inst_flag: extract flag bit from meta byte.
pub fun inst_flag(inst: *Inst) u8 {
    ret inst.meta & 1;
}

# --- instruction accessors ---

pub fun dst_reg(inst: *Inst) u8    { ret inst.f0; }
pub fun src1_reg(inst: *Inst) u8   { ret inst.f1; }
pub fun src2_reg(inst: *Inst) u8   { ret inst.f2::u8; }
pub fun imm32(inst: *Inst) i32     { ret inst.f2; }
pub fun disp(inst: *Inst) i32      { ret inst.f2; }
pub fun label_idx(inst: *Inst) i32 { ret inst.f2; }

# memory operand unpacking (indexed mode, flag=1)
# f2 = index:u8 (bits 31-24) | scale:u8 (bits 23-16) | disp:i16 (bits 15-0)
pub fun mem_index(inst: *Inst) u8  { ret (inst.f2 >> 24)::u8; }
pub fun mem_scale(inst: *Inst) u8  { ret (inst.f2 >> 16)::u8; }
pub fun mem_disp16(inst: *Inst) i16 { ret inst.f2::i16; }

# pack indexed memory fields into f2
pub fun pack_indexed(index: u8, scale: u8, disp16: i16) i32 {
    ret (index::i32 << 24) | (scale::i32 << 16) | (disp16::i32 & 0xFFFF);
}

# --- ABI metadata unpacking ---

# abi_meta byte: size_log2:3 | align_log2:3 | agg:1 | float:1
pub fun make_abi_meta(size: u8, align: u8, is_agg: bool, is_float: bool) u8 {
    var m: u8 = encode_size(size) << 5;
    m = m | (encode_size(align) << 2);
    if (is_agg) { m = m | 2; }
    if (is_float) { m = m | 1; }
    ret m;
}

pub fun abi_byte_size(meta: u8) u8  { ret decode_size((meta >> 5) & 7); }
pub fun abi_align(meta: u8) u8      { ret decode_size((meta >> 2) & 7); }
pub fun abi_is_agg(meta: u8) bool   { ret (meta & 2) != 0; }
pub fun abi_is_float(meta: u8) bool { ret (meta & 1) != 0; }

# pack OP_ARG/OP_RETVAL f2: byte_size:u16 | flags:u8 | align:u8
pub fun pack_arg_meta(byte_size: i32, flags: u8, align: u8) i32 {
    ret (byte_size & 0xFFFF) | (flags::i32 << 16) | (align::i32 << 24);
}
pub fun unpack_arg_size(f2: i32) i32  { ret f2 & 0xFFFF; }
pub fun unpack_arg_flags(f2: i32) u8  { ret (f2 >> 16)::u8; }
pub fun unpack_arg_align(f2: i32) u8  { ret (f2 >> 24)::u8; }

# --- per-shape instruction constructors ---

# mk_inst: raw constructor (internal).
fun mk_inst(op: u8, meta: u8, f0: u8, f1: u8, f2: i32) Inst {
    var i: Inst;
    i.op = op;
    i.meta = meta;
    i.f0 = f0;
    i.f1 = f1;
    i.f2 = f2;
    ret i;
}

# 3-register ALU: ADD, SUB, MUL, DIV, MOD, DIVU, MODU,
#                 AND, OR, XOR, SHL, SHR, SAR,
#                 FADD, FSUB, FMUL, FDIV, MEMSET
# f0=dst, f1=src1, f2.low=src2
pub fun mk_alu(op: u8, dst: u8, src1: u8, src2: u8, size: u8) Inst {
    ret mk_inst(op, make_meta(0, size, 0), dst, src1, src2::i32);
}

# compare: ICMP, FCMP — f0=dst, f1=src1, f2.low=src2, meta.cc=cond
pub fun mk_cmp(op: u8, dst: u8, src1: u8, src2: u8, cc: u8, size: u8) Inst {
    ret mk_inst(op, make_meta(cc, size, 0), dst, src1, src2::i32);
}

# unary reg-reg: MOV reg-reg, ZEXT, SEXT, TRUNC, ITOF, FEXT, FTRUNC
# f0=dst, f1=src
# (FTOI uses mk_ftoi instead, to carry source float size in f2)
pub fun mk_unary(op: u8, dst: u8, src: u8, size: u8) Inst {
    ret mk_inst(op, make_meta(0, size, 0), dst, src, 0);
}

# FTOI: f0=dst, f1=src, meta.size=dst_int_size, f2=src_float_size
pub fun mk_ftoi(dst: u8, src: u8, dst_size: u8, src_float_size: u8) Inst {
    ret mk_inst(OP_FTOI, make_meta(0, dst_size, 0), dst, src, src_float_size::i32);
}

# MOV reg, imm32: f0=dst, f2=imm32, cc=1, flag=0
pub fun mk_mov_imm(dst: u8, imm: i32, size: u8) Inst {
    ret mk_inst(OP_MOV, make_meta(1, size, 0), dst, 0, imm);
}

# MOV reg, const pool i64: f0=dst, f2=pool_idx, flag=1
pub fun mk_mov_const(dst: u8, pool_idx: i32, size: u8) Inst {
    ret mk_inst(OP_MOV, make_meta(0, size, 1), dst, 0, pool_idx);
}

# MOV reg, label address: f0=dst, f2=label_idx, flag=0
# used for loading symbol/label addresses (ISel produces MOVABS/LEA)
pub fun mk_mov_label(dst: u8, lbl_idx: i32, size: u8) Inst {
    ret mk_inst(OP_ADDR, make_meta(0, size, 0), dst, 0, lbl_idx);
}

# LOAD simple (base+disp): f0=dst, f1=base, f2=disp, flag=0
pub fun mk_load(dst: u8, base: u8, displacement: i32, size: u8) Inst {
    ret mk_inst(OP_LOAD, make_meta(0, size, 0), dst, base, displacement);
}

# LOAD indexed (base+index*scale+disp): f0=dst, f1=base, f2=packed, flag=1
pub fun mk_load_idx(dst: u8, base: u8, index: u8, scale: u8, disp16: i16, size: u8) Inst {
    ret mk_inst(OP_LOAD, make_meta(0, size, 1), dst, base,
                pack_indexed(index, scale, disp16));
}

# STORE simple: f0=src, f1=base, f2=disp, flag=0
pub fun mk_store(src: u8, base: u8, displacement: i32, size: u8) Inst {
    ret mk_inst(OP_STORE, make_meta(0, size, 0), src, base, displacement);
}

# STORE indexed: f0=src, f1=base, f2=packed, flag=1
pub fun mk_store_idx(src: u8, base: u8, index: u8, scale: u8, disp16: i16, size: u8) Inst {
    ret mk_inst(OP_STORE, make_meta(0, size, 1), src, base,
                pack_indexed(index, scale, disp16));
}

# ADDR simple (base+disp): f0=dst, f1=base, f2=disp, flag=0
pub fun mk_addr(dst: u8, base: u8, displacement: i32, size: u8) Inst {
    ret mk_inst(OP_ADDR, make_meta(0, size, 0), dst, base, displacement);
}

# ADDR indexed: f0=dst, f1=base, f2=packed, flag=1
pub fun mk_addr_idx(dst: u8, base: u8, index: u8, scale: u8, disp16: i16, size: u8) Inst {
    ret mk_inst(OP_ADDR, make_meta(0, size, 1), dst, base,
                pack_indexed(index, scale, disp16));
}

# ADDR label: f0=dst, f2=label_idx, cc=1, flag=0, f1=0
# for symbol/label address loading (function pointers, global addresses)
pub fun mk_addr_label(dst: u8, lbl_idx: i32, size: u8) Inst {
    ret mk_inst(OP_ADDR, make_meta(1, size, 0), dst, 0, lbl_idx);
}

# JMP: f2=label_idx
pub fun mk_jmp(lbl_idx: i32) Inst {
    ret mk_inst(OP_JMP, 0, 0, 0, lbl_idx);
}

# BRCOND: f0=cond_reg, f2=label_idx, meta.cc=condition
pub fun mk_brcond(cond_reg: u8, lbl_idx: i32, cc: u8) Inst {
    ret mk_inst(OP_BRCOND, make_meta(cc, 0, 0), cond_reg, 0, lbl_idx);
}

# CALL direct (pre-ABI): f0=result_reg, f1=ret_meta, f2=label_idx
#   ret_meta = make_abi_meta(ret_size, ret_align, ret_agg, ret_float)
#   meta.cc = call_flags, meta.flag=0
pub fun mk_call(result_reg: u8, ret_meta: u8, lbl_idx: i32,
                call_flags: u8, size: u8) Inst {
    ret mk_inst(OP_CALL, make_meta(call_flags, size, 0),
                result_reg, ret_meta, lbl_idx);
}

# CALL indirect (pre-ABI): f0=result_reg, f1=target_reg, f2=ret_meta_packed
#   meta.cc = call_flags, meta.flag=1
pub fun mk_call_indirect(result_reg: u8, target_reg: u8,
                         ret_size: i32, ret_flags: u8, ret_align: u8,
                         call_flags: u8, size: u8) Inst {
    ret mk_inst(OP_CALL, make_meta(call_flags, size, 1),
                result_reg, target_reg,
                pack_arg_meta(ret_size, ret_flags, ret_align));
}

# CALL simplified (post-ABI): f0=callee_label_idx or 0, f1=0 or target_reg
pub fun mk_call_simple(lbl_idx: i32) Inst {
    ret mk_inst(OP_CALL, make_meta(0, 0, 0), 0, 0, lbl_idx);
}

pub fun mk_call_simple_indirect(target_reg: u8) Inst {
    ret mk_inst(OP_CALL, make_meta(0, 0, 1), 0, target_reg, 0);
}

# RET
pub fun mk_ret() Inst {
    ret mk_inst(OP_RET, 0, 0, 0, 0);
}

# LABEL: f2=label_idx
pub fun mk_label_inst(lbl_idx: i32) Inst {
    ret mk_inst(OP_LABEL, 0, 0, 0, lbl_idx);
}

# SYSCALL: f0=result_reg (0 if unused)
pub fun mk_syscall(result_reg: u8) Inst {
    ret mk_inst(OP_SYSCALL, 0, result_reg, 0, 0);
}

# NOP
pub fun mk_nop() Inst {
    ret mk_inst(OP_NOP, 0, 0, 0, 0);
}

# --- ABI-abstract instruction constructors ---

# OP_PARAM: f0=param_idx, f1=abi_meta, f2=disp (FP-relative dest)
pub fun mk_param(param_idx: u8, byte_size: u8, align: u8,
                 is_agg: bool, is_float: bool, displacement: i32) Inst {
    ret mk_inst(OP_PARAM, 0, param_idx,
                make_abi_meta(byte_size, align, is_agg, is_float),
                displacement);
}

# OP_ARG: f0=arg_idx, f1=value_reg, f2=packed(byte_size|flags|align)
pub fun mk_arg(arg_idx: u8, value_reg: u8, byte_size: i32,
               flags: u8, align: u8, size: u8) Inst {
    ret mk_inst(OP_ARG, make_meta(0, size, 0), arg_idx, value_reg,
                pack_arg_meta(byte_size, flags, align));
}

# OP_SCARG: f0=arg_idx, f1=value_reg
pub fun mk_scarg(arg_idx: u8, value_reg: u8, size: u8) Inst {
    ret mk_inst(OP_SCARG, make_meta(0, size, 0), arg_idx, value_reg, 0);
}

# OP_RETVAL: f0=value_reg, f2=packed(byte_size|flags|align)
pub fun mk_retval(value_reg: u8, byte_size: i32, flags: u8,
                  align: u8, size: u8) Inst {
    ret mk_inst(OP_RETVAL, make_meta(0, size, 0), value_reg, 0,
                pack_arg_meta(byte_size, flags, align));
}

# ================================================================
# debug info side table
# ================================================================

# DebugLoc: source location for one instruction (parallel array in Block).
pub rec DebugLoc {
    src_line: i32;
    src_file: u16;
    pad:      u16;
}

# ================================================================
# constant pool (per-function)
# ================================================================

pub rec ConstPool {
    values: *i64;
    count:  i32;
    cap:    i32;
}

val CONST_POOL_INITIAL_CAP: i32 = 8;

pub fun const_pool_init() ConstPool {
    var p: ConstPool;
    p.values = nil;
    p.count = 0;
    p.cap = 0;
    ret p;
}

# const_intern: add a value to the constant pool, returning its index.
# deduplicates: returns existing index if value already present.
pub fun const_intern(alloc: *allocator.Allocator, pool: *ConstPool, value: i64) i32 {
    if (alloc == nil || pool == nil) { ret -1; }

    # check for existing value
    var i: i32 = 0;
    for (i < pool.count) {
        if (pool.values[i] == value) { ret i; }
        i = i + 1;
    }

    # grow if needed
    if (pool.count >= pool.cap) {
        var new_cap: i32 = CONST_POOL_INITIAL_CAP;
        if (pool.cap > 0) { new_cap = pool.cap * 2; }
        val r: Result[*i64, allocator.AllocError] =
            allocator.allocator_resize[i64](alloc, pool.values,
                pool.cap::usize, new_cap::usize);
        if (result_is_err[*i64, allocator.AllocError](r)) { ret -1; }
        pool.values = result_unwrap_ok[*i64, allocator.AllocError](r);
        pool.cap = new_cap;
    }

    val idx: i32 = pool.count;
    pool.values[idx] = value;
    pool.count = pool.count + 1;
    ret idx;
}

pub fun const_get(pool: *ConstPool, idx: i32) i64 {
    if (pool == nil || idx < 0 || idx >= pool.count) { ret 0; }
    ret pool.values[idx];
}

# ================================================================
# label table (per-function)
# ================================================================

pub rec LabelTable {
    names: *str;
    count: i32;
    cap:   i32;
}

val LABEL_TABLE_INITIAL_CAP: i32 = 16;

pub fun label_table_init() LabelTable {
    var t: LabelTable;
    t.names = nil;
    t.count = 0;
    t.cap = 0;
    ret t;
}

# label_intern: add a label name, returning its index.
# deduplicates by pointer equality (labels are typically interned strings).
pub fun label_intern(alloc: *allocator.Allocator, tbl: *LabelTable, name: str) i32 {
    if (alloc == nil || tbl == nil) { ret -1; }

    # check for existing label
    var i: i32 = 0;
    for (i < tbl.count) {
        if (str_equals(tbl.names[i], name)) { ret i; }
        i = i + 1;
    }

    # grow if needed
    if (tbl.count >= tbl.cap) {
        var new_cap: i32 = LABEL_TABLE_INITIAL_CAP;
        if (tbl.cap > 0) { new_cap = tbl.cap * 2; }
        val r: Result[*str, allocator.AllocError] =
            allocator.allocator_resize[str](alloc, tbl.names,
                tbl.cap::usize, new_cap::usize);
        if (result_is_err[*str, allocator.AllocError](r)) { ret -1; }
        tbl.names = result_unwrap_ok[*str, allocator.AllocError](r);
        tbl.cap = new_cap;
    }

    val idx: i32 = tbl.count;
    tbl.names[idx] = name;
    tbl.count = tbl.count + 1;
    ret idx;
}

pub fun label_get(tbl: *LabelTable, idx: i32) str {
    if (tbl == nil || idx < 0 || idx >= tbl.count) { ret nil; }
    ret tbl.names[idx];
}

# ================================================================
# Operand type — retained for MachInst and AsmInst (ISA layer)
# ================================================================

# --- operand kinds ---

pub val OPK_NONE:   ValueKind = 0;
pub val OPK_REG:    ValueKind = 1;   # register (physical or virtual)
pub val OPK_IMM:    ValueKind = 2;   # immediate value
pub val OPK_MEM:    ValueKind = 3;   # memory reference (base + index * scale + disp)
pub val OPK_LABEL:  ValueKind = 4;   # label reference
pub val OPK_SYM:    ValueKind = 5;   # symbol reference

# Operand: an operand in a MachInst or AsmInst.
# ---
# flat record with a kind discriminant. fields are interpreted based on kind:
#   OPK_REG:   reg, size
#   OPK_IMM:   imm, size
#   OPK_MEM:   base, index, scale, disp, size
#   OPK_LABEL: label
#   OPK_SYM:   sym_id
pub rec Operand {
    kind:   ValueKind;
    size:   u8;       # operand size in bytes
    reg:    i32;      # register id
    imm:    i64;      # immediate value
    base:   i32;      # base register for memory
    index:  i32;      # index register for memory (-1 = none)
    scale:  i32;      # scale factor for memory (1, 2, 4, 8)
    disp:   i64;      # displacement for memory
    sym_id: u64;      # symbol index
    label:  str;      # label name
}

# --- operand constructors ---

pub fun make_none() Operand {
    var o: Operand;
    o.kind = OPK_NONE;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = -1;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_reg(reg: i32, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_REG;
    o.size = size;
    o.reg = reg;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_imm(imm: i64, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_IMM;
    o.size = size;
    o.reg = 0;
    o.imm = imm;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_mem(base: i32, index: i32, scale: i32, disp: i64, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_MEM;
    o.size = size;
    o.reg = 0;
    o.imm = 0;
    o.base = base;
    o.index = index;
    o.scale = scale;
    o.disp = disp;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_label(label: str) Operand {
    var o: Operand;
    o.kind = OPK_LABEL;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = label;
    ret o;
}

pub fun make_sym(sym_id: u64) Operand {
    var o: Operand;
    o.kind = OPK_SYM;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = sym_id;
    o.label = nil;
    ret o;
}

# ================================================================
# instruction → Operand reconstruction helpers (for ISel bridge)
# ================================================================

# inst_to_dst_operand: reconstruct destination Operand from compact Inst.
# used by ISel to bridge compact IR → Operand-based MachInst.
pub fun inst_to_dst_operand(inst: *Inst, func: *Function) Operand {
    val op: u8 = inst.op;
    val sz: u8 = inst_size(inst);

    # STORE: dst is memory [f1 + f2]
    if (op == OP_STORE) {
        if (inst_flag(inst) != 0) {
            ret make_mem(inst.f1::i32, mem_index(inst)::i32,
                         mem_scale(inst)::i32, mem_disp16(inst)::i64, sz);
        }
        ret make_mem(inst.f1::i32, -1, 1, inst.f2::i64, sz);
    }

    # JMP, BRCOND, LABEL: dst is label
    if (op == OP_JMP || op == OP_BRCOND || op == OP_LABEL) {
        val name: str = label_get(?func.labels, inst.f2);
        ret make_label(name);
    }

    # CALL: direct (flag=0) → label, indirect (flag=1) → target register in f1
    if (op == OP_CALL) {
        if (inst_flag(inst) == 0) {
            val name: str = label_get(?func.labels, inst.f2);
            ret make_label(name);
        }
        ret make_reg(inst.f1::i32, 8);
    }

    # ICMP/FCMP: dst is always 1-byte bool result
    if (op == OP_ICMP || op == OP_FCMP) {
        ret make_reg(inst.f0::i32, 1);
    }

    # default: dst is register f0
    ret make_reg(inst.f0::i32, sz);
}

# inst_to_src1_operand: reconstruct src1 Operand from compact Inst.
pub fun inst_to_src1_operand(inst: *Inst, func: *Function) Operand {
    val op: u8 = inst.op;
    val sz: u8 = inst_size(inst);

    # ADDR with cc=1: label address (not memory LEA)
    if (op == OP_ADDR && inst_cc(inst) == 1) {
        val name: str = label_get(?func.labels, inst.f2);
        ret make_label(name);
    }

    # LOAD, ADDR (cc=0): src1 is memory [f1 + f2]
    if (op == OP_LOAD || op == OP_ADDR) {
        if (inst_flag(inst) != 0) {
            ret make_mem(inst.f1::i32, mem_index(inst)::i32,
                         mem_scale(inst)::i32, mem_disp16(inst)::i64, sz);
        }
        ret make_mem(inst.f1::i32, -1, 1, inst.f2::i64, sz);
    }

    # MOV with const pool (flag=1)
    if (op == OP_MOV && inst_flag(inst) != 0) {
        val value: i64 = const_get(?func.const_pool, inst.f2);
        ret make_imm(value, sz);
    }

    # MOV with imm32 (cc=1, flag=0)
    if (op == OP_MOV && inst_cc(inst) == 1) {
        ret make_imm(inst.f2::i64, sz);
    }

    # BRCOND: src1 is condition register
    if (op == OP_BRCOND) {
        ret make_reg(inst.f0::i32, 1);
    }

    # STORE: src1 is the value register f0
    if (op == OP_STORE) {
        ret make_reg(inst.f0::i32, sz);
    }

    # FTOI: src1 is float register f1, size from f2 (source float size)
    if (op == OP_FTOI) {
        var src_sz: u8 = inst.f2::u8;
        if (src_sz == 0) { src_sz = sz; }
        ret make_reg(inst.f1::i32, src_sz);
    }

    # default: src1 is register f1
    ret make_reg(inst.f1::i32, sz);
}

# inst_to_src2_operand: reconstruct src2 Operand from compact Inst.
pub fun inst_to_src2_operand(inst: *Inst) Operand {
    val op: u8 = inst.op;
    val sz: u8 = inst_size(inst);

    # 3-register ops: src2 is register in f2 low byte
    if (op >= OP_ADD && op <= OP_SAR) {
        ret make_reg(src2_reg(inst)::i32, sz);
    }
    if (op >= OP_FADD && op <= OP_FDIV) {
        ret make_reg(src2_reg(inst)::i32, sz);
    }
    if (op == OP_ICMP || op == OP_FCMP) {
        ret make_reg(src2_reg(inst)::i32, sz);
    }
    if (op == OP_MEMSET) {
        ret make_reg(src2_reg(inst)::i32, sz);
    }

    ret make_none();
}

# ================================================================
# Block and Function records
# ================================================================

# Block: a basic block in the IR.
pub rec Block {
    label:      str;
    insts:      *Inst;
    debug_locs: *DebugLoc;   # parallel array, indexed by instruction index
    inst_count: i32;
    inst_cap:   i32;
}

# Function: a function in the IR.
pub rec Function {
    name:           str;
    blocks:         **Block;
    block_count:    i32;
    block_cap:      i32;
    param_count:    i32;
    local_size:     usize;
    call_area_size: usize;   # max outgoing stack arg bytes across all calls
    const_pool:     ConstPool;
    labels:         LabelTable;
}

# --- operator helpers ---

pub fun op_name(op: Operator) str {
    if (op == OP_MOV)     { ret "mov"; }
    if (op == OP_LOAD)    { ret "load"; }
    if (op == OP_STORE)   { ret "store"; }
    if (op == OP_ADDR)    { ret "addr"; }
    if (op == OP_ADD)     { ret "add"; }
    if (op == OP_SUB)     { ret "sub"; }
    if (op == OP_MUL)     { ret "mul"; }
    if (op == OP_DIV)     { ret "div"; }
    if (op == OP_MOD)     { ret "mod"; }
    if (op == OP_DIVU)    { ret "divu"; }
    if (op == OP_MODU)    { ret "modu"; }
    if (op == OP_AND)     { ret "and"; }
    if (op == OP_OR)      { ret "or"; }
    if (op == OP_XOR)     { ret "xor"; }
    if (op == OP_SHL)     { ret "shl"; }
    if (op == OP_SHR)     { ret "shr"; }
    if (op == OP_SAR)     { ret "sar"; }
    if (op == OP_ICMP)    { ret "icmp"; }
    if (op == OP_FCMP)    { ret "fcmp"; }
    if (op == OP_JMP)     { ret "jmp"; }
    if (op == OP_BRCOND)  { ret "brcond"; }
    if (op == OP_CALL)    { ret "call"; }
    if (op == OP_RET)     { ret "ret"; }
    if (op == OP_ZEXT)    { ret "zext"; }
    if (op == OP_SEXT)    { ret "sext"; }
    if (op == OP_TRUNC)   { ret "trunc"; }
    if (op == OP_ITOF)    { ret "itof"; }
    if (op == OP_FTOI)    { ret "ftoi"; }
    if (op == OP_FEXT)    { ret "fext"; }
    if (op == OP_FTRUNC)  { ret "ftrunc"; }
    if (op == OP_FADD)    { ret "fadd"; }
    if (op == OP_FSUB)    { ret "fsub"; }
    if (op == OP_FMUL)    { ret "fmul"; }
    if (op == OP_FDIV)    { ret "fdiv"; }
    if (op == OP_LABEL)   { ret "label"; }
    if (op == OP_SYSCALL) { ret "syscall"; }
    if (op == OP_ARG)     { ret "arg"; }
    if (op == OP_PARAM)   { ret "param"; }
    if (op == OP_RETVAL)  { ret "retval"; }
    if (op == OP_SCARG)   { ret "scarg"; }
    if (op == OP_NOP)     { ret "nop"; }
    if (op == OP_MEMSET)  { ret "memset"; }
    ret "unknown";
}

pub fun cc_name(cc: Cond) str {
    if (cc == CC_NONE) { ret ""; }
    if (cc == CC_EQ)   { ret "eq"; }
    if (cc == CC_NE)   { ret "ne"; }
    if (cc == CC_LT)   { ret "lt"; }
    if (cc == CC_LE)   { ret "le"; }
    if (cc == CC_GT)   { ret "gt"; }
    if (cc == CC_GE)   { ret "ge"; }
    if (cc == CC_ULT)  { ret "ult"; }
    if (cc == CC_ULE)  { ret "ule"; }
    if (cc == CC_UGT)  { ret "ugt"; }
    if (cc == CC_UGE)  { ret "uge"; }
    ret "unknown";
}

# is_vreg: check if a register id is a virtual register.
pub fun is_vreg(reg: i32) bool {
    ret reg >= VREG_START;
}

# --- block operations ---

pub fun create_block(alloc: *allocator.Allocator, lbl: str) Result[*Block, str] {
    if (alloc == nil) {
        ret err[*Block, str]("allocator is nil");
    }

    val r: Result[*Block, allocator.AllocError] = allocator.allocator_zalloc[Block](alloc, 1);
    if (result_is_err[*Block, allocator.AllocError](r)) {
        ret err[*Block, str]("out of memory");
    }

    val b: *Block = result_unwrap_ok[*Block, allocator.AllocError](r);
    b.label = lbl;
    b.insts = nil;
    b.debug_locs = nil;
    b.inst_count = 0;
    b.inst_cap = 0;

    ret ok[*Block, str](b);
}

# block_append: append a compact instruction to a block.
# returns the index of the appended instruction, or -1 on failure.
pub fun block_append(alloc: *allocator.Allocator, block: *Block, inst: Inst) i32 {
    if (block == nil || alloc == nil) {
        ret -1;
    }

    # grow if needed
    if (block.inst_count >= block.inst_cap) {
        var new_cap: i32 = 8;
        if (block.inst_cap > 0) {
            new_cap = block.inst_cap * 2;
        }

        val r: Result[*Inst, allocator.AllocError] = allocator.allocator_resize[Inst](
            alloc, block.insts, block.inst_cap::usize, new_cap::usize
        );
        if (result_is_err[*Inst, allocator.AllocError](r)) {
            ret -1;
        }
        block.insts = result_unwrap_ok[*Inst, allocator.AllocError](r);

        # grow debug_locs in parallel
        val dr: Result[*DebugLoc, allocator.AllocError] = allocator.allocator_resize[DebugLoc](
            alloc, block.debug_locs, block.inst_cap::usize, new_cap::usize
        );
        if (result_is_err[*DebugLoc, allocator.AllocError](dr)) {
            ret -1;
        }
        block.debug_locs = result_unwrap_ok[*DebugLoc, allocator.AllocError](dr);

        block.inst_cap = new_cap;
    }

    val idx: i32 = block.inst_count;
    block.insts[idx] = inst;
    block.debug_locs[idx].src_line = 0;
    block.debug_locs[idx].src_file = 0;
    block.debug_locs[idx].pad = 0;

    block.inst_count = block.inst_count + 1;

    ret idx;
}

# block_set_debug: set debug info for an instruction by index.
pub fun block_set_debug(block: *Block, idx: i32, line: i32, file: u16) {
    if (block == nil || block.debug_locs == nil) { ret; }
    if (idx < 0 || idx >= block.inst_count) { ret; }
    block.debug_locs[idx].src_line = line;
    block.debug_locs[idx].src_file = file;
}

# --- function operations ---

pub fun create_function(alloc: *allocator.Allocator, name: str) Result[*Function, str] {
    if (alloc == nil) {
        ret err[*Function, str]("allocator is nil");
    }

    val r: Result[*Function, allocator.AllocError] = allocator.allocator_zalloc[Function](alloc, 1);
    if (result_is_err[*Function, allocator.AllocError](r)) {
        ret err[*Function, str]("out of memory");
    }

    val f: *Function = result_unwrap_ok[*Function, allocator.AllocError](r);
    f.name = name;
    f.blocks = nil;
    f.block_count = 0;
    f.block_cap = 0;
    f.param_count = 0;
    f.local_size = 0;
    f.call_area_size = 0;
    f.const_pool = const_pool_init();
    f.labels = label_table_init();

    ret ok[*Function, str](f);
}

pub fun func_add_block(alloc: *allocator.Allocator, func: *Function, block: *Block) i32 {
    if (func == nil || block == nil || alloc == nil) {
        ret -1;
    }

    # grow if needed
    if (func.block_count >= func.block_cap) {
        var new_cap: i32 = 8;
        if (func.block_cap > 0) {
            new_cap = func.block_cap * 2;
        }

        val r: Result[**Block, allocator.AllocError] = allocator.allocator_resize[*Block](
            alloc, func.blocks, func.block_cap::usize, new_cap::usize
        );
        if (result_is_err[**Block, allocator.AllocError](r)) {
            ret -1;
        }

        func.blocks = result_unwrap_ok[**Block, allocator.AllocError](r);
        func.block_cap = new_cap;
    }

    val idx: i32 = func.block_count;
    func.blocks[idx] = block;
    func.block_count = func.block_count + 1;

    ret idx;
}

# --- string comparison helper ---

fun str_equals(a: str, b: str) bool {
    if (a == nil && b == nil) { ret true; }
    if (a == nil || b == nil) { ret false; }
    if (a == b) { ret true; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}
