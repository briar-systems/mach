# ir_label: create a label opcode.
pub fun ir_label() IROp {
    ret IROp { ir_label: OP_LABEL };
}

# ir_br: create a branch opcode (alias for jmp).
pub fun ir_br() IROp {
    ret IROp { ir_jmp: OP_JMP };
}

# ir_cond_br: create a conditional branch opcode (alias for jcc).
pub fun ir_cond_br() IROp {
    ret IROp { ir_jcc: OP_JCC };
}

# ir_syscall: create a syscall opcode.
pub fun ir_syscall() IROp {
    ret IROp { ir_call: OP_CALL };
}

# --- condition code constants ---

pub val CC_NONE: i32 = 0;
pub val CC_EQ:   i32 = 1;   # equal
pub val CC_NE:   i32 = 2;   # not equal
pub val CC_LT:   i32 = 3;   # less than (signed)
pub val CC_LE:   i32 = 4;   # less or equal (signed)
pub val CC_GT:   i32 = 5;   # greater than (signed)
pub val CC_GE:   i32 = 6;   # greater or equal (signed)
pub val CC_B:    i32 = 7;   # below (unsigned)
pub val CC_BE:   i32 = 8;   # below or equal (unsigned)
pub val CC_A:    i32 = 9;   # above (unsigned)
pub val CC_AE:   i32 = 10;  # above or equal (unsigned)
