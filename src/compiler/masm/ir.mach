use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.masm.ir: intermediate representation for code generation.
# ---
# provides IR types used between AST lowering and machine code emission.

# IROp: IR instruction opcode.
# ---
# each variant represents a distinct IR operation.
pub uni IROp {
    # data movement
    ir_mov:      u8;
    ir_load:     u8;
    ir_store:    u8;
    ir_lea:      u8;

    # arithmetic
    ir_add:      u8;
    ir_sub:      u8;
    ir_mul:      u8;
    ir_div:      u8;
    ir_mod:      u8;
    ir_neg:      u8;

    # bitwise
    ir_and:      u8;
    ir_or:       u8;
    ir_xor:      u8;
    ir_not:      u8;
    ir_shl:      u8;
    ir_shr:      u8;
    ir_sar:      u8;

    # comparison
    ir_cmp:      u8;
    ir_test:     u8;

    # control flow
    ir_jmp:      u8;
    ir_jcc:      u8;
    ir_call:     u8;
    ir_ret:      u8;

    # stack
    ir_push:     u8;
    ir_pop:      u8;

    # stack frame
    ir_frame:    u8;  # set up stack frame (sub rsp, N)
    ir_unframe:  u8;  # tear down stack frame (add rsp, N)

    # condition code set
    ir_sete:     u8;  # set if equal
    ir_setne:    u8;  # set if not equal
    ir_setl:     u8;  # set if less (signed)
    ir_setle:    u8;  # set if less or equal (signed)
    ir_setg:     u8;  # set if greater (signed)
    ir_setge:    u8;  # set if greater or equal (signed)
    ir_setb:     u8;  # set if below (unsigned)
    ir_setbe:    u8;  # set if below or equal (unsigned)
    ir_seta:     u8;  # set if above (unsigned)
    ir_setae:    u8;  # set if above or equal (unsigned)

    # conversions
    ir_zext:     u8;  # zero extend
    ir_sext:     u8;  # sign extend
    ir_trunc:    u8;  # truncate
    ir_itof:     u8;  # integer to float
    ir_ftoi:     u8;  # float to integer
    ir_fext:     u8;  # float extend (f32 -> f64)
    ir_ftrunc:   u8;  # float truncate (f64 -> f32)

    # special
    ir_nop:      u8;
    ir_label:    u8;
    ir_phi:      u8;
    ir_syscall:  u8;
}

# pub values for IROp tags (for pattern matching)
pub val OP_MOV:     u8 = 0;
pub val OP_LOAD:    u8 = 1;
pub val OP_STORE:   u8 = 2;
pub val OP_LEA:     u8 = 3;
pub val OP_ADD:     u8 = 4;
pub val OP_SUB:     u8 = 5;
pub val OP_MUL:     u8 = 6;
pub val OP_DIV:     u8 = 7;
pub val OP_MOD:     u8 = 8;
pub val OP_NEG:     u8 = 9;
pub val OP_AND:     u8 = 10;
pub val OP_OR:      u8 = 11;
pub val OP_XOR:     u8 = 12;
pub val OP_NOT:     u8 = 13;
pub val OP_SHL:     u8 = 14;
pub val OP_SHR:     u8 = 15;
pub val OP_SAR:     u8 = 16;
pub val OP_CMP:     u8 = 17;
pub val OP_TEST:    u8 = 18;
pub val OP_JMP:     u8 = 19;
pub val OP_JCC:     u8 = 20;
pub val OP_CALL:    u8 = 21;
pub val OP_RET:     u8 = 22;
pub val OP_PUSH:    u8 = 23;
pub val OP_POP:     u8 = 24;
pub val OP_FRAME:   u8 = 25;
pub val OP_UNFRAME: u8 = 26;
pub val OP_SETE:    u8 = 27;
pub val OP_SETNE:   u8 = 28;
pub val OP_SETL:    u8 = 29;
pub val OP_SETLE:   u8 = 30;
pub val OP_SETG:    u8 = 31;
pub val OP_SETGE:   u8 = 32;
pub val OP_SETB:    u8 = 33;
pub val OP_SETBE:   u8 = 34;
pub val OP_SETA:    u8 = 35;
pub val OP_SETAE:   u8 = 36;
pub val OP_ZEXT:    u8 = 37;
pub val OP_SEXT:    u8 = 38;
pub val OP_TRUNC:   u8 = 39;
pub val OP_ITOF:    u8 = 40;
pub val OP_FTOI:    u8 = 41;
pub val OP_FEXT:    u8 = 42;
pub val OP_FTRUNC:  u8 = 43;
pub val OP_NOP:     u8 = 44;
pub val OP_LABEL:   u8 = 45;
pub val OP_PHI:     u8 = 46;
pub val OP_SYSCALL: u8 = 47;
pub val OP_DIVU:    u8 = 48;  # unsigned division
pub val OP_MODU:    u8 = 49;  # unsigned modulo

# x86_64 physical register numbers (for isel layer)
# matches sysv64 abi: 0-15 for rax, rcx, rdx, rbx, rsp, rbp, rsi, rdi, r8-r15
pub val RAX: i32 = 0;
pub val RCX: i32 = 1;
pub val RDX: i32 = 2;
pub val RBX: i32 = 3;
pub val RSP: i32 = 4;
pub val RBP: i32 = 5;
pub val RSI: i32 = 6;
pub val RDI: i32 = 7;
pub val R8:  i32 = 8;
pub val R9:  i32 = 9;
pub val R10: i32 = 10;
pub val R11: i32 = 11;
pub val R12: i32 = 12;
pub val R13: i32 = 13;
pub val R14: i32 = 14;
pub val R15: i32 = 15;

# virtual register start (arbitrary number > physical registers)
pub val VREG_START: i32 = 1024;

# get_op_tag: get the tag byte from an IROp.
# ---
# op: pointer to IROp union
# ret: tag value
pub fun get_op_tag(op: *IROp) u8 {
    if (op == nil) {
        ret 255;
    }
    val tag_ptr: *u8 = op::*u8;
    ret @tag_ptr;
}

# IRValueKind: discriminant for IRValue
pub def IRValueKind: u8;

# pub values for IRValueKind tags
pub val VAL_NONE:  u8 = 0;
pub val VAL_REG:   u8 = 1;
pub val VAL_IMM:   u8 = 2;
pub val VAL_MEM:   u8 = 3;
pub val VAL_LABEL: u8 = 4;
pub val VAL_SYM:   u8 = 5;

# IRCond: condition code for conditional branches
pub def IRCond: u8;

# pub values for IRCond
pub val CC_NONE: u8 = 0;
pub val CC_EQ:   u8 = 1;
pub val CC_NE:   u8 = 2;
pub val CC_LT:   u8 = 3;
pub val CC_LE:   u8 = 4;
pub val CC_GT:   u8 = 5;
pub val CC_GE:   u8 = 6;
pub val CC_B:    u8 = 7;
pub val CC_BE:   u8 = 8;
pub val CC_A:    u8 = 9;
pub val CC_AE:   u8 = 10;

# IRValue: an operand or result value in IR.
# ---
# kind:       value kind (register, immediate, memory, label)
# reg:        register number (for register values)
# imm:        immediate value (for immediates)
# offset:     memory offset (for memory operands)
# base_reg:   base register (for memory operands)
# index_reg:  index register (for memory operands)
# scale:      index scale (1, 2, 4, 8)
# label:      label name (for label values)
# size:       operand size in bytes
pub rec IRValue {
    kind:      IRValueKind;
    reg:       i32;
    imm:       i64;
    offset:    i64;
    base_reg:  i32;
    index_reg: i32;
    scale:     i32;
    label:     str;
    size:      usize;
}

# make_none: create a none value.
pub fun make_none() IRValue {
    var v: IRValue;
    v.kind = VAL_NONE;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = nil;
    v.size = 0;
    ret v;
}

# make_reg: create a register value.
pub fun make_reg(r: i32, sz: usize) IRValue {
    var v: IRValue;
    v.kind = VAL_REG;
    v.reg = r;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = nil;
    v.size = sz;
    ret v;
}

# make_imm: create an immediate value.
pub fun make_imm(i: i64, sz: usize) IRValue {
    var v: IRValue;
    v.kind = VAL_IMM;
    v.reg = 0;
    v.imm = i;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = nil;
    v.size = sz;
    ret v;
}

# make_mem: create a memory operand value.
pub fun make_mem(base: i32, idx: i32, scl: i32, off: i64, sz: usize) IRValue {
    var v: IRValue;
    v.kind = VAL_MEM;
    v.reg = 0;
    v.imm = 0;
    v.offset = off;
    v.base_reg = base;
    v.index_reg = idx;
    v.scale = scl;
    v.label = nil;
    v.size = sz;
    ret v;
}

# make_label: create a label value.
pub fun make_label(lbl: str) IRValue {
    var v: IRValue;
    v.kind = VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = lbl;
    v.size = 0;
    ret v;
}

# Instr: a single IR instruction.
# ---
# op:    operation code
# dst:   destination operand
# src1:  first source operand
# src2:  second source operand
# cond:  condition code (for conditional ops)
pub rec Instr {
    op:       IROp;
    dst:      IRValue;
    src1:     IRValue;
    src2:     IRValue;
    cond:     IRCond;
    src_line: i32;
    src_file: u16;
}

# IRBlock: a basic block in the IR.
# ---
# label:        block label (used as identifier)
# instrs:       array of instructions
# instr_count:  number of instructions in block
# instr_cap:    capacity of instrs array
pub rec IRBlock {
    label:       str;
    instrs:      *Instr;
    instr_count: i32;
    instr_cap:   i32;
}

# create_block: create a new IR block.
# ---
# alloc: allocator
# lbl:   block label
# ret:   result containing block or error
pub fun create_block(alloc: *allocator.Allocator, lbl: str) Result[*IRBlock, str] {
    if (alloc == nil) {
        ret err[*IRBlock, str]("allocator is nil");
    }

    val r: Result[*IRBlock, allocator.AllocError] = alloc.alloc[IRBlock](1);
    if (r.is_err()) {
        ret err[*IRBlock, str]("out of memory");
    }

    val b: *IRBlock = r.unwrap_ok();
    b.label = lbl;
    b.instrs = nil;
    b.instr_count = 0;
    b.instr_cap = 0;

    ret ok[*IRBlock, str](b);
}

# emit_instr: emit an instruction to a block.
# ---
# alloc: allocator
# block: the IR block
# op:    operation code
# dst:   destination
# src1:  first source
# src2:  second source
# cond:  condition code
# ret:   instruction index
pub fun emit_instr(alloc: *allocator.Allocator, block: *IRBlock, op: IROp, dst: IRValue, src1: IRValue, src2: IRValue, cond: IRCond) i32 {
    if (block == nil || alloc == nil) {
        ret -1;
    }

    # grow array if needed
    if (block.instr_count >= block.instr_cap) {
        var new_cap: i32 = 8;
        if (block.instr_cap > 0) {
            new_cap = block.instr_cap * 2;
        }

        val r: Result[*Instr, allocator.AllocError] = alloc.resize[Instr](
            block.instrs, block.instr_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret -1;
        }

        block.instrs = r.unwrap_ok();
        block.instr_cap = new_cap;
    }

    val idx: i32 = block.instr_count;
    block.instrs[idx].op = op;
    block.instrs[idx].dst = dst;
    block.instrs[idx].src1 = src1;
    block.instrs[idx].src2 = src2;
    block.instrs[idx].cond = cond;
    block.instrs[idx].src_line = 0;
    block.instrs[idx].src_file = 0;
    block.instr_count = block.instr_count + 1;

    ret idx;
}

# IRFunction: a function in the IR.
# ---
# name:        function name
# blocks:      array of basic blocks
# block_count: number of blocks
# block_cap:   capacity of blocks array
# params:      parameter count
# local_size:  total size of local variables
pub rec IRFunction {
    name:        str;
    blocks:      **IRBlock;
    block_count: i32;
    block_cap:   i32;
    param_count: i32;
    local_size:  usize;
}

# create_function: create a new IR function.
# ---
# alloc: allocator
# n:     function name
# ret:   result containing function or error
pub fun create_function(alloc: *allocator.Allocator, n: str) Result[*IRFunction, str] {
    if (alloc == nil) {
        ret err[*IRFunction, str]("allocator is nil");
    }

    val r: Result[*IRFunction, allocator.AllocError] = alloc.alloc[IRFunction](1);
    if (r.is_err()) {
        ret err[*IRFunction, str]("out of memory");
    }

    val f: *IRFunction = r.unwrap_ok();
    f.name = n;
    f.blocks = nil;
    f.block_count = 0;
    f.block_cap = 0;
    f.param_count = 0;
    f.local_size = 0;

    ret ok[*IRFunction, str](f);
}

# add_block: add a block to a function.
# ---
# alloc: allocator
# func:  the function
# block: the block to add
# ret:   block index
pub fun add_block(alloc: *allocator.Allocator, func: *IRFunction, block: *IRBlock) i32 {
    if (func == nil || block == nil || alloc == nil) {
        ret -1;
    }

    # grow array if needed
    if (func.block_count >= func.block_cap) {
        var new_cap: i32 = 8;
        if (func.block_cap > 0) {
            new_cap = func.block_cap * 2;
        }

        val r: Result[**IRBlock, allocator.AllocError] = alloc.resize[*IRBlock](
            func.blocks, func.block_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret -1;
        }

        func.blocks = r.unwrap_ok();
        func.block_cap = new_cap;
    }

    val idx: i32 = func.block_count;
    func.blocks[idx] = block;
    func.block_count = func.block_count + 1;

    ret idx;
}
