use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.masm.ir: intermediate representation for code generation.
# ---
# provides IR types used between AST lowering and machine code emission.

# IROp: IR instruction opcode.
# ---
# each variant represents a distinct IR operation.
pub uni IROp {
    # data movement
    ir_mov:      u8;
    ir_load:     u8;
    ir_store:    u8;
    ir_lea:      u8;

    # arithmetic
    ir_add:      u8;
    ir_sub:      u8;
    ir_mul:      u8;
    ir_div:      u8;
    ir_mod:      u8;
    ir_neg:      u8;

    # bitwise
    ir_and:      u8;
    ir_or:       u8;
    ir_xor:      u8;
    ir_not:      u8;
    ir_shl:      u8;
    ir_shr:      u8;
    ir_sar:      u8;

    # comparison
    ir_cmp:      u8;
    ir_test:     u8;

    # control flow
    ir_jmp:      u8;
    ir_jcc:      u8;
    ir_call:     u8;
    ir_ret:      u8;

    # stack
    ir_push:     u8;
    ir_pop:      u8;

    # stack frame
    ir_frame:    u8;  # set up stack frame (sub rsp, N)
    ir_unframe:  u8;  # tear down stack frame (add rsp, N)

    # condition code set
    ir_sete:     u8;  # set if equal
    ir_setne:    u8;  # set if not equal
    ir_setl:     u8;  # set if less (signed)
    ir_setle:    u8;  # set if less or equal (signed)
    ir_setg:     u8;  # set if greater (signed)
    ir_setge:    u8;  # set if greater or equal (signed)
    ir_setb:     u8;  # set if below (unsigned)
    ir_setbe:    u8;  # set if below or equal (unsigned)
    ir_seta:     u8;  # set if above (unsigned)
    ir_setae:    u8;  # set if above or equal (unsigned)

    # conversions
    ir_zext:     u8;  # zero extend
    ir_sext:     u8;  # sign extend
    ir_trunc:    u8;  # truncate
    ir_itof:     u8;  # integer to float
    ir_ftoi:     u8;  # float to integer
    ir_fext:     u8;  # float extend (f32 -> f64)
    ir_ftrunc:   u8;  # float truncate (f64 -> f32)

    # special
    ir_nop:      u8;
    ir_label:    u8;
    ir_phi:      u8;
}

# IROp tag constants for dispatch
pub val OP_MOV:     u8 = 0;
pub val OP_LOAD:    u8 = 1;
pub val OP_STORE:   u8 = 2;
pub val OP_LEA:     u8 = 3;
pub val OP_ADD:     u8 = 4;
pub val OP_SUB:     u8 = 5;
pub val OP_MUL:     u8 = 6;
pub val OP_DIV:     u8 = 7;
pub val OP_MOD:     u8 = 8;
pub val OP_NEG:     u8 = 9;
pub val OP_AND:     u8 = 10;
pub val OP_OR:      u8 = 11;
pub val OP_XOR:     u8 = 12;
pub val OP_NOT:     u8 = 13;
pub val OP_SHL:     u8 = 14;
pub val OP_SHR:     u8 = 15;
pub val OP_SAR:     u8 = 16;
pub val OP_CMP:     u8 = 17;
pub val OP_TEST:    u8 = 18;
pub val OP_JMP:     u8 = 19;
pub val OP_JCC:     u8 = 20;
pub val OP_CALL:    u8 = 21;
pub val OP_RET:     u8 = 22;
pub val OP_PUSH:    u8 = 23;
pub val OP_POP:     u8 = 24;
pub val OP_FRAME:   u8 = 25;
pub val OP_UNFRAME: u8 = 26;
pub val OP_SETE:    u8 = 27;
pub val OP_SETNE:   u8 = 28;
pub val OP_SETL:    u8 = 29;
pub val OP_SETLE:   u8 = 30;
pub val OP_SETG:    u8 = 31;
pub val OP_SETGE:   u8 = 32;
pub val OP_SETB:    u8 = 33;
pub val OP_SETBE:   u8 = 34;
pub val OP_SETA:    u8 = 35;
pub val OP_SETAE:   u8 = 36;
pub val OP_ZEXT:    u8 = 37;
pub val OP_SEXT:    u8 = 38;
pub val OP_TRUNC:   u8 = 39;
pub val OP_ITOF:    u8 = 40;
pub val OP_FTOI:    u8 = 41;
pub val OP_FEXT:    u8 = 42;
pub val OP_FTRUNC:  u8 = 43;
pub val OP_NOP:     u8 = 44;
pub val OP_LABEL:   u8 = 45;
pub val OP_PHI:     u8 = 46;

# get_op_tag: get the tag byte from an IROp.
# ---
# op: pointer to IROp union
# ret: tag value
pub fun get_op_tag(op: *IROp) u8 {
    if (op == nil) {
        ret 255;
    }
    val tag_ptr: *u8 = op::*u8;
    ret @tag_ptr;
}

# IRValue: an operand or result value in IR.
# ---
# kind:       value kind (register, immediate, memory, label)
# reg:        register number (for register values)
# imm:        immediate value (for immediates)
# offset:     memory offset (for memory operands)
# base_reg:   base register (for memory operands)
# index_reg:  index register (for memory operands)
# scale:      index scale (1, 2, 4, 8)
# label:      label name (for label values)
# size:       operand size in bytes
pub rec IRValue {
    kind:      IRValueKind;
    reg:       i32;
    imm:       i64;
    offset:    i64;
    base_reg:  i32;
    index_reg: i32;
    scale:     i32;
    label:     str;
    size:      usize;
}

# IRValueKind tag constants
pub val VAL_NONE:  u8 = 0;
pub val VAL_REG:   u8 = 1;
pub val VAL_IMM:   u8 = 2;
pub val VAL_MEM:   u8 = 3;
pub val VAL_LABEL: u8 = 4;

# IRValueKind: the kind of IR value (tagged record pattern for enum-like behavior).
# ---
# tag: VAL_NONE, VAL_REG, VAL_IMM, VAL_MEM, or VAL_LABEL
pub rec IRValueKind {
    tag: u8;
}

# IRValueKind constructors
pub fun val_none() IRValueKind {
    ret IRValueKind { tag: VAL_NONE };
}

pub fun val_reg() IRValueKind {
    ret IRValueKind { tag: VAL_REG };
}

pub fun val_imm() IRValueKind {
    ret IRValueKind { tag: VAL_IMM };
}

pub fun val_mem() IRValueKind {
    ret IRValueKind { tag: VAL_MEM };
}

pub fun val_label() IRValueKind {
    ret IRValueKind { tag: VAL_LABEL };
}

# IRInstr: an IR instruction.
# ---
# op:     instruction opcode
# dst:    destination operand
# src1:   first source operand
# src2:   second source operand
# cond:   condition code (for conditional operations)
pub rec IRInstr {
    op:   IROp;
    dst:  IRValue;
    src1: IRValue;
    src2: IRValue;
    cond: i32;
}

# IRBlock: a basic block of IR instructions.
# ---
# label:       block label
# instrs:      array of instructions
# instr_count: number of instructions
# instr_cap:   allocated capacity
pub rec IRBlock {
    label:       str;
    instrs:      *IRInstr;
    instr_count: i32;
    instr_cap:   i32;
}

# IRFunction: a function in IR form.
# ---
# name:        function name
# blocks:      array of basic blocks
# block_count: number of blocks
# block_cap:   allocated capacity
# param_count: number of parameters
# local_size:  size of local variables in bytes
pub rec IRFunction {
    name:        str;
    blocks:      **IRBlock;
    block_count: i32;
    block_cap:   i32;
    param_count: i32;
    local_size:  usize;
}

# create_function: create a new IR function.
# ---
# alloc: allocator to use
# name:  function name
# ret:   Ok(*IRFunction) on success, Err(str) on failure
pub fun create_function(alloc: *allocator.Allocator, name: str) Result[*IRFunction, str] {
    if (alloc == nil) {
        ret err[*IRFunction, str]("allocator is nil");
    }

    val r: Result[*IRFunction, allocator.AllocError] = alloc.zalloc[IRFunction](1);
    if (r.is_err()) {
        ret err[*IRFunction, str](r.unwrap_err());
    }

    val func: *IRFunction = r.unwrap_ok();
    func.name = name;
    func.blocks = nil;
    func.block_count = 0;
    func.block_cap = 0;
    func.param_count = 0;
    func.local_size = 0;

    ret ok[*IRFunction, str](func);
}

# create_block: create a new basic block.
# ---
# alloc: allocator to use
# label: block label
# ret:   Ok(*IRBlock) on success, Err(str) on failure
pub fun create_block(alloc: *allocator.Allocator, label: str) Result[*IRBlock, str] {
    if (alloc == nil) {
        ret err[*IRBlock, str]("allocator is nil");
    }

    val r: Result[*IRBlock, allocator.AllocError] = alloc.zalloc[IRBlock](1);
    if (r.is_err()) {
        ret err[*IRBlock, str](r.unwrap_err());
    }

    val block: *IRBlock = r.unwrap_ok();
    block.label = label;
    block.instrs = nil;
    block.instr_count = 0;
    block.instr_cap = 0;

    ret ok[*IRBlock, str](block);
}

# emit_instr: append an instruction to a block.
# ---
# alloc: allocator for growing
# block: block to append to
# instr: instruction to append
# ret:   Ok(true) on success, Err(str) on failure
pub fun emit_instr(alloc: *allocator.Allocator, block: *IRBlock, instr: IRInstr) Result[bool, str] {
    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    if (block == nil) {
        ret err[bool, str]("block is nil");
    }

    if (block.instr_count >= block.instr_cap) {
        var new_cap: i32 = 16;
        if (block.instr_cap > 0) {
            new_cap = block.instr_cap * 2;
        }

        val r: Result[*IRInstr, allocator.AllocError] = alloc.resize[IRInstr](
            block.instrs, block.instr_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[bool, str](r.unwrap_err());
        }

        block.instrs = r.unwrap_ok();
        block.instr_cap = new_cap;
    }

    block.instrs[block.instr_count] = instr;
    block.instr_count = block.instr_count + 1;

    ret ok[bool, str](true);
}

# make_reg: create a register value.
# ---
# reg:  register number
# size: operand size in bytes
# ret:  IRValue for the register
pub fun make_reg(reg: i32, size: usize) IRValue {
    var v: IRValue;
    v.kind = val_reg();
    v.reg = reg;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 0;
    v.label = nil;
    v.size = size;
    ret v;
}

# make_imm: create an immediate value.
# ---
# imm:  immediate value
# size: operand size in bytes
# ret:  IRValue for the immediate
pub fun make_imm(imm: i64, size: usize) IRValue {
    var v: IRValue;
    v.kind = val_imm();
    v.reg = 0;
    v.imm = imm;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 0;
    v.label = nil;
    v.size = size;
    ret v;
}

# make_none: create an empty/none value.
# ---
# ret: IRValue with kind = VAL_NONE and all fields zeroed
pub fun make_none() IRValue {
    var v: IRValue;
    v.kind = val_none();
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 0;
    v.label = nil;
    v.size = 0;
    ret v;
}

# make_label: create a label value.
# ---
# label: label name
# ret:   IRValue for the label
pub fun make_label(label: str) IRValue {
    var v: IRValue;
    v.kind = val_label();
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 0;
    v.label = label;
    v.size = 0;
    ret v;
}

# --- IROp helper functions ---

# ir_mov: create a mov opcode.
pub fun ir_mov() IROp {
    ret IROp { ir_mov: OP_MOV };
}

# ir_load: create a load opcode.
pub fun ir_load() IROp {
    ret IROp { ir_load: OP_LOAD };
}

