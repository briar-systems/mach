use std.types.bool;
use std.types.size;
use std.types.string;

use op:   masm.op;
use inst: masm.inst;

# mach.compiler.masm.ir: compiler-internal IR extensions.
# ---
# the core IR (opcodes, instruction format, constructors, pools, functions)
# lives in the external masm library (masm.op, masm.inst, masm.pool,
# masm.function). this file provides only compiler-internal additions:
#
#   - OP_NOP, OP_MEMSET: peephole/ISel-only tombstone and optimization ops
#   - Operand, ValueKind, OPK_*: ISA-layer operand representation
#   - ABI metadata packing: pre-ABI encoding for OP_ARG/OP_PARAM/OP_CALL
#   - param/call sentinels: PARAM_SRET, PARAM_VARARGS, ARG_SRET, CALL_*

# compiler-internal opcodes (never emitted by lowering, never serialized)
pub val OP_NOP:    op.Operator = 40;
pub val OP_MEMSET: op.Operator = 41;

# compiler-internal instruction constructors

pub fun mk_nop() inst.Instruction {
    var i: inst.Instruction;
    i.op = OP_NOP;
    i.meta = 0;
    i.f0 = 0;
    i.f1 = 0;
    i.f2 = 0;
    ret i;
}

# operand kinds (for MachInst/AsmInst, ISA layer only)
pub def ValueKind: u8;

pub val OPK_NONE:   ValueKind = 0;
pub val OPK_REG:    ValueKind = 1;
pub val OPK_IMM:    ValueKind = 2;
pub val OPK_MEM:    ValueKind = 3;
pub val OPK_LABEL:  ValueKind = 4;
pub val OPK_SYM:    ValueKind = 5;

# Operand: an operand in a MachInst or AsmInst.
# ---
# flat record with a kind discriminant. fields are interpreted based on kind:
#   OPK_REG:   reg, size
#   OPK_IMM:   imm, size
#   OPK_MEM:   base, index, scale, disp, size
#   OPK_LABEL: label
#   OPK_SYM:   sym_id
pub rec Operand {
    kind:   ValueKind;
    size:   u8;
    reg:    i32;
    imm:    i64;
    base:   i32;
    index:  i32;
    scale:  i32;
    disp:   i64;
    sym_id: u64;
    label:  str;
}

# ABI metadata packing (pre-ABI instruction encoding)

pub val ABI_FLAG_FLOAT: u8 = 1;
pub val ABI_FLAG_AGG:   u8 = 2;

pub val CALL_VARIADIC:  u8 = 1;
pub val CALL_RET_FLOAT: u8 = 2;
pub val CALL_RET_AGG:   u8 = 4;

# param index sentinels
pub val PARAM_SRET:    u8 = 254;
pub val PARAM_VARARGS: u8 = 255;
pub val ARG_SRET:      u8 = 254;

# abi_meta byte: size_log2:3 | align_log2:3 | agg:1 | float:1
pub fun make_abi_meta(size: u8, align: u8, is_agg: bool, is_float: bool) u8 {
    var m: u8 = inst.encode_size(size) << 5;
    m = m | (inst.encode_size(align) << 2);
    if (is_agg) { m = m | 2; }
    if (is_float) { m = m | 1; }
    ret m;
}

pub fun abi_byte_size(meta: u8) u8  { ret inst.decode_size((meta >> 5) & 7); }
pub fun abi_align(meta: u8) u8      { ret inst.decode_size((meta >> 2) & 7); }
pub fun abi_is_agg(meta: u8) bool   { ret (meta & 2) != 0; }
pub fun abi_is_float(meta: u8) bool { ret (meta & 1) != 0; }

# pack OP_ARG/OP_RETVAL f2: byte_size:u16 | flags:u8 | align:u8
pub fun pack_arg_meta(byte_size: i32, flags: u8, align: u8) i32 {
    ret (byte_size & 0xFFFF) | (flags::i32 << 16) | (align::i32 << 24);
}
pub fun unpack_arg_size(f2: i32) i32  { ret f2 & 0xFFFF; }
pub fun unpack_arg_flags(f2: i32) u8  { ret (f2 >> 16)::u8; }
pub fun unpack_arg_align(f2: i32) u8  { ret (f2 >> 24)::u8; }
