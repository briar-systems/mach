use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use print:     std.print;

use masm:    mach.compiler.masm.masm;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;
use spec:    mach.compiler.masm.of.spec;
use dwarf:   mach.compiler.masm.of.dwarf;

# ELF executable base virtual address (standard for Linux x86-64)
pub val ELF_BASE_VADDR: u64 = 0x400000;

# ELF page size for alignment
pub val ELF_PAGE_SIZE: u64 = 0x1000;

# mach.compiler.masm.of.elf: ELF object file format implementation.
# ---
# provides ELF64 object file generation for Linux and other Unix-like systems.

# ELF magic bytes
pub val ELF_MAGIC_0: u8 = 127;  # 0x7F
pub val ELF_MAGIC_1: u8 = 69;   # 'E'
pub val ELF_MAGIC_2: u8 = 76;   # 'L'
pub val ELF_MAGIC_3: u8 = 70;   # 'F'

# ELF class
pub val ELFCLASS64: u8 = 2;

# ELF data encoding
pub val ELFDATA2LSB: u8 = 1;  # little-endian

# ELF version
pub val EV_CURRENT: u8 = 1;

# ELF OS/ABI
pub val ELFOSABI_SYSV: u8 = 0;

# ELF type
pub val ET_REL:  u16 = 1;  # relocatable object file
pub val ET_EXEC: u16 = 2;  # executable file

# ELF program header types
pub val PT_NULL: u32 = 0;
pub val PT_LOAD: u32 = 1;

# ELF program header flags
pub val PF_X: u32 = 1;  # executable
pub val PF_W: u32 = 2;  # writable
pub val PF_R: u32 = 4;  # readable

# ELF64 program header size
pub val ELF64_PHDR_SIZE: usize = 56;

# ELF machine
pub val EM_X86_64: u16 = 62;

# section types
pub val SHT_NULL:     u32 = 0;
pub val SHT_PROGBITS: u32 = 1;
pub val SHT_SYMTAB:   u32 = 2;
pub val SHT_STRTAB:   u32 = 3;
pub val SHT_RELA:     u32 = 4;
pub val SHT_NOBITS:   u32 = 8;

# section flags
pub val SHF_WRITE:     u64 = 1;
pub val SHF_ALLOC:     u64 = 2;
pub val SHF_EXECINSTR: u64 = 4;

# symbol binding
pub val STB_LOCAL:  u8 = 0;
pub val STB_GLOBAL: u8 = 1;
pub val STB_WEAK:   u8 = 2;

# symbol type
pub val STT_NOTYPE:  u8 = 0;
pub val STT_OBJECT:  u8 = 1;
pub val STT_FUNC:    u8 = 2;
pub val STT_SECTION: u8 = 3;
pub val STT_FILE:    u8 = 4;

# special section indices
pub val SHN_UNDEF: u16 = 0;
pub val SHN_ABS:   u16 = 65521;

# ELF64 header size
pub val ELF64_EHDR_SIZE: usize = 64;

# ELF64 section header size
pub val ELF64_SHDR_SIZE: usize = 64;

# ELF64 symbol entry size
pub val ELF64_SYM_SIZE: usize = 24;

# ELF64 relocation entry size (with addend)
pub val ELF64_RELA_SIZE: usize = 24;

# x86-64 relocation types
pub val R_X86_64_NONE:     u32 = 0;
pub val R_X86_64_64:       u32 = 1;   # direct 64-bit
pub val R_X86_64_PC32:     u32 = 2;   # PC-relative 32-bit
pub val R_X86_64_GOT32:    u32 = 3;
pub val R_X86_64_PLT32:    u32 = 4;   # PLT-relative 32-bit
pub val R_X86_64_32:       u32 = 10;  # direct 32-bit zero-extended
pub val R_X86_64_32S:      u32 = 11;  # direct 32-bit sign-extended

# SHF_INFO_LINK flag (sh_info contains section index)
pub val SHF_INFO_LINK: u64 = 64;

# ElfContext: context for ELF file generation.
# ---
# writer:        output writer
# alloc:         allocator
# shstrtab:      section header string table
# strtab:           symbol string table
# section_count:    number of sections
# symbol_count:     number of symbols
# sym_elf_indices:  mapping from masm symbol index to ELF symbol index
# sym_strtab_offs:  mapping from masm symbol index to strtab offset
pub rec ElfContext {
    writer:          spec.Writer;
    alloc:           *allocator.Allocator;
    shstrtab:        *u8;
    shstrtab_size:   usize;
    shstrtab_cap:    usize;
    strtab:          *u8;
    strtab_size:     usize;
    strtab_cap:      usize;
    section_count:   i32;
    symbol_count:    i32;
    sym_elf_indices: *u32;
    sym_strtab_offs: *u32;
    sym_map_cap:     i32;
}

# init: create a new ELF generation context.
# ---
# alloc: allocator to use
# ret:   initialized ElfContext
pub fun init(alloc: *allocator.Allocator) ElfContext {
    var ctx: ElfContext;
    ctx.writer = spec.init_writer(alloc);
    ctx.alloc = alloc;
    ctx.shstrtab = nil;
    ctx.shstrtab_size = 0;
    ctx.shstrtab_cap = 0;
    ctx.strtab = nil;
    ctx.strtab_size = 0;
    ctx.strtab_cap = 0;
    ctx.section_count = 0;
    ctx.symbol_count = 0;
    ctx.sym_elf_indices = nil;
    ctx.sym_strtab_offs = nil;
    ctx.sym_map_cap = 0;
    ret ctx;
}

# dnit: free ELF context resources.
# ---
# ctx: context to clean up
# ret: none
pub fun dnit(ctx: *ElfContext) {
    if (ctx == nil) {
        ret;
    }

    spec.dnit_writer(?ctx.writer);

    if (ctx.alloc != nil) {
        if (ctx.shstrtab != nil) {
            allocator.allocator_free[u8](ctx.alloc, ctx.shstrtab, ctx.shstrtab_cap);
        }
        if (ctx.strtab != nil) {
            allocator.allocator_free[u8](ctx.alloc, ctx.strtab, ctx.strtab_cap);
        }
        if (ctx.sym_elf_indices != nil) {
            allocator.allocator_free[u32](ctx.alloc, ctx.sym_elf_indices, ctx.sym_map_cap::u64);
        }
        if (ctx.sym_strtab_offs != nil) {
            allocator.allocator_free[u32](ctx.alloc, ctx.sym_strtab_offs, ctx.sym_map_cap::u64);
        }
    }
}

# write_elf_header: write the ELF64 file header.
# ---
# ctx:            ELF context
# section_count:  number of sections
# shstrndx:       section header string table index
# ret:            Ok(true) on success, Err(str) on failure
pub fun write_elf_header(ctx: *ElfContext, section_count: u16, shstrndx: u16) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    val w: *spec.Writer = ?ctx.writer;

    # e_ident (16 bytes)
    spec.write_u8(w, ELF_MAGIC_0);
    spec.write_u8(w, ELF_MAGIC_1);
    spec.write_u8(w, ELF_MAGIC_2);
    spec.write_u8(w, ELF_MAGIC_3);
    spec.write_u8(w, ELFCLASS64);     # 64-bit
    spec.write_u8(w, ELFDATA2LSB);    # little-endian
    spec.write_u8(w, EV_CURRENT);     # version
    spec.write_u8(w, ELFOSABI_SYSV);  # OS/ABI
    spec.write_zeros(w, 8);           # padding

    # e_type
    spec.write_u16_le(w, ET_REL);

    # e_machine
    spec.write_u16_le(w, EM_X86_64);

    # e_version
    spec.write_u32_le(w, 1);

    # e_entry (no entry point for .o files)
    spec.write_u64_le(w, 0);

    # e_phoff (no program headers for .o files)
    spec.write_u64_le(w, 0);

    # e_shoff (section headers follow immediately after header for now)
    # this will need to be patched later
    spec.write_u64_le(w, 0);

    # e_flags
    spec.write_u32_le(w, 0);

    # e_ehsize
    spec.write_u16_le(w, ELF64_EHDR_SIZE::u16);

    # e_phentsize
    spec.write_u16_le(w, 0);

    # e_phnum
    spec.write_u16_le(w, 0);

    # e_shentsize
    spec.write_u16_le(w, ELF64_SHDR_SIZE::u16);

    # e_shnum
    spec.write_u16_le(w, section_count);

    # e_shstrndx
    spec.write_u16_le(w, shstrndx);

    ret ok[bool, str](true);
}

# write_section_header: write an ELF64 section header.
# ---
# ctx:       ELF context
# name_off:  offset into section header string table
# sh_type:   section type
# flags:     section flags
# addr:      virtual address (usually 0 for .o files)
# offset:    file offset of section data
# size:      section size in bytes
# link:      linked section index
# info:      extra info
# align:     alignment
# entsize:   entry size (for symbol tables, etc.)
# ret:       Ok(true) on success, Err(str) on failure
pub fun write_section_header(ctx: *ElfContext, name_off: u32, sh_type: u32, flags: u64, addr: u64, offset: u64, size: u64, link: u32, info: u32, align: u64, entsize: u64) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    val w: *spec.Writer = ?ctx.writer;

    spec.write_u32_le(w, name_off);   # sh_name
    spec.write_u32_le(w, sh_type);    # sh_type
    spec.write_u64_le(w, flags);      # sh_flags
    spec.write_u64_le(w, addr);       # sh_addr
    spec.write_u64_le(w, offset);     # sh_offset
    spec.write_u64_le(w, size);       # sh_size
    spec.write_u32_le(w, link);       # sh_link
    spec.write_u32_le(w, info);       # sh_info
    spec.write_u64_le(w, align);      # sh_addralign
    spec.write_u64_le(w, entsize);    # sh_entsize

    ret ok[bool, str](true);
}

# write_relocation: write an ELF64 relocation entry (with addend).
# ---
# ctx:        ELF context
# offset:     offset within section where relocation applies
# sym_index:  index of symbol in symbol table
# rtype:      relocation type (R_X86_64_64, R_X86_64_PC32, etc.)
# addend:     addend value
# ret:        Ok(true) on success, Err(str) on failure
pub fun write_relocation(ctx: *ElfContext, offset: u64, sym_index: u32, rtype: u32, addend: i64) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    val w: *spec.Writer = ?ctx.writer;

    # r_offset
    spec.write_u64_le(w, offset);

    # r_info = (sym_index << 32) | type
    spec.write_u64_le(w, (sym_index::u64 << 32) | rtype::u64);

    # r_addend
    spec.write_u64_le(w, addend::u64);

    ret ok[bool, str](true);
}

# convert_reloc_type: convert section relocation type to ELF relocation type.
# ---
# rtype: section relocation type (RELOC_64, RELOC_PC32, etc.)
# ret:   ELF relocation type
pub fun convert_reloc_type(rtype: u8) u32 {
    if (rtype == section.RELOC_64) { ret R_X86_64_64; }
    if (rtype == section.RELOC_PC32) { ret R_X86_64_PC32; }
    if (rtype == section.RELOC_PLT32) { ret R_X86_64_PLT32; }
    if (rtype == section.RELOC_32) { ret R_X86_64_32; }
    if (rtype == section.RELOC_32S) { ret R_X86_64_32S; }
    ret R_X86_64_NONE;
}

# find_symbol_index: find the index of a symbol by name.
# ---
# m:    MASM context
# name: symbol name to find
# ret:  symbol index (1-based, 0 if not found)
pub fun find_symbol_index(m: *masm.Masm, name: str) u32 {
    if (m == nil || name == nil) {
        ret 0;
    }

    var i: i32 = 0;
    for (i < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && str_equals(s.name, name)) {
            ret (i + 1)::u32;  # +1 because index 0 is null symbol
        }
        i = i + 1;
    }

    ret 0;
}

# build_symbol_mapping: build mapping from masm symbol indices to ELF indices.
# ELF requires local symbols before global symbols in the symbol table.
# This function computes the reordered indices and strtab offsets.
# ---
# ctx: ELF context
# m:   MASM context
# ret: number of local symbols (for symtab sh_info)
pub fun build_symbol_mapping(ctx: *ElfContext, m: *masm.Masm) i32 {
    if (ctx == nil || m == nil || m.symbol_count == 0) {
        ret 1;  # null symbol counts as 1 local
    }

    # allocate mapping arrays
    val count: i32 = m.symbol_count;
    val alloc_res1: Result[*u32, allocator.AllocError] = allocator.allocator_alloc[u32](ctx.alloc, count::u64);
    val alloc_res2: Result[*u32, allocator.AllocError] = allocator.allocator_alloc[u32](ctx.alloc, count::u64);
    if (result_is_err[*u32, allocator.AllocError](alloc_res1) || result_is_err[*u32, allocator.AllocError](alloc_res2)) {
        ret 1;
    }
    ctx.sym_elf_indices = result_unwrap_ok[*u32, allocator.AllocError](alloc_res1);
    ctx.sym_strtab_offs = result_unwrap_ok[*u32, allocator.AllocError](alloc_res2);
    ctx.sym_map_cap = count;

    # first pass: count locals and assign strtab offsets
    # skip SYM_NONE symbols (internal branch labels) — they don't belong in ELF
    var strtab_off: u32 = 1;  # skip null byte
    var local_count: i32 = 1;  # null symbol is local
    var i: i32 = 0;
    for (i < count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
            ctx.sym_strtab_offs[i] = strtab_off;
            strtab_off = strtab_off + str_len(s.name)::u32 + 1;
            if (!sym.is_global(s)) {
                local_count = local_count + 1;
            }
        } or {
            ctx.sym_strtab_offs[i] = 0;
        }
        i = i + 1;
    }

    # second pass: assign ELF indices (locals first, then globals)
    var elf_idx: u32 = 1;  # 0 is null symbol

    # locals first
    i = 0;
    for (i < count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && !sym.is_global(s) && s.sym_type.tag != sym.SYM_NONE) {
            ctx.sym_elf_indices[i] = elf_idx;
            elf_idx = elf_idx + 1;
        }
        i = i + 1;
    }

    # then globals
    i = 0;
    for (i < count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && sym.is_global(s) && s.sym_type.tag != sym.SYM_NONE) {
            ctx.sym_elf_indices[i] = elf_idx;
            elf_idx = elf_idx + 1;
        }
        i = i + 1;
    }

    # store emitted symbol count (excluding null symbol)
    ctx.symbol_count = elf_idx::i32 - 1;

    ret local_count;
}

# find_symbol_elf_index: find the ELF index of a symbol by name using the mapping.
# ---
# ctx:  ELF context with symbol mapping built
# m:    MASM context
# name: symbol name to find
# ret:  ELF symbol index (0 if not found)
pub fun find_symbol_elf_index(ctx: *ElfContext, m: *masm.Masm, name: str) u32 {
    if (ctx == nil || m == nil || name == nil) {
        ret 0;
    }
    if (ctx.sym_elf_indices == nil) {
        # fallback to old behavior if mapping not built
        ret find_symbol_index(m, name);
    }

    var i: i32 = 0;
    for (i < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && str_equals(s.name, name)) {
            ret ctx.sym_elf_indices[i];
        }
        i = i + 1;
    }

    ret 0;
}

# write_symbol: write an ELF64 symbol table entry.
# ---
# ctx:     ELF context
# name:    offset into string table
# info:    symbol info (binding << 4 | type)
# other:   symbol visibility
# shndx:   section index
# value:   symbol value
# size:    symbol size
# ret:     Ok(true) on success, Err(str) on failure
pub fun write_symbol(ctx: *ElfContext, name: u32, info: u8, other: u8, shndx: u16, value: u64, size: u64) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    val w: *spec.Writer = ?ctx.writer;

    spec.write_u32_le(w, name);       # st_name
    spec.write_u8(w, info);           # st_info
    spec.write_u8(w, other);          # st_other
    spec.write_u16_le(w, shndx);      # st_shndx
    spec.write_u64_le(w, value);      # st_value
    spec.write_u64_le(w, size);       # st_size

    ret ok[bool, str](true);
}

# emit_object: emit a MASM context as an ELF object file.
# ---
# m:           MASM context to emit
# output_path: path for output file
# alloc:       allocator to use
# ret:         Ok(true) on success, Err(str) on failure
pub fun emit_object(m: *masm.Masm, output_path: str, alloc: *allocator.Allocator) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("masm context is nil");
    }

    if (output_path == nil) {
        ret err[bool, str]("output path is nil");
    }

    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    # initialize ELF context
    var ctx: ElfContext = init(alloc);

    # build section header string table (.shstrtab)
    # starts with null byte
    add_shstrtab_string(?ctx, "");

    # add standard section names
    val shstrtab_idx: u32 = add_shstrtab_string(?ctx, ".shstrtab")::u32;
    val strtab_name_idx: u32 = add_shstrtab_string(?ctx, ".strtab")::u32;
    val symtab_name_idx: u32 = add_shstrtab_string(?ctx, ".symtab")::u32;

    # track section info for headers
    # section 0 is always null
    # layout: null, .text, .data, .rodata, .bss, .rela.text, .symtab, .strtab, .shstrtab
    var section_name_offsets: [24]u32;
    var section_offsets: [24]u64;
    var section_sizes: [24]u64;
    var section_types: [24]u32;
    var section_flags: [24]u64;
    var section_aligns: [24]u64;
    var section_links: [24]u32;
    var section_infos: [24]u32;
    var section_entsizes: [24]u64;
    var section_count: i32 = 1;  # start with null section

    # track which MASM section each ELF section corresponds to
    var masm_section_map: [24]i32;
    var k: i32 = 0;
    for (k < 24) {
        masm_section_map[k] = -1;
        section_links[k] = 0;
        section_infos[k] = 0;
        section_entsizes[k] = 0;
        k = k + 1;
    }

    # add section names from MASM context
    var i: i32 = 0;
    var data_section_start: i32 = section_count;
    for (i < m.section_count && section_count < 16) {
        val sec: *section.Section = m.sections[i];
        if (sec != nil && sec.name != nil && sec.size > 0) {
            section_name_offsets[section_count] = add_shstrtab_string(?ctx, sec.name)::u32;
            section_sizes[section_count] = sec.size;
            section_aligns[section_count] = sec.align;
            masm_section_map[section_count] = i;

            # determine type and flags
            val kind_tag: u8 = section.get_kind_tag(sec.kind);
            if (kind_tag == section.SEC_TEXT) {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC | SHF_EXECINSTR;
            } or (kind_tag == section.SEC_DATA) {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC | SHF_WRITE;
            } or (kind_tag == section.SEC_RODATA) {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC;
            } or (kind_tag == section.SEC_BSS) {
                section_types[section_count] = SHT_NOBITS;
                section_flags[section_count] = SHF_ALLOC | SHF_WRITE;
            } or {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC;
            }

            section_count = section_count + 1;
        }
        i = i + 1;
    }

    val data_section_end: i32 = section_count;

    # add relocation sections for sections that have relocations
    var rela_section_indices: [8]i32;  # maps data section index to rela section index
    var rela_count: i32 = 0;
    i = data_section_start;
    for (i < data_section_end && rela_count < 8) {
        val masm_idx: i32 = masm_section_map[i];
        if (masm_idx >= 0 && masm_idx < m.section_count) {
            val sec: *section.Section = m.sections[masm_idx];
            if (sec != nil && section.has_relocations(sec)) {
                # create .rela.<name> section
                var rela_name_buf: [32]u8;
                rela_name_buf[0] = 46;   # '.'
                rela_name_buf[1] = 114;  # 'r'
                rela_name_buf[2] = 101;  # 'e'
                rela_name_buf[3] = 108;  # 'l'
                rela_name_buf[4] = 97;   # 'a'

                # copy original section name (skip leading dot if present)
                var src_idx: usize = 0;
                if (sec.name[0] == 46) {
                    src_idx = 0;  # include the dot
                }
                var dst_idx: usize = 5;
                for (src_idx < str_len(sec.name) && dst_idx < 31) {
                    rela_name_buf[dst_idx] = sec.name[src_idx];
                    src_idx = src_idx + 1;
                    dst_idx = dst_idx + 1;
                }
                rela_name_buf[dst_idx] = 0;

                val rela_name: str = (?rela_name_buf[0])::str;
                section_name_offsets[section_count] = add_shstrtab_string(?ctx, rela_name)::u32;
                section_sizes[section_count] = (sec.reloc_count::u64) * ELF64_RELA_SIZE;
                section_aligns[section_count] = 8;
                section_types[section_count] = SHT_RELA;
                section_flags[section_count] = SHF_INFO_LINK;
                section_infos[section_count] = i::u32;  # section being relocated
                section_entsizes[section_count] = ELF64_RELA_SIZE;
                # link will be set to symtab index later

                rela_section_indices[rela_count] = section_count;
                rela_count = rela_count + 1;
                section_count = section_count + 1;
            }
        }
        i = i + 1;
    }

    # reserve indices for symtab, strtab, shstrtab
    val symtab_idx: i32 = section_count;
    section_name_offsets[symtab_idx] = symtab_name_idx;
    section_types[symtab_idx] = SHT_SYMTAB;
    section_flags[symtab_idx] = 0;
    section_aligns[symtab_idx] = 8;
    section_entsizes[symtab_idx] = ELF64_SYM_SIZE;
    section_count = section_count + 1;

    val strtab_idx: i32 = section_count;
    section_name_offsets[strtab_idx] = strtab_name_idx;
    section_types[strtab_idx] = SHT_STRTAB;
    section_flags[strtab_idx] = 0;
    section_aligns[strtab_idx] = 1;
    section_count = section_count + 1;

    val shstrtab_section_idx: i32 = section_count;
    section_name_offsets[shstrtab_section_idx] = shstrtab_idx;
    section_types[shstrtab_section_idx] = SHT_STRTAB;
    section_flags[shstrtab_section_idx] = 0;
    section_aligns[shstrtab_section_idx] = 1;
    section_count = section_count + 1;

    # set symtab link for all rela sections
    var r: i32 = 0;
    for (r < rela_count) {
        section_links[rela_section_indices[r]] = symtab_idx::u32;
        r = r + 1;
    }

    # build symbol string table (skip SYM_NONE branch labels)
    add_strtab_string(?ctx, "");  # null entry

    # add symbols to strtab and build index mapping
    var j: i32 = 0;
    for (j < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[j];
        if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
            add_strtab_string(?ctx, s.name);
        }
        j = j + 1;
    }

    # build symbol mapping (locals before globals) - must be done before relocs
    val local_sym_count: i32 = build_symbol_mapping(?ctx, m);

    # compute file layout
    var current_offset: u64 = ELF64_EHDR_SIZE;

    # section data offsets (only data sections, not rela/symtab/strtab)
    i = 1;  # skip null section
    for (i < data_section_end) {
        # align offset
        val align: u64 = section_aligns[i];
        if (align > 1) {
            val mask: u64 = align - 1;
            current_offset = (current_offset + mask) & ~mask;
        }
        section_offsets[i] = current_offset;
        current_offset = current_offset + section_sizes[i];
        i = i + 1;
    }

    # relocation section offsets
    r = 0;
    for (r < rela_count) {
        val rela_idx: i32 = rela_section_indices[r];
        val align: u64 = section_aligns[rela_idx];
        if (align > 1) {
            val mask: u64 = align - 1;
            current_offset = (current_offset + mask) & ~mask;
        }
        section_offsets[rela_idx] = current_offset;
        current_offset = current_offset + section_sizes[rela_idx];
        r = r + 1;
    }

    # symtab offset and size (use emitted count, excludes SYM_NONE labels)
    val symtab_offset: u64 = current_offset;
    val sym_count: i32 = ctx.symbol_count + 1;  # +1 for null symbol
    val symtab_size: u64 = (sym_count::u64) * ELF64_SYM_SIZE;
    section_offsets[symtab_idx] = symtab_offset;
    section_sizes[symtab_idx] = symtab_size;
    current_offset = current_offset + symtab_size;

    # strtab offset and size
    val strtab_offset: u64 = current_offset;
    section_offsets[strtab_idx] = strtab_offset;
    section_sizes[strtab_idx] = ctx.strtab_size;
    current_offset = current_offset + ctx.strtab_size;

    # shstrtab offset and size
    val shstrtab_offset: u64 = current_offset;
    section_offsets[shstrtab_section_idx] = shstrtab_offset;
    section_sizes[shstrtab_section_idx] = ctx.shstrtab_size;
    current_offset = current_offset + ctx.shstrtab_size;

    # section headers offset
    val shoff: u64 = current_offset;

    # write ELF header
    write_elf_header(?ctx, section_count::u16, shstrtab_section_idx::u16);

    # patch shoff in header (offset 40)
    patch_u64_at(?ctx, 40, shoff);

    # write section data (only data sections)
    i = 1;
    for (i < data_section_end) {
        # align to section offset
        align_writer_to(?ctx, section_offsets[i]);

        # find corresponding MASM section
        val masm_idx: i32 = masm_section_map[i];
        if (masm_idx >= 0 && masm_idx < m.section_count) {
            val sec: *section.Section = m.sections[masm_idx];
            if (sec != nil && sec.data != nil && sec.size > 0) {
                write_section_data(?ctx, sec);
            }
        }
        i = i + 1;
    }

    # write relocation sections
    r = 0;
    for (r < rela_count) {
        val rela_idx: i32 = rela_section_indices[r];
        align_writer_to(?ctx, section_offsets[rela_idx]);

        # find the data section this rela applies to
        val target_sec_idx: i32 = section_infos[rela_idx]::i32;
        val masm_idx: i32 = masm_section_map[target_sec_idx];
        if (masm_idx >= 0 && masm_idx < m.section_count) {
            val sec: *section.Section = m.sections[masm_idx];
            if (sec != nil && sec.relocs != nil) {
                var ri: i32 = 0;
                for (ri < sec.reloc_count) {
                    val reloc: *section.Relocation = section.get_relocation(sec, ri);
                    if (reloc != nil) {
                        val sym_idx: u32 = find_symbol_elf_index(?ctx, m, reloc.symbol_name);
                        val elf_rtype: u32 = convert_reloc_type(reloc.rtype);
                        write_relocation(?ctx, reloc.offset, sym_idx, elf_rtype, reloc.addend);
                    }
                    ri = ri + 1;
                }
            }
        }
        r = r + 1;
    }

    # write symbol table (two passes: locals first, then globals)
    align_writer_to(?ctx, symtab_offset);
    write_null_symbol(?ctx);

    # helper to write a single symbol
    # pass 0: locals only, pass 1: globals only
    var pass: i32 = 0;
    for (pass < 2) {
        j = 0;
        for (j < m.symbol_count) {
            val s: *sym.Symbol = m.symbols[j];
            if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
                val is_global_sym: bool = sym.is_global(s);

                # pass 0 = locals, pass 1 = globals
                if ((pass == 0 && !is_global_sym) || (pass == 1 && is_global_sym)) {
                    # get strtab offset from mapping
                    val strtab_off: u32 = ctx.sym_strtab_offs[j];

                    # determine symbol info
                    var binding: u8 = STB_LOCAL;
                    if (is_global_sym) {
                        binding = STB_GLOBAL;
                    }

                    var stype: u8 = STT_NOTYPE;
                    if (sym.is_function(s)) {
                        stype = STT_FUNC;
                    } or (s.sym_type.tag == sym.SYM_OBJECT) {
                        stype = STT_OBJECT;
                    }

                    val info: u8 = make_symbol_info(binding, stype);

                    # section index: look up which ELF section this symbol belongs to
                    var shndx: u16 = SHN_UNDEF;
                    if (sym.is_defined(s) && s.section != nil) {
                        var si: i32 = data_section_start;
                        for (si < data_section_end) {
                            val mi: i32 = masm_section_map[si];
                            if (mi >= 0 && mi < m.section_count) {
                                if (m.sections[mi] == s.section) {
                                    shndx = si::u16;
                                    brk;
                                }
                            }
                            si = si + 1;
                        }
                    }

                    write_symbol(?ctx, strtab_off, info, 0, shndx, s.offset, s.size);
                }
            }
            j = j + 1;
        }
        pass = pass + 1;
    }

    # write string table
    align_writer_to(?ctx, strtab_offset);
    write_strtab(?ctx);

    # write section header string table
    align_writer_to(?ctx, shstrtab_offset);
    write_shstrtab(?ctx);

    # write section headers
    align_writer_to(?ctx, shoff);

    # null section header
    write_section_header(?ctx, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0);

    # data section headers
    i = 1;
    for (i < data_section_end) {
        write_section_header(?ctx,
            section_name_offsets[i],
            section_types[i],
            section_flags[i],
            0,  # addr
            section_offsets[i],
            section_sizes[i],
            section_links[i],
            section_infos[i],
            section_aligns[i],
            section_entsizes[i]
        );
        i = i + 1;
    }

    # relocation section headers
    r = 0;
    for (r < rela_count) {
        val rela_idx: i32 = rela_section_indices[r];
        write_section_header(?ctx,
            section_name_offsets[rela_idx],
            section_types[rela_idx],
            section_flags[rela_idx],
            0,  # addr
            section_offsets[rela_idx],
            section_sizes[rela_idx],
            section_links[rela_idx],  # symtab index
            section_infos[rela_idx],  # section being relocated
            section_aligns[rela_idx],
            section_entsizes[rela_idx]
        );
        r = r + 1;
    }

    # symtab section header (link = strtab index, info = first global symbol)
    write_section_header(?ctx,
        section_name_offsets[symtab_idx],
        section_types[symtab_idx],
        section_flags[symtab_idx],
        0,
        section_offsets[symtab_idx],
        section_sizes[symtab_idx],
        strtab_idx::u32,
        local_sym_count::u32,
        section_aligns[symtab_idx],
        section_entsizes[symtab_idx]
    );

    # strtab section header
    write_section_header(?ctx,
        section_name_offsets[strtab_idx],
        section_types[strtab_idx],
        section_flags[strtab_idx],
        0,
        section_offsets[strtab_idx],
        section_sizes[strtab_idx],
        0,
        0,
        section_aligns[strtab_idx],
        0
    );

    # shstrtab section header
    write_section_header(?ctx,
        section_name_offsets[shstrtab_section_idx],
        section_types[shstrtab_section_idx],
        section_flags[shstrtab_section_idx],
        0,
        section_offsets[shstrtab_section_idx],
        section_sizes[shstrtab_section_idx],
        0,
        0,
        section_aligns[shstrtab_section_idx],
        0
    );

    # write to output file
    val file_res: Result[fs.File, str] = fs.create(output_path, 420);  # 0644 octal
    if (result_is_err[fs.File, str](file_res)) {
        dnit(?ctx);
        ret err[bool, str](result_unwrap_err[fs.File, str](file_res));
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](file_res);
    val write_res: Result[usize, str] = fs.file_write(file, ctx.writer.data::&u8, ctx.writer.size);
    fs.file_close(file);

    if (result_is_err[usize, str](write_res)) {
        dnit(?ctx);
        ret err[bool, str](result_unwrap_err[usize, str](write_res));
    }

    dnit(?ctx);
    ret ok[bool, str](true);
}

# add_shstrtab_string: add a string to the section header string table.
# ---
# ctx: ELF context
# s:   string to add
# ret: offset of string in table
fun add_shstrtab_string(ctx: *ElfContext, s: str) usize {
    if (ctx == nil || ctx.alloc == nil) {
        ret 0;
    }

    val offset: usize = ctx.shstrtab_size;
    val len: usize = str_len(s) + 1;  # include null terminator

    # grow buffer if needed
    val needed: usize = ctx.shstrtab_size + len;
    if (needed > ctx.shstrtab_cap) {
        var new_cap: usize = 256;
        if (ctx.shstrtab_cap > 0) {
            new_cap = ctx.shstrtab_cap * 2;
        }
        for (new_cap < needed) {
            new_cap = new_cap * 2;
        }

        val r: Result[*u8, allocator.AllocError] = allocator.allocator_resize[u8](
            ctx.alloc, ctx.shstrtab, ctx.shstrtab_cap, new_cap
        );
        if (result_is_err[*u8, allocator.AllocError](r)) {
            ret offset;
        }

        ctx.shstrtab = result_unwrap_ok[*u8, allocator.AllocError](r);
        ctx.shstrtab_cap = new_cap;
    }

    # copy string
    var i: usize = 0;
    for (i < str_len(s)) {
        ctx.shstrtab[ctx.shstrtab_size + i] = s[i];
        i = i + 1;
    }
    ctx.shstrtab[ctx.shstrtab_size + i] = 0;  # null terminator
    ctx.shstrtab_size = ctx.shstrtab_size + len;

    ret offset;
}

# add_strtab_string: add a string to the symbol string table.
# ---
# ctx: ELF context
# s:   string to add
# ret: offset of string in table
fun add_strtab_string(ctx: *ElfContext, s: str) usize {
    if (ctx == nil || ctx.alloc == nil) {
        ret 0;
    }

    val offset: usize = ctx.strtab_size;
    val len: usize = str_len(s) + 1;

    val needed: usize = ctx.strtab_size + len;
    if (needed > ctx.strtab_cap) {
        var new_cap: usize = 256;
        if (ctx.strtab_cap > 0) {
            new_cap = ctx.strtab_cap * 2;
        }
        for (new_cap < needed) {
            new_cap = new_cap * 2;
        }

        val r: Result[*u8, allocator.AllocError] = allocator.allocator_resize[u8](
            ctx.alloc, ctx.strtab, ctx.strtab_cap, new_cap
        );
        if (result_is_err[*u8, allocator.AllocError](r)) {
            ret offset;
        }

        ctx.strtab = result_unwrap_ok[*u8, allocator.AllocError](r);
        ctx.strtab_cap = new_cap;
    }

    var i: usize = 0;
    for (i < str_len(s)) {
        ctx.strtab[ctx.strtab_size + i] = s[i];
        i = i + 1;
    }
    ctx.strtab[ctx.strtab_size + i] = 0;
    ctx.strtab_size = ctx.strtab_size + len;

    ret offset;
}

# patch_u64_at: patch a 64-bit value at a specific offset in the writer.
# ---
# ctx:    ELF context
# offset: offset to patch
# value:  value to write
# ret:    none
fun patch_u64_at(ctx: *ElfContext, offset: usize, value: u64) {
    if (ctx == nil || ctx.writer.data == nil || offset + 8 > ctx.writer.size) {
        ret;
    }

    ctx.writer.data[offset] = (value & 255)::u8;
    ctx.writer.data[offset + 1] = ((value >> 8) & 255)::u8;
    ctx.writer.data[offset + 2] = ((value >> 16) & 255)::u8;
    ctx.writer.data[offset + 3] = ((value >> 24) & 255)::u8;
    ctx.writer.data[offset + 4] = ((value >> 32) & 255)::u8;
    ctx.writer.data[offset + 5] = ((value >> 40) & 255)::u8;
    ctx.writer.data[offset + 6] = ((value >> 48) & 255)::u8;
    ctx.writer.data[offset + 7] = ((value >> 56) & 255)::u8;
}

# align_writer_to: align writer position to specific offset, padding with zeros.
# ---
# ctx:    ELF context
# offset: target offset
# ret:    none
fun align_writer_to(ctx: *ElfContext, offset: u64) {
    if (ctx == nil) {
        ret;
    }

    val current: u64 = ctx.writer.size;
    if (current < offset) {
        val pad: usize = (offset - current)::usize;
        spec.write_zeros(?ctx.writer, pad);
    }
}

# write_section_data: write section data bytes.
# ---
# ctx: ELF context
# sec: section to write
# ret: none
fun write_section_data(ctx: *ElfContext, sec: *section.Section) {
    if (ctx == nil || sec == nil || sec.data == nil) {
        ret;
    }

    spec.write_bytes(?ctx.writer, sec.data, sec.size);
}

# write_null_symbol: write the null symbol table entry.
# ---
# ctx: ELF context
# ret: none
fun write_null_symbol(ctx: *ElfContext) {
    if (ctx == nil) {
        ret;
    }

    write_symbol(ctx, 0, 0, 0, 0, 0, 0);
}

# write_strtab: write the symbol string table.
# ---
# ctx: ELF context
# ret: none
fun write_strtab(ctx: *ElfContext) {
    if (ctx == nil || ctx.strtab == nil) {
        ret;
    }

    spec.write_bytes(?ctx.writer, ctx.strtab, ctx.strtab_size);
}

# write_shstrtab: write the section header string table.
# ---
# ctx: ELF context
# ret: none
fun write_shstrtab(ctx: *ElfContext) {
    if (ctx == nil || ctx.shstrtab == nil) {
        ret;
    }

    spec.write_bytes(?ctx.writer, ctx.shstrtab, ctx.shstrtab_size);
}

# make_symbol_info: create a symbol info byte from binding and type.
# ---
# binding: symbol binding (STB_LOCAL, STB_GLOBAL, STB_WEAK)
# sym_type: symbol type (STT_NOTYPE, STT_FUNC, etc.)
# ret:      combined info byte
pub fun make_symbol_info(binding: u8, sym_type: u8) u8 {
    ret ((binding & 15) << 4) | (sym_type & 15);
}

# section_flags_to_elf: convert section kind to ELF flags.
# ---
# kind: section kind
# ret:  ELF section flags
pub fun section_flags_to_elf(kind: section.SectionKind) u64 {
    val tag: u8 = kind.tag;

    # text section: allocatable and executable
    if (tag == section.SEC_TEXT) {
        ret SHF_ALLOC | SHF_EXECINSTR;
    }

    # data section: allocatable and writable
    if (tag == section.SEC_DATA) {
        ret SHF_ALLOC | SHF_WRITE;
    }

    # rodata section: allocatable only (read-only)
    if (tag == section.SEC_RODATA) {
        ret SHF_ALLOC;
    }

    # bss section: allocatable and writable
    if (tag == section.SEC_BSS) {
        ret SHF_ALLOC | SHF_WRITE;
    }

    # custom/unknown: default to allocatable
    ret SHF_ALLOC;
}

# write_program_header: write an ELF64 program header.
# ---
# ctx:     ELF context
# p_type:  segment type (PT_LOAD, etc.)
# flags:   segment flags (PF_R, PF_W, PF_X)
# offset:  file offset of segment
# vaddr:   virtual address
# paddr:   physical address (usually same as vaddr)
# filesz:  size in file
# memsz:   size in memory
# align:   alignment
# ret:     Ok(true) on success, Err(str) on failure
pub fun write_program_header(ctx: *ElfContext, p_type: u32, flags: u32, offset: u64, vaddr: u64, paddr: u64, filesz: u64, memsz: u64, align: u64) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    val w: *spec.Writer = ?ctx.writer;

    spec.write_u32_le(w, p_type);   # p_type
    spec.write_u32_le(w, flags);    # p_flags
    spec.write_u64_le(w, offset);   # p_offset
    spec.write_u64_le(w, vaddr);    # p_vaddr
    spec.write_u64_le(w, paddr);    # p_paddr
    spec.write_u64_le(w, filesz);   # p_filesz
    spec.write_u64_le(w, memsz);    # p_memsz
    spec.write_u64_le(w, align);    # p_align

    ret ok[bool, str](true);
}

# write_executable_elf_header: write the ELF64 header for an executable.
# ---
# ctx:           ELF context
# entry:         entry point virtual address
# phoff:         program header offset
# phnum:         number of program headers
# section_count: number of sections
# shstrndx:      section header string table index
# ret:           Ok(true) on success, Err(str) on failure
pub fun write_executable_elf_header(ctx: *ElfContext, entry: u64, phoff: u64, phnum: u16, section_count: u16, shstrndx: u16) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    val w: *spec.Writer = ?ctx.writer;

    # e_ident (16 bytes)
    spec.write_u8(w, ELF_MAGIC_0);
    spec.write_u8(w, ELF_MAGIC_1);
    spec.write_u8(w, ELF_MAGIC_2);
    spec.write_u8(w, ELF_MAGIC_3);
    spec.write_u8(w, ELFCLASS64);
    spec.write_u8(w, ELFDATA2LSB);
    spec.write_u8(w, EV_CURRENT);
    spec.write_u8(w, ELFOSABI_SYSV);
    spec.write_zeros(w, 8);

    # e_type - executable
    spec.write_u16_le(w, ET_EXEC);

    # e_machine
    spec.write_u16_le(w, EM_X86_64);

    # e_version
    spec.write_u32_le(w, 1);

    # e_entry
    spec.write_u64_le(w, entry);

    # e_phoff
    spec.write_u64_le(w, phoff);

    # e_shoff (will be patched)
    spec.write_u64_le(w, 0);

    # e_flags
    spec.write_u32_le(w, 0);

    # e_ehsize
    spec.write_u16_le(w, ELF64_EHDR_SIZE::u16);

    # e_phentsize
    spec.write_u16_le(w, ELF64_PHDR_SIZE::u16);

    # e_phnum
    spec.write_u16_le(w, phnum);

    # e_shentsize
    spec.write_u16_le(w, ELF64_SHDR_SIZE::u16);

    # e_shnum
    spec.write_u16_le(w, section_count);

    # e_shstrndx
    spec.write_u16_le(w, shstrndx);

    ret ok[bool, str](true);
}

# find_entry_symbol: find the _start symbol and return its address.
# ---
# m:          MASM context
# text_vaddr: virtual address of .text section
# ret:        Ok(entry address) if defined, Err if missing
pub fun find_entry_symbol(m: *masm.Masm, text_vaddr: u64) Result[u64, str] {
    if (m == nil) {
        ret err[u64, str]("masm context is nil");
    }

    var i: i32 = 0;
    for (i < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && str_equals(s.name, "_start")) {
            if (!sym.is_defined(s)) {
                ret err[u64, str]("entry symbol _start is undefined");
            }
            ret ok[u64, str](text_vaddr + s.offset);
        }
        i = i + 1;
    }

    ret err[u64, str]("entry symbol _start not found");
}

# apply_relocations: resolve and apply all relocations in a section.
# ---
# sec:          section with relocations
# sec_vaddr:    virtual address of this section
# m:            MASM context for symbol lookup
# section_map:  maps MASM section index to virtual address
# text_vaddr:   virtual address of .text section (fallback)
# ret:          none
pub fun apply_relocations(sec: *section.Section, sec_vaddr: u64, m: *masm.Masm, text_vaddr: u64, rodata_vaddr: u64, data_vaddr: u64) {
    apply_relocations_ex(sec, sec_vaddr, m, text_vaddr, rodata_vaddr, data_vaddr, 0);
}

# apply_relocations_ex: apply relocations with .bss support.
pub fun apply_relocations_ex(sec: *section.Section, sec_vaddr: u64, m: *masm.Masm, text_vaddr: u64, rodata_vaddr: u64, data_vaddr: u64, bss_vaddr: u64) {
    if (sec == nil || !section.has_relocations(sec)) {
        ret;
    }

    var i: i32 = 0;
    for (i < sec.reloc_count) {
        val reloc: *section.Relocation = section.get_relocation(sec, i);
        if (reloc == nil) {
            i = i + 1;
            cnt;
        }

        # find symbol value
        var sym_addr: u64 = 0;
        if (reloc.symbol_name != nil && m != nil) {
            var j: i32 = 0;
            for (j < m.symbol_count) {
                val s: *sym.Symbol = m.symbols[j];
                if (s != nil && s.name != nil && str_equals(s.name, reloc.symbol_name)) {
                    if (s.section != nil && s.section.name != nil && str_equals(s.section.name, ".rodata")) {
                        sym_addr = rodata_vaddr + s.offset;
                    } or (s.section != nil && s.section.name != nil && str_equals(s.section.name, ".data")) {
                        sym_addr = data_vaddr + s.offset;
                    } or (s.section != nil && s.section.name != nil && str_equals(s.section.name, ".bss")) {
                        sym_addr = bss_vaddr + s.offset;
                    } or {
                        sym_addr = text_vaddr + s.offset;
                    }
                    brk;
                }
                j = j + 1;
            }
        }

        # warn if symbol was not found
        if (sym_addr == 0 && reloc.symbol_name != nil && (reloc.rtype == section.RELOC_PC32 || reloc.rtype == section.RELOC_PLT32 || reloc.rtype == section.RELOC_64)) {
            print.eprint("[reloc] unresolved: ");
            print.eprintln(reloc.symbol_name);
        }

        # apply relocation based on type
        if (reloc.rtype == section.RELOC_64) {
            val value: i64 = sym_addr::i64 + reloc.addend;
            section.patch_i64(sec, reloc.offset, value);
        } or (reloc.rtype == section.RELOC_PC32 || reloc.rtype == section.RELOC_PLT32) {
            val place: u64 = sec_vaddr + reloc.offset;
            val value: i64 = sym_addr::i64 + reloc.addend - place::i64;
            section.patch_i32(sec, reloc.offset, value::i32);
        } or (reloc.rtype == section.RELOC_32 || reloc.rtype == section.RELOC_32S) {
            val value: i64 = sym_addr::i64 + reloc.addend;
            section.patch_i32(sec, reloc.offset, value::i32);
        }

        i = i + 1;
    }
}

# emit_executable: emit a MASM context as an executable ELF file (no external linker needed).
# ---
# m:           MASM context to emit
# output_path: path for output file
# alloc:       allocator to use
# ret:         Ok(true) on success, Err(str) on failure
# page_align: align a value up to the next page boundary.
fun page_align(v: u64) u64 {
    ret (v + ELF_PAGE_SIZE - 1) & ~(ELF_PAGE_SIZE - 1);
}

pub fun emit_executable(m: *masm.Masm, output_path: str, alloc: *allocator.Allocator) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("masm context is nil");
    }

    if (output_path == nil) {
        ret err[bool, str]("output path is nil");
    }

    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    var ctx: ElfContext = init(alloc);

    # find sections
    var text_sec: *section.Section = nil;
    var rodata_sec: *section.Section = nil;
    var data_sec: *section.Section = nil;
    var bss_sec: *section.Section = nil;
    var i: i32 = 0;
    for (i < m.section_count) {
        val sec: *section.Section = m.sections[i];
        if (sec != nil && sec.name != nil) {
            if (str_equals(sec.name, ".text")) {
                text_sec = sec;
            } or (str_equals(sec.name, ".rodata")) {
                rodata_sec = sec;
            } or (str_equals(sec.name, ".data")) {
                data_sec = sec;
            } or (str_equals(sec.name, ".bss")) {
                bss_sec = sec;
            }
        }
        i = i + 1;
    }

    if (text_sec == nil || text_sec.size == 0) {
        dnit(?ctx);
        ret err[bool, str]("no .text section found");
    }

    val text_size: u64 = text_sec.size;
    var rodata_size: u64 = 0;
    if (rodata_sec != nil) { rodata_size = rodata_sec.size; }
    var data_size: u64 = 0;
    if (data_sec != nil) { data_size = data_sec.size; }
    var bss_size: u64 = 0;
    if (bss_sec != nil) { bss_size = bss_sec.size; }

    # compute number of PT_LOAD segments
    var num_phdrs: u16 = 1;  # .text always present
    if (rodata_size > 0) { num_phdrs = num_phdrs + 1; }
    if (data_size > 0 || bss_size > 0) { num_phdrs = num_phdrs + 1; }

    # compute layout with page-aligned segments
    val ehdr_size: u64 = ELF64_EHDR_SIZE;
    val phdr_offset: u64 = ehdr_size;
    val phdr_total_size: u64 = (num_phdrs::u64) * ELF64_PHDR_SIZE;

    # .text at first page boundary
    val text_file_offset: u64 = ELF_PAGE_SIZE;
    val text_vaddr: u64 = ELF_BASE_VADDR + text_file_offset;

    # .rodata at next page boundary after .text
    val rodata_file_offset: u64 = page_align(text_file_offset + text_size);
    val rodata_vaddr: u64 = ELF_BASE_VADDR + rodata_file_offset;

    # .data at next page boundary after .rodata
    var data_file_offset: u64 = rodata_file_offset;
    if (rodata_size > 0) {
        data_file_offset = page_align(rodata_file_offset + rodata_size);
    }
    val data_vaddr: u64 = ELF_BASE_VADDR + data_file_offset;

    # .bss immediately follows .data in memory (no file bytes)
    val bss_vaddr: u64 = data_vaddr + data_size;

    # find entry point
    val entry_res: Result[u64, str] = find_entry_symbol(m, text_vaddr);
    if (result_is_err[u64, str](entry_res)) {
        dnit(?ctx);
        ret err[bool, str](result_unwrap_err[u64, str](entry_res));
    }
    val entry: u64 = result_unwrap_ok[u64, str](entry_res);

    # apply relocations before writing
    apply_relocations_ex(text_sec, text_vaddr, m, text_vaddr, rodata_vaddr, data_vaddr, bss_vaddr);
    if (rodata_sec != nil) {
        apply_relocations_ex(rodata_sec, rodata_vaddr, m, text_vaddr, rodata_vaddr, data_vaddr, bss_vaddr);
    }
    if (data_sec != nil) {
        apply_relocations_ex(data_sec, data_vaddr, m, text_vaddr, rodata_vaddr, data_vaddr, bss_vaddr);
    }

    # build symbol string table (skip SYM_NONE branch labels)
    add_strtab_string(?ctx, "");
    var j: i32 = 0;
    for (j < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[j];
        if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
            add_strtab_string(?ctx, s.name);
        }
        j = j + 1;
    }

    # build section header string table
    add_shstrtab_string(?ctx, "");
    val sh_text: usize = add_shstrtab_string(?ctx, ".text");
    var sh_rodata: usize = 0;
    var sh_data: usize = 0;
    var sh_bss: usize = 0;
    if (rodata_size > 0) {
        sh_rodata = add_shstrtab_string(?ctx, ".rodata");
    }
    if (data_size > 0 || bss_size > 0) {
        sh_data = add_shstrtab_string(?ctx, ".data");
    }
    if (bss_size > 0) {
        sh_bss = add_shstrtab_string(?ctx, ".bss");
    }
    val sh_debug_info: usize = add_shstrtab_string(?ctx, ".debug_info");
    val sh_debug_abbrev: usize = add_shstrtab_string(?ctx, ".debug_abbrev");
    val sh_debug_line: usize = add_shstrtab_string(?ctx, ".debug_line");
    val sh_symtab: usize = add_shstrtab_string(?ctx, ".symtab");
    val sh_strtab: usize = add_shstrtab_string(?ctx, ".strtab");
    val sh_shstrtab: usize = add_shstrtab_string(?ctx, ".shstrtab");

    # section indices
    var section_count: u16 = 1;  # null section
    val text_idx: u16 = section_count; section_count = section_count + 1;
    var rodata_idx: u16 = 0;
    if (rodata_size > 0) {
        rodata_idx = section_count;
        section_count = section_count + 1;
    }
    var data_idx: u16 = 0;
    if (data_size > 0) {
        data_idx = section_count;
        section_count = section_count + 1;
    }
    var bss_idx: u16 = 0;
    if (bss_size > 0) {
        bss_idx = section_count;
        section_count = section_count + 1;
    }
    val debug_info_idx: u16 = section_count; section_count = section_count + 1;
    val debug_abbrev_idx: u16 = section_count; section_count = section_count + 1;
    val debug_line_idx: u16 = section_count; section_count = section_count + 1;
    val symtab_idx: u16 = section_count; section_count = section_count + 1;
    val strtab_idx: u16 = section_count; section_count = section_count + 1;
    val shstrtab_idx: u16 = section_count; section_count = section_count + 1;

    # build symbol mapping (locals before globals)
    val local_sym_count: i32 = build_symbol_mapping(?ctx, m);

    # compute symtab size
    val sym_count: i32 = ctx.symbol_count + 1;
    val symtab_size: u64 = (sym_count::u64) * ELF64_SYM_SIZE;

    # build DWARF debug sections
    var debug_abbrev_writer: spec.Writer = spec.init_writer(alloc);
    dwarf.build_debug_abbrev(?debug_abbrev_writer);
    val debug_abbrev_size: u64 = debug_abbrev_writer.size;

    var main_debug_file: str = nil;
    if (m.debug_file_count > 0 && m.debug_files != nil) {
        main_debug_file = m.debug_files[0];
    }

    var debug_info_writer: spec.Writer = spec.init_writer(alloc);
    dwarf.build_debug_info(?debug_info_writer, m, text_vaddr, text_size, main_debug_file);
    val debug_info_size: u64 = debug_info_writer.size;

    var debug_line_writer: spec.Writer = spec.init_writer(alloc);
    dwarf.build_debug_line(?debug_line_writer, m, text_vaddr);
    val debug_line_size: u64 = debug_line_writer.size;

    # compute non-loadable section layout (after last loadable segment)
    var metadata_offset: u64 = data_file_offset + data_size;
    if (rodata_size == 0 && data_size == 0 && bss_size == 0) {
        metadata_offset = text_file_offset + text_size;
    } or (data_size == 0 && bss_size == 0) {
        metadata_offset = rodata_file_offset + rodata_size;
    }
    val debug_info_offset: u64 = metadata_offset;
    val debug_abbrev_offset: u64 = debug_info_offset + debug_info_size;
    val debug_line_offset: u64 = debug_abbrev_offset + debug_abbrev_size;
    val symtab_offset: u64 = debug_line_offset + debug_line_size;
    val strtab_offset: u64 = symtab_offset + symtab_size;
    val shstrtab_offset: u64 = strtab_offset + ctx.strtab_size;
    val shoff: u64 = shstrtab_offset + ctx.shstrtab_size;

    # write ELF header
    write_executable_elf_header(?ctx, entry, phdr_offset, num_phdrs, section_count, shstrtab_idx);

    # write program headers — one per segment

    # segment 1: .text (R+X)
    write_program_header(?ctx,
        PT_LOAD,
        PF_R | PF_X,
        text_file_offset,
        text_vaddr,
        text_vaddr,
        text_size,
        text_size,
        ELF_PAGE_SIZE
    );

    # segment 2: .rodata (R) — skip if empty
    if (rodata_size > 0) {
        write_program_header(?ctx,
            PT_LOAD,
            PF_R,
            rodata_file_offset,
            rodata_vaddr,
            rodata_vaddr,
            rodata_size,
            rodata_size,
            ELF_PAGE_SIZE
        );
    }

    # segment 3: .data + .bss (R+W) — skip if both empty
    if (data_size > 0 || bss_size > 0) {
        write_program_header(?ctx,
            PT_LOAD,
            PF_R | PF_W,
            data_file_offset,
            data_vaddr,
            data_vaddr,
            data_size,
            data_size + bss_size,
            ELF_PAGE_SIZE
        );
    }

    # pad to .text offset
    align_writer_to(?ctx, text_file_offset);

    # write .text data
    write_section_data(?ctx, text_sec);

    # write .rodata if present (at page boundary)
    if (rodata_sec != nil && rodata_sec.size > 0) {
        align_writer_to(?ctx, rodata_file_offset);
        write_section_data(?ctx, rodata_sec);
    }

    # write .data if present (at page boundary)
    if (data_sec != nil && data_sec.size > 0) {
        align_writer_to(?ctx, data_file_offset);
        write_section_data(?ctx, data_sec);
    }

    # write DWARF debug sections
    align_writer_to(?ctx, debug_info_offset);
    if (debug_info_writer.data != nil && debug_info_writer.size > 0) {
        spec.write_bytes(?ctx.writer, debug_info_writer.data, debug_info_writer.size);
    }

    align_writer_to(?ctx, debug_abbrev_offset);
    if (debug_abbrev_writer.data != nil && debug_abbrev_writer.size > 0) {
        spec.write_bytes(?ctx.writer, debug_abbrev_writer.data, debug_abbrev_writer.size);
    }

    align_writer_to(?ctx, debug_line_offset);
    if (debug_line_writer.data != nil && debug_line_writer.size > 0) {
        spec.write_bytes(?ctx.writer, debug_line_writer.data, debug_line_writer.size);
    }

    # write symtab
    align_writer_to(?ctx, symtab_offset);
    write_null_symbol(?ctx);

    # locals then globals
    var pass: i32 = 0;
    for (pass < 2) {
        j = 0;
        for (j < m.symbol_count) {
            val s: *sym.Symbol = m.symbols[j];
            if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
                val is_global_sym: bool = sym.is_global(s);
                if ((pass == 0 && !is_global_sym) || (pass == 1 && is_global_sym)) {
                    var binding: u8 = STB_LOCAL;
                    if (is_global_sym) {
                        binding = STB_GLOBAL;
                    }

                    var stype: u8 = STT_NOTYPE;
                    if (sym.is_function(s)) {
                        stype = STT_FUNC;
                    } or (s.sym_type.tag == sym.SYM_OBJECT) {
                        stype = STT_OBJECT;
                    }

                    val info: u8 = make_symbol_info(binding, stype);
                    var shndx: u16 = SHN_UNDEF;
                    var sym_value: u64 = 0;
                    if (sym.is_defined(s) && s.section != nil) {
                        if (s.section == text_sec) {
                            shndx = text_idx;
                            sym_value = text_vaddr + s.offset;
                        } or (rodata_sec != nil && s.section == rodata_sec) {
                            shndx = rodata_idx;
                            sym_value = rodata_vaddr + s.offset;
                        } or (data_sec != nil && s.section == data_sec) {
                            shndx = data_idx;
                            sym_value = data_vaddr + s.offset;
                        } or (bss_sec != nil && s.section == bss_sec) {
                            shndx = bss_idx;
                            sym_value = bss_vaddr + s.offset;
                        }
                    }

                    val name_off: u32 = ctx.sym_strtab_offs[j];
                    write_symbol(?ctx, name_off, info, 0, shndx, sym_value, s.size);
                }
            }
            j = j + 1;
        }
        pass = pass + 1;
    }

    # write strtab
    align_writer_to(?ctx, strtab_offset);
    write_strtab(?ctx);

    # write shstrtab
    align_writer_to(?ctx, shstrtab_offset);
    write_shstrtab(?ctx);

    # patch shoff in header (offset 40)
    patch_u64_at(?ctx, 40, shoff);

    # write section headers
    align_writer_to(?ctx, shoff);
    write_section_header(?ctx, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0);

    # .text
    write_section_header(?ctx,
        sh_text::u32,
        SHT_PROGBITS,
        SHF_ALLOC | SHF_EXECINSTR,
        text_vaddr,
        text_file_offset,
        text_size,
        0,
        0,
        16,
        0
    );

    # .rodata
    if (rodata_size > 0) {
        write_section_header(?ctx,
            sh_rodata::u32,
            SHT_PROGBITS,
            SHF_ALLOC,
            rodata_vaddr,
            rodata_file_offset,
            rodata_size,
            0,
            0,
            8,
            0
        );
    }

    # .data
    if (data_size > 0) {
        write_section_header(?ctx,
            sh_data::u32,
            SHT_PROGBITS,
            SHF_ALLOC | SHF_WRITE,
            data_vaddr,
            data_file_offset,
            data_size,
            0,
            0,
            8,
            0
        );
    }

    # .bss (SHT_NOBITS - no file bytes, only memory)
    if (bss_size > 0) {
        write_section_header(?ctx,
            sh_bss::u32,
            SHT_NOBITS,
            SHF_ALLOC | SHF_WRITE,
            bss_vaddr,
            data_file_offset + data_size,  # file offset (no actual bytes)
            bss_size,
            0,
            0,
            16,
            0
        );
    }

    # .debug_info
    write_section_header(?ctx,
        sh_debug_info::u32,
        SHT_PROGBITS,
        0,
        0,
        debug_info_offset,
        debug_info_size,
        0,
        0,
        1,
        0
    );

    # .debug_abbrev
    write_section_header(?ctx,
        sh_debug_abbrev::u32,
        SHT_PROGBITS,
        0,
        0,
        debug_abbrev_offset,
        debug_abbrev_size,
        0,
        0,
        1,
        0
    );

    # .debug_line
    write_section_header(?ctx,
        sh_debug_line::u32,
        SHT_PROGBITS,
        0,
        0,
        debug_line_offset,
        debug_line_size,
        0,
        0,
        1,
        0
    );

    # symtab
    write_section_header(?ctx,
        sh_symtab::u32,
        SHT_SYMTAB,
        0,
        0,
        symtab_offset,
        symtab_size,
        strtab_idx::u32,
        local_sym_count::u32,
        8,
        ELF64_SYM_SIZE::u64
    );

    # strtab
    write_section_header(?ctx,
        sh_strtab::u32,
        SHT_STRTAB,
        0,
        0,
        strtab_offset,
        ctx.strtab_size,
        0,
        0,
        1,
        0
    );

    # shstrtab
    write_section_header(?ctx,
        sh_shstrtab::u32,
        SHT_STRTAB,
        0,
        0,
        shstrtab_offset,
        ctx.shstrtab_size,
        0,
        0,
        1,
        0
    );

    # free debug writers
    spec.dnit_writer(?debug_info_writer);
    spec.dnit_writer(?debug_abbrev_writer);
    spec.dnit_writer(?debug_line_writer);

    # write to output file
    val file_res: Result[fs.File, str] = fs.create(output_path, 493);  # 0755 octal
    if (result_is_err[fs.File, str](file_res)) {
        dnit(?ctx);
        ret err[bool, str](result_unwrap_err[fs.File, str](file_res));
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](file_res);
    val write_res: Result[usize, str] = fs.file_write(file, ctx.writer.data::&u8, ctx.writer.size);
    fs.file_close(file);

    if (result_is_err[usize, str](write_res)) {
        dnit(?ctx);
        ret err[bool, str](result_unwrap_err[usize, str](write_res));
    }

    dnit(?ctx);
    ret ok[bool, str](true);
}

# emit_object_to_writer: emit a MASM context as a relocatable .o file into a Writer.
# ---
# m:      masm context to emit
# writer: output writer (caller-provided)
# alloc:  allocator
# ret:    Ok(true) on success, Err(str) on failure
pub fun emit_object_to_writer(m: *masm.Masm, writer: *spec.Writer, alloc: *allocator.Allocator) Result[bool, str] {
    if (m == nil || writer == nil || alloc == nil) {
        ret err[bool, str]("nil argument to emit_object_to_writer");
    }

    # build ELF .o content into an internal ElfContext, then copy bytes to caller's writer
    var ctx: ElfContext = init(alloc);

    # build section header string table (.shstrtab)
    add_shstrtab_string(?ctx, "");

    val shstrtab_idx: u32 = add_shstrtab_string(?ctx, ".shstrtab")::u32;
    val strtab_name_idx: u32 = add_shstrtab_string(?ctx, ".strtab")::u32;
    val symtab_name_idx: u32 = add_shstrtab_string(?ctx, ".symtab")::u32;

    # track section info for headers
    # section 0 is always null
    var section_name_offsets: [24]u32;
    var section_offsets: [24]u64;
    var section_sizes: [24]u64;
    var section_types: [24]u32;
    var section_flags: [24]u64;
    var section_aligns: [24]u64;
    var section_links: [24]u32;
    var section_infos: [24]u32;
    var section_entsizes: [24]u64;
    var section_count: i32 = 1;  # start with null section

    # track which MASM section each ELF section corresponds to
    var masm_section_map: [24]i32;
    var k: i32 = 0;
    for (k < 24) {
        masm_section_map[k] = -1;
        section_links[k] = 0;
        section_infos[k] = 0;
        section_entsizes[k] = 0;
        k = k + 1;
    }

    # add section names from MASM context
    var i: i32 = 0;
    var data_section_start: i32 = section_count;
    for (i < m.section_count && section_count < 16) {
        val sec: *section.Section = m.sections[i];
        if (sec != nil && sec.name != nil && sec.size > 0) {
            section_name_offsets[section_count] = add_shstrtab_string(?ctx, sec.name)::u32;
            section_sizes[section_count] = sec.size;
            section_aligns[section_count] = sec.align;
            masm_section_map[section_count] = i;

            # determine type and flags
            val kind_tag: u8 = section.get_kind_tag(sec.kind);
            if (kind_tag == section.SEC_TEXT) {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC | SHF_EXECINSTR;
            } or (kind_tag == section.SEC_DATA) {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC | SHF_WRITE;
            } or (kind_tag == section.SEC_RODATA) {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC;
            } or (kind_tag == section.SEC_BSS) {
                section_types[section_count] = SHT_NOBITS;
                section_flags[section_count] = SHF_ALLOC | SHF_WRITE;
            } or {
                section_types[section_count] = SHT_PROGBITS;
                section_flags[section_count] = SHF_ALLOC;
            }

            section_count = section_count + 1;
        }
        i = i + 1;
    }

    val data_section_end: i32 = section_count;

    # add relocation sections for sections that have relocations
    var rela_section_indices: [8]i32;
    var rela_count: i32 = 0;
    i = data_section_start;
    for (i < data_section_end && rela_count < 8) {
        val masm_idx: i32 = masm_section_map[i];
        if (masm_idx >= 0 && masm_idx < m.section_count) {
            val sec: *section.Section = m.sections[masm_idx];
            if (sec != nil && section.has_relocations(sec)) {
                # create .rela.<name> section
                var rela_name_buf: [32]u8;
                rela_name_buf[0] = 46;   # '.'
                rela_name_buf[1] = 114;  # 'r'
                rela_name_buf[2] = 101;  # 'e'
                rela_name_buf[3] = 108;  # 'l'
                rela_name_buf[4] = 97;   # 'a'

                # copy original section name (include leading dot)
                var src_idx: usize = 0;
                if (sec.name[0] == 46) {
                    src_idx = 0;
                }
                var dst_idx: usize = 5;
                for (src_idx < str_len(sec.name) && dst_idx < 31) {
                    rela_name_buf[dst_idx] = sec.name[src_idx];
                    src_idx = src_idx + 1;
                    dst_idx = dst_idx + 1;
                }
                rela_name_buf[dst_idx] = 0;

                val rela_name: str = (?rela_name_buf[0])::str;
                section_name_offsets[section_count] = add_shstrtab_string(?ctx, rela_name)::u32;
                section_sizes[section_count] = (sec.reloc_count::u64) * ELF64_RELA_SIZE;
                section_aligns[section_count] = 8;
                section_types[section_count] = SHT_RELA;
                section_flags[section_count] = SHF_INFO_LINK;
                section_infos[section_count] = i::u32;  # section being relocated
                section_entsizes[section_count] = ELF64_RELA_SIZE;

                rela_section_indices[rela_count] = section_count;
                rela_count = rela_count + 1;
                section_count = section_count + 1;
            }
        }
        i = i + 1;
    }

    # reserve indices for symtab, strtab, shstrtab
    val symtab_idx: i32 = section_count;
    section_name_offsets[symtab_idx] = symtab_name_idx;
    section_types[symtab_idx] = SHT_SYMTAB;
    section_flags[symtab_idx] = 0;
    section_aligns[symtab_idx] = 8;
    section_entsizes[symtab_idx] = ELF64_SYM_SIZE;
    section_count = section_count + 1;

    val strtab_idx: i32 = section_count;
    section_name_offsets[strtab_idx] = strtab_name_idx;
    section_types[strtab_idx] = SHT_STRTAB;
    section_flags[strtab_idx] = 0;
    section_aligns[strtab_idx] = 1;
    section_count = section_count + 1;

    val shstrtab_section_idx: i32 = section_count;
    section_name_offsets[shstrtab_section_idx] = shstrtab_idx;
    section_types[shstrtab_section_idx] = SHT_STRTAB;
    section_flags[shstrtab_section_idx] = 0;
    section_aligns[shstrtab_section_idx] = 1;
    section_count = section_count + 1;

    # set symtab link for all rela sections
    var r: i32 = 0;
    for (r < rela_count) {
        section_links[rela_section_indices[r]] = symtab_idx::u32;
        r = r + 1;
    }

    # build symbol string table (skip SYM_NONE branch labels)
    add_strtab_string(?ctx, "");  # null entry

    var j: i32 = 0;
    for (j < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[j];
        if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
            add_strtab_string(?ctx, s.name);
        }
        j = j + 1;
    }

    # build symbol mapping (locals before globals) - must be done before relocs
    val local_sym_count: i32 = build_symbol_mapping(?ctx, m);

    # compute file layout
    var current_offset: u64 = ELF64_EHDR_SIZE;

    # section data offsets (only data sections, not rela/symtab/strtab)
    i = 1;  # skip null section
    for (i < data_section_end) {
        val align: u64 = section_aligns[i];
        if (align > 1) {
            val mask: u64 = align - 1;
            current_offset = (current_offset + mask) & ~mask;
        }
        section_offsets[i] = current_offset;
        current_offset = current_offset + section_sizes[i];
        i = i + 1;
    }

    # relocation section offsets
    r = 0;
    for (r < rela_count) {
        val rela_idx: i32 = rela_section_indices[r];
        val align: u64 = section_aligns[rela_idx];
        if (align > 1) {
            val mask: u64 = align - 1;
            current_offset = (current_offset + mask) & ~mask;
        }
        section_offsets[rela_idx] = current_offset;
        current_offset = current_offset + section_sizes[rela_idx];
        r = r + 1;
    }

    # symtab offset and size
    val symtab_offset: u64 = current_offset;
    val sym_count: i32 = ctx.symbol_count + 1;  # +1 for null symbol
    val symtab_size: u64 = (sym_count::u64) * ELF64_SYM_SIZE;
    section_offsets[symtab_idx] = symtab_offset;
    section_sizes[symtab_idx] = symtab_size;
    current_offset = current_offset + symtab_size;

    # strtab offset and size
    val strtab_offset: u64 = current_offset;
    section_offsets[strtab_idx] = strtab_offset;
    section_sizes[strtab_idx] = ctx.strtab_size;
    current_offset = current_offset + ctx.strtab_size;

    # shstrtab offset and size
    val shstrtab_offset: u64 = current_offset;
    section_offsets[shstrtab_section_idx] = shstrtab_offset;
    section_sizes[shstrtab_section_idx] = ctx.shstrtab_size;
    current_offset = current_offset + ctx.shstrtab_size;

    # section headers offset
    val shoff: u64 = current_offset;

    # write ELF header
    write_elf_header(?ctx, section_count::u16, shstrtab_section_idx::u16);

    # patch shoff in header (offset 40)
    patch_u64_at(?ctx, 40, shoff);

    # write section data (only data sections)
    i = 1;
    for (i < data_section_end) {
        align_writer_to(?ctx, section_offsets[i]);

        val masm_idx: i32 = masm_section_map[i];
        if (masm_idx >= 0 && masm_idx < m.section_count) {
            val sec: *section.Section = m.sections[masm_idx];
            if (sec != nil && sec.data != nil && sec.size > 0) {
                write_section_data(?ctx, sec);
            }
        }
        i = i + 1;
    }

    # write relocation sections
    r = 0;
    for (r < rela_count) {
        val rela_idx: i32 = rela_section_indices[r];
        align_writer_to(?ctx, section_offsets[rela_idx]);

        val target_sec_idx: i32 = section_infos[rela_idx]::i32;
        val masm_idx: i32 = masm_section_map[target_sec_idx];
        if (masm_idx >= 0 && masm_idx < m.section_count) {
            val sec: *section.Section = m.sections[masm_idx];
            if (sec != nil && sec.relocs != nil) {
                var ri: i32 = 0;
                for (ri < sec.reloc_count) {
                    val reloc: *section.Relocation = section.get_relocation(sec, ri);
                    if (reloc != nil) {
                        val sym_idx: u32 = find_symbol_elf_index(?ctx, m, reloc.symbol_name);
                        val elf_rtype: u32 = convert_reloc_type(reloc.rtype);
                        write_relocation(?ctx, reloc.offset, sym_idx, elf_rtype, reloc.addend);
                    }
                    ri = ri + 1;
                }
            }
        }
        r = r + 1;
    }

    # write symbol table (two passes: locals first, then globals)
    align_writer_to(?ctx, symtab_offset);
    write_null_symbol(?ctx);

    var pass: i32 = 0;
    for (pass < 2) {
        j = 0;
        for (j < m.symbol_count) {
            val s: *sym.Symbol = m.symbols[j];
            if (s != nil && s.name != nil && s.sym_type.tag != sym.SYM_NONE) {
                val is_global_sym: bool = sym.is_global(s);

                if ((pass == 0 && !is_global_sym) || (pass == 1 && is_global_sym)) {
                    val strtab_off: u32 = ctx.sym_strtab_offs[j];

                    var binding: u8 = STB_LOCAL;
                    if (is_global_sym) {
                        binding = STB_GLOBAL;
                    }

                    var stype: u8 = STT_NOTYPE;
                    if (sym.is_function(s)) {
                        stype = STT_FUNC;
                    } or (s.sym_type.tag == sym.SYM_OBJECT) {
                        stype = STT_OBJECT;
                    }

                    val info: u8 = make_symbol_info(binding, stype);

                    # find actual section index by matching symbol's section pointer
                    var shndx: u16 = SHN_UNDEF;
                    if (sym.is_defined(s) && s.section != nil) {
                        var si: i32 = 1;
                        for (si < data_section_end) {
                            val mi: i32 = masm_section_map[si];
                            if (mi >= 0 && mi < m.section_count) {
                                if (m.sections[mi] == s.section) {
                                    shndx = si::u16;
                                }
                            }
                            si = si + 1;
                        }
                        # fallback to 1 if section not found but symbol is defined
                        if (shndx == SHN_UNDEF) {
                            shndx = 1;
                        }
                    }

                    write_symbol(?ctx, strtab_off, info, 0, shndx, s.offset, s.size);
                }
            }
            j = j + 1;
        }
        pass = pass + 1;
    }

    # write string table
    align_writer_to(?ctx, strtab_offset);
    write_strtab(?ctx);

    # write section header string table
    align_writer_to(?ctx, shstrtab_offset);
    write_shstrtab(?ctx);

    # write section headers
    align_writer_to(?ctx, shoff);

    # null section header
    write_section_header(?ctx, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0);

    # data section headers
    i = 1;
    for (i < data_section_end) {
        write_section_header(?ctx,
            section_name_offsets[i],
            section_types[i],
            section_flags[i],
            0,  # addr
            section_offsets[i],
            section_sizes[i],
            section_links[i],
            section_infos[i],
            section_aligns[i],
            section_entsizes[i]
        );
        i = i + 1;
    }

    # relocation section headers
    r = 0;
    for (r < rela_count) {
        val rela_idx: i32 = rela_section_indices[r];
        write_section_header(?ctx,
            section_name_offsets[rela_idx],
            section_types[rela_idx],
            section_flags[rela_idx],
            0,  # addr
            section_offsets[rela_idx],
            section_sizes[rela_idx],
            section_links[rela_idx],
            section_infos[rela_idx],
            section_aligns[rela_idx],
            section_entsizes[rela_idx]
        );
        r = r + 1;
    }

    # symtab section header (link = strtab index, info = first global symbol)
    write_section_header(?ctx,
        section_name_offsets[symtab_idx],
        section_types[symtab_idx],
        section_flags[symtab_idx],
        0,
        section_offsets[symtab_idx],
        section_sizes[symtab_idx],
        strtab_idx::u32,
        local_sym_count::u32,
        section_aligns[symtab_idx],
        section_entsizes[symtab_idx]
    );

    # strtab section header
    write_section_header(?ctx,
        section_name_offsets[strtab_idx],
        section_types[strtab_idx],
        section_flags[strtab_idx],
        0,
        section_offsets[strtab_idx],
        section_sizes[strtab_idx],
        0,
        0,
        section_aligns[strtab_idx],
        0
    );

    # shstrtab section header
    write_section_header(?ctx,
        section_name_offsets[shstrtab_section_idx],
        section_types[shstrtab_section_idx],
        section_flags[shstrtab_section_idx],
        0,
        section_offsets[shstrtab_section_idx],
        section_sizes[shstrtab_section_idx],
        0,
        0,
        section_aligns[shstrtab_section_idx],
        0
    );

    # copy assembled ELF bytes to caller's writer
    if (ctx.writer.size > 0 && ctx.writer.data != nil) {
        val write_res: Result[usize, str] = spec.write_bytes(writer, ctx.writer.data::&u8, ctx.writer.size);
        if (result_is_err[usize, str](write_res)) {
            dnit(?ctx);
            ret err[bool, str](result_unwrap_err[usize, str](write_res));
        }
    }

    dnit(?ctx);
    ret ok[bool, str](true);
}
