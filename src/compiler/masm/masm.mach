use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use target:  mach.compiler.masm.target;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;

# mach.compiler.masm.masm: main MASM assembler context.
# ---
# provides the top-level context for machine code generation.

# Masm: the main MASM context.
# ---
# alloc:         allocator for all masm allocations
# tgt:           target configuration
# sections:      array of sections
# section_count: number of sections
# section_cap:   allocated capacity
# symbols:       array of symbols
# symbol_count:  number of symbols
# symbol_cap:    allocated capacity
pub rec Masm {
    alloc:         *allocator.Allocator;
    tgt:           target.Target;
    sections:      **section.Section;
    section_count: i32;
    section_cap:   i32;
    symbols:       **sym.Symbol;
    symbol_count:  i32;
    symbol_cap:    i32;
}

# create: create a new MASM context.
# ---
# alloc: allocator to use
# tgt:   target configuration
# ret:   Ok(Masm) on success, Err(str) on failure
pub fun create(alloc: *allocator.Allocator, tgt: target.Target) Result[Masm, str] {
    if (alloc == nil) {
        ret err[Masm, str]("allocator is nil");
    }

    var m: Masm;
    m.alloc = alloc;
    m.tgt = tgt;
    m.sections = nil;
    m.section_count = 0;
    m.section_cap = 0;
    m.symbols = nil;
    m.symbol_count = 0;
    m.symbol_cap = 0;

    ret ok[Masm, str](m);
}

# destroy: free all resources associated with a MASM context.
# ---
# m: context to destroy
# ret: none
pub fun destroy(m: *Masm) {
    if (m == nil || m.alloc == nil) {
        ret;
    }

    # TODO: free all sections
    # TODO: free all symbols

    if (m.sections != nil) {
        m.alloc.free[*section.Section](m.sections, m.section_cap::usize);
    }

    if (m.symbols != nil) {
        m.alloc.free[*sym.Symbol](m.symbols, m.symbol_cap::usize);
    }
}

# get_section: find a section by name.
# ---
# m:    masm context
# name: section name to find
# ret:  pointer to section or nil if not found
pub fun get_section(m: *Masm, name: str) *section.Section {
    if (m == nil || m.sections == nil || name == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < m.section_count) {
        val s: *section.Section = m.sections[i];
        if (s != nil && s.name != nil && s.name.equals(name)) {
            ret s;
        }
        i = i + 1;
    }

    ret nil;
}

# get_or_create_section: find a section by name, or create it if it doesn't exist.
# ---
# m:    masm context
# name: section name
# kind: section kind if creating
# ret:  Ok(*Section) on success, Err(str) on failure
pub fun get_or_create_section(m: *Masm, name: str, kind: section.SectionKind) Result[*section.Section, str] {
    if (m == nil) {
        ret err[*section.Section, str]("masm is nil");
    }

    val existing: *section.Section = get_section(m, name);
    if (existing != nil) {
        ret ok[*section.Section, str](existing);
    }

    # create new section
    if (m.alloc == nil) {
        ret err[*section.Section, str]("m.alloc is nil");
    }
    val sec_res: Result[*section.Section, str] = section.create(m.alloc, name, kind);
    if (sec_res.is_err()) {
        ret sec_res;
    }

    val sec: *section.Section = sec_res.unwrap_ok();

    # add to sections array
    if (m.section_count >= m.section_cap) {
        var new_cap: i32 = 8;
        if (m.section_cap > 0) {
            new_cap = m.section_cap * 2;
        }

        val r: Result[**section.Section, allocator.AllocError] = m.alloc.resize[*section.Section](
            m.sections, m.section_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[*section.Section, str](r.unwrap_err());
        }

        m.sections = r.unwrap_ok();
        m.section_cap = new_cap;
    }

    m.sections[m.section_count] = sec;
    m.section_count = m.section_count + 1;

    ret ok[*section.Section, str](sec);
}

# get_symbol: find a symbol by name.
# ---
# m:    masm context
# name: symbol name to find
# ret:  pointer to symbol or nil if not found
pub fun get_symbol(m: *Masm, name: str) *sym.Symbol {
    if (m == nil || m.symbols == nil || name == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < m.symbol_count) {
        val s: *sym.Symbol = m.symbols[i];
        if (s != nil && s.name != nil && s.name.equals(name)) {
            ret s;
        }
        i = i + 1;
    }

    ret nil;
}

# add_symbol: add a symbol to the context.
# ---
# m:   masm context
# s:   symbol to add
# ret: Ok(true) on success, Err(str) on failure
pub fun add_symbol(m: *Masm, s: *sym.Symbol) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("masm is nil");
    }

    if (s == nil) {
        ret err[bool, str]("symbol is nil");
    }

    if (m.symbol_count >= m.symbol_cap) {
        var new_cap: i32 = 8;
        if (m.symbol_cap > 0) {
            new_cap = m.symbol_cap * 2;
        }

        val r: Result[**sym.Symbol, allocator.AllocError] = m.alloc.resize[*sym.Symbol](
            m.symbols, m.symbol_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[bool, str](r.unwrap_err());
        }

        m.symbols = r.unwrap_ok();
        m.symbol_cap = new_cap;
    }

    m.symbols[m.symbol_count] = s;
    m.symbol_count = m.symbol_count + 1;

    ret ok[bool, str](true);
}

# merge: merge another MASM context into this one.
# ---
# dest: destination context
# src:  source context to merge from
# ret:  Ok(true) on success, Err(str) on failure
pub fun merge(dest: *Masm, src: *Masm) Result[bool, str] {
    if (dest == nil) {
        ret err[bool, str]("dest is nil");
    }

    if (src == nil) {
        ret ok[bool, str](true);
    }

    # TODO: merge sections (combine same-named sections)
    # TODO: merge symbols (check for conflicts)

    ret err[bool, str]("merge not yet implemented");
}
