# --- expression lowering ---

# lower_expr: lower an expression to IR.
# ---
# ctx:  lowering context
# node: expression AST node
# ret:  IRValue with result
pub fun lower_expr(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();
    none_val.reg = 0;
    none_val.imm = 0;
    none_val.offset = 0;
    none_val.base_reg = -1;
    none_val.index_reg = -1;
    none_val.scale = 1;
    none_val.label = nil;
    none_val.size = 0;

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val kind: ast.NodeKind = node.kind;

    # integer literal
    if (kind == ast.NODE_EXPR_LIT_INT) {
        val int_val: i64 = node.get_int_value();
        ret ir.make_imm(int_val, 8);
    }

    # float literal
    if (kind == ast.NODE_EXPR_LIT_FLOAT) {
        val float_val: f64 = node.get_float_value();
        # store float bits as i64 for now
        # TODO: proper float handling
        ret ir.make_imm(0, 8);
    }

    # char literal
    if (kind == ast.NODE_EXPR_LIT_CHAR) {
        val char_val: i64 = node.get_int_value();
        ret ir.make_imm(char_val, 1);
    }

    # bool literal
    if (kind == ast.NODE_EXPR_LIT_BOOL) {
        val bool_val: bool = node.get_bool_value();
        if (bool_val) {
            ret ir.make_imm(1, 1);
        }
        ret ir.make_imm(0, 1);
    }

    # nil literal
    if (kind == ast.NODE_EXPR_LIT_NIL) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # string literal
    if (kind == ast.NODE_EXPR_LIT_STR) {
        val str_val: str = node.get_name();
        val label: str = new_string_label(ctx);

        # add string to .rodata section
        if (ctx.m != nil) {
            val rodata_res: Result[*section.Section, str] = masm.get_or_create_section(
                ctx.m, ".rodata", section.section_rodata()
            );
            if (rodata_res.is_ok()) {
                val rodata: *section.Section = rodata_res.unwrap_ok();
                val offset: usize = rodata.size;

                # emit string bytes
                if (str_val != nil && ctx.alloc != nil) {
                    var i: usize = 0;
                    for (i < str_val.len()) {
                        section.emit_byte(ctx.alloc, rodata, str_val[i]);
                        i = i + 1;
                    }
                    section.emit_byte(ctx.alloc, rodata, 0);  # null terminator
                }

                # create symbol for the string
                val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, label);
                if (sym_res.is_ok()) {
                    val s: *sym.Symbol = sym_res.unwrap_ok();
                    sym.define(s, rodata, offset, str_val.len() + 1);
                    sym.set_binding(s, sym.bind_local());
                    sym.set_type(s, sym.sym_object());
                    masm.add_symbol(ctx.m, s);
                }
            }
        }

        # emit LEA to load string address
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);
        val src: ir.IRValue = ir.make_label(label);
        emit_lea(ctx, dst, src);

        ret dst;
    }

    # identifier
    if (kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.get_name();

        # check local variables first
        val lv: *LocalVar = find_local_var(ctx, name);
        if (lv != nil) {
            ret frame_mem(ctx, lv.offset, lv.size);
        }

        # check symbol table for globals
        if (ctx.symbols != nil) {
            val sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(name);
            if (sym_opt.is_some()) {
                # return label for global
                ret ir.make_label(name);
            }
        }

        ret none_val;
    }

    # parenthesized expression
    if (kind == ast.NODE_EXPR_PAREN) {
        val inner: *ast.Node = node.get_child(0);
        ret lower_expr(ctx, inner);
    }

    # binary expression
    if (kind == ast.NODE_EXPR_BINARY) {
        ret lower_binary(ctx, node);
    }

    # unary expression
    if (kind == ast.NODE_EXPR_UNARY) {
        ret lower_unary(ctx, node);
    }

    # call expression
    if (kind == ast.NODE_EXPR_CALL) {
        ret lower_call(ctx, node);
    }

    # field access
    if (kind == ast.NODE_EXPR_FIELD) {
        ret lower_field(ctx, node);
    }

    # index expression
    if (kind == ast.NODE_EXPR_INDEX) {
        ret lower_index(ctx, node);
    }

    # cast expression
    if (kind == ast.NODE_EXPR_CAST) {
        ret lower_cast(ctx, node);
    }

    # address-of
    if (kind == ast.NODE_EXPR_ADDR) {
        ret lower_addr(ctx, node);
    }

    # dereference
    if (kind == ast.NODE_EXPR_DEREF) {
        ret lower_deref(ctx, node);
    }

    # array literal
    if (kind == ast.NODE_EXPR_ARRAY_LIT) {
        ret lower_array_lit(ctx, node);
    }

    # struct literal
    if (kind == ast.NODE_EXPR_STRUCT_LIT) {
        ret lower_struct_lit(ctx, node);
    }

    ret none_val;
}

# lower_binary: lower a binary expression.
# ---
# ctx:  lowering context
# node: binary expression node
# ret:  IRValue with result
pub fun lower_binary(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    # get operator from token
    val op: u8 = node.tok.tag;

    # get left and right operands from children
    val lhs_node: *ast.Node = node.get_child(0);
    val rhs_node: *ast.Node = node.get_child(1);

    # check for assignment
    if (op == token.TAG_EQ) {
        ret lower_assign(ctx, lhs_node, rhs_node);
    }

    # check for short-circuit operators
    if (op == token.TAG_AMP_AMP || op == token.TAG_PIPE_PIPE) {
        ret lower_short_circuit(ctx, node, op);
    }

    # lower operands
    var lhs: ir.IRValue = lower_expr(ctx, lhs_node);
    var rhs: ir.IRValue = lower_expr(ctx, rhs_node);

    # ensure operands are in registers
    lhs = ensure_in_reg(ctx, lhs, ctx.ptr_size);
    rhs = ensure_in_reg(ctx, rhs, ctx.ptr_size);

    # allocate result register
    val dst: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);

    # select IR operation
    var ir_op: ir.IROp;
    ir_op = ir.IROp { ir_add: 0 };  # default

    if (op == token.TAG_PLUS) {
        ir_op = ir.IROp { ir_add: 0 };
    } or (op == token.TAG_MINUS) {
        ir_op = ir.IROp { ir_sub: 0 };
    } or (op == token.TAG_STAR) {
        ir_op = ir.IROp { ir_mul: 0 };
    } or (op == token.TAG_SLASH) {
        ir_op = ir.IROp { ir_div: 0 };
    } or (op == token.TAG_PERCENT) {
        ir_op = ir.IROp { ir_mod: 0 };
    } or (op == token.TAG_AMP) {
        ir_op = ir.IROp { ir_and: 0 };
    } or (op == token.TAG_PIPE) {
        ir_op = ir.IROp { ir_or: 0 };
    } or (op == token.TAG_CARET) {
        ir_op = ir.IROp { ir_xor: 0 };
    } or (op == token.TAG_LT_LT) {
        ir_op = ir.IROp { ir_shl: 0 };
    } or (op == token.TAG_GT_GT) {
        ir_op = ir.IROp { ir_shr: 0 };
    } or (op == token.TAG_EQ_EQ || op == token.TAG_BANG_EQ ||
          op == token.TAG_LT || op == token.TAG_LT_EQ ||
          op == token.TAG_GT || op == token.TAG_GT_EQ) {
        # comparison: emit CMP then set result based on condition
        emit_cmp(ctx, lhs, rhs);

        # determine condition code and signedness
        # get type from lhs_node to check signedness
        val is_signed: bool = type_is_signed(lhs_node.ty);

        var cond: i32 = 0;
        if (op == token.TAG_EQ_EQ) {
            cond = 0;  # e (equal)
        } or (op == token.TAG_BANG_EQ) {
            cond = 1;  # ne (not equal)
        } or (op == token.TAG_LT) {
            if (is_signed) { cond = 2; }  # l (less, signed)
            or { cond = 6; }              # b (below, unsigned)
        } or (op == token.TAG_LT_EQ) {
            if (is_signed) { cond = 3; }  # le (less or equal, signed)
            or { cond = 7; }              # be (below or equal, unsigned)
        } or (op == token.TAG_GT) {
            if (is_signed) { cond = 4; }  # g (greater, signed)
            or { cond = 8; }              # a (above, unsigned)
        } or (op == token.TAG_GT_EQ) {
            if (is_signed) { cond = 5; }  # ge (greater or equal, signed)
            or { cond = 9; }              # ae (above or equal, unsigned)
        }

        # emit setcc to set result byte
        val result_byte: ir.IRValue = ir.make_reg(new_temp(ctx, 1), 1);
        emit_setcc(ctx, cond, result_byte);

        # zero-extend to full register size
        emit_mov(ctx, dst, result_byte);

        ret dst;
    }

    emit_binop(ctx, ir_op, dst, lhs, rhs);

    ret dst;
}

# lower_unary: lower a unary expression.
# ---
# ctx:  lowering context
# node: unary expression node
# ret:  IRValue with result
pub fun lower_unary(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val op: u8 = node.tok.tag;
    val operand_node: *ast.Node = node.get_child(0);

    if (op == token.TAG_MINUS) {
        # negation
        var operand: ir.IRValue = lower_expr(ctx, operand_node);
        operand = ensure_in_reg(ctx, operand, ctx.ptr_size);

        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);
        emit_unaryop(ctx, ir.IROp { ir_neg: 0 }, dst, operand);
        ret dst;
    }

    if (op == token.TAG_BANG) {
        # logical not
        var operand: ir.IRValue = lower_expr(ctx, operand_node);
        operand = ensure_in_reg(ctx, operand, ctx.ptr_size);

        # compare to 0 and set opposite
        emit_cmp(ctx, operand, ir.make_imm(0, ctx.ptr_size));

        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, 1), 1);
        # TODO: emit sete (set if equal to zero)
        ret dst;
    }

    if (op == token.TAG_TILDE) {
        # bitwise not
        var operand: ir.IRValue = lower_expr(ctx, operand_node);
        operand = ensure_in_reg(ctx, operand, ctx.ptr_size);

        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);
        emit_unaryop(ctx, ir.IROp { ir_not: 0 }, dst, operand);
        ret dst;
    }

    ret none_val;
}

# lower_assign: lower an assignment expression.
# ---
# ctx: lowering context
# lhs: left-hand side node
# rhs: right-hand side node
# ret: IRValue with result (the assigned value)
pub fun lower_assign(ctx: *LowerContext, lhs: *ast.Node, rhs: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || lhs == nil || rhs == nil) {
        ret none_val;
    }

    # get the LHS type to determine if this is an aggregate assignment
    val lhs_type: *ty.Type = lhs.ty;
    val is_aggregate: bool = type_is_aggregate(lhs_type);
    var size: usize = ctx.ptr_size;
    if (lhs_type != nil) {
        size = lhs_type.size;
        if (size == 0) {
            size = ctx.ptr_size;
        }
    }

    # check if RHS is a call expression returning a small aggregate
    # small aggregates (<= ptr_size) are returned by value in a register, not by pointer
    val rhs_is_call: bool = rhs != nil && rhs.kind == ast.NODE_EXPR_CALL;
    val is_small_agg_from_call: bool = is_aggregate && size <= ctx.ptr_size && rhs_is_call;

    # lower the LHS as an lvalue (get address)
    var lhs_addr: ir.IRValue = lower_lvalue(ctx, lhs);
    lhs_addr = ensure_in_reg(ctx, lhs_addr, ctx.ptr_size);

    # for aggregate types (except small ones from calls), use memory copy
    if (is_aggregate && !is_small_agg_from_call) {
        # lower RHS - for aggregates, this returns a pointer to the data
        var rhs_val: ir.IRValue = lower_expr(ctx, rhs);
        rhs_val = ensure_in_reg(ctx, rhs_val, ctx.ptr_size);

        # copy the aggregate from src to dst
        emit_aggregate_copy(ctx, lhs_addr, rhs_val, size);

        ret rhs_val;
    }

    # scalar or small aggregate from call: use simple store
    var rhs_val: ir.IRValue = lower_expr(ctx, rhs);
    rhs_val = ensure_in_reg(ctx, rhs_val, ctx.ptr_size);

    # store RHS to LHS address
    emit_store(ctx, lhs_addr, rhs_val);

    ret rhs_val;
}

# lower_short_circuit: lower a short-circuit logical expression (&&, ||).
# ---
# ctx:  lowering context
# node: binary expression node
# op:   operator (TAG_AMP_AMP or TAG_PIPE_PIPE)
# ret:  IRValue with result
pub fun lower_short_circuit(ctx: *LowerContext, node: *ast.Node, op: u8) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val lhs_node: *ast.Node = node.get_child(0);
    val rhs_node: *ast.Node = node.get_child(1);

    val end_label: str = new_label(ctx, "scend");
    val result_reg: i32 = new_temp(ctx, 1);
    val dst: ir.IRValue = ir.make_reg(result_reg, 1);

    # evaluate LHS
    var lhs: ir.IRValue = lower_expr(ctx, lhs_node);
    lhs = ensure_in_reg(ctx, lhs, ctx.ptr_size);

    # test LHS
    emit_cmp(ctx, lhs, ir.make_imm(0, ctx.ptr_size));

    if (op == token.TAG_AMP_AMP) {
        # for &&: if LHS is false (0), short-circuit to end with 0
        emit_mov(ctx, dst, ir.make_imm(0, 1));
        emit_jcc(ctx, 0, end_label);  # JE (jump if equal to 0)
    } or {
        # for ||: if LHS is true (non-0), short-circuit to end with 1
        emit_mov(ctx, dst, ir.make_imm(1, 1));
        emit_jcc(ctx, 1, end_label);  # JNE (jump if not equal to 0)
    }

    # evaluate RHS
    var rhs: ir.IRValue = lower_expr(ctx, rhs_node);
    rhs = ensure_in_reg(ctx, rhs, ctx.ptr_size);

    # convert RHS to bool (compare to 0)
    emit_cmp(ctx, rhs, ir.make_imm(0, ctx.ptr_size));
    # TODO: emit setne to set result

    emit_label(ctx, end_label);

    ret dst;
}

# lower_call: lower a function call expression.
# ---
# ctx:  lowering context
# node: call expression node
# ret:  IRValue with result
pub fun lower_call(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    # get callee (first child)
    val callee_node: *ast.Node = node.get_child(0);

    # get arguments from node.data (should be a List)
    val args: *ast.List = node.get_list();

    # lower callee to get function address
    val callee: ir.IRValue = lower_expr(ctx, callee_node);

    # lower and place arguments
    var int_arg_idx: i32 = 0;
    var float_arg_idx: i32 = 0;
    var stack_arg_count: i32 = 0;

    if (args != nil) {
        var i: i32 = 0;
        for (i < args.count) {
            val arg_node: *ast.Node = args.nodes[i];
            var arg_val: ir.IRValue = lower_expr(ctx, arg_node);
            arg_val = ensure_in_reg(ctx, arg_val, ctx.ptr_size);

            # determine if float or int argument
            val is_float: bool = false;  # TODO: check arg type

            if (is_float && float_arg_idx < 8) {
                # place in float register
                val reg: i32 = sysv64.get_float_arg_reg(float_arg_idx);
                emit_mov(ctx, ir.make_reg(reg, ctx.ptr_size), arg_val);
                float_arg_idx = float_arg_idx + 1;
            } or (int_arg_idx < 6) {
                # place in integer register
                val reg: i32 = sysv64.get_arg_reg(int_arg_idx);
                emit_mov(ctx, ir.make_reg(reg, ctx.ptr_size), arg_val);
                int_arg_idx = int_arg_idx + 1;
            } or {
                # push to stack
                emit_push(ctx, arg_val);
                stack_arg_count = stack_arg_count + 1;
            }

            i = i + 1;
        }
    }

    # emit call
    emit_call(ctx, callee);

    # clean up stack arguments if any
    if (stack_arg_count > 0) {
        # add rsp, stack_arg_count * 8
        # TODO: emit stack cleanup
    }

    # return value is in RAX
    val result: ir.IRValue = ir.make_reg(sysv64.RAX, ctx.ptr_size);

    ret result;
}

# lower_field: lower a field access expression.
# ---
# ctx:  lowering context
# node: field access node
# ret:  IRValue with result
pub fun lower_field(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    # get base expression (first child)
    val base_node: *ast.Node = node.get_child(0);

    # get field name from data
    val field_name: str = node.get_name();

    # lower base to get struct address
    var base: ir.IRValue = lower_expr(ctx, base_node);
    base = ensure_in_reg(ctx, base, ctx.ptr_size);

    # look up field offset and size from base type
    var field_offset: i64 = 0;
    var field_size: usize = ctx.ptr_size;

    if (base_node.ty != nil && field_name != nil) {
        # handle pointer-to-struct (auto-deref)
        var struct_type: *ty.Type = base_node.ty;
        if (struct_type.kind == ty.TY_POINTER && struct_type.inner != nil) {
            struct_type = struct_type.inner;
        }

        if (struct_type.kind == ty.TY_RECORD || struct_type.kind == ty.TY_UNION) {
            field_offset = get_field_offset(struct_type, field_name, ctx.ptr_size)::i64;
            field_size = get_field_size(struct_type, field_name, ctx.ptr_size);
        }
    }

    # create memory operand for field
    var mem: ir.IRValue;
    mem.kind = ir.val_mem();
    mem.base_reg = base.reg;
    mem.offset = field_offset;
    mem.size = field_size;
    mem.reg = 0;
    mem.imm = 0;
    mem.index_reg = -1;
    mem.scale = 1;
    mem.label = nil;

    ret mem;
}

# lower_index: lower an index expression.
# ---
# ctx:  lowering context
# node: index expression node
# ret:  IRValue with result
pub fun lower_index(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    # get base and index (children)
    val base_node: *ast.Node = node.get_child(0);
    val index_node: *ast.Node = node.get_child(1);

    # lower base
    var base: ir.IRValue = lower_expr(ctx, base_node);
    base = ensure_in_reg(ctx, base, ctx.ptr_size);

    # lower index
    var idx: ir.IRValue = lower_expr(ctx, index_node);
    idx = ensure_in_reg(ctx, idx, ctx.ptr_size);

    # get element size from type
    var elem_size: usize = ctx.ptr_size;

    if (base_node.ty != nil) {
        val base_type: *ty.Type = base_node.ty;
        if (base_type.kind == ty.TY_ARRAY && base_type.inner != nil) {
            elem_size = type_size(base_type.inner, ctx.ptr_size);
        } or (base_type.kind == ty.TY_POINTER && base_type.inner != nil) {
            elem_size = type_size(base_type.inner, ctx.ptr_size);
        } or (base_type.kind == ty.TY_STR) {
            elem_size = 1;  # str is a byte array
        }
    }

    if (elem_size == 0) {
        elem_size = ctx.ptr_size;
    }

    # compute address: base + index * elem_size
    var mem: ir.IRValue;
    mem.kind = ir.val_mem();
    mem.base_reg = base.reg;
    mem.index_reg = idx.reg;
    mem.scale = elem_size::i32;
    mem.offset = 0;
    mem.size = elem_size;
    mem.reg = 0;
    mem.imm = 0;
    mem.label = nil;

    ret mem;
}

# lower_cast: lower a cast expression.
# ---
# ctx:  lowering context
# node: cast expression node
# ret:  IRValue with result
pub fun lower_cast(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    # get expression to cast (first child)
    val expr_node: *ast.Node = node.get_child(0);

    # lower expression
    var src: ir.IRValue = lower_expr(ctx, expr_node);
    src = ensure_in_reg(ctx, src, ctx.ptr_size);

    # get source and target types
    val src_type: *ty.Type = expr_node.ty;
    val dst_type: *ty.Type = node.ty;

    # if types are nil or same, return as-is
    if (src_type == nil || dst_type == nil) {
        ret src;
    }

    val src_size: usize = type_size(src_type, ctx.ptr_size);
    val dst_size: usize = type_size(dst_type, ctx.ptr_size);

    # pointer conversions - no-op at machine level
    if ((src_type.kind == ty.TY_POINTER || src_type.kind == ty.TY_PTR) &&
        (dst_type.kind == ty.TY_POINTER || dst_type.kind == ty.TY_PTR)) {
        ret src;
    }

    # integer to pointer or pointer to integer - no-op at machine level
    if ((src_type.kind == ty.TY_POINTER || src_type.kind == ty.TY_PTR) &&
        (dst_type.is_integer() || dst_type.kind == ty.TY_USIZE || dst_type.kind == ty.TY_ISIZE)) {
        ret src;
    }
    if ((src_type.is_integer() || src_type.kind == ty.TY_USIZE || src_type.kind == ty.TY_ISIZE) &&
        (dst_type.kind == ty.TY_POINTER || dst_type.kind == ty.TY_PTR)) {
        ret src;
    }

    # integer widening
    if (src_type.is_integer() && dst_type.is_integer() && dst_size > src_size) {
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, dst_size), dst_size);
        var instr: ir.IRInstr;

        if (type_is_signed(src_type)) {
            instr.op = ir.IROp { ir_sext: 0 };
        } or {
            instr.op = ir.IROp { ir_zext: 0 };
        }

        instr.dst = dst;
        instr.src1 = src;
        instr.src2.kind = ir.val_none();
        instr.cond = 0;

        if (ctx.current_block != nil && ctx.alloc != nil) {
            ir.emit_instr(ctx.alloc, ctx.current_block, instr);
        }

        ret dst;
    }

    # integer narrowing (truncate)
    if (src_type.is_integer() && dst_type.is_integer() && dst_size < src_size) {
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, dst_size), dst_size);
        var instr: ir.IRInstr;
        instr.op = ir.IROp { ir_trunc: 0 };
        instr.dst = dst;
        instr.src1 = src;
        instr.src2.kind = ir.val_none();
        instr.cond = 0;

        if (ctx.current_block != nil && ctx.alloc != nil) {
            ir.emit_instr(ctx.alloc, ctx.current_block, instr);
        }

        ret dst;
    }

    # float to int
    if (type_is_float(src_type) && dst_type.is_integer()) {
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, dst_size), dst_size);
        var instr: ir.IRInstr;
        instr.op = ir.IROp { ir_ftoi: 0 };
        instr.dst = dst;
        instr.src1 = src;
        instr.src2.kind = ir.val_none();
        instr.cond = 0;

        if (ctx.current_block != nil && ctx.alloc != nil) {
            ir.emit_instr(ctx.alloc, ctx.current_block, instr);
        }

        ret dst;
    }

    # int to float
    if (src_type.is_integer() && type_is_float(dst_type)) {
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, dst_size), dst_size);
        var instr: ir.IRInstr;
        instr.op = ir.IROp { ir_itof: 0 };
        instr.dst = dst;
        instr.src1 = src;
        instr.src2.kind = ir.val_none();
        instr.cond = 0;

        if (ctx.current_block != nil && ctx.alloc != nil) {
            ir.emit_instr(ctx.alloc, ctx.current_block, instr);
        }

        ret dst;
    }

    # float extension (f32 -> f64)
    if (src_type.kind == ty.TY_F32 && dst_type.kind == ty.TY_F64) {
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, 8), 8);
        var instr: ir.IRInstr;
        instr.op = ir.IROp { ir_fext: 0 };
        instr.dst = dst;
        instr.src1 = src;
        instr.src2.kind = ir.val_none();
        instr.cond = 0;

        if (ctx.current_block != nil && ctx.alloc != nil) {
            ir.emit_instr(ctx.alloc, ctx.current_block, instr);
        }

        ret dst;
    }

    # float truncation (f64 -> f32)
    if (src_type.kind == ty.TY_F64 && dst_type.kind == ty.TY_F32) {
        val dst: ir.IRValue = ir.make_reg(new_temp(ctx, 4), 4);
        var instr: ir.IRInstr;
        instr.op = ir.IROp { ir_ftrunc: 0 };
        instr.dst = dst;
        instr.src1 = src;
        instr.src2.kind = ir.val_none();
        instr.cond = 0;

        if (ctx.current_block != nil && ctx.alloc != nil) {
            ir.emit_instr(ctx.alloc, ctx.current_block, instr);
        }

        ret dst;
    }

    # same size or no conversion needed
    ret src;
}

# lower_addr: lower an address-of expression (?).
# ---
# ctx:  lowering context
# node: address-of expression node
# ret:  IRValue with result (address)
pub fun lower_addr(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val operand_node: *ast.Node = node.get_child(0);

    # lower operand as lvalue to get its address
    val addr: ir.IRValue = lower_lvalue(ctx, operand_node);

    # emit LEA to get address into a register
    val dst: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);
    emit_lea(ctx, dst, addr);

    ret dst;
}

# lower_deref: lower a dereference expression (@).
# ---
# ctx:  lowering context
# node: dereference expression node
# ret:  IRValue with result
pub fun lower_deref(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val ptr_node: *ast.Node = node.get_child(0);

    # lower pointer expression
    var ptr: ir.IRValue = lower_expr(ctx, ptr_node);
    ptr = ensure_in_reg(ctx, ptr, ctx.ptr_size);

    # create memory operand for dereferencing
    var mem: ir.IRValue;
    mem.kind = ir.val_mem();
    mem.base_reg = ptr.reg;
    mem.offset = 0;
    mem.size = ctx.ptr_size;  # TODO: get size from pointed-to type
    mem.reg = 0;
    mem.imm = 0;
    mem.index_reg = -1;
    mem.scale = 1;
    mem.label = nil;

    ret mem;
}

# lower_array_lit: lower an array literal expression.
# ---
# ctx:  lowering context
# node: array literal node
# ret:  IRValue with address of array
pub fun lower_array_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val elements: *ast.List = node.get_list();
    if (elements == nil || elements.count == 0) {
        ret none_val;
    }

    # TODO: get element size from type
    val elem_size: usize = ctx.ptr_size;
    val total_size: usize = elem_size * elements.count::usize;

    # allocate stack space
    val offset: i32 = add_local_var(ctx, nil, total_size);
    val base_addr: ir.IRValue = frame_mem(ctx, offset, total_size);

    # initialize each element
    var i: i32 = 0;
    for (i < elements.count) {
        val elem_node: *ast.Node = elements.nodes[i];
        var elem_val: ir.IRValue = lower_expr(ctx, elem_node);
        elem_val = ensure_in_reg(ctx, elem_val, elem_size);

        # compute element address
        var elem_addr: ir.IRValue;
        elem_addr.kind = ir.val_mem();
        elem_addr.base_reg = sysv64.RBP;
        elem_addr.offset = offset::i64 + (i::i64 * elem_size::i64);
        elem_addr.size = elem_size;
        elem_addr.reg = 0;
        elem_addr.imm = 0;
        elem_addr.index_reg = -1;
        elem_addr.scale = 1;
        elem_addr.label = nil;

        emit_store(ctx, elem_addr, elem_val);

        i = i + 1;
    }

    # return address of array
    val dst: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);
    emit_lea(ctx, dst, base_addr);

    ret dst;
}

# lower_struct_lit: lower a struct literal expression.
# ---
# ctx:  lowering context
# node: struct literal node
# ret:  IRValue with address of struct
pub fun lower_struct_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    # TODO: implement struct literal lowering
    # - get struct type and size
    # - allocate stack space
    # - initialize each field

    ret none_val;
}

# --- lvalue lowering ---

# lower_lvalue: lower an expression as an lvalue (for assignment targets).
# ---
# ctx:  lowering context
# node: expression AST node
# ret:  IRValue with address
pub fun lower_lvalue(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    var none_val: ir.IRValue;
    none_val.kind = ir.val_none();

    if (ctx == nil || node == nil) {
        ret none_val;
    }

    val kind: ast.NodeKind = node.kind;

    # identifier
    if (kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.get_name();

        # check local variables
        val lv: *LocalVar = find_local_var(ctx, name);
        if (lv != nil) {
            ret frame_mem(ctx, lv.offset, lv.size);
        }

        # global variable - return label
        ret ir.make_label(name);
    }

    # field access
    if (kind == ast.NODE_EXPR_FIELD) {
        val base_node: *ast.Node = node.get_child(0);
        val field_name: str = node.get_name();

        # lower base as lvalue
        var base_addr: ir.IRValue = lower_lvalue(ctx, base_node);
        base_addr = ensure_in_reg(ctx, base_addr, ctx.ptr_size);

        # TODO: look up field offset
        val field_offset: i64 = 0;
        val field_size: usize = ctx.ptr_size;

        var mem: ir.IRValue;
        mem.kind = ir.val_mem();
        mem.base_reg = base_addr.reg;
        mem.offset = field_offset;
        mem.size = field_size;
        mem.reg = 0;
        mem.imm = 0;
        mem.index_reg = -1;
        mem.scale = 1;
        mem.label = nil;

        ret mem;
    }

    # index expression
    if (kind == ast.NODE_EXPR_INDEX) {
        val base_node: *ast.Node = node.get_child(0);
        val index_node: *ast.Node = node.get_child(1);

        var base: ir.IRValue = lower_lvalue(ctx, base_node);
        base = ensure_in_reg(ctx, base, ctx.ptr_size);

        var idx: ir.IRValue = lower_expr(ctx, index_node);
        idx = ensure_in_reg(ctx, idx, ctx.ptr_size);

        val elem_size: usize = ctx.ptr_size;  # TODO: get from type

        var mem: ir.IRValue;
        mem.kind = ir.val_mem();
        mem.base_reg = base.reg;
        mem.index_reg = idx.reg;
        mem.scale = elem_size::i32;
        mem.offset = 0;
        mem.size = elem_size;
        mem.reg = 0;
        mem.imm = 0;
        mem.label = nil;

        ret mem;
    }

    # dereference
    if (kind == ast.NODE_EXPR_DEREF) {
        val ptr_node: *ast.Node = node.get_child(0);

        var ptr: ir.IRValue = lower_expr(ctx, ptr_node);
        ptr = ensure_in_reg(ctx, ptr, ctx.ptr_size);

        var mem: ir.IRValue;
        mem.kind = ir.val_mem();
        mem.base_reg = ptr.reg;
        mem.offset = 0;
        mem.size = ctx.ptr_size;
        mem.reg = 0;
        mem.imm = 0;
        mem.index_reg = -1;
        mem.scale = 1;
        mem.label = nil;

        ret mem;
    }

    ret none_val;
}

# --- statement lowering ---

# lower_stmt: lower a statement to IR.
# ---
# ctx:  lowering context
# node: statement AST node
# ret:  none
pub fun lower_stmt(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val kind: ast.NodeKind = node.kind;

    # block statement
    if (kind == ast.NODE_STMT_BLOCK) {
        lower_block(ctx, node);
        ret;
    }

    # expression statement
    if (kind == ast.NODE_STMT_EXPR) {
        val expr: *ast.Node = node.get_child(0);
        lower_expr(ctx, expr);  # discard result
        ret;
    }

    # local val declaration
    if (kind == ast.NODE_DECL_VAL) {
        lower_local_decl(ctx, node, false);
        ret;
    }

    # local var declaration
    if (kind == ast.NODE_DECL_VAR) {
        lower_local_decl(ctx, node, true);
        ret;
    }

    # return statement
    if (kind == ast.NODE_STMT_RET) {
        lower_return(ctx, node);
        ret;
    }

    # if statement
    if (kind == ast.NODE_STMT_IF) {
        lower_if(ctx, node);
        ret;
    }

    # for statement
    if (kind == ast.NODE_STMT_FOR) {
        lower_for(ctx, node);
        ret;
    }

    # break statement
    if (kind == ast.NODE_STMT_BRK) {
        lower_break(ctx);
        ret;
    }

    # continue statement
    if (kind == ast.NODE_STMT_CNT) {
        lower_continue(ctx);
        ret;
    }

    # defer statement
    if (kind == ast.NODE_STMT_FIN) {
        lower_defer(ctx, node);
        ret;
    }

    # inline assembly
    if (kind == ast.NODE_STMT_MASM) {
        lower_inline_asm(ctx, node);
        ret;
    }
}

# lower_block: lower a block statement.
# ---
# ctx:  lowering context
# node: block node
# ret:  none
pub fun lower_block(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val stmts: *ast.List = node.get_list();
    if (stmts == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < stmts.count) {
        val stmt: *ast.Node = stmts.nodes[i];
        lower_stmt(ctx, stmt);
        i = i + 1;
    }
}

# lower_local_decl: lower a local variable declaration.
# ---
# ctx:     lowering context
# node:    declaration node
# mutable: true for var, false for val
# ret:     none
pub fun lower_local_decl(ctx: *LowerContext, node: *ast.Node, mutable: bool) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val name: str = node.get_name();
    val init_node: *ast.Node = node.extra::*ast.Node;

    # get size from type, defaulting to pointer size
    var size: usize = ctx.ptr_size;
    if (node.ty != nil) {
        size = type_size(node.ty, ctx.ptr_size);
    }
    if (size == 0) {
        size = ctx.ptr_size;
    }

    # allocate stack space
    val offset: i32 = add_local_var(ctx, name, size);
    val addr: ir.IRValue = frame_mem(ctx, offset, size);

    # lower initializer if present
    if (init_node != nil) {
        # check if this is a large aggregate
        if (type_is_large_aggregate(node.ty, ctx.ptr_size)) {
            # aggregate initialization - copy from initializer address
            var init_addr: ir.IRValue = lower_expr(ctx, init_node);
            init_addr = ensure_in_reg(ctx, init_addr, ctx.ptr_size);
            emit_aggregate_copy(ctx, addr, init_addr, size);
        } or {
            # scalar initialization
            var init_val: ir.IRValue = lower_expr(ctx, init_node);
            init_val = ensure_in_reg(ctx, init_val, size);
            emit_store(ctx, addr, init_val);
        }
    }
}

# lower_return: lower a return statement.
# ---
# ctx:  lowering context
# node: return node
# ret:  none
pub fun lower_return(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # emit all deferred statements
    emit_deferred_from(ctx, 0);

    val expr: *ast.Node = node.get_child(0);

    var ret_val: ir.IRValue;
    ret_val.kind = ir.val_none();

    if (expr != nil) {
        ret_val = lower_expr(ctx, expr);
        ret_val = ensure_in_reg(ctx, ret_val, ctx.ptr_size);

        # move return value to RAX
        emit_mov(ctx, ir.make_reg(sysv64.RAX, ctx.ptr_size), ret_val);
    }

    emit_ret(ctx, ret_val);
}

# lower_if: lower an if statement.
# ---
# ctx:  lowering context
# node: if node
# ret:  none
pub fun lower_if(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # children: condition, then-body, else-body (optional)
    val cond_node: *ast.Node = node.get_child(0);
    val then_node: *ast.Node = node.get_child(1);
    val else_node: *ast.Node = node.get_child(2);

    val else_label: str = new_label(ctx, "else");
    val end_label: str = new_label(ctx, "endif");

    # lower condition
    var cond: ir.IRValue = lower_expr(ctx, cond_node);
    cond = ensure_in_reg(ctx, cond, ctx.ptr_size);

    # test condition
    emit_cmp(ctx, cond, ir.make_imm(0, ctx.ptr_size));

    # jump to else if condition is false
    if (else_node != nil) {
        emit_jcc(ctx, 0, else_label);  # JE
    } or {
        emit_jcc(ctx, 0, end_label);   # JE
    }

    # lower then branch
    lower_stmt(ctx, then_node);

    if (else_node != nil) {
        # jump to end after then branch
        emit_jmp(ctx, end_label);

        # else branch
        emit_label(ctx, else_label);
        lower_stmt(ctx, else_node);
    }

    emit_label(ctx, end_label);
}

# lower_for: lower a for loop.
# ---
# ctx:  lowering context
# node: for node
# ret:  none
pub fun lower_for(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val cond_node: *ast.Node = node.get_child(0);
    val body_node: *ast.Node = node.get_child(1);

    val start_label: str = new_label(ctx, "for");
    val end_label: str = new_label(ctx, "endfor");

    # save loop labels for break/continue
    val prev_start: str = ctx.loop_start_label;
    val prev_end: str = ctx.loop_end_label;
    ctx.loop_start_label = start_label;
    ctx.loop_end_label = end_label;

    # push defer mark for loop
    push_loop_defer_mark(ctx);

    # loop start
    emit_label(ctx, start_label);

    # condition (if present)
    if (cond_node != nil) {
        var cond: ir.IRValue = lower_expr(ctx, cond_node);
        cond = ensure_in_reg(ctx, cond, ctx.ptr_size);

        emit_cmp(ctx, cond, ir.make_imm(0, ctx.ptr_size));
        emit_jcc(ctx, 0, end_label);  # JE - exit if false
    }

    # loop body
    lower_stmt(ctx, body_node);

    # jump back to start
    emit_jmp(ctx, start_label);

    # loop end
    emit_label(ctx, end_label);

    # pop defer mark
    pop_loop_defer_mark(ctx);

    # restore loop labels
    ctx.loop_start_label = prev_start;
    ctx.loop_end_label = prev_end;
}

# lower_break: lower a break statement.
# ---
# ctx: lowering context
# ret: none
pub fun lower_break(ctx: *LowerContext) {
    if (ctx == nil || ctx.loop_end_label == nil) {
        ret;
    }

    # emit deferred statements for current loop
    val mark: i32 = get_current_loop_defer_mark(ctx);
    emit_deferred_from(ctx, mark);

    # jump to loop end
    emit_jmp(ctx, ctx.loop_end_label);
}

# lower_continue: lower a continue statement.
# ---
# ctx: lowering context
# ret: none
pub fun lower_continue(ctx: *LowerContext) {
    if (ctx == nil || ctx.loop_start_label == nil) {
        ret;
    }

    # emit deferred statements for current loop
    val mark: i32 = get_current_loop_defer_mark(ctx);
    emit_deferred_from(ctx, mark);

    # jump to loop start
    emit_jmp(ctx, ctx.loop_start_label);
}

# lower_defer: lower a defer statement.
# ---
# ctx:  lowering context
# node: defer node
# ret:  none
pub fun lower_defer(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # get the statement to defer (first child)
    val stmt: *ast.Node = node.get_child(0);
    if (stmt != nil) {
        push_deferred(ctx, stmt);
    }
}

# lower_inline_asm: lower an inline assembly block.
# ---
# ctx:  lowering context
# node: asm node
# ret:  none
pub fun lower_inline_asm(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.m == nil || ctx.text == nil) {
        ret;
    }

    # get asm content from node.data
    val content: str = node.data::str;
    if (content == nil) {
        ret;
    }

    # check for ISA-specific block: "x86_64 { ... }"
    # the parser stores the full content including any ISA prefix
    var asm_content: str = content;
    var i: usize = 0;

    # skip leading whitespace
    for (content[i] == ' ' || content[i] == '\t' || content[i] == '\n' || content[i] == '\r') {
        i = i + 1;
    }

    # check for "x86_64" prefix
    if (content[i] == 'x' && content[i+1] == '8' && content[i+2] == '6' &&
        content[i+3] == '_' && content[i+4] == '6' && content[i+5] == '4') {
        i = i + 6;

        # skip whitespace
        for (content[i] == ' ' || content[i] == '\t' || content[i] == '\n' || content[i] == '\r') {
            i = i + 1;
        }

        # expect '{'
        if (content[i] == '{') {
            i = i + 1;

            # find matching '}'
            var depth: i32 = 1;
            val start: usize = i;
            for (depth > 0 && content[i] != 0) {
                if (content[i] == '{') {
                    depth = depth + 1;
                }
                if (content[i] == '}') {
                    depth = depth - 1;
                }
                if (depth > 0) {
                    i = i + 1;
                }
            }

            # extract inner content
            val inner_len: usize = i - start;
            if (inner_len > 0) {
                val alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](inner_len + 1);
                if (alloc_res.is_ok()) {
                    val buf: *u8 = alloc_res.unwrap_ok();
                    var j: usize = 0;
                    for (j < inner_len) {
                        buf[j] = content[start + j];
                        j = j + 1;
                    }
                    buf[inner_len] = 0;
                    asm_content = buf::str;
                }
            }
        }
    }

    # parse and emit the x86_64 asm
    x86asm.parse_x86_64_asm(asm_content, ctx.text, ctx.m, ctx.alloc);
}

# --- function lowering ---

# lower_function: lower a function declaration to IR.
# ---
# ctx:  lowering context
# node: function AST node
# ret:  Ok(*IRFunction) on success, Err(str) on failure
pub fun lower_function(ctx: *LowerContext, node: *ast.Node) Result[*ir.IRFunction, str] {
    print.eprintln("[lower_function] entered");

    if (ctx == nil) {
        ret err[*ir.IRFunction, str]("context is nil");
    }
    print.eprintln("[lower_function] ctx ok");

    if (node == nil) {
        ret err[*ir.IRFunction, str]("node is nil");
    }
    print.eprintln("[lower_function] node ok");

    # reset per-function state
    print.eprintln("[lower_function] calling reset_function_state...");
    reset_function_state(ctx);
    print.eprintln("[lower_function] reset_function_state done");

    print.eprintln("[lower_function] calling node.get_name()...");
    val name: str = node.get_name();
    print.eprintln("[lower_function] get_name returned");
    if (name == nil) {
        ret err[*ir.IRFunction, str]("function has no name");
    }
    print.eprint("[lower_function] name = ");
    print.eprintln(name);

    # create IR function
    print.eprintln("[lower_function] creating IR function...");
    val fn_res: Result[*ir.IRFunction, str] = ir.create_function(ctx.alloc, name);
    print.eprintln("[lower_function] ir.create_function returned");
    if (fn_res.is_err()) {
        print.eprintln("[lower_function] ir.create_function failed");
        ret fn_res;
    }
    print.eprintln("[lower_function] ir.create_function succeeded");

    val func: *ir.IRFunction = fn_res.unwrap_ok();
    print.eprintln("[lower_function] unwrap_ok done");
    ctx.current_fn = func;
    print.eprintln("[lower_function] ctx.current_fn assigned");

    # create entry block
    print.eprintln("[lower_function] calling new_label...");
    val entry_label: str = new_label(ctx, "entry");
    print.eprintln("[lower_function] new_label returned");
    print.eprintln("[lower_function] calling ir.create_block...");
    val block_res: Result[*ir.IRBlock, str] = ir.create_block(ctx.alloc, entry_label);
    print.eprintln("[lower_function] ir.create_block returned");
    if (block_res.is_err()) {
        print.eprintln("[lower_function] ir.create_block failed");
        ret err[*ir.IRFunction, str](block_res.unwrap_err());
    }
    print.eprintln("[lower_function] ir.create_block succeeded");

    print.eprintln("[lower_function] calling block_res.unwrap_ok()...");
    val entry_block: *ir.IRBlock = block_res.unwrap_ok();
    print.eprintln("[lower_function] entry_block obtained");
    ctx.current_block = entry_block;
    print.eprintln("[lower_function] ctx.current_block assigned");

    # add block to function
    print.eprintln("[lower_function] checking block capacity...");
    if (func.block_count >= func.block_cap) {
        print.eprintln("[lower_function] need to grow blocks array");
        var new_cap: i32 = 8;
        if (func.block_cap > 0) {
            new_cap = func.block_cap * 2;
        }

        val r: Result[**ir.IRBlock, allocator.AllocError] = ctx.alloc.resize[*ir.IRBlock](
            func.blocks, func.block_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[*ir.IRFunction, str](r.unwrap_err());
        }

        func.blocks = r.unwrap_ok();
        func.block_cap = new_cap;
        print.eprintln("[lower_function] blocks array grown");
    }

    print.eprintln("[lower_function] assigning entry_block to func.blocks...");
    func.blocks[func.block_count] = entry_block;
    print.eprintln("[lower_function] entry_block assigned");
    print.eprintln("[lower_function] incrementing block_count...");
    func.block_count = func.block_count + 1;
    print.eprintln("[lower_function] block_count incremented");

    # emit function label
    print.eprintln("[lower_function] calling emit_label...");
    emit_label(ctx, name);
    print.eprintln("[lower_function] emit_label returned");

    # create MASM symbol for function
    print.eprintln("[lower_function] creating MASM symbol...");
    if (ctx.m != nil) {
        print.eprintln("[lower_function] ctx.m is not nil");
        print.eprintln("[lower_function] calling sym.create...");
        val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, name);
        print.eprintln("[lower_function] sym.create returned");
        if (sym_res.is_ok()) {
            print.eprintln("[lower_function] sym_res is ok, unwrapping...");
            val s: *sym.Symbol = sym_res.unwrap_ok();
            print.eprintln("[lower_function] setting binding directly...");
            # inline binding/type assignment to avoid struct copy bugs
            s.binding.tag = sym.BIND_GLOBAL;
            print.eprintln("[lower_function] setting type directly...");
            s.sym_type.tag = sym.SYM_FUNC;
            print.eprintln("[lower_function] adding symbol...");
            # offset will be set when we emit to section
            masm.add_symbol(ctx.m, s);
            print.eprintln("[lower_function] symbol added");
        }
    } or {
        print.eprintln("[lower_function] ctx.m is nil, skipping symbol creation");
    }
    print.eprintln("[lower_function] MASM symbol created");

    # check if this is the entry point (_start)
    print.eprintln("[lower_function] checking is_entry...");
    val is_entry: bool = name != nil && name.equals("_start");

    print.eprintln("[lower_function] is_entry check done");

    # determine function return type and whether we need sret
    print.eprintln("[lower_function] checking return type...");
    print.eprintln("[lower_function] checking node.ty...");
    if (node.ty != nil) {
        print.eprintln("[lower_function] node.ty is not nil");
        print.eprintln("[lower_function] checking node.ty.kind...");
        if (node.ty.kind == ty.TY_FUN) {
            print.eprintln("[lower_function] node.ty.kind is TY_FUN");
            print.eprintln("[lower_function] checking node.ty.ret_type...");
            if (node.ty.ret_type != nil) {
                print.eprintln("[lower_function] node.ty.ret_type is not nil");
                ctx.fn_ret_type = node.ty.ret_type;
                print.eprintln("[lower_function] checking large aggregate...");
                if (type_is_large_aggregate(ctx.fn_ret_type, ctx.ptr_size)) {
                    ctx.fn_has_sret = true;
                }
                print.eprintln("[lower_function] large aggregate check done");
            }
        }
    } or {
        print.eprintln("[lower_function] node.ty is nil");
    }
    print.eprintln("[lower_function] return type check complete");

    # emit stack frame setup placeholder (will be patched after we know frame size)
    # for entry point, no frame setup
    print.eprintln("[lower_function] getting frame_instr_idx...");
    val frame_instr_idx: i32 = ctx.current_block.instr_count;
    print.eprintln("[lower_function] frame_instr_idx obtained");
    if (!is_entry) {
        print.eprintln("[lower_function] calling emit_frame_setup...");
        emit_frame_setup(ctx, 0);  # placeholder with size 0
        print.eprintln("[lower_function] emit_frame_setup done");
    }

    # track argument register usage
    print.eprintln("[lower_function] initializing arg indices...");
    var int_arg_idx: i32 = 0;
    var float_arg_idx: i32 = 0;
    print.eprintln("[lower_function] arg indices initialized");

    # handle hidden sret pointer for large aggregate returns
    print.eprintln("[lower_function] checking sret...");
    print.eprintln("[lower_function] is_entry and fn_has_sret checked");
    if (!is_entry && ctx.fn_has_sret) {
        print.eprintln("[lower_function] has sret, processing...");
        # sret pointer is passed in first integer arg register
        ctx.stack_offset = ctx.stack_offset - ctx.ptr_size::i32;
        ctx.sret_offset = ctx.stack_offset;
        int_arg_idx = 1;  # skip first arg reg since it holds sret

        # store sret pointer to stack slot
        val sret_reg: i32 = sysv64.get_arg_reg(0);
        val sret_addr: ir.IRValue = frame_mem(ctx, ctx.sret_offset, ctx.ptr_size);
        emit_store(ctx, sret_addr, ir.make_reg(sret_reg, ctx.ptr_size));
        print.eprintln("[lower_function] sret processed");
    }
    print.eprintln("[lower_function] sret check complete");

    # lower parameters - get param list from AST
    print.eprintln("[lower_function] getting params from node.extra...");
    # params are stored in node.extra (not node.data) by the parser
    print.eprintln("[lower_function] checking if node.extra is nil...");
    if (node.extra == nil) {
        print.eprintln("[lower_function] node.extra is nil, skipping params");
    } or {
        print.eprintln("[lower_function] node.extra is not nil");
    }
    val params: *ast.List = node.extra::*ast.List;
    print.eprintln("[lower_function] params cast done");
    print.eprintln("[lower_function] checking is_entry and params...");
    if (!is_entry && params != nil) {
        print.eprintln("[lower_function] processing params loop");
        var i: i32 = 0;
        for (i < params.count) {
            print.eprintln("[lower_function] processing param");
            val param: *ast.Node = params.nodes[i];
            if (param == nil) {
                i = i + 1;
                cnt;
            }

            val param_name: str = param.get_name();
            val param_type: *ty.Type = param.ty;

            # determine parameter size
            var param_size: usize = ctx.ptr_size;
            if (param_type != nil) {
                param_size = type_size(param_type, ctx.ptr_size);
            }
            if (param_size == 0) {
                param_size = ctx.ptr_size;
            }

            # check if parameter is float
            val is_float: bool = type_is_float(param_type);

            # check if parameter is large aggregate (passed by pointer)
            val is_large_agg: bool = type_is_large_aggregate(param_type, ctx.ptr_size);

            # allocate stack space for the parameter
            val offset: i32 = add_local_var(ctx, param_name, param_size);
            val param_addr: ir.IRValue = frame_mem(ctx, offset, param_size);

            # copy parameter from register or stack to local slot
            if (is_large_agg) {
                # large aggregate: pointer is passed in register, copy data
                if (int_arg_idx < 6) {
                    val ptr_reg: i32 = sysv64.get_arg_reg(int_arg_idx);
                    int_arg_idx = int_arg_idx + 1;

                    # copy aggregate from pointer to local slot
                    val src_ptr: ir.IRValue = ir.make_reg(ptr_reg, ctx.ptr_size);
                    emit_aggregate_copy(ctx, param_addr, src_ptr, param_size);
                }
            } or (is_float && float_arg_idx < 8) {
                # float in XMM register
                val float_reg: i32 = sysv64.get_float_arg_reg(float_arg_idx);
                float_arg_idx = float_arg_idx + 1;

                emit_store(ctx, param_addr, ir.make_reg(float_reg, param_size));
            } or (int_arg_idx < 6) {
                # integer/pointer in GPR
                val int_reg: i32 = sysv64.get_arg_reg(int_arg_idx);
                int_arg_idx = int_arg_idx + 1;

                emit_store(ctx, param_addr, ir.make_reg(int_reg, param_size));
            } or {
                # parameter on stack - copy from caller's stack frame
                # stack params are at positive offsets from RBP (after return address and saved RBP)
                # offset = 16 + (stack_param_index * 8)
                # TODO: implement stack parameter handling
            }

            i = i + 1;
        }

        print.eprintln("[lower_function] params loop complete");
        func.param_count = params.count;
        print.eprintln("[lower_function] param_count set");
    }
    print.eprintln("[lower_function] params processing complete");

    # lower function body
    print.eprintln("[lower_function] getting function body...");
    val body: *ast.Node = node.children;
    print.eprintln("[lower_function] body obtained");
    if (body != nil) {
        print.eprintln("[lower_function] lowering body...");
        lower_stmt(ctx, body);
        print.eprintln("[lower_function] body lowered");
    } or {
        print.eprintln("[lower_function] body is nil, skipping");
    }

    # emit remaining deferred statements
    print.eprintln("[lower_function] emitting deferred stmts...");
    emit_deferred_from(ctx, 0);
    print.eprintln("[lower_function] deferred stmts emitted");

    # emit implicit return if no explicit return at end
    print.eprintln("[lower_function] creating none_val...");
    var none_val: ir.IRValue;
    print.eprintln("[lower_function] setting none_val.kind...");
    none_val.kind = ir.val_none();
    print.eprintln("[lower_function] calling emit_ret...");
    emit_ret(ctx, none_val);
    print.eprintln("[lower_function] emit_ret done");

    # record frame size and align to 16 bytes
    print.eprintln("[lower_function] calculating frame size...");
    var frame_size: usize = 0;
    if (ctx.stack_offset < 0) {
        frame_size = (-ctx.stack_offset)::usize;
    }
    print.eprintln("[lower_function] frame size calculated");

    # align frame size to stack alignment (16 bytes for sysv64)
    print.eprintln("[lower_function] aligning frame size...");
    if (frame_size > 0 && frame_size % 16 != 0) {
        frame_size = (frame_size + 15) & ~15::usize;
    }
    print.eprintln("[lower_function] frame size aligned");

    print.eprintln("[lower_function] setting func.local_size...");
    func.local_size = frame_size;
    print.eprintln("[lower_function] func.local_size set");

    # patch stack frame size in the frame setup instruction
    print.eprintln("[lower_function] patching frame setup instruction...");
    if (!is_entry && ctx.current_block != nil && frame_instr_idx < ctx.current_block.instr_count) {
        print.eprintln("[lower_function] patching instr dst.imm...");
        ctx.current_block.instrs[frame_instr_idx].dst.imm = frame_size::i64;
        print.eprintln("[lower_function] instr patched");
    }
    print.eprintln("[lower_function] frame setup patched");

    print.eprintln("[lower_function] returning func...");
    # workaround: create result in local variable to avoid return value corruption
    # fully initialize all fields to avoid garbage
    var result: Result[*ir.IRFunction, str];
    result.tag = true;  # is_ok
    result.value.ok = func;
    result.value.err = nil;  # zero out the err side too
    print.eprintln("[lower_function] result created, returning...");
    ret result;
}

# --- global variable lowering ---

# lower_global_var: lower a global variable declaration.
# ---
# ctx:  lowering context
# node: variable declaration node
# ret:  none
pub fun lower_global_var(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        ret;
    }

    val init_node: *ast.Node = node.extra::*ast.Node;

    # determine section (.data for mutable, .rodata for immutable)
    var sec_kind: section.SectionKind;
    var sec_name: str;

    if (node.kind == ast.NODE_DECL_VAL) {
        sec_kind = section.section_rodata();
        sec_name = ".rodata";
    } or {
        sec_kind = section.section_data();
        sec_name = ".data";
    }

    val sec_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, sec_name, sec_kind);
    if (sec_res.is_err()) {
        ret;
    }

    val sec: *section.Section = sec_res.unwrap_ok();
    val offset: usize = sec.size;

    # create symbol
    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, name);
    if (sym_res.is_ok()) {
        val s: *sym.Symbol = sym_res.unwrap_ok();
        sym.set_binding(s, sym.bind_global());
        sym.set_type(s, sym.sym_object());
        s.section = sec;
        s.offset = offset;
        masm.add_symbol(ctx.m, s);
    }

    # emit initializer data
    if (init_node != nil) {
        # TODO: handle different literal types
        if (init_node.kind == ast.NODE_EXPR_LIT_INT) {
            val int_val: i64 = init_node.get_int_value();
            section.emit_u64(ctx.alloc, sec, int_val::u64);
        } or (init_node.kind == ast.NODE_EXPR_LIT_STR) {
            val str_val: str = init_node.get_name();
            if (str_val != nil) {
                var i: usize = 0;
                for (i < str_val.len()) {
                    section.emit_byte(ctx.alloc, sec, str_val[i]);
                    i = i + 1;
                }
                section.emit_byte(ctx.alloc, sec, 0);
            }
        } or {
            # zero-initialize
            section.emit_u64(ctx.alloc, sec, 0);
        }
    } or {
        # zero-initialize
        section.emit_u64(ctx.alloc, sec, 0);
    }
}

# --- module lowering ---

# lower_decls_into: lower declarations from an AST into an existing lowering context.
# ---
# ctx:     lowering context (with m and text already set)
# root:    program AST node
# symbols: symbol table for this module
# ret:     Ok(true) on success, Err(str) on failure
pub fun lower_decls_into(ctx: *LowerContext, root: *ast.Node, symbols: *symbol.Table) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }
    if (root == nil) {
        ret err[bool, str]("root is nil");
    }
    if (symbols == nil) {
        ret ok[bool, str](true);
    }

    # temporarily update symbols for this module
    val saved_symbols: *symbol.Table = ctx.symbols;
    ctx.symbols = symbols;

    # iterate top-level declarations
    val decls: *ast.List = root.get_list();
    if (decls == nil) {
        ctx.symbols = saved_symbols;
        ret ok[bool, str](true);
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val decl: *ast.Node = decls.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # lower functions
        if (kind == ast.NODE_DECL_FUN) {
            val fn_res: Result[*ir.IRFunction, str] = lower_function(ctx, decl);
            if (fn_res.is_err()) {
                # TODO: collect errors instead of failing
            } or {
                # store IR function for later isel
                add_ir_function(ctx, fn_res.unwrap_ok());
            }
        }
        # lower global values
        or (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
            lower_global_var(ctx, decl);
        }
        # handle pub wrapper
        or (kind == ast.NODE_DECL_PUB) {
            val inner: *ast.Node = decl.get_child(0);
            if (inner != nil) {
                if (inner.kind == ast.NODE_DECL_FUN) {
                    val fn_res: Result[*ir.IRFunction, str] = lower_function(ctx, inner);
                    if (fn_res.is_ok()) {
                        add_ir_function(ctx, fn_res.unwrap_ok());
                    }
                } or (inner.kind == ast.NODE_DECL_VAL || inner.kind == ast.NODE_DECL_VAR) {
                    lower_global_var(ctx, inner);
                }
            }
        }
        # skip type declarations, use statements, tests, etc.

        i = i + 1;
    }

    ctx.symbols = saved_symbols;
    ret ok[bool, str](true);
}

# lower_module: lower an entire module AST to a MASM context.
# ---
# root:    program AST node
# symbols: symbol table
# types:   type context
# alloc:   allocator
# tgt:     target configuration
# ret:     Ok(*Masm) on success, Err(str) on failure
pub fun lower_module(root: *ast.Node, symbols: *symbol.Table, types: *ty.TypeContext, alloc: *allocator.Allocator, tgt: target.Target) Result[*masm.Masm, str] {
    if (root == nil) {
        ret err[*masm.Masm, str]("root is nil");
    }

    if (symbols == nil) {
        ret err[*masm.Masm, str]("symbol table is nil");
    }

    if (types == nil) {
        ret err[*masm.Masm, str]("type registry is nil");
    }

    if (alloc == nil) {
        ret err[*masm.Masm, str]("allocator is nil");
    }

    # create MASM context
    val masm_res: Result[masm.Masm, str] = masm.create(alloc, tgt);
    if (masm_res.is_err()) {
        ret err[*masm.Masm, str](masm_res.unwrap_err());
    }

    # allocate pointer to masm context
    val m_alloc_res: Result[*masm.Masm, allocator.AllocError] = alloc.alloc[masm.Masm](1);
    if (m_alloc_res.is_err()) {
        ret err[*masm.Masm, str](m_alloc_res.unwrap_err());
    }

    val m: *masm.Masm = m_alloc_res.unwrap_ok();
    @m = masm_res.unwrap_ok();

    # create lowering context
    var ctx: LowerContext = init(alloc, symbols, types, tgt);
    ctx.m = m;

    # create .text section
    val sec_kind: section.SectionKind = section.section_text();
    val text_res: Result[*section.Section, str] = masm.get_or_create_section(
        m, ".text", sec_kind
    );
    if (text_res.is_err()) {
        ret err[*masm.Masm, str](text_res.unwrap_err());
    }
    ctx.text = text_res.unwrap_ok();

    # lower declarations from main module
    val lower_res: Result[bool, str] = lower_decls_into(?ctx, root, symbols);
    if (lower_res.is_err()) {
        ret err[*masm.Masm, str](lower_res.unwrap_err());
    }

    # run instruction selection on all collected IR functions
    if (ctx.ir_func_count > 0) {
        val isel_res: Result[bool, str] = isel.run_isel(m, ctx.ir_funcs, ctx.ir_func_count, alloc);
        if (isel_res.is_err()) {
            ret err[*masm.Masm, str](isel_res.unwrap_err());
        }
    }

    ret ok[*masm.Masm, str](m);
}

# lower_all_modules: lower main module plus all imported modules.
# ---
# root:       main module AST
# symbols:    main module symbol table
# types:      type context
# alloc:      allocator
# tgt:        target configuration
# loaded:     array of loaded modules (from sema.get_loaded_modules)
# load_count: number of loaded modules
# ret:        Ok(*Masm) on success, Err(str) on failure
pub fun lower_all_modules(root: *ast.Node, symbols: *symbol.Table, types: *ty.TypeContext, alloc: *allocator.Allocator, tgt: target.Target, loaded: *sema.LoadedModule, load_count: i32) Result[*masm.Masm, str] {
    if (root == nil) {
        ret err[*masm.Masm, str]("root is nil");
    }

    if (symbols == nil) {
        ret err[*masm.Masm, str]("symbol table is nil");
    }

    if (types == nil) {
        ret err[*masm.Masm, str]("type registry is nil");
    }

    if (alloc == nil) {
        ret err[*masm.Masm, str]("allocator is nil");
    }

    # allocate masm context directly and initialize fields
    # (avoid struct copy via @m = result.unwrap_ok() which has a codegen bug)
    val m_alloc_res: Result[*masm.Masm, allocator.AllocError] = alloc.zalloc[masm.Masm](1);
    if (m_alloc_res.is_err()) {
        ret err[*masm.Masm, str](m_alloc_res.unwrap_err());
    }

    val m: *masm.Masm = m_alloc_res.unwrap_ok();

    # initialize masm fields directly instead of copying from result
    m.alloc = alloc;
    m.tgt = tgt;
    m.sections = nil;
    m.section_count = 0;
    m.section_cap = 0;
    m.symbols = nil;
    m.symbol_count = 0;
    m.symbol_cap = 0;

    # create lowering context
    var ctx: LowerContext = init(alloc, symbols, types, tgt);
    ctx.m = m;

    # create .text section
    val sec_kind: section.SectionKind = section.section_text();
    val text_res: Result[*section.Section, str] = masm.get_or_create_section(
        m, ".text", sec_kind
    );
    if (text_res.is_err()) {
        ret err[*masm.Masm, str](text_res.unwrap_err());
    }
    ctx.text = text_res.unwrap_ok();

    # lower main module first
    val main_res: Result[bool, str] = lower_decls_into(?ctx, root, symbols);
    if (main_res.is_err()) {
        ret err[*masm.Masm, str](main_res.unwrap_err());
    }

    # lower all imported modules
    if (loaded != nil && load_count > 0) {
        var i: i32 = 0;
        for (i < load_count) {
            val mod_ast: *ast.Node = loaded[i].ast;
            val mod_table: *symbol.Table = loaded[i].table;
            if (mod_ast != nil && mod_table != nil) {
                val mod_res: Result[bool, str] = lower_decls_into(?ctx, mod_ast, mod_table);
                if (mod_res.is_err()) {
                    # log but continue - don't fail entire build for one module
                }
            }
            i = i + 1;
        }
    }

    # run instruction selection on all collected IR functions
    if (ctx.ir_func_count > 0) {
        val isel_res: Result[bool, str] = isel.run_isel(m, ctx.ir_funcs, ctx.ir_func_count, alloc);
        if (isel_res.is_err()) {
            ret err[*masm.Masm, str](isel_res.unwrap_err());
        }
    }

    ret ok[*masm.Masm, str](m);
}
