use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use allocator: std.allocator;
use print: std.print;

use ast:     mach.compiler.ast;
use isel:    mach.compiler.masm.isel;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use token:  mach.compiler.token;

use ir:      mach.compiler.masm.ir;
use masm:    mach.compiler.masm.masm;
use operand: mach.compiler.masm.operand;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;
use target:  mach.compiler.masm.target;
use abi:     mach.compiler.masm.abi.spec;
use sysv64:  mach.compiler.masm.abi.sysv64;
use sema:    mach.compiler.sema;
use x86asm:  mach.compiler.masm.isa.x86asm;

# mach.compiler.masm.lower: AST to IR lowering.
# ---
# converts the typed AST into MASM intermediate representation.

# LocalVar: tracking info for a local variable.
# ---
# name:   variable name
# offset: stack offset from frame pointer (negative for locals)
# size:   size in bytes
pub rec LocalVar {
    name:   str;
    offset: i32;
    size:   usize;
}

# LowerContext: context for lowering AST to IR.
# ---
# alloc:            allocator for IR allocations
# symbols:          symbol table for lookups
# types:            type context
# tgt:              target configuration
# abi:              ABI specification for calling convention
# current_fn:       current function being lowered
# current_block:    current basic block
# ptr_size:         pointer size in bytes
# stack_align:      stack alignment in bytes
#
# local_vars:       array of local variables
# local_count:      number of locals
# local_cap:        allocated capacity
# stack_offset:     current stack offset (grows negative)
#
# deferred:         array of deferred statement nodes (fin)
# deferred_count:   number of deferred statements
# deferred_cap:     allocated capacity
#
# loop_defer_marks: stack of indices into deferred array at loop entry
# loop_mark_count:  number of loop marks
# loop_mark_cap:    allocated capacity
#
# loop_start_label: label for loop start (for cnt)
# loop_end_label:   label for loop end (for brk)
#
# vreg_next:        next virtual register number
# label_counter:    counter for unique labels
# str_counter:      counter for string literals
# loop_counter:     counter for loops
#
# fn_ret_type:      return type of current function
# fn_has_sret:      true if function returns aggregate via hidden pointer
# sret_offset:      stack offset of hidden sret pointer
pub rec LowerContext {
    alloc:            *allocator.Allocator;
    symbols:          *symbol.Table;
    types:            *ty.TypeContext;
    tgt:              target.Target;
    abi:              abi.ABI;
    current_fn:       *ir.IRFunction;
    current_block:    *ir.IRBlock;
    ptr_size:         usize;
    stack_align:      usize;

    local_vars:       *LocalVar;
    local_count:      i32;
    local_cap:        i32;
    stack_offset:     i32;

    deferred:         **ast.Node;
    deferred_count:   i32;
    deferred_cap:     i32;

    loop_defer_marks: *i32;
    loop_mark_count:  i32;
    loop_mark_cap:    i32;

    loop_start_label: str;
    loop_end_label:   str;

    vreg_next:        i32;
    label_counter:    i32;
    str_counter:      i32;
    loop_counter:     i32;

    fn_ret_type:      *ty.Type;
    fn_has_sret:      bool;
    sret_offset:      i32;

    # MASM context for symbol registration
    m:                *masm.Masm;

    # source text for error messages
    text:             str;
}

# init: initialize a lowering context.
# ---
# alloc:   allocator for IR allocations
# symbols: symbol table for lookups
# types:   type context
# tgt:     target configuration
# m:       masm context for symbol registration
# text:    source text for error messages
# ret:     initialized context
pub fun init(alloc: *allocator.Allocator, symbols: *symbol.Table, types: *ty.TypeContext, tgt: target.Target, m: *masm.Masm, text: str) LowerContext {
    var ctx: LowerContext;
    ctx.alloc         = alloc;
    ctx.symbols       = symbols;
    ctx.types         = types;
    ctx.tgt           = tgt;
    ctx.ptr_size      = 8;  # assume 64-bit
    ctx.stack_align   = 16; # sysv64
    ctx.current_fn    = nil;
    ctx.current_block = nil;
    ctx.local_vars    = nil;
    ctx.local_count   = 0;
    ctx.local_cap     = 0;
    ctx.stack_offset  = 0;
    ctx.deferred      = nil;
    ctx.deferred_count = 0;
    ctx.deferred_cap  = 0;
    ctx.loop_defer_marks = nil;
    ctx.loop_mark_count = 0;
    ctx.loop_mark_cap = 0;
    ctx.loop_start_label = nil;
    ctx.loop_end_label = nil;
    ctx.vreg_next     = ir.VREG_START;
    ctx.label_counter = 0;
    ctx.str_counter   = 0;
    ctx.loop_counter  = 0;
    ctx.fn_ret_type   = nil;
    ctx.fn_has_sret   = false;
    ctx.sret_offset   = 0;
    ctx.m             = m;
    ctx.text          = text;

    # initialize ABI
    ctx.abi = sysv64.get();

    ret ctx;
}

# reset_function_state: reset per-function state for a new function.
# ---
# ctx: lowering context
# ret: none
fun reset_function_state(ctx: *LowerContext) {
    if (ctx == nil) {
        ret;
    }

    # reset local variables
    ctx.local_count = 0;
    ctx.stack_offset = 0;

    # reset deferred statements
    ctx.deferred_count = 0;
    ctx.loop_mark_count = 0;

    # reset loop labels
    ctx.loop_start_label = nil;
    ctx.loop_end_label = nil;

    # reset function-specific state
    ctx.fn_ret_type = nil;
    ctx.fn_has_sret = false;
    ctx.sret_offset = 0;

    # note: we don't reset vreg_next so registers are unique across functions
}

# add_local_var: add a local variable to the context.
# ---
# ctx:   lowering context
# name:  variable name
# size:  size in bytes
# ret:   stack offset for the variable
fun add_local_var(ctx: *LowerContext, name: str, size: usize) i32 {
    if (ctx == nil || ctx.alloc == nil) {
        ret 0;
    }

    # align size to stack alignment
    var aligned_size: usize = size;
    if (aligned_size % ctx.stack_align != 0) {
        aligned_size = aligned_size + (ctx.stack_align - (aligned_size % ctx.stack_align));
    }

    # grow array if needed
    if (ctx.local_count >= ctx.local_cap) {
        var new_cap: i32 = 8;
        if (ctx.local_cap > 0) {
            new_cap = ctx.local_cap * 2;
        }

        val r: Result[*LocalVar, allocator.AllocError] = ctx.alloc.resize[LocalVar](
            ctx.local_vars, ctx.local_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret 0;
        }

        ctx.local_vars = r.unwrap_ok();
        ctx.local_cap = new_cap;
    }

    # allocate stack space (stack grows down)
    ctx.stack_offset = ctx.stack_offset - aligned_size::i32;

    # add to locals array
    val idx: i32 = ctx.local_count;
    ctx.local_vars[idx].name = name;
    ctx.local_vars[idx].offset = ctx.stack_offset;
    ctx.local_vars[idx].size = size;
    ctx.local_count = ctx.local_count + 1;

    ret ctx.stack_offset;
}

# find_local_var: find a local variable by name.
# ---
# ctx:  lowering context
# name: variable name to find
# ret:  index in local_vars array, or -1 if not found
fun find_local_var(ctx: *LowerContext, name: str) i32 {
    if (ctx == nil || ctx.local_vars == nil || name == nil) {
        ret -1;
    }

    var i: i32 = 0;
    for (i < ctx.local_count) {
        if (ctx.local_vars[i].name != nil && ctx.local_vars[i].name.equals(name)) {
            ret i;
        }
        i = i + 1;
    }

    ret -1;
}

# get_local_var_offset: get the stack offset for a local variable.
# ---
# ctx:  lowering context
# idx:  index from find_local_var
# ret:  stack offset (negative for locals)
fun get_local_var_offset(ctx: *LowerContext, idx: i32) i32 {
    if (ctx == nil || idx < 0 || idx >= ctx.local_count) {
        ret 0;
    }
    ret ctx.local_vars[idx].offset;
}

# defer_statement: add a statement to the deferred list.
# ---
# ctx:  lowering context
# stmt: statement to defer (typically a fin statement)
# ret:  none
fun defer_statement(ctx: *LowerContext, stmt: *ast.Node) {
    if (ctx == nil || ctx.alloc == nil || stmt == nil) {
        ret;
    }

    # grow array if needed
    if (ctx.deferred_count >= ctx.deferred_cap) {
        var new_cap: i32 = 8;
        if (ctx.deferred_cap > 0) {
            new_cap = ctx.deferred_cap * 2;
        }

        val r: Result[**ast.Node, allocator.AllocError] = ctx.alloc.resize[*ast.Node](
            ctx.deferred, ctx.deferred_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret;
        }

        ctx.deferred = r.unwrap_ok();
        ctx.deferred_cap = new_cap;
    }

    # add to deferred array
    ctx.deferred[ctx.deferred_count] = stmt;
    ctx.deferred_count = ctx.deferred_count + 1;
}

# emit_deferred_from: emit deferred statements from given index to current.
# ---
# ctx:        lowering context
# from_index: starting index in deferred stack
# ret:        none
pub fun emit_deferred_from(ctx: *LowerContext, from_index: i32) {
    if (ctx == nil || ctx.deferred == nil) {
        ret;
    }

    # emit in reverse order (LIFO)
    var i: i32 = ctx.deferred_count - 1;
    for (i >= from_index) {
        val node: *ast.Node = ctx.deferred[i];
        if (node != nil) {
            lower_stmt(ctx, node);
        }
        i = i - 1;
    }
}

# push_loop_defer_mark: mark current deferred stack depth when entering a loop.
# ---
# ctx: lowering context
# ret: none
pub fun push_loop_defer_mark(ctx: *LowerContext) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }

    if (ctx.loop_mark_count >= ctx.loop_mark_cap) {
        var new_cap: i32 = 8;
        if (ctx.loop_mark_cap > 0) {
            new_cap = ctx.loop_mark_cap * 2;
        }

        val r: Result[*i32, allocator.AllocError] = ctx.alloc.resize[i32](
            ctx.loop_defer_marks, ctx.loop_mark_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret;
        }

        ctx.loop_defer_marks = r.unwrap_ok();
        ctx.loop_mark_cap = new_cap;
    }

    ctx.loop_defer_marks[ctx.loop_mark_count] = ctx.deferred_count;
    ctx.loop_mark_count = ctx.loop_mark_count + 1;
}

# pop_loop_defer_mark: pop the defer mark stack when leaving a loop.
# ---
# ctx: lowering context
# ret: the deferred count at loop entry (for emit_deferred_from)
pub fun pop_loop_defer_mark(ctx: *LowerContext) i32 {
    if (ctx == nil || ctx.loop_mark_count <= 0) {
        ret 0;
    }

    ctx.loop_mark_count = ctx.loop_mark_count - 1;
    ret ctx.loop_defer_marks[ctx.loop_mark_count];
}

# new_vreg: allocate a new virtual register.
# ---
# ctx:  lowering context
# size: register size in bytes
# ret:  new virtual register number
pub fun new_vreg(ctx: *LowerContext, size: usize) i32 {
    if (ctx == nil) {
        ret 0;
    }

    val reg: i32 = ctx.vreg_next;
    ctx.vreg_next = ctx.vreg_next + 1;
    ret reg;
}

# new_label: create a new unique label.
# ---
# ctx:    lowering context
# prefix: label prefix string
# ret:    new label string
pub fun new_label(ctx: *LowerContext, prefix: str) str {
    if (ctx == nil || ctx.alloc == nil) {
        ret nil;
    }

    # create label name: prefix + counter
    # for now, use a simple numbered scheme
    ctx.label_counter = ctx.label_counter + 1;

    # allocate buffer for label name
    # format: prefix + "." + number (estimate 16 chars max for number)
    var prefix_len: usize = 0;
    if (prefix != nil) {
        prefix_len = prefix.len();
    }
    val buf_size: usize = prefix_len + 20;  # prefix + "." + number + null

    val r: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](buf_size);
    if (r.is_err()) {
        ret nil;
    }

    val buf: *u8 = r.unwrap_ok();

    # copy prefix
    var i: usize = 0;
    for (i < prefix_len) {
        buf[i] = prefix[i];
        i = i + 1;
    }

    # add "."
    if (prefix_len > 0) {
        buf[prefix_len] = '.';
        i = prefix_len + 1;
    }

    # convert counter to string (manual itoa)
    val num: i32 = ctx.label_counter;
    var n: i32 = num;
    var digits: i32 = 0;

    # count digits
    if (n == 0) {
        digits = 1;
    }
    for (n > 0) {
        digits = digits + 1;
        n = n / 10;
    }

    # write digits in reverse order
    n = num;
    var j: i32 = digits - 1;
    for (j >= 0) {
        val digit: u8 = (n % 10)::u8 + '0'::u8;
        buf[i + j::usize] = digit;
        n = n / 10;
        j = j - 1;
    }

    # add null terminator
    buf[i + digits::usize] = 0;

    ret buf::str;
}

# frame_mem: create a memory operand for a stack slot.
# ---
# ctx:    lowering context
# offset: stack offset from frame pointer
# size:   size in bytes
# ret:    memory operand as IRValue
fun frame_mem(ctx: *LowerContext, offset: i32, size: usize) ir.IRValue {
    var v: ir.IRValue;
    v.kind = ir.VAL_MEM;
    v.reg = 0;
    v.imm = 0;
    v.offset = offset::i64;
    v.base_reg = ir.RBP;
    v.index_reg = 0;
    v.scale = 1;
    v.label = nil;
    v.size = size;
    ret v;
}

# emit_instr: emit an instruction to the current block.
# ---
# ctx:   lowering context
# op:    operation code
# dst:   destination operand
# src1:  first source operand
# src2:  second source operand
# cond:  condition code (for conditional ops)
# ret:   index of emitted instruction
fun emit_instr(ctx: *LowerContext, op: ir.IROp, dst: ir.IRValue, src1: ir.IRValue, src2: ir.IRValue, cond: i32) i32 {
    if (ctx == nil || ctx.current_block == nil) {
        ret -1;
    }

    var instr: ir.Instr;
    instr.op = op;
    instr.dst = dst;
    instr.src1 = src1;
    instr.src2 = src2;
    instr.cond = cond::u8;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr.op, instr.dst, instr.src1, instr.src2, instr.cond);
    ret ctx.current_block.instr_count - 1;
}

# emit_label: emit a label instruction.
# ---
# ctx:   lowering context
# label: label name
# ret:   none
fun emit_label(ctx: *LowerContext, label: str) {
    if (ctx == nil || ctx.current_block == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_label: ir.OP_LABEL};
    instr.dst = ir.make_label(label);
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_mov: emit a move instruction.
# ---
# ctx:  lowering context
# dst:  destination
# src:  source
# size: size in bytes
# ret:  none
fun emit_mov(ctx: *LowerContext, dst: ir.IRValue, src: ir.IRValue, size: usize) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_mov: ir.OP_MOV};
    instr.dst = dst;
    instr.src1 = src;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_load: emit a load instruction.
# ---
# ctx:    lowering context
# addr:   memory address to load from
# size:   size in bytes
# ret:    destination register value
fun emit_load(ctx: *LowerContext, addr: ir.IRValue, size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    val dst_reg: i32 = new_vreg(ctx, size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, size);

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_load: ir.OP_LOAD};
    instr.dst = dst;
    instr.src1 = addr;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);

    ret dst;
}

# emit_store: emit a store instruction.
# ---
# ctx:    lowering context
# addr:   memory address to store to
# src:    value to store
# ret:    none
fun emit_store(ctx: *LowerContext, addr: ir.IRValue, src: ir.IRValue) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_store: ir.OP_STORE};
    instr.dst = addr;  # store uses dst as address
    instr.src1 = src;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_frame_setup: emit stack frame setup instructions.
# ---
# ctx:       lowering context
# frame_size: size of stack frame in bytes
# ret:       none
fun emit_frame_setup(ctx: *LowerContext, frame_size: usize) {
    if (ctx == nil) {
        ret;
    }

    # push rbp
    var push_instr: ir.Instr;
    push_instr.op = ir.IROp{ir_push: ir.OP_PUSH};
    push_instr.dst = ir.make_reg(ir.RBP, ctx.ptr_size);
    push_instr.src1 = ir.make_none();
    push_instr.src2 = ir.make_none();
    push_instr.cond = ir.CC_NONE;
    emit_instr(ctx, push_instr.op, push_instr.dst, push_instr.src1, push_instr.src2, 0);

    # mov rsp, rbp
    var mov_instr: ir.Instr;
    mov_instr.op = ir.IROp{ir_mov: ir.OP_MOV};
    mov_instr.dst = ir.make_reg(ir.RBP, ctx.ptr_size);
    mov_instr.src1 = ir.make_reg(ir.RSP, ctx.ptr_size);
    mov_instr.src2 = ir.make_none();
    mov_instr.cond = ir.CC_NONE;
    emit_instr(ctx, mov_instr.op, mov_instr.dst, mov_instr.src1, mov_instr.src2, 0);

    # sub rsp, frame_size
    var sub_instr: ir.Instr;
    sub_instr.op = ir.IROp{ir_sub: ir.OP_SUB};
    sub_instr.dst = ir.make_reg(ir.RSP, ctx.ptr_size);
    sub_instr.src1 = ir.make_reg(ir.RSP, ctx.ptr_size);
    sub_instr.src2 = ir.make_imm(frame_size::i64, ctx.ptr_size);
    sub_instr.cond = ir.CC_NONE;
    emit_instr(ctx, sub_instr.op, sub_instr.dst, sub_instr.src1, sub_instr.src2, 0);
}

# emit_frame_teardown: emit stack frame teardown instructions.
# ---
# ctx: lowering context
# ret:  none
fun emit_frame_teardown(ctx: *LowerContext) {
    if (ctx == nil) {
        ret;
    }

    # mov rbp, rsp
    var mov_instr: ir.Instr;
    mov_instr.op = ir.IROp{ir_mov: ir.OP_MOV};
    mov_instr.dst = ir.make_reg(ir.RSP, ctx.ptr_size);
    mov_instr.src1 = ir.make_reg(ir.RBP, ctx.ptr_size);
    mov_instr.src2 = ir.make_none();
    mov_instr.cond = ir.CC_NONE;
    emit_instr(ctx, mov_instr.op, mov_instr.dst, mov_instr.src1, mov_instr.src2, 0);

    # pop rbp
    var pop_instr: ir.Instr;
    pop_instr.op = ir.IROp{ir_pop: ir.OP_POP};
    pop_instr.dst = ir.make_reg(ir.RBP, ctx.ptr_size);
    pop_instr.src1 = ir.make_none();
    pop_instr.src2 = ir.make_none();
    pop_instr.cond = ir.CC_NONE;
    emit_instr(ctx, pop_instr.op, pop_instr.dst, pop_instr.src1, pop_instr.src2, 0);
}

# emit_ret: emit a return instruction.
# ---
# ctx: lowering context
# val: value to return (can be none)
# ret: none
fun emit_ret(ctx: *LowerContext, value: ir.IRValue) {
    if (ctx == nil) {
        ret;
    }

    # emit frame teardown before return
    emit_frame_teardown(ctx);

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_ret: ir.OP_RET};
    instr.dst = value;
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_br: emit an unconditional branch.
# ---
# ctx:   lowering context
# label: target label
# ret:   none
fun emit_br(ctx: *LowerContext, label: str) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_jmp: ir.OP_JMP};
    instr.dst = ir.make_label(label);
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_cond_br: emit a conditional branch.
# ---
# ctx:   lowering context
# cond:  condition code
# label: target label
# ret:   none
fun emit_cond_br(ctx: *LowerContext, cond: i32, label: str) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_jcc: ir.OP_JCC};
    instr.dst = ir.make_label(label);
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = cond::u8;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, cond);
}

# emit_alu: emit an ALU (arithmetic/logic) instruction.
# ---
# ctx:  lowering context
# op:   operation code (add, sub, mul, etc.)
# dst:  destination register
# src1: first source
# src2: second source
# size: operand size
# ret:  destination value
fun emit_alu(ctx: *LowerContext, op: ir.IROp, dst: ir.IRValue, src1: ir.IRValue, src2: ir.IRValue, size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    var instr: ir.Instr;
    instr.op = op;
    instr.dst = dst;
    instr.src1 = src1;
    instr.src2 = src2;
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);

    ret dst;
}

# emit_cmp: emit a compare instruction.
# ---
# ctx:  lowering context
# src1: first operand
# src2: second operand
# size: operand size
# ret:  none
fun emit_cmp(ctx: *LowerContext, src1: ir.IRValue, src2: ir.IRValue, size: usize) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_cmp: ir.OP_CMP};
    instr.dst = ir.make_none();
    instr.src1 = src1;
    instr.src2 = src2;
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_call: emit a function call.
# ---
# ctx:        lowering context
# callee:     function name or address
# args:       argument values
# arg_count:  number of arguments
# ret_size:   return value size (0 for void)
# ret:        return value register (or none)
fun emit_call(ctx: *LowerContext, callee: str, args: *ir.IRValue, arg_count: i32, ret_size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    # emit argument moves to registers/stack
    var i: i32 = 0;
    for (i < arg_count) {
        if (i < 6) {
            # integer argument registers
            val arg_reg: i32 = sysv64.get_arg_reg(i);
            var mov_instr: ir.Instr;
            mov_instr.op = ir.IROp{ir_mov: ir.OP_MOV};
            mov_instr.dst = ir.make_reg(arg_reg, ctx.ptr_size);
            mov_instr.src1 = args[i];
            mov_instr.src2 = ir.make_none();
            mov_instr.cond = ir.CC_NONE;
            emit_instr(ctx, mov_instr.op, mov_instr.dst, mov_instr.src1, mov_instr.src2, 0);
        }
        # TODO: handle stack arguments
        i = i + 1;
    }

    # emit call instruction
    var call_instr: ir.Instr;
    call_instr.op = ir.IROp{ir_call: ir.OP_CALL};
    call_instr.dst = ir.make_label(callee);
    call_instr.src1 = ir.make_none();
    call_instr.src2 = ir.make_none();
    call_instr.cond = ir.CC_NONE;
    emit_instr(ctx, call_instr.op, call_instr.dst, call_instr.src1, call_instr.src2, 0);

    # return value is in rax
    if (ret_size > 0) {
        ret ir.make_reg(ir.RAX, ret_size);
    }
    ret ir.make_none();
}

# emit_sycall: emit a system call instruction.
# ---
# ctx:  lowering context
# num:  syscall number
# args: syscall arguments (up to 6)
# ret:  return value in rax
fun emit_syscall(ctx: *LowerContext, num: i64, args: *ir.IRValue, arg_count: i32) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    # move syscall number to rax
    var mov_num: ir.Instr;
    mov_num.op = ir.IROp{ir_mov: ir.OP_MOV};
    mov_num.dst = ir.make_reg(0, 8);  # RAX = 0
    mov_num.src1 = ir.make_imm(num, 8);
    mov_num.src2 = ir.make_none();
    mov_num.cond = ir.CC_NONE;
    emit_instr(ctx, mov_num.op, mov_num.dst, mov_num.src1, mov_num.src2, 0);

    # emit argument moves to syscall registers
    # syscall register order: RDI, RSI, RDX, R10, R8, R9
    
    var i: i32 = 0;
    for (i < arg_count && i < 6) {
        var mov_arg: ir.Instr;
        mov_arg.op = ir.IROp{ir_mov: ir.OP_MOV};
        
        # select syscall register based on index
        var syscall_reg: i32 = ir.R9;  # default
        if (i == 0) {
            syscall_reg = ir.RDI;
        }
        if (i == 1) {
            syscall_reg = ir.RSI;
        }
        if (i == 2) {
            syscall_reg = ir.RDX;
        }
        if (i == 3) {
            syscall_reg = ir.R10;
        }
        if (i == 4) {
            syscall_reg = ir.R8;
        }
        if (i == 5) {
            syscall_reg = ir.R9;
        }
        
        mov_arg.dst = ir.make_reg(syscall_reg, 8);
        mov_arg.src1 = args[i];
        mov_arg.src2 = ir.make_none();
        mov_arg.cond = ir.CC_NONE;
        emit_instr(ctx, mov_arg.op, mov_arg.dst, mov_arg.src1, mov_arg.src2, 0);
        i = i + 1;
    }

    # emit syscall instruction
    var syscall_instr: ir.Instr;
    syscall_instr.op = ir.IROp{ir_syscall: ir.OP_SYSCALL};
    syscall_instr.dst = ir.make_none();
    syscall_instr.src1 = ir.make_none();
    syscall_instr.src2 = ir.make_none();
    syscall_instr.cond = ir.CC_NONE;
    emit_instr(ctx, syscall_instr.op, syscall_instr.dst, syscall_instr.src1, syscall_instr.src2, 0);

    # return value in rax
    ret ir.make_reg(ir.RAX, 8);
}

# type_is_large_aggregate: check if a type is a large aggregate (>16 bytes).
# ---
# t:        type to check
# ptr_size: pointer size for comparison
# ret:      true if large aggregate
fun type_is_large_aggregate(t: *ty.Type, ptr_size: usize) bool {
    if (t == nil) {
        ret false;
    }

    # records and unions can be large
    if (t.kind == ty.TY_RECORD || t.kind == ty.TY_UNION) {
        if (t.size > 16) {
            ret true;
        }
    }

    # arrays are always aggregates
    if (t.kind == ty.TY_ARRAY) {
        ret true;
    }

    ret false;
}

# --- value and operand helpers ---

# make_lit_int: create an integer literal value.
# ---
# alloc: allocator
# val:   integer value
# ret:   IRValue
fun make_lit_int(alloc: *allocator.Allocator, value: i64) ir.IRValue {
    ret ir.make_imm(value, 8);
}

# make_none: create a "none" value.
# ---
# ret: IRValue representing none
fun make_none() ir.IRValue {
    var v: ir.IRValue;
    v.kind = ir.VAL_NONE;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 1;
    v.label = nil;
    v.size = 0;
    ret v;
}

# --- expression lowering ---

# lower_expr: lower an expression node to IR.
# ---
# ctx:  lowering context
# node: expression AST node
# ret:  IRValue representing the expression result
pub fun lower_expr(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    # dispatch based on node kind
    if (node.kind == ast.NODE_EXPR_LIT_INT) {
        val int_val: i64 = node.get_int_value();
        ret ir.make_imm(int_val, 8);
    }

    if (node.kind == ast.NODE_EXPR_LIT_STR) {
        ret lower_string_lit(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_IDENT) {
        ret lower_identifier(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_BINARY) {
        ret lower_binary(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_UNARY) {
        ret lower_unary(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_CALL) {
        ret lower_call(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_FIELD) {
        ret lower_field_access(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_INDEX) {
        ret lower_index(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_CAST) {
        ret lower_cast(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_ADDR) {
        ret lower_addr(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_DEREF) {
        ret lower_deref(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_ARRAY_LIT) {
        ret lower_array_lit(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_STRUCT_LIT) {
        ret lower_struct_lit(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_LIT_NIL) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # default: return none
    ret make_none();
}

# lower_string_lit: lower a string literal.
# ---
# ctx:  lowering context
# node: string literal node
# ret:  IRValue containing string address
fun lower_string_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val str_val: str = node.get_name();
    if (str_val == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # create a unique label for the string
    val label: str = new_label(ctx, "str");

    # emit string data to rodata section
    val sec_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, ".rodata", section.section_rodata());
    if (sec_res.is_err()) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val sec: *section.Section = sec_res.unwrap_ok();

    # create symbol for the string
    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, label);
    if (sym_res.is_ok()) {
        val s: *sym.Symbol = sym_res.unwrap_ok();
        sym.set_binding(s, sym.bind_local());
        sym.set_type(s, sym.sym_object());
        s.section = sec;
        s.offset = sec.size;
        masm.add_symbol(ctx.m, s);
    }

    # emit string bytes
    var i: usize = 0;
    for (i < str_val.len()) {
        section.emit_byte(ctx.alloc, sec, str_val[i]);
        i = i + 1;
    }
    # null terminator
    section.emit_byte(ctx.alloc, sec, 0);

    # return symbol reference as immediate
    var v: ir.IRValue;
    v.kind = ir.VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 1;
    v.label = label;
    v.size = ctx.ptr_size;

    ret v;
}

# lower_identifier: lower an identifier reference.
# ---
# ctx:  lowering context
# node: identifier node
# ret:  IRValue containing the identifier's value
fun lower_identifier(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val name: str = node.get_name();
    if (name == nil) {
        ret make_none();
    }

    # check if it's a local variable
    val local_idx: i32 = find_local_var(ctx, name);
    if (local_idx >= 0) {
        val offset: i32 = get_local_var_offset(ctx, local_idx);
        val size: usize = ctx.local_vars[local_idx].size;
        val addr: ir.IRValue = frame_mem(ctx, offset, size);
        ret emit_load(ctx, addr, size);
    }

    # check if it's a parameter
    # parameters are handled during function lowering
    # for now, assume it's a global

    # create symbol reference
    var v: ir.IRValue;
    v.kind = ir.VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = 0;
    v.scale = 1;
    v.label = name;
    v.size = ctx.ptr_size;

    # load from global
    ret emit_load(ctx, v, ctx.ptr_size);
}

# lower_binary: lower a binary expression.
# ---
# ctx:  lowering context
# node: binary expression node
# ret:  IRValue containing result
fun lower_binary(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val lhs: *ast.Node = node.get_child(0);
    val rhs: *ast.Node = node.get_child(1);
    val op: u8 = node.tok.tag;

    if (lhs == nil || rhs == nil) {
        ret make_none();
    }

    # lower operands
    val left_value: ir.IRValue = lower_expr(ctx, lhs);
    val right_value: ir.IRValue = lower_expr(ctx, rhs);

    # determine size from node type or default to 8
    var size: usize = 8;
    if (node.ty != nil) {
        size = node.ty.size;
    }

    # allocate result register
    val dst_reg: i32 = new_vreg(ctx, size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, size);

    # map token kind to IR opcode
    var ir_op: ir.IROp = ir.IROp{ir_mov: ir.OP_MOV};

    # arithmetic
    if (op == token.TAG_PLUS) {
        ir_op = ir.IROp{ir_add: ir.OP_ADD};
    }
    if (op == token.TAG_MINUS) {
        ir_op = ir.IROp{ir_sub: ir.OP_SUB};
    }
    if (op == token.TAG_STAR) {
        ir_op = ir.IROp{ir_mul: ir.OP_MUL};
    }
    if (op == token.TAG_SLASH) {
        ir_op = ir.IROp{ir_div: ir.OP_DIV};
    }
    if (op == token.TAG_PERCENT) {
        ir_op = ir.IROp{ir_mod: ir.OP_MOD};
    }

    # bitwise
    if (op == token.TAG_AMP) {
        ir_op = ir.IROp{ir_and: ir.OP_AND};
    }
    if (op == token.TAG_PIPE) {
        ir_op = ir.IROp{ir_or: ir.OP_OR};
    }
    if (op == token.TAG_CARET) {
        ir_op = ir.IROp{ir_xor: ir.OP_XOR};
    }
    if (op == token.TAG_LT_LT) {
        ir_op = ir.IROp{ir_shl: ir.OP_SHL};
    }
    if (op == token.TAG_GT_GT) {
        ir_op = ir.IROp{ir_shr: ir.OP_SHR};
    }

    # comparison (set result to 0 or 1 based on condition)
    if (op == token.TAG_EQ_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        # sete dst (set if equal)
        # TODO: proper condition code handling
        ir_op = ir.IROp{ir_mov: ir.OP_MOV};
        ret dst;
    }
    if (op == token.TAG_BANG_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        ir_op = ir.IROp{ir_mov: ir.OP_MOV};
        ret dst;
    }
    if (op == token.TAG_LT) {
        emit_cmp(ctx, left_value, right_value, size);
        ir_op = ir.IROp{ir_mov: ir.OP_MOV};
        ret dst;
    }
    if (op == token.TAG_GT) {
        emit_cmp(ctx, left_value, right_value, size);
        ir_op = ir.IROp{ir_mov: ir.OP_MOV};
        ret dst;
    }
    if (op == token.TAG_LT_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        ir_op = ir.IROp{ir_mov: ir.OP_MOV};
        ret dst;
    }
    if (op == token.TAG_GT_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        ir_op = ir.IROp{ir_mov: ir.OP_MOV};
        ret dst;
    }

    # assignment
    if (op == token.TAG_EQ) {
        # store right value to left address
        emit_store(ctx, left_value, right_value);
        ret right_value;
    }

    # emit ALU instruction
    ret emit_alu(ctx, ir_op, dst, left_value, right_value, size);
}

# lower_unary: lower a unary expression.
# ---
# ctx:  lowering context
# node: unary expression node
# ret:  IRValue containing result
fun lower_unary(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val operand: *ast.Node = node.get_child(0);  # unary uses lhs for operand
    val op: u8 = node.tok.tag;

    if (operand == nil) {
        ret make_none();
    }

    val value: ir.IRValue = lower_expr(ctx, operand);

    # determine size
    var size: usize = 8;
    if (node.ty != nil) {
        size = node.ty.size;
    }

    # negation
    if (op == token.TAG_MINUS) {
        val zero: ir.IRValue = ir.make_imm(0, size);
        val dst_reg: i32 = new_vreg(ctx, size);
        val dst: ir.IRValue = ir.make_reg(dst_reg, size);
        ret emit_alu(ctx, ir.IROp{ir_sub: ir.OP_SUB}, dst, zero, value, size);
    }

    # bitwise not
    if (op == token.TAG_TILDE) {
        val dst_reg: i32 = new_vreg(ctx, size);
        val dst: ir.IRValue = ir.make_reg(dst_reg, size);
        # xor with all 1s to get complement
        val all_ones: ir.IRValue = ir.make_imm(-1, size);
        ret emit_alu(ctx, ir.IROp{ir_xor: ir.OP_XOR}, dst, value, all_ones, size);
    }

    # logical not
    if (op == token.TAG_BANG) {
        # compare with 0 and set result
        val zero: ir.IRValue = ir.make_imm(0, size);
        emit_cmp(ctx, value, zero, size);
        val dst_reg: i32 = new_vreg(ctx, size);
        val dst: ir.IRValue = ir.make_reg(dst_reg, size);
        # sete result (1 if equal to 0, 0 otherwise)
        # TODO: proper condition code
        ret dst;
    }

    # try operator (unwrap Result/Option)
    # TODO: TAG_KW_TRY not defined
    if (false) {
        # already handled in lower_try
        ret make_none();
    }

    ret value;
}

# lower_call: lower a function call expression.
# ---
# ctx:  lowering context
# node: call expression node
# ret:  IRValue containing return value
fun lower_call(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val callee: *ast.Node = node.get_child(0);
    val args: *ast.List = node.extra::*ast.List;

    if (callee == nil) {
        ret make_none();
    }

    # get function name
    val func_name: str = callee.get_name();
    if (func_name == nil) {
        ret make_none();
    }

    # lower arguments
    var arg_count: i32 = 0;
    if (args != nil) {
        arg_count = args.count;
    }

    # allocate array for argument values
    val args_r: Result[*ir.IRValue, allocator.AllocError] = ctx.alloc.alloc[ir.IRValue](arg_count::usize);
    if (args_r.is_err()) {
        ret make_none();
    }

    val arg_vals: *ir.IRValue = args_r.unwrap_ok();

    var i: i32 = 0;
    for (i < arg_count) {
        arg_vals[i] = lower_expr(ctx, args.nodes[i]);
        i = i + 1;
    }

    # determine return size
    var ret_size: usize = 0;
    if (node.ty != nil) {
        ret_size = node.ty.size;
    }

    # emit call
    val result: ir.IRValue = emit_call(ctx, func_name, arg_vals, arg_count, ret_size);

    # clean up argument array
    ctx.alloc.free[ir.IRValue](arg_vals, arg_count::usize);

    ret result;
}

# lower_field_access: lower a field access expression.
# ---
# ctx:  lowering context
# node: field access node
# ret:  IRValue containing field value
fun lower_field_access(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val base: *ast.Node = node.get_child(0);
    val field_name: str = node.get_name();

    if (base == nil || field_name == nil) {
        ret make_none();
    }

    # lower base to get struct pointer
    val base_value: ir.IRValue = lower_expr(ctx, base);

    # calculate field offset
    # for now, assume all fields are 8 bytes
    val field_offset: usize = 0;  # TODO: look up field offset

    # add offset to base address
    val offset_value: ir.IRValue = ir.make_imm(field_offset::i64, ctx.ptr_size);
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, base_value, offset_value, ctx.ptr_size);

    # load from field address
    # TODO: get field size from type
    val field_size: usize = 8;
    ret emit_load(ctx, addr, field_size);
}

# lower_index: lower an array index expression.
# ---
# ctx:  lowering context
# node: index expression node
# ret:  IRValue containing element value
fun lower_index(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val base: *ast.Node = node.get_child(0);
    val index: *ast.Node = node.get_child(1);

    if (base == nil || index == nil) {
        ret make_none();
    }

    # lower base and index
    val base_value: ir.IRValue = lower_expr(ctx, base);
    val index_value: ir.IRValue = lower_expr(ctx, index);

    # calculate element address: base + index * elem_size
    # for now, assume elem_size = 8
    val elem_size: usize = ctx.ptr_size;  # TODO: get element size from type
    val elem_size_value: ir.IRValue = ir.make_imm(elem_size::i64, ctx.ptr_size);

    # multiply index by element size
    val offset_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val offset: ir.IRValue = ir.make_reg(offset_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_mul: ir.OP_MUL}, offset, index_value, elem_size_value, ctx.ptr_size);

    # add to base
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, base_value, offset, ctx.ptr_size);

    # load element
    ret emit_load(ctx, addr, elem_size);
}

# lower_cast: lower a type cast expression.
# ---
# ctx:  lowering context
# node: cast expression node
# ret:  IRValue containing casted value
fun lower_cast(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val operand: *ast.Node = node.get_child(0);
    if (operand == nil) {
        ret make_none();
    }

    val value: ir.IRValue = lower_expr(ctx, operand);

    # determine target size
    var target_size: usize = 8;
    if (node.ty != nil) {
        target_size = node.ty.size;
    }

    # for now, just move to a register of the right size
    # proper casting (sign extension, zero extension) would go here
    val dst_reg: i32 = new_vreg(ctx, target_size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, target_size);

    emit_mov(ctx, dst, value, target_size);

    ret dst;
}

# lower_addr: lower an address-of expression.
# ---
# ctx:  lowering context
# node: address-of node
# ret:  IRValue containing address
fun lower_addr(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val operand: *ast.Node = node.get_child(0);
    if (operand == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # get lvalue address
    ret lower_lvalue(ctx, operand);
}

# lower_deref: lower a dereference expression.
# ---
# ctx:  lowering context
# node: dereference node
# ret:  IRValue containing dereferenced value
fun lower_deref(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val operand: *ast.Node = node.get_child(0);
    if (operand == nil) {
        ret make_none();
    }

    # lower operand to get pointer
    val ptr: ir.IRValue = lower_expr(ctx, operand);

    # load from pointer
    # determine size from pointed-to type
    var size: usize = ctx.ptr_size;  # TODO: get size from pointed-to type
    if (node.ty != nil) {
        size = node.ty.size;
    }

    ret emit_load(ctx, ptr, size);
}

# lower_try: lower a try expression (unwrap Result/Option).
# ---
# ctx:  lowering context
# node: try expression node
# ret:  IRValue containing unwrapped value or error return
fun lower_try(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val operand: *ast.Node = node.get_child(0);
    if (operand == nil) {
        ret make_none();
    }

    # lower the operand
    val value: ir.IRValue = lower_expr(ctx, operand);

    # TODO: check if result is error, and if so, return early
    # this requires type information about the Result/Option

    ret value;
}

# lower_array_lit: lower an array literal expression.
# ---
# ctx:  lowering context
# node: array literal node
# ret:  IRValue containing array address
fun lower_array_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val elements: *ast.List = node.extra::*ast.List;
    if (elements == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val elem_count: i32 = elements.count;
    if (elem_count == 0) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # allocate stack space for array
    # TODO: get element size from type
    val elem_size: usize = ctx.ptr_size;
    val array_size: usize = elem_count::usize * elem_size;

    # allocate stack space
    ctx.stack_offset = ctx.stack_offset - array_size::i32;
    val array_offset: i32 = ctx.stack_offset;

    # emit initializers
    var i: i32 = 0;
    for (i < elem_count) {
        val elem_value: ir.IRValue = lower_expr(ctx, elements.nodes[i]);
        val elem_addr: ir.IRValue = frame_mem(ctx, array_offset + i::i32 * elem_size::i32, elem_size);
        emit_store(ctx, elem_addr, elem_value);
        i = i + 1;
    }

    # return address of array
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);

    # compute array address from frame pointer
    var instr: ir.Instr;
    instr.op = ir.IROp{ir_lea: ir.OP_LEA};
    instr.dst = addr;
    # frame_mem gives us an address relative to FP
    val fp_addr: ir.IRValue = frame_mem(ctx, array_offset, ctx.ptr_size);
    instr.src1 = fp_addr;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr.op, instr.dst, instr.src1, instr.src2, instr.cond);

    ret addr;
}

# lower_struct_lit: lower a struct literal expression.
# ---
# ctx:  lowering context
# node: struct literal node
# ret:  IRValue containing struct address (for large structs) or value
fun lower_struct_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    # TODO: implement struct literal lowering
    # - get struct type and size
    # - allocate stack space
    # - initialize each field

    ret make_none();
}

# lower_lvalue: get the address of an lvalue expression.
# ---
# ctx:  lowering context
# node: lvalue node (identifier, field access, index, deref)
# ret:  IRValue containing address
fun lower_lvalue(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # identifier - local or global variable
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.get_name();
        if (name == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }

        # check locals
        val local_idx: i32 = find_local_var(ctx, name);
        if (local_idx >= 0) {
            val offset: i32 = get_local_var_offset(ctx, local_idx);
            val size: usize = ctx.local_vars[local_idx].size;
            ret frame_mem(ctx, offset, size);
        }

        # global variable - return symbol reference
        var v: ir.IRValue;
        v.kind = ir.VAL_LABEL;
        v.reg = 0;
        v.imm = 0;
        v.offset = 0;
        v.base_reg = 0;
        v.index_reg = 0;
        v.scale = 1;
        v.label = name;
        v.size = ctx.ptr_size;
        ret v;
    }

    # field access - base address + field offset
    if (node.kind == ast.NODE_EXPR_FIELD) {
        val base: *ast.Node = node.get_child(0);
        val field_name: str = node.get_name();

        if (base == nil || field_name == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }

        val base_addr: ir.IRValue = lower_lvalue(ctx, base);

        # TODO: look up field offset from type
        val field_offset: usize = 0;

        # add offset to base address
        val offset_value: ir.IRValue = ir.make_imm(field_offset::i64, ctx.ptr_size);
        val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
        emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, base_addr, offset_value, ctx.ptr_size);

        ret addr;
    }

    # array index - base + index * elem_size
    if (node.kind == ast.NODE_EXPR_INDEX) {
        val base: *ast.Node = node.get_child(0);
        val index: *ast.Node = node.get_child(1);

        if (base == nil || index == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }

        val base_addr: ir.IRValue = lower_lvalue(ctx, base);
        val index_value: ir.IRValue = lower_expr(ctx, index);

        # TODO: get element size from type
        val elem_size: usize = ctx.ptr_size;
        val elem_size_value: ir.IRValue = ir.make_imm(elem_size::i64, ctx.ptr_size);

        # multiply index by element size
        val offset_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val offset: ir.IRValue = ir.make_reg(offset_reg, ctx.ptr_size);
        emit_alu(ctx, ir.IROp{ir_mul: ir.OP_MUL}, offset, index_value, elem_size_value, ctx.ptr_size);

        # add to base
        val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
        emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, base_addr, offset, ctx.ptr_size);

        ret addr;
    }

    # dereference - just return the pointer value
    if (node.kind == ast.NODE_EXPR_DEREF) {
        val operand: *ast.Node = node.get_child(0);
        if (operand == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }
        ret lower_expr(ctx, operand);
    }

    ret ir.make_imm(0, ctx.ptr_size);
}

# --- statement lowering ---

# lower_stmt: lower a statement node to IR.
# ---
# ctx:  lowering context
# node: statement AST node
# ret:  none
pub fun lower_stmt(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # variable declaration
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        lower_var_decl(ctx, node);
        ret;
    }

    # expression statement
    if (node.kind == ast.NODE_STMT_EXPR) {
        val expr: *ast.Node = node.get_child(0);
        if (expr != nil) {
            lower_expr(ctx, expr);
        }
        ret;
    }

    # assignment
    if (node.kind == ast.NODE_STMT_EXPR) {
        lower_assign(ctx, node);
        ret;
    }

    # return statement
    if (node.kind == ast.NODE_STMT_RET) {
        lower_return(ctx, node);
        ret;
    }

    # if statement
    if (node.kind == ast.NODE_STMT_IF) {
        lower_if(ctx, node);
        ret;
    }

    # while/for loop
    if (node.kind == ast.NODE_STMT_FOR) {
        lower_loop(ctx, node);
        ret;
    }

    # break statement
    if (node.kind == ast.NODE_STMT_BRK) {
        # emit deferred statements up to loop mark
        val mark: i32 = pop_loop_defer_mark(ctx);
        emit_deferred_from(ctx, mark);

        # branch to loop end label
        if (ctx.loop_end_label != nil) {
            emit_br(ctx, ctx.loop_end_label);
        }
        ret;
    }

    # continue statement
    if (node.kind == ast.NODE_STMT_CNT) {
        # emit deferred statements up to loop mark
        val mark: i32 = pop_loop_defer_mark(ctx);
        emit_deferred_from(ctx, mark);

        # branch to loop start label
        if (ctx.loop_start_label != nil) {
            emit_br(ctx, ctx.loop_start_label);
        }
        ret;
    }

    # defer statement
    if (node.kind == ast.NODE_STMT_FIN) {
        val stmt: *ast.Node = node.get_child(0);
        defer_statement(ctx, stmt);
        ret;
    }

    # block statement
    if (node.kind == ast.NODE_STMT_BLOCK) {
        lower_block(ctx, node);
        ret;
    }

    # inline assembly
    if (node.kind == ast.NODE_STMT_MASM) {
        lower_inline_asm(ctx, node);
        ret;
    }
}

# lower_var_decl: lower a variable declaration.
# ---
# ctx:  lowering context
# node: variable declaration node
# ret:  none
fun lower_var_decl(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        ret;
    }

    # get type size
    var size: usize = ctx.ptr_size;
    if (node.ty != nil) {
        size = node.ty.size;
    }

    # allocate stack space
    val offset: i32 = add_local_var(ctx, name, size);

    # get initializer
    val init_node: *ast.Node = node.extra::*ast.Node;
    if (init_node != nil) {
        val init_value: ir.IRValue = lower_expr(ctx, init_node);
        val addr: ir.IRValue = frame_mem(ctx, offset, size);
        emit_store(ctx, addr, init_value);
    }
}

# lower_assign: lower an assignment statement.
# ---
# ctx:  lowering context
# node: assignment node
# ret:  none
fun lower_assign(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val lhs: *ast.Node = node.get_child(0);
    val rhs: *ast.Node = node.get_child(1);

    if (lhs == nil || rhs == nil) {
        ret;
    }

    # get lvalue address
    val addr: ir.IRValue = lower_lvalue(ctx, lhs);

    # lower right-hand side
    val value: ir.IRValue = lower_expr(ctx, rhs);

    # determine size
    var size: usize = ctx.ptr_size;
    if (lhs.ty != nil) {
        size = lhs.ty.size;
    }

    # emit store
    emit_store(ctx, addr, value);
}

# lower_return: lower a return statement.
# ---
# ctx:  lowering context
# node: return statement node
# ret:  none
fun lower_return(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # emit all deferred statements in LIFO order
    emit_deferred_from(ctx, 0);

    # lower return value if present
    val expr: *ast.Node = node.get_child(0);
    var ret_value: ir.IRValue = make_none();
    if (expr != nil) {
        ret_value = lower_expr(ctx, expr);
    }

    # emit return instruction
    emit_ret(ctx, ret_value);
}

# lower_if: lower an if statement.
# ---
# ctx:  lowering context
# node: if statement node
# ret:  none
fun lower_if(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val cond: *ast.Node = node.get_child(0);
    val then_stmt: *ast.Node = node.get_child(1);
    val else_stmt: *ast.Node = node.extra::*ast.Node;

    if (cond == nil) {
        ret;
    }

    # lower condition
    val cond_value: ir.IRValue = lower_expr(ctx, cond);

    # create labels
    val then_label: str = new_label(ctx, "then");
    val else_label: str = new_label(ctx, "else");
    val end_label: str = new_label(ctx, "endif");

    # emit conditional branch
    # compare condition with 0
    val zero: ir.IRValue = ir.make_imm(0, 8);
    emit_cmp(ctx, cond_value, zero, 8);

    # branch to else if condition is false (equal to 0)
    if (else_stmt != nil) {
        emit_cond_br(ctx, ir.CC_EQ::i32, else_label);
    } or {
        emit_cond_br(ctx, ir.CC_EQ::i32, end_label);
    }

    # then block
    emit_br(ctx, then_label);
    emit_label(ctx, then_label);
    if (then_stmt != nil) {
        lower_stmt(ctx, then_stmt);
    }
    emit_br(ctx, end_label);

    # else block
    if (else_stmt != nil) {
        emit_label(ctx, else_label);
        lower_stmt(ctx, else_stmt);
        emit_br(ctx, end_label);
    }

    # end
    emit_label(ctx, end_label);
}

# lower_loop: lower a while or for loop.
# ---
# ctx:  lowering context
# node: loop statement node
# ret:  none
fun lower_loop(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # create labels
    val start_label: str = new_label(ctx, "loop");
    val end_label: str = new_label(ctx, "endloop");

    # save previous loop labels
    val prev_start: str = ctx.loop_start_label;
    val prev_end: str = ctx.loop_end_label;

    # set new loop labels
    ctx.loop_start_label = start_label;
    ctx.loop_end_label = end_label;

    # mark defer stack for this loop
    push_loop_defer_mark(ctx);

    # for loop: emit init, then condition check
    if (node.kind == ast.NODE_STMT_FOR) {
        # node.data contains the for loop components
        val for_data: *ast.Node = node.data::*ast.Node;
        if (for_data != nil) {
            # for_data.get_child(0) is the init statement
            val init_stmt: *ast.Node = for_data.get_child(0);
            if (init_stmt != nil) {
                lower_stmt(ctx, init_stmt);
            }
        }
    }

    # loop start
    emit_label(ctx, start_label);

    # condition check (if present)
    val cond: *ast.Node = node.get_child(0);
    if (cond != nil) {
        val cond_value: ir.IRValue = lower_expr(ctx, cond);
        val zero: ir.IRValue = ir.make_imm(0, 8);
        emit_cmp(ctx, cond_value, zero, 8);
        emit_cond_br(ctx, ir.CC_EQ::i32, end_label);
    }

    # loop body
    val body: *ast.Node = node.get_child(1);
    if (body != nil) {
        lower_stmt(ctx, body);
    }

    # for loop: emit increment
    if (node.kind == ast.NODE_STMT_FOR) {
        val for_data: *ast.Node = node.data::*ast.Node;
        if (for_data != nil) {
            # for_data.get_child(1) contains the condition and increment
            val cond_incr: *ast.Node = for_data.get_child(1);
            if (cond_incr != nil) {
                # cond_incr.get_child(1) is the increment expression
                val incr: *ast.Node = cond_incr.get_child(1);
                if (incr != nil) {
                    lower_expr(ctx, incr);
                }
            }
        }
    }

    # branch back to start
    emit_br(ctx, start_label);

    # loop end
    emit_label(ctx, end_label);

    # emit deferred statements for normal loop exit
    val mark: i32 = pop_loop_defer_mark(ctx);
    emit_deferred_from(ctx, mark);

    # restore previous loop labels
    ctx.loop_start_label = prev_start;
    ctx.loop_end_label = prev_end;
}

# lower_block: lower a block statement.
# ---
# ctx:  lowering context
# node: block node
# ret:  none
fun lower_block(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val stmts: *ast.List = node.extra::*ast.List;
    if (stmts == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < stmts.count) {
        lower_stmt(ctx, stmts.nodes[i]);
        i = i + 1;
    }
}

# lower_inline_asm: lower an inline assembly block.
# ---
# ctx:  lowering context
# node: asm node
# ret:  none
pub fun lower_inline_asm(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret;
    }

    # get asm content from node.data
    val content: str = node.data::str;
    if (content == nil) {
        ret;
    }

    # check for ISA-specific block: "x86_64 { ... }"
    # the parser stores the full content including any ISA prefix
    var asm_content: str = content;
    var i: usize = 0;

    # skip leading whitespace
    for (content[i] == ' ' || content[i] == '\t' || content[i] == '\n' || content[i] == '\r') {
        i = i + 1;
    }

    # check for "x86_64" prefix
    if (content[i] == 'x' && content[i+1] == '8' && content[i+2] == '6' &&
        content[i+3] == '_' && content[i+4] == '6' && content[i+5] == '4') {
        i = i + 6;

        # skip whitespace
        for (content[i] == ' ' || content[i] == '\t' || content[i] == '\n' || content[i] == '\r') {
            i = i + 1;
        }

        # expect '{'
        if (content[i] == '{') {
            i = i + 1;

            # find matching '}'
            var depth: i32 = 1;
            val start: usize = i;
            for (depth > 0 && content[i] != 0) {
                if (content[i] == '{') {
                    depth = depth + 1;
                }
                if (content[i] == '}') {
                    depth = depth - 1;
                }
                if (depth > 0) {
                    i = i + 1;
                }
            }

            # extract inner content
            val inner_len: usize = i - start;
            if (inner_len > 0) {
                val alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](inner_len + 1);
                if (alloc_res.is_ok()) {
                    val buf: *u8 = alloc_res.unwrap_ok();
                    var j: usize = 0;
                    for (j < inner_len) {
                        buf[j] = content[start + j];
                        j = j + 1;
                    }
                    buf[inner_len] = 0;
                    asm_content = buf::str;
                }
            }
        }
    }

    # parse and emit the x86_64 asm
    val text_sec: *section.Section = masm.get_section(ctx.m, ".text");
    x86asm.parse_x86_64_asm(asm_content, text_sec, ctx.m, ctx.alloc);
}

# --- function lowering ---

# lower_function: lower a function declaration to IR.
# ---
# ctx:  lowering context
# node: function AST node
# ret:  Ok(*IRFunction) on success, Err(str) on failure
pub fun lower_function(ctx: *LowerContext, node: *ast.Node) Result[*ir.IRFunction, str] {
    if (ctx == nil) {
        ret err[*ir.IRFunction, str]("context is nil");
    }

    if (node == nil) {
        ret err[*ir.IRFunction, str]("node is nil");
    }

    # reset per-function state
    reset_function_state(ctx);

    val name: str = node.get_name();
    if (name == nil) {
        ret err[*ir.IRFunction, str]("function has no name");
    }

    # create IR function
    val fn_res: Result[*ir.IRFunction, str] = ir.create_function(ctx.alloc, name);
    if (fn_res.is_err()) {
        ret fn_res;
    }

    val func: *ir.IRFunction = fn_res.unwrap_ok();
    ctx.current_fn = func;

    # create entry block
    val entry_label: str = new_label(ctx, "entry");
    val block_res: Result[*ir.IRBlock, str] = ir.create_block(ctx.alloc, entry_label);
    if (block_res.is_err()) {
        ret err[*ir.IRFunction, str](block_res.unwrap_err());
    }

    val entry_block: *ir.IRBlock = block_res.unwrap_ok();
    ctx.current_block = entry_block;

    # add block to function
    if (func.block_count >= func.block_cap) {
        var new_cap: i32 = 8;
        if (func.block_cap > 0) {
            new_cap = func.block_cap * 2;
        }

        val r: Result[**ir.IRBlock, allocator.AllocError] = ctx.alloc.resize[*ir.IRBlock](
            func.blocks, func.block_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[*ir.IRFunction, str](r.unwrap_err());
        }

        func.blocks = r.unwrap_ok();
        func.block_cap = new_cap;
    }

    func.blocks[func.block_count] = entry_block;
    func.block_count = func.block_count + 1;

    # emit function label
    emit_label(ctx, name);

    # create MASM symbol for function
    if (ctx.m != nil) {
        val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, name);
        if (sym_res.is_ok()) {
            val s: *sym.Symbol = sym_res.unwrap_ok();
            s.binding.tag = sym.BIND_GLOBAL;
            s.sym_type.tag = sym.SYM_FUNC;
            masm.add_symbol(ctx.m, s);
        }
    }

    # check if this is the entry point (_start)
    val is_entry: bool = name != nil && name.equals("_start");

    # determine function return type and whether we need sret
    if (node.ty != nil) {
        if (node.ty.kind == ty.TY_FUN) {
            if (node.ty.ret_type != nil) {
                ctx.fn_ret_type = node.ty.ret_type;
                if (type_is_large_aggregate(ctx.fn_ret_type, ctx.ptr_size)) {
                    ctx.fn_has_sret = true;
                }
            }
        }
    }

    # emit stack frame setup placeholder (will be patched after we know frame size)
    # for entry point, no frame setup
    val frame_instr_idx: i32 = ctx.current_block.instr_count;
    if (!is_entry) {
        emit_frame_setup(ctx, 0);  # placeholder with size 0
    }

    # track argument register usage
    var int_arg_idx: i32 = 0;
    var float_arg_idx: i32 = 0;

    # handle hidden sret pointer for large aggregate returns
    if (!is_entry && ctx.fn_has_sret) {
        # sret pointer is passed in first integer arg register
        ctx.stack_offset = ctx.stack_offset - ctx.ptr_size::i32;
        ctx.sret_offset = ctx.stack_offset;
        int_arg_idx = 1;  # skip first arg reg since it holds sret

        # store sret pointer to stack slot
        val sret_reg: i32 = sysv64.get_arg_reg(0);
        val sret_addr: ir.IRValue = frame_mem(ctx, ctx.sret_offset, ctx.ptr_size);
        emit_store(ctx, sret_addr, ir.make_reg(sret_reg, ctx.ptr_size));
    }

    # lower parameters - get param list from AST
    # params are stored in node.extra (not node.data) by the parser
    val params: *ast.List = node.extra::*ast.List;
    if (!is_entry && params != nil) {
        var i: i32 = 0;
        for (i < params.count) {
            val param: *ast.Node = params.nodes[i];
            if (param == nil) {
                i = i + 1;
                cnt;
            }

            val param_name: str = param.get_name();
            val param_type: *ty.Type = param.ty;

            # determine parameter size
            var param_size: usize = ctx.ptr_size;
            if (param_type != nil) {
                param_size = param_type.size;
            }

            # allocate stack space for parameter
            val param_offset: i32 = add_local_var(ctx, param_name, param_size);

            # store parameter from register to stack
            if (int_arg_idx < 6) {
                val arg_reg: i32 = sysv64.get_arg_reg(int_arg_idx);
                val param_addr: ir.IRValue = frame_mem(ctx, param_offset, param_size);
                emit_store(ctx, param_addr, ir.make_reg(arg_reg, param_size));
                int_arg_idx = int_arg_idx + 1;
            }

            i = i + 1;
        }
        func.param_count = params.count;
    }

    # get function body and lower it
    val body: *ast.Node = node.get_child(1);
    if (body != nil) {
        lower_stmt(ctx, body);
    }

    # emit deferred statements from any remaining defer stack entries
    emit_deferred_from(ctx, 0);

    # if no explicit return, emit one
    if (ctx.current_block != nil && ctx.current_block.instr_count > 0) {
        val last_instr: ir.Instr = ctx.current_block.instrs[ctx.current_block.instr_count - 1];
        if (last_instr.op != ir.IROp{ir_ret: ir.OP_RET}) {
            # create none value for void return
            val none_value: ir.IRValue = make_none();
            emit_ret(ctx, none_value);
        }
    } or {
        # empty function, emit return
        val none_value: ir.IRValue = make_none();
        emit_ret(ctx, none_value);
    }

    # calculate frame size from local variables
    var frame_size: usize = 0;
    if (ctx.stack_offset < 0) {
        frame_size = (-ctx.stack_offset)::usize;
    }

    # align frame size to stack alignment (16 bytes for sysv64)
    if (frame_size > 0 && frame_size % 16 != 0) {
        frame_size = (frame_size + 15) & ~15::usize;
    }

    func.local_size = frame_size;

    # patch stack frame size in the frame setup instruction
    if (!is_entry && ctx.current_block != nil && frame_instr_idx < ctx.current_block.instr_count) {
        ctx.current_block.instrs[frame_instr_idx].dst.imm = frame_size::i64;
    }

    # workaround: create result in local variable to avoid return value corruption
    # fully initialize all fields to avoid garbage
    var result: Result[*ir.IRFunction, str];
    result.tag = true;  # is_ok
    result.value.ok = func;
    result.value.err = nil;  # zero out the err side too
    ret result;
}

# --- global variable lowering ---

# lower_global_var: lower a global variable declaration.
# ---
# ctx:  lowering context
# node: variable declaration node
# ret:  none
pub fun lower_global_var(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        ret;
    }

    val init_node: *ast.Node = node.extra::*ast.Node;

    # determine section (.data for mutable, .rodata for immutable)
    var sec_kind: section.SectionKind;
    var sec_name: str;

    if (node.kind == ast.NODE_DECL_VAL) {
        sec_kind = section.section_rodata();
        sec_name = ".rodata";
    } or {
        sec_kind = section.section_data();
        sec_name = ".data";
    }

    val sec_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, sec_name, sec_kind);
    if (sec_res.is_err()) {
        ret;
    }

    val sec: *section.Section = sec_res.unwrap_ok();
    val offset: usize = sec.size;

    # create symbol
    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, name);
    if (sym_res.is_ok()) {
        val s: *sym.Symbol = sym_res.unwrap_ok();
        sym.set_binding(s, sym.bind_global());
        sym.set_type(s, sym.sym_object());
        s.section = sec;
        s.offset = offset;
        masm.add_symbol(ctx.m, s);
    }

    # emit initializer data
    if (init_node != nil) {
        # TODO: handle different literal types
        if (init_node.kind == ast.NODE_EXPR_LIT_INT) {
            val int_val: i64 = init_node.get_int_value();
            section.emit_u64(ctx.alloc, sec, int_val::u64);
        } or (init_node.kind == ast.NODE_EXPR_LIT_STR) {
            val str_val: str = init_node.get_name();
            if (str_val != nil) {
                var i: usize = 0;
                for (i < str_val.len()) {
                    section.emit_byte(ctx.alloc, sec, str_val[i]);
                    i = i + 1;
                }
                # null terminator
                section.emit_byte(ctx.alloc, sec, 0);
            }
        }
    }
}

# --- module lowering ---

# lower_module: lower all functions in a module.
# ---
# ctx:    lowering context
# module: module root node
# ret:    number of functions lowered
pub fun lower_module(ctx: *LowerContext, module: *ast.Node) i32 {
    if (ctx == nil || module == nil) {
        ret 0;
    }

    var count: i32 = 0;

    # get declarations from module
    val decls: *ast.List = module.extra::*ast.List;
    if (decls == nil) {
        ret count;
    }

    # first pass: collect global variables and function declarations
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # global variable declaration
        if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
            lower_global_var(ctx, node);
        }

        i = i + 1;
    }

    # second pass: lower function bodies
    i = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # function declaration
        if (node.kind == ast.NODE_DECL_FUN) {
            val fn_res: Result[*ir.IRFunction, str] = lower_function(ctx, node);
            if (fn_res.is_ok()) {
                val func: *ir.IRFunction = fn_res.unwrap_ok();
                # add function to IR module
                # function already added to masm module via lower_function
                count = count + 1;
            }
        }

        i = i + 1;
    }

    ret count;
}

# lower_entry_point: lower the program entry point (_start).
# ---
# ctx:       lowering context
# main_name: name of the main function to call
# ret:       Ok(*IRFunction) on success, Err(str) on failure
pub fun lower_entry_point(ctx: *LowerContext, main_name: str) Result[*ir.IRFunction, str] {
    if (ctx == nil || main_name == nil) {
        ret err[*ir.IRFunction, str]("invalid arguments");
    }

    # create _start function
    val fn_res: Result[*ir.IRFunction, str] = ir.create_function(ctx.alloc, "_start");
    if (fn_res.is_err()) {
        ret fn_res;
    }

    val func: *ir.IRFunction = fn_res.unwrap_ok();
    ctx.current_fn = func;

    # create entry block
    val entry_label: str = new_label(ctx, "entry");
    val block_res: Result[*ir.IRBlock, str] = ir.create_block(ctx.alloc, entry_label);
    if (block_res.is_err()) {
        ret err[*ir.IRFunction, str](block_res.unwrap_err());
    }

    val entry_block: *ir.IRBlock = block_res.unwrap_ok();
    ctx.current_block = entry_block;

    # add block to function
    if (func.block_count >= func.block_cap) {
        var new_cap: i32 = 8;
        if (func.block_cap > 0) {
            new_cap = func.block_cap * 2;
        }

        val r: Result[**ir.IRBlock, allocator.AllocError] = ctx.alloc.resize[*ir.IRBlock](
            func.blocks, func.block_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[*ir.IRFunction, str](r.unwrap_err());
        }

        func.blocks = r.unwrap_ok();
        func.block_cap = new_cap;
    }

    func.blocks[func.block_count] = entry_block;
    func.block_count = func.block_count + 1;

    # emit _start label
    emit_label(ctx, "_start");

    # create MASM symbol for _start
    if (ctx.m != nil) {
        val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, "_start");
        if (sym_res.is_ok()) {
            val s: *sym.Symbol = sym_res.unwrap_ok();
            s.binding.tag = sym.BIND_GLOBAL;
            s.sym_type.tag = sym.SYM_FUNC;
            masm.add_symbol(ctx.m, s);
        }
    }

    # call main function
    val main_args: Result[*ir.IRValue, allocator.AllocError] = ctx.alloc.alloc[ir.IRValue](0);
    if (main_args.is_ok()) {
        val call_result: ir.IRValue = emit_call(ctx, main_name, main_args.unwrap_ok(), 0, 8);
        ctx.alloc.free[ir.IRValue](main_args.unwrap_ok(), 0);

        # exit with main's return value
        # syscall exit(rax)
        var exit_args: [1]ir.IRValue;
        exit_args[0] = call_result;
        emit_syscall(ctx, 60, ?exit_args[0], 1);  # SYS_exit = 60
    }

    # workaround: create result in local variable
    var result: Result[*ir.IRFunction, str];
    result.tag = true;  # is_ok
    result.value.ok = func;
    result.value.err = nil;
    ret result;
}