use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use allocator: std.allocator;

use ast:     mach.compiler.ast;
use isel:    mach.compiler.masm.isa.dispatch;
use abi_dispatch: mach.compiler.masm.abi.dispatch;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use token:  mach.compiler.token;

use ir:      mach.compiler.masm.ir;
use masm:    mach.compiler.masm.masm;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;
use target:  mach.compiler.masm.target;
use abi:     mach.compiler.masm.abi.spec;
use sema:      mach.compiler.sema;
use print:     std.print;

# ModuleMasm: per-module MASM context for split lowering.
# ---
# m:              masm context for this module
# mod_name:       module name (e.g. "mach.compiler.ast")
# file_path:      source file path
# ir_funcs:       IR functions belonging to this module
# ir_func_count:  number of IR functions
# ir_func_cap:    capacity of ir_funcs array
pub rec ModuleMasm {
    m:              *masm.Masm;
    mod_name:       str;
    file_path:      str;
    ir_funcs:       **ir.IRFunction;
    ir_func_count:  i32;
    ir_func_cap:    i32;
}

fun is_space_u8(c: u8) bool {
    ret c == 32 || c == 9 || c == 10 || c == 13;
}

fun is_digit_u8(c: u8) bool {
    ret c >= 48 && c <= 57;
}

fun parse_float(s: str) f64 {
    if (s == nil) {
        ret 0.0;
    }

    var i: usize = 0;
    for (is_space_u8(s[i])) {
        i = i + 1;
    }

    var neg: bool = false;
    if (s[i] == '-') {
        neg = true;
        i = i + 1;
    }

    # integer part
    var value: f64 = 0.0;
    for (s[i] != 0 && is_digit_u8(s[i])) {
        value = value * 10.0 + (s[i] - '0')::f64;
        i = i + 1;
    }

    # fractional part
    if (s[i] == '.') {
        i = i + 1;
        var frac: f64 = 0.0;
        var divisor: f64 = 1.0;
        for (s[i] != 0 && is_digit_u8(s[i])) {
            frac = frac * 10.0 + (s[i] - '0')::f64;
            divisor = divisor * 10.0;
            i = i + 1;
        }
        value = value + frac / divisor;
    }

    # exponent part
    if (s[i] == 'e' || s[i] == 'E') {
        i = i + 1;
        var exp_neg: bool = false;
        if (s[i] == '-') {
            exp_neg = true;
            i = i + 1;
        } or (s[i] == '+') {
            i = i + 1;
        }
        var exp: i64 = 0;
        for (s[i] != 0 && is_digit_u8(s[i])) {
            exp = exp * 10 + (s[i] - '0')::i64;
            i = i + 1;
        }
        var mult: f64 = 1.0;
        var ei: i64 = 0;
        for (ei < exp) {
            mult = mult * 10.0;
            ei = ei + 1;
        }
        if (exp_neg) {
            value = value / mult;
        } or {
            value = value * mult;
        }
    }

    if (neg) {
        ret 0.0 - value;
    }
    ret value;
}

fun parse_int_str(s: str) i64 {
    if (s == nil) {
        ret 0;
    }

    var i: usize = 0;
    for (is_space_u8(s[i])) {
        i = i + 1;
    }

    var neg: bool = false;
    if (s[i] == 45) {
        neg = true;
        i = i + 1;
    }

    var value: i64 = 0;

    # hex: 0x...
    if (s[i] == '0' && (s[i + 1] == 'x' || s[i + 1] == 'X')) {
        i = i + 2;
        for (s[i] != 0) {
            if (is_digit_u8(s[i])) {
                value = value * 16 + (s[i] - '0')::i64;
            } or (s[i] >= 'a' && s[i] <= 'f') {
                value = value * 16 + (s[i] - 'a' + 10)::i64;
            } or (s[i] >= 'A' && s[i] <= 'F') {
                value = value * 16 + (s[i] - 'A' + 10)::i64;
            } or {
                brk;
            }
            i = i + 1;
        }
    }
    # octal: 0o...
    or (s[i] == '0' && (s[i + 1] == 'o' || s[i + 1] == 'O')) {
        i = i + 2;
        for (s[i] != 0 && s[i] >= '0' && s[i] <= '7') {
            value = value * 8 + (s[i] - '0')::i64;
            i = i + 1;
        }
    }
    # binary: 0b...
    or (s[i] == '0' && (s[i + 1] == 'b' || s[i + 1] == 'B')) {
        i = i + 2;
        for (s[i] != 0 && (s[i] == '0' || s[i] == '1')) {
            value = value * 2 + (s[i] - '0')::i64;
            i = i + 1;
        }
    }
    # decimal
    or {
        for (s[i] != 0 && is_digit_u8(s[i])) {
            value = value * 10 + (s[i] - 48)::i64;
            i = i + 1;
        }
    }

    if (neg) {
        ret -value;
    }
    ret value;
}

fun extract_token(ctx: *LowerContext, s: str, start: usize, end: *usize) str {
    if (s == nil || ctx == nil || ctx.alloc == nil || end == nil) {
        ret nil;
    }

    var i: usize = start;
    for (is_space_u8(s[i])) {
        i = i + 1;
    }

    var j: usize = i;
    for (s[j] != 0 && s[j] != ',' && !is_space_u8(s[j])) {
        j = j + 1;
    }

    if (j <= i) {
        @end = j;
        ret nil;
    }

    val len: usize = j - i;
    val alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](len + 1);
    if (alloc_res.is_err()) {
        @end = j;
        ret nil;
    }

    val buf: *u8 = alloc_res.unwrap_ok();
    var k: usize = 0;
    for (k < len) {
        buf[k] = s[i + k];
        k = k + 1;
    }
    buf[len] = 0;
    @end = j;
    ret buf::str;
}

fun resolve_value_token(ctx: *LowerContext, name: str) ir.IRValue {
    if (ctx == nil || name == nil) {
        ret make_none();
    }

    var base: str = name;
    var last_dot: i32 = -1;
    var i: usize = 0;
    for (name[i] != 0) {
        if (name[i] == '.') {
            last_dot = i::i32;
        }
        i = i + 1;
    }
    if (last_dot >= 0 && name[(last_dot + 1)::usize] != 0) {
        base = (name::usize + (last_dot + 1)::usize)::str;
    }

    if (base.equals("nil")) { ret ir.make_imm(0, ctx.ptr_size); }

    if (base.equals("SYS_WAIT4")) { ret ir.make_imm(61, ctx.ptr_size); }
    if (base.equals("SYS_FORK")) { ret ir.make_imm(57, ctx.ptr_size); }
    if (base.equals("SYS_VFORK")) { ret ir.make_imm(58, ctx.ptr_size); }
    if (base.equals("SYS_EXECVE")) { ret ir.make_imm(59, ctx.ptr_size); }
    if (base.equals("SYS_EXIT")) { ret ir.make_imm(60, ctx.ptr_size); }

    if (is_digit_u8(base[0]) || (base[0] == 45 && is_digit_u8(base[1]))) {
        ret ir.make_imm(parse_int_str(base), ctx.ptr_size);
    }

    # local variable
    val local_idx: i32 = find_local_var(ctx, base);
    if (local_idx >= 0) {
        val offset: i32 = get_local_var_offset(ctx, local_idx);
        val size: usize = ctx.local_vars[local_idx].size;
        val addr: ir.IRValue = frame_mem(ctx, offset, size);
        ret emit_load(ctx, addr, size);
    }

    # global symbol
    var v: ir.IRValue;
    v.kind = ir.VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = base;
    v.size = ctx.ptr_size;
    ret emit_load(ctx, v, ctx.ptr_size);
}

fun resolve_lvalue_token(ctx: *LowerContext, name: str) ir.IRValue {
    if (ctx == nil || name == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    var base: str = name;
    var last_dot: i32 = -1;
    var i: usize = 0;
    for (name[i] != 0) {
        if (name[i] == '.') {
            last_dot = i::i32;
        }
        i = i + 1;
    }
    if (last_dot >= 0 && name[(last_dot + 1)::usize] != 0) {
        base = (name::usize + (last_dot + 1)::usize)::str;
    }

    val local_idx: i32 = find_local_var(ctx, base);
    if (local_idx >= 0) {
        val offset: i32 = get_local_var_offset(ctx, local_idx);
        val size: usize = ctx.local_vars[local_idx].size;
        ret frame_mem(ctx, offset, size);
    }

    var v: ir.IRValue;
    v.kind = ir.VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = base;
    v.size = ctx.ptr_size;
    ret v;
}

# mach.compiler.masm.lower: AST to IR lowering.
# ---
# converts the typed AST into MASM intermediate representation.

# LocalVar: tracking info for a local variable.
# ---
# name:   variable name
# offset: stack offset from frame pointer (negative for locals)
# size:   size in bytes
pub rec LocalVar {
    name:   str;
    offset: i32;
    size:   usize;
    ty:     *ty.Type;
}

# LowerError: a lowering error with source location.
# ---
# pos:       byte position in source
# line:      1-based line number
# col:       1-based column number
# file_path: path to the source file
# message:   error description
# source:    source text (for printing error lines)
pub rec LowerError {
    pos:       i32;
    line:      i32;
    col:       i32;
    file_path: str;
    message:   str;
    source:    str;
}

# LowerContext: context for lowering AST to IR.
# ---
# alloc:            allocator for IR allocations
# symbols:          symbol table for lookups
# types:            type context
# tgt:              target configuration
# abi:              ABI specification for calling convention
# current_fn:       current function being lowered
# current_block:    current basic block
# ptr_size:         pointer size in bytes
# stack_align:      stack alignment in bytes
#
# local_vars:       array of local variables
# local_count:      number of locals
# local_cap:        allocated capacity
# stack_offset:     current stack offset (grows negative)
#
# deferred:         array of deferred statement nodes (fin)
# deferred_count:   number of deferred statements
# deferred_cap:     allocated capacity
#
# loop_defer_marks: stack of indices into deferred array at loop entry
# loop_mark_count:  number of loop marks
# loop_mark_cap:    allocated capacity
#
# loop_start_label: label for loop start (for cnt)
# loop_end_label:   label for loop end (for brk)
#
# vreg_next:        next virtual register number
# label_counter:    counter for unique labels
# str_counter:      counter for string literals
# loop_counter:     counter for loops
#
# fn_ret_type:      return type of current function
# fn_has_sret:      true if function returns aggregate via hidden pointer
# sret_offset:      stack offset of hidden sret pointer
pub rec LowerContext {
    alloc:            *allocator.Allocator;
    symbols:          *symbol.Table;
    types:            *ty.TypeContext;
    tgt:              target.Target;
    abi:              abi.ABI;
    current_fn:       *ir.IRFunction;
    current_block:    *ir.IRBlock;
    ptr_size:         usize;
    stack_align:      usize;

    local_vars:       *LocalVar;
    local_count:      i32;
    local_cap:        i32;
    stack_offset:     i32;

    # hash table for fast local variable lookup by name
    # stores indices into local_vars; -1 means empty slot
    local_hash:       *i32;
    local_hash_cap:   i32;

    deferred:         **ast.Node;
    deferred_count:   i32;
    deferred_cap:     i32;

    loop_defer_marks: *i32;
    loop_mark_count:  i32;
    loop_mark_cap:    i32;

    loop_start_label: str;
    loop_end_label:   str;

    vreg_next:        i32;
    label_counter:    i32;
    str_counter:      i32;
    loop_counter:     i32;

    fn_ret_type:      *ty.Type;
    fn_has_sret:      bool;
    sret_offset:      i32;

    # variadic function lowering state
    fn_is_variadic:       bool;
    va_reg_save_off:      i32;   # rbp-relative base offset for reg_save_area
    va_named_gp:          i32;   # named gp regs consumed (excluding sret)
    va_named_fp:          i32;   # named fp regs consumed
    va_named_stack_slots: i32;   # named params passed on stack

    # MASM context for symbol registration
    m:                *masm.Masm;

    # source text for error messages
    text:             str;

    # IR functions for code generation
    ir_funcs:         **ir.IRFunction;
    ir_func_count:    i32;
    ir_func_cap:      i32;

    # imported modules for cross-module symbol lookup
    loaded_mods:      **sema.SemaModule;
    loaded_mod_count: i32;

    # current module being lowered (for alias/import resolution)
    current_sema_mod: *sema.SemaModule;

    # type bindings for generic method instantiation
    # when lowering an instantiated generic method body, these map
    # generic param names (e.g., "T", "E") to concrete types
    type_binding_names:  *str;
    type_binding_types:  **ty.Type;
    type_binding_count:  i32;

    # override for function name when lowering instantiations
    func_name_override:  str;
    # override for receiver type
    recv_type_override:  *ty.Type;
    # override for return type
    ret_type_override:   *ty.Type;

    # debug info: current source file index for DWARF (1-based)
    current_file_idx:    u16;

    # error tracking for lowering diagnostics
    had_error:    bool;
    errors:       *LowerError;
    error_count:  i32;
    error_cap:    i32;
}

# init: initialize a lowering context.
# ---
# alloc:   allocator for IR allocations
# symbols: symbol table for lookups
# types:   type context
# tgt:     target configuration
# m:       masm context for symbol registration
# text:    source text for error messages
# ret:     initialized context
pub fun init(alloc: *allocator.Allocator, symbols: *symbol.Table, types: *ty.TypeContext, tgt: target.Target, m: *masm.Masm, text: str) LowerContext {
    var ctx: LowerContext;
    ctx.alloc         = alloc;
    ctx.symbols       = symbols;
    ctx.types         = types;
    ctx.tgt           = tgt;
    ctx.ptr_size      = 8;  # assume 64-bit
    ctx.stack_align   = 16; # sysv64
    ctx.current_fn    = nil;
    ctx.current_block = nil;
    ctx.local_vars    = nil;
    ctx.local_count   = 0;
    ctx.local_cap     = 0;
    ctx.stack_offset  = 0;
    ctx.local_hash    = nil;
    ctx.local_hash_cap = 0;
    ctx.deferred      = nil;
    ctx.deferred_count = 0;
    ctx.deferred_cap  = 0;
    ctx.loop_defer_marks = nil;
    ctx.loop_mark_count = 0;
    ctx.loop_mark_cap = 0;
    ctx.loop_start_label = nil;
    ctx.loop_end_label = nil;
    ctx.vreg_next     = ir.VREG_START;
    ctx.label_counter = 0;
    ctx.str_counter   = 0;
    ctx.loop_counter  = 0;
    ctx.fn_ret_type   = nil;
    ctx.fn_has_sret   = false;
    ctx.sret_offset   = 0;
    ctx.m             = m;
    ctx.text          = text;

    # initialize IR function storage
    ctx.ir_funcs      = nil;
    ctx.ir_func_count = 0;
    ctx.ir_func_cap   = 0;

    # initialize ABI
    ctx.abi = abi_dispatch.for_target(?ctx.tgt);

    # imported modules (set later by lower_all_modules)
    ctx.loaded_mods = nil;
    ctx.loaded_mod_count = 0;

    # type bindings (for generic instantiation lowering)
    ctx.type_binding_names = nil;
    ctx.type_binding_types = nil;
    ctx.type_binding_count = 0;
    ctx.func_name_override = nil;
    ctx.recv_type_override = nil;
    ctx.ret_type_override = nil;
    ctx.current_file_idx = 0;

    # error tracking
    ctx.had_error    = false;
    ctx.errors       = nil;
    ctx.error_count  = 0;
    ctx.error_cap    = 0;

    ret ctx;
}

# line_for_pos: compute 1-based line number from byte offset in source text.
# ---
# text: source text
# pos:  byte offset
# ret:  1-based line number (0 if text is nil or pos < 0)
fun line_for_pos(text: str, pos: i32) i32 {
    if (text == nil || pos <= 0) {
        ret 1;
    }

    var line: i32 = 1;
    var i: i32 = 0;
    for (i < pos) {
        if (text[i::usize] == 10) {
            line = line + 1;
        }
        i = i + 1;
    }
    ret line;
}

# col_for_pos: compute 1-based column number from byte offset in source text.
# ---
# text: source text
# pos:  byte offset
# ret:  1-based column number
fun col_for_pos(text: str, pos: i32) i32 {
    if (text == nil || pos <= 0) {
        ret 1;
    }

    var col: i32 = 1;
    var i: i32 = 0;
    val len: i32 = text.len()::i32;

    for (i < pos && i < len) {
        if (text[i::usize] == 10) {
            col = 1;
        } or {
            col = col + 1;
        }
        i = i + 1;
    }
    ret col;
}

# report_lower_error: record a lowering error at a token position.
# ---
# ctx:     lowering context
# tok:     token where error occurred
# message: error message
fun report_lower_error(ctx: *LowerContext, tok: token.Token, message: str) {
    if (ctx == nil) {
        ret;
    }

    ctx.had_error = true;

    if (ctx.error_count >= 20) {
        ret;
    }

    if (ctx.error_count >= ctx.error_cap) {
        var new_cap: i32 = 8;
        if (ctx.error_cap > 0) {
            new_cap = ctx.error_cap * 2;
        }

        val r: Result[*LowerError, allocator.AllocError] = ctx.alloc.resize[LowerError](
            ctx.errors,
            ctx.error_cap::u64,
            new_cap::u64
        );

        if (r.is_err()) {
            ret;
        }

        ctx.errors = r.unwrap_ok();
        ctx.error_cap = new_cap;
    }

    val idx: i32 = ctx.error_count;
    ctx.errors[idx].pos = tok.pos;
    ctx.errors[idx].line = line_for_pos(ctx.text, tok.pos);
    ctx.errors[idx].col = col_for_pos(ctx.text, tok.pos);
    ctx.errors[idx].source = ctx.text;

    if (ctx.current_sema_mod != nil && ctx.current_sema_mod.file_path != nil) {
        ctx.errors[idx].file_path = ctx.current_sema_mod.file_path;
    } or {
        ctx.errors[idx].file_path = "<main>";
    }

    ctx.errors[idx].message = message;
    ctx.error_count = ctx.error_count + 1;
}

# report_lower_error_str: record a lowering error without a specific token.
# ---
# ctx:     lowering context
# message: error message
fun report_lower_error_str(ctx: *LowerContext, message: str) {
    if (ctx == nil) {
        ret;
    }

    var tok: token.Token;
    tok.pos = 0;
    tok.len = 0;
    tok.tag = 0;
    report_lower_error(ctx, tok, message);
}

# lower_print_i32: print an i32 value to stderr.
# ---
# n: number to print
fun lower_print_i32(n: i32) {
    if (n < 0) {
        print.eprint("-");
        lower_print_i32(-n);
        ret;
    }

    if (n == 0) {
        print.eprint("0");
        ret;
    }

    var buf: [16]u8;
    var len: i32 = 0;
    var num: i32 = n;

    for (num > 0) {
        buf[len] = (num % 10)::u8 + 48;
        num = num / 10;
        len = len + 1;
    }

    # print in forward order
    var j: i32 = len - 1;
    for (j >= 0) {
        var ch: [2]u8;
        ch[0] = buf[j];
        ch[1] = 0;
        print.eprint((?ch[0])::str);
        j = j - 1;
    }
}

# lower_print_error_line: print a source line with a caret at the column.
# ---
# source: full source text
# line:   1-based line number
# col:    1-based column number
fun lower_print_error_line(source: str, line: i32, col: i32) {
    if (source == nil || line < 1) {
        ret;
    }

    var current_line: i32 = 1;
    var line_start: i32 = 0;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    for (i < len && current_line < line) {
        if (source[i::usize] == 10) {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) {
        ret;
    }

    var line_end: i32 = line_start;
    for (line_end < len && source[line_end::usize] != 10) {
        line_end = line_end + 1;
    }

    # print line number and content
    print.eprint("  ");
    lower_print_i32(line);
    print.eprint(" | ");
    i = line_start;
    for (i < line_end) {
        var ch: [2]u8;
        ch[0] = source[i::usize];
        ch[1] = 0;
        print.eprint((?ch[0])::str);
        i = i + 1;
    }
    print.eprintln("");

    # caret line
    print.eprint("    | ");
    var c: i32 = 1;
    for (c < col) {
        print.eprint(" ");
        c = c + 1;
    }
    print.eprintln("^");
}

# print_lower_errors: print all collected lowering errors to stderr.
# ---
# ctx: lowering context
pub fun print_lower_errors(ctx: *LowerContext) {
    if (ctx == nil || ctx.errors == nil || ctx.error_count == 0) {
        ret;
    }

    var i: i32 = 0;
    for (i < ctx.error_count) {
        val e: *LowerError = ?ctx.errors[i];

        print.eprint("error: ");
        if (e.message != nil) {
            print.eprintln(e.message);
        } or {
            print.eprintln("(null message)");
        }

        if (e.file_path != nil) {
            print.eprint(e.file_path);
            print.eprint(":");
        } or {
            print.eprint("<unknown>:");
        }

        lower_print_i32(e.line);
        print.eprint(":");
        lower_print_i32(e.col);
        print.eprintln("");

        lower_print_error_line(e.source, e.line, e.col);
        i = i + 1;
    }

    lower_print_i32(ctx.error_count);
    print.eprint(" lowering error(s) found");
    if (ctx.error_count >= 20) {
        print.eprintln(" (error limit reached)");
    } or {
        print.eprintln("");
    }
}

# has_lower_errors: check if the lowering context has recorded any errors.
# ---
# ctx: lowering context
# ret: true if errors were recorded
pub fun has_lower_errors(ctx: *LowerContext) bool {
    if (ctx == nil) {
        ret false;
    }
    ret ctx.error_count > 0;
}

# annotate_instr: set source location on an IR instruction from an AST node.
# ---
# ctx:   lowering context
# block: IR block containing the instruction
# idx:   instruction index in block
# node:  AST node providing source location
fun annotate_instr(ctx: *LowerContext, block: *ir.IRBlock, idx: i32, node: *ast.Node) {
    if (ctx == nil || block == nil || idx < 0 || idx >= block.instr_count || node == nil) {
        ret;
    }
    if (ctx.text == nil || ctx.current_file_idx == 0) {
        ret;
    }
    val line: i32 = line_for_pos(ctx.text, node.tok.pos);
    if (line > 0) {
        block.instrs[idx].src_line = line;
        block.instrs[idx].src_file = ctx.current_file_idx;
    }
}

# find_method_type_name: search symbol tables for a method and return its type prefix.
# ---
# for a method name like "equals", searches for symbols named "*.equals" and
# returns the type prefix (e.g., "str" from "str.equals").
# ctx:  lowering context
# method_name: method name to search for
# ret:  type name prefix or nil
fun find_method_type_name(ctx: *LowerContext, method_name: str) str {
    if (ctx == nil || method_name == nil) {
        ret nil;
    }

    val method_len: usize = method_name.len();

    # search current module's symbol table
    if (ctx.symbols != nil) {
        val found: str = search_scope_for_method(ctx, ctx.symbols.root_scope(), method_name, method_len);
        if (found != nil) {
            ret found;
        }
    }

    # search imported modules
    if (ctx.loaded_mods != nil) {
        var k: i32 = 0;
        for (k < ctx.loaded_mod_count) {
            val smod: *sema.SemaModule = ctx.loaded_mods[k];
            if (smod != nil && smod.table != nil) {
                val found: str = search_scope_for_method(ctx, smod.table.root_scope(), method_name, method_len);
                if (found != nil) {
                    ret found;
                }
            }
            k = k + 1;
        }
    }

    ret nil;
}

# search_scope_for_method: search a scope for a symbol ending in ".methodName".
fun search_scope_for_method(ctx: *LowerContext, root: *symbol.Scope, method_name: str, method_len: usize) str {
    if (root == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < root.symbol_count) {
        val found_sym: *symbol.Symbol = ?root.symbols[i];
        if (found_sym != nil && found_sym.name != nil) {
            val slen: usize = found_sym.name.len();
            if (slen > method_len + 1) {
                val dot_pos: usize = slen - method_len - 1;
                if (found_sym.name[dot_pos] == '.') {
                    val suffix: str = (found_sym.name::usize + dot_pos + 1)::str;
                    if (suffix.equals(method_name)) {
                        val buf_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](dot_pos + 1);
                        if (buf_res.is_ok()) {
                            val buf: *u8 = buf_res.unwrap_ok();
                            var j: usize = 0;
                            for (j < dot_pos) {
                                buf[j] = found_sym.name[j];
                                j = j + 1;
                            }
                            buf[dot_pos] = 0;
                            ret buf::str;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }

    ret nil;
}

# is_module_alias: check if a name is a module alias (not a local variable or value symbol).
# ---
# called when base_name is not found in local_vars and has no type.
# checks the current symbol table for a value symbol with this name.
# if no value symbol is found, the name is assumed to be a module alias.
# ctx:  lowering context
# name: name to check
# ret:  true if name is likely a module alias
fun is_module_alias(ctx: *LowerContext, name: str) bool {
    if (ctx == nil || name == nil) {
        ret false;
    }

    # check if name is a known value/function symbol in the current module's scope
    if (ctx.symbols != nil) {
        val result: Option[*symbol.Symbol] = ctx.symbols.lookup(name);
        if (result.is_some()) {
            val s: *symbol.Symbol = result.unwrap();
            # if it's a value, parameter, or function - it's not a module alias
            if (s.is_value_symbol() || s.is_callable()) {
                ret false;
            }
        }
    }

    # check the current module's aliases list directly
    if (ctx.current_sema_mod != nil) {
        var alias: *sema.ModuleAlias = ctx.current_sema_mod.aliases;
        for (alias != nil) {
            if (alias.alias != nil && alias.alias.equals(name)) {
                ret true;
            }
            alias = alias.next;
        }
    }

    # not found as a value symbol in current scope - likely a module alias
    # (module aliases are stored in SemaModule, not in the symbol table)
    ret true;
}

# lookup_symbol_in_imports: search imported modules for a symbol by name.
# ---
# ctx:  lowering context
# name: symbol name to find
# ret:  pointer to symbol if found, nil otherwise
fun lookup_symbol_in_imports(ctx: *LowerContext, name: str) *symbol.Symbol {
    if (ctx == nil || name == nil || ctx.loaded_mods == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < ctx.loaded_mod_count) {
        val smod: *sema.SemaModule = ctx.loaded_mods[i];
        if (smod != nil && smod.table != nil) {
            val root: *symbol.Scope = smod.table.root_scope();
            if (root != nil) {
                val found_opt: Option[*symbol.Symbol] = root.lookup_local(name);
                if (found_opt.is_some()) {
                    val found: *symbol.Symbol = found_opt.unwrap();
                    if (found.is_public) {
                        ret found;
                    }
                }
            }
        }
        i = i + 1;
    }

    ret nil;
}

# reset_function_state: reset per-function state for a new function.
# ---
# ctx: lowering context
# ret: none
fun reset_function_state(ctx: *LowerContext) {
    if (ctx == nil) {
        ret;
    }

    # reset local variables
    ctx.local_count = 0;
    ctx.stack_offset = 0;
    local_hash_clear(ctx);

    # reset deferred statements
    ctx.deferred_count = 0;
    ctx.loop_mark_count = 0;

    # reset loop labels
    ctx.loop_start_label = nil;
    ctx.loop_end_label = nil;

    # reset function-specific state
    ctx.fn_ret_type = nil;
    ctx.fn_has_sret = false;
    ctx.sret_offset = 0;

    # reset variadic state
    ctx.fn_is_variadic = false;
    ctx.va_reg_save_off = 0;
    ctx.va_named_gp = 0;
    ctx.va_named_fp = 0;
    ctx.va_named_stack_slots = 0;

    # note: we don't reset vreg_next so registers are unique across functions
}

# add_ir_function: add an IR function to the context storage.
# ---
# ctx:  lowering context
# func: IR function to add
# ret:  true on success, false on failure
fun add_ir_function(ctx: *LowerContext, func: *ir.IRFunction) bool {
    if (ctx == nil || func == nil) {
        ret false;
    }

    # grow array if needed
    if (ctx.ir_func_count >= ctx.ir_func_cap) {
        var new_cap: i32 = 16;
        if (ctx.ir_func_cap > 0) {
            new_cap = ctx.ir_func_cap * 2;
        }

        val r: Result[**ir.IRFunction, allocator.AllocError] = ctx.alloc.resize[*ir.IRFunction](
            ctx.ir_funcs, ctx.ir_func_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret false;
        }

        ctx.ir_funcs = r.unwrap_ok();
        ctx.ir_func_cap = new_cap;
    }

    ctx.ir_funcs[ctx.ir_func_count] = func;
    ctx.ir_func_count = ctx.ir_func_count + 1;

    ret true;
}

# hash_name: FNV-1a hash of a null-terminated string.
# ---
# name: string to hash
# ret:  32-bit hash value
fun hash_name(name: str) u32 {
    var h: u32 = 2166136261;
    var i: usize = 0;
    for (name[i] != 0) {
        h = h ^ name[i]::u32;
        h = h * 16777619;
        i = i + 1;
    }
    ret h;
}

# local_hash_insert: insert a local variable index into the hash table.
# ---
# ctx: lowering context
# name: variable name
# idx:  index in local_vars array
fun local_hash_insert(ctx: *LowerContext, name: str, idx: i32) {
    if (ctx.local_hash == nil || ctx.local_hash_cap == 0) {
        ret;
    }

    val mask: u32 = (ctx.local_hash_cap - 1)::u32;
    var slot: u32 = hash_name(name) & mask;

    for (true) {
        val entry: i32 = ctx.local_hash[slot::usize];
        if (entry < 0) {
            # empty slot — insert here
            ctx.local_hash[slot::usize] = idx;
            ret;
        }
        # if existing entry has the same name, overwrite (re-declaration)
        if (ctx.local_vars[entry::usize].name != nil && ctx.local_vars[entry::usize].name.equals(name)) {
            ctx.local_hash[slot::usize] = idx;
            ret;
        }
        slot = (slot + 1) & mask;
    }
}

# local_hash_grow: grow and rehash the local variable hash table.
# ---
# ctx: lowering context
fun local_hash_grow(ctx: *LowerContext) {
    var new_cap: i32 = 16;
    if (ctx.local_hash_cap > 0) {
        new_cap = ctx.local_hash_cap * 2;
    }

    val r: Result[*i32, allocator.AllocError] = ctx.alloc.resize[i32](
        nil, 0, new_cap::usize
    );
    if (r.is_err()) {
        ret;
    }

    val old_hash: *i32 = ctx.local_hash;
    val old_cap: i32 = ctx.local_hash_cap;

    ctx.local_hash = r.unwrap_ok();
    ctx.local_hash_cap = new_cap;

    # fill with -1 (empty)
    var j: i32 = 0;
    for (j < new_cap) {
        ctx.local_hash[j::usize] = -1;
        j = j + 1;
    }

    # rehash existing entries
    var k: i32 = 0;
    for (k < ctx.local_count) {
        if (ctx.local_vars[k::usize].name != nil) {
            local_hash_insert(ctx, ctx.local_vars[k::usize].name, k);
        }
        k = k + 1;
    }
}

# local_hash_clear: reset the hash table for a new function.
# ---
# ctx: lowering context
fun local_hash_clear(ctx: *LowerContext) {
    var j: i32 = 0;
    for (j < ctx.local_hash_cap) {
        ctx.local_hash[j::usize] = -1;
        j = j + 1;
    }
}

# add_local_var: add a local variable to the context.
# ---
# ctx:   lowering context
# name:  variable name
# size:  size in bytes
# ret:   stack offset for the variable
fun add_local_var(ctx: *LowerContext, name: str, size: usize, var_ty: *ty.Type) i32 {
    if (ctx == nil || ctx.alloc == nil) {
        ret 0;
    }

    # align size to stack alignment
    var aligned_size: usize = size;
    if (aligned_size % ctx.stack_align != 0) {
        aligned_size = aligned_size + (ctx.stack_align - (aligned_size % ctx.stack_align));
    }

    # grow array if needed
    if (ctx.local_count >= ctx.local_cap) {
        var new_cap: i32 = 8;
        if (ctx.local_cap > 0) {
            new_cap = ctx.local_cap * 2;
        }

        val r: Result[*LocalVar, allocator.AllocError] = ctx.alloc.resize[LocalVar](
            ctx.local_vars, ctx.local_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret 0;
        }

        ctx.local_vars = r.unwrap_ok();
        ctx.local_cap = new_cap;
    }

    # allocate stack space (stack grows down)
    ctx.stack_offset = ctx.stack_offset - aligned_size::i32;

    # grow hash table if load factor > 50%
    if (ctx.local_count * 2 >= ctx.local_hash_cap) {
        local_hash_grow(ctx);
    }

    # add to locals array
    val idx: i32 = ctx.local_count;
    ctx.local_vars[idx].name = name;
    ctx.local_vars[idx].offset = ctx.stack_offset;
    ctx.local_vars[idx].size = size;
    ctx.local_vars[idx].ty = var_ty;
    ctx.local_count = ctx.local_count + 1;

    # insert into hash table
    local_hash_insert(ctx, name, idx);

    ret ctx.stack_offset;
}

# find_local_var: find a local variable by name.
# ---
# ctx:  lowering context
# name: variable name to find
# ret:  index in local_vars array, or -1 if not found
fun find_local_var(ctx: *LowerContext, name: str) i32 {
    if (ctx == nil || ctx.local_vars == nil || name == nil) {
        ret -1;
    }

    # use hash table for O(1) average lookup
    if (ctx.local_hash != nil && ctx.local_hash_cap > 0) {
        val mask: u32 = (ctx.local_hash_cap - 1)::u32;
        var slot: u32 = hash_name(name) & mask;

        for (true) {
            val entry: i32 = ctx.local_hash[slot::usize];
            if (entry < 0) {
                ret -1;
            }
            if (ctx.local_vars[entry::usize].name != nil && ctx.local_vars[entry::usize].name.equals(name)) {
                ret entry;
            }
            slot = (slot + 1) & mask;
        }
    }

    # fallback: linear scan (should not reach here after first add)
    var i: i32 = ctx.local_count - 1;
    for (i >= 0) {
        if (ctx.local_vars[i].name != nil && ctx.local_vars[i].name.equals(name)) {
            ret i;
        }
        i = i - 1;
    }

    ret -1;
}

# get_local_var_offset: get the stack offset for a local variable.
# ---
# ctx:  lowering context
# idx:  index from find_local_var
# ret:  stack offset (negative for locals)
fun get_local_var_offset(ctx: *LowerContext, idx: i32) i32 {
    if (ctx == nil || idx < 0 || idx >= ctx.local_count) {
        ret 0;
    }
    ret ctx.local_vars[idx].offset;
}

# defer_statement: add a statement to the deferred list.
# ---
# ctx:  lowering context
# stmt: statement to defer (typically a fin statement)
# ret:  none
fun defer_statement(ctx: *LowerContext, stmt: *ast.Node) {
    if (ctx == nil || ctx.alloc == nil || stmt == nil) {
        ret;
    }

    # grow array if needed
    if (ctx.deferred_count >= ctx.deferred_cap) {
        var new_cap: i32 = 8;
        if (ctx.deferred_cap > 0) {
            new_cap = ctx.deferred_cap * 2;
        }

        val r: Result[**ast.Node, allocator.AllocError] = ctx.alloc.resize[*ast.Node](
            ctx.deferred, ctx.deferred_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret;
        }

        ctx.deferred = r.unwrap_ok();
        ctx.deferred_cap = new_cap;
    }

    # add to deferred array
    ctx.deferred[ctx.deferred_count] = stmt;
    ctx.deferred_count = ctx.deferred_count + 1;
}

# emit_deferred_from: emit deferred statements from given index to current.
# ---
# ctx:        lowering context
# from_index: starting index in deferred stack
# ret:        none
pub fun emit_deferred_from(ctx: *LowerContext, from_index: i32) {
    if (ctx == nil || ctx.deferred == nil) {
        ret;
    }

    # emit in reverse order (LIFO)
    var i: i32 = ctx.deferred_count - 1;
    for (i >= from_index) {
        val node: *ast.Node = ctx.deferred[i];
        if (node != nil) {
            lower_stmt(ctx, node);
        }
        i = i - 1;
    }
}

# push_loop_defer_mark: mark current deferred stack depth when entering a loop.
# ---
# ctx: lowering context
# ret: none
pub fun push_loop_defer_mark(ctx: *LowerContext) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }

    if (ctx.loop_mark_count >= ctx.loop_mark_cap) {
        var new_cap: i32 = 8;
        if (ctx.loop_mark_cap > 0) {
            new_cap = ctx.loop_mark_cap * 2;
        }

        val r: Result[*i32, allocator.AllocError] = ctx.alloc.resize[i32](
            ctx.loop_defer_marks, ctx.loop_mark_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret;
        }

        ctx.loop_defer_marks = r.unwrap_ok();
        ctx.loop_mark_cap = new_cap;
    }

    ctx.loop_defer_marks[ctx.loop_mark_count] = ctx.deferred_count;
    ctx.loop_mark_count = ctx.loop_mark_count + 1;
}

# pop_loop_defer_mark: pop the defer mark stack when leaving a loop.
# ---
# ctx: lowering context
# ret: the deferred count at loop entry (for emit_deferred_from)
pub fun pop_loop_defer_mark(ctx: *LowerContext) i32 {
    if (ctx == nil || ctx.loop_mark_count <= 0) {
        ret 0;
    }

    ctx.loop_mark_count = ctx.loop_mark_count - 1;
    ret ctx.loop_defer_marks[ctx.loop_mark_count];
}

# new_vreg: allocate a new virtual register.
# ---
# ctx:  lowering context
# size: register size in bytes
# ret:  new virtual register number
pub fun new_vreg(ctx: *LowerContext, size: usize) i32 {
    if (ctx == nil) {
        ret 0;
    }

    val reg: i32 = ctx.vreg_next;
    ctx.vreg_next = ctx.vreg_next + 1;
    ret reg;
}

# new_label: create a new unique label.
# ---
# ctx:    lowering context
# prefix: label prefix string
# ret:    new label string
pub fun new_label(ctx: *LowerContext, prefix: str) str {
    if (ctx == nil || ctx.alloc == nil) {
        ret nil;
    }

    # create label name: prefix + counter
    # for now, use a simple numbered scheme
    ctx.label_counter = ctx.label_counter + 1;

    # allocate buffer for label name
    # format: prefix + "." + number (estimate 16 chars max for number)
    var prefix_len: usize = 0;
    if (prefix != nil) {
        prefix_len = prefix.len();
    }
    val buf_size: usize = prefix_len + 20;  # prefix + "." + number + null

    val r: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](buf_size);
    if (r.is_err()) {
        ret nil;
    }

    val buf: *u8 = r.unwrap_ok();

    # copy prefix
    var i: usize = 0;
    for (i < prefix_len) {
        buf[i] = prefix[i];
        i = i + 1;
    }

    # add "."
    if (prefix_len > 0) {
        buf[prefix_len] = '.';
        i = prefix_len + 1;
    }

    # convert counter to string (manual itoa)
    val num: i32 = ctx.label_counter;
    var n: i32 = num;
    var digits: i32 = 0;

    # count digits
    if (n == 0) {
        digits = 1;
    }
    for (n > 0) {
        digits = digits + 1;
        n = n / 10;
    }

    # write digits in reverse order
    n = num;
    var j: i32 = digits - 1;
    for (j >= 0) {
        val digit: u8 = (n % 10)::u8 + '0'::u8;
        buf[i + j::usize] = digit;
        n = n / 10;
        j = j - 1;
    }

    # add null terminator
    buf[i + digits::usize] = 0;

    ret buf::str;
}

# types_match: compare two types for logical equality.
# Uses pointer equality first, then falls back to structural comparison.
fun types_match(a: *ty.Type, b: *ty.Type) bool {
    if (a == b) { ret true; }
    if (a == nil || b == nil) { ret false; }
    if (a.kind != b.kind) { ret false; }

    # for pointer/ref types, compare inner types recursively
    if (a.kind == ty.TY_PTR || a.kind == ty.TY_POINTER) {
        ret types_match(a.inner, b.inner);
    }

    # for named types (records, unions, enums), compare by name
    if (a.name != nil && b.name != nil) {
        ret a.name.equals(b.name);
    }

    # if one has name and other doesn't, not a match
    if (a.name != nil || b.name != nil) {
        ret false;
    }

    # both unnamed: primitives with same kind are equal,
    # but anonymous composites need size match too
    if (a.kind == ty.TY_RECORD || a.kind == ty.TY_UNION) {
        ret a.size == b.size;
    }
    ret true;
}

# find_instantiated_type: search all types in the context for an instantiated type
# matching the given base name and generic arguments.
# ---
# ctx:       lowering context
# base_name: name of the generic type (e.g., "Result")
# args:      array of resolved concrete type arguments
# arg_count: number of arguments
# ret:       matching instantiated Type, or nil
fun find_instantiated_type(ctx: *LowerContext, base_name: str, args: **ty.Type, arg_count: i32) *ty.Type {
    if (ctx == nil || ctx.types == nil || base_name == nil || args == nil || arg_count <= 0) {
        ret nil;
    }

    # iterate all types in the context to find a matching instantiation
    var ti: i32 = 0;
    for (ti < ctx.types.type_count) {
        val t: *ty.Type = ctx.types.types[ti];
        if (t != nil && t.name != nil && t.name.equals(base_name)) {
            if (t.generic_arg_count == arg_count && t.generic_args != nil) {
                # check if all generic args match
                var all_match: bool = true;
                var ai: i32 = 0;
                for (ai < arg_count) {
                    if (!types_match(t.generic_args[ai], args[ai])) {
                        all_match = false;
                    }
                    ai = ai + 1;
                }
                if (all_match) {
                    ret t;
                }
            }
        }
        ti = ti + 1;
    }

    ret nil;
}

# resolve_type_annotation: resolve a type from an AST type annotation node.
# ---
# ctx:       lowering context
# type_node: type annotation AST node (NODE_TYPE_NAME, NODE_TYPE_PTR, etc.)
# ret:       resolved Type or nil
fun resolve_type_annotation(ctx: *LowerContext, type_node: *ast.Node) *ty.Type {
    if (ctx == nil || type_node == nil) {
        ret nil;
    }

    if (type_node.kind == ast.NODE_TYPE_NAME) {
        val type_name: str = type_node.info.type_name.path;
        if (type_name == nil) {
            ret nil;
        }

        # check type bindings first (for generic instantiation lowering)
        if (ctx.type_binding_count > 0 && ctx.type_binding_names != nil) {
            var tbi: i32 = 0;
            for (tbi < ctx.type_binding_count) {
                if (ctx.type_binding_names[tbi] != nil && ctx.type_binding_names[tbi].equals(type_name)) {
                    ret ctx.type_binding_types[tbi];
                }
                tbi = tbi + 1;
            }
        }

        # handle parameterized types like Result[T, E] — resolve args through
        # type bindings and find the matching instantiated type
        val rta_args_node: *ast.Node = type_node.info.type_name.args;
        if (rta_args_node != nil && ctx.type_binding_count > 0 &&
            rta_args_node.kind == ast.NODE_GENERIC) {
            val rta_args_list: *ast.List = rta_args_node.info.generic_node.args;
            if (rta_args_list != nil && rta_args_list.count > 0) {
                var rta_resolved: [8]*ty.Type;
                var rta_count: i32 = 0;
                var rta_ok: bool = true;
                var rta_i: i32 = 0;
                for (rta_i < rta_args_list.count && rta_i < 8) {
                    val rta_arg: *ast.Node = rta_args_list.nodes[rta_i];
                    if (rta_arg != nil) {
                        val rta_rt: *ty.Type = resolve_type_annotation(ctx, rta_arg);
                        if (rta_rt != nil) {
                            rta_resolved[rta_count] = rta_rt;
                            rta_count = rta_count + 1;
                        } or {
                            rta_ok = false;
                        }
                    }
                    rta_i = rta_i + 1;
                }
                if (rta_ok && rta_count > 0) {
                    val rta_found: *ty.Type = find_instantiated_type(ctx, type_name, ?rta_resolved[0], rta_count);
                    if (rta_found != nil) {
                        ret rta_found;
                    }
                }
            }
        }

        # handle primitive type names that may not be in the symbol table
        # or may be aliased (e.g., "str" is defined as &u8 but we need TY_STR)
        if (ctx.types != nil) {
            var prim_kind: i32 = -1;
            if (type_name.equals("u8"))    { prim_kind = ty.TY_U8::i32; }
            if (type_name.equals("u16"))   { prim_kind = ty.TY_U16::i32; }
            if (type_name.equals("u32"))   { prim_kind = ty.TY_U32::i32; }
            if (type_name.equals("u64"))   { prim_kind = ty.TY_U64::i32; }
            if (type_name.equals("i8"))    { prim_kind = ty.TY_I8::i32; }
            if (type_name.equals("i16"))   { prim_kind = ty.TY_I16::i32; }
            if (type_name.equals("i32"))   { prim_kind = ty.TY_I32::i32; }
            if (type_name.equals("i64"))   { prim_kind = ty.TY_I64::i32; }
            if (type_name.equals("f32"))   { prim_kind = ty.TY_F32::i32; }
            if (type_name.equals("f64"))   { prim_kind = ty.TY_F64::i32; }
            if (type_name.equals("bool"))  { prim_kind = ty.TY_BOOL::i32; }
            if (type_name.equals("usize")) { prim_kind = ty.TY_USIZE::i32; }
            if (type_name.equals("isize")) { prim_kind = ty.TY_ISIZE::i32; }
            if (type_name.equals("str"))   { prim_kind = ty.TY_STR::i32; }
            if (type_name.equals("ptr"))   { prim_kind = ty.TY_PTR::i32; }
            if (prim_kind >= 0) {
                var pti: i32 = 0;
                for (pti < ctx.types.type_count) {
                    val pt: *ty.Type = ctx.types.types[pti];
                    if (pt != nil && pt.kind == prim_kind::u8) {
                        ret pt;
                    }
                    pti = pti + 1;
                }
            }
        }

        # check for module-qualified type name (e.g., "ir.IRFunction")
        if (ctx.current_sema_mod != nil) {
            var dot_pos: usize = 0;
            var has_dot: bool = false;
            var di: usize = 0;
            val name_len: usize = type_name.len();
            for (di < name_len) {
                if (type_name[di] == '.') {
                    dot_pos = di;
                    has_dot = true;
                    brk;
                }
                di = di + 1;
            }
            if (has_dot && dot_pos > 0) {
                # split: alias = type_name[0..dot_pos], local_name = type_name[dot_pos+1..]
                var alias_entry: *sema.ModuleAlias = ctx.current_sema_mod.aliases;
                for (alias_entry != nil) {
                    if (alias_entry.alias != nil) {
                        val alias_len: usize = alias_entry.alias.len();
                        if (alias_len == dot_pos) {
                            var amatch: bool = true;
                            var ai: usize = 0;
                            for (ai < dot_pos) {
                                if (type_name[ai] != alias_entry.alias[ai]) {
                                    amatch = false;
                                    brk;
                                }
                                ai = ai + 1;
                            }
                            if (amatch && alias_entry.module != nil && alias_entry.module.table != nil) {
                                val local_start: usize = dot_pos + 1;
                                val local_len: usize = name_len - local_start;
                                val root: *symbol.Scope = alias_entry.module.table.root_scope();
                                if (root != nil) {
                                    var si: i32 = 0;
                                    for (si < root.symbol_count) {
                                        val ts: *symbol.Symbol = ?root.symbols[si::usize];
                                        if (ts != nil && ts.name != nil) {
                                            val ts_len: usize = ts.name.len();
                                            if (ts_len == local_len) {
                                                var tmatch: bool = true;
                                                var ti: usize = 0;
                                                for (ti < local_len) {
                                                    if (type_name[local_start + ti] != ts.name[ti]) {
                                                        tmatch = false;
                                                        brk;
                                                    }
                                                    ti = ti + 1;
                                                }
                                                if (tmatch && (ts.kind == symbol.SYM_TYPE ||
                                                               ts.kind == symbol.SYM_REC ||
                                                               ts.kind == symbol.SYM_UNI)) {
                                                    if (ts.resolved_type != nil) {
                                                        ret ts.resolved_type;
                                                    }
                                                }
                                            }
                                        }
                                        si = si + 1;
                                    }
                                }
                                brk; # found matching alias, stop searching
                            }
                        }
                    }
                    alias_entry = alias_entry.next;
                }
            }
        }

        # check if this type name has generic args (e.g., Result[T, E])
        val generic_args_node: *ast.Node = type_node.info.type_name.args;
        if (generic_args_node != nil && generic_args_node.kind == ast.NODE_GENERIC) {
            # resolve each generic arg (they might be bound type params)
            val gargs_list: *ast.List = generic_args_node.info.generic_node.args;
            if (gargs_list != nil && gargs_list.count > 0) {
                # first resolve all args
                var resolved_args: [8]*ty.Type;
                var all_resolved: bool = true;
                var gi: i32 = 0;
                for (gi < gargs_list.count && gi < 8) {
                    val garg: *ast.Node = gargs_list.nodes[gi];
                    if (garg != nil) {
                        resolved_args[gi] = resolve_type_annotation(ctx, garg);
                        if (resolved_args[gi] == nil) {
                            all_resolved = false;
                        }
                    } or {
                        all_resolved = false;
                    }
                    gi = gi + 1;
                }

                # if all args resolved, instantiate the generic type
                if (all_resolved) {
                    # look up the base type symbol
                    var base_sym: *symbol.Symbol = nil;
                    if (ctx.symbols != nil) {
                        val bs_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(type_name);
                        if (bs_opt.is_some()) {
                            base_sym = bs_opt.unwrap();
                        }
                    }
                    if (base_sym == nil) {
                        base_sym = lookup_symbol_in_imports(ctx, type_name);
                    }
                    if (base_sym != nil && base_sym.is_generic && base_sym.decl_node != nil) {
                        val inst_ty: *ty.Type = find_instantiated_type(ctx, type_name, ?resolved_args[0], gargs_list.count);
                        if (inst_ty != nil) {
                            ret inst_ty;
                        }
                    }
                }
            }
        }

        # look up in current module's symbol table
        if (ctx.symbols != nil) {
            val rta_sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(type_name);
            if (rta_sym_opt.is_some()) {
                val rta_sym: *symbol.Symbol = rta_sym_opt.unwrap();
                if (rta_sym.resolved_type != nil) {
                    ret rta_sym.resolved_type;
                }
            }
        }

        # look up in imported modules
        val rta_imp_sym: *symbol.Symbol = lookup_symbol_in_imports(ctx, type_name);
        if (rta_imp_sym != nil && rta_imp_sym.resolved_type != nil) {
            ret rta_imp_sym.resolved_type;
        }

        ret nil;
    }

    if (type_node.kind == ast.NODE_TYPE_PTR || type_node.kind == ast.NODE_TYPE_REF) {
        val inner_node: *ast.Node = type_node.info.type_ptr.inner;
        if (inner_node != nil) {
            val inner_ty: *ty.Type = resolve_type_annotation(ctx, inner_node);
            if (inner_ty != nil && ctx.types != nil) {
                val ptr_res: Result[*ty.Type, str] = ty.pointer_type(ctx.types, inner_ty, true);
                if (ptr_res.is_ok()) {
                    ret ptr_res.unwrap_ok();
                }
            }
        }
        ret nil;
    }

    ret nil;
}

# get_receiver_type_name: extract base type name from method receiver.
# ---
# receiver: receiver parameter node
# ret:      base type name (e.g., "Writer") or nil
fun get_receiver_type_name(receiver: *ast.Node) str {
    if (receiver == nil) {
        ret nil;
    }

    # receiver is NODE_PARAM, its type is in field_decl.type_node
    var recv_type: *ast.Node = receiver.info.field_decl.type_node;
    if (recv_type == nil) {
        ret nil;
    }

    # unwrap pointer/ref types
    for (recv_type != nil && (recv_type.kind == ast.NODE_TYPE_PTR || recv_type.kind == ast.NODE_TYPE_REF)) {
        recv_type = recv_type.info.type_ptr.inner;
    }

    if (recv_type != nil && recv_type.kind == ast.NODE_TYPE_NAME) {
        ret recv_type.info.type_name.path;
    }

    ret nil;
}

# frame_mem: create a memory operand for a stack slot.
# ---
# ctx:    lowering context
# offset: stack offset from frame pointer
# size:   size in bytes
# ret:    memory operand as IRValue
fun frame_mem(ctx: *LowerContext, offset: i32, size: usize) ir.IRValue {
    var v: ir.IRValue;
    v.kind = ir.VAL_MEM;
    v.reg = 0;
    v.imm = 0;
    v.offset = offset::i64;
    v.base_reg = ir.RBP;
    v.index_reg = -1;
    v.scale = 1;
    v.label = nil;
    v.size = size;
    ret v;
}

# emit_instr: emit an instruction to the current block.
# ---
# ctx:   lowering context
# op:    operation code
# dst:   destination operand
# src1:  first source operand
# src2:  second source operand
# cond:  condition code (for conditional ops)
# ret:   index of emitted instruction
fun emit_instr(ctx: *LowerContext, op: ir.IROp, dst: ir.IRValue, src1: ir.IRValue, src2: ir.IRValue, cond: i32) i32 {
    if (ctx == nil || ctx.current_block == nil) {
        ret -1;
    }

    var instr: ir.Instr;
    instr.op = op;
    instr.dst = dst;
    instr.src1 = src1;
    instr.src2 = src2;
    instr.cond = cond::u8;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr.op, instr.dst, instr.src1, instr.src2, instr.cond);
    ret ctx.current_block.instr_count - 1;
}

# emit_label: emit a label instruction.
# ---
# ctx:   lowering context
# label: label name
# ret:   none
fun emit_label(ctx: *LowerContext, label: str) {
    if (ctx == nil || ctx.current_block == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_label: ir.OP_LABEL};
    instr.dst = ir.make_label(label);
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_mov: emit a move instruction.
# ---
# ctx:  lowering context
# dst:  destination
# src:  source
# size: size in bytes
# ret:  none
fun emit_mov(ctx: *LowerContext, dst: ir.IRValue, src: ir.IRValue, size: usize) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_mov: ir.OP_MOV};
    instr.dst = dst;
    instr.src1 = src;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_load: emit a load instruction.
# ---
# ctx:    lowering context
# addr:   memory address to load from
# size:   size in bytes
# ret:    destination register value
fun emit_load(ctx: *LowerContext, addr: ir.IRValue, size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    val dst_reg: i32 = new_vreg(ctx, size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, size);

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_load: ir.OP_LOAD};
    instr.dst = dst;
    instr.src1 = addr;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);

    ret dst;
}

# emit_load_signed: load a value with sign-extension for small types (i8, i16).
# passes a flag via src2 to tell isel to use MOVSX instead of MOVZX.
fun emit_load_signed(ctx: *LowerContext, addr: ir.IRValue, size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    val dst_reg: i32 = new_vreg(ctx, size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, size);

    # src2 = imm(1) signals signed load to isel
    ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                  dst, addr, ir.make_imm(1, 1), ir.CC_NONE);

    ret dst;
}

# load_ptr_if_needed: for pointer/str types, load the pointer value from the address.
# ---
# ctx:    lowering context
# addr:   address operand (may be memory or register)
# base_ty: type of the base expression
# ret:    loaded pointer value if pointer/str type, otherwise the original addr
fun load_ptr_if_needed(ctx: *LowerContext, addr: ir.IRValue, base_ty: *ty.Type) ir.IRValue {
    if (base_ty != nil && (base_ty.kind == ty.TY_POINTER || base_ty.kind == ty.TY_STR)) {
        ret emit_load(ctx, addr, ctx.ptr_size);
    }
    ret addr;
}

# emit_store: emit a store instruction.
# ---
# ctx:    lowering context
# addr:   memory address to store to
# src:    value to store
# ret:    none
fun emit_store(ctx: *LowerContext, addr: ir.IRValue, src: ir.IRValue) {
    if (ctx == nil) {
        ret;
    }

    # aggregate store: source is a register holding a pointer to aggregate data,
    # destination is a memory operand with size > ptr_size. Copy addr.size bytes.
    if (src.kind == ir.VAL_REG && addr.kind == ir.VAL_MEM && addr.size > ctx.ptr_size) {
        val agg_dst_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val agg_dst_ptr: ir.IRValue = ir.make_reg(agg_dst_reg, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      agg_dst_ptr, addr, ir.make_none(), ir.CC_NONE);

        val agg_src_reg: i32 = src.reg;
        val agg_total: i32 = addr.size::i32;
        var agg_off: i32 = 0;
        for (agg_off < agg_total) {
            var agg_chunk: usize = 8;
            if ((agg_total - agg_off)::usize < 8) {
                agg_chunk = (agg_total - agg_off)::usize;
            }
            val agg_tmp_reg: i32 = new_vreg(ctx, agg_chunk);
            val agg_tmp: ir.IRValue = ir.make_reg(agg_tmp_reg, agg_chunk);

            var agg_s: ir.IRValue;
            agg_s.kind = ir.VAL_MEM;
            agg_s.base_reg = agg_src_reg;
            agg_s.offset = agg_off::i64;
            agg_s.size = agg_chunk;
            agg_s.reg = 0;
            agg_s.imm = 0;
            agg_s.index_reg = -1;
            agg_s.scale = 1;
            agg_s.label = nil;

            var agg_d: ir.IRValue;
            agg_d.kind = ir.VAL_MEM;
            agg_d.base_reg = agg_dst_reg;
            agg_d.offset = agg_off::i64;
            agg_d.size = agg_chunk;
            agg_d.reg = 0;
            agg_d.imm = 0;
            agg_d.index_reg = -1;
            agg_d.scale = 1;
            agg_d.label = nil;

            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                          agg_tmp, agg_s, ir.make_none(), ir.CC_NONE);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                          agg_d, agg_tmp, ir.make_none(), ir.CC_NONE);

            agg_off = agg_off + agg_chunk::i32;
        }
        ret;
    }

    # for memory-to-memory copies, emit chunked load/store operations
    # (x86 cannot do direct mem-to-mem moves)
    if (src.kind == ir.VAL_MEM && addr.kind == ir.VAL_MEM && src.size > 0) {
        # LEA source address
        val src_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val src_ptr: ir.IRValue = ir.make_reg(src_reg, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      src_ptr, src, ir.make_none(), ir.CC_NONE);

        # LEA destination address
        val dst_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val dst_ptr: ir.IRValue = ir.make_reg(dst_reg, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      dst_ptr, addr, ir.make_none(), ir.CC_NONE);

        # copy in 8-byte chunks
        val total: i32 = src.size::i32;
        var off: i32 = 0;
        for (off < total) {
            var chunk: usize = 8;
            if ((total - off)::usize < 8) {
                chunk = (total - off)::usize;
            }
            val tmp_reg: i32 = new_vreg(ctx, chunk);
            val tmp: ir.IRValue = ir.make_reg(tmp_reg, chunk);

            var s_mem: ir.IRValue;
            s_mem.kind = ir.VAL_MEM;
            s_mem.base_reg = src_reg;
            s_mem.offset = off::i64;
            s_mem.size = chunk;
            s_mem.reg = 0;
            s_mem.imm = 0;
            s_mem.index_reg = -1;
            s_mem.scale = 1;
            s_mem.label = nil;

            var d_mem: ir.IRValue;
            d_mem.kind = ir.VAL_MEM;
            d_mem.base_reg = dst_reg;
            d_mem.offset = off::i64;
            d_mem.size = chunk;
            d_mem.reg = 0;
            d_mem.imm = 0;
            d_mem.index_reg = -1;
            d_mem.scale = 1;
            d_mem.label = nil;

            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                          tmp, s_mem, ir.make_none(), ir.CC_NONE);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                          d_mem, tmp, ir.make_none(), ir.CC_NONE);

            off = off + chunk::i32;
        }
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_store: ir.OP_STORE};
    instr.dst = addr;  # store uses dst as address
    instr.src1 = src;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_frame_setup: emit stack frame setup instructions.
# ---
# ctx:       lowering context
# frame_size: size of stack frame in bytes
# ret:       none
fun emit_frame_setup(ctx: *LowerContext, frame_size: usize) {
    if (ctx == nil) {
        ret;
    }

    # push rbp
    var push_instr: ir.Instr;
    push_instr.op = ir.IROp{ir_push: ir.OP_PUSH};
    push_instr.dst = ir.make_reg(ir.RBP, ctx.ptr_size);
    push_instr.src1 = ir.make_none();
    push_instr.src2 = ir.make_none();
    push_instr.cond = ir.CC_NONE;
    emit_instr(ctx, push_instr.op, push_instr.dst, push_instr.src1, push_instr.src2, 0);

    # mov rsp, rbp
    var mov_instr: ir.Instr;
    mov_instr.op = ir.IROp{ir_mov: ir.OP_MOV};
    mov_instr.dst = ir.make_reg(ir.RBP, ctx.ptr_size);
    mov_instr.src1 = ir.make_reg(ir.RSP, ctx.ptr_size);
    mov_instr.src2 = ir.make_none();
    mov_instr.cond = ir.CC_NONE;
    emit_instr(ctx, mov_instr.op, mov_instr.dst, mov_instr.src1, mov_instr.src2, 0);

    # sub rsp, frame_size
    var sub_instr: ir.Instr;
    sub_instr.op = ir.IROp{ir_sub: ir.OP_SUB};
    sub_instr.dst = ir.make_reg(ir.RSP, ctx.ptr_size);
    sub_instr.src1 = ir.make_reg(ir.RSP, ctx.ptr_size);
    sub_instr.src2 = ir.make_imm(frame_size::i64, ctx.ptr_size);
    sub_instr.cond = ir.CC_NONE;
    emit_instr(ctx, sub_instr.op, sub_instr.dst, sub_instr.src1, sub_instr.src2, 0);
}

# emit_frame_teardown: emit stack frame teardown instructions.
# ---
# ctx: lowering context
# ret:  none
fun emit_frame_teardown(ctx: *LowerContext) {
    if (ctx == nil) {
        ret;
    }

    # mov rbp, rsp
    var mov_instr: ir.Instr;
    mov_instr.op = ir.IROp{ir_mov: ir.OP_MOV};
    mov_instr.dst = ir.make_reg(ir.RSP, ctx.ptr_size);
    mov_instr.src1 = ir.make_reg(ir.RBP, ctx.ptr_size);
    mov_instr.src2 = ir.make_none();
    mov_instr.cond = ir.CC_NONE;
    emit_instr(ctx, mov_instr.op, mov_instr.dst, mov_instr.src1, mov_instr.src2, 0);

    # pop rbp
    var pop_instr: ir.Instr;
    pop_instr.op = ir.IROp{ir_pop: ir.OP_POP};
    pop_instr.dst = ir.make_reg(ir.RBP, ctx.ptr_size);
    pop_instr.src1 = ir.make_none();
    pop_instr.src2 = ir.make_none();
    pop_instr.cond = ir.CC_NONE;
    emit_instr(ctx, pop_instr.op, pop_instr.dst, pop_instr.src1, pop_instr.src2, 0);
}

# emit_ret: emit a return instruction.
# ---
# ctx: lowering context
# val: value to return (can be none)
# ret: none
fun emit_ret(ctx: *LowerContext, value: ir.IRValue) {
    if (ctx == nil) {
        ret;
    }

    # frame teardown is handled by isel epilogue, just emit ret with value
    var instr: ir.Instr;
    instr.op = ir.IROp{ir_ret: ir.OP_RET};
    instr.dst = value;
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_br: emit an unconditional branch.
# ---
# ctx:   lowering context
# label: target label
# ret:   none
fun emit_br(ctx: *LowerContext, label: str) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_jmp: ir.OP_JMP};
    instr.dst = ir.make_label(label);
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_cond_br: emit a conditional branch.
# ---
# ctx:   lowering context
# cond:  condition code
# label: target label
# ret:   none
fun emit_cond_br(ctx: *LowerContext, cond: i32, label: str) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_jcc: ir.OP_JCC};
    instr.dst = ir.make_label(label);
    instr.src1 = ir.make_none();
    instr.src2 = ir.make_none();
    instr.cond = cond::u8;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, cond);
}

# emit_alu: emit an ALU (arithmetic/logic) instruction.
# ---
# ctx:  lowering context
# op:   operation code (add, sub, mul, etc.)
# dst:  destination register
# src1: first source
# src2: second source
# size: operand size
# ret:  destination value
fun emit_alu(ctx: *LowerContext, op: ir.IROp, dst: ir.IRValue, src1: ir.IRValue, src2: ir.IRValue, size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    var instr: ir.Instr;
    instr.op = op;
    instr.dst = dst;
    instr.src1 = src1;
    instr.src2 = src2;
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);

    ret dst;
}

# emit_cmp: emit a compare instruction.
# ---
# ctx:  lowering context
# src1: first operand
# src2: second operand
# size: operand size
# ret:  none
fun emit_cmp(ctx: *LowerContext, src1: ir.IRValue, src2: ir.IRValue, size: usize) {
    if (ctx == nil) {
        ret;
    }

    var instr: ir.Instr;
    instr.op = ir.IROp{ir_cmp: ir.OP_CMP};
    instr.dst = ir.make_none();
    instr.src1 = src1;
    instr.src2 = src2;
    instr.cond = ir.CC_NONE;

    emit_instr(ctx, instr.op, instr.dst, instr.src1, instr.src2, 0);
}

# emit_call: emit a function call.
# ---
# ctx:        lowering context
# callee:     function name or address
# args:       argument values
# arg_count:  number of arguments
# ret_size:   return value size (0 for void)
# ret:        return value register (or none)
fun emit_call(ctx: *LowerContext, callee: str, args: *ir.IRValue, arg_count: i32, ret_size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    # calculate stack arguments count
    val stack_arg_count: i32 = arg_count - ctx.abi.arg_reg_count;
    var stack_space: i32 = 0;
    if (stack_arg_count > 0) {
        stack_space = stack_arg_count * 8;
        # ensure 16-byte alignment (stack space + return address must be 16-byte aligned)
        if ((stack_space % 16) != 0) {
            stack_space = stack_space + (16 - (stack_space % 16));
        }
    }

    # push stack arguments in reverse order (right to left)
    if (stack_arg_count > 0) {
        var k: i32 = arg_count - 1;
        for (k >= ctx.abi.arg_reg_count) {
            emit_instr(ctx, ir.IROp{ir_push: ir.OP_PUSH}, ir.make_none(), args[k], ir.make_none(), 0);
            k = k - 1;
        }
    }

    # emit register argument moves
    var i: i32 = 0;
    for (i < arg_count && i < ctx.abi.arg_reg_count) {
        val arg_reg: i32 = abi.get_arg_reg(?ctx.abi, i);
        var mov_instr: ir.Instr;
        mov_instr.op = ir.IROp{ir_mov: ir.OP_MOV};
        mov_instr.dst = ir.make_reg(arg_reg, ctx.ptr_size);
        mov_instr.src1 = args[i];
        mov_instr.src2 = ir.make_none();
        mov_instr.cond = ir.CC_NONE;
        emit_instr(ctx, mov_instr.op, mov_instr.dst, mov_instr.src1, mov_instr.src2, 0);
        i = i + 1;
    }

    # emit call instruction
    var call_instr: ir.Instr;
    call_instr.op = ir.IROp{ir_call: ir.OP_CALL};
    call_instr.dst = ir.make_label(callee);
    call_instr.src1 = ir.make_none();
    call_instr.src2 = ir.make_none();
    call_instr.cond = ir.CC_NONE;
    emit_instr(ctx, call_instr.op, call_instr.dst, call_instr.src1, call_instr.src2, 0);

    # clean up stack after call (caller cleans up in SysV x86_64)
    if (stack_arg_count > 0) {
        # add rsp, stack_space
        emit_instr(ctx, ir.IROp{ir_add: ir.OP_ADD},
            ir.make_reg(ir.RSP, ctx.ptr_size),
            ir.make_reg(ir.RSP, ctx.ptr_size),
            ir.make_imm(stack_space::i64, 8), 0);
    }

    # always save RAX to vreg after call - subsequent expressions may clobber RAX,
    # and return type may not be resolved for calls in imported module functions
    var ret_sz: usize = 8;
    if (ret_size > 0) {
        ret_sz = ret_size;
    }
    val result_reg: i32 = new_vreg(ctx, ret_sz);
    val result: ir.IRValue = ir.make_reg(result_reg, ret_sz);
    emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, result, ir.make_reg(ir.RAX, ret_sz), ir.make_none(), 0);
    ret result;
}

# emit_indirect_call: emit an indirect function call through a register.
# ---
# ctx:       lowering context
# fn_ptr:    IRValue containing the function pointer (typically a vreg)
# args:      pointer to array of argument IRValues
# arg_count: number of arguments
# ret_size:  size of return value (0 for void)
# ret:       IRValue containing return value (RAX) or none
fun emit_indirect_call(ctx: *LowerContext, fn_ptr: ir.IRValue, args: *ir.IRValue, arg_count: i32, ret_size: usize) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    # calculate stack arguments count
    val stack_arg_count: i32 = arg_count - ctx.abi.arg_reg_count;
    var stack_space: i32 = 0;
    if (stack_arg_count > 0) {
        stack_space = stack_arg_count * 8;
        if ((stack_space % 16) != 0) {
            stack_space = stack_space + (16 - (stack_space % 16));
        }
    }

    # push stack arguments in reverse order (right to left)
    if (stack_arg_count > 0) {
        var k: i32 = arg_count - 1;
        for (k >= ctx.abi.arg_reg_count) {
            emit_instr(ctx, ir.IROp{ir_push: ir.OP_PUSH}, ir.make_none(), args[k], ir.make_none(), 0);
            k = k - 1;
        }
    }

    # emit register argument moves
    var i: i32 = 0;
    for (i < arg_count && i < ctx.abi.arg_reg_count) {
        val arg_reg: i32 = abi.get_arg_reg(?ctx.abi, i);
        emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, ir.make_reg(arg_reg, ctx.ptr_size), args[i], ir.make_none(), 0);
        i = i + 1;
    }

    # emit indirect call instruction (src1 = fn_ptr register)
    emit_instr(ctx, ir.IROp{ir_call: ir.OP_CALL}, ir.make_none(), fn_ptr, ir.make_none(), 0);

    # clean up stack after call
    if (stack_arg_count > 0) {
        emit_instr(ctx, ir.IROp{ir_add: ir.OP_ADD},
            ir.make_reg(ir.RSP, ctx.ptr_size),
            ir.make_reg(ir.RSP, ctx.ptr_size),
            ir.make_imm(stack_space::i64, 8), 0);
    }

    # always save RAX to vreg after call - subsequent expressions may clobber RAX,
    # and return type may not be resolved for calls in imported module functions
    var ic_ret_sz: usize = 8;
    if (ret_size > 0) {
        ic_ret_sz = ret_size;
    }
    val ic_result_reg: i32 = new_vreg(ctx, ic_ret_sz);
    val ic_result: ir.IRValue = ir.make_reg(ic_result_reg, ic_ret_sz);
    emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, ic_result, ir.make_reg(ir.RAX, ic_ret_sz), ir.make_none(), 0);
    ret ic_result;
}

# emit_sycall: emit a system call instruction.
# ---
# ctx:  lowering context
# num:  syscall number
# args: syscall arguments (up to 6)
# ret:  return value in rax
fun emit_syscall(ctx: *LowerContext, num: i64, args: *ir.IRValue, arg_count: i32) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    # emit argument moves to syscall registers
    # syscall register order: RDI, RSI, RDX, R10, R8, R9
    
    var i: i32 = 0;
    for (i < arg_count && i < 6) {
        var mov_arg: ir.Instr;
        mov_arg.op = ir.IROp{ir_mov: ir.OP_MOV};
        
        # select syscall register based on index
        var syscall_reg: i32 = ir.R9;  # default
        if (i == 0) {
            syscall_reg = ir.RDI;
        }
        if (i == 1) {
            syscall_reg = ir.RSI;
        }
        if (i == 2) {
            syscall_reg = ir.RDX;
        }
        if (i == 3) {
            syscall_reg = ir.R10;
        }
        if (i == 4) {
            syscall_reg = ir.R8;
        }
        if (i == 5) {
            syscall_reg = ir.R9;
        }
        
        mov_arg.dst = ir.make_reg(syscall_reg, 8);
        mov_arg.src1 = args[i];
        mov_arg.src2 = ir.make_none();
        mov_arg.cond = ir.CC_NONE;
        emit_instr(ctx, mov_arg.op, mov_arg.dst, mov_arg.src1, mov_arg.src2, 0);
        i = i + 1;
    }

    # move syscall number to rax
    var mov_num: ir.Instr;
    mov_num.op = ir.IROp{ir_mov: ir.OP_MOV};
    mov_num.dst = ir.make_reg(0, 8);  # RAX = 0
    mov_num.src1 = ir.make_imm(num, 8);
    mov_num.src2 = ir.make_none();
    mov_num.cond = ir.CC_NONE;
    emit_instr(ctx, mov_num.op, mov_num.dst, mov_num.src1, mov_num.src2, 0);

    # emit syscall instruction
    var syscall_instr: ir.Instr;
    syscall_instr.op = ir.IROp{ir_syscall: ir.OP_SYSCALL};
    syscall_instr.dst = ir.make_none();
    syscall_instr.src1 = ir.make_none();
    syscall_instr.src2 = ir.make_none();
    syscall_instr.cond = ir.CC_NONE;
    emit_instr(ctx, syscall_instr.op, syscall_instr.dst, syscall_instr.src1, syscall_instr.src2, 0);

    # return value in rax - copy to vreg
    val sc_result_reg: i32 = new_vreg(ctx, 8);
    val sc_result: ir.IRValue = ir.make_reg(sc_result_reg, 8);
    emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, sc_result, ir.make_reg(ir.RAX, 8), ir.make_none(), 0);
    ret sc_result;
}

fun emit_syscall_value(ctx: *LowerContext, num_val: ir.IRValue, args: *ir.IRValue, arg_count: i32) ir.IRValue {
    if (ctx == nil) {
        ret ir.make_none();
    }

    # emit argument moves to syscall registers
    # syscall register order: RDI, RSI, RDX, R10, R8, R9
    var i: i32 = 0;
    for (i < arg_count && i < 6) {
        var mov_arg: ir.Instr;
        mov_arg.op = ir.IROp{ir_mov: ir.OP_MOV};

        var syscall_reg: i32 = ir.R9;
        if (i == 0) { syscall_reg = ir.RDI; }
        if (i == 1) { syscall_reg = ir.RSI; }
        if (i == 2) { syscall_reg = ir.RDX; }
        if (i == 3) { syscall_reg = ir.R10; }
        if (i == 4) { syscall_reg = ir.R8; }
        if (i == 5) { syscall_reg = ir.R9; }

        mov_arg.dst = ir.make_reg(syscall_reg, 8);
        mov_arg.src1 = args[i];
        mov_arg.src2 = ir.make_none();
        mov_arg.cond = ir.CC_NONE;
        emit_instr(ctx, mov_arg.op, mov_arg.dst, mov_arg.src1, mov_arg.src2, 0);
        i = i + 1;
    }

    # move syscall number into rax
    if (num_val.kind == ir.VAL_IMM) {
        var mov_num: ir.Instr;
        mov_num.op = ir.IROp{ir_mov: ir.OP_MOV};
        mov_num.dst = ir.make_reg(0, 8);
        mov_num.src1 = num_val;
        mov_num.src2 = ir.make_none();
        mov_num.cond = ir.CC_NONE;
        emit_instr(ctx, mov_num.op, mov_num.dst, mov_num.src1, mov_num.src2, 0);
    } or {
        emit_mov(ctx, ir.make_reg(ir.RAX, 8), num_val, 8);
    }

    # emit syscall instruction
    var syscall_instr: ir.Instr;
    syscall_instr.op = ir.IROp{ir_syscall: ir.OP_SYSCALL};
    syscall_instr.dst = ir.make_none();
    syscall_instr.src1 = ir.make_none();
    syscall_instr.src2 = ir.make_none();
    syscall_instr.cond = ir.CC_NONE;
    emit_instr(ctx, syscall_instr.op, syscall_instr.dst, syscall_instr.src1, syscall_instr.src2, 0);

    val sc2_result_reg: i32 = new_vreg(ctx, 8);
    val sc2_result: ir.IRValue = ir.make_reg(sc2_result_reg, 8);
    emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, sc2_result, ir.make_reg(ir.RAX, 8), ir.make_none(), 0);
    ret sc2_result;
}

# emit_va_start: emit code to initialize a va_list (SysV x86_64 ABI).
# ---
# ctx:  lowering context
# args: argument list (first arg is pointer to va_list)
# ret:  IRValue (none)
fun emit_va_start(ctx: *LowerContext, args: *ast.List) ir.IRValue {
    if (ctx == nil || args == nil || args.count < 1) {
        ret make_none();
    }

    # ap is a pointer to va_list, passed as first argument
    val ap_arg: *ast.Node = args.nodes[0];
    if (ap_arg == nil) {
        ret make_none();
    }

    # lower the ap argument to get a register holding the va_list pointer
    var ap: ir.IRValue = lower_expr(ctx, ap_arg);
    if (ap.kind != ir.VAL_REG) {
        # ensure it's in a register
        val ap_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        emit_mov(ctx, ir.make_reg(ap_reg, ctx.ptr_size), ap, ctx.ptr_size);
        ap = ir.make_reg(ap_reg, ctx.ptr_size);
    }

    # va_list layout (SysV x86_64):
    #   offset 0:  u32 gp_offset
    #   offset 4:  u32 fp_offset
    #   offset 8:  ptr overflow_arg_area
    #   offset 16: ptr reg_save_area

    # gp_offset = va_named_gp * 8
    val gp_off_val: i32 = ctx.va_named_gp * 8;
    val gp_off_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, 0, 4);
    emit_store(ctx, gp_off_mem, ir.make_imm(gp_off_val::i64, 4));

    # fp_offset = 48 + va_named_fp * 16
    val fp_off_val: i32 = 48 + ctx.va_named_fp * 16;
    val fp_off_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, 4, 4);
    emit_store(ctx, fp_off_mem, ir.make_imm(fp_off_val::i64, 4));

    # overflow_arg_area = RBP + 16 + va_named_stack_slots * 8
    # (RBP+0 is saved RBP, RBP+8 is return address, RBP+16 is first stack arg)
    val overflow_off: i32 = 16 + ctx.va_named_stack_slots * 8;
    val overflow_ptr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val overflow_ptr: ir.IRValue = ir.make_reg(overflow_ptr_reg, ctx.ptr_size);
    val overflow_src: ir.IRValue = frame_mem(ctx, overflow_off, ctx.ptr_size);
    emit_instr(ctx, ir.IROp{ir_lea: ir.OP_LEA}, overflow_ptr, overflow_src, ir.make_none(), 0);
    val overflow_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, 8, ctx.ptr_size);
    emit_store(ctx, overflow_mem, overflow_ptr);

    # reg_save_area = RBP + va_reg_save_off
    val regsave_ptr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val regsave_ptr: ir.IRValue = ir.make_reg(regsave_ptr_reg, ctx.ptr_size);
    val regsave_src: ir.IRValue = frame_mem(ctx, ctx.va_reg_save_off, ctx.ptr_size);
    emit_instr(ctx, ir.IROp{ir_lea: ir.OP_LEA}, regsave_ptr, regsave_src, ir.make_none(), 0);
    val regsave_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, 16, ctx.ptr_size);
    emit_store(ctx, regsave_mem, regsave_ptr);

    ret make_none();
}

# emit_va_arg: emit code to fetch the next argument from a va_list.
# ---
# ctx:      lowering context
# args:     argument list (first arg is pointer to va_list)
# arg_type: type of the argument to fetch
# ret:      IRValue containing the fetched argument
fun emit_va_arg(ctx: *LowerContext, args: *ast.List, arg_type: *ty.Type) ir.IRValue {
    if (ctx == nil || args == nil || args.count < 1) {
        ret make_none();
    }

    val ap_arg: *ast.Node = args.nodes[0];
    if (ap_arg == nil) {
        ret make_none();
    }

    # lower the ap argument
    var ap: ir.IRValue = lower_expr(ctx, ap_arg);
    if (ap.kind != ir.VAL_REG) {
        val ap_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        emit_mov(ctx, ir.make_reg(ap_reg, ctx.ptr_size), ap, ctx.ptr_size);
        ap = ir.make_reg(ap_reg, ctx.ptr_size);
    }

    # determine argument size (promote to at least 8 bytes)
    var arg_size: usize = ctx.ptr_size;
    if (arg_type != nil && arg_type.size > 0) {
        arg_size = arg_type.size;
    }
    if (arg_size < ctx.ptr_size) {
        arg_size = ctx.ptr_size;
    }

    # for now, assume all types are GP (not floating-point)
    # threshold for GP is 48 (6 registers * 8 bytes)
    val threshold: i32 = 48;
    val increment: i32 = 8;
    val offset_field: i32 = 0;  # gp_offset at offset 0

    # allocate result register
    val result_reg: i32 = new_vreg(ctx, arg_size);
    val result: ir.IRValue = ir.make_reg(result_reg, arg_size);

    # generate unique labels for branching
    val stack_label: str = new_label(ctx, ".Lva_stack");
    val done_label: str = new_label(ctx, ".Lva_done");

    # load gp_offset (32-bit)
    val off_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val off_64: ir.IRValue = ir.make_reg(off_reg, ctx.ptr_size);
    val off_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, offset_field::i64, 4);
    emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, off_64, off_mem, ir.make_imm(4, 1), 0);

    # compare offset < threshold
    emit_cmp(ctx, off_64, ir.make_imm(threshold::i64, ctx.ptr_size), ctx.ptr_size);
    # jump to stack path if offset >= threshold (i.e., not below)
    emit_cond_br(ctx, ir.CC_AE::i32, stack_label);

    # --- register path ---
    # load reg_save_area pointer
    val regsave_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val regsave: ir.IRValue = ir.make_reg(regsave_reg, ctx.ptr_size);
    val regsave_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, 16, ctx.ptr_size);
    emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, regsave, regsave_mem, ir.make_imm(ctx.ptr_size::i64, 1), 0);

    # compute address = reg_save_area + offset
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, regsave, off_64, ctx.ptr_size);

    # load value from computed address
    val val_mem: ir.IRValue = ir.make_mem(addr_reg, -1, 1, 0, arg_size);
    emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, result, val_mem, ir.make_imm(arg_size::i64, 1), 0);

    # increment offset
    val new_off_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val new_off: ir.IRValue = ir.make_reg(new_off_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, new_off, off_64, ir.make_imm(increment::i64, ctx.ptr_size), ctx.ptr_size);
    # store back (truncate to 32-bit)
    emit_store(ctx, off_mem, new_off);

    # jump to done
    emit_br(ctx, done_label);

    # --- stack path ---
    emit_label(ctx, stack_label);

    # load overflow_arg_area pointer
    val overflow_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val overflow: ir.IRValue = ir.make_reg(overflow_reg, ctx.ptr_size);
    val overflow_mem: ir.IRValue = ir.make_mem(ap.reg, -1, 1, 8, ctx.ptr_size);
    emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, overflow, overflow_mem, ir.make_imm(ctx.ptr_size::i64, 1), 0);

    # load value from overflow_arg_area
    val stack_val_mem: ir.IRValue = ir.make_mem(overflow_reg, -1, 1, 0, arg_size);
    emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, result, stack_val_mem, ir.make_imm(arg_size::i64, 1), 0);

    # increment overflow_arg_area by 8
    val new_overflow_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val new_overflow: ir.IRValue = ir.make_reg(new_overflow_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, new_overflow, overflow, ir.make_imm(8, ctx.ptr_size), ctx.ptr_size);
    emit_store(ctx, overflow_mem, new_overflow);

    # --- done ---
    emit_label(ctx, done_label);

    ret result;
}

# type_is_large_aggregate: check if a type is a large aggregate (>16 bytes).
# ---
# t:        type to check
# ptr_size: pointer size for comparison
# ret:      true if large aggregate
fun type_is_large_aggregate(t: *ty.Type, ptr_size: usize) bool {
    if (t == nil) {
        ret false;
    }

    # records and unions can be large
    if (t.kind == ty.TY_RECORD || t.kind == ty.TY_UNION) {
        if (t.size > ptr_size) {
            ret true;
        }
    }

    # arrays are always aggregates
    if (t.kind == ty.TY_ARRAY) {
        ret true;
    }

    ret false;
}

# --- value and operand helpers ---

# make_lit_int: create an integer literal value.
# ---
# alloc: allocator
# val:   integer value
# ret:   IRValue
fun make_lit_int(alloc: *allocator.Allocator, value: i64) ir.IRValue {
    ret ir.make_imm(value, 8);
}

# make_none: create a "none" value.
# ---
# ret: IRValue representing none
fun make_none() ir.IRValue {
    var v: ir.IRValue;
    v.kind = ir.VAL_NONE;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = nil;
    v.size = 0;
    ret v;
}

# --- expression lowering ---

# lower_expr: lower an expression node to IR.
# ---
# ctx:  lowering context
# node: expression AST node
# ret:  IRValue representing the expression result
pub fun lower_expr(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    # dispatch based on node kind
    if (node.kind == ast.NODE_EXPR_LIT_INT) {
        val int_val: i64 = parse_int_str(node.info.lit_expr.text);
        ret ir.make_imm(int_val, 8);
    }

    if (node.kind == ast.NODE_EXPR_LIT_CHAR) {
        val char_text: str = node.info.lit_expr.text;
        var char_val: i64 = 0;
        if (char_text != nil) {
            # text is the raw token text including quotes, e.g. 'A' or '\n'
            # char_text[0] is the opening quote, char_text[1] is the char or backslash
            if (char_text[1] == '\\') {
                # escape sequence
                val esc: u8 = char_text[2];
                if (esc == 'n') { char_val = 10; }
                or (esc == 't') { char_val = 9; }
                or (esc == 'r') { char_val = 13; }
                or (esc == '0') { char_val = 0; }
                or (esc == '\\') { char_val = 92; }
                or (esc == '\'') { char_val = 39; }
                or (esc == '"') { char_val = 34; }
                or { char_val = esc::i64; }
            } or {
                char_val = char_text[1]::i64;
            }
        }
        ret ir.make_imm(char_val, 8);
    }

    if (node.kind == ast.NODE_EXPR_LIT_STR) {
        ret lower_string_lit(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_IDENT) {
        ret lower_identifier(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_BINARY) {
        ret lower_binary(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_UNARY) {
        ret lower_unary(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_CALL) {
        # check for comptime call: $size_of(T), $align_of(T)
        val ct_callee: *ast.Node = node.info.call_expr.callee;
        if (ct_callee != nil && ct_callee.kind == ast.NODE_COMPTIME) {
            val ct_ident: *ast.Node = ct_callee.info.wrapper.inner;
            val ct_args: *ast.List = node.info.call_expr.args;
            if (ct_ident != nil && ct_ident.kind == ast.NODE_EXPR_IDENT &&
                ct_args != nil && ct_args.count > 0) {
                val ct_name: str = ct_ident.info.ident_expr.name;
                val ct_arg: *ast.Node = ct_args.nodes[0];
                if (ct_name != nil && ct_arg != nil) {
                    var ct_type: *ty.Type = nil;

                    # try resolve_type_annotation (handles NODE_TYPE_NAME)
                    ct_type = resolve_type_annotation(ctx, ct_arg);

                    # fallback: if arg is NODE_EXPR_IDENT, check type bindings
                    if (ct_type == nil && ct_arg.kind == ast.NODE_EXPR_IDENT) {
                        val ct_type_name: str = ct_arg.info.ident_expr.name;
                        if (ct_type_name != nil && ctx.type_binding_count > 0 &&
                            ctx.type_binding_names != nil) {
                            var tbi: i32 = 0;
                            for (tbi < ctx.type_binding_count) {
                                if (ctx.type_binding_names[tbi] != nil &&
                                    ctx.type_binding_names[tbi].equals(ct_type_name)) {
                                    ct_type = ctx.type_binding_types[tbi];
                                }
                                tbi = tbi + 1;
                            }
                        }
                    }

                    # pointer types always have size/align 8
                    if (ct_type == nil && ct_arg.kind == ast.NODE_TYPE_PTR) {
                        if (ct_name.equals("size_of") || ct_name.equals("align_of")) {
                            ret ir.make_imm(8, 8);
                        }
                    }

                    if (ct_type != nil) {
                        if (ct_name.equals("size_of")) {
                            ret ir.make_imm(ct_type.size::i64, 8);
                        }
                        if (ct_name.equals("align_of")) {
                            var ct_align: usize = ct_type.size;
                            if (ct_align > 8) { ct_align = 8; }
                            if (ct_align == 0) { ct_align = 1; }
                            ret ir.make_imm(ct_align::i64, 8);
                        }
                    }
                }
            }
        }
        ret lower_call(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_FIELD) {
        ret lower_field_access(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_INDEX) {
        ret lower_index(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_CAST) {
        ret lower_cast(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_ADDR) {
        ret lower_addr(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_DEREF) {
        ret lower_deref(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_ARRAY_LIT) {
        ret lower_array_lit(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_STRUCT_LIT) {
        ret lower_struct_lit(ctx, node);
    }

    if (node.kind == ast.NODE_EXPR_LIT_BOOL) {
        val bool_text: str = node.info.lit_expr.text;
        if (bool_text != nil && bool_text.equals("true")) {
            ret ir.make_imm(1, 1);
        }
        ret ir.make_imm(0, 1);
    }

    if (node.kind == ast.NODE_EXPR_LIT_NIL) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # parenthesized expression: unwrap and lower inner expression
    if (node.kind == ast.NODE_EXPR_PAREN) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            ret lower_expr(ctx, inner);
        }
        ret make_none();
    }

    # comptime expression: $size_of(T), $align_of(T), etc.
    if (node.kind == ast.NODE_COMPTIME) {
        val ct_inner: *ast.Node = node.info.wrapper.inner;
        if (ct_inner != nil && ct_inner.kind == ast.NODE_EXPR_CALL) {
            val ct_callee: *ast.Node = ct_inner.info.call_expr.callee;
            val ct_args: *ast.List = ct_inner.info.call_expr.args;
            if (ct_callee != nil && ct_callee.kind == ast.NODE_EXPR_IDENT &&
                ct_args != nil && ct_args.count > 0) {
                val ct_name: str = ct_callee.info.ident_expr.name;
                val ct_arg: *ast.Node = ct_args.nodes[0];
                if (ct_name != nil && ct_arg != nil) {
                    # resolve the type argument
                    var ct_type: *ty.Type = nil;

                    # try resolve_type_annotation (handles NODE_TYPE_NAME with bindings)
                    ct_type = resolve_type_annotation(ctx, ct_arg);

                    # fallback: if arg is NODE_EXPR_IDENT, look up type bindings and primitives
                    if (ct_type == nil && ct_arg.kind == ast.NODE_EXPR_IDENT) {
                        val ct_type_name: str = ct_arg.info.ident_expr.name;
                        if (ct_type_name != nil) {
                            # check type bindings (for generic params like T)
                            if (ctx.type_binding_count > 0 && ctx.type_binding_names != nil) {
                                var tbi: i32 = 0;
                                for (tbi < ctx.type_binding_count) {
                                    if (ctx.type_binding_names[tbi] != nil &&
                                        ctx.type_binding_names[tbi].equals(ct_type_name)) {
                                        ct_type = ctx.type_binding_types[tbi];
                                    }
                                    tbi = tbi + 1;
                                }
                            }
                        }
                    }

                    # if arg is a pointer type, size/align is always 8
                    if (ct_type == nil && ct_arg.kind == ast.NODE_TYPE_PTR) {
                        if (ct_name.equals("size_of") || ct_name.equals("align_of")) {
                            ret ir.make_imm(8, 8);
                        }
                    }

                    if (ct_type != nil) {
                        if (ct_name.equals("size_of")) {
                            ret ir.make_imm(ct_type.size::i64, 8);
                        }
                        if (ct_name.equals("align_of")) {
                            var ct_align: usize = ct_type.size;
                            if (ct_align > 8) { ct_align = 8; }
                            if (ct_align == 0) { ct_align = 1; }
                            ret ir.make_imm(ct_align::i64, 8);
                        }
                    }
                }
            }
        }
        # fallback: try lowering inner expression
        if (ct_inner != nil) {
            ret lower_expr(ctx, ct_inner);
        }
        ret make_none();
    }

    # default: return none
    ret make_none();
}

# lower_string_lit: lower a string literal.
# ---
# ctx:  lowering context
# node: string literal node
# ret:  IRValue containing string address
fun lower_string_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val str_val: str = node.info.lit_expr.text;
    if (str_val == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # create a unique label for the string
    val label: str = new_label(ctx, ".Lstr");

    # emit string data to rodata section
    val sec_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, ".rodata", section.section_rodata());
    if (sec_res.is_err()) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val sec: *section.Section = sec_res.unwrap_ok();

    # create symbol for the string
    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, label);
    if (sym_res.is_ok()) {
        val s: *sym.Symbol = sym_res.unwrap_ok();
        sym.set_binding(s, sym.bind_local());
        sym.set_type(s, sym.sym_object());
        sym.define(s, sec, sec.size, 0);
        masm.add_symbol(ctx.m, s);
    }

    # emit string bytes - strip surrounding quotes and process escape sequences
    val slen: usize = str_val.len();
    var start: usize = 0;
    var end: usize = slen;

    # strip surrounding quotes if present
    if (slen >= 2 && str_val[0] == 34) {
        start = 1;
        if (str_val[slen - 1] == 34) {
            end = slen - 1;
        }
    }

    var i: usize = start;
    for (i < end) {
        val c: u8 = str_val[i];
        if (c == 92 && i + 1 < end) {
            # backslash escape
            val e: u8 = str_val[i + 1];
            if (e == 110) {
                # \n → newline
                section.emit_byte(ctx.alloc, sec, 10);
            } or (e == 116) {
                # \t → tab
                section.emit_byte(ctx.alloc, sec, 9);
            } or (e == 114) {
                # \r → carriage return
                section.emit_byte(ctx.alloc, sec, 13);
            } or (e == 48) {
                # \0 → null
                section.emit_byte(ctx.alloc, sec, 0);
            } or (e == 92) {
                # \\ → backslash
                section.emit_byte(ctx.alloc, sec, 92);
            } or (e == 34) {
                # \" → double quote
                section.emit_byte(ctx.alloc, sec, 34);
            } or (e == 39) {
                # \' → single quote
                section.emit_byte(ctx.alloc, sec, 39);
            } or {
                # unknown escape: emit the escaped char as-is
                section.emit_byte(ctx.alloc, sec, e);
            }
            i = i + 2;
        } or {
            section.emit_byte(ctx.alloc, sec, c);
            i = i + 1;
        }
    }
    # null terminator
    section.emit_byte(ctx.alloc, sec, 0);

    # return symbol reference as immediate
    var v: ir.IRValue;
    v.kind = ir.VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = label;
    v.size = ctx.ptr_size;

    ret v;
}

# lower_identifier: lower an identifier reference.
# ---
# ctx:  lowering context
# node: identifier node
# ret:  IRValue containing the identifier's value
fun lower_identifier(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val name: str = node.info.ident_expr.name;
    if (name == nil) {
        ret make_none();
    }

    # check if it's a local variable
    val local_idx: i32 = find_local_var(ctx, name);
    if (local_idx >= 0) {
        val offset: i32 = get_local_var_offset(ctx, local_idx);
        val size: usize = ctx.local_vars[local_idx].size;
        val addr: ir.IRValue = frame_mem(ctx, offset, size);

        # aggregates (structs, unions, arrays) and large types: return address with LEA
        # because field/index access expects a pointer base, not a loaded value
        # try node.ty first, fall back to local_vars type table
        var var_ty: *ty.Type = node.ty;
        if (var_ty == nil) {
            var_ty = ctx.local_vars[local_idx].ty;
        }
        val is_aggregate: bool = var_ty != nil && (var_ty.kind == ty.TY_RECORD ||
                                                    var_ty.kind == ty.TY_UNION ||
                                                    var_ty.kind == ty.TY_ARRAY);
        val is_odd_size: bool = size != 1 && size != 2 && size != 4 && size != 8;

        if (size > 8 || is_aggregate || is_odd_size) {
            # LEA: load effective address into register
            val result_reg: i32 = new_vreg(ctx, ctx.ptr_size);
            val result: ir.IRValue = ir.make_reg(result_reg, ctx.ptr_size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                          result, addr, ir.make_none(), ir.CC_NONE);
            ret result;
        }

        # scalar: load value (sign-extend for signed i8/i16)
        if (var_ty != nil && var_ty.is_signed() && (size == 1 || size == 2)) {
            ret emit_load_signed(ctx, addr, size);
        }
        ret emit_load(ctx, addr, size);
    }

    # check if it's a parameter
    # parameters are handled during function lowering
    # for now, assume it's a global

    # look up symbol for linkage name and function detection
    var global_label: str = name;
    var is_func_sym: bool = false;
    if (ctx.symbols != nil) {
        val id_sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(name);
        if (id_sym_opt.is_some()) {
            val id_sym: *symbol.Symbol = id_sym_opt.unwrap();
            if (id_sym.kind == symbol.SYM_FUN) {
                is_func_sym = true;
            }
            val link: str = symbol.linkage_name(id_sym, ctx.alloc);
            if (link != nil) {
                global_label = link;
            }
        }
        if (!is_func_sym) {
            val id_imp_sym: *symbol.Symbol = lookup_symbol_in_imports(ctx, name);
            if (id_imp_sym != nil) {
                if (id_imp_sym.kind == symbol.SYM_FUN) {
                    is_func_sym = true;
                }
                val imp_link: str = symbol.linkage_name(id_imp_sym, ctx.alloc);
                if (imp_link != nil) {
                    global_label = imp_link;
                }
            }
        }
    }

    # create symbol reference (for global)
    var v: ir.IRValue;
    v.kind = ir.VAL_LABEL;
    v.reg = 0;
    v.imm = 0;
    v.offset = 0;
    v.base_reg = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = global_label;
    v.size = ctx.ptr_size;

    # for aggregates, return address in register
    val var_ty: *ty.Type = node.ty;
    val is_aggregate: bool = var_ty != nil && (var_ty.kind == ty.TY_RECORD ||
                                                var_ty.kind == ty.TY_UNION ||
                                                var_ty.kind == ty.TY_ARRAY);
    # load address into register
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
    ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                  addr, v, ir.make_none(), ir.CC_NONE);

    if (is_aggregate || is_func_sym) {
        ret addr;
    }

    # scalar: load value from address
    val mem: ir.IRValue = ir.make_mem(addr_reg, -1, 1, 0, ctx.ptr_size);
    ret emit_load(ctx, mem, ctx.ptr_size);
}

# lower_short_circuit: lower && and || with short-circuit evaluation.
# ---
# ctx:    lowering context
# node:   binary expression node (TAG_AMP_AMP or TAG_PIPE_PIPE)
# is_and: true for &&, false for ||
# ret:    IRValue containing boolean result (0 or 1)
fun lower_short_circuit(ctx: *LowerContext, node: *ast.Node, is_and: bool) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val lhs: *ast.Node = node.info.binary_expr.left;
    val rhs: *ast.Node = node.info.binary_expr.right;

    if (lhs == nil || rhs == nil) {
        ret make_none();
    }

    val end_label: str = new_label(ctx, ".Lsc_end");
    val true_label: str = new_label(ctx, ".Lsc_true");

    # allocate result vreg
    val dst_reg: i32 = new_vreg(ctx, 8);
    val dst: ir.IRValue = ir.make_reg(dst_reg, 8);
    val zero: ir.IRValue = ir.make_imm(0, 8);

    # evaluate left operand
    val left_value: ir.IRValue = lower_expr(ctx, lhs);

    # move left result to dst
    emit_mov(ctx, dst, left_value, 8);

    # compare with 0
    emit_cmp(ctx, dst, zero, 8);

    if (is_and) {
        # AND: if left is 0, short-circuit to end (result stays 0)
        emit_cond_br(ctx, ir.CC_EQ::i32, end_label);
    } or {
        # OR: if left is non-zero, short-circuit to true (result = 1)
        emit_cond_br(ctx, ir.CC_NE::i32, true_label);
    }

    # evaluate right operand
    val right_value: ir.IRValue = lower_expr(ctx, rhs);

    # result = (right != 0)
    emit_cmp(ctx, right_value, zero, 8);
    emit_instr(ctx, ir.IROp{ir_setne: ir.OP_SETNE}, dst, ir.make_none(), ir.make_none(), 0);
    emit_br(ctx, end_label);

    if (!is_and) {
        # OR: true label - set result to 1
        emit_label(ctx, true_label);
        emit_mov(ctx, dst, ir.make_imm(1, 8), 8);
    }

    emit_label(ctx, end_label);
    ret dst;
}

# lower_binary: lower a binary expression.
# ---
# ctx:  lowering context
# node: binary expression node
# ret:  IRValue containing result
fun lower_binary(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val lhs: *ast.Node = node.info.binary_expr.left;
    val rhs: *ast.Node = node.info.binary_expr.right;
    val op: u8 = node.tok.tag;

    if (lhs == nil || rhs == nil) {
        ret make_none();
    }

    # handle short-circuit logical operators
    if (op == token.TAG_AMP_AMP) {
        ret lower_short_circuit(ctx, node, true);
    }
    if (op == token.TAG_PIPE_PIPE) {
        ret lower_short_circuit(ctx, node, false);
    }

    # handle assignment separately - left side needs lvalue, not rvalue
    if (op == token.TAG_EQ) {
        val left_addr: ir.IRValue = lower_lvalue(ctx, lhs);
        val right_value: ir.IRValue = lower_expr(ctx, rhs);

        # aggregate assignment: when RHS is a large local variable, lower_identifier
        # returns VAL_REG (via LEA) containing the address. Detect this by checking
        # the local variable's size and do a chunked copy instead of a scalar store.
        if (right_value.kind == ir.VAL_REG && rhs.kind == ast.NODE_EXPR_IDENT) {
            val asg_rhs_name: str = rhs.info.ident_expr.name;
            if (asg_rhs_name != nil) {
                val asg_rhs_idx: i32 = find_local_var(ctx, asg_rhs_name);
                if (asg_rhs_idx >= 0) {
                    val asg_rhs_size: usize = ctx.local_vars[asg_rhs_idx].size;
                    if (asg_rhs_size > ctx.ptr_size) {
                        # LEA destination address
                        val asg_dst_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                        val asg_dst: ir.IRValue = ir.make_reg(asg_dst_reg, ctx.ptr_size);
                        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                                      asg_dst, left_addr, ir.make_none(), ir.CC_NONE);

                        # source: right_value.reg already holds the aggregate address
                        val asg_src_reg: i32 = right_value.reg;

                        # chunked copy
                        val asg_total: i32 = asg_rhs_size::i32;
                        var asg_off: i32 = 0;
                        for (asg_off < asg_total) {
                            var asg_chunk: usize = 8;
                            if ((asg_total - asg_off)::usize < 8) {
                                asg_chunk = (asg_total - asg_off)::usize;
                            }
                            val asg_tmp_reg: i32 = new_vreg(ctx, asg_chunk);
                            val asg_tmp: ir.IRValue = ir.make_reg(asg_tmp_reg, asg_chunk);

                            var asg_s: ir.IRValue;
                            asg_s.kind = ir.VAL_MEM;
                            asg_s.base_reg = asg_src_reg;
                            asg_s.offset = asg_off::i64;
                            asg_s.size = asg_chunk;
                            asg_s.reg = 0;
                            asg_s.imm = 0;
                            asg_s.index_reg = -1;
                            asg_s.scale = 1;
                            asg_s.label = nil;

                            var asg_d: ir.IRValue;
                            asg_d.kind = ir.VAL_MEM;
                            asg_d.base_reg = asg_dst_reg;
                            asg_d.offset = asg_off::i64;
                            asg_d.size = asg_chunk;
                            asg_d.reg = 0;
                            asg_d.imm = 0;
                            asg_d.index_reg = -1;
                            asg_d.scale = 1;
                            asg_d.label = nil;

                            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                                          asg_tmp, asg_s, ir.make_none(), ir.CC_NONE);
                            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                                          asg_d, asg_tmp, ir.make_none(), ir.CC_NONE);

                            asg_off = asg_off + asg_chunk::i32;
                        }
                        ret right_value;
                    }
                }
            }
        }

        # general aggregate assignment: when RHS is a large aggregate (returned from
        # function call via sret as VAL_MEM, or from a register address as VAL_REG),
        # do a chunked copy to the destination.
        var agg_copy_size: usize = 0;
        if (right_value.kind == ir.VAL_MEM && right_value.size > ctx.ptr_size) {
            agg_copy_size = right_value.size;
        } or (right_value.kind == ir.VAL_REG && rhs.ty != nil && rhs.ty.size > ctx.ptr_size) {
            agg_copy_size = rhs.ty.size;
        }

        if (agg_copy_size > 0) {
            # get destination register
            var agg_dst_reg: i32 = 0;
            if (left_addr.kind == ir.VAL_REG) {
                agg_dst_reg = left_addr.reg;
            } or {
                agg_dst_reg = new_vreg(ctx, ctx.ptr_size);
                val agg_dst: ir.IRValue = ir.make_reg(agg_dst_reg, ctx.ptr_size);
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                              agg_dst, left_addr, ir.make_none(), ir.CC_NONE);
            }

            # get source register: for VAL_MEM, LEA to get address; for VAL_REG, use directly
            var agg_src_reg: i32 = 0;
            if (right_value.kind == ir.VAL_MEM) {
                agg_src_reg = new_vreg(ctx, ctx.ptr_size);
                val agg_src: ir.IRValue = ir.make_reg(agg_src_reg, ctx.ptr_size);
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                              agg_src, right_value, ir.make_none(), ir.CC_NONE);
            } or {
                agg_src_reg = right_value.reg;
            }

            val agg_total: i32 = agg_copy_size::i32;
            var agg_off: i32 = 0;
            for (agg_off < agg_total) {
                var agg_chunk: usize = 8;
                if ((agg_total - agg_off)::usize < 8) {
                    agg_chunk = (agg_total - agg_off)::usize;
                }
                val agg_tmp_reg: i32 = new_vreg(ctx, agg_chunk);
                val agg_tmp: ir.IRValue = ir.make_reg(agg_tmp_reg, agg_chunk);

                var agg_s: ir.IRValue;
                agg_s.kind = ir.VAL_MEM;
                agg_s.base_reg = agg_src_reg;
                agg_s.offset = agg_off::i64;
                agg_s.size = agg_chunk;
                agg_s.reg = 0;
                agg_s.imm = 0;
                agg_s.index_reg = -1;
                agg_s.scale = 1;
                agg_s.label = nil;

                var agg_d: ir.IRValue;
                agg_d.kind = ir.VAL_MEM;
                agg_d.base_reg = agg_dst_reg;
                agg_d.offset = agg_off::i64;
                agg_d.size = agg_chunk;
                agg_d.reg = 0;
                agg_d.imm = 0;
                agg_d.index_reg = -1;
                agg_d.scale = 1;
                agg_d.label = nil;

                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                              agg_tmp, agg_s, ir.make_none(), ir.CC_NONE);
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                              agg_d, agg_tmp, ir.make_none(), ir.CC_NONE);

                agg_off = agg_off + agg_chunk::i32;
            }
            ret right_value;
        }

        emit_store(ctx, left_addr, right_value);
        ret right_value;
    }

    # lower operands (for non-assignment operators)
    val left_value: ir.IRValue = lower_expr(ctx, lhs);
    val right_value: ir.IRValue = lower_expr(ctx, rhs);

    # determine size from node type or default to 8
    var size: usize = 8;
    if (node.ty != nil) {
        size = node.ty.size;
    }

    # allocate result register
    val dst_reg: i32 = new_vreg(ctx, size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, size);

    # map token kind to IR opcode
    var ir_op: ir.IROp = ir.IROp{ir_mov: ir.OP_MOV};

    # arithmetic
    if (op == token.TAG_PLUS) {
        ir_op = ir.IROp{ir_add: ir.OP_ADD};
    }
    if (op == token.TAG_MINUS) {
        ir_op = ir.IROp{ir_sub: ir.OP_SUB};
    }
    if (op == token.TAG_STAR) {
        ir_op = ir.IROp{ir_mul: ir.OP_MUL};
    }
    if (op == token.TAG_SLASH) {
        if (node.ty != nil && node.ty.is_unsigned()) {
            ir_op = ir.IROp{ir_div: ir.OP_DIVU};
        } or {
            ir_op = ir.IROp{ir_div: ir.OP_DIV};
        }
    }
    if (op == token.TAG_PERCENT) {
        if (node.ty != nil && node.ty.is_unsigned()) {
            ir_op = ir.IROp{ir_mod: ir.OP_MODU};
        } or {
            ir_op = ir.IROp{ir_mod: ir.OP_MOD};
        }
    }

    # bitwise
    if (op == token.TAG_AMP) {
        ir_op = ir.IROp{ir_and: ir.OP_AND};
    }
    if (op == token.TAG_PIPE) {
        ir_op = ir.IROp{ir_or: ir.OP_OR};
    }
    if (op == token.TAG_CARET) {
        ir_op = ir.IROp{ir_xor: ir.OP_XOR};
    }
    if (op == token.TAG_LT_LT) {
        ir_op = ir.IROp{ir_shl: ir.OP_SHL};
    }
    if (op == token.TAG_GT_GT) {
        ir_op = ir.IROp{ir_shr: ir.OP_SHR};
    }

    # comparison (set result to 0 or 1 based on condition)
    # check if operand type is unsigned to select correct comparison opcodes
    var cmp_unsigned: bool = false;
    if (lhs != nil && lhs.ty != nil && lhs.ty.is_unsigned()) {
        cmp_unsigned = true;
    }

    if (op == token.TAG_EQ_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        emit_instr(ctx, ir.IROp{ir_sete: ir.OP_SETE}, dst, ir.make_none(), ir.make_none(), 0);
        ret dst;
    }
    if (op == token.TAG_BANG_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        emit_instr(ctx, ir.IROp{ir_setne: ir.OP_SETNE}, dst, ir.make_none(), ir.make_none(), 0);
        ret dst;
    }
    if (op == token.TAG_LT) {
        emit_cmp(ctx, left_value, right_value, size);
        if (cmp_unsigned) {
            emit_instr(ctx, ir.IROp{ir_setb: ir.OP_SETB}, dst, ir.make_none(), ir.make_none(), 0);
        } or {
            emit_instr(ctx, ir.IROp{ir_setl: ir.OP_SETL}, dst, ir.make_none(), ir.make_none(), 0);
        }
        ret dst;
    }
    if (op == token.TAG_GT) {
        emit_cmp(ctx, left_value, right_value, size);
        if (cmp_unsigned) {
            emit_instr(ctx, ir.IROp{ir_seta: ir.OP_SETA}, dst, ir.make_none(), ir.make_none(), 0);
        } or {
            emit_instr(ctx, ir.IROp{ir_setg: ir.OP_SETG}, dst, ir.make_none(), ir.make_none(), 0);
        }
        ret dst;
    }
    if (op == token.TAG_LT_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        if (cmp_unsigned) {
            emit_instr(ctx, ir.IROp{ir_setbe: ir.OP_SETBE}, dst, ir.make_none(), ir.make_none(), 0);
        } or {
            emit_instr(ctx, ir.IROp{ir_setle: ir.OP_SETLE}, dst, ir.make_none(), ir.make_none(), 0);
        }
        ret dst;
    }
    if (op == token.TAG_GT_EQ) {
        emit_cmp(ctx, left_value, right_value, size);
        if (cmp_unsigned) {
            emit_instr(ctx, ir.IROp{ir_setae: ir.OP_SETAE}, dst, ir.make_none(), ir.make_none(), 0);
        } or {
            emit_instr(ctx, ir.IROp{ir_setge: ir.OP_SETGE}, dst, ir.make_none(), ir.make_none(), 0);
        }
        ret dst;
    }

    # emit ALU instruction
    ret emit_alu(ctx, ir_op, dst, left_value, right_value, size);
}

# lower_unary: lower a unary expression.
# ---
# ctx:  lowering context
# node: unary expression node
# ret:  IRValue containing result
fun lower_unary(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val operand: *ast.Node = node.info.unary_expr.expr;  # unary uses expr for operand
    val op: u8 = node.tok.tag;

    if (operand == nil) {
        ret make_none();
    }

    val value: ir.IRValue = lower_expr(ctx, operand);

    # determine size
    var size: usize = 8;
    if (node.ty != nil) {
        size = node.ty.size;
    }

    # negation
    if (op == token.TAG_MINUS) {
        val zero: ir.IRValue = ir.make_imm(0, size);
        val dst_reg: i32 = new_vreg(ctx, size);
        val dst: ir.IRValue = ir.make_reg(dst_reg, size);
        ret emit_alu(ctx, ir.IROp{ir_sub: ir.OP_SUB}, dst, zero, value, size);
    }

    # bitwise not
    if (op == token.TAG_TILDE) {
        val dst_reg: i32 = new_vreg(ctx, size);
        val dst: ir.IRValue = ir.make_reg(dst_reg, size);
        # xor with all 1s to get complement
        val all_ones: ir.IRValue = ir.make_imm(-1, size);
        ret emit_alu(ctx, ir.IROp{ir_xor: ir.OP_XOR}, dst, value, all_ones, size);
    }

    # logical not
    if (op == token.TAG_BANG) {
        # compare with 0 and set result
        val zero: ir.IRValue = ir.make_imm(0, size);
        emit_cmp(ctx, value, zero, size);
        val dst_reg: i32 = new_vreg(ctx, size);
        val dst: ir.IRValue = ir.make_reg(dst_reg, size);
        # sete result (1 if equal to 0, 0 otherwise)
        emit_instr(ctx, ir.IROp{ir_sete: ir.OP_SETE}, dst, ir.make_none(), ir.make_none(), 0);
        ret dst;
    }

    ret value;
}

# lower_call: lower a function call expression.
# ---
# ctx:  lowering context
# node: call expression node
# ret:  IRValue containing return value
fun lower_call(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val callee: *ast.Node = node.info.call_expr.callee;
    val args: *ast.List = node.info.call_expr.args;

    if (callee == nil) {
        ret make_none();
    }

    # get function name
    var func_name: str = nil;
    if (callee.kind == ast.NODE_EXPR_IDENT) {
        func_name = callee.info.ident_expr.name;
    } or (callee.kind == ast.NODE_EXPR_FIELD) {
        func_name = callee.info.field_expr.field;
    }
    if (func_name == nil) {
        ret make_none();
    }

    # check if this is a module-qualified call (e.g., fs.write) or a method call (e.g., arg.equals())
    var is_module_qualified: bool = false;
    var is_method_call: bool = false;
    var method_receiver_type_name: str = nil;
    var method_recv_base_ty: *ty.Type = nil;
    var module_alias_name: str = nil;
    if (callee.kind == ast.NODE_EXPR_FIELD) {
        val callee_base: *ast.Node = callee.info.field_expr.object;
        if (callee_base != nil) {
            # get base type, trying local vars first if base.ty is nil
            var base_ty: *ty.Type = callee_base.ty;

            if (base_ty == nil && callee_base.kind == ast.NODE_EXPR_IDENT) {
                # try to get type from local variable table
                val base_name: str = callee_base.info.ident_expr.name;
                var found_in_locals: bool = false;
                if (base_name != nil) {
                    val local_idx: i32 = find_local_var(ctx, base_name);
                    if (local_idx >= 0) {
                        found_in_locals = true;
                        base_ty = ctx.local_vars[local_idx].ty;
                    }
                }

                # check if base is a module alias (only if NOT a local variable)
                if (!found_in_locals && base_ty == nil && base_name != nil) {
                    val is_alias: bool = is_module_alias(ctx, base_name);
                    if (is_alias) {
                        is_module_qualified = true;
                        module_alias_name = base_name;
                    }
                }
            }

            # if not module-qualified, try to detect method call
            if (!is_module_qualified) {
                if (base_ty != nil) {
                    # handle str type directly (str is alias for &char = &u8,
                    # but methods are registered under "str" not "u8")
                    if (base_ty.kind == ty.TY_STR) {
                        is_method_call = true;
                        method_receiver_type_name = ty.kind_name(base_ty.kind);
                        method_recv_base_ty = base_ty;
                    } or {
                        # unwrap pointers to get base type name
                        for (base_ty != nil && base_ty.kind == ty.TY_POINTER) {
                            base_ty = base_ty.inner;
                        }
                        if (base_ty != nil) {
                            # &u8 is the expanded form of str (str = &char = &u8),
                            # methods are registered under "str" not "u8"
                            if (base_ty.kind == ty.TY_U8) {
                                is_method_call = true;
                                method_receiver_type_name = ty.kind_name(ty.TY_STR);
                                method_recv_base_ty = base_ty;
                            } or (base_ty.name != nil) {
                                is_method_call = true;
                                method_receiver_type_name = base_ty.name;
                                method_recv_base_ty = base_ty;
                            } or {
                                val kind_nm: str = ty.kind_name(base_ty.kind);
                                if (kind_nm != nil) {
                                    is_method_call = true;
                                    method_receiver_type_name = kind_nm;
                                    method_recv_base_ty = base_ty;
                                }
                            }
                        }
                    }
                } or {
                    # no type available - search symbol tables for method
                    method_receiver_type_name = find_method_type_name(ctx, func_name);
                    if (method_receiver_type_name != nil) {
                        is_method_call = true;
                    }
                }
            }
        }
    }

    # for method calls, build qualified name "ReceiverType.methodName"
    # and mangle with type args if the receiver is a generic instantiation
    if (is_method_call && method_receiver_type_name != nil) {
        val recv_len: usize = method_receiver_type_name.len();
        val name_len: usize = func_name.len();

        # check if the method call itself has type args (e.g., alloc.alloc[u8](count))
        # this is distinct from methods on generic types (receiver has generic_args)
        val mc_type_args: *ast.Node = node.info.call_expr.type_args;
        var mc_has_call_type_args: bool = false;
        if (mc_type_args != nil) {
            val mc_ta_list: *ast.List = mc_type_args.info.generic_node.args;
            if (mc_ta_list != nil && mc_ta_list.count > 0) {
                mc_has_call_type_args = true;
            }
        }

        if (mc_has_call_type_args) {
            # generic method with own type args: "ReceiverType.methodName" + "I" + mangle(call type args) + "E"
            val mc_ta_list2: *ast.List = mc_type_args.info.generic_node.args;
            var mg_buf: [512]u8;
            var mg_pos: i32 = 0;

            # write "ReceiverType."
            var mg_ri: usize = 0;
            for (mg_ri < recv_len && mg_pos < 480) {
                mg_buf[mg_pos::usize] = method_receiver_type_name[mg_ri];
                mg_pos = mg_pos + 1;
                mg_ri = mg_ri + 1;
            }
            mg_buf[mg_pos::usize] = '.';
            mg_pos = mg_pos + 1;

            # write "methodName"
            var mg_ni: usize = 0;
            for (mg_ni < name_len && mg_pos < 480) {
                mg_buf[mg_pos::usize] = func_name[mg_ni];
                mg_pos = mg_pos + 1;
                mg_ni = mg_ni + 1;
            }

            # write "I"
            mg_buf[mg_pos::usize] = 'I';
            mg_pos = mg_pos + 1;

            # mangle each call-site type arg
            var mg_ai: i32 = 0;
            for (mg_ai < mc_ta_list2.count && mg_pos < 500) {
                val mg_arg_node: *ast.Node = mc_ta_list2.nodes[mg_ai];
                if (mg_arg_node != nil) {
                    val mg_arg_ty: *ty.Type = resolve_type_annotation(ctx, mg_arg_node);
                    if (mg_arg_ty != nil) {
                        val mg_written: i32 = ty.type_mangle(mg_arg_ty, ?mg_buf[mg_pos::usize], (512 - mg_pos)::usize);
                        mg_pos = mg_pos + mg_written;
                    }
                }
                mg_ai = mg_ai + 1;
            }

            # write "E\0"
            mg_buf[mg_pos::usize] = 'E';
            mg_pos = mg_pos + 1;
            mg_buf[mg_pos::usize] = 0;

            # allocate persistent copy
            val mg_alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8]((mg_pos + 1)::usize);
            if (mg_alloc_res.is_ok()) {
                val mg_dest: *u8 = mg_alloc_res.unwrap_ok();
                var mg_ci: i32 = 0;
                for (mg_ci <= mg_pos) {
                    mg_dest[mg_ci::usize] = mg_buf[mg_ci::usize];
                    mg_ci = mg_ci + 1;
                }
                func_name = mg_dest::str;
            }
        } or (method_recv_base_ty != nil && method_recv_base_ty.generic_args != nil && method_recv_base_ty.generic_arg_count > 0) {
            # receiver is a generic instantiation (e.g., Result[usize, str])
            # build "ReceiverType.methodNameI<type_args>E"
            var rg_buf: [512]u8;
            var rg_pos: i32 = 0;

            # write "ReceiverType."
            var rg_ri: usize = 0;
            for (rg_ri < recv_len && rg_pos < 480) {
                rg_buf[rg_pos::usize] = method_receiver_type_name[rg_ri];
                rg_pos = rg_pos + 1;
                rg_ri = rg_ri + 1;
            }
            rg_buf[rg_pos::usize] = '.';
            rg_pos = rg_pos + 1;

            # write "methodName"
            var rg_ni: usize = 0;
            for (rg_ni < name_len && rg_pos < 480) {
                rg_buf[rg_pos::usize] = func_name[rg_ni];
                rg_pos = rg_pos + 1;
                rg_ni = rg_ni + 1;
            }

            # write "I"
            rg_buf[rg_pos::usize] = 'I';
            rg_pos = rg_pos + 1;

            # mangle each receiver type arg
            var rg_ai: i32 = 0;
            for (rg_ai < method_recv_base_ty.generic_arg_count && rg_pos < 500) {
                val rg_arg_ty: *ty.Type = method_recv_base_ty.generic_args[rg_ai];
                if (rg_arg_ty != nil) {
                    val rg_written: i32 = ty.type_mangle(rg_arg_ty, ?rg_buf[rg_pos::usize], (512 - rg_pos)::usize);
                    rg_pos = rg_pos + rg_written;
                }
                rg_ai = rg_ai + 1;
            }

            # write "E\0"
            rg_buf[rg_pos::usize] = 'E';
            rg_pos = rg_pos + 1;
            rg_buf[rg_pos::usize] = 0;

            # allocate persistent copy
            val rg_alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8]((rg_pos + 1)::usize);
            if (rg_alloc_res.is_ok()) {
                val rg_dest: *u8 = rg_alloc_res.unwrap_ok();
                var rg_ci: i32 = 0;
                for (rg_ci <= rg_pos) {
                    rg_dest[rg_ci::usize] = rg_buf[rg_ci::usize];
                    rg_ci = rg_ci + 1;
                }
                func_name = rg_dest::str;
            }
        } or {
            # non-generic method: just build "ReceiverType.methodName"
            val total_len: usize = recv_len + 1 + name_len + 1;

            val alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](total_len);
            if (alloc_res.is_ok()) {
                val buf: *u8 = alloc_res.unwrap_ok();
                var i: usize = 0;
                for (i < recv_len) {
                    buf[i] = method_receiver_type_name[i];
                    i = i + 1;
                }
                buf[i] = '.';
                i = i + 1;
                var j: usize = 0;
                for (j < name_len) {
                    buf[i] = func_name[j];
                    i = i + 1;
                    j = j + 1;
                }
                buf[i] = 0;
                func_name = buf::str;
            }
        }
    }

    # handle variadic builtins: va_start, va_end, va_arg
    if (ctx.fn_is_variadic && callee.kind == ast.NODE_EXPR_IDENT) {
        # va_start(ap): initialize va_list fields
        if (func_name.equals("va_start")) {
            ret emit_va_start(ctx, args);
        }

        # va_end(ap): no-op on SysV x86_64
        if (func_name.equals("va_end")) {
            ret make_none();
        }

        # va_arg[T](ap): fetch next argument of type T from va_list
        if (func_name.equals("va_arg")) {
            ret emit_va_arg(ctx, args, node.ty);
        }
    }

    # for generic function calls (e.g., ok[*Section, str](val)), compute mangled name
    if (!is_method_call && !is_module_qualified && node.info.call_expr.type_args != nil) {
        val type_args_node: *ast.Node = node.info.call_expr.type_args;
        if (type_args_node != nil) {
            val gf_args_list: *ast.List = type_args_node.info.generic_node.args;
            if (gf_args_list != nil && gf_args_list.count > 0) {
                var gf_buf: [512]u8;
                var gf_pos: i32 = 0;

                # write base function name
                val gf_name_len: usize = func_name.len();
                var gf_ni: usize = 0;
                for (gf_ni < gf_name_len && gf_pos < 480) {
                    gf_buf[gf_pos::usize] = func_name[gf_ni];
                    gf_pos = gf_pos + 1;
                    gf_ni = gf_ni + 1;
                }

                # write "I"
                gf_buf[gf_pos::usize] = 'I';
                gf_pos = gf_pos + 1;

                # resolve and mangle each type arg
                var gf_ai: i32 = 0;
                for (gf_ai < gf_args_list.count && gf_pos < 500) {
                    val gf_arg: *ast.Node = gf_args_list.nodes[gf_ai];
                    if (gf_arg != nil) {
                        val gf_arg_ty: *ty.Type = resolve_type_annotation(ctx, gf_arg);
                        if (gf_arg_ty != nil) {
                            val gf_written: i32 = ty.type_mangle(gf_arg_ty, ?gf_buf[gf_pos::usize], (512 - gf_pos)::usize);
                            gf_pos = gf_pos + gf_written;
                        }
                    }
                    gf_ai = gf_ai + 1;
                }

                # write "E\0"
                gf_buf[gf_pos::usize] = 'E';
                gf_pos = gf_pos + 1;
                gf_buf[gf_pos::usize] = 0;

                # allocate persistent copy
                val gf_alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8]((gf_pos + 1)::usize);
                if (gf_alloc_res.is_ok()) {
                    val gf_dest: *u8 = gf_alloc_res.unwrap_ok();
                    var gf_ci: i32 = 0;
                    for (gf_ci <= gf_pos) {
                        gf_dest[gf_ci::usize] = gf_buf[gf_ci::usize];
                        gf_ci = gf_ci + 1;
                    }
                    func_name = gf_dest::str;
                }
            }
        }
    }

    # resolve linkage name for all calls (direct, module-qualified, and method calls)
    var call_sym: *symbol.Symbol = nil;
    var found_via: i32 = 0;

    # for module-qualified calls, look up in the specific aliased module first
    if (is_module_qualified && module_alias_name != nil && ctx.current_sema_mod != nil) {
        var ma: *sema.ModuleAlias = ctx.current_sema_mod.aliases;
        for (ma != nil) {
            if (ma.alias != nil && ma.alias.equals(module_alias_name)) {
                if (ma.module != nil && ma.module.table != nil) {
                    val mod_root: *symbol.Scope = ma.module.table.root_scope();
                    if (mod_root != nil) {
                        val mod_sym_opt: Option[*symbol.Symbol] = mod_root.lookup_local(func_name);
                        if (mod_sym_opt.is_some()) {
                            call_sym = mod_sym_opt.unwrap();
                            found_via = 1;
                        }
                    }
                }
            }
            ma = ma.next;
        }
    }

    # try current module's symbol table
    if (call_sym == nil && ctx.symbols != nil) {
        val sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(func_name);
        if (sym_opt.is_some()) {
            call_sym = sym_opt.unwrap();
            found_via = 2;
        }
    }

    # if not found, search imported modules
    if (call_sym == nil) {
        call_sym = lookup_symbol_in_imports(ctx, func_name);
        if (call_sym != nil) {
            found_via = 3;
        }
    }

    # use linkage name if symbol was found
    var is_indirect_call: bool = false;
    if (call_sym != nil) {
        val link: str = symbol.linkage_name(call_sym, ctx.alloc);
        if (link != nil) {
            func_name = link;
        }
    } or {
        # no symbol found — field access callee might be a function pointer
        if (callee.kind == ast.NODE_EXPR_FIELD) {
            is_indirect_call = true;
        }
    }

    # lower arguments
    var arg_count: i32 = 0;
    if (args != nil) {
        arg_count = args.count;
    }

    # determine return type and if we need sret
    var ret_size: usize = 0;
    var needs_sret: bool = false;
    var ret_ty: *ty.Type = node.ty;

    # if node type not resolved (e.g., calls in unanalyzed imported module functions),
    # try to get return type from the called function's symbol
    if (ret_ty == nil && call_sym != nil && call_sym.resolved_type != nil) {
        if (call_sym.resolved_type.kind == ty.TY_FUN && call_sym.resolved_type.ret_type != nil) {
            ret_ty = call_sym.resolved_type.ret_type;
        }
    }

    # resolve TY_GENERIC_PARAM return types through receiver's generic args
    # e.g., unwrap_ok() returns T, resolve T -> Stat via Result[Stat, str]
    if (ret_ty != nil && ret_ty.kind == ty.TY_GENERIC_PARAM && ret_ty.name != nil &&
        method_recv_base_ty != nil && method_recv_base_ty.generic_arg_count > 0 &&
        method_recv_base_ty.generic_args != nil) {
        val base_gen: *ty.Type = method_recv_base_ty.base_generic;
        if (base_gen != nil && base_gen.generic_param_count > 0) {
            var gpi: i32 = 0;
            var gp_resolved: bool = false;
            for (gpi < base_gen.generic_param_count) {
                val pname: str = ty.get_generic_param_name(base_gen, gpi);
                if (!gp_resolved && pname != nil && pname.equals(ret_ty.name) &&
                    gpi < method_recv_base_ty.generic_arg_count) {
                    ret_ty = method_recv_base_ty.generic_args[gpi];
                    gp_resolved = true;
                }
                gpi = gpi + 1;
            }
        }
    }

    if (ret_ty != nil) {
        ret_size = ret_ty.size;
        # sret is needed for large aggregates (must match callee-side detection)
        if (type_is_large_aggregate(ret_ty, ctx.ptr_size)) {
            needs_sret = true;
        }

        # handle generic return types (e.g., Result[T, E], Option[T])
        # generic types are typically Result or Option which are aggregates > 8 bytes.
        # always assume sret for generic return types to match callee-side detection.
        if (ret_ty.kind == ty.TY_GENERIC) {
            needs_sret = true;
            # try to get actual size from call symbol's concrete return type
            if (call_sym != nil && call_sym.resolved_type != nil &&
                call_sym.resolved_type.kind == ty.TY_FUN &&
                call_sym.resolved_type.ret_type != nil &&
                call_sym.resolved_type.ret_type.size > 0) {
                ret_size = call_sym.resolved_type.ret_type.size;
                ret_ty = call_sym.resolved_type.ret_type;
            } or {
                if (ret_size == 0) {
                    ret_size = 24;  # conservative estimate as last resort
                }
            }
        }

        # fallback: if ret_ty is unresolved (generic param/small), cross-check with call_sym
        if (!needs_sret && call_sym != nil && call_sym.resolved_type != nil) {
            if (call_sym.resolved_type.kind == ty.TY_FUN && call_sym.resolved_type.ret_type != nil) {
                val sym_ret: *ty.Type = call_sym.resolved_type.ret_type;
                if (type_is_large_aggregate(sym_ret, ctx.ptr_size)) {
                    needs_sret = true;
                    ret_ty = sym_ret;
                    ret_size = sym_ret.size;
                }
            }
        }
    } or {
        # fallback: if type is unknown but call has type args, assume generic return
        # this handles cases where imported module function bodies weren't analyzed
        if (node.info.call_expr.type_args != nil) {
            needs_sret = true;
            # try to get actual size from call symbol's concrete return type
            if (call_sym != nil && call_sym.resolved_type != nil &&
                call_sym.resolved_type.kind == ty.TY_FUN &&
                call_sym.resolved_type.ret_type != nil &&
                call_sym.resolved_type.ret_type.size > 0) {
                ret_size = call_sym.resolved_type.ret_type.size;
            } or {
                ret_size = 24;  # conservative estimate as last resort
            }
        }
    }

    # allocate space for sret buffer if needed
    var sret_offset: i32 = 0;
    var sret_ptr: ir.IRValue = ir.make_none();
    if (needs_sret) {
        ctx.stack_offset = ctx.stack_offset - ret_size::i32;
        if (ctx.stack_offset % 8 != 0) {
            ctx.stack_offset = ctx.stack_offset - (8 - ((-ctx.stack_offset) % 8));
        }
        sret_offset = ctx.stack_offset;
        # LEA address of sret buffer into a register
        val sret_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        sret_ptr = ir.make_reg(sret_reg, ctx.ptr_size);
        val sret_mem: ir.IRValue = frame_mem(ctx, sret_offset, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      sret_ptr, sret_mem, ir.make_none(), ir.CC_NONE);
    }

    # allocate array for argument values (+ 1 for sret if needed)
    var total_args: i32 = arg_count;
    if (needs_sret) {
        total_args = total_args + 1;
    }
    val args_r: Result[*ir.IRValue, allocator.AllocError] = ctx.alloc.alloc[ir.IRValue](total_args::usize);
    if (args_r.is_err()) {
        ret make_none();
    }

    val arg_vals: *ir.IRValue = args_r.unwrap_ok();

    # first argument is sret pointer if needed
    var arg_offset: i32 = 0;
    if (needs_sret) {
        arg_vals[0] = sret_ptr;
        arg_offset = 1;
    }

    var i: i32 = 0;
    for (i < arg_count) {
        arg_vals[arg_offset + i] = lower_expr(ctx, args.nodes[i]);

        # large aggregates (records/arrays > ptr_size) are passed by hidden pointer:
        # take the address of the stack slot instead of loading the value
        val av: ir.IRValue = arg_vals[arg_offset + i];
        if (av.kind == ir.VAL_MEM && av.size > ctx.ptr_size) {
            val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
            val addr_val: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                          addr_val, av, ir.make_none(), ir.CC_NONE);
            arg_vals[arg_offset + i] = addr_val;
        }

        i = i + 1;
    }

    # emit call - for sret, pass 0 ret_size since return is via pointer
    var call_ret_size: usize = 0;
    if (!needs_sret) {
        call_ret_size = ret_size;
    }
    var result: ir.IRValue = ir.make_none();
    if (is_indirect_call) {
        # load function pointer from field access
        val fn_ptr: ir.IRValue = lower_expr(ctx, callee);
        # ensure it's in a register
        val fn_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val fn_val: ir.IRValue = ir.make_reg(fn_reg, ctx.ptr_size);
        emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, fn_val, fn_ptr, ir.make_none(), 0);
        result = emit_indirect_call(ctx, fn_val, arg_vals, total_args, call_ret_size);
    } or {
        result = emit_call(ctx, func_name, arg_vals, total_args, call_ret_size);
    }

    # clean up argument array
    ctx.alloc.free[ir.IRValue](arg_vals, total_args::usize);

    # for sret, return memory reference to the buffer
    if (needs_sret) {
        ret frame_mem(ctx, sret_offset, ret_size);
    }

    ret result;
}

# resolve_node_type: recursively resolve the type of an expression node.
# ---
# ctx:  lowering context
# node: expression node
# ret:  resolved type or nil
fun resolve_node_type(ctx: *LowerContext, node: *ast.Node) *ty.Type {
    if (ctx == nil || node == nil) {
        ret nil;
    }

    # in generic instantiations, skip node.ty shortcut — it holds
    # the uninstantiated type from the shared AST. Instead, resolve
    # through local_vars and field chains to get concrete types.
    if (node.ty != nil && ctx.type_binding_count == 0) {
        ret node.ty;
    }

    # IDENT: look up local variable type
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.info.ident_expr.name;
        if (name != nil) {
            val idx: i32 = find_local_var(ctx, name);
            if (idx >= 0) {
                ret ctx.local_vars[idx].ty;
            }
        }
        ret nil;
    }

    # FIELD: resolve base type, then look up field
    if (node.kind == ast.NODE_EXPR_FIELD) {
        val inner_base: *ast.Node = node.info.field_expr.object;
        val inner_field: str = node.info.field_expr.field;
        if (inner_base == nil || inner_field == nil) {
            ret nil;
        }
        val inner_base_ty: *ty.Type = resolve_node_type(ctx, inner_base);
        if (inner_base_ty == nil) {
            ret nil;
        }
        # auto-dereference pointer
        var struct_ty: *ty.Type = inner_base_ty;
        if (struct_ty.kind == ty.TY_POINTER && struct_ty.inner != nil) {
            struct_ty = struct_ty.inner;
        }
        if (struct_ty.kind == ty.TY_RECORD || struct_ty.kind == ty.TY_UNION) {
            val field_opt: Option[*ty.Field] = ty.get_field(struct_ty, inner_field);
            if (field_opt.is_some()) {
                val resolved_field: *ty.Field = field_opt.unwrap();
                var rnt_ft: *ty.Type = resolved_field.ty;
                # resolve generic parameter types through type bindings
                if (rnt_ft != nil && rnt_ft.kind == ty.TY_GENERIC_PARAM &&
                    ctx.type_binding_count > 0 && ctx.type_binding_names != nil && rnt_ft.name != nil) {
                    val rnt_gp: str = rnt_ft.name;
                    var rnt_i: i32 = 0;
                    for (rnt_i < ctx.type_binding_count) {
                        if (ctx.type_binding_names[rnt_i] != nil && ctx.type_binding_names[rnt_i].equals(rnt_gp)) {
                            rnt_ft = ctx.type_binding_types[rnt_i];
                        }
                        rnt_i = rnt_i + 1;
                    }
                }
                ret rnt_ft;
            }
        }
        ret nil;
    }

    # INDEX: resolve base type, get element type
    if (node.kind == ast.NODE_EXPR_INDEX) {
        val index_base: *ast.Node = node.info.index_expr.base;
        if (index_base == nil) {
            ret nil;
        }
        val index_base_ty: *ty.Type = resolve_node_type(ctx, index_base);
        if (index_base_ty == nil) {
            ret nil;
        }
        if (index_base_ty.kind == ty.TY_POINTER && index_base_ty.inner != nil) {
            ret index_base_ty.inner;
        }
        if (index_base_ty.kind == ty.TY_ARRAY && index_base_ty.inner != nil) {
            ret index_base_ty.inner;
        }
        ret nil;
    }

    # CAST: resolve target type
    if (node.kind == ast.NODE_EXPR_CAST) {
        val cast_type_node: *ast.Node = node.info.cast_expr.type_node;
        if (cast_type_node != nil) {
            ret resolve_type_annotation(ctx, cast_type_node);
        }
        ret nil;
    }

    ret nil;
}

# lower_field_access: lower a field access expression.
# ---
# ctx:  lowering context
# node: field access node
# ret:  IRValue containing field value
fun lower_field_access(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val base: *ast.Node = node.info.field_expr.object;
    val field_name: str = node.info.field_expr.field;

    if (base == nil || field_name == nil) {
        ret make_none();
    }

    # get the base expression's type FIRST to check if this is a module-qualified access
    var base_ty: *ty.Type = base.ty;

    # check if base is a local variable that may have nil type due to sema issues
    # or wrong type due to shared AST in generic instantiation.
    # Prefer local_vars resolved type when type bindings exist.
    var base_is_local: bool = false;
    if ((base_ty == nil || ctx.type_binding_count > 0) && base.kind == ast.NODE_EXPR_IDENT) {
        val base_name: str = base.info.ident_expr.name;
        if (base_name != nil) {
            val local_idx: i32 = find_local_var(ctx, base_name);
            if (local_idx >= 0) {
                # found a local variable - use its resolved type
                val resolved_bt: *ty.Type = ctx.local_vars[local_idx].ty;
                if (resolved_bt != nil) {
                    base_ty = resolved_bt;
                }
                base_is_local = true;
            }
        }
    }

    # for non-IDENT bases (FIELD, INDEX, CAST, etc.), recursively resolve the type
    if ((base_ty == nil || ctx.type_binding_count > 0) && base.kind != ast.NODE_EXPR_IDENT) {
        val resolved_nidt: *ty.Type = resolve_node_type(ctx, base);
        if (resolved_nidt != nil) {
            base_ty = resolved_nidt;
        }
    }

    if (base_ty == nil) {
        # if base is a local variable with nil type, this is an error - return none
        if (base_is_local) {
            ret make_none();
        }

        # base has no type and is not a local - this might be a module alias access
        # like c.STDERR_FILENO. Treat field_name as a global symbol reference.

        # look up symbol for linkage name and function detection
        var global_label: str = field_name;
        var is_func_sym: bool = false;

        # for module alias access, look up in the specific aliased module first
        var fa_found: bool = false;
        if (base.kind == ast.NODE_EXPR_IDENT && ctx.current_sema_mod != nil) {
            val alias_name: str = base.info.ident_expr.name;
            if (alias_name != nil) {
                var fa_ma: *sema.ModuleAlias = ctx.current_sema_mod.aliases;
                for (fa_ma != nil) {
                    if (fa_ma.alias != nil && fa_ma.alias.equals(alias_name)) {
                        if (fa_ma.module != nil && fa_ma.module.table != nil) {
                            val fa_mod_root: *symbol.Scope = fa_ma.module.table.root_scope();
                            if (fa_mod_root != nil) {
                                val fa_mod_sym_opt: Option[*symbol.Symbol] = fa_mod_root.lookup_local(field_name);
                                if (fa_mod_sym_opt.is_some()) {
                                    val fa_mod_sym: *symbol.Symbol = fa_mod_sym_opt.unwrap();
                                    if (fa_mod_sym.kind == symbol.SYM_FUN) {
                                        is_func_sym = true;
                                    }
                                    val fa_mod_link: str = symbol.linkage_name(fa_mod_sym, ctx.alloc);
                                    if (fa_mod_link != nil) {
                                        global_label = fa_mod_link;
                                    }
                                    fa_found = true;
                                }
                            }
                        }
                    }
                    fa_ma = fa_ma.next;
                }
            }
        }

        # fallback: search current module and imports
        if (!fa_found && ctx.symbols != nil) {
            val fa_sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(field_name);
            if (fa_sym_opt.is_some()) {
                val fa_sym: *symbol.Symbol = fa_sym_opt.unwrap();
                if (fa_sym.kind == symbol.SYM_FUN) {
                    is_func_sym = true;
                }
                val fa_link: str = symbol.linkage_name(fa_sym, ctx.alloc);
                if (fa_link != nil) {
                    global_label = fa_link;
                }
            }
            if (global_label == field_name) {
                val fa_imp_sym: *symbol.Symbol = lookup_symbol_in_imports(ctx, field_name);
                if (fa_imp_sym != nil) {
                    if (fa_imp_sym.kind == symbol.SYM_FUN) {
                        is_func_sym = true;
                    }
                    val fa_imp_link: str = symbol.linkage_name(fa_imp_sym, ctx.alloc);
                    if (fa_imp_link != nil) {
                        global_label = fa_imp_link;
                    }
                }
            }
        }

        var v: ir.IRValue;
        v.kind = ir.VAL_LABEL;
        v.reg = 0;
        v.imm = 0;
        v.offset = 0;
        v.base_reg = 0;
        v.index_reg = -1;
        v.scale = 1;
        v.label = global_label;
        v.size = ctx.ptr_size;

        # determine size from node type if available
        var sym_size: usize = ctx.ptr_size;
        if (node.ty != nil) {
            sym_size = node.ty.size;
        }

        # load address into register
        val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      addr, v, ir.make_none(), ir.CC_NONE);

        # check if this is an aggregate type or function
        val var_ty: *ty.Type = node.ty;
        val is_aggregate: bool = var_ty != nil && (var_ty.kind == ty.TY_RECORD ||
                                                    var_ty.kind == ty.TY_UNION ||
                                                    var_ty.kind == ty.TY_ARRAY);
        if (is_aggregate || is_func_sym || sym_size > 8) {
            ret addr;
        }

        # scalar: load value from address
        val mem: ir.IRValue = ir.make_mem(addr_reg, -1, 1, 0, sym_size);
        ret emit_load(ctx, mem, sym_size);
    }

    # lower base to get struct pointer/value
    val base_value: ir.IRValue = lower_expr(ctx, base);

    # if pointer, dereference to get struct type
    var struct_ty: *ty.Type = base_ty;
    var is_pointer: bool = false;
    if (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
        struct_ty = base_ty.inner;
        is_pointer = true;
    }

    # look up field by name
    val field_opt: Option[*ty.Field] = ty.get_field(struct_ty, field_name);
    if (field_opt.is_none()) {
        ret make_none();
    }
    val field: *ty.Field = field_opt.unwrap();

    # get field offset and size from type system
    val field_offset: i32 = field.offset::i32;
    var field_size: usize = ctx.ptr_size;
    var effective_field_ty: *ty.Type = field.ty;
    # resolve generic parameter types through type bindings (e.g., T -> File)
    if (effective_field_ty != nil && effective_field_ty.kind == ty.TY_GENERIC_PARAM &&
        ctx.type_binding_count > 0 && ctx.type_binding_names != nil && effective_field_ty.name != nil) {
        val gp_name: str = effective_field_ty.name;
        var tbi: i32 = 0;
        var resolved_binding: bool = false;
        for (tbi < ctx.type_binding_count) {
            if (!resolved_binding && ctx.type_binding_names[tbi] != nil && ctx.type_binding_names[tbi].equals(gp_name)) {
                effective_field_ty = ctx.type_binding_types[tbi];
                resolved_binding = true;
            }
            tbi = tbi + 1;
        }
    }
    # fallback: use AST node type when field type is nil (common in monomorphized generics)
    if (effective_field_ty == nil && node.ty != nil) {
        effective_field_ty = node.ty;
    }
    if (effective_field_ty != nil && effective_field_ty.size > 0) {
        field_size = effective_field_ty.size;
    }

    # For aggregate fields (record/union/array), or when field type is unknown
    # (common in monomorphized generics), return the memory operand directly
    # so the caller can use it as an address for further field access or copying.
    # For scalar fields with known type, load the value into a register.
    val field_is_aggregate: bool = effective_field_ty == nil ||
        effective_field_ty.kind == ty.TY_GENERIC_PARAM ||
        (effective_field_ty.kind == ty.TY_RECORD || effective_field_ty.kind == ty.TY_UNION ||
         effective_field_ty.kind == ty.TY_ARRAY);

    # compute field address based on base_value kind and pointer vs direct access
    if (is_pointer) {
        # pointer field access: need the pointer value as base
        if (base_value.kind == ir.VAL_REG) {
            # base_value is already a register containing the pointer value
            val mem: ir.IRValue = ir.make_mem(base_value.reg, -1, 1, field_offset::i64, field_size);
            if (field_is_aggregate) {
                ret mem;
            }
            ret emit_load(ctx, mem, field_size);
        } or {
            if (base_value.kind == ir.VAL_MEM) {
                # base_value is memory operand - load the pointer value first
                val ptr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                val ptr_val: ir.IRValue = ir.make_reg(ptr_reg, ctx.ptr_size);
                emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, ptr_val, base_value, ir.make_none(), 0);
                val mem: ir.IRValue = ir.make_mem(ptr_reg, -1, 1, field_offset::i64, field_size);
                if (field_is_aggregate) {
                    ret mem;
                }
                ret emit_load(ctx, mem, field_size);
            }
        }
    } or {
        # direct struct access (not through pointer)
        if (base_value.kind == ir.VAL_REG) {
            # base_value is register containing address of struct (LEA result)
            val mem: ir.IRValue = ir.make_mem(base_value.reg, -1, 1, field_offset::i64, field_size);
            if (field_is_aggregate) {
                ret mem;
            }
            ret emit_load(ctx, mem, field_size);
        } or {
            if (base_value.kind == ir.VAL_MEM) {
                # base_value is memory operand (struct on stack) - adjust displacement
                val mem: ir.IRValue = ir.make_mem(base_value.base_reg, base_value.index_reg,
                                                   base_value.scale, base_value.offset + field_offset::i64, field_size);
                if (field_is_aggregate) {
                    ret mem;
                }
                ret emit_load(ctx, mem, field_size);
            }
        }
    }

    # fallback: use ADD (shouldn't normally reach here)
    val offset_value: ir.IRValue = ir.make_imm(field_offset::i64, ctx.ptr_size);
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, base_value, offset_value, ctx.ptr_size);

    # load from field address
    ret emit_load(ctx, addr, field_size);
}

# lower_index: lower an array index expression.
# ---
# ctx:  lowering context
# node: index expression node
# ret:  IRValue containing element value
fun lower_index(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val base: *ast.Node = node.info.index_expr.base;
    val index: *ast.Node = node.info.index_expr.index;

    if (base == nil || index == nil) {
        ret make_none();
    }

    # lower index and extend to pointer size if needed
    val raw_index: ir.IRValue = lower_expr(ctx, index);
    var index_value: ir.IRValue = raw_index;
    val index_ty: *ty.Type = index.ty;
    if (index_ty != nil && index_ty.size < ctx.ptr_size) {
        val ext_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val ext_val: ir.IRValue = ir.make_reg(ext_reg, ctx.ptr_size);
        if (index_ty.is_signed()) {
            emit_instr(ctx, ir.IROp{ir_sext: ir.OP_SEXT}, ext_val, raw_index, ir.make_none(), 0);
        } or {
            emit_instr(ctx, ir.IROp{ir_zext: ir.OP_ZEXT}, ext_val, raw_index, ir.make_none(), 0);
        }
        index_value = ext_val;
    }

    # lower base
    var base_value: ir.IRValue = lower_expr(ctx, base);
    var base_ty: *ty.Type = base.ty;

    # fall back to local_vars type table if node type is nil
    if (base_ty == nil && base.kind == ast.NODE_EXPR_IDENT) {
        val idx_base_name: str = base.info.ident_expr.name;
        if (idx_base_name != nil) {
            val idx_local: i32 = find_local_var(ctx, idx_base_name);
            if (idx_local >= 0) {
                base_ty = ctx.local_vars[idx_local].ty;
            }
        }
    }

    if (base_value.kind == ir.VAL_MEM) {
        if (base_ty != nil && (base_ty.kind == ty.TY_POINTER || base_ty.kind == ty.TY_STR)) {
            # load pointer value from memory (str is also a pointer type)
            base_value = emit_load(ctx, base_value, ctx.ptr_size);
        }
        # array types keep base_value as memory (address of array)
    }

    # calculate element address: base + index * elem_size
    var elem_size: usize = ctx.ptr_size;
    var elem_type: *ty.Type = nil;
    if (base_ty != nil) {
        if (base_ty.kind == ty.TY_ARRAY && base_ty.inner != nil) {
            elem_type = base_ty.inner;
            elem_size = base_ty.inner.size;
        } or (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
            elem_type = base_ty.inner;
            elem_size = base_ty.inner.size;
        } or (base_ty.kind == ty.TY_STR) {
            elem_size = 1;  # str is &u8, element size is 1
        }
    }

    # check if element type is aggregate (record/union/array) — return address, not value
    val elem_is_aggregate: bool = elem_type != nil &&
        (elem_type.kind == ty.TY_RECORD || elem_type.kind == ty.TY_UNION ||
         elem_type.kind == ty.TY_ARRAY);

    if (index_value.kind == ir.VAL_IMM) {
        val idx_offset: i64 = index_value.imm * elem_size::i64;
        var addr: ir.IRValue;
        if (base_value.kind == ir.VAL_MEM) {
            addr = ir.make_mem(base_value.base_reg, base_value.index_reg,
                               base_value.scale, base_value.offset + idx_offset, elem_size);
        } or {
            # VAL_REG: register contains pointer/address
            addr = ir.make_mem(base_value.reg, -1, 1, idx_offset, elem_size);
        }
        if (elem_is_aggregate) {
            ret addr;
        }
        ret emit_load(ctx, addr, elem_size);
    }

    # ensure base_value is in a register (LEA for VAL_MEM arrays)
    val idx_needs_lea: bool = base_value.kind == ir.VAL_MEM;
    var idx_lea_reg: i32 = 0;
    if (idx_needs_lea) {
        idx_lea_reg = new_vreg(ctx, ctx.ptr_size);
        val idx_lea_dst: ir.IRValue = ir.make_reg(idx_lea_reg, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      idx_lea_dst, base_value, ir.make_none(), ir.CC_NONE);
    }

    val elem_size_value: ir.IRValue = ir.make_imm(elem_size::i64, ctx.ptr_size);
    val offset_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val offset: ir.IRValue = ir.make_reg(offset_reg, ctx.ptr_size);
    emit_alu(ctx, ir.IROp{ir_mul: ir.OP_MUL}, offset, index_value, elem_size_value, ctx.ptr_size);

    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
    if (idx_needs_lea) {
        val idx_lea_src: ir.IRValue = ir.make_reg(idx_lea_reg, ctx.ptr_size);
        emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, idx_lea_src, offset, ctx.ptr_size);
    } or {
        emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, base_value, offset, ctx.ptr_size);
    }

    # aggregate elements: return memory operand (address) for further field access
    if (elem_is_aggregate) {
        ret ir.make_mem(addr_reg, -1, 1, 0, elem_size);
    }

    # scalar elements: load value
    ret emit_load(ctx, addr, elem_size);
}

# lower_cast: lower a type cast expression.
# ---
# ctx:  lowering context
# node: cast expression node
# ret:  IRValue containing casted value
fun lower_cast(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val op_node: *ast.Node = node.info.cast_expr.expr;
    if (op_node == nil) {
        ret make_none();
    }

    var src_ty: *ty.Type = op_node.ty;
    val dst_ty: *ty.Type = node.ty;

    # resolve source type from local vars if not set on the node
    if (src_ty == nil && op_node.kind == ast.NODE_EXPR_IDENT) {
        val src_name: str = op_node.info.ident_expr.name;
        if (src_name != nil) {
            val src_idx: i32 = find_local_var(ctx, src_name);
            if (src_idx >= 0) {
                src_ty = ctx.local_vars[src_idx].ty;
            }
        }
    }

    # array to pointer/str casts should use the array address
    if (src_ty != nil && src_ty.kind == ty.TY_ARRAY &&
        dst_ty != nil && (dst_ty.kind == ty.TY_POINTER || dst_ty.kind == ty.TY_STR)) {
        ret lower_lvalue(ctx, op_node);
    }

    val value: ir.IRValue = lower_expr(ctx, op_node);

    # determine target size
    var target_size: usize = 8;
    if (node.ty != nil) {
        target_size = node.ty.size;
    }

    # aggregate-to-scalar cast: load the value from the aggregate address
    if (src_ty != nil && (src_ty.kind == ty.TY_RECORD || src_ty.kind == ty.TY_UNION)) {
        if (dst_ty == nil || (dst_ty.kind != ty.TY_RECORD && dst_ty.kind != ty.TY_UNION)) {
            if (value.kind == ir.VAL_REG) {
                # value is an address (from LEA); load the scalar value from it
                val agg_mem: ir.IRValue = ir.make_mem(value.reg, -1, 1, 0, target_size);
                ret emit_load(ctx, agg_mem, target_size);
            }
            if (value.kind == ir.VAL_MEM) {
                # value is already a memory reference; load from it with target size
                var load_mem: ir.IRValue = value;
                load_mem.size = target_size;
                ret emit_load(ctx, load_mem, target_size);
            }
        }
    }

    # for now, just move to a register of the right size
    # proper casting (sign extension, zero extension) would go here
    val dst_reg: i32 = new_vreg(ctx, target_size);
    val dst: ir.IRValue = ir.make_reg(dst_reg, target_size);

    emit_mov(ctx, dst, value, target_size);

    ret dst;
}

# lower_addr: lower an address-of expression.
# ---
# ctx:  lowering context
# node: address-of node
# ret:  IRValue containing address
fun lower_addr(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val operand: *ast.Node = node.info.unary_expr.expr;
    if (operand == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # get lvalue memory reference
    val mem: ir.IRValue = lower_lvalue(ctx, operand);

    # if lvalue is a memory reference, emit LEA to compute the address as a value
    if (mem.kind == ir.VAL_MEM) {
        val result_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val result: ir.IRValue = ir.make_reg(result_reg, ctx.ptr_size);
        ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                      result, mem, ir.make_none(), ir.CC_NONE);
        ret result;
    }

    # for labels or other kinds, return as-is (address is the label itself)
    ret mem;
}

# lower_deref: lower a dereference expression.
# ---
# ctx:  lowering context
# node: dereference node
# ret:  IRValue containing dereferenced value
fun lower_deref(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val op_node: *ast.Node = node.info.unary_expr.expr;
    if (op_node == nil) {
        ret make_none();
    }

    # lower operand to get pointer
    val ptr: ir.IRValue = lower_expr(ctx, op_node);

    # load from pointer
    # determine size from result type or pointed-to type
    var size: usize = ctx.ptr_size;
    if (node.ty != nil) {
        size = node.ty.size;
    } or {
        # fallback: get from operand's pointed-to type
        val ptr_ty: *ty.Type = op_node.ty;
        if (ptr_ty != nil && ptr_ty.kind == ty.TY_POINTER && ptr_ty.inner != nil) {
            size = ptr_ty.inner.size;
        }
    }

    ret emit_load(ctx, ptr, size);
}

# lower_try: lower a try expression (unwrap Result/Option).
# ---
# ctx:  lowering context
# node: try expression node
# ret:  IRValue containing unwrapped value or error return
fun lower_try(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    val operand: *ast.Node = node.info.unary_expr.expr;
    if (operand == nil) {
        ret make_none();
    }

    # lower the operand
    val value: ir.IRValue = lower_expr(ctx, operand);

    # TODO: check if result is error, and if so, return early
    # this requires type information about the Result/Option

    ret value;
}

# lower_array_lit: lower an array literal expression.
# ---
# ctx:  lowering context
# node: array literal node
# ret:  IRValue containing array address
fun lower_array_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # elements are stored in array_lit.elements
    val elements: *ast.List = node.info.array_lit.elements;
    if (elements == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    val elem_count: i32 = elements.count;
    if (elem_count == 0) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # allocate stack space for array
    var elem_size: usize = ctx.ptr_size;
    val arr_ty: *ty.Type = node.ty;
    if (arr_ty != nil && arr_ty.kind == ty.TY_ARRAY && arr_ty.inner != nil) {
        elem_size = arr_ty.inner.size;
    }
    val array_size: usize = elem_count::usize * elem_size;

    # allocate stack space
    ctx.stack_offset = ctx.stack_offset - array_size::i32;
    val array_offset: i32 = ctx.stack_offset;

    # emit initializers
    var i: i32 = 0;
    for (i < elem_count) {
        val elem_value: ir.IRValue = lower_expr(ctx, elements.nodes[i]);
        val elem_addr: ir.IRValue = frame_mem(ctx, array_offset + i::i32 * elem_size::i32, elem_size);
        emit_store(ctx, elem_addr, elem_value);
        i = i + 1;
    }

    # return address of array
    val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
    val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);

    # compute array address from frame pointer
    var instr: ir.Instr;
    instr.op = ir.IROp{ir_lea: ir.OP_LEA};
    instr.dst = addr;
    # frame_mem gives us an address relative to FP
    val fp_addr: ir.IRValue = frame_mem(ctx, array_offset, ctx.ptr_size);
    instr.src1 = fp_addr;
    instr.src2 = ir.make_none();
    instr.cond = ir.CC_NONE;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr.op, instr.dst, instr.src1, instr.src2, instr.cond);

    ret addr;
}

# lower_struct_lit: lower a struct literal expression.
# ---
# ctx:  lowering context
# node: struct literal node
# ret:  IRValue containing struct address (for large structs) or value
fun lower_struct_lit(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret make_none();
    }

    # get struct type - try node.ty first, fall back to type annotation in struct_lit.type_node
    var struct_ty: *ty.Type = node.ty;
    if (struct_ty == nil) {
        val slit_type_node: *ast.Node = node.info.struct_lit.type_node;
        if (slit_type_node != nil) {
            val type_name: str = slit_type_node.info.type_name.path;
            if (type_name != nil) {
                # look up in current module symbols
                var type_sym: *symbol.Symbol = nil;
                if (ctx.symbols != nil) {
                    val sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(type_name);
                    if (sym_opt.is_some()) {
                        type_sym = sym_opt.unwrap();
                    }
                }
                if (type_sym == nil) {
                    type_sym = lookup_symbol_in_imports(ctx, type_name);
                }
                if (type_sym != nil && type_sym.resolved_type != nil) {
                    struct_ty = type_sym.resolved_type;
                }
            }
        }
    }
    if (struct_ty == nil) {
        ret make_none();
    }
    if (struct_ty.kind != ty.TY_RECORD && struct_ty.kind != ty.TY_UNION) {
        ret make_none();
    }

    # allocate stack space for struct
    ctx.stack_offset = ctx.stack_offset - struct_ty.size::i32;

    # align to pointer size
    val align: i32 = ctx.ptr_size::i32;
    if (align > 1) {
        val abs_offset: i32 = -ctx.stack_offset;
        val remainder: i32 = abs_offset % align;
        if (remainder != 0) {
            ctx.stack_offset = ctx.stack_offset - (align - remainder);
        }
    }

    val base_offset: i32 = ctx.stack_offset;

    # get field initializers from struct_lit.fields
    val fields: *ast.List = node.info.struct_lit.fields;
    if (fields != nil && fields.count > 0) {
        var i: i32 = 0;
        for (i < fields.count) {
            val field_node: *ast.Node = fields.nodes[i];
            if (field_node == nil) {
                i = i + 1;
                cnt;
            }

            # field name from field_decl.name, init expr from field_decl.type_node
            val field_name: str = field_node.info.field_decl.name;
            val init_expr: *ast.Node = field_node.info.field_decl.type_node;

            if (field_name == nil || init_expr == nil) {
                i = i + 1;
                cnt;
            }

            # look up field info from type
            var field_offset: usize = 0;
            var field_ty: *ty.Type = nil;

            if (struct_ty.kind == ty.TY_RECORD) {
                val field_opt: Option[*ty.Field] = ty.get_field(struct_ty, field_name);
                if (field_opt.is_some()) {
                    val field: *ty.Field = field_opt.unwrap();
                    field_offset = field.offset;
                    field_ty = field.ty;
                }
            } or {
                # union: all variants at offset 0
                val field_opt: Option[*ty.Field] = ty.get_field(struct_ty, field_name);
                if (field_opt.is_some()) {
                    val field: *ty.Field = field_opt.unwrap();
                    field_ty = field.ty;
                }
                field_offset = 0;
            }

            if (field_ty == nil) {
                i = i + 1;
                cnt;
            }

            # lower init expression
            val init_value: ir.IRValue = lower_expr(ctx, init_expr);

            # compute destination address
            val dest_disp: i32 = base_offset + field_offset::i32;

            # check if aggregate field needing memcpy
            val is_agg: bool = field_ty.kind == ty.TY_RECORD ||
                               field_ty.kind == ty.TY_UNION ||
                               field_ty.kind == ty.TY_ARRAY;

            if (is_agg && field_ty.size > ctx.ptr_size) {
                # aggregate copy: load source address, copy bytes
                val fsize: usize = field_ty.size;
                if (fsize > 0) {
                    # get source pointer
                    var src_ptr: ir.IRValue;
                    if (init_value.kind == ir.VAL_MEM) {
                        # LEA to get address
                        val src_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                        src_ptr = ir.make_reg(src_reg, ctx.ptr_size);
                        emit_instr(ctx, ir.IROp{ir_lea: ir.OP_LEA}, src_ptr, init_value, ir.make_none(), 0);
                    } or {
                        src_ptr = init_value;
                    }

                    # get dest pointer
                    val dst_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                    val dst_ptr: ir.IRValue = ir.make_reg(dst_reg, ctx.ptr_size);
                    val dst_addr: ir.IRValue = frame_mem(ctx, dest_disp, ctx.ptr_size);
                    emit_instr(ctx, ir.IROp{ir_lea: ir.OP_LEA}, dst_ptr, dst_addr, ir.make_none(), 0);

                    # byte-by-byte copy (chunk = 8 where possible)
                    var k: usize = 0;
                    var chunk: usize = 8;
                    for (k < fsize) {
                        if (fsize - k < 8) {
                            chunk = 1;
                        }
                        val tmp_reg: i32 = new_vreg(ctx, chunk);
                        val tmp: ir.IRValue = ir.make_reg(tmp_reg, chunk);

                        # load from src
                        var src_mem: ir.IRValue;
                        src_mem.kind = ir.VAL_MEM;
                        src_mem.size = chunk;
                        src_mem.base_reg = src_ptr.reg;
                        src_mem.index_reg = -1;
                        src_mem.scale = 1;
                        src_mem.offset = k::i64;

                        emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, tmp, src_mem, ir.make_none(), 0);

                        # store to dst
                        var dst_mem: ir.IRValue;
                        dst_mem.kind = ir.VAL_MEM;
                        dst_mem.size = chunk;
                        dst_mem.base_reg = dst_ptr.reg;
                        dst_mem.index_reg = -1;
                        dst_mem.scale = 1;
                        dst_mem.offset = k::i64;

                        emit_instr(ctx, ir.IROp{ir_store: ir.OP_STORE}, dst_mem, tmp, ir.make_imm(chunk::i64, 8), 0);

                        k = k + chunk;
                    }
                }
            } or {
                # simple scalar store
                val dest: ir.IRValue = frame_mem(ctx, dest_disp, field_ty.size);
                emit_store(ctx, dest, init_value);
            }

            i = i + 1;
        }
    }

    # return frame memory reference for the struct
    var ret_size: usize = struct_ty.size;
    if (ret_size == 0) {
        ret_size = ctx.ptr_size;
    }
    ret frame_mem(ctx, base_offset, ret_size);
}

# lower_lvalue: get the address of an lvalue expression.
# ---
# ctx:  lowering context
# node: lvalue node (identifier, field access, index, deref)
# ret:  IRValue containing address
fun lower_lvalue(ctx: *LowerContext, node: *ast.Node) ir.IRValue {
    if (ctx == nil || node == nil) {
        ret ir.make_imm(0, ctx.ptr_size);
    }

    # identifier - local or global variable
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.info.ident_expr.name;
        if (name == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }

        # check locals
        val local_idx: i32 = find_local_var(ctx, name);
        if (local_idx >= 0) {
            val offset: i32 = get_local_var_offset(ctx, local_idx);
            val size: usize = ctx.local_vars[local_idx].size;
            ret frame_mem(ctx, offset, size);
        }

        # global variable - look up symbol for linkage name
        var lv_label: str = name;
        if (ctx.symbols != nil) {
            val lv_sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(name);
            if (lv_sym_opt.is_some()) {
                val lv_sym: *symbol.Symbol = lv_sym_opt.unwrap();
                val lv_link: str = symbol.linkage_name(lv_sym, ctx.alloc);
                if (lv_link != nil) {
                    lv_label = lv_link;
                }
            }
            if (lv_label == name) {
                val lv_imp_sym: *symbol.Symbol = lookup_symbol_in_imports(ctx, name);
                if (lv_imp_sym != nil) {
                    val lv_imp_link: str = symbol.linkage_name(lv_imp_sym, ctx.alloc);
                    if (lv_imp_link != nil) {
                        lv_label = lv_imp_link;
                    }
                }
            }
        }

        var v: ir.IRValue;
        v.kind = ir.VAL_LABEL;
        v.reg = 0;
        v.imm = 0;
        v.offset = 0;
        v.base_reg = 0;
        v.index_reg = -1;
        v.scale = 1;
        v.label = lv_label;
        v.size = ctx.ptr_size;
        ret v;
    }

    # field access - base address + field offset
    if (node.kind == ast.NODE_EXPR_FIELD) {
        val base: *ast.Node = node.info.field_expr.object;
        val field_name: str = node.info.field_expr.field;

        if (base == nil || field_name == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }

        # resolve type and field info FIRST (before deciding lvalue vs expr)
        var field_offset: usize = 0;
        var field_size: usize = ctx.ptr_size;
        var base_ty: *ty.Type = base.ty;
        if ((base_ty == nil || ctx.type_binding_count > 0) && base.kind == ast.NODE_EXPR_IDENT) {
            val base_name: str = base.info.ident_expr.name;
            if (base_name != nil) {
                val local_idx: i32 = find_local_var(ctx, base_name);
                if (local_idx >= 0) {
                    val resolved_bt: *ty.Type = ctx.local_vars[local_idx].ty;
                    if (resolved_bt != nil) {
                        base_ty = resolved_bt;
                    }
                }
            }
        }
        if ((base_ty == nil || ctx.type_binding_count > 0) && base.kind != ast.NODE_EXPR_IDENT) {
            val resolved_bt2: *ty.Type = resolve_node_type(ctx, base);
            if (resolved_bt2 != nil) {
                base_ty = resolved_bt2;
            }
        }
        var is_pointer: bool = false;
        if (base_ty != nil) {
            var struct_ty: *ty.Type = base_ty;
            if (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
                struct_ty = base_ty.inner;
                is_pointer = true;
            }
            val field_opt: Option[*ty.Field] = ty.get_field(struct_ty, field_name);
            if (field_opt.is_some()) {
                val field: *ty.Field = field_opt.unwrap();
                field_offset = field.offset;
                var lv_eff_ft: *ty.Type = field.ty;
                if (lv_eff_ft != nil && lv_eff_ft.kind == ty.TY_GENERIC_PARAM &&
                    ctx.type_binding_count > 0 && ctx.type_binding_names != nil && lv_eff_ft.name != nil) {
                    val lv_gp_name: str = lv_eff_ft.name;
                    var lv_tbi: i32 = 0;
                    for (lv_tbi < ctx.type_binding_count) {
                        if (ctx.type_binding_names[lv_tbi] != nil && ctx.type_binding_names[lv_tbi].equals(lv_gp_name)) {
                            lv_eff_ft = ctx.type_binding_types[lv_tbi];
                        }
                        lv_tbi = lv_tbi + 1;
                    }
                }
                if (lv_eff_ft != nil && lv_eff_ft.size > 0) {
                    field_size = lv_eff_ft.size;
                }
            }
        }

        # for non-lvalue base expressions (CALL, CAST) returning pointer types,
        # use lower_expr to get the pointer value directly — lower_lvalue would
        # return imm(0) since CALL nodes don't have addressable storage
        if (base.kind == ast.NODE_EXPR_CALL && is_pointer) {
            val base_val: ir.IRValue = lower_expr(ctx, base);
            if (base_val.kind == ir.VAL_REG) {
                ret ir.make_mem(base_val.reg, -1, 1, field_offset::i64, field_size);
            }
            if (base_val.kind == ir.VAL_MEM) {
                val lv_ptr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                val lv_ptr_val: ir.IRValue = ir.make_reg(lv_ptr_reg, ctx.ptr_size);
                emit_instr(ctx, ir.IROp{ir_load: ir.OP_LOAD}, lv_ptr_val, base_val, ir.make_none(), 0);
                ret ir.make_mem(lv_ptr_reg, -1, 1, field_offset::i64, field_size);
            }
        }

        val base_addr: ir.IRValue = lower_lvalue(ctx, base);

        # handle pointer field access - need to load pointer value first
        if (is_pointer) {
            # load the pointer value into a register
            val ptr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
            val ptr_val: ir.IRValue = ir.make_reg(ptr_reg, ctx.ptr_size);
            var load_instr: ir.Instr;
            load_instr.op = ir.IROp{ir_load: ir.OP_LOAD};
            load_instr.dst = ptr_val;
            load_instr.src1 = base_addr;
            load_instr.src2 = ir.make_none();
            load_instr.cond = ir.CC_NONE;
            emit_instr(ctx, load_instr.op, load_instr.dst, load_instr.src1, load_instr.src2, 0);

            ret ir.make_mem(ptr_reg, -1, 1, field_offset::i64, field_size);
        }

        # for non-pointer: check if base_addr is a memory operand (local struct)
        if (base_addr.kind == ir.VAL_MEM) {
            # just adjust the displacement - no ADD instruction needed
            var result: ir.IRValue = base_addr;
            result.offset = base_addr.offset + field_offset::i64;
            result.size = field_size;
            ret result;
        }

        # for register or label operands, use LEA to compute address
        if (base_addr.kind == ir.VAL_REG) {
            ret ir.make_mem(base_addr.reg, -1, 1, field_offset::i64, field_size);
        }

        # fallback: use LEA for other cases (e.g., globals)
        val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
        var mem: ir.IRValue = base_addr;
        mem.offset = mem.offset + field_offset::i64;
        emit_instr(ctx, ir.IROp{ir_lea: ir.OP_LEA}, addr, mem, ir.make_none(), 0);
        ret addr;
    }

    # array index - base + index * elem_size
    if (node.kind == ast.NODE_EXPR_INDEX) {
        val base: *ast.Node = node.info.index_expr.base;
        val index: *ast.Node = node.info.index_expr.index;

        if (base == nil || index == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }

        val raw_base_addr: ir.IRValue = lower_lvalue(ctx, base);
        val index_value: ir.IRValue = lower_expr(ctx, index);

        # get element size from type
        var elem_size: usize = ctx.ptr_size;
        var base_ty: *ty.Type = base.ty;
        # fall back to local_vars type table if node type is nil
        if (base_ty == nil && base.kind == ast.NODE_EXPR_IDENT) {
            val lv_idx_name: str = base.info.ident_expr.name;
            if (lv_idx_name != nil) {
                val lv_idx_local: i32 = find_local_var(ctx, lv_idx_name);
                if (lv_idx_local >= 0) {
                    base_ty = ctx.local_vars[lv_idx_local].ty;
                }
            }
        }
        if (base_ty != nil) {
            if (base_ty.kind == ty.TY_ARRAY && base_ty.inner != nil) {
                elem_size = base_ty.inner.size;
            } or (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
                elem_size = base_ty.inner.size;
            } or (base_ty.kind == ty.TY_STR) {
                elem_size = 1;  # str is &u8, element size is 1
            }
        }
        # for pointer/str types, load the pointer value from the address
        val lv_ptr_base: ir.IRValue = load_ptr_if_needed(ctx, raw_base_addr, base_ty);

        # for array types (VAL_MEM), LEA the address into a register
        # so that select_add can operate on it
        val lv_needs_lea: bool = lv_ptr_base.kind == ir.VAL_MEM;
        var lv_lea_reg: i32 = 0;
        if (lv_needs_lea) {
            lv_lea_reg = new_vreg(ctx, ctx.ptr_size);
            val lv_lea_dst: ir.IRValue = ir.make_reg(lv_lea_reg, ctx.ptr_size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                          lv_lea_dst, lv_ptr_base, ir.make_none(), ir.CC_NONE);
        }

        val elem_size_value: ir.IRValue = ir.make_imm(elem_size::i64, ctx.ptr_size);

        # multiply index by element size
        val offset_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val offset: ir.IRValue = ir.make_reg(offset_reg, ctx.ptr_size);
        emit_alu(ctx, ir.IROp{ir_mul: ir.OP_MUL}, offset, index_value, elem_size_value, ctx.ptr_size);

        # add to base
        val addr_reg: i32 = new_vreg(ctx, ctx.ptr_size);
        val addr: ir.IRValue = ir.make_reg(addr_reg, ctx.ptr_size);
        if (lv_needs_lea) {
            val lv_lea_src: ir.IRValue = ir.make_reg(lv_lea_reg, ctx.ptr_size);
            emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, lv_lea_src, offset, ctx.ptr_size);
        } or {
            emit_alu(ctx, ir.IROp{ir_add: ir.OP_ADD}, addr, lv_ptr_base, offset, ctx.ptr_size);
        }

        ret addr;
    }

    # dereference - just return the pointer value
    if (node.kind == ast.NODE_EXPR_DEREF) {
        val operand: *ast.Node = node.info.unary_expr.expr;
        if (operand == nil) {
            ret ir.make_imm(0, ctx.ptr_size);
        }
        ret lower_expr(ctx, operand);
    }

    # parenthesized expression: unwrap and lower inner lvalue
    if (node.kind == ast.NODE_EXPR_PAREN) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            ret lower_lvalue(ctx, inner);
        }
        ret ir.make_imm(0, ctx.ptr_size);
    }

    ret ir.make_imm(0, ctx.ptr_size);
}

# --- statement lowering ---

# lower_stmt: lower a statement node to IR.
# ---
# ctx:  lowering context
# node: statement AST node
# ret:  none
pub fun lower_stmt(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # record pre-emission instruction count for debug annotation
    var pre_count: i32 = 0;
    if (ctx.current_block != nil) {
        pre_count = ctx.current_block.instr_count;
    }

    lower_stmt_inner(ctx, node);

    # annotate first new instruction with source location
    if (ctx.current_block != nil && ctx.current_block.instr_count > pre_count) {
        annotate_instr(ctx, ctx.current_block, pre_count, node);
    }
}

fun lower_stmt_inner(ctx: *LowerContext, node: *ast.Node) {
    # variable declaration
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        lower_var_decl(ctx, node);
        ret;
    }

    # expression statement (includes assignments: binary expr with op == '=')
    if (node.kind == ast.NODE_STMT_EXPR) {
        val expr: *ast.Node = node.info.wrapper.inner;
        if (expr != nil) {
            lower_expr(ctx, expr);
        }
        ret;
    }

    # return statement
    if (node.kind == ast.NODE_STMT_RET) {
        lower_return(ctx, node);
        ret;
    }

    # if statement
    if (node.kind == ast.NODE_STMT_IF) {
        lower_if(ctx, node);
        ret;
    }

    # or block (else clause of if/or chain)
    if (node.kind == ast.NODE_STMT_OR) {
        val or_cond: *ast.Node = node.info.cond_stmt.cond;
        val or_body: *ast.Node = node.info.cond_stmt.body;

        if (or_cond != nil) {
            # conditional or: or (cond) { ... } — treat as if
            lower_if(ctx, node);
        } or {
            # unconditional or: or { ... } — just lower the body
            if (or_body != nil) {
                lower_stmt(ctx, or_body);
            }
        }
        ret;
    }

    # while/for loop
    if (node.kind == ast.NODE_STMT_FOR) {
        lower_loop(ctx, node);
        ret;
    }

    # break statement
    if (node.kind == ast.NODE_STMT_BRK) {
        # emit deferred statements up to loop mark
        val mark: i32 = pop_loop_defer_mark(ctx);
        emit_deferred_from(ctx, mark);

        # branch to loop end label
        if (ctx.loop_end_label != nil) {
            emit_br(ctx, ctx.loop_end_label);
        }
        ret;
    }

    # continue statement
    if (node.kind == ast.NODE_STMT_CNT) {
        # emit deferred statements up to loop mark
        val mark: i32 = pop_loop_defer_mark(ctx);
        emit_deferred_from(ctx, mark);

        # branch to loop start label
        if (ctx.loop_start_label != nil) {
            emit_br(ctx, ctx.loop_start_label);
        }
        ret;
    }

    # defer statement
    if (node.kind == ast.NODE_STMT_FIN) {
        val stmt: *ast.Node = node.info.wrapper.inner;
        defer_statement(ctx, stmt);
        ret;
    }

    # block statement
    if (node.kind == ast.NODE_STMT_BLOCK) {
        lower_block(ctx, node);
        ret;
    }

    # inline assembly
    if (node.kind == ast.NODE_STMT_MASM) {
        lower_inline_asm(ctx, node);
        ret;
    }
}

# lower_var_decl: lower a variable declaration.
# ---
# ctx:  lowering context
# node: variable declaration node
# ret:  none
fun lower_var_decl(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val name: str = node.info.var_decl.name;
    if (name == nil) {
        ret;
    }

    # get type - try node.ty first, fall back to type annotation resolution
    var var_ty: *ty.Type = node.ty;
    # when type bindings exist (generic instantiation), resolve via annotation
    # to get the concrete type (e.g., Result[T, E] -> Result[stat_t, str])
    if (ctx.type_binding_count > 0) {
        val type_ann_g: *ast.Node = node.info.var_decl.type_node;
        if (type_ann_g != nil) {
            val resolved_vt: *ty.Type = resolve_type_annotation(ctx, type_ann_g);
            if (resolved_vt != nil) {
                # only override if the resolved type has a larger or equal size
                # (avoids replacing a correct instantiated type from node.ty
                #  with a smaller generic type from symbol lookup)
                if (var_ty == nil || resolved_vt.size >= var_ty.size) {
                    var_ty = resolved_vt;
                }
            }
        }
    }
    if (var_ty == nil) {
        # try to resolve type from type annotation (stored in extra)
        val type_ann: *ast.Node = node.info.var_decl.type_node;
        if (type_ann != nil && type_ann.kind == ast.NODE_TYPE_NAME) {
            val type_name: str = type_ann.info.type_name.path;
            if (type_name != nil) {
                var type_sym: *symbol.Symbol = nil;
                if (ctx.symbols != nil) {
                    val sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(type_name);
                    if (sym_opt.is_some()) {
                        type_sym = sym_opt.unwrap();
                    }
                }
                if (type_sym == nil) {
                    type_sym = lookup_symbol_in_imports(ctx, type_name);
                }
                if (type_sym != nil && type_sym.resolved_type != nil) {
                    var_ty = type_sym.resolved_type;
                }
            }
        }
    }

    # get type size
    var size: usize = ctx.ptr_size;
    if (var_ty != nil) {
        size = var_ty.size;
    }

    # get initializer from var_decl.init
    val init_node: *ast.Node = node.info.var_decl.init;

    # allocate stack space
    val offset: i32 = add_local_var(ctx, name, size, var_ty);

    if (init_node != nil) {
        val init_value: ir.IRValue = lower_expr(ctx, init_node);
        val addr: ir.IRValue = frame_mem(ctx, offset, size);
        emit_store(ctx, addr, init_value);
    }
}

# lower_return: lower a return statement.
# ---
# ctx:  lowering context
# node: return statement node
# ret:  none
fun lower_return(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # emit all deferred statements in LIFO order
    emit_deferred_from(ctx, 0);

    # lower return value if present
    val expr: *ast.Node = node.info.wrapper.inner;
    var ret_value: ir.IRValue = make_none();
    if (expr != nil) {
        ret_value = lower_expr(ctx, expr);
    }

    # for sret returns, copy value into the sret buffer and return the pointer
    if (ctx.fn_has_sret && ctx.fn_ret_type != nil && ctx.fn_ret_type.size > ctx.ptr_size && expr != nil) {
        # load sret pointer from its stack slot
        val sret_slot: ir.IRValue = frame_mem(ctx, ctx.sret_offset, ctx.ptr_size);
        val dst_ptr: ir.IRValue = emit_load(ctx, sret_slot, ctx.ptr_size);
        val dst_reg: i32 = dst_ptr.reg;

        # copy return value into sret buffer
        if (ret_value.kind == ir.VAL_MEM) {
            # source is a memory operand - get its address for a chunked copy
            val src_reg: i32 = new_vreg(ctx, ctx.ptr_size);
            val src_ptr: ir.IRValue = ir.make_reg(src_reg, ctx.ptr_size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                          src_ptr, ret_value, ir.make_none(), ir.CC_NONE);

            # chunked copy: 8 bytes at a time
            val total_size: i32 = ctx.fn_ret_type.size::i32;
            var off: i32 = 0;
            for (off < total_size) {
                var chunk: usize = 8;
                if ((total_size - off)::usize < 8) {
                    chunk = (total_size - off)::usize;
                }
                val tmp_reg: i32 = new_vreg(ctx, chunk);
                val tmp: ir.IRValue = ir.make_reg(tmp_reg, chunk);

                # load from source + offset
                var src_mem: ir.IRValue;
                src_mem.kind = ir.VAL_MEM;
                src_mem.base_reg = src_reg;
                src_mem.offset = off::i64;
                src_mem.size = chunk;
                src_mem.reg = 0;
                src_mem.imm = 0;
                src_mem.index_reg = -1;
                src_mem.scale = 1;
                src_mem.label = nil;
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                              tmp, src_mem, ir.make_none(), ir.CC_NONE);

                # store to sret buffer + offset
                var dst_mem: ir.IRValue;
                dst_mem.kind = ir.VAL_MEM;
                dst_mem.base_reg = dst_reg;
                dst_mem.offset = off::i64;
                dst_mem.size = chunk;
                dst_mem.reg = 0;
                dst_mem.imm = 0;
                dst_mem.index_reg = -1;
                dst_mem.scale = 1;
                dst_mem.label = nil;
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                              dst_mem, tmp, ir.make_none(), ir.CC_NONE);

                off = off + chunk::i32;
            }
        } or (ret_value.kind == ir.VAL_REG) {
            # source is a register containing an address (LEA result for aggregate)
            # chunk-copy from that address to the sret buffer
            val src_reg: i32 = ret_value.reg;
            val total_size: i32 = ctx.fn_ret_type.size::i32;
            var off: i32 = 0;
            for (off < total_size) {
                var chunk: usize = 8;
                if ((total_size - off)::usize < 8) {
                    chunk = (total_size - off)::usize;
                }
                val tmp_reg: i32 = new_vreg(ctx, chunk);
                val tmp: ir.IRValue = ir.make_reg(tmp_reg, chunk);

                # load from source address + offset
                var src_mem: ir.IRValue;
                src_mem.kind = ir.VAL_MEM;
                src_mem.base_reg = src_reg;
                src_mem.offset = off::i64;
                src_mem.size = chunk;
                src_mem.reg = 0;
                src_mem.imm = 0;
                src_mem.index_reg = -1;
                src_mem.scale = 1;
                src_mem.label = nil;
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                              tmp, src_mem, ir.make_none(), ir.CC_NONE);

                # store to sret buffer + offset
                var dst_mem: ir.IRValue;
                dst_mem.kind = ir.VAL_MEM;
                dst_mem.base_reg = dst_reg;
                dst_mem.offset = off::i64;
                dst_mem.size = chunk;
                dst_mem.reg = 0;
                dst_mem.imm = 0;
                dst_mem.index_reg = -1;
                dst_mem.scale = 1;
                dst_mem.label = nil;
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                              dst_mem, tmp, ir.make_none(), ir.CC_NONE);

                off = off + chunk::i32;
            }
        }

        # return the sret pointer
        emit_ret(ctx, dst_ptr);
        ret;
    }

    # small aggregate return (size <= ptr_size): lower_expr returns an address (LEA)
    # for local variables, or a memory operand for field accesses.
    # we need to return the actual value in a register.
    # call expressions already return the value directly in a register.
    if (expr != nil && ctx.fn_ret_type != nil &&
        (ctx.fn_ret_type.kind == ty.TY_RECORD ||
         ctx.fn_ret_type.kind == ty.TY_UNION ||
         ctx.fn_ret_type.kind == ty.TY_ARRAY) &&
        ctx.fn_ret_type.size > 0 && ctx.fn_ret_type.size <= ctx.ptr_size &&
        expr.kind != ast.NODE_EXPR_CALL) {
        if (ret_value.kind == ir.VAL_REG) {
            # ret_value register holds an address (LEA result) — load the value from it
            var agg_src_mem: ir.IRValue;
            agg_src_mem.kind = ir.VAL_MEM;
            agg_src_mem.base_reg = ret_value.reg;
            agg_src_mem.offset = 0;
            agg_src_mem.size = ctx.fn_ret_type.size;
            agg_src_mem.reg = 0;
            agg_src_mem.imm = 0;
            agg_src_mem.index_reg = -1;
            agg_src_mem.scale = 1;
            agg_src_mem.label = nil;
            val agg_val_reg: i32 = new_vreg(ctx, ctx.fn_ret_type.size);
            val agg_val: ir.IRValue = ir.make_reg(agg_val_reg, ctx.fn_ret_type.size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                          agg_val, agg_src_mem, ir.make_none(), ir.CC_NONE);
            ret_value = agg_val;
        } or (ret_value.kind == ir.VAL_MEM) {
            # ret_value is a memory operand (from field access) — override size
            # with the return type's actual size and load into register
            ret_value.size = ctx.fn_ret_type.size;
            val agg_val_reg: i32 = new_vreg(ctx, ctx.fn_ret_type.size);
            val agg_val: ir.IRValue = ir.make_reg(agg_val_reg, ctx.fn_ret_type.size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                          agg_val, ret_value, ir.make_none(), ir.CC_NONE);
            ret_value = agg_val;
        }
    }

    # emit return instruction
    emit_ret(ctx, ret_value);
}

# lower_if: lower an if statement.
# ---
# ctx:  lowering context
# node: if statement node
# ret:  none
fun lower_if(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val cond: *ast.Node = node.info.cond_stmt.cond;
    val then_stmt: *ast.Node = node.info.cond_stmt.body;
    val else_stmt: *ast.Node = node.info.cond_stmt.or_branch;

    if (cond == nil) {
        ret;
    }

    # lower condition
    val cond_value: ir.IRValue = lower_expr(ctx, cond);

    # create labels
    val then_label: str = new_label(ctx, ".Lif_then");
    val else_label: str = new_label(ctx, ".Lif_or");
    val end_label: str = new_label(ctx, ".Lif_end");

    # emit conditional branch
    # compare condition with 0
    val zero: ir.IRValue = ir.make_imm(0, 8);
    emit_cmp(ctx, cond_value, zero, 8);

    # branch to else if condition is false (equal to 0)
    if (else_stmt != nil) {
        emit_cond_br(ctx, ir.CC_EQ::i32, else_label);
    } or {
        emit_cond_br(ctx, ir.CC_EQ::i32, end_label);
    }

    # then block (fall through - no JMP needed)
    if (then_stmt != nil) {
        lower_stmt(ctx, then_stmt);
    }
    emit_br(ctx, end_label);

    # else block
    if (else_stmt != nil) {
        emit_label(ctx, else_label);
        lower_stmt(ctx, else_stmt);
    }

    # end
    emit_label(ctx, end_label);
}

# lower_loop: lower a while or for loop.
# ---
# ctx:  lowering context
# node: loop statement node
# ret:  none
fun lower_loop(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    # create labels
    val start_label: str = new_label(ctx, ".Lfor_start");
    val end_label: str = new_label(ctx, ".Lfor_end");

    # save previous loop labels
    val prev_start: str = ctx.loop_start_label;
    val prev_end: str = ctx.loop_end_label;

    # set new loop labels
    ctx.loop_start_label = start_label;
    ctx.loop_end_label = end_label;

    # mark defer stack for this loop
    push_loop_defer_mark(ctx);

    # loop start
    emit_label(ctx, start_label);

    # condition check (if present)
    val cond: *ast.Node = node.info.for_stmt.cond;
    if (cond != nil) {
        val cond_value: ir.IRValue = lower_expr(ctx, cond);
        val zero: ir.IRValue = ir.make_imm(0, 8);
        emit_cmp(ctx, cond_value, zero, 8);
        emit_cond_br(ctx, ir.CC_EQ::i32, end_label);
    }

    # loop body
    val body: *ast.Node = node.info.for_stmt.body;
    if (body != nil) {
        lower_stmt(ctx, body);
    }

    # branch back to start
    emit_br(ctx, start_label);

    # loop end
    emit_label(ctx, end_label);

    # emit deferred statements for normal loop exit
    val mark: i32 = pop_loop_defer_mark(ctx);
    emit_deferred_from(ctx, mark);

    # restore previous loop labels
    ctx.loop_start_label = prev_start;
    ctx.loop_end_label = prev_end;
}

# lower_block: lower a block statement.
# ---
# ctx:  lowering context
# node: block node
# ret:  none
fun lower_block(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil) {
        ret;
    }

    val stmts: *ast.List = node.info.block_stmt.stmts;
    if (stmts == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < stmts.count) {
        lower_stmt(ctx, stmts.nodes[i]);
        i = i + 1;
    }
}


# lower_inline_asm: lower an inline assembly block.
# ---
# ctx:  lowering context
# node: asm node
# ret:  none
pub fun lower_inline_asm(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret;
    }

    # get asm content from masm_stmt.content
    val content: str = node.info.masm_stmt.content;
    if (content == nil) {
        ret;
    }

    # check for ISA-specific block: "x86_64 { ... }"
    # the parser stores the full content including any ISA prefix
    var asm_content: str = content;
    var i: usize = 0;

    # skip leading whitespace
    for (content[i] == ' ' || content[i] == '\t' || content[i] == '\n' || content[i] == '\r') {
        i = i + 1;
    }

    # check for "x86_64" prefix
    if (content[i] == 'x' && content[i+1] == '8' && content[i+2] == '6' &&
        content[i+3] == '_' && content[i+4] == '6' && content[i+5] == '4') {
        i = i + 6;

        # skip whitespace
        for (content[i] == ' ' || content[i] == '\t' || content[i] == '\n' || content[i] == '\r') {
            i = i + 1;
        }

        # expect '{'
        if (content[i] == '{') {
            i = i + 1;

            # find matching '}'
            var depth: i32 = 1;
            val start: usize = i;
            for (depth > 0 && content[i] != 0) {
                if (content[i] == '{') {
                    depth = depth + 1;
                }
                if (content[i] == '}') {
                    depth = depth - 1;
                }
                if (depth > 0) {
                    i = i + 1;
                }
            }

            # extract inner content
            val inner_len: usize = i - start;
            if (inner_len > 0) {
                val alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](inner_len + 1);
                if (alloc_res.is_ok()) {
                    val buf: *u8 = alloc_res.unwrap_ok();
                    var j: usize = 0;
                    for (j < inner_len) {
                        buf[j] = content[start + j];
                        j = j + 1;
                    }
                    buf[inner_len] = 0;
                    asm_content = buf::str;
                }
            }
        }
    }

    # handle syscall DSL: "syscall result, num, arg0, ..."
    var scan_idx: usize = 0;
    for (asm_content[scan_idx] != 0) {
        for (is_space_u8(asm_content[scan_idx])) {
            scan_idx = scan_idx + 1;
        }

        if (asm_content[scan_idx] == 0) {
            brk;
        }

        # skip line comments
        if (asm_content[scan_idx] == '#') {
            for (asm_content[scan_idx] != 0 && asm_content[scan_idx] != '\n') {
                scan_idx = scan_idx + 1;
            }
            cnt;
        }

        var line_end: usize = scan_idx;
        for (asm_content[line_end] != 0 && asm_content[line_end] != '\n' && asm_content[line_end] != ';' && asm_content[line_end] != '#') {
            line_end = line_end + 1;
        }

        var syscall_pos: i32 = -1;
        var search_idx: usize = scan_idx;
        for (search_idx + 7 <= line_end) {
            if (asm_content[search_idx] == 's' && asm_content[search_idx + 1] == 'y' && asm_content[search_idx + 2] == 's' &&
                asm_content[search_idx + 3] == 'c' && asm_content[search_idx + 4] == 'a' && asm_content[search_idx + 5] == 'l' &&
                asm_content[search_idx + 6] == 'l') {
                val before_ok: bool = search_idx == scan_idx || is_space_u8(asm_content[search_idx - 1]);
                val after_ok: bool = search_idx + 7 == line_end || is_space_u8(asm_content[search_idx + 7]);
                if (before_ok && after_ok) {
                    syscall_pos = search_idx::i32;
                    brk;
                }
            }
            search_idx = search_idx + 1;
        }

        if (syscall_pos < 0) {
            scan_idx = line_end;
            for (asm_content[scan_idx] == '\n' || asm_content[scan_idx] == ';' || asm_content[scan_idx] == '#') {
                scan_idx = scan_idx + 1;
            }
            cnt;
        }

        var idx: usize = syscall_pos::usize + 7;
        val dst_tok: str = extract_token(ctx, asm_content, idx, ?idx);
        if (dst_tok == nil) {
            # standalone syscall instruction, not DSL format - skip and let x86 parser handle it
            scan_idx = line_end;
            for (asm_content[scan_idx] == '\n' || asm_content[scan_idx] == ';' || asm_content[scan_idx] == '#') {
                scan_idx = scan_idx + 1;
            }
            cnt;
        }

        for (idx < line_end && (asm_content[idx] == ',' || is_space_u8(asm_content[idx]))) {
            idx = idx + 1;
        }

        if (idx >= line_end) {
            # no more tokens after dst - not valid DSL format, skip
            scan_idx = line_end;
            for (asm_content[scan_idx] == '\n' || asm_content[scan_idx] == ';' || asm_content[scan_idx] == '#') {
                scan_idx = scan_idx + 1;
            }
            cnt;
        }

        # skip comma
        for (asm_content[idx] == ',' || is_space_u8(asm_content[idx])) {
            idx = idx + 1;
        }

        if (idx >= line_end) {
            # no syscall number - not valid DSL format, skip
            scan_idx = line_end;
            for (asm_content[scan_idx] == '\n' || asm_content[scan_idx] == ';' || asm_content[scan_idx] == '#') {
                scan_idx = scan_idx + 1;
            }
            cnt;
        }

        val num_tok: str = extract_token(ctx, asm_content, idx, ?idx);
        if (num_tok == nil) {
            # no syscall number - not valid DSL format, skip
            scan_idx = line_end;
            for (asm_content[scan_idx] == '\n' || asm_content[scan_idx] == ';' || asm_content[scan_idx] == '#') {
                scan_idx = scan_idx + 1;
            }
            cnt;
        }

        val num_val: ir.IRValue = resolve_value_token(ctx, num_tok);

        var arg_vals: [6]ir.IRValue;
        var arg_count: i32 = 0;
        for (arg_count < 6) {
            for (asm_content[idx] == ',' || is_space_u8(asm_content[idx])) {
                idx = idx + 1;
            }

            if (idx >= line_end || asm_content[idx] == 0 || asm_content[idx] == '\n' || asm_content[idx] == ';' || asm_content[idx] == '#') {
                brk;
            }

            val arg_tok: str = extract_token(ctx, asm_content, idx, ?idx);
            if (arg_tok == nil) {
                brk;
            }

            arg_vals[arg_count] = resolve_value_token(ctx, arg_tok);
            arg_count = arg_count + 1;
        }

        var ret_val: ir.IRValue = ir.make_none();
        if (arg_count > 0) {
            ret_val = emit_syscall_value(ctx, num_val, ?arg_vals[0], arg_count);
        } or {
            ret_val = emit_syscall_value(ctx, num_val, nil, 0);
        }

        val dst_addr: ir.IRValue = resolve_lvalue_token(ctx, dst_tok);
        if (dst_addr.kind == ir.VAL_NONE || (dst_addr.kind == ir.VAL_IMM && dst_addr.imm == 0)) {
            # no destination; ignore syscall result
            ret;
        }
        emit_store(ctx, dst_addr, ret_val);
        ret;
    }

    # dispatch inline assembly to ISA-specific backend
    val text_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, ".text", section.section_text());
    if (text_res.is_err()) {
        report_lower_error(ctx, node.tok, "failed to get .text section for inline asm");
        ret;
    }
    val text_sec: *section.Section = text_res.unwrap_ok();
    val asm_res: Result[usize, str] = isel.assemble(?ctx.tgt, asm_content, text_sec, ctx.m, ctx.alloc);
    if (asm_res.is_err()) {
        report_lower_error(ctx, node.tok, asm_res.unwrap_err());
        ret;
    }
}

# --- function lowering ---

# lower_function: lower a function declaration to IR.
# ---
# ctx:  lowering context
# node: function AST node
# ret:  Ok(*IRFunction) on success, Err(str) on failure
pub fun lower_function(ctx: *LowerContext, node: *ast.Node) Result[*ir.IRFunction, str] {
    if (ctx == nil) {
        ret err[*ir.IRFunction, str]("context is nil");
    }

    if (node == nil) {
        ret err[*ir.IRFunction, str]("node is nil");
    }

    # reset per-function state
    reset_function_state(ctx);

    val name: str = node.info.fun_decl.name;
    if (name == nil) {
        ret err[*ir.IRFunction, str]("function has no name");
    }

    # for methods, build qualified name "ReceiverType.methodName" to look up symbol
    var symbol_key: str = name;
    if (node.info.fun_decl.receiver != nil) {
        val recv_type_name: str = get_receiver_type_name(node.info.fun_decl.receiver);
        if (recv_type_name != nil) {
            # build "ReceiverType.methodName"
            val recv_len: usize = recv_type_name.len();
            val name_len: usize = name.len();
            val total_len: usize = recv_len + 1 + name_len + 1;

            val alloc_res: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](total_len);
            if (alloc_res.is_ok()) {
                val buf: *u8 = alloc_res.unwrap_ok();
                var i: usize = 0;
                # copy receiver type name
                for (i < recv_len) {
                    buf[i] = recv_type_name[i];
                    i = i + 1;
                }
                buf[i] = '.';
                i = i + 1;
                # copy method name
                var j: usize = 0;
                for (j < name_len) {
                    buf[i] = name[j];
                    i = i + 1;
                    j = j + 1;
                }
                buf[i] = 0;
                symbol_key = buf::str;
            }
        }
    }

    # skip generic functions/methods in regular lowering pass (they get lowered
    # per-instantiation in a separate pass with type bindings)
    if (ctx.func_name_override == nil) {
        # skip generic free functions (have fun_decl.generics)
        if (node.info.fun_decl.generics != nil) {
            ret err[*ir.IRFunction, str]("skipped generic function");
        }

        # skip generic methods (receiver has generic type args)
        if (node.info.fun_decl.receiver != nil) {
            var skip_recv_type: *ast.Node = node.info.fun_decl.receiver.info.field_decl.type_node;
            for (skip_recv_type != nil && (skip_recv_type.kind == ast.NODE_TYPE_PTR || skip_recv_type.kind == ast.NODE_TYPE_REF)) {
                skip_recv_type = skip_recv_type.info.type_ptr.inner;
            }
            if (skip_recv_type != nil && skip_recv_type.kind == ast.NODE_TYPE_NAME) {
                val skip_generic_args: *ast.Node = skip_recv_type.info.type_name.args;
                if (skip_generic_args != nil && skip_generic_args.kind == ast.NODE_GENERIC) {
                    ret err[*ir.IRFunction, str]("skipped generic method");
                }
            }
        }
    }

    # resolve linkage name (e.g., $main.symbol override)
    var func_name: str = symbol_key;
    var sym: *symbol.Symbol = nil;

    # if we have a function name override (instantiation lowering), use it
    if (ctx.func_name_override != nil) {
        func_name = ctx.func_name_override;
        # look up the instantiated symbol
        if (ctx.symbols != nil) {
            val sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(ctx.func_name_override);
            if (sym_opt.is_some()) {
                sym = sym_opt.unwrap();
            }
        }
        if (sym == nil) {
            sym = lookup_symbol_in_imports(ctx, ctx.func_name_override);
        }
        # compute linkage name for the instantiated symbol
        if (sym != nil) {
            val link: str = symbol.linkage_name(sym, ctx.alloc);
            if (link != nil) {
                func_name = link;
            }
        }
    } or {
        # first try current module's symbol table
        if (ctx.symbols != nil) {
            val sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(symbol_key);
            if (sym_opt.is_some()) {
                sym = sym_opt.unwrap();
            }
        }

        # if not found, search imported modules
        if (sym == nil) {
            sym = lookup_symbol_in_imports(ctx, symbol_key);
        }

        # use linkage name if symbol was found
        if (sym != nil) {
            val link: str = symbol.linkage_name(sym, ctx.alloc);
            if (link != nil) {
                func_name = link;
            }
        }
    }

    # create IR function
    val fn_res: Result[*ir.IRFunction, str] = ir.create_function(ctx.alloc, func_name);
    if (fn_res.is_err()) {
        ret fn_res;
    }

    val func: *ir.IRFunction = fn_res.unwrap_ok();
    ctx.current_fn = func;

    # create entry block
    val entry_label: str = new_label(ctx, ".Lentry");
    val block_res: Result[*ir.IRBlock, str] = ir.create_block(ctx.alloc, entry_label);
    if (block_res.is_err()) {
        ret err[*ir.IRFunction, str](block_res.unwrap_err());
    }

    val entry_block: *ir.IRBlock = block_res.unwrap_ok();
    ctx.current_block = entry_block;

    # add block to function
    if (ir.add_block(ctx.alloc, func, entry_block) < 0) {
        ret err[*ir.IRFunction, str]("failed to add entry block");
    }

    # emit function label
    emit_label(ctx, func_name);

    # check if this is the entry point (_start)
    val is_entry: bool = func_name != nil && func_name.equals("_start");

    # create MASM symbol for function
    if (ctx.m != nil) {
        val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, func_name);
        if (sym_res.is_ok()) {
            val s: *sym.Symbol = sym_res.unwrap_ok();
            s.binding.tag = sym.BIND_GLOBAL;
            s.sym_type.tag = sym.SYM_FUNC;

            # set source location for DWARF debug info
            if (ctx.text != nil && node.tok.pos > 0) {
                s.src_line = line_for_pos(ctx.text, node.tok.pos);
            }
            if (ctx.current_sema_mod != nil && ctx.current_sema_mod.file_path != nil) {
                s.src_file = ctx.current_sema_mod.file_path;
            }

            # for entry point functions, define symbol now at current .text offset
            # because their code is emitted directly via inline asm, not through isel
            if (is_entry) {
                val text_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, ".text", section.section_text());
                if (text_res.is_ok()) {
                    val text_sec: *section.Section = text_res.unwrap_ok();
                    sym.define(s, text_sec, text_sec.size, 0);
                }
            }
            
            masm.add_symbol(ctx.m, s);
        }
    }

    # determine function return type and whether we need sret
    # use return type override if available (for generic instantiation)
    if (ctx.ret_type_override != nil) {
        ctx.fn_ret_type = ctx.ret_type_override;
        if (type_is_large_aggregate(ctx.fn_ret_type, ctx.ptr_size)) {
            ctx.fn_has_sret = true;
        }
    } or (node.ty != nil) {
        if (node.ty.kind == ty.TY_FUN) {
            if (node.ty.ret_type != nil) {
                ctx.fn_ret_type = node.ty.ret_type;
                if (type_is_large_aggregate(ctx.fn_ret_type, ctx.ptr_size)) {
                    ctx.fn_has_sret = true;
                }
            }
        }
    }

    # track argument register usage
    # note: stack frame setup is handled by isel prologue, not emitted as IR
    var int_arg_idx: i32 = 0;
    var float_arg_idx: i32 = 0;

    # handle hidden sret pointer for large aggregate returns
    if (!is_entry && ctx.fn_has_sret) {
        # sret pointer is passed in first integer arg register
        ctx.stack_offset = ctx.stack_offset - ctx.ptr_size::i32;
        ctx.sret_offset = ctx.stack_offset;
        int_arg_idx = 1;  # skip first arg reg since it holds sret

        # store sret pointer to stack slot
        val sret_reg: i32 = abi.get_arg_reg(?ctx.abi, 0);
        val sret_addr: ir.IRValue = frame_mem(ctx, ctx.sret_offset, ctx.ptr_size);
        emit_store(ctx, sret_addr, ir.make_reg(sret_reg, ctx.ptr_size));
    }

    # lower parameters - get param list from AST
    val params: *ast.List = node.info.fun_decl.params;

    # handle method receiver first - it's passed as the first argument (rdi)
    # but stored separately in fun_decl.receiver, not in the params list
    val receiver: *ast.Node = node.info.fun_decl.receiver;
    if (!is_entry && receiver != nil) {
        val recv_name: str = receiver.info.field_decl.name;
        var recv_type: *ty.Type = nil;

        # use receiver type override if set (for generic instantiation lowering)
        if (ctx.recv_type_override != nil) {
            recv_type = ctx.recv_type_override;
        } or {
            recv_type = receiver.ty;
            # if sema didn't set the type, resolve from the type annotation
            if (recv_type == nil) {
                val recv_ann_inner: *ast.Node = receiver.info.field_decl.type_node;
                if (recv_ann_inner != nil) {
                    recv_type = resolve_type_annotation(ctx, recv_ann_inner);
                }
            }
        }

        var recv_size: usize = ctx.ptr_size;
        # check if receiver type annotation is a pointer or reference
        # the AST node for the receiver's type annotation tells us if it's &T or *T
        val recv_ann: *ast.Node = receiver.info.field_decl.type_node;
        val recv_is_ptr: bool = recv_ann != nil &&
            (recv_ann.kind == ast.NODE_TYPE_PTR || recv_ann.kind == ast.NODE_TYPE_REF);

        if (recv_is_ptr) {
            # references and pointers are always pointer-sized at ABI level
            recv_size = ctx.ptr_size;
        } or (recv_type != nil) {
            recv_size = recv_type.size;
        }

        # large aggregate receivers are passed as hidden pointers by the caller
        # (matching SysV AMD64 ABI for structs > ptr_size)
        # we copy the struct from the pointer into our local stack slot
        val recv_is_large_agg: bool = !recv_is_ptr && recv_type != nil &&
            (recv_type.kind == ty.TY_RECORD ||
             recv_type.kind == ty.TY_UNION ||
             recv_type.kind == ty.TY_ARRAY) &&
            recv_type.size > ctx.ptr_size;

        # allocate stack space for receiver (full struct size, not pointer)
        val recv_offset: i32 = add_local_var(ctx, recv_name, recv_size, recv_type);

        # store receiver from arg register to stack
        val recv_reg_idx: i32 = abi.get_arg_reg(?ctx.abi, int_arg_idx);
        if (recv_is_large_agg) {
            # caller passed a pointer — copy the struct into our local slot
            val rsrc_reg: i32 = new_vreg(ctx, ctx.ptr_size);
            val rsrc_ptr: ir.IRValue = ir.make_reg(rsrc_reg, ctx.ptr_size);
            emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, rsrc_ptr,
                       ir.make_reg(recv_reg_idx, ctx.ptr_size), ir.make_none(), 0);

            val rdst_reg: i32 = new_vreg(ctx, ctx.ptr_size);
            val rdst_ptr: ir.IRValue = ir.make_reg(rdst_reg, ctx.ptr_size);
            val rdst_mem: ir.IRValue = frame_mem(ctx, recv_offset, ctx.ptr_size);
            ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                          rdst_ptr, rdst_mem, ir.make_none(), ir.CC_NONE);

            val rtotal: i32 = recv_size::i32;
            var roff: i32 = 0;
            for (roff < rtotal) {
                var rchunk: usize = 8;
                if ((rtotal - roff)::usize < 8) {
                    rchunk = (rtotal - roff)::usize;
                }
                val rtmp_reg: i32 = new_vreg(ctx, rchunk);
                val rtmp: ir.IRValue = ir.make_reg(rtmp_reg, rchunk);

                var rs_mem: ir.IRValue;
                rs_mem.kind = ir.VAL_MEM;
                rs_mem.base_reg = rsrc_reg;
                rs_mem.offset = roff::i64;
                rs_mem.size = rchunk;
                rs_mem.reg = 0;
                rs_mem.imm = 0;
                rs_mem.index_reg = -1;
                rs_mem.scale = 1;
                rs_mem.label = nil;

                var rd_mem: ir.IRValue;
                rd_mem.kind = ir.VAL_MEM;
                rd_mem.base_reg = rdst_reg;
                rd_mem.offset = roff::i64;
                rd_mem.size = rchunk;
                rd_mem.reg = 0;
                rd_mem.imm = 0;
                rd_mem.index_reg = -1;
                rd_mem.scale = 1;
                rd_mem.label = nil;

                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                              rtmp, rs_mem, ir.make_none(), ir.CC_NONE);
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                              rd_mem, rtmp, ir.make_none(), ir.CC_NONE);

                roff = roff + rchunk::i32;
            }
        } or {
            val recv_addr: ir.IRValue = frame_mem(ctx, recv_offset, recv_size);
            emit_store(ctx, recv_addr, ir.make_reg(recv_reg_idx, recv_size));
        }
        int_arg_idx = int_arg_idx + 1;
    }

    # detect variadic functions: check if any parameter is NODE_VARIADIC
    if (!is_entry && params != nil) {
        var vi: i32 = 0;
        for (vi < params.count) {
            val vparam: *ast.Node = params.nodes[vi];
            if (vparam != nil && vparam.kind == ast.NODE_VARIADIC) {
                ctx.fn_is_variadic = true;
                brk;
            }
            vi = vi + 1;
        }
    }

    # allocate register save area for variadic functions (176 bytes: 6 GP + 8 XMM)
    if (!is_entry && ctx.fn_is_variadic) {
        ctx.stack_offset = ctx.stack_offset - 176;
        # align to 16 bytes
        if (ctx.stack_offset % 16 != 0) {
            ctx.stack_offset = ctx.stack_offset - (16 - ((-ctx.stack_offset) % 16));
        }
        ctx.va_reg_save_off = ctx.stack_offset;
    }

    if (!is_entry && params != nil) {
        # Two-pass approach: save scalar params from registers first, then copy aggregates.
        # This prevents aggregate copy loops from clobbering unsaved argument registers.

        # Pre-pass: allocate stack space and record metadata for all params
        var param_offsets: [32]i32;
        var param_sizes:   [32]usize;
        var param_byval:   [32]bool;
        var param_count: i32 = params.count;
        if (param_count > 32) { param_count = 32; }

        var i: i32 = 0;
        for (i < param_count) {
            val param: *ast.Node = params.nodes[i];
            if (param == nil || param.kind == ast.NODE_VARIADIC) {
                param_offsets[i] = 0;
                param_sizes[i] = 0;
                param_byval[i] = false;
                i = i + 1;
                cnt;
            }

            val param_name: str = param.info.field_decl.name;
            var param_type: *ty.Type = param.ty;
            if (param_type == nil || ctx.type_binding_count > 0) {
                val param_ann: *ast.Node = param.info.field_decl.type_node;
                if (param_ann != nil) {
                    val resolved_pt: *ty.Type = resolve_type_annotation(ctx, param_ann);
                    if (resolved_pt != nil) {
                        param_type = resolved_pt;
                    }
                }
            }

            var param_size: usize = ctx.ptr_size;
            if (param_type != nil && param_type.size > 0) {
                param_size = param_type.size;
            }

            val is_large_agg: bool = param_type != nil &&
                (param_type.kind == ty.TY_RECORD ||
                 param_type.kind == ty.TY_UNION ||
                 param_type.kind == ty.TY_ARRAY) &&
                param_type.size > ctx.ptr_size;

            val p_offset: i32 = add_local_var(ctx, param_name, param_size, param_type);
            param_offsets[i] = p_offset;
            param_sizes[i] = param_size;
            param_byval[i] = is_large_agg;
            i = i + 1;
        }

        # Pass 1: Save all scalar params from registers to stack slots
        var gp_idx: i32 = int_arg_idx;
        var stack_idx: i32 = 0;

        i = 0;
        for (i < param_count) {
            if (param_sizes[i] == 0) {
                i = i + 1;
                cnt;
            }

            if (!param_byval[i]) {
                # scalar/pointer param
                if (gp_idx < ctx.abi.arg_reg_count) {
                    val arg_reg: i32 = abi.get_arg_reg(?ctx.abi, gp_idx);
                    val dst: ir.IRValue = frame_mem(ctx, param_offsets[i], param_sizes[i]);
                    emit_store(ctx, dst, ir.make_reg(arg_reg, param_sizes[i]));
                    gp_idx = gp_idx + 1;
                } or {
                    # stack param (7+ args): load from caller's stack frame
                    val stack_off: i32 = 16 + (stack_idx * ctx.ptr_size::i32);
                    val src_mem: ir.IRValue = frame_mem(ctx, stack_off, ctx.ptr_size);
                    val tmp_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                    val tmp: ir.IRValue = ir.make_reg(tmp_reg, ctx.ptr_size);
                    ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                                  tmp, src_mem, ir.make_none(), ir.CC_NONE);
                    val dst: ir.IRValue = frame_mem(ctx, param_offsets[i], param_sizes[i]);
                    emit_store(ctx, dst, tmp);
                    stack_idx = stack_idx + 1;
                }
            } or {
                # byval large aggregate — just consume register slot, copy in pass 2
                if (gp_idx < ctx.abi.arg_reg_count) {
                    gp_idx = gp_idx + 1;
                } or {
                    stack_idx = stack_idx + 1;
                }
            }
            i = i + 1;
        }

        # Pass 2: Copy large aggregates (scalar registers are safely saved now)
        gp_idx = int_arg_idx;
        stack_idx = 0;

        i = 0;
        for (i < param_count) {
            if (param_sizes[i] == 0) {
                i = i + 1;
                cnt;
            }

            if (!param_byval[i]) {
                # scalar — already handled, just advance register index
                if (gp_idx < ctx.abi.arg_reg_count) {
                    gp_idx = gp_idx + 1;
                } or {
                    stack_idx = stack_idx + 1;
                }
            } or {
                # large aggregate passed by hidden pointer — copy into local slot
                val src_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                val src_ptr: ir.IRValue = ir.make_reg(src_reg, ctx.ptr_size);

                if (gp_idx < ctx.abi.arg_reg_count) {
                    val arg_reg: i32 = abi.get_arg_reg(?ctx.abi, gp_idx);
                    emit_instr(ctx, ir.IROp{ir_mov: ir.OP_MOV}, src_ptr,
                               ir.make_reg(arg_reg, ctx.ptr_size), ir.make_none(), 0);
                    gp_idx = gp_idx + 1;
                } or {
                    val stack_off: i32 = 16 + (stack_idx * ctx.ptr_size::i32);
                    val src_mem: ir.IRValue = frame_mem(ctx, stack_off, ctx.ptr_size);
                    ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                                  src_ptr, src_mem, ir.make_none(), ir.CC_NONE);
                    stack_idx = stack_idx + 1;
                }

                val dst_reg: i32 = new_vreg(ctx, ctx.ptr_size);
                val dst_ptr: ir.IRValue = ir.make_reg(dst_reg, ctx.ptr_size);
                val dst_mem: ir.IRValue = frame_mem(ctx, param_offsets[i], ctx.ptr_size);
                ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_lea: ir.OP_LEA},
                              dst_ptr, dst_mem, ir.make_none(), ir.CC_NONE);

                val total: i32 = param_sizes[i]::i32;
                var off: i32 = 0;
                for (off < total) {
                    var chunk: usize = 8;
                    if ((total - off)::usize < 8) {
                        chunk = (total - off)::usize;
                    }
                    val cp_tmp_reg: i32 = new_vreg(ctx, chunk);
                    val cp_tmp: ir.IRValue = ir.make_reg(cp_tmp_reg, chunk);

                    var s_mem: ir.IRValue;
                    s_mem.kind = ir.VAL_MEM;
                    s_mem.base_reg = src_reg;
                    s_mem.offset = off::i64;
                    s_mem.size = chunk;
                    s_mem.reg = 0;
                    s_mem.imm = 0;
                    s_mem.index_reg = -1;
                    s_mem.scale = 1;
                    s_mem.label = nil;

                    var d_mem: ir.IRValue;
                    d_mem.kind = ir.VAL_MEM;
                    d_mem.base_reg = dst_reg;
                    d_mem.offset = off::i64;
                    d_mem.size = chunk;
                    d_mem.reg = 0;
                    d_mem.imm = 0;
                    d_mem.index_reg = -1;
                    d_mem.scale = 1;
                    d_mem.label = nil;

                    ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_load: ir.OP_LOAD},
                                  cp_tmp, s_mem, ir.make_none(), ir.CC_NONE);
                    ir.emit_instr(ctx.alloc, ctx.current_block, ir.IROp{ir_store: ir.OP_STORE},
                                  d_mem, cp_tmp, ir.make_none(), ir.CC_NONE);

                    off = off + chunk::i32;
                }
            }
            i = i + 1;
        }

        # update int_arg_idx for variadic handling
        int_arg_idx = gp_idx;
        func.param_count = params.count;

        # for variadic functions, record named param counts and save all registers
        if (ctx.fn_is_variadic) {
            # count named params: int_arg_idx tracks GP regs used (minus sret adjustment)
            val arg_shift: i32 = 0;
            if (ctx.fn_has_sret) {
                ctx.va_named_gp = int_arg_idx - 1;
            } or {
                ctx.va_named_gp = int_arg_idx;
            }
            ctx.va_named_fp = float_arg_idx;
            ctx.va_named_stack_slots = 0;  # TODO: track stack params

            # save all GP arg registers to reg_save_area
            var gi: i32 = 0;
            for (gi < ctx.abi.arg_reg_count) {
                val reg_off: i32 = ctx.va_reg_save_off + (gi * ctx.ptr_size::i32);
                val reg_dst: ir.IRValue = frame_mem(ctx, reg_off, ctx.ptr_size);
                val reg_src: ir.IRValue = ir.make_reg(abi.get_arg_reg(?ctx.abi, gi), ctx.ptr_size);
                emit_store(ctx, reg_dst, reg_src);
                gi = gi + 1;
            }

            # save XMM0-XMM7 to reg_save_area (offsets 48 + i*16)
            # note: we don't track FP arg regs in current sysv64 module, skip for now
            # this is safe because va_arg for FP types will fall back to stack path
        }
    }

    # get function body and lower it
    val body: *ast.Node = node.info.fun_decl.body;
    if (body != nil) {
        lower_stmt(ctx, body);
    }

    # emit deferred statements from any remaining defer stack entries
    emit_deferred_from(ctx, 0);

    # if no explicit return, emit one
    if (ctx.current_block != nil && ctx.current_block.instr_count > 0) {
        val last_instr: ir.Instr = ctx.current_block.instrs[ctx.current_block.instr_count - 1];
        if (last_instr.op != ir.IROp{ir_ret: ir.OP_RET}) {
            # create none value for void return
            val none_value: ir.IRValue = make_none();
            emit_ret(ctx, none_value);
        }
    } or {
        # empty function, emit return
        val none_value: ir.IRValue = make_none();
        emit_ret(ctx, none_value);
    }

    # calculate frame size from local variables
    var frame_size: usize = 0;
    if (ctx.stack_offset < 0) {
        frame_size = (-ctx.stack_offset)::usize;
    }

    # align frame size to stack alignment (16 bytes for sysv64)
    if (frame_size > 0 && frame_size % 16 != 0) {
        frame_size = (frame_size + 15) & ~15::usize;
    }

    func.local_size = frame_size;

    # note: frame size is used by isel for stack allocation
    # stack frame setup/teardown is handled by isel, not emitted as IR

    # add function to IR function list for code generation
    # skip entry point functions - their code is emitted directly via inline asm
    # and shouldn't go through isel which would add unwanted prologue/epilogue
    if (!is_entry) {
        add_ir_function(ctx, func);
    }

    # workaround: create result in local variable to avoid return value corruption
    # fully initialize all fields to avoid garbage
    var result: Result[*ir.IRFunction, str];
    result.tag = true;  # is_ok
    result.value.ok = func;
    result.value.err = nil;  # zero out the err side too
    ret result;
}

# --- global variable lowering ---

# lower_global_var: lower a global variable declaration.
# ---
# ctx:  lowering context
# node: variable declaration node
# ret:  none
pub fun lower_global_var(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.m == nil) {
        ret;
    }

    val name: str = node.info.var_decl.name;
    if (name == nil) {
        ret;
    }

    # get initializer from var_decl.init
    val init_node: *ast.Node = node.info.var_decl.init;

    # determine section (.data for mutable, .rodata for immutable)
    var sec_kind: section.SectionKind;
    var sec_name: str;

    if (node.kind == ast.NODE_DECL_VAL) {
        sec_kind = section.section_rodata();
        sec_name = ".rodata";
    } or {
        sec_kind = section.section_data();
        sec_name = ".data";
    }

    val sec_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, sec_name, sec_kind);
    if (sec_res.is_err()) {
        ret;
    }

    val sec: *section.Section = sec_res.unwrap_ok();
    val offset: usize = sec.size;

    # look up sema symbol for mangled linkage name
    var global_name: str = name;
    if (ctx.symbols != nil) {
        val gv_sym_opt: Option[*symbol.Symbol] = ctx.symbols.lookup(name);
        if (gv_sym_opt.is_some()) {
            val gv_link: str = symbol.linkage_name(gv_sym_opt.unwrap(), ctx.alloc);
            if (gv_link != nil) {
                global_name = gv_link;
            }
        }
        if (global_name == name) {
            val gv_imp: *symbol.Symbol = lookup_symbol_in_imports(ctx, name);
            if (gv_imp != nil) {
                val gv_imp_link: str = symbol.linkage_name(gv_imp, ctx.alloc);
                if (gv_imp_link != nil) {
                    global_name = gv_imp_link;
                }
            }
        }
    }

    # create symbol with mangled name
    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, global_name);
    if (sym_res.is_ok()) {
        val s: *sym.Symbol = sym_res.unwrap_ok();
        sym.set_binding(s, sym.bind_global());
        sym.set_type(s, sym.sym_object());
        sym.define(s, sec, offset, 0);
        masm.add_symbol(ctx.m, s);
    }

    # determine declared type size
    var var_size: usize = 8;
    if (node.ty != nil) {
        var_size = node.ty.size;
    }
    if (var_size == 0) {
        var_size = 8;
    }

    # emit initializer data
    var emitted: bool = false;
    if (init_node != nil) {
        if (init_node.kind == ast.NODE_EXPR_LIT_INT) {
            val int_val: i64 = parse_int_str(init_node.info.lit_expr.text);
            emit_global_int(ctx, sec, int_val, var_size);
            emitted = true;
        }
        if (!emitted && init_node.kind == ast.NODE_EXPR_UNARY) {
            # handle unary negate: -100, -4, etc.
            var unary_child: *ast.Node = init_node.info.unary_expr.expr;
            if (unary_child != nil && unary_child.kind == ast.NODE_EXPR_LIT_INT && init_node.tok.tag == token.TAG_MINUS) {
                val pos_val: i64 = parse_int_str(unary_child.info.lit_expr.text);
                emit_global_int(ctx, sec, -pos_val, var_size);
                emitted = true;
            }
        } or (init_node.kind == ast.NODE_EXPR_LIT_STR) {
            val str_val: str = init_node.info.lit_expr.text;
            if (str_val != nil) {
                val gslen: usize = str_val.len();
                var gstart: usize = 0;
                var gend: usize = gslen;
                # strip surrounding quotes
                if (gslen >= 2 && str_val[0] == 34) {
                    gstart = 1;
                    if (str_val[gslen - 1] == 34) {
                        gend = gslen - 1;
                    }
                }
                var gi: usize = gstart;
                for (gi < gend) {
                    val gc: u8 = str_val[gi];
                    if (gc == 92 && gi + 1 < gend) {
                        val ge: u8 = str_val[gi + 1];
                        if (ge == 110) { section.emit_byte(ctx.alloc, sec, 10); }
                        or (ge == 116) { section.emit_byte(ctx.alloc, sec, 9); }
                        or (ge == 114) { section.emit_byte(ctx.alloc, sec, 13); }
                        or (ge == 48) { section.emit_byte(ctx.alloc, sec, 0); }
                        or (ge == 92) { section.emit_byte(ctx.alloc, sec, 92); }
                        or (ge == 34) { section.emit_byte(ctx.alloc, sec, 34); }
                        or (ge == 39) { section.emit_byte(ctx.alloc, sec, 39); }
                        or { section.emit_byte(ctx.alloc, sec, ge); }
                        gi = gi + 2;
                    } or {
                        section.emit_byte(ctx.alloc, sec, gc);
                        gi = gi + 1;
                    }
                }
                # null terminator
                section.emit_byte(ctx.alloc, sec, 0);
                emitted = true;
            }
        } or (init_node.kind == ast.NODE_EXPR_LIT_BOOL) {
            val bool_text: str = init_node.info.lit_expr.text;
            if (bool_text != nil && bool_text.equals("true")) {
                section.emit_byte(ctx.alloc, sec, 1);
            } or {
                section.emit_byte(ctx.alloc, sec, 0);
            }
            emitted = true;
        } or (init_node.kind == ast.NODE_EXPR_LIT_CHAR) {
            # char literal stored as int
            val char_val: i64 = parse_int_str(init_node.info.lit_expr.text);
            section.emit_byte(ctx.alloc, sec, char_val::u8);
            emitted = true;
        } or (init_node.kind == ast.NODE_EXPR_LIT_NIL) {
            # nil is a null pointer (8 bytes of zeros)
            section.emit_u64(ctx.alloc, sec, 0);
            emitted = true;
        } or (init_node.kind == ast.NODE_EXPR_LIT_FLOAT) {
            # float literal - reinterpret f64 bits as u64
            var float_val: f64 = parse_float(init_node.info.lit_expr.text);
            val float_ptr: *f64 = ?float_val;
            val bits_ptr: *u64 = float_ptr::*u64;
            section.emit_u64(ctx.alloc, sec, @bits_ptr);
            emitted = true;
        } or (init_node.kind == ast.NODE_EXPR_BINARY) {
            # handle binary expressions (e.g., constant OR/AND for flag combinations)
            # for now, emit zeros and let runtime handle it
        }
    }

    # fallback: emit zeros if nothing was emitted (unrecognized initializer or no init)
    if (!emitted) {
        var zi: usize = 0;
        for (zi < var_size) {
            section.emit_byte(ctx.alloc, sec, 0);
            zi = zi + 1;
        }
    }
}

# emit_global_int: emit an integer value to a section with the correct size.
fun emit_global_int(ctx: *LowerContext, sec: *section.Section, v: i64, size: usize) {
    if (size <= 1) {
        section.emit_byte(ctx.alloc, sec, v::u8);
    } or (size <= 2) {
        section.emit_u16(ctx.alloc, sec, v::u16);
    } or (size <= 4) {
        section.emit_u32(ctx.alloc, sec, v::u32);
    } or {
        section.emit_u64(ctx.alloc, sec, v::u64);
    }
}

# --- module lowering ---

# lower_module: lower all functions in a module.
# ---
# ctx:    lowering context
# module: module root node
# ret:    number of functions lowered
pub fun lower_module(ctx: *LowerContext, module: *ast.Node) i32 {
    if (ctx == nil || module == nil) {
        ret 0;
    }

    var count: i32 = 0;

    # get declarations from module (program node stores them in block_stmt.stmts)
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) {
        ret count;
    }

    # first pass: collect global variables and function declarations
    var i: i32 = 0;
    for (i < decls.count) {
        val decl: *ast.Node = decls.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        var node: *ast.Node = decl;

        # unwrap pub declarations
        if (node.kind == ast.NODE_DECL_PUB) {
            if (node.info.wrapper.inner != nil) {
                node = node.info.wrapper.inner;
            } or {
                i = i + 1;
                cnt;
            }
        }

        # global variable declaration
        if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
            lower_global_var(ctx, node);
        }

        i = i + 1;
    }

    # second pass: lower function bodies
    i = 0;
    for (i < decls.count) {
        val decl: *ast.Node = decls.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        var node: *ast.Node = decl;

        # unwrap pub declarations
        if (node.kind == ast.NODE_DECL_PUB) {
            if (node.info.wrapper.inner != nil) {
                node = node.info.wrapper.inner;
            } or {
                i = i + 1;
                cnt;
            }
        }

        # function declaration
        if (node.kind == ast.NODE_DECL_FUN) {
            val fn_res: Result[*ir.IRFunction, str] = lower_function(ctx, node);
            if (fn_res.is_ok()) {
                # note: lower_function already adds non-entry functions to ir_funcs
                # entry functions emit their code directly via inline asm
                count = count + 1;
            }
        }

        # comptime if - lower functions from taken branch
        if (node.kind == ast.NODE_COMPTIME_IF) {
            count = count + lower_comptime_if_functions(ctx, node);
        }

        i = i + 1;
    }

    ret count;
}

# lower_comptime_if_functions: lower functions from a $if taken branch.
# ---
# ctx:  lowering context
# node: comptime_if node
# ret:  number of functions lowered
fun lower_comptime_if_functions(ctx: *LowerContext, node: *ast.Node) i32 {
    if (ctx == nil || node == nil) {
        ret 0;
    }

    # get taken branch (stored in cond_stmt.body by sema)
    val taken: *ast.Node = node.info.cond_stmt.body;
    if (taken == nil) {
        ret 0;
    }

    var count: i32 = 0;

    # taken might be a block with multiple declarations
    if (taken.kind == ast.NODE_STMT_BLOCK) {
        val decls: *ast.List = taken.info.block_stmt.stmts;
        if (decls != nil) {
            var i: i32 = 0;
            for (i < decls.count) {
                val decl: *ast.Node = decls.nodes[i];
                if (decl != nil) {
                    var fn_node: *ast.Node = decl;
                    # unwrap pub wrapper
                    if (fn_node.kind == ast.NODE_DECL_PUB && fn_node.info.wrapper.inner != nil) {
                        fn_node = fn_node.info.wrapper.inner;
                    }
                    if (fn_node.kind == ast.NODE_DECL_FUN) {
                        val fn_res: Result[*ir.IRFunction, str] = lower_function(ctx, fn_node);
                        if (fn_res.is_ok()) {
                            count = count + 1;
                        }
                    }
                    if (fn_node.kind == ast.NODE_COMPTIME_IF || fn_node.kind == ast.NODE_COMPTIME_OR) {
                        count = count + lower_comptime_if_functions(ctx, fn_node);
                    }
                }
                i = i + 1;
            }
        }
    } or {
        # single declaration - unwrap pub wrapper
        var single: *ast.Node = taken;
        if (single.kind == ast.NODE_DECL_PUB && single.info.wrapper.inner != nil) {
            single = single.info.wrapper.inner;
        }
        if (single.kind == ast.NODE_DECL_FUN) {
            val fn_res: Result[*ir.IRFunction, str] = lower_function(ctx, single);
            if (fn_res.is_ok()) {
                count = count + 1;
            }
        }
        if (single.kind == ast.NODE_COMPTIME_IF || single.kind == ast.NODE_COMPTIME_OR) {
            count = count + lower_comptime_if_functions(ctx, single);
        }
    }

    ret count;
}

# lower_entry_point: lower the program entry point (_start).
# emits x86_64 linux entry point code directly to .text section.
# ---
# ctx:       lowering context
# main_name: name of the main function to call
# ret:       Ok(true) on success, Err(str) on failure
pub fun lower_entry_point(ctx: *LowerContext, main_name: str) Result[bool, str] {
    if (ctx == nil || ctx.m == nil || main_name == nil) {
        ret err[bool, str]("invalid arguments");
    }

    # get .text section
    val text_res: Result[*section.Section, str] = masm.get_or_create_section(ctx.m, ".text", section.section_text());
    if (text_res.is_err()) {
        ret err[bool, str]("failed to get .text section");
    }
    val text: *section.Section = text_res.unwrap_ok();

    # create and define _start symbol at current .text offset
    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, "_start");
    if (sym_res.is_err()) {
        ret err[bool, str]("failed to create _start symbol");
    }
    val s: *sym.Symbol = sym_res.unwrap_ok();
    s.binding.tag = sym.BIND_GLOBAL;
    s.sym_type.tag = sym.SYM_FUNC;
    sym.define(s, text, text.size, 0);
    masm.add_symbol(ctx.m, s);

    # emit x86_64 linux entry point code:
    #   mov rax, rsp          ; rax = initial stack pointer
    #   mov rdi, [rax]        ; argc -> rdi (1st argument)
    #   lea rsi, [rax+8]      ; argv -> rsi (2nd argument)
    #   and rsp, -16          ; align stack to 16 bytes
    #   sub rsp, 8            ; adjust for CALL (pushes 8-byte return address)
    #   call main
    #   mov rdi, rax          ; exit code from main -> rdi (1st syscall arg)
    #   mov rax, 60           ; SYS_exit
    #   syscall

    # mov rax, rsp (48 89 e0)
    section.emit_byte(ctx.alloc, text, 0x48);
    section.emit_byte(ctx.alloc, text, 0x89);
    section.emit_byte(ctx.alloc, text, 0xe0);

    # mov rdi, [rax] (48 8b 38)
    section.emit_byte(ctx.alloc, text, 0x48);
    section.emit_byte(ctx.alloc, text, 0x8b);
    section.emit_byte(ctx.alloc, text, 0x38);

    # lea rsi, [rax+8] (48 8d 70 08)
    section.emit_byte(ctx.alloc, text, 0x48);
    section.emit_byte(ctx.alloc, text, 0x8d);
    section.emit_byte(ctx.alloc, text, 0x70);
    section.emit_byte(ctx.alloc, text, 0x08);

    # and rsp, -16 (48 83 e4 f0)
    section.emit_byte(ctx.alloc, text, 0x48);
    section.emit_byte(ctx.alloc, text, 0x83);
    section.emit_byte(ctx.alloc, text, 0xe4);
    section.emit_byte(ctx.alloc, text, 0xf0);

    # sub rsp, 8 (48 83 ec 08)
    section.emit_byte(ctx.alloc, text, 0x48);
    section.emit_byte(ctx.alloc, text, 0x83);
    section.emit_byte(ctx.alloc, text, 0xec);
    section.emit_byte(ctx.alloc, text, 0x08);

    # call main (e8 xx xx xx xx) - relative call, needs relocation
    # record offset of displacement for relocation
    section.emit_byte(ctx.alloc, text, 0xe8);
    val call_offset: usize = text.size;
    # placeholder for 32-bit relative displacement (will be patched by relocation)
    section.emit_byte(ctx.alloc, text, 0x00);
    section.emit_byte(ctx.alloc, text, 0x00);
    section.emit_byte(ctx.alloc, text, 0x00);
    section.emit_byte(ctx.alloc, text, 0x00);

    # add relocation for call main
    section.add_relocation(ctx.alloc, text, call_offset, main_name, section.RELOC_PC32, -4);

    # mov rdi, rax (48 89 c7)
    section.emit_byte(ctx.alloc, text, 0x48);
    section.emit_byte(ctx.alloc, text, 0x89);
    section.emit_byte(ctx.alloc, text, 0xc7);

    # mov eax, 60 (b8 3c 00 00 00)
    section.emit_byte(ctx.alloc, text, 0xb8);
    section.emit_byte(ctx.alloc, text, 0x3c);
    section.emit_byte(ctx.alloc, text, 0x00);
    section.emit_byte(ctx.alloc, text, 0x00);
    section.emit_byte(ctx.alloc, text, 0x00);

    # syscall (0f 05)
    section.emit_byte(ctx.alloc, text, 0x0f);
    section.emit_byte(ctx.alloc, text, 0x05);

    ret ok[bool, str](true);
}

# find_module_index: find the output module index for a sema module.
# ---
# origin:      sema module pointer (nil = main module)
# loaded_mods: array of loaded sema modules
# mod_count:   number of loaded modules
# ret:         index into out_modules (0 = main, 1..N = imports)
fun find_module_index(origin: *sema.SemaModule, loaded_mods: **sema.SemaModule, mod_count: i32) i32 {
    if (origin == nil) {
        ret 0;
    }
    var i: i32 = 0;
    for (i < mod_count) {
        if (loaded_mods[i] == origin) {
            ret i + 1;
        }
        i = i + 1;
    }
    ret 0;
}

# init_module_masm: initialize a ModuleMasm with a fresh Masm context.
fun init_module_masm(mod_out: *ModuleMasm, name: str, path: str, alloc: *allocator.Allocator, tgt: target.Target) Result[bool, str] {
    val m_res: Result[masm.Masm, str] = masm.create(alloc, tgt);
    if (m_res.is_err()) {
        ret err[bool, str]("failed to create masm for module");
    }

    val m_heap_res: Result[*masm.Masm, allocator.AllocError] = alloc.alloc[masm.Masm](1);
    if (m_heap_res.is_err()) {
        ret err[bool, str]("out of memory for module masm");
    }
    val m_ptr: *masm.Masm = m_heap_res.unwrap_ok();
    @m_ptr = m_res.unwrap_ok();

    val text_res: Result[*section.Section, str] = masm.get_or_create_section(m_ptr, ".text", section.section_text());
    val rodata_res: Result[*section.Section, str] = masm.get_or_create_section(m_ptr, ".rodata", section.section_rodata());
    val data_res: Result[*section.Section, str] = masm.get_or_create_section(m_ptr, ".data", section.section_data());

    if (text_res.is_ok()) { section.set_align(text_res.unwrap_ok(), 16); }
    if (rodata_res.is_ok()) { section.set_align(rodata_res.unwrap_ok(), 16); }
    if (data_res.is_ok()) { section.set_align(data_res.unwrap_ok(), 16); }

    mod_out.m = m_ptr;
    mod_out.mod_name = name;
    mod_out.file_path = path;
    mod_out.ir_funcs = nil;
    mod_out.ir_func_count = 0;
    mod_out.ir_func_cap = 0;

    ret ok[bool, str](true);
}

# lower_all_modules_split: lower all modules into separate per-module MASM contexts.
# ---
# root:            root AST node of main module
# symbols:         symbol table
# types:           type context
# alloc:           allocator
# tgt:             target configuration
# loaded_mods:     array of loaded sema modules
# mod_count:       number of loaded modules
# method_insts:    linked list of generic method instantiations
# func_insts:      linked list of generic function instantiations
# main_file_path:  path to main source file
# main_source:     main module source text
# out_modules:     output array of ModuleMasm (caller-allocated)
# out_count:       output: number of modules written
# max_modules:     capacity of out_modules array
# ret:             Ok(true) on success, Err(str) on failure
pub fun lower_all_modules_split(
    root: *ast.Node, symbols: *symbol.Table, types: *ty.TypeContext,
    alloc: *allocator.Allocator, tgt: target.Target,
    loaded_mods: **sema.SemaModule, mod_count: i32,
    method_insts: *sema.MethodInstantiation,
    func_insts: *sema.FunctionInstantiation,
    main_file_path: str, main_source: str,
    out_modules: *ModuleMasm, out_count: *i32, max_modules: i32
) Result[bool, str] {

    if (root == nil || alloc == nil || out_modules == nil || out_count == nil) {
        ret err[bool, str]("invalid arguments");
    }

    var total: i32 = 0;

    # --- Initialize main module ---
    val main_init: Result[bool, str] = init_module_masm(?out_modules[0], "main", main_file_path, alloc, tgt);
    if (main_init.is_err()) {
        ret err[bool, str]("failed to init main module masm");
    }
    total = 1;

    # --- Initialize imported modules ---
    var i: i32 = 0;
    for (i < mod_count && total < max_modules) {
        val smod: *sema.SemaModule = loaded_mods[i];
        if (smod != nil && smod.ast != nil) {
            var mod_name: str = "module";
            if (smod.path != nil) {
                mod_name = smod.path;
            }
            var mod_path: str = nil;
            if (smod.file_path != nil) {
                mod_path = smod.file_path;
            }
            val mod_init: Result[bool, str] = init_module_masm(?out_modules[total], mod_name, mod_path, alloc, tgt);
            if (mod_init.is_err()) {
                ret err[bool, str]("failed to init module masm");
            }
            total = total + 1;
        }
        i = i + 1;
    }

    # --- Create lower context (starts with main module) ---
    var ctx: LowerContext = init(alloc, symbols, types, tgt, out_modules[0].m, main_source);
    ctx.loaded_mods = loaded_mods;
    ctx.loaded_mod_count = mod_count;

    # --- Lower main module ---
    if (main_file_path != nil) {
        ctx.current_file_idx = masm.add_debug_file(out_modules[0].m, main_file_path);
    }
    ctx.current_sema_mod = nil;
    val main_lower_count: i32 = lower_module(?ctx, root);
    if (main_lower_count < 0) {
        ret err[bool, str]("failed to lower main module");
    }
    # save main module IR functions
    out_modules[0].ir_funcs = ctx.ir_funcs;
    out_modules[0].ir_func_count = ctx.ir_func_count;
    out_modules[0].ir_func_cap = ctx.ir_func_cap;

    # --- Lower imported modules ---
    i = 0;
    var mod_idx: i32 = 1;
    for (i < mod_count) {
        val smod: *sema.SemaModule = loaded_mods[i];
        if (smod != nil && smod.ast != nil && mod_idx < total) {
            # reset ctx IR function storage for this module
            ctx.ir_funcs = nil;
            ctx.ir_func_count = 0;
            ctx.ir_func_cap = 0;
            ctx.m = out_modules[mod_idx].m;

            if (smod.table != nil) {
                ctx.symbols = smod.table;
            }
            ctx.current_sema_mod = smod;

            if (smod.file_path != nil) {
                ctx.current_file_idx = masm.add_debug_file(out_modules[mod_idx].m, smod.file_path);
            } or {
                ctx.current_file_idx = 0;
            }
            if (smod.source != nil) {
                ctx.text = smod.source;
            } or {
                ctx.text = nil;
            }

            val mod_lower_count: i32 = lower_module(?ctx, smod.ast);
            if (mod_lower_count < 0) {
                ret err[bool, str]("failed to lower imported module");
            }

            # save this module's IR functions
            out_modules[mod_idx].ir_funcs = ctx.ir_funcs;
            out_modules[mod_idx].ir_func_count = ctx.ir_func_count;
            out_modules[mod_idx].ir_func_cap = ctx.ir_func_cap;

            mod_idx = mod_idx + 1;
        }
        i = i + 1;
    }

    # restore main module context
    ctx.symbols = symbols;
    ctx.text = main_source;
    ctx.current_sema_mod = nil;
    if (main_file_path != nil) {
        ctx.current_file_idx = masm.add_debug_file(out_modules[0].m, main_file_path);
    } or {
        ctx.current_file_idx = 0;
    }

    # --- Lower generic method instantiations ---
    var inst: *sema.MethodInstantiation = method_insts;
    for (inst != nil) {
        if (inst.func_ast != nil && inst.mangled_name != nil && inst.param_count > 0) {
            val target_idx: i32 = find_module_index(inst.origin_module, loaded_mods, mod_count);

            # swap ctx to target module's IR storage
            ctx.ir_funcs = out_modules[target_idx].ir_funcs;
            ctx.ir_func_count = out_modules[target_idx].ir_func_count;
            ctx.ir_func_cap = out_modules[target_idx].ir_func_cap;
            ctx.m = out_modules[target_idx].m;

            ctx.type_binding_names = inst.param_names;
            ctx.type_binding_types = inst.param_types;
            ctx.type_binding_count = inst.param_count;
            ctx.func_name_override = inst.mangled_name;
            ctx.recv_type_override = inst.receiver_type;
            if (inst.func_type != nil && inst.func_type.kind == ty.TY_FUN) {
                ctx.ret_type_override = inst.func_type.ret_type;
            } or {
                ctx.ret_type_override = nil;
            }

            if (inst.origin_module != nil && inst.origin_module.table != nil) {
                ctx.symbols = inst.origin_module.table;
                ctx.current_sema_mod = inst.origin_module;
                if (inst.origin_module.source != nil) {
                    ctx.text = inst.origin_module.source;
                }
                if (inst.origin_module.file_path != nil) {
                    ctx.current_file_idx = masm.add_debug_file(out_modules[target_idx].m, inst.origin_module.file_path);
                }
            } or {
                ctx.symbols = symbols;
                ctx.current_sema_mod = nil;
            }

            val inst_fn_res: Result[*ir.IRFunction, str] = lower_function(?ctx, inst.func_ast);
            if (inst_fn_res.is_ok()) {
                add_ir_function(?ctx, inst_fn_res.unwrap_ok());
            }

            # save back to target module
            out_modules[target_idx].ir_funcs = ctx.ir_funcs;
            out_modules[target_idx].ir_func_count = ctx.ir_func_count;
            out_modules[target_idx].ir_func_cap = ctx.ir_func_cap;
        }
        inst = inst.next;
    }

    # --- Lower generic function instantiations ---
    var finst: *sema.FunctionInstantiation = func_insts;
    for (finst != nil) {
        if (finst.func_ast != nil && finst.mangled_name != nil && finst.param_count > 0) {
            val target_idx2: i32 = find_module_index(finst.origin_module, loaded_mods, mod_count);

            ctx.ir_funcs = out_modules[target_idx2].ir_funcs;
            ctx.ir_func_count = out_modules[target_idx2].ir_func_count;
            ctx.ir_func_cap = out_modules[target_idx2].ir_func_cap;
            ctx.m = out_modules[target_idx2].m;

            ctx.type_binding_names = finst.param_names;
            ctx.type_binding_types = finst.param_types;
            ctx.type_binding_count = finst.param_count;
            ctx.func_name_override = finst.mangled_name;
            ctx.recv_type_override = nil;
            if (finst.func_type != nil && finst.func_type.kind == ty.TY_FUN) {
                ctx.ret_type_override = finst.func_type.ret_type;
            } or {
                ctx.ret_type_override = nil;
            }

            if (finst.origin_module != nil && finst.origin_module.table != nil) {
                ctx.symbols = finst.origin_module.table;
                ctx.current_sema_mod = finst.origin_module;
                if (finst.origin_module.source != nil) {
                    ctx.text = finst.origin_module.source;
                }
                if (finst.origin_module.file_path != nil) {
                    ctx.current_file_idx = masm.add_debug_file(out_modules[target_idx2].m, finst.origin_module.file_path);
                }
            } or {
                ctx.symbols = symbols;
                ctx.current_sema_mod = nil;
            }

            val finst_fn_res: Result[*ir.IRFunction, str] = lower_function(?ctx, finst.func_ast);
            if (finst_fn_res.is_ok()) {
                add_ir_function(?ctx, finst_fn_res.unwrap_ok());
            }

            out_modules[target_idx2].ir_funcs = ctx.ir_funcs;
            out_modules[target_idx2].ir_func_count = ctx.ir_func_count;
            out_modules[target_idx2].ir_func_cap = ctx.ir_func_cap;
        }
        finst = finst.next;
    }

    # clear type bindings and overrides
    ctx.type_binding_names = nil;
    ctx.type_binding_types = nil;
    ctx.type_binding_count = 0;
    ctx.func_name_override = nil;
    ctx.recv_type_override = nil;
    ctx.ret_type_override = nil;

    # --- Run isel per module ---
    i = 0;
    for (i < total) {
        if (out_modules[i].ir_func_count > 0) {
            val isel_res: Result[bool, str] = isel.run_isel(out_modules[i].m, out_modules[i].ir_funcs, out_modules[i].ir_func_count, alloc);
            if (isel_res.is_err()) {
                report_lower_error_str(?ctx, isel_res.unwrap_err());
            }
        }
        i = i + 1;
    }

    # print collected lowering errors and bail if any occurred
    if (ctx.had_error) {
        print_lower_errors(?ctx);
        ret err[bool, str]("lowering failed with errors");
    }

    @out_count = total;
    ret ok[bool, str](true);
}

# lower_all_modules: lower main module and all imported modules to MASM.
# ---
# delegates to lower_all_modules_split, then merges all per-module MASMs into one.
# preserves backward compatibility for callers like testing.mach.
pub fun lower_all_modules(root: *ast.Node, symbols: *symbol.Table, types: *ty.TypeContext,
    alloc: *allocator.Allocator, tgt: target.Target, loaded_mods: **sema.SemaModule, mod_count: i32,
    method_insts: *sema.MethodInstantiation, func_insts: *sema.FunctionInstantiation,
    main_file_path: str, main_source: str) Result[*masm.Masm, str] {

    if (root == nil || alloc == nil) {
        ret err[*masm.Masm, str]("invalid arguments");
    }

    var module_masms: [256]ModuleMasm;
    var module_count: i32 = 0;

    val split_res: Result[bool, str] = lower_all_modules_split(
        root, symbols, types, alloc, tgt,
        loaded_mods, mod_count, method_insts, func_insts,
        main_file_path, main_source,
        ?module_masms[0], ?module_count, 256
    );
    if (split_res.is_err()) {
        ret err[*masm.Masm, str](split_res.unwrap_err());
    }

    if (module_count == 0) {
        ret err[*masm.Masm, str]("no modules lowered");
    }

    # use first module (main) as base, merge remaining modules into it
    val m_ptr: *masm.Masm = module_masms[0].m;
    var i: i32 = 1;
    for (i < module_count) {
        val merge_res: Result[bool, str] = masm.merge(m_ptr, module_masms[i].m);
        if (merge_res.is_err()) {
            ret err[*masm.Masm, str](merge_res.unwrap_err());
        }
        i = i + 1;
    }

    ret ok[*masm.Masm, str](m_ptr);
}
