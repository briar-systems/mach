# emit_cmp: emit a comparison instruction.
# ---
# ctx: lowering context
# lhs: left operand
# rhs: right operand
# ret: none
pub fun emit_cmp(ctx: *LowerContext, lhs: ir.IRValue, rhs: ir.IRValue) {
