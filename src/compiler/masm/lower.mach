use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use allocator: std.allocator;
use print: std.print;

use ast:     mach.compiler.ast;
use isel:    mach.compiler.masm.isel;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use token:  mach.compiler.token;

use ir:      mach.compiler.masm.ir;
use masm:    mach.compiler.masm.masm;
use operand: mach.compiler.masm.operand;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;
use target:  mach.compiler.masm.target;
use abi:     mach.compiler.masm.abi.spec;
use sysv64:  mach.compiler.masm.abi.sysv64;
use sema:    mach.compiler.sema;
use x86asm:  mach.compiler.masm.isa.x86asm;

# mach.compiler.masm.lower: AST to IR lowering.
# ---
# converts the typed AST into MASM intermediate representation.

# LocalVar: tracking info for a local variable.
# ---
# name:   variable name
# offset: stack offset from frame pointer (negative for locals)
# size:   size in bytes
pub rec LocalVar {
    name:   str;
    offset: i32;
    size:   usize;
}

# LowerContext: context for lowering AST to IR.
# ---
# alloc:            allocator for IR allocations
# symbols:          symbol table for lookups
# types:            type context
# tgt:              target configuration
# abi:              ABI specification for calling convention
# current_fn:       current function being lowered
# current_block:    current basic block
# ptr_size:         pointer size in bytes
# stack_align:      stack alignment in bytes
#
# local_vars:       array of local variables
# local_count:      number of locals
# local_cap:        allocated capacity
# stack_offset:     current stack offset (grows negative)
#
# deferred:         array of deferred statement nodes (fin)
# deferred_count:   number of deferred statements
# deferred_cap:     allocated capacity
#
# loop_defer_marks: stack of indices into deferred array at loop entry
# loop_mark_count:  number of loop marks
# loop_mark_cap:    allocated capacity
#
# loop_start_label: label for loop start (for cnt)
# loop_end_label:   label for loop end (for brk)
#
# vreg_next:        next virtual register number
# label_counter:    counter for unique labels
# str_counter:      counter for string literals
# loop_counter:     counter for loops
#
# fn_ret_type:      return type of current function
# fn_has_sret:      true if function returns aggregate via hidden pointer
# sret_offset:      stack offset of hidden sret pointer
pub rec LowerContext {
    alloc:            *allocator.Allocator;
    symbols:          *symbol.Table;
    types:            *ty.TypeContext;
    tgt:              target.Target;
    abi:              abi.ABI;
    current_fn:       *ir.IRFunction;
    current_block:    *ir.IRBlock;
    ptr_size:         usize;
    stack_align:      usize;

    local_vars:       *LocalVar;
    local_count:      i32;
    local_cap:        i32;
    stack_offset:     i32;

    deferred:         **ast.Node;
    deferred_count:   i32;
    deferred_cap:     i32;

    loop_defer_marks: *i32;
    loop_mark_count:  i32;
    loop_mark_cap:    i32;

    loop_start_label: str;
    loop_end_label:   str;

    vreg_next:        i32;
    label_counter:    i32;
    str_counter:      i32;
    loop_counter:     i32;

    fn_ret_type:      *ty.Type;
    fn_has_sret:      bool;
    sret_offset:      i32;

    # module-level masm context
    m:                *masm.Masm;

    # current text section
    text:             *section.Section;

    # collected IR functions for isel
    ir_funcs:         **ir.IRFunction;
    ir_func_count:    i32;
    ir_func_cap:      i32;
}

# init: create a new lowering context.
# ---
# alloc:   allocator to use
# symbols: symbol table
# types:   type context
# tgt:     target configuration
# ret:     initialized LowerContext
pub fun init(alloc: *allocator.Allocator, symbols: *symbol.Table, types: *ty.TypeContext, tgt: target.Target) LowerContext {
    var ctx: LowerContext;
    ctx.alloc = alloc;
    ctx.symbols = symbols;
    ctx.types = types;
    ctx.tgt = tgt;
    ctx.abi = sysv64.get();
    ctx.current_fn = nil;
    ctx.current_block = nil;
    ctx.ptr_size = tgt.ptr_size;
    ctx.stack_align = 16;

    ctx.local_vars = nil;
    ctx.local_count = 0;
    ctx.local_cap = 0;
    ctx.stack_offset = 0;

    ctx.deferred = nil;
    ctx.deferred_count = 0;
    ctx.deferred_cap = 0;

    ctx.loop_defer_marks = nil;
    ctx.loop_mark_count = 0;
    ctx.loop_mark_cap = 0;

    ctx.loop_start_label = nil;
    ctx.loop_end_label = nil;

    ctx.vreg_next = 0;
    ctx.label_counter = 0;
    ctx.str_counter = 0;
    ctx.loop_counter = 0;

    ctx.fn_ret_type = nil;
    ctx.fn_has_sret = false;
    ctx.sret_offset = 0;

    ctx.m = nil;
    ctx.text = nil;

    ctx.ir_funcs = nil;
    ctx.ir_func_count = 0;
    ctx.ir_func_cap = 0;

    ret ctx;
}

# add_ir_function: add an IR function to the context for later isel.
# ---
# ctx:  lowering context
# func: IR function to add
# ret:  Ok(true) on success, Err(str) on failure
pub fun add_ir_function(ctx: *LowerContext, func: *ir.IRFunction) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }
    if (func == nil) {
        ret err[bool, str]("function is nil");
    }

    # grow array if needed
    if (ctx.ir_func_count >= ctx.ir_func_cap) {
        var new_cap: i32 = 16;
        if (ctx.ir_func_cap > 0) {
            new_cap = ctx.ir_func_cap * 2;
        }

        val r: Result[**ir.IRFunction, allocator.AllocError] = ctx.alloc.resize[*ir.IRFunction](
            ctx.ir_funcs, ctx.ir_func_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret err[bool, str](r.unwrap_err());
        }

        ctx.ir_funcs = r.unwrap_ok();
        ctx.ir_func_cap = new_cap;
    }

    ctx.ir_funcs[ctx.ir_func_count] = func;
    ctx.ir_func_count = ctx.ir_func_count + 1;

    ret ok[bool, str](true);
}

# deinit: clean up lowering context.
# ---
# ctx: context to clean up
# ret: none
pub fun deinit(ctx: *LowerContext) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }

    if (ctx.local_vars != nil) {
        ctx.alloc.free[LocalVar](ctx.local_vars, ctx.local_cap::usize);
        ctx.local_vars = nil;
    }

    if (ctx.deferred != nil) {
        ctx.alloc.free[*ast.Node](ctx.deferred, ctx.deferred_cap::usize);
        ctx.deferred = nil;
    }

    if (ctx.loop_defer_marks != nil) {
        ctx.alloc.free[i32](ctx.loop_defer_marks, ctx.loop_mark_cap::usize);
        ctx.loop_defer_marks = nil;
    }
}

# reset_function_state: reset per-function state before lowering a new function.
# ---
# ctx: lowering context
# ret: none
pub fun reset_function_state(ctx: *LowerContext) {
    if (ctx == nil) {
        ret;
    }

    ctx.local_count = 0;
    ctx.stack_offset = 0;
    ctx.deferred_count = 0;
    ctx.loop_mark_count = 0;
    ctx.loop_start_label = nil;
    ctx.loop_end_label = nil;
    ctx.vreg_next = 0;
    ctx.fn_ret_type = nil;
    ctx.fn_has_sret = false;
    ctx.sret_offset = 0;
    ctx.current_fn = nil;
    ctx.current_block = nil;
}

# --- helper functions ---

# new_label: generate a unique label name.
# ---
# ctx:    lowering context
# prefix: label prefix (e.g. "if", "for", "end")
# ret:    unique label string
pub fun new_label(ctx: *LowerContext, prefix: str) str {
    if (ctx == nil || ctx.alloc == nil) {
        ret ".L0";
    }

    ctx.label_counter = ctx.label_counter + 1;

    # allocate buffer for label
    val buf_size: usize = 64;
    val r: Result[*u8, allocator.AllocError] = ctx.alloc.alloc[u8](buf_size);
    if (r.is_err()) {
        ret ".L0";
    }

    val buf: *u8 = r.unwrap_ok();

    # format: .L<prefix>_<counter>
    var i: usize = 0;
    buf[i] = 46;  # '.'
    i = i + 1;
    buf[i] = 76;  # 'L'
    i = i + 1;

    # copy prefix
    if (prefix != nil) {
        var j: usize = 0;
        for (j < prefix.len() && i < buf_size - 16) {
            buf[i] = prefix[j];
            i = i + 1;
            j = j + 1;
        }
    }

    buf[i] = 95;  # '_'
    i = i + 1;

    # write counter digits
    var num: i32 = ctx.label_counter;
    var digits: [16]u8;
    var d: i32 = 0;
    if (num == 0) {
        digits[0] = 48;  # '0'
        d = 1;
    } or {
        for (num > 0 && d < 16) {
            digits[d] = ((num % 10) + 48)::u8;
            num = num / 10;
            d = d + 1;
        }
    }

    # reverse and copy digits
    for (d > 0 && i < buf_size - 1) {
        d = d - 1;
        buf[i] = digits[d];
        i = i + 1;
    }

    buf[i] = 0;  # null terminator

    ret buf::str;
}

# new_string_label: generate a unique label for a string literal.
# ---
# ctx: lowering context
# ret: unique label string
pub fun new_string_label(ctx: *LowerContext) str {
    if (ctx == nil) {
        ret ".Lstr_0";
    }

    ctx.str_counter = ctx.str_counter + 1;
    ret new_label(ctx, "str");
}

# new_temp: allocate a new virtual register.
# ---
# ctx: lowering context
# ret: register number
pub fun new_temp(ctx: *LowerContext, size: usize) i32 {
    if (ctx == nil) {
        ret 0;
    }

    var slots: i32 = 1;
    if (size > 8) {
        slots = ((size + 7) / 8)::i32;
    }

    val reg: i32 = ctx.vreg_next;
    ctx.vreg_next = ctx.vreg_next + slots;
    ret reg;
}

# add_local_var: track a local variable on the stack.
# ---
# ctx:    lowering context
# name:   variable name
# size:   size in bytes
# ret:    stack offset (negative from frame pointer)
pub fun add_local_var(ctx: *LowerContext, name: str, size: usize) i32 {
    if (ctx == nil || ctx.alloc == nil) {
        ret 0;
    }

    # align size to 8 bytes minimum
    var aligned_size: usize = size;
    if (aligned_size < 8) {
        aligned_size = 8;
    }
    val mask: usize = 7;
    aligned_size = (aligned_size + mask) & ~mask;

    # grow locals array if needed
    if (ctx.local_count >= ctx.local_cap) {
        var new_cap: i32 = 16;
        if (ctx.local_cap > 0) {
            new_cap = ctx.local_cap * 2;
        }

        val r: Result[*LocalVar, allocator.AllocError] = ctx.alloc.resize[LocalVar](
            ctx.local_vars, ctx.local_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret 0;
        }

        ctx.local_vars = r.unwrap_ok();
        ctx.local_cap = new_cap;
    }

    # allocate stack space
    ctx.stack_offset = ctx.stack_offset - aligned_size::i32;
    val offset: i32 = ctx.stack_offset;

    # record local
    val idx: i32 = ctx.local_count;
    ctx.local_vars[idx].name = name;
    ctx.local_vars[idx].offset = offset;
    ctx.local_vars[idx].size = size;
    ctx.local_count = ctx.local_count + 1;

    ret offset;
}

# find_local_var: look up a local variable by name.
# ---
# ctx:  lowering context
# name: variable name
# ret:  pointer to LocalVar or nil if not found
pub fun find_local_var(ctx: *LowerContext, name: str) *LocalVar {
    if (ctx == nil || name == nil || ctx.local_vars == nil) {
        ret nil;
    }

    var i: i32 = ctx.local_count - 1;
    for (i >= 0) {
        val lv: *LocalVar = ?ctx.local_vars[i];
        if (lv.name != nil && lv.name.equals(name)) {
            ret lv;
        }
        i = i - 1;
    }

    ret nil;
}

# frame_mem: create a memory operand relative to frame pointer.
# ---
# ctx:    lowering context
# offset: offset from frame pointer
# size:   operand size in bytes
# ret:    IRValue for the memory operand
pub fun frame_mem(ctx: *LowerContext, offset: i32, size: usize) ir.IRValue {
    var v: ir.IRValue;
    v.kind = ir.val_mem();
    v.base_reg = sysv64.RBP;
    v.offset = offset::i64;
    v.size = size;
    v.reg = 0;
    v.imm = 0;
    v.index_reg = -1;
    v.scale = 1;
    v.label = nil;
    ret v;
}

# ensure_in_reg: ensure a value is in a register, loading if needed.
# ---
# ctx:       lowering context
# src_value: value to ensure is in register
# size:      operand size
# ret:       IRValue in a register
pub fun ensure_in_reg(ctx: *LowerContext, src_value: ir.IRValue, size: usize) ir.IRValue {
    # if already a register, return as-is
    if (src_value.kind.tag == ir.VAL_REG) {
        ret src_value;
    }

    # allocate a new temp register
    val reg: i32 = new_temp(ctx, size);
    var result: ir.IRValue = ir.make_reg(reg, size);

    # emit load or move instruction
    var instr: ir.IRInstr;
    instr.cond = 0;
    instr.dst = result;
    instr.src1 = src_value;

    # use MOV for immediates, LOAD for memory
    if (src_value.kind.tag == ir.VAL_MEM) {
        instr.op = ir.IROp { ir_load: 0 };
    } or {
        instr.op = ir.IROp { ir_mov: 0 };
    }

    if (ctx.current_block != nil && ctx.alloc != nil) {
        ir.emit_instr(ctx.alloc, ctx.current_block, instr);
    }

    ret result;
}

# push_deferred: push a deferred statement (fin).
# ---
# ctx:  lowering context
# node: statement node to defer
# ret:  none
pub fun push_deferred(ctx: *LowerContext, node: *ast.Node) {
    if (ctx == nil || node == nil || ctx.alloc == nil) {
        ret;
    }

    if (ctx.deferred_count >= ctx.deferred_cap) {
        var new_cap: i32 = 8;
        if (ctx.deferred_cap > 0) {
            new_cap = ctx.deferred_cap * 2;
        }

        val r: Result[**ast.Node, allocator.AllocError] = ctx.alloc.resize[*ast.Node](
            ctx.deferred, ctx.deferred_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret;
        }

        ctx.deferred = r.unwrap_ok();
        ctx.deferred_cap = new_cap;
    }

    ctx.deferred[ctx.deferred_count] = node;
    ctx.deferred_count = ctx.deferred_count + 1;
}

# emit_deferred_from: emit deferred statements from given index to current.
# ---
# ctx:        lowering context
# from_index: starting index in deferred stack
# ret:        none
pub fun emit_deferred_from(ctx: *LowerContext, from_index: i32) {
    print.eprintln("[emit_deferred_from] entered");
    if (ctx == nil) {
        print.eprintln("[emit_deferred_from] ctx is nil, returning");
        ret;
    }
    print.eprintln("[emit_deferred_from] ctx is valid");
    if (ctx.deferred == nil) {
        print.eprintln("[emit_deferred_from] ctx.deferred is nil, returning");
        ret;
    }
    print.eprintln("[emit_deferred_from] ctx.deferred is valid");

    # emit in reverse order (LIFO)
    print.eprintln("[emit_deferred_from] starting loop");
    var i: i32 = ctx.deferred_count - 1;
    for (i >= from_index) {
        print.eprintln("[emit_deferred_from] processing deferred item");
        val node: *ast.Node = ctx.deferred[i];
        if (node != nil) {
            lower_stmt(ctx, node);
        }
        i = i - 1;
    }
    print.eprintln("[emit_deferred_from] done");
}

# push_loop_defer_mark: mark current deferred stack depth when entering a loop.
# ---
# ctx: lowering context
# ret: none
pub fun push_loop_defer_mark(ctx: *LowerContext) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }

    if (ctx.loop_mark_count >= ctx.loop_mark_cap) {
        var new_cap: i32 = 8;
        if (ctx.loop_mark_cap > 0) {
            new_cap = ctx.loop_mark_cap * 2;
        }

        val r: Result[*i32, allocator.AllocError] = ctx.alloc.resize[i32](
            ctx.loop_defer_marks, ctx.loop_mark_cap::usize, new_cap::usize
        );
        if (r.is_err()) {
            ret;
        }

        ctx.loop_defer_marks = r.unwrap_ok();
        ctx.loop_mark_cap = new_cap;
    }

    ctx.loop_defer_marks[ctx.loop_mark_count] = ctx.deferred_count;
    ctx.loop_mark_count = ctx.loop_mark_count + 1;
}

# pop_loop_defer_mark: pop loop defer mark when exiting a loop.
# ---
# ctx: lowering context
# ret: the mark value (deferred count at loop entry)
pub fun pop_loop_defer_mark(ctx: *LowerContext) i32 {
    if (ctx == nil || ctx.loop_mark_count <= 0) {
        ret 0;
    }

    ctx.loop_mark_count = ctx.loop_mark_count - 1;
    ret ctx.loop_defer_marks[ctx.loop_mark_count];
}

# get_current_loop_defer_mark: get current loop's defer mark without popping.
# ---
# ctx: lowering context
# ret: mark value or 0 if not in a loop
pub fun get_current_loop_defer_mark(ctx: *LowerContext) i32 {
    if (ctx == nil || ctx.loop_mark_count <= 0) {
        ret 0;
    }
    ret ctx.loop_defer_marks[ctx.loop_mark_count - 1];
}

# type_size: get the size of a type in bytes.
# ---
# t:        type to measure
# ptr_size: pointer size
# ret:      size in bytes
pub fun type_size(t: *ty.Type, ptr_size: usize) usize {
    if (t == nil) {
        ret ptr_size;  # default to pointer size
    }

    # use the size field if populated
    if (t.size > 0) {
        ret t.size;
    }

    # compute size based on type kind
    val kind: ty.TypeKind = t.kind;

    if (kind == ty.TY_VOID)  { ret 0; }
    if (kind == ty.TY_BOOL)  { ret 1; }
    if (kind == ty.TY_U8)    { ret 1; }
    if (kind == ty.TY_I8)    { ret 1; }
    if (kind == ty.TY_U16)   { ret 2; }
    if (kind == ty.TY_I16)   { ret 2; }
    if (kind == ty.TY_U32)   { ret 4; }
    if (kind == ty.TY_I32)   { ret 4; }
    if (kind == ty.TY_F32)   { ret 4; }
    if (kind == ty.TY_U64)   { ret 8; }
    if (kind == ty.TY_I64)   { ret 8; }
    if (kind == ty.TY_F64)   { ret 8; }
    if (kind == ty.TY_USIZE) { ret ptr_size; }
    if (kind == ty.TY_ISIZE) { ret ptr_size; }
    if (kind == ty.TY_PTR)   { ret ptr_size; }
    if (kind == ty.TY_POINTER) { ret ptr_size; }
    if (kind == ty.TY_STR)   { ret ptr_size; }  # str is &char (pointer)
    if (kind == ty.TY_NIL)   { ret ptr_size; }

    if (kind == ty.TY_ARRAY) {
        val elem_size: usize = type_size(t.inner, ptr_size);
        ret elem_size * t.array_len::usize;
    }

    if (kind == ty.TY_RECORD || kind == ty.TY_UNION) {
        # sum up field sizes for record, max for union
        var total: usize = 0;
        var i: i32 = 0;
        for (i < t.field_count) {
            val field: *ty.Field = ?t.fields[i];
            val field_size: usize = type_size(field.ty, ptr_size);
            if (kind == ty.TY_UNION) {
                if (field_size > total) {
                    total = field_size;
                }
            } or {
                total = total + field_size;
                # add padding for alignment
                val align: usize = type_align_of(field.ty, ptr_size);
                if (align > 1 && total % align != 0) {
                    total = total + (align - (total % align));
                }
            }
            i = i + 1;
        }
        ret total;
    }

    if (kind == ty.TY_FUN) {
        ret ptr_size;  # function pointers
    }

    ret ptr_size;  # fallback
}

# type_align_of: get the alignment of a type.
# ---
# t:        type to measure
# ptr_size: pointer size
# ret:      alignment in bytes
pub fun type_align_of(t: *ty.Type, ptr_size: usize) usize {
    if (t == nil) {
        ret ptr_size;
    }

    if (t.align > 0) {
        ret t.align;
    }

    val kind: ty.TypeKind = t.kind;

    if (kind == ty.TY_BOOL || kind == ty.TY_U8 || kind == ty.TY_I8) { ret 1; }
    if (kind == ty.TY_U16 || kind == ty.TY_I16) { ret 2; }
    if (kind == ty.TY_U32 || kind == ty.TY_I32 || kind == ty.TY_F32) { ret 4; }
    if (kind == ty.TY_U64 || kind == ty.TY_I64 || kind == ty.TY_F64) { ret 8; }
    if (kind == ty.TY_USIZE || kind == ty.TY_ISIZE) { ret ptr_size; }
    if (kind == ty.TY_PTR || kind == ty.TY_POINTER) { ret ptr_size; }
    if (kind == ty.TY_STR) { ret ptr_size; }

    if (kind == ty.TY_ARRAY) {
        ret type_align_of(t.inner, ptr_size);
    }

    if (kind == ty.TY_RECORD || kind == ty.TY_UNION) {
        # alignment is max of field alignments
        var max_align: usize = 1;
        var i: i32 = 0;
        for (i < t.field_count) {
            val field: *ty.Field = ?t.fields[i];
            val align: usize = type_align_of(field.ty, ptr_size);
            if (align > max_align) {
                max_align = align;
            }
            i = i + 1;
        }
        ret max_align;
    }

    ret ptr_size;
}

# get_field_offset: get the offset of a field within a record type.
# ---
# t:        record type
# name:     field name
# ptr_size: pointer size
# ret:      offset in bytes, or 0 if not found
pub fun get_field_offset(t: *ty.Type, name: str, ptr_size: usize) usize {
    if (t == nil || name == nil) {
        ret 0;
    }

    if (t.kind == ty.TY_UNION) {
        ret 0;  # unions have all fields at offset 0
    }

    var offset: usize = 0;
    var i: i32 = 0;
    for (i < t.field_count) {
        val field: *ty.Field = ?t.fields[i];

        # check for field offset already computed
        if (field.offset > 0 || i == 0) {
            offset = field.offset;
        }

        if (field.name != nil && field.name.equals(name)) {
            ret offset;
        }

        # add field size and padding for next field
        val field_size: usize = type_size(field.ty, ptr_size);
        offset = offset + field_size;

        # align for next field
        if (i + 1 < t.field_count) {
            val next_field: *ty.Field = ?t.fields[i + 1];
            val next_align: usize = type_align_of(next_field.ty, ptr_size);
            if (next_align > 1 && offset % next_align != 0) {
                offset = offset + (next_align - (offset % next_align));
            }
        }

        i = i + 1;
    }

    ret 0;
}

# get_field_size: get the size of a field by name.
# ---
# t:        record or union type
# name:     field name
# ptr_size: pointer size
# ret:      size in bytes, or ptr_size if not found
pub fun get_field_size(t: *ty.Type, name: str, ptr_size: usize) usize {
    if (t == nil || name == nil) {
        ret ptr_size;
    }

    var i: i32 = 0;
    for (i < t.field_count) {
        val field: *ty.Field = ?t.fields[i];
        if (field.name != nil && field.name.equals(name)) {
            ret type_size(field.ty, ptr_size);
        }
        i = i + 1;
    }

    ret ptr_size;
}

# type_is_aggregate: check if type is an aggregate (struct/union/array).
# ---
# t: type to check
# ret: true if aggregate
pub fun type_is_aggregate(t: *ty.Type) bool {
    if (t == nil) {
        ret false;
    }

    val kind: ty.TypeKind = t.kind;
    ret kind == ty.TY_RECORD || kind == ty.TY_UNION || kind == ty.TY_ARRAY;
}

# type_is_large_aggregate: check if type is an aggregate larger than 2 registers.
# ---
# t:        type to check
# ptr_size: pointer/register size
# ret:      true if large aggregate (passed by hidden pointer)
pub fun type_is_large_aggregate(t: *ty.Type, ptr_size: usize) bool {
    if (!type_is_aggregate(t)) {
        ret false;
    }

    # sysv64 ABI: aggregates > 16 bytes are passed by hidden pointer
    ret type_size(t, ptr_size) > (ptr_size * 2);
}

# type_is_float: check if type is floating point.
# ---
# t: type to check
# ret: true if float
pub fun type_is_float(t: *ty.Type) bool {
    if (t == nil) {
        ret false;
    }

    ret t.kind == ty.TY_F32 || t.kind == ty.TY_F64;
}

# type_is_signed: check if type is a signed integer.
# ---
# t: type to check
# ret: true if signed
pub fun type_is_signed(t: *ty.Type) bool {
    if (t == nil) {
        ret false;
    }

    val kind: ty.TypeKind = t.kind;
    ret kind == ty.TY_I8 || kind == ty.TY_I16 ||
        kind == ty.TY_I32 || kind == ty.TY_I64 || kind == ty.TY_ISIZE;
}

# emit_frame_setup: emit stack frame prologue.
# ---
# ctx:        lowering context
# frame_size: size of stack frame
# ret:        none
pub fun emit_frame_setup(ctx: *LowerContext, frame_size: usize) {
    if (ctx == nil || ctx.current_block == nil || ctx.alloc == nil) {
        ret;
    }

    var instr: ir.IRInstr;
    instr.op = ir.IROp { ir_frame: 0 };
    instr.dst = ir.make_imm(frame_size::i64, ctx.ptr_size);
    instr.src1.kind = ir.val_none();
    instr.src2.kind = ir.val_none();
    instr.cond = 0;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr);
}

# emit_frame_teardown: emit stack frame epilogue.
# ---
# ctx:        lowering context
# frame_size: size of stack frame
# ret:        none
pub fun emit_frame_teardown(ctx: *LowerContext, frame_size: usize) {
    if (ctx == nil || ctx.current_block == nil || ctx.alloc == nil) {
        ret;
    }

    var instr: ir.IRInstr;
    instr.op = ir.IROp { ir_unframe: 0 };
    instr.dst = ir.make_imm(frame_size::i64, ctx.ptr_size);
    instr.src1.kind = ir.val_none();
    instr.src2.kind = ir.val_none();
    instr.cond = 0;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr);
}

# emit_aggregate_copy: copy an aggregate from one address to another.
# ---
# ctx:  lowering context
# dst:  destination memory address
# src:  source pointer (in register)
# size: size in bytes to copy
# ret:  none
pub fun emit_aggregate_copy(ctx: *LowerContext, dst: ir.IRValue, src: ir.IRValue, size: usize) {
    if (ctx == nil || ctx.current_block == nil || ctx.alloc == nil) {
        ret;
    }

    # get destination address into a register
    val dst_ptr: ir.IRValue = ir.make_reg(new_temp(ctx, ctx.ptr_size), ctx.ptr_size);
    emit_lea(ctx, dst_ptr, dst);

    # ensure source is in a register
    var src_ptr: ir.IRValue = src;
    if (src.kind.tag != ir.VAL_REG) {
        src_ptr = ensure_in_reg(ctx, src, ctx.ptr_size);
    }

    # copy in 8-byte chunks, then remaining bytes
    var offset: usize = 0;
    for (offset + 8 <= size) {
        val tmp: ir.IRValue = ir.make_reg(new_temp(ctx, 8), 8);

        # create source memory operand
        var src_mem: ir.IRValue;
        src_mem.kind = ir.val_mem();
        src_mem.base_reg = src_ptr.reg;
        src_mem.offset = offset::i64;
        src_mem.size = 8;
        src_mem.reg = 0;
        src_mem.imm = 0;
        src_mem.index_reg = -1;
        src_mem.scale = 1;
        src_mem.label = nil;

        # create destination memory operand
        var dst_mem: ir.IRValue;
        dst_mem.kind = ir.val_mem();
        dst_mem.base_reg = dst_ptr.reg;
        dst_mem.offset = offset::i64;
        dst_mem.size = 8;
        dst_mem.reg = 0;
        dst_mem.imm = 0;
        dst_mem.index_reg = -1;
        dst_mem.scale = 1;
        dst_mem.label = nil;

        emit_load(ctx, tmp, src_mem);
        emit_store(ctx, dst_mem, tmp);

        offset = offset + 8;
    }

    # copy remaining bytes one at a time
    for (offset < size) {
        val tmp: ir.IRValue = ir.make_reg(new_temp(ctx, 1), 1);

        var src_mem: ir.IRValue;
        src_mem.kind = ir.val_mem();
        src_mem.base_reg = src_ptr.reg;
        src_mem.offset = offset::i64;
        src_mem.size = 1;
        src_mem.reg = 0;
        src_mem.imm = 0;
        src_mem.index_reg = -1;
        src_mem.scale = 1;
        src_mem.label = nil;

        var dst_mem: ir.IRValue;
        dst_mem.kind = ir.val_mem();
        dst_mem.base_reg = dst_ptr.reg;
        dst_mem.offset = offset::i64;
        dst_mem.size = 1;
        dst_mem.reg = 0;
        dst_mem.imm = 0;
        dst_mem.index_reg = -1;
        dst_mem.scale = 1;
        dst_mem.label = nil;

        emit_load(ctx, tmp, src_mem);
        emit_store(ctx, dst_mem, tmp);

        offset = offset + 1;
    }
}

# emit_setcc: emit a conditional set instruction.
# ---
# ctx:  lowering context
# cond: condition code (0=e, 1=ne, 2=l, 3=le, 4=g, 5=ge, 6=b, 7=be, 8=a, 9=ae)
# dst:  destination register
# ret:  none
pub fun emit_setcc(ctx: *LowerContext, cond: i32, dst: ir.IRValue) {
    if (ctx == nil || ctx.current_block == nil || ctx.alloc == nil) {
        ret;
    }

    var instr: ir.IRInstr;

    if (cond == 0) { instr.op = ir.IROp { ir_sete: 0 }; }
    or (cond == 1) { instr.op = ir.IROp { ir_setne: 0 }; }
    or (cond == 2) { instr.op = ir.IROp { ir_setl: 0 }; }
    or (cond == 3) { instr.op = ir.IROp { ir_setle: 0 }; }
    or (cond == 4) { instr.op = ir.IROp { ir_setg: 0 }; }
    or (cond == 5) { instr.op = ir.IROp { ir_setge: 0 }; }
    or (cond == 6) { instr.op = ir.IROp { ir_setb: 0 }; }
    or (cond == 7) { instr.op = ir.IROp { ir_setbe: 0 }; }
    or (cond == 8) { instr.op = ir.IROp { ir_seta: 0 }; }
    or (cond == 9) { instr.op = ir.IROp { ir_setae: 0 }; }
    or { instr.op = ir.IROp { ir_sete: 0 }; }

    instr.dst = dst;
    instr.src1.kind = ir.val_none();
    instr.src2.kind = ir.val_none();
    instr.cond = cond;

    ir.emit_instr(ctx.alloc, ctx.current_block, instr);
}

# --- IR emission helpers ---

# emit_label: emit a label instruction.
# ---
# ctx:   lowering context
# label: label name
# ret:   none
pub fun emit_label(ctx: *LowerContext, label: str) {
    print.eprintln("[emit_label] entered");
    if (ctx == nil || ctx.current_block == nil || ctx.alloc == nil) {
        print.eprintln("[emit_label] early return due to nil");
        ret;
    }
    print.eprintln("[emit_label] ctx checks passed");

    print.eprintln("[emit_label] creating instr...");
    var instr: ir.IRInstr;
    print.eprintln("[emit_label] setting op...");
    instr.op = ir.IROp { ir_label: 0 };
    print.eprintln("[emit_label] setting dst...");
    instr.dst = ir.make_label(label);
    print.eprintln("[emit_label] setting src1...");
    instr.src1 = ir.make_none();
    print.eprintln("[emit_label] setting src2...");
    instr.src2 = ir.make_none();
    print.eprintln("[emit_label] setting cond...");
    instr.cond = 0;
    print.eprintln("[emit_label] instr fully initialized");

    print.eprintln("[emit_label] calling ir.emit_instr...");
    ir.emit_instr(ctx.alloc, ctx.current_block, instr);
    print.eprintln("[emit_label] ir.emit_instr returned");
}

