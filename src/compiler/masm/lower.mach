use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;

use ir:     mach.compiler.masm.ir;
use masm:   mach.compiler.masm.masm;
use target: mach.compiler.masm.target;

# mach.compiler.masm.lower: AST to IR lowering.
# ---
# converts the typed AST into MASM intermediate representation.

# LowerContext: context for lowering AST to IR.
# ---
# alloc:       allocator for IR allocations
# symbols:     symbol table for lookups
# types:       type context
# target:      target configuration
# current_fn:  current function being lowered
# label_count: counter for generating unique labels
# temp_count:  counter for generating temporary registers
pub rec LowerContext {
    alloc:       *allocator.Allocator;
    symbols:     *symbol.Table;
    types:       *ty.TypeContext;
    tgt:         target.Target;
    current_fn:  *ir.IRFunction;
    label_count: i32;
    temp_count:  i32;
}

# init: create a new lowering context.
# ---
# alloc:   allocator to use
# symbols: symbol table
# types:   type context
# tgt:     target configuration
# ret:     initialized LowerContext
pub fun init(alloc: *allocator.Allocator, symbols: *symbol.Table, types: *ty.TypeContext, tgt: target.Target) LowerContext {
    var ctx: LowerContext;
    ctx.alloc = alloc;
    ctx.symbols = symbols;
    ctx.types = types;
    ctx.tgt = tgt;
    ctx.current_fn = nil;
    ctx.label_count = 0;
    ctx.temp_count = 0;
    ret ctx;
}

# new_label: generate a unique label name.
# ---
# ctx:    lowering context
# prefix: label prefix (e.g. "if", "for", "end")
# ret:    unique label string
pub fun new_label(ctx: *LowerContext, prefix: str) str {
    if (ctx == nil) {
        ret ".L0";
    }

    ctx.label_count = ctx.label_count + 1;

    # TODO: format label with counter
    # for now return placeholder
    ret ".L";
}

# new_temp: allocate a new temporary register.
# ---
# ctx: lowering context
# ret: register number
pub fun new_temp(ctx: *LowerContext) i32 {
    if (ctx == nil) {
        ret 0;
    }

    val reg: i32 = ctx.temp_count;
    ctx.temp_count = ctx.temp_count + 1;
    ret reg;
}

# lower_module: lower an entire module AST to a MASM context.
# ---
# root:    program AST node
# symbols: symbol table
# types:   type context
# alloc:   allocator
# tgt:     target configuration
# ret:     Ok(*masm.Masm) on success, Err(str) on failure
pub fun lower_module(root: *ast.Node, symbols: *symbol.Table, types: *ty.TypeContext, alloc: *allocator.Allocator, tgt: target.Target) Result[*masm.Masm, str] {
    if (root == nil) {
        ret err[*masm.Masm, str]("AST is nil");
    }

    if (alloc == nil) {
        ret err[*masm.Masm, str]("allocator is nil");
    }

    # create MASM context
    val masm_res: Result[masm.Masm, str] = masm.create(alloc, tgt);
    if (masm_res.is_err()) {
        ret err[*masm.Masm, str](masm_res.unwrap_err());
    }

    # TODO: allocate and return pointer to masm context
    # TODO: iterate top-level declarations
    # TODO: lower each function to IR
    # TODO: lower each global variable

    ret err[*masm.Masm, str]("lower_module not yet implemented");
}

# lower_function: lower a function declaration to IR.
# ---
# ctx:  lowering context
# node: function AST node
# ret:  Ok(*ir.IRFunction) on success, Err(str) on failure
pub fun lower_function(ctx: *LowerContext, node: *ast.Node) Result[*ir.IRFunction, str] {
    if (ctx == nil) {
        ret err[*ir.IRFunction, str]("context is nil");
    }

    if (node == nil) {
        ret err[*ir.IRFunction, str]("node is nil");
    }

    # TODO: extract function name
    # TODO: create IR function
    # TODO: create entry block
    # TODO: lower parameters
    # TODO: lower function body
    # TODO: handle return

    ret err[*ir.IRFunction, str]("lower_function not yet implemented");
}

# lower_stmt: lower a statement to IR.
# ---
# ctx:   lowering context
# block: current basic block
# node:  statement AST node
# ret:   Ok(true) on success, Err(str) on failure
pub fun lower_stmt(ctx: *LowerContext, block: *ir.IRBlock, node: *ast.Node) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    if (node == nil) {
        ret err[bool, str]("node is nil");
    }

    # TODO: dispatch based on node kind
    # - val/var: allocate stack space, lower initializer
    # - if: lower condition, emit conditional jump, lower branches
    # - for: lower condition, emit loop structure
    # - ret: lower return value, emit return
    # - block: lower each statement
    # - expr: lower expression, discard result

    ret err[bool, str]("lower_stmt not yet implemented");
}

# lower_expr: lower an expression to IR.
# ---
# ctx:   lowering context
# block: current basic block
# node:  expression AST node
# ret:   Ok(ir.IRValue) with result value, Err(str) on failure
pub fun lower_expr(ctx: *LowerContext, block: *ir.IRBlock, node: *ast.Node) Result[ir.IRValue, str] {
    if (ctx == nil) {
        ret err[ir.IRValue, str]("context is nil");
    }

    if (node == nil) {
        ret err[ir.IRValue, str]("node is nil");
    }

    # TODO: dispatch based on node kind
    # - lit_int: return immediate value
    # - lit_string: emit string constant, return label
    # - ident: look up variable, return location
    # - binary: lower operands, emit operation
    # - unary: lower operand, emit operation
    # - call: lower arguments, emit call
    # - field: lower base, compute offset
    # - index: lower base and index, compute address
    # - cast: lower operand, emit conversion if needed
    # - addr: lower operand, take address
    # - deref: lower operand, emit load

    ret err[ir.IRValue, str]("lower_expr not yet implemented");
}

# lower_lvalue: lower an expression as an lvalue (for assignment).
# ---
# ctx:   lowering context
# block: current basic block
# node:  expression AST node
# ret:   Ok(ir.IRValue) with address, Err(str) on failure
pub fun lower_lvalue(ctx: *LowerContext, block: *ir.IRBlock, node: *ast.Node) Result[ir.IRValue, str] {
    if (ctx == nil) {
        ret err[ir.IRValue, str]("context is nil");
    }

    if (node == nil) {
        ret err[ir.IRValue, str]("node is nil");
    }

    # TODO: compute address of lvalue
    # - ident: look up variable address
    # - field: compute field address
    # - index: compute element address
    # - deref: lower pointer expression

    ret err[ir.IRValue, str]("lower_lvalue not yet implemented");
}
