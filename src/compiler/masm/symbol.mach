use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use section: mach.compiler.masm.section;

# mach.compiler.masm.symbol: symbol management for object files.
# ---
# provides symbol types for the MASM backend, representing functions, data,
# and references in the generated object file.

# SymbolBinding tag constants
pub val BIND_LOCAL:  u8 = 0;
pub val BIND_GLOBAL: u8 = 1;
pub val BIND_WEAK:   u8 = 2;

# SymbolBinding: symbol visibility/binding type (tagged record pattern for enum-like behavior).
# ---
# tag: BIND_LOCAL, BIND_GLOBAL, or BIND_WEAK
pub rec SymbolBinding {
    tag: u8;
}

# SymbolBinding constructors
pub fun bind_local() SymbolBinding {
    ret SymbolBinding { tag: BIND_LOCAL };
}

pub fun bind_global() SymbolBinding {
    ret SymbolBinding { tag: BIND_GLOBAL };
}

pub fun bind_weak() SymbolBinding {
    ret SymbolBinding { tag: BIND_WEAK };
}

# SymbolType tag constants
pub val SYM_NONE:    u8 = 0;
pub val SYM_FUNC:    u8 = 1;
pub val SYM_OBJECT:  u8 = 2;
pub val SYM_SECTION: u8 = 3;
pub val SYM_FILE:    u8 = 4;

# SymbolType: the kind of entity a symbol represents (tagged record pattern for enum-like behavior).
# ---
# tag: SYM_NONE, SYM_FUNC, SYM_OBJECT, SYM_SECTION, or SYM_FILE
pub rec SymbolType {
    tag: u8;
}

# SymbolType constructors
pub fun sym_none() SymbolType {
    ret SymbolType { tag: SYM_NONE };
}

pub fun sym_func() SymbolType {
    ret SymbolType { tag: SYM_FUNC };
}

pub fun sym_object() SymbolType {
    ret SymbolType { tag: SYM_OBJECT };
}

pub fun sym_section() SymbolType {
    ret SymbolType { tag: SYM_SECTION };
}

pub fun sym_file() SymbolType {
    ret SymbolType { tag: SYM_FILE };
}

# Symbol: a symbol in the object file.
# ---
# name:       symbol name
# binding:    symbol binding (local/global/weak)
# sym_type:   symbol type (func/object/etc.)
# section:    section this symbol is defined in (or nil for undefined)
# offset:     offset within section
# size:       size of the symbol (for objects)
# defined:    true if symbol is defined, false if referenced
pub rec Symbol {
    name:     str;
    binding:  SymbolBinding;
    sym_type: SymbolType;
    section:  *section.Section;
    offset:   usize;
    size:     usize;
    defined:  bool;
    src_file: str;
    src_line: i32;
}

# create: create a new symbol.
# ---
# alloc: allocator to use
# name:  symbol name
# ret:   Ok(*Symbol) on success, Err(str) on failure
pub fun create(alloc: *allocator.Allocator, name: str) Result[*Symbol, str] {
    if (alloc == nil) {
        ret err[*Symbol, str]("allocator is nil");
    }

    val r: Result[*Symbol, allocator.AllocError] = allocator.allocator_zalloc[Symbol](alloc, 1);
    if (result_is_err(r)) {
        ret err[*Symbol, str](result_unwrap_err(r));
    }

    val sym: *Symbol = result_unwrap_ok(r);
    sym.name = name;
    sym.binding = bind_local();
    sym.sym_type = sym_none();
    sym.section = nil;
    sym.offset = 0;
    sym.size = 0;
    sym.defined = false;

    ret ok[*Symbol, str](sym);
}

# destroy: free a symbol.
# ---
# alloc: allocator used to create the symbol
# sym:   symbol to destroy
# ret:   none
pub fun destroy(alloc: *allocator.Allocator, sym: *Symbol) {
    if (alloc == nil || sym == nil) {
        ret;
    }

    allocator.allocator_free[Symbol](alloc, sym, 1);
}

# define: mark a symbol as defined at the given location.
# ---
# sym:     symbol to define
# sec:     section where symbol is defined
# offset:  offset within section
# size:    size of the symbol
# ret:     none
pub fun define(sym: *Symbol, sec: *section.Section, offset: usize, size: usize) {
    if (sym == nil) {
        ret;
    }

    sym.section = sec;
    sym.offset = offset;
    sym.size = size;
    sym.defined = true;
}

# set_binding: set the symbol binding.
# ---
# sym:     symbol to modify
# binding: binding to set
# ret:     none
pub fun set_binding(sym: *Symbol, binding: SymbolBinding) {
    if (sym == nil) {
        ret;
    }

    sym.binding = binding;
}

# set_type: set the symbol type.
# ---
# sym:      symbol to modify
# sym_type: type to set
# ret:      none
pub fun set_type(sym: *Symbol, sym_type: SymbolType) {
    if (sym == nil) {
        ret;
    }

    sym.sym_type = sym_type;
}

# is_defined: check if a symbol is defined.
# ---
# sym: symbol to check
# ret: true if defined, false if undefined/external
pub fun is_defined(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }
    ret sym.defined;
}

# is_global: check if a symbol has global binding.
# ---
# sym: symbol to check
# ret: true if global binding
pub fun is_global(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }

    ret sym.binding.tag == BIND_GLOBAL;
}

# is_function: check if a symbol is a function.
# ---
# sym: symbol to check
# ret: true if function type
pub fun is_function(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }

    ret sym.sym_type.tag == SYM_FUNC;
}
