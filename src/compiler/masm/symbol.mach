use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use section: mach.compiler.masm.section;

# mach.compiler.masm.symbol: symbol management for object files.
# ---
# provides symbol types for the MASM backend, representing functions, data,
# and references in the generated object file.

# SymbolBinding: symbol visibility/binding type.
# ---
# bind_local:  symbol is local to the object file
# bind_global: symbol is visible to other object files
# bind_weak:   symbol can be overridden by another definition
pub uni SymbolBinding {
    bind_local:  u8;
    bind_global: u8;
    bind_weak:   u8;
}

# SymbolType: the kind of entity a symbol represents.
# ---
# sym_func:    function/code symbol
# sym_object:  data object symbol
# sym_section: section symbol
# sym_file:    file symbol
# sym_none:    no type
pub uni SymbolType {
    sym_func:    u8;
    sym_object:  u8;
    sym_section: u8;
    sym_file:    u8;
    sym_none:    u8;
}

# Symbol: a symbol in the object file.
# ---
# name:       symbol name
# binding:    symbol binding (local/global/weak)
# sym_type:   symbol type (func/object/etc.)
# section:    section this symbol is defined in (or nil for undefined)
# offset:     offset within section
# size:       size of the symbol (for objects)
# defined:    true if symbol is defined, false if referenced
pub rec Symbol {
    name:     str;
    binding:  SymbolBinding;
    sym_type: SymbolType;
    section:  *section.Section;
    offset:   usize;
    size:     usize;
    defined:  bool;
}

# create: create a new symbol.
# ---
# alloc: allocator to use
# name:  symbol name
# ret:   Ok(*Symbol) on success, Err(str) on failure
pub fun create(alloc: *allocator.Allocator, name: str) Result[*Symbol, str] {
    if (alloc == nil) {
        ret err[*Symbol, str]("allocator is nil");
    }

    val r: Result[*Symbol, allocator.AllocError] = alloc.zalloc[Symbol](1);
    if (r.is_err()) {
        ret err[*Symbol, str](r.unwrap_err());
    }

    val sym: *Symbol = r.unwrap_ok();
    sym.name = name;
    sym.binding = SymbolBinding { bind_local: 0 };
    sym.sym_type = SymbolType { sym_none: 0 };
    sym.section = nil;
    sym.offset = 0;
    sym.size = 0;
    sym.defined = false;

    ret ok[*Symbol, str](sym);
}

# destroy: free a symbol.
# ---
# alloc: allocator used to create the symbol
# sym:   symbol to destroy
# ret:   none
pub fun destroy(alloc: *allocator.Allocator, sym: *Symbol) {
    if (alloc == nil || sym == nil) {
        ret;
    }

    alloc.free[Symbol](sym, 1);
}

# define: mark a symbol as defined at the given location.
# ---
# sym:     symbol to define
# sec:     section where symbol is defined
# offset:  offset within section
# size:    size of the symbol
# ret:     none
pub fun define(sym: *Symbol, sec: *section.Section, offset: usize, size: usize) {
    if (sym == nil) {
        ret;
    }

    sym.section = sec;
    sym.offset = offset;
    sym.size = size;
    sym.defined = true;
}

# set_binding: set the symbol binding.
# ---
# sym:     symbol to modify
# binding: binding to set
# ret:     none
pub fun set_binding(sym: *Symbol, binding: SymbolBinding) {
    if (sym == nil) {
        ret;
    }

    sym.binding = binding;
}

# set_type: set the symbol type.
# ---
# sym:      symbol to modify
# sym_type: type to set
# ret:      none
pub fun set_type(sym: *Symbol, sym_type: SymbolType) {
    if (sym == nil) {
        ret;
    }

    sym.sym_type = sym_type;
}

# is_defined: check if a symbol is defined.
# ---
# sym: symbol to check
# ret: true if defined, false if undefined/external
pub fun is_defined(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }
    ret sym.defined;
}

# is_global: check if a symbol has global binding.
# ---
# sym: symbol to check
# ret: true if global binding
pub fun is_global(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }

    # TODO: proper union tag checking
    ret false;
}

# is_function: check if a symbol is a function.
# ---
# sym: symbol to check
# ret: true if function type
pub fun is_function(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }

    # TODO: proper union tag checking
    ret false;
}
