use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.masm.section: section management for the IR.
# ---
# MASM is the canonical source for section kind, flag, and relocation constants.
# OF implementations consume these values — they do NOT redefine them.

# SectionKind: what kind of content a section holds.
pub def SectionKind: u8;

pub val SEC_TEXT:   SectionKind = 0;
pub val SEC_DATA:   SectionKind = 1;
pub val SEC_RODATA: SectionKind = 2;
pub val SEC_BSS:    SectionKind = 3;
pub val SEC_CUSTOM: SectionKind = 4;

# SectionFlags: runtime behavior flags for sections.
pub def SectionFlags: u32;

pub val FLAG_WRITE: SectionFlags = 1;  # writable
pub val FLAG_EXEC:  SectionFlags = 2;  # executable
pub val FLAG_ALLOC: SectionFlags = 4;  # occupies memory at runtime

# RelocKind: abstract relocation types.
# ---
# target-independent. OF implementations map these to format-specific
# values (e.g. ELF relocation types, Mach-O relocation types).
pub def RelocKind: u8;

pub val RELOC_NONE:   RelocKind = 0;
pub val RELOC_ABS64:  RelocKind = 1;   # 64-bit absolute address
pub val RELOC_REL32:  RelocKind = 2;   # 32-bit PC-relative
pub val RELOC_CALL32: RelocKind = 3;   # 32-bit call (OF maps to PLT/stub/IAT)
pub val RELOC_ABS32:  RelocKind = 4;   # 32-bit absolute (zero-extended)
pub val RELOC_ABS32S: RelocKind = 5;   # 32-bit absolute (sign-extended)

# endian constants (match target.mach values)
pub val ENDIAN_LITTLE: u8 = 0;
pub val ENDIAN_BIG:    u8 = 1;

# initial capacity constants
val INITIAL_RELOC_CAP: i32 = 16;
val INITIAL_DATA_CAP: usize = 256;

# Relocation: a relocation entry within a section.
pub rec Relocation {
    offset:      usize;
    symbol_name: str;
    rtype:       RelocKind;
    addend:      i64;
}

# Section: a section in the output.
pub rec Section {
    name:        str;
    kind:        SectionKind;
    data:        *u8;
    size:        usize;
    capacity:    usize;
    align:       usize;
    flags:       SectionFlags;
    endian:      u8;
    relocs:      *Relocation;
    reloc_count: i32;
    reloc_cap:   i32;
}

# --- byte writers (little-endian) ---

fun write_u16_le(dst: *u8, v: u16) {
    dst[0] = (v & 255)::u8;
    dst[1] = ((v >> 8) & 255)::u8;
}

fun write_u32_le(dst: *u8, v: u32) {
    dst[0] = (v & 255)::u8;
    dst[1] = ((v >> 8) & 255)::u8;
    dst[2] = ((v >> 16) & 255)::u8;
    dst[3] = ((v >> 24) & 255)::u8;
}

fun write_u64_le(dst: *u8, v: u64) {
    dst[0] = (v & 255)::u8;
    dst[1] = ((v >> 8) & 255)::u8;
    dst[2] = ((v >> 16) & 255)::u8;
    dst[3] = ((v >> 24) & 255)::u8;
    dst[4] = ((v >> 32) & 255)::u8;
    dst[5] = ((v >> 40) & 255)::u8;
    dst[6] = ((v >> 48) & 255)::u8;
    dst[7] = ((v >> 56) & 255)::u8;
}

# --- byte writers (big-endian) ---

fun write_u16_be(dst: *u8, v: u16) {
    dst[0] = ((v >> 8) & 255)::u8;
    dst[1] = (v & 255)::u8;
}

fun write_u32_be(dst: *u8, v: u32) {
    dst[0] = ((v >> 24) & 255)::u8;
    dst[1] = ((v >> 16) & 255)::u8;
    dst[2] = ((v >> 8) & 255)::u8;
    dst[3] = (v & 255)::u8;
}

fun write_u64_be(dst: *u8, v: u64) {
    dst[0] = ((v >> 56) & 255)::u8;
    dst[1] = ((v >> 48) & 255)::u8;
    dst[2] = ((v >> 40) & 255)::u8;
    dst[3] = ((v >> 32) & 255)::u8;
    dst[4] = ((v >> 24) & 255)::u8;
    dst[5] = ((v >> 16) & 255)::u8;
    dst[6] = ((v >> 8) & 255)::u8;
    dst[7] = (v & 255)::u8;
}

# --- section operations ---

# create: allocate a new section.
pub fun create(alloc: *allocator.Allocator, name: str, kind: SectionKind, endian: u8) Result[*Section, str] {
    if (alloc == nil) {
        ret err[*Section, str]("allocator is nil");
    }

    val r: Result[*Section, allocator.AllocError] = allocator.allocator_zalloc[Section](alloc, 1);
    if (result_is_err[*Section, allocator.AllocError](r)) {
        ret err[*Section, str](result_unwrap_err[*Section, allocator.AllocError](r));
    }

    val sec: *Section = result_unwrap_ok[*Section, allocator.AllocError](r);
    sec.name = name;
    sec.kind = kind;
    sec.data = nil;
    sec.size = 0;
    sec.capacity = 0;
    sec.align = 1;
    sec.flags = FLAG_ALLOC;
    sec.endian = endian;
    sec.relocs = nil;
    sec.reloc_count = 0;
    sec.reloc_cap = 0;

    # set default flags based on kind
    if (kind == SEC_TEXT) {
        sec.flags = FLAG_ALLOC | FLAG_EXEC;
    } or (kind == SEC_DATA) {
        sec.flags = FLAG_ALLOC | FLAG_WRITE;
    } or (kind == SEC_RODATA) {
        sec.flags = FLAG_ALLOC;
    } or (kind == SEC_BSS) {
        sec.flags = FLAG_ALLOC | FLAG_WRITE;
    }

    ret ok[*Section, str](sec);
}

# --- query helpers ---

pub fun is_text(sec: *Section) bool {
    if (sec == nil) { ret false; }
    ret sec.kind == SEC_TEXT;
}

pub fun is_data(sec: *Section) bool {
    if (sec == nil) { ret false; }
    ret sec.kind == SEC_DATA;
}

pub fun is_rodata(sec: *Section) bool {
    if (sec == nil) { ret false; }
    ret sec.kind == SEC_RODATA;
}

pub fun is_bss(sec: *Section) bool {
    if (sec == nil) { ret false; }
    ret sec.kind == SEC_BSS;
}

# --- data emission ---

# emit_bytes: append bytes to a section.
pub fun emit_bytes(alloc: *allocator.Allocator, sec: *Section, bytes: &u8, len: usize) Result[usize, str] {
    if (alloc == nil) {
        ret err[usize, str]("allocator is nil");
    }
    if (sec == nil) {
        ret err[usize, str]("section is nil");
    }
    if (len == 0) {
        ret ok[usize, str](sec.size);
    }

    # grow if needed
    val needed: usize = sec.size + len;
    if (needed > sec.capacity) {
        var new_cap: usize = INITIAL_DATA_CAP;
        if (sec.capacity > 0) {
            new_cap = sec.capacity * 2;
        }
        for (new_cap < needed) {
            new_cap = new_cap * 2;
        }

        val r: Result[*u8, allocator.AllocError] = allocator.allocator_resize[u8](alloc, sec.data, sec.capacity, new_cap);
        if (result_is_err[*u8, allocator.AllocError](r)) {
            ret err[usize, str](result_unwrap_err[*u8, allocator.AllocError](r));
        }

        sec.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        sec.capacity = new_cap;
    }

    val offset: usize = sec.size;
    var i: usize = 0;
    for (i < len) {
        sec.data[sec.size + i] = bytes[i];
        i = i + 1;
    }
    sec.size = sec.size + len;

    ret ok[usize, str](offset);
}

# emit_byte: append a single byte.
pub fun emit_byte(alloc: *allocator.Allocator, sec: *Section, b: u8) Result[usize, str] {
    val byte: u8 = b;
    ret emit_bytes(alloc, sec, ?byte, 1);
}

# emit_u16: append a 16-bit value in the section's byte order.
pub fun emit_u16(alloc: *allocator.Allocator, sec: *Section, v: u16) Result[usize, str] {
    var bytes: [2]u8;
    if (sec != nil && sec.endian == ENDIAN_BIG) {
        write_u16_be(?bytes[0], v);
    } or {
        write_u16_le(?bytes[0], v);
    }
    ret emit_bytes(alloc, sec, ?bytes[0], 2);
}

# emit_u32: append a 32-bit value in the section's byte order.
pub fun emit_u32(alloc: *allocator.Allocator, sec: *Section, v: u32) Result[usize, str] {
    var bytes: [4]u8;
    if (sec != nil && sec.endian == ENDIAN_BIG) {
        write_u32_be(?bytes[0], v);
    } or {
        write_u32_le(?bytes[0], v);
    }
    ret emit_bytes(alloc, sec, ?bytes[0], 4);
}

# emit_u64: append a 64-bit value in the section's byte order.
pub fun emit_u64(alloc: *allocator.Allocator, sec: *Section, v: u64) Result[usize, str] {
    var bytes: [8]u8;
    if (sec != nil && sec.endian == ENDIAN_BIG) {
        write_u64_be(?bytes[0], v);
    } or {
        write_u64_le(?bytes[0], v);
    }
    ret emit_bytes(alloc, sec, ?bytes[0], 8);
}

# --- offset and alignment ---

# current_offset: get the current write position.
pub fun current_offset(sec: *Section) usize {
    if (sec == nil) { ret 0; }
    ret sec.size;
}

# set_align: set the alignment requirement for a section.
pub fun set_align(sec: *Section, align: usize) {
    if (sec == nil) { ret; }
    sec.align = align;
}

# --- relocations ---

# add_relocation: add a relocation entry to a section.
pub fun add_relocation(alloc: *allocator.Allocator, sec: *Section, offset: usize,
                       symbol_name: str, rtype: RelocKind, addend: i64) Result[bool, str] {
    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }
    if (sec == nil) {
        ret err[bool, str]("section is nil");
    }

    if (sec.reloc_count >= sec.reloc_cap) {
        var new_cap: i32 = INITIAL_RELOC_CAP;
        if (sec.reloc_cap > 0) {
            new_cap = sec.reloc_cap * 2;
        }

        val r: Result[*Relocation, allocator.AllocError] = allocator.allocator_resize[Relocation](
            alloc, sec.relocs, sec.reloc_cap::usize, new_cap::usize
        );
        if (result_is_err[*Relocation, allocator.AllocError](r)) {
            ret err[bool, str](result_unwrap_err[*Relocation, allocator.AllocError](r));
        }

        sec.relocs = result_unwrap_ok[*Relocation, allocator.AllocError](r);
        sec.reloc_cap = new_cap;
    }

    val idx: i32 = sec.reloc_count;
    sec.relocs[idx].offset = offset;
    sec.relocs[idx].symbol_name = symbol_name;
    sec.relocs[idx].rtype = rtype;
    sec.relocs[idx].addend = addend;
    sec.reloc_count = sec.reloc_count + 1;

    ret ok[bool, str](true);
}

# has_relocations: check if a section has any relocations.
pub fun has_relocations(sec: *Section) bool {
    if (sec == nil) { ret false; }
    ret sec.reloc_count > 0;
}

# get_relocation: get a relocation entry by index.
pub fun get_relocation(sec: *Section, index: i32) *Relocation {
    if (sec == nil || sec.relocs == nil) { ret nil; }
    if (index < 0 || index >= sec.reloc_count) { ret nil; }
    ret ?sec.relocs[index];
}

# --- patching ---

# patch_i32: overwrite a 32-bit value at a given offset in the section's byte order.
pub fun patch_i32(sec: *Section, offset: usize, value: i32) {
    if (sec == nil || sec.data == nil) { ret; }
    if (offset + 4 > sec.size) { ret; }
    if (sec.endian == ENDIAN_BIG) {
        write_u32_be(?sec.data[offset], value::u32);
    } or {
        write_u32_le(?sec.data[offset], value::u32);
    }
}

# patch_i64: overwrite a 64-bit value at a given offset in the section's byte order.
pub fun patch_i64(sec: *Section, offset: usize, value: i64) {
    if (sec == nil || sec.data == nil) { ret; }
    if (offset + 8 > sec.size) { ret; }
    if (sec.endian == ENDIAN_BIG) {
        write_u64_be(?sec.data[offset], value::u64);
    } or {
        write_u64_le(?sec.data[offset], value::u64);
    }
}

# --- cleanup ---

# destroy: free a section and its data.
pub fun destroy(alloc: *allocator.Allocator, sec: *Section) {
    if (alloc == nil || sec == nil) { ret; }

    if (sec.data != nil) {
        allocator.allocator_free[u8](alloc, sec.data, sec.capacity);
    }

    if (sec.relocs != nil) {
        allocator.allocator_free[Relocation](alloc, sec.relocs, sec.reloc_cap::usize);
    }

    allocator.allocator_free[Section](alloc, sec, 1);
}
