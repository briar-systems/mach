use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.masm.section: section management for object files.
# ---
# provides section types and operations for organizing generated code and data.

# section kind tag constants
pub val SEC_TEXT:   u8 = 0;
pub val SEC_DATA:   u8 = 1;
pub val SEC_RODATA: u8 = 2;
pub val SEC_BSS:    u8 = 3;
pub val SEC_CUSTOM: u8 = 4;

# relocation type constants (x86-64 ELF)
pub val RELOC_NONE:    u8 = 0;
pub val RELOC_64:      u8 = 1;   # 64-bit absolute address
pub val RELOC_PC32:    u8 = 2;   # 32-bit PC-relative
pub val RELOC_PLT32:   u8 = 3;   # 32-bit PLT-relative
pub val RELOC_32:      u8 = 4;   # 32-bit absolute (zero-extended)
pub val RELOC_32S:     u8 = 5;   # 32-bit absolute (sign-extended)

# initial capacity constants
val INITIAL_RELOC_CAP: i32 = 16;
val INITIAL_DATA_CAP: usize = 256;

# Relocation: a relocation entry within a section.
# ---
# offset:      offset within section where relocation applies
# symbol_name: name of symbol being referenced
# rtype:       relocation type (RELOC_64, RELOC_PC32, etc.)
# addend:      addend to add to symbol value
pub rec Relocation {
    offset:      usize;
    symbol_name: str;
    rtype:       u8;
    addend:      i64;
}

# SectionKind: the type of section (tagged record pattern for enum-like behavior).
# ---
# tag: SEC_TEXT, SEC_DATA, SEC_RODATA, SEC_BSS, or SEC_CUSTOM
pub rec SectionKind {
    tag: u8;
}

# section kind constructors
pub fun section_text() SectionKind {
    ret SectionKind { tag: SEC_TEXT };
}

pub fun section_data() SectionKind {
    ret SectionKind { tag: SEC_DATA };
}

pub fun section_rodata() SectionKind {
    ret SectionKind { tag: SEC_RODATA };
}

pub fun section_bss() SectionKind {
    ret SectionKind { tag: SEC_BSS };
}

pub fun section_custom() SectionKind {
    ret SectionKind { tag: SEC_CUSTOM };
}

# Section: a section in the output object file.
# ---
# name:        section name (e.g. ".text", ".data")
# kind:        section kind
# data:        section content bytes
# size:        current size in bytes
# capacity:    allocated capacity
# align:       section alignment requirement
# flags:       section flags (writable, executable, etc.)
# relocs:      array of relocations
# reloc_count: number of relocations
# reloc_cap:   allocated relocation capacity
pub rec Section {
    name:        str;
    kind:        SectionKind;
    data:        *u8;
    size:        usize;
    capacity:    usize;
    align:       usize;
    flags:       u32;
    relocs:      *Relocation;
    reloc_count: i32;
    reloc_cap:   i32;
}

# section flags
pub val FLAG_WRITE:   u32 = 1;  # writable
pub val FLAG_EXEC:    u32 = 2;  # executable
pub val FLAG_ALLOC:   u32 = 4;  # occupies memory at runtime

# write_u16_le: write a 16-bit value in little-endian to a memory location.
# ---
# dst: pointer to destination bytes
# v:   value to write
fun write_u16_le(dst: *u8, v: u16) {
    dst[0] = (v & 255)::u8;
    dst[1] = ((v >> 8) & 255)::u8;
}

# write_u32_le: write a 32-bit value in little-endian to a memory location.
# ---
# dst: pointer to destination bytes
# v:   value to write
fun write_u32_le(dst: *u8, v: u32) {
    dst[0] = (v & 255)::u8;
    dst[1] = ((v >> 8) & 255)::u8;
    dst[2] = ((v >> 16) & 255)::u8;
    dst[3] = ((v >> 24) & 255)::u8;
}

# write_u64_le: write a 64-bit value in little-endian to a memory location.
# ---
# dst: pointer to destination bytes
# v:   value to write
fun write_u64_le(dst: *u8, v: u64) {
    dst[0] = (v & 255)::u8;
    dst[1] = ((v >> 8) & 255)::u8;
    dst[2] = ((v >> 16) & 255)::u8;
    dst[3] = ((v >> 24) & 255)::u8;
    dst[4] = ((v >> 32) & 255)::u8;
    dst[5] = ((v >> 40) & 255)::u8;
    dst[6] = ((v >> 48) & 255)::u8;
    dst[7] = ((v >> 56) & 255)::u8;
}

# create: create a new section.
# ---
# alloc: allocator to use
# name:  section name
# kind:  section kind
# ret:   Ok(*Section) on success, Err(str) on failure
pub fun create(alloc: *allocator.Allocator, name: str, kind: SectionKind) Result[*Section, str] {
    if (alloc == nil) {
        ret err[*Section, str]("allocator is nil");
    }

    val r: Result[*Section, allocator.AllocError] = allocator.allocator_zalloc[Section](alloc, 1);
    if (result_is_err[*Section, allocator.AllocError](r)) {
        ret err[*Section, str](result_unwrap_err[*Section, allocator.AllocError](r));
    }

    val sec: *Section = result_unwrap_ok[*Section, allocator.AllocError](r);
    sec.name = name;
    sec.kind = kind;
    sec.data = nil;
    sec.size = 0;
    sec.capacity = 0;
    sec.align = 1;
    sec.flags = FLAG_ALLOC;
    sec.relocs = nil;
    sec.reloc_count = 0;
    sec.reloc_cap = 0;

    # set default flags based on kind
    if (kind.tag == SEC_TEXT) {
        sec.flags = FLAG_ALLOC | FLAG_EXEC;
    } or (kind.tag == SEC_DATA) {
        sec.flags = FLAG_ALLOC | FLAG_WRITE;
    } or (kind.tag == SEC_RODATA) {
        sec.flags = FLAG_ALLOC;
    } or (kind.tag == SEC_BSS) {
        sec.flags = FLAG_ALLOC | FLAG_WRITE;
    }

    ret ok[*Section, str](sec);
}

# get_kind_tag: get the tag value for a section kind.
# ---
# kind: section kind
# ret:  tag value (SEC_TEXT, SEC_DATA, etc.)
pub fun get_kind_tag(kind: SectionKind) u8 {
    ret kind.tag;
}

# is_text: check if section is executable code.
# ---
# sec: section to check
# ret: true if text section
pub fun is_text(sec: *Section) bool {
    if (sec == nil) {
        ret false;
    }
    ret sec.kind.tag == SEC_TEXT;
}

# is_data: check if section is initialized data.
# ---
# sec: section to check
# ret: true if data section
pub fun is_data(sec: *Section) bool {
    if (sec == nil) {
        ret false;
    }
    ret sec.kind.tag == SEC_DATA;
}

# is_rodata: check if section is read-only data.
# ---
# sec: section to check
# ret: true if rodata section
pub fun is_rodata(sec: *Section) bool {
    if (sec == nil) {
        ret false;
    }
    ret sec.kind.tag == SEC_RODATA;
}

# is_bss: check if section is uninitialized data.
# ---
# sec: section to check
# ret: true if bss section
pub fun is_bss(sec: *Section) bool {
    if (sec == nil) {
        ret false;
    }
    ret sec.kind.tag == SEC_BSS;
}

# destroy: free a section and its data.
# ---
# alloc: allocator used to create the section
# sec:   section to destroy
# ret:   none
pub fun destroy(alloc: *allocator.Allocator, sec: *Section) {
    if (alloc == nil || sec == nil) {
        ret;
    }

    if (sec.data != nil) {
        allocator.allocator_free[u8](alloc, sec.data, sec.capacity);
    }

    if (sec.relocs != nil) {
        allocator.allocator_free[Relocation](alloc, sec.relocs, sec.reloc_cap::usize);
    }

    allocator.allocator_free[Section](alloc, sec, 1);
}

# emit_bytes: append bytes to a section.
# ---
# alloc: allocator for growing
# sec:   section to append to
# bytes: pointer to bytes to append
# len:   number of bytes to append
# ret:   Ok(offset where bytes were written) on success, Err(str) on failure
pub fun emit_bytes(alloc: *allocator.Allocator, sec: *Section, bytes: &u8, len: usize) Result[usize, str] {
    if (alloc == nil) {
        ret err[usize, str]("allocator is nil");
    }

    if (sec == nil) {
        ret err[usize, str]("section is nil");
    }

    if (len == 0) {
        ret ok[usize, str](sec.size);
    }

    # grow if needed
    val needed: usize = sec.size + len;
    if (needed > sec.capacity) {
        var new_cap: usize = INITIAL_DATA_CAP;
        if (sec.capacity > 0) {
            new_cap = sec.capacity * 2;
        }
        for (new_cap < needed) {
            new_cap = new_cap * 2;
        }

        val r: Result[*u8, allocator.AllocError] = allocator.allocator_resize[u8](alloc, sec.data, sec.capacity, new_cap);
        if (result_is_err[*u8, allocator.AllocError](r)) {
            ret err[usize, str](result_unwrap_err[*u8, allocator.AllocError](r));
        }

        sec.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        sec.capacity = new_cap;
    }

    # copy bytes
    val offset: usize = sec.size;
    var i: usize = 0;
    for (i < len) {
        sec.data[sec.size + i] = bytes[i];
        i = i + 1;
    }
    sec.size = sec.size + len;

    ret ok[usize, str](offset);
}

# emit_byte: append a single byte to a section.
# ---
# alloc: allocator for growing
# sec:   section to append to
# b:     byte to append
# ret:   Ok(offset) on success, Err(str) on failure
pub fun emit_byte(alloc: *allocator.Allocator, sec: *Section, b: u8) Result[usize, str] {
    val byte: u8 = b;
    ret emit_bytes(alloc, sec, ?byte, 1);
}

# emit_u16: append a 16-bit value (little-endian).
# ---
# alloc: allocator for growing
# sec:   section to append to
# val:   value to append
# ret:   Ok(offset) on success, Err(str) on failure
pub fun emit_u16(alloc: *allocator.Allocator, sec: *Section, v: u16) Result[usize, str] {
    var bytes: [2]u8;
    write_u16_le(?bytes[0], v);
    ret emit_bytes(alloc, sec, ?bytes[0], 2);
}

# emit_u32: append a 32-bit value (little-endian).
# ---
# alloc: allocator for growing
# sec:   section to append to
# val:   value to append
# ret:   Ok(offset) on success, Err(str) on failure
pub fun emit_u32(alloc: *allocator.Allocator, sec: *Section, v: u32) Result[usize, str] {
    var bytes: [4]u8;
    write_u32_le(?bytes[0], v);
    ret emit_bytes(alloc, sec, ?bytes[0], 4);
}

# emit_u64: append a 64-bit value (little-endian).
# ---
# alloc: allocator for growing
# sec:   section to append to
# val:   value to append
# ret:   Ok(offset) on success, Err(str) on failure
pub fun emit_u64(alloc: *allocator.Allocator, sec: *Section, v: u64) Result[usize, str] {
    var bytes: [8]u8;
    write_u64_le(?bytes[0], v);
    ret emit_bytes(alloc, sec, ?bytes[0], 8);
}

# current_offset: get the current write offset in a section.
# ---
# sec: section to query
# ret: current size/offset
pub fun current_offset(sec: *Section) usize {
    if (sec == nil) {
        ret 0;
    }
    ret sec.size;
}

# set_align: set the alignment requirement for a section.
# ---
# sec:   section to modify
# align: alignment in bytes (must be power of 2)
# ret:   none
pub fun set_align(sec: *Section, align: usize) {
    if (sec == nil) {
        ret;
    }
    sec.align = align;
}

# add_relocation: add a relocation entry to a section.
# ---
# alloc:       allocator for growing
# sec:         section to add relocation to
# offset:      offset within section
# symbol_name: name of referenced symbol
# rtype:       relocation type
# addend:      addend value
# ret:         Ok(true) on success, Err(str) on failure
pub fun add_relocation(alloc: *allocator.Allocator, sec: *Section, offset: usize, symbol_name: str, rtype: u8, addend: i64) Result[bool, str] {
    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    if (sec == nil) {
        ret err[bool, str]("section is nil");
    }

    # grow relocation array if needed
    if (sec.reloc_count >= sec.reloc_cap) {
        var new_cap: i32 = INITIAL_RELOC_CAP;
        if (sec.reloc_cap > 0) {
            new_cap = sec.reloc_cap * 2;
        }

        val r: Result[*Relocation, allocator.AllocError] = allocator.allocator_resize[Relocation](
            alloc, sec.relocs, sec.reloc_cap::usize, new_cap::usize
        );
        if (result_is_err[*Relocation, allocator.AllocError](r)) {
            ret err[bool, str](result_unwrap_err[*Relocation, allocator.AllocError](r));
        }

        sec.relocs = result_unwrap_ok[*Relocation, allocator.AllocError](r);
        sec.reloc_cap = new_cap;
    }

    # add relocation entry
    val idx: i32 = sec.reloc_count;
    sec.relocs[idx].offset = offset;
    sec.relocs[idx].symbol_name = symbol_name;
    sec.relocs[idx].rtype = rtype;
    sec.relocs[idx].addend = addend;
    sec.reloc_count = sec.reloc_count + 1;

    ret ok[bool, str](true);
}

# has_relocations: check if a section has any relocations.
# ---
# sec: section to check
# ret: true if section has relocations
pub fun has_relocations(sec: *Section) bool {
    if (sec == nil) {
        ret false;
    }
    ret sec.reloc_count > 0;
}

# get_relocation: get a relocation entry by index.
# ---
# sec:   section
# index: relocation index
# ret:   pointer to relocation, or nil if out of bounds
pub fun get_relocation(sec: *Section, index: i32) *Relocation {
    if (sec == nil || sec.relocs == nil) {
        ret nil;
    }

    if (index < 0 || index >= sec.reloc_count) {
        ret nil;
    }

    ret ?sec.relocs[index];
}

# patch_i32: patch a 32-bit value at a given offset in a section.
# ---
# sec:    section to patch
# offset: offset to patch at
# value:  value to write
# ret:    none
pub fun patch_i32(sec: *Section, offset: usize, value: i32) {
    if (sec == nil || sec.data == nil) {
        ret;
    }

    if (offset + 4 > sec.size) {
        ret;
    }

    write_u32_le(?sec.data[offset], value::u32);
}

# patch_i64: patch a 64-bit value at a given offset in a section.
# ---
# sec:    section to patch
# offset: offset to patch at
# value:  value to write
# ret:    none
pub fun patch_i64(sec: *Section, offset: usize, value: i64) {
    if (sec == nil || sec.data == nil) {
        ret;
    }

    if (offset + 8 > sec.size) {
        ret;
    }

    write_u64_le(?sec.data[offset], value::u64);
}
