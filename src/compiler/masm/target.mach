use std.types.bool;
use std.types.string;
use std.types.option;

# mach.compiler.masm.target: target configuration for code generation.
# ---
# defines target platform properties (OS, ISA, ABI) for MASM.

# TargetOS: target operating system.
pub uni TargetOS {
    os_linux:   u8;
    os_darwin:  u8;
    os_windows: u8;
    os_unknown: u8;
}

# TargetISA: target instruction set architecture.
pub uni TargetISA {
    isa_x86_64:  u8;
    isa_aarch64: u8;
    isa_unknown: u8;
}

# TargetABI: target application binary interface.
pub uni TargetABI {
    abi_sysv64:  u8;
    abi_win64:   u8;
    abi_unknown: u8;
}

# Target: complete target configuration.
# ---
# os:         target operating system
# isa:        target instruction set architecture
# abi:        target ABI
# ptr_size:   pointer size in bytes
# ptr_align:  pointer alignment in bytes
# endian_big: true if big-endian, false if little-endian
pub rec Target {
    os:         TargetOS;
    isa:        TargetISA;
    abi:        TargetABI;
    ptr_size:   usize;
    ptr_align:  usize;
    endian_big: bool;
}

# default_target: create a default target (linux x86_64 sysv64).
# ---
# ret: Target with default configuration
pub fun default_target() Target {
    var t: Target;
    t.os = TargetOS { os_linux: 0 };
    t.isa = TargetISA { isa_x86_64: 0 };
    t.abi = TargetABI { abi_sysv64: 0 };
    t.ptr_size = 8;
    t.ptr_align = 8;
    t.endian_big = false;
    ret t;
}

# from_strings: create a target from string identifiers.
# ---
# os:  OS name (e.g. "linux", "darwin", "windows")
# isa: ISA name (e.g. "x86_64", "aarch64")
# abi: ABI name (e.g. "sysv64", "win64")
# ret: configured Target
pub fun from_strings(os: str, isa: str, abi: str) Target {
    var t: Target = default_target();

    if (os != nil) {
        if (os.equals("linux")) {
            t.os = TargetOS { os_linux: 0 };
        } or (os.equals("darwin")) {
            t.os = TargetOS { os_darwin: 0 };
        } or (os.equals("windows")) {
            t.os = TargetOS { os_windows: 0 };
        } or {
            t.os = TargetOS { os_unknown: 0 };
        }
    }

    if (isa != nil) {
        if (isa.equals("x86_64")) {
            t.isa = TargetISA { isa_x86_64: 0 };
            t.ptr_size = 8;
            t.ptr_align = 8;
        } or (isa.equals("aarch64")) {
            t.isa = TargetISA { isa_aarch64: 0 };
            t.ptr_size = 8;
            t.ptr_align = 8;
        } or {
            t.isa = TargetISA { isa_unknown: 0 };
        }
    }

    if (abi != nil) {
        if (abi.equals("sysv64")) {
            t.abi = TargetABI { abi_sysv64: 0 };
        } or (abi.equals("win64")) {
            t.abi = TargetABI { abi_win64: 0 };
        } or {
            t.abi = TargetABI { abi_unknown: 0 };
        }
    }

    ret t;
}

# pointer_size: get the pointer size for a target.
# ---
# t: target configuration
# ret: pointer size in bytes
pub fun pointer_size(t: *Target) usize {
    if (t == nil) {
        ret 8;
    }
    ret t.ptr_size;
}

# pointer_align: get the pointer alignment for a target.
# ---
# t: target configuration
# ret: pointer alignment in bytes
pub fun pointer_align(t: *Target) usize {
    if (t == nil) {
        ret 8;
    }
    ret t.ptr_align;
}

# is_little_endian: check if target is little-endian.
# ---
# t: target configuration
# ret: true if little-endian
pub fun is_little_endian(t: *Target) bool {
    if (t == nil) {
        ret true;
    }
    ret !t.endian_big;
}
