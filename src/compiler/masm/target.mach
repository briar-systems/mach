use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;

# mach.compiler.masm.target: target configuration for code generation.
# ---
# defines target platform properties (OS, ISA, ABI) for MASM.

# TargetOS tag constants
pub val OS_LINUX:   u8 = 0;
pub val OS_DARWIN:  u8 = 1;
pub val OS_WINDOWS: u8 = 2;
pub val OS_UNKNOWN: u8 = 3;

# TargetOS: target operating system (tagged record pattern for enum-like behavior).
# ---
# tag: OS_LINUX, OS_DARWIN, OS_WINDOWS, or OS_UNKNOWN
pub rec TargetOS {
    tag: u8;
}

# TargetOS constructors
pub fun os_linux() TargetOS {
    ret TargetOS { tag: OS_LINUX };
}

pub fun os_darwin() TargetOS {
    ret TargetOS { tag: OS_DARWIN };
}

pub fun os_windows() TargetOS {
    ret TargetOS { tag: OS_WINDOWS };
}

pub fun os_unknown() TargetOS {
    ret TargetOS { tag: OS_UNKNOWN };
}

# TargetISA tag constants
pub val ISA_X86_64:  u8 = 0;
pub val ISA_AARCH64: u8 = 1;
pub val ISA_UNKNOWN: u8 = 2;

# TargetISA: target instruction set architecture (tagged record pattern for enum-like behavior).
# ---
# tag: ISA_X86_64, ISA_AARCH64, or ISA_UNKNOWN
pub rec TargetISA {
    tag: u8;
}

# TargetISA constructors
pub fun isa_x86_64() TargetISA {
    ret TargetISA { tag: ISA_X86_64 };
}

pub fun isa_aarch64() TargetISA {
    ret TargetISA { tag: ISA_AARCH64 };
}

pub fun isa_unknown() TargetISA {
    ret TargetISA { tag: ISA_UNKNOWN };
}

# TargetABI tag constants
pub val ABI_SYSV64:  u8 = 0;
pub val ABI_WIN64:   u8 = 1;
pub val ABI_UNKNOWN: u8 = 2;

# TargetABI: target application binary interface (tagged record pattern for enum-like behavior).
# ---
# tag: ABI_SYSV64, ABI_WIN64, or ABI_UNKNOWN
pub rec TargetABI {
    tag: u8;
}

# TargetABI constructors
pub fun abi_sysv64() TargetABI {
    ret TargetABI { tag: ABI_SYSV64 };
}

pub fun abi_win64() TargetABI {
    ret TargetABI { tag: ABI_WIN64 };
}

pub fun abi_unknown() TargetABI {
    ret TargetABI { tag: ABI_UNKNOWN };
}

# Target: complete target configuration.
# ---
# os:         target operating system
# isa:        target instruction set architecture
# abi:        target ABI
# ptr_size:   pointer size in bytes
# ptr_align:  pointer alignment in bytes
# endian_big: true if big-endian, false if little-endian
pub rec Target {
    os:         TargetOS;
    isa:        TargetISA;
    abi:        TargetABI;
    ptr_size:   usize;
    ptr_align:  usize;
    endian_big: bool;
}

# default_target: create a default target (linux x86_64 sysv64).
# ---
# ret: Target with default configuration
pub fun default_target() Target {
    var t: Target;
    t.os = os_linux();
    t.isa = isa_x86_64();
    t.abi = abi_sysv64();
    t.ptr_size = 8;
    t.ptr_align = 8;
    t.endian_big = false;
    ret t;
}

# from_strings: create a target from string identifiers.
# ---
# os:  OS name (e.g. "linux", "darwin", "windows")
# isa: ISA name (e.g. "x86_64", "aarch64")
# abi: ABI name (e.g. "sysv64", "win64")
# ret: configured Target
pub fun from_strings(os: str, isa: str, abi: str) Target {
    var t: Target = default_target();

    if (os != nil) {
        if (os.equals("linux")) {
            t.os = os_linux();
        } or (os.equals("darwin")) {
            t.os = os_darwin();
        } or (os.equals("windows")) {
            t.os = os_windows();
        } or {
            t.os = os_unknown();
        }
    }

    if (isa != nil) {
        if (isa.equals("x86_64")) {
            t.isa = isa_x86_64();
            t.ptr_size = 8;
            t.ptr_align = 8;
        } or (isa.equals("aarch64")) {
            t.isa = isa_aarch64();
            t.ptr_size = 8;
            t.ptr_align = 8;
        } or {
            t.isa = isa_unknown();
        }
    }

    if (abi != nil) {
        if (abi.equals("sysv64")) {
            t.abi = abi_sysv64();
        } or (abi.equals("win64")) {
            t.abi = abi_win64();
        } or {
            t.abi = abi_unknown();
        }
    }

    ret t;
}

# pointer_size: get the pointer size for a target.
# ---
# t: target configuration
# ret: pointer size in bytes
pub fun pointer_size(t: *Target) usize {
    if (t == nil) {
        ret 8;
    }
    ret t.ptr_size;
}

# pointer_align: get the pointer alignment for a target.
# ---
# t: target configuration
# ret: pointer alignment in bytes
pub fun pointer_align(t: *Target) usize {
    if (t == nil) {
        ret 8;
    }
    ret t.ptr_align;
}

# is_little_endian: check if target is little-endian.
# ---
# t: target configuration
# ret: true if little-endian
pub fun is_little_endian(t: *Target) bool {
    if (t == nil) {
        ret true;
    }
    ret !t.endian_big;
}
