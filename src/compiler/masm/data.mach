use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use section:   mach.compiler.masm.section;
use sym:       mach.compiler.masm.symbol;

# mach.compiler.masm.data: module-level data declarations.
# ---
# DataDecl records represent constant data, global variables, and BSS
# reservations at the module level. lowering produces these instead of
# writing raw bytes to sections directly.
#
# a separate data emission pass materializes DataDecls into sections,
# creating symbols and relocations as needed.

# --- data declaration kinds ---

pub def DataKind: u8;

pub val DATA_BYTES: DataKind = 0;   # raw byte data (strings, floats, integers)
pub val DATA_ZERO:  DataKind = 1;   # zero-filled / uninitialized (BSS)

# --- relocation within a data declaration ---

# DeclReloc: a relocation entry within a DataDecl's data buffer.
# ---
# used when a data declaration contains a pointer to another symbol
# (e.g. a global string variable in .data pointing to string bytes in .rodata).
pub rec DeclReloc {
    offset: u32;              # byte offset within this decl's data
    target: str;              # target symbol name
    kind:   section.RelocKind;
    addend: i64;
}

# --- data declaration ---

# DataDecl: a module-level data declaration.
# ---
# represents a named piece of data that will be materialized into a section.
# lowering creates these; the data emission pass writes them to sections.
pub rec DataDecl {
    name:        str;              # symbol name
    section:     section.SectionKind;  # target section: RODATA / DATA / BSS
    binding:     sym.SymBinding;   # LOCAL / GLOBAL
    sym_type:    sym.SymKind;      # SYM_OBJECT / SYM_FUNC
    kind:        DataKind;         # BYTES / ZERO
    align:       u8;               # alignment requirement
    data:        *u8;              # raw bytes (DATA_BYTES only)
    data_len:    u32;              # byte count (or reservation size for DATA_ZERO)
    relocs:      *DeclReloc;       # relocations within this decl
    reloc_count: i32;
    reloc_cap:   i32;
    src_file:    str;              # source file for debug info
    src_line:    i32;              # source line for debug info
}

# --- DataDecl storage (growable array) ---

val INITIAL_DECL_CAP:  i32 = 32;
val INITIAL_RELOC_CAP: i32 = 4;

# DataDeclList: growable array of data declarations.
pub rec DataDeclList {
    decls: *DataDecl;
    count: i32;
    cap:   i32;
}

# --- lifecycle ---

# list_init: initialize an empty DataDeclList.
pub fun list_init() DataDeclList {
    var l: DataDeclList;
    l.decls = nil;
    l.count = 0;
    l.cap = 0;
    ret l;
}

# list_add: append a DataDecl to the list.
# returns the index of the added decl, or -1 on failure.
pub fun list_add(alloc: *allocator.Allocator, l: *DataDeclList, decl: DataDecl) i32 {
    if (alloc == nil || l == nil) { ret -1; }

    if (l.count >= l.cap) {
        var new_cap: i32 = INITIAL_DECL_CAP;
        if (l.cap > 0) { new_cap = l.cap * 2; }

        val r: Result[*DataDecl, allocator.AllocError] =
            allocator.allocator_resize[DataDecl](alloc, l.decls, l.cap::usize, new_cap::usize);
        if (!r.tag) { ret -1; }

        l.decls = r.value.ok;
        l.cap = new_cap;
    }

    val idx: i32 = l.count;
    l.decls[idx] = decl;
    l.count = l.count + 1;
    ret idx;
}

# list_get: get a DataDecl by index.
pub fun list_get(l: *DataDeclList, index: i32) *DataDecl {
    if (l == nil || l.decls == nil) { ret nil; }
    if (index < 0 || index >= l.count) { ret nil; }
    ret ?l.decls[index];
}

# list_destroy: free a DataDeclList and all its relocations.
pub fun list_destroy(alloc: *allocator.Allocator, l: *DataDeclList) {
    if (alloc == nil || l == nil) { ret; }

    # free per-decl relocation arrays
    var i: i32 = 0;
    for (i < l.count) {
        if (l.decls[i].relocs != nil) {
            allocator.allocator_free[DeclReloc](alloc, l.decls[i].relocs, l.decls[i].reloc_cap::usize);
        }
        if (l.decls[i].data != nil) {
            allocator.allocator_free[u8](alloc, l.decls[i].data, l.decls[i].data_len::usize);
        }
        i = i + 1;
    }

    if (l.decls != nil) {
        allocator.allocator_free[DataDecl](alloc, l.decls, l.cap::usize);
    }
    l.decls = nil;
    l.count = 0;
    l.cap = 0;
}

# --- DataDecl construction helpers ---

# make_bytes: create a DATA_BYTES declaration.
# the caller is responsible for populating data/data_len before adding.
pub fun make_bytes(name: str, sec: section.SectionKind, binding: sym.SymBinding,
                   data: *u8, data_len: u32, align: u8) DataDecl {
    var d: DataDecl;
    d.name = name;
    d.section = sec;
    d.binding = binding;
    d.sym_type = sym.SYM_OBJECT;
    d.kind = DATA_BYTES;
    d.align = align;
    d.data = data;
    d.data_len = data_len;
    d.relocs = nil;
    d.reloc_count = 0;
    d.reloc_cap = 0;
    d.src_file = nil;
    d.src_line = 0;
    ret d;
}

# make_zero: create a DATA_ZERO (BSS) declaration.
pub fun make_zero(name: str, size: u32, binding: sym.SymBinding, align: u8) DataDecl {
    var d: DataDecl;
    d.name = name;
    d.section = section.SEC_BSS;
    d.binding = binding;
    d.sym_type = sym.SYM_OBJECT;
    d.kind = DATA_ZERO;
    d.align = align;
    d.data = nil;
    d.data_len = size;
    d.relocs = nil;
    d.reloc_count = 0;
    d.reloc_cap = 0;
    d.src_file = nil;
    d.src_line = 0;
    ret d;
}

# make_func: create a function symbol declaration (no data, just symbol registration).
pub fun make_func(name: str, binding: sym.SymBinding) DataDecl {
    var d: DataDecl;
    d.name = name;
    d.section = section.SEC_TEXT;
    d.binding = binding;
    d.sym_type = sym.SYM_FUNC;
    d.kind = DATA_ZERO;
    d.align = 1;
    d.data = nil;
    d.data_len = 0;
    d.relocs = nil;
    d.reloc_count = 0;
    d.reloc_cap = 0;
    d.src_file = nil;
    d.src_line = 0;
    ret d;
}

# --- relocation helpers ---

# decl_add_reloc: add a relocation to a DataDecl.
# returns the relocation index, or -1 on failure.
pub fun decl_add_reloc(alloc: *allocator.Allocator, d: *DataDecl,
                       offset: u32, target: str, kind: section.RelocKind,
                       addend: i64) i32 {
    if (alloc == nil || d == nil) { ret -1; }

    if (d.reloc_count >= d.reloc_cap) {
        var new_cap: i32 = INITIAL_RELOC_CAP;
        if (d.reloc_cap > 0) { new_cap = d.reloc_cap * 2; }

        val r: Result[*DeclReloc, allocator.AllocError] =
            allocator.allocator_resize[DeclReloc](alloc, d.relocs, d.reloc_cap::usize, new_cap::usize);
        if (!r.tag) { ret -1; }

        d.relocs = r.value.ok;
        d.reloc_cap = new_cap;
    }

    val idx: i32 = d.reloc_count;
    d.relocs[idx].offset = offset;
    d.relocs[idx].target = target;
    d.relocs[idx].kind = kind;
    d.relocs[idx].addend = addend;
    d.reloc_count = d.reloc_count + 1;
    ret idx;
}
