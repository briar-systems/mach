# ============================================================================
# CONTROL FLOW ENCODING
# ============================================================================

# encode_jmp: encode jmp instruction.
pub fun encode_jmp(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_imm(target)) {
        # jmp rel32
        result = section.emit_byte(alloc, sec, 0xE9);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_imm32(alloc, sec, target.imm::i32);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(target)) {
        # jmp r (indirect)
        val r: i32 = target.reg;
        val rex_b: bool = needs_rex_b(r);

        result = emit_rex(alloc, sec, false, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, 4, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(target)) {
        # jmp m (indirect)
        val rex_x: bool = needs_rex_x(target.index);
        val rex_b: bool = needs_rex_b(target.base);

        result = emit_rex(alloc, sec, false, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, target.base, target.index, target.scale, target.disp, 4);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_label(target)) {
        # jmp rel32 with relocation
        result = section.emit_byte(alloc, sec, 0xE9);
        if (result_is_err[usize, str](result)) { ret result; }

        # record offset for relocation
        val reloc_offset: usize = section.current_offset(sec);

        # emit placeholder
        result = emit_imm32(alloc, sec, 0);
        if (result_is_err[usize, str](result)) { ret result; }

        # add PC-relative relocation (addend -4)
        val reloc_res: Result[bool, str] = section.add_relocation(alloc, sec, reloc_offset, target.label, section.RELOC_PC32, -4);
        if (result_is_err[bool, str](reloc_res)) { ret err[usize, str]("failed to add jmp relocation"); }

    } or {
        ret err[usize, str]("invalid target for jmp");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_jcc: encode conditional jump instruction.
pub fun encode_jcc(alloc: *allocator.Allocator, sec: *section.Section, cond: u8, target: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_imm(target)) {
        # jcc rel32 with immediate offset
        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, cond);  # jcc uses 0F 8x format (cond is already the long form opcode)
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_imm32(alloc, sec, target.imm::i32);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_label(target)) {
        # jcc rel32 with label relocation
        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, cond);  # cond is already the long form opcode (0x8x)
        if (result_is_err[usize, str](result)) { ret result; }

        # record offset for relocation
        val reloc_offset: usize = section.current_offset(sec);

        # emit placeholder
        result = emit_imm32(alloc, sec, 0);
        if (result_is_err[usize, str](result)) { ret result; }

        # add PC-relative relocation (addend -4)
        val reloc_res: Result[bool, str] = section.add_relocation(alloc, sec, reloc_offset, target.label, section.RELOC_PC32, -4);
        if (result_is_err[bool, str](reloc_res)) { ret err[usize, str]("failed to add jcc relocation"); }

    } or {
        ret err[usize, str]("conditional jump requires immediate offset or label");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_je: encode je (jump if equal) instruction.
pub fun encode_je(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
    ret encode_jcc(alloc, sec, 0x84, target);
}

