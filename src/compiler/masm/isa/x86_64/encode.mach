}

# encode_jb: encode jb (jump if below / unsigned less) instruction.
pub fun encode_jb(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
    ret encode_jcc(alloc, sec, 0x82, target);
}

# encode_jbe: encode jbe (jump if below or equal / unsigned less or equal) instruction.
pub fun encode_jbe(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
    ret encode_jcc(alloc, sec, 0x86, target);
}

# encode_ja: encode ja (jump if above / unsigned greater) instruction.
pub fun encode_ja(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
