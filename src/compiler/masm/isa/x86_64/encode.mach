use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use print: std.print;

use opcode: mach.compiler.masm.isa.x86_64.opcode;
use operand: mach.compiler.masm.operand;
use section: mach.compiler.masm.section;
use spec: mach.compiler.masm.isa.spec;

# mach.compiler.masm.isa.x86_64.encode: x86-64 instruction encoder.
# ---
# converts x86-64 opcodes + operands to machine code bytes.

# === operand type check helpers ===
# these directly check the tag for operand type

fun is_reg(o: operand.Operand) bool {
    ret o.kind.tag == operand.OP_REG;
}

fun is_mem(o: operand.Operand) bool {
    ret o.kind.tag == operand.OP_MEM;
}

fun is_imm(o: operand.Operand) bool {
    ret o.kind.tag == operand.OP_IMM;
}

fun is_label(o: operand.Operand) bool {
    ret o.kind.tag == operand.OP_LABEL;
}

fun is_none(o: operand.Operand) bool {
    ret o.kind.tag == operand.OP_NONE;
}

# === REX prefix constants ===
pub val REX_W: u8 = 0x08;
pub val REX_R: u8 = 0x04;
pub val REX_X: u8 = 0x02;
pub val REX_B: u8 = 0x01;

# === ModR/M constants ===
pub val MOD_DISP0:  u8 = 0;
pub val MOD_DISP8:  u8 = 1;
pub val MOD_DISP32: u8 = 2;
pub val MOD_REG:    u8 = 3;

# scale encoding for SIB
pub val SCALE_1: u8 = 0;
pub val SCALE_2: u8 = 1;
pub val SCALE_4: u8 = 2;
pub val SCALE_8: u8 = 3;

# condition codes for setcc/jcc
pub val CC_E:   u8 = 0x94;  # equal / zero
pub val CC_NE:  u8 = 0x95;  # not equal / not zero
pub val CC_L:   u8 = 0x9C;  # less (signed)
pub val CC_LE:  u8 = 0x9E;  # less or equal (signed)
pub val CC_G:   u8 = 0x9F;  # greater (signed)
pub val CC_GE:  u8 = 0x9D;  # greater or equal (signed)
pub val CC_B:   u8 = 0x92;  # below (unsigned)
pub val CC_BE:  u8 = 0x96;  # below or equal (unsigned)
pub val CC_A:   u8 = 0x97;  # above (unsigned)
pub val CC_AE:  u8 = 0x93;  # above or equal (unsigned)
pub val CC_C:   u8 = 0x92;  # carry
pub val CC_NC:  u8 = 0x93;  # not carry
pub val CC_O:   u8 = 0x90;  # overflow
pub val CC_NO:  u8 = 0x91;  # not overflow
pub val CC_S:   u8 = 0x98;  # sign
pub val CC_NS:  u8 = 0x99;  # not sign
pub val CC_P:   u8 = 0x9A;  # parity
pub val CC_NP:  u8 = 0x9B;  # not parity

# encode_rex: encode REX prefix byte.
pub fun encode_rex(w: bool, r: bool, x: bool, b: bool) u8 {
    var rex: u8 = 0x40;
    if (w) { rex = rex | REX_W; }
    if (r) { rex = rex | REX_R; }
    if (x) { rex = rex | REX_X; }
    if (b) { rex = rex | REX_B; }
    ret rex;
}

# emit_rex: emit REX prefix only if needed (non-zero or forced).
fun emit_rex(alloc: *allocator.Allocator, sec: *section.Section, w: bool, r: bool, x: bool, b: bool) Result[usize, str] {
    var rex: u8 = encode_rex(w, r, x, b);
    if (rex != 0x40 || w || r || x || b) {
        ret section.emit_byte(alloc, sec, rex);
    }
    ret ok[usize, str](section.current_offset(sec));
}

# emit_rex_force: emit REX prefix when forced (for spl/bpl/sil/dil).
fun emit_rex_force(alloc: *allocator.Allocator, sec: *section.Section, force: bool, w: bool, r: bool, x: bool, b: bool) Result[usize, str] {
    var rex: u8 = encode_rex(w, r, x, b);
    if (force || rex != 0x40) {
        ret section.emit_byte(alloc, sec, rex);
    }
    ret ok[usize, str](section.current_offset(sec));
}

# encode_modrm: encode ModR/M byte.
pub fun encode_modrm(mod_val: u8, reg: u8, rm: u8) u8 {
    ret ((mod_val & 3) << 6) | ((reg & 7) << 3) | (rm & 7);
}

# encode_sib: encode SIB byte.
pub fun encode_sib(scale_val: u8, index: u8, base: u8) u8 {
    ret ((scale_val & 3) << 6) | ((index & 7) << 3) | (base & 7);
}

# reg_low: get the low 3 bits of a register number.
fun reg_low(r: i32) u8 {
    ret (r & 7)::u8;
}

# needs_rex_w: check if instruction needs 64-bit operand size.
fun needs_rex_w(sz: usize) bool {
    ret sz == 8;
}

# needs_rex_b: check if register needs REX.B extension.
fun needs_rex_b(reg: i32) bool {
    ret reg >= 8;
}

# needs_rex_r: check if register needs REX.R extension.
fun needs_rex_r(reg: i32) bool {
    ret reg >= 8;
}

# needs_rex_x: check if index register needs REX.X extension.
fun needs_rex_x(index: i32) bool {
    ret index >= 8;
}

# needs_rex_force: check if low byte register needs forced REX.
fun needs_rex_force_byte(r: i32) bool {
    # spl, bpl, sil, dil (registers 4-7) need REX prefix for byte access
    ret r >= 4 && r <= 7;
}

# emit_imm8: emit 8-bit immediate.
fun emit_imm8(alloc: *allocator.Allocator, sec: *section.Section, imm: i8) Result[usize, str] {
    ret section.emit_byte(alloc, sec, imm::u8);
}

# emit_imm16: emit 16-bit immediate (little-endian).
fun emit_imm16(alloc: *allocator.Allocator, sec: *section.Section, imm: i16) Result[usize, str] {
    var bytes: [2]u8;
    val v: u16 = imm::u16;
    bytes[0] = (v & 255)::u8;
    bytes[1] = ((v >> 8) & 255)::u8;
    ret section.emit_bytes(alloc, sec, ?bytes[0], 2);
}

# emit_imm32: emit 32-bit immediate (little-endian).
fun emit_imm32(alloc: *allocator.Allocator, sec: *section.Section, imm: i32) Result[usize, str] {
    var bytes: [4]u8;
    val v: u32 = imm::u32;
    bytes[0] = (v & 255)::u8;
    bytes[1] = ((v >> 8) & 255)::u8;
    bytes[2] = ((v >> 16) & 255)::u8;
    bytes[3] = ((v >> 24) & 255)::u8;
    ret section.emit_bytes(alloc, sec, ?bytes[0], 4);
}

# emit_imm64: emit 64-bit immediate (little-endian).
fun emit_imm64(alloc: *allocator.Allocator, sec: *section.Section, imm: i64) Result[usize, str] {
    var bytes: [8]u8;
    val v: u64 = imm::u64;
    bytes[0] = (v & 255)::u8;
    bytes[1] = ((v >> 8) & 255)::u8;
    bytes[2] = ((v >> 16) & 255)::u8;
    bytes[3] = ((v >> 24) & 255)::u8;
    bytes[4] = ((v >> 32) & 255)::u8;
    bytes[5] = ((v >> 40) & 255)::u8;
    bytes[6] = ((v >> 48) & 255)::u8;
    bytes[7] = ((v >> 56) & 255)::u8;
    ret section.emit_bytes(alloc, sec, ?bytes[0], 8);
}

# emit_mem: emit memory addressing (ModR/M + optional SIB + displacement).
# handles complex addressing modes including SIB encoding.
fun emit_mem(alloc: *allocator.Allocator, sec: *section.Section, base: i32, index: i32, scale: i32, disp: i64, reg_field: i32) Result[usize, str] {
    var has_index: bool = index >= 0 && scale > 0;
    var mod_val: u8 = MOD_DISP32;
    var result: Result[usize, str];

    # determine mod based on displacement size
    if (!has_index && disp == 0 && (base & 7) != 5 && base != 5 && base != 13) {
        # RBP/R13 always needs displacement (base & 7 == 5)
        mod_val = MOD_DISP0;
    } or (disp >= -128 && disp <= 127) {
        mod_val = MOD_DISP8;
    }

    # check if we need SIB byte
    var needs_sib: bool = has_index || (base & 7) == 4;

    if (needs_sib) {
        # emit ModR/M with R/M = 0x04 (indicates SIB follows)
        val modrm: u8 = encode_modrm(mod_val, reg_field::u8, 4);
        result = section.emit_byte(alloc, sec, modrm);
        if (result_is_err[usize, str](result)) { ret result; }

        # emit SIB byte
        var scale_bits: u8 = 0;
        if (scale == 2) { scale_bits = 1; }
        or (scale == 4) { scale_bits = 2; }
        or (scale == 8) { scale_bits = 3; }

        var index_low: i32 = index;
        if (!has_index) { index_low = 4; }  # no index encoding

        val sib: u8 = encode_sib(scale_bits, index_low::u8, base::u8);
        result = section.emit_byte(alloc, sec, sib);
        if (result_is_err[usize, str](result)) { ret result; }
    } or {
        # direct base register addressing
        val modrm: u8 = encode_modrm(mod_val, reg_field::u8, base::u8);
        result = section.emit_byte(alloc, sec, modrm);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    # emit displacement if needed
    if (mod_val == MOD_DISP8) {
        result = section.emit_byte(alloc, sec, disp::i8::u8);
        if (result_is_err[usize, str](result)) { ret result; }
    } or (mod_val == MOD_DISP32 || (!has_index && (base & 7) == 5)) {
        # need 32-bit displacement for RBP/R13 base or large disp
        result = emit_imm32(alloc, sec, disp::i32);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    ret ok[usize, str](section.current_offset(sec));
}

# emit_operand_size_prefix: emit 0x66 prefix for 16-bit operations.
fun emit_operand_size_prefix(alloc: *allocator.Allocator, sec: *section.Section, sz: usize) Result[usize, str] {
    if (sz == 2) {
        ret section.emit_byte(alloc, sec, 0x66);
    }
    ret ok[usize, str](section.current_offset(sec));
}

# ============================================================================
# DATA MOVEMENT ENCODING
# ============================================================================

# encode_mov: encode mov instruction (handles RR, RI, RM, MR variants).
# ---
# alloc:   allocator for section growth
# sec:     section to emit to
# dst:     destination operand
# src:     source operand
# ret:     Ok(bytes_emitted) on success, Err(str) on failure
pub fun encode_mov(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_reg(dst) && is_reg(src)) {
        # mov r, r (RR)
        val dst_reg: i32 = dst.reg;
        val src_reg: i32 = src.reg;
        val sz: usize = dst.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;
        val rex_r: bool = needs_rex_r(src_reg);
        val rex_b: bool = needs_rex_b(dst_reg);
        val rex_force: bool = byte && (needs_rex_force_byte(src_reg) || needs_rex_force_byte(dst_reg));

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x89;
        if (byte) { opcode = 0x88; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(src_reg), reg_low(dst_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_mem(src)) {
        # mov r, m (RM)
        val dst_reg: i32 = dst.reg;
        val sz: usize = dst.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;
        val rex_r: bool = needs_rex_r(dst_reg);
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);
        val rex_force: bool = byte && needs_rex_force_byte(dst_reg);

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x8B;
        if (byte) { opcode = 0x8A; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst) && is_reg(src)) {
        # mov m, r (MR)
        val src_reg: i32 = src.reg;
        val sz: usize = dst.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;
        val rex_r: bool = needs_rex_r(src_reg);
        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);
        val rex_force: bool = byte && needs_rex_force_byte(src_reg);

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x89;
        if (byte) { opcode = 0x88; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, src_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_imm(src)) {
        # mov r, i (RI)
        val dst_reg: i32 = dst.reg;
        val sz: usize = dst.size;
        val imm: i64 = src.imm;

        if (sz == 1) {
            # 8-bit immediate
            val rex_b: bool = needs_rex_b(dst_reg);
            val rex_force: bool = needs_rex_force_byte(dst_reg);
            result = emit_rex_force(alloc, sec, rex_force, false, false, false, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }

            result = section.emit_byte(alloc, sec, 0xB0 + reg_low(dst_reg));
            if (result_is_err[usize, str](result)) { ret result; }

            result = section.emit_byte(alloc, sec, imm::i8::u8);
            if (result_is_err[usize, str](result)) { ret result; }

        } or {
            result = emit_operand_size_prefix(alloc, sec, sz);
            if (result_is_err[usize, str](result)) { ret result; }

            val w: bool = sz == 8;
            val rex_b: bool = needs_rex_b(dst_reg);

            # check if imm fits in 32 bits - order matters!
            # first: zero-extend for positive values in u32 range [0, 0xFFFFFFFF]
            if (sz == 8 && imm >= 0 && imm <= 0xFFFFFFFF::i64) {
                # use mov r64, imm32 (zero-extended upper bits, no REX.W)
                result = emit_rex(alloc, sec, false, false, false, rex_b);
                if (result_is_err[usize, str](result)) { ret result; }

                result = section.emit_byte(alloc, sec, 0xB8 + reg_low(dst_reg));
                if (result_is_err[usize, str](result)) { ret result; }

                result = emit_imm32(alloc, sec, imm::i32);
                if (result_is_err[usize, str](result)) { ret result; }

            } or (sz == 8 && imm >= -2147483648 && imm <= -1) {
                # sign-extend for negative i32 values [-2147483648, -1]
                result = emit_rex(alloc, sec, true, false, false, rex_b);
                if (result_is_err[usize, str](result)) { ret result; }

                result = section.emit_byte(alloc, sec, 0xC7);
                if (result_is_err[usize, str](result)) { ret result; }

                result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, 0, reg_low(dst_reg)));
                if (result_is_err[usize, str](result)) { ret result; }

                result = emit_imm32(alloc, sec, imm::i32);
                if (result_is_err[usize, str](result)) { ret result; }

            } or (sz == 8) {
                # full 64-bit immediate
                result = emit_rex(alloc, sec, true, false, false, rex_b);
                if (result_is_err[usize, str](result)) { ret result; }

                result = section.emit_byte(alloc, sec, 0xB8 + reg_low(dst_reg));
                if (result_is_err[usize, str](result)) { ret result; }

                result = emit_imm64(alloc, sec, imm);
                if (result_is_err[usize, str](result)) { ret result; }

            } or (sz == 2) {
                # 16-bit immediate
                result = section.emit_byte(alloc, sec, 0xB8 + reg_low(dst_reg));
                if (result_is_err[usize, str](result)) { ret result; }

                result = emit_imm16(alloc, sec, imm::i16);
                if (result_is_err[usize, str](result)) { ret result; }

            } or {
                # 32-bit immediate
                result = section.emit_byte(alloc, sec, 0xB8 + reg_low(dst_reg));
                if (result_is_err[usize, str](result)) { ret result; }

                result = emit_imm32(alloc, sec, imm::i32);
                if (result_is_err[usize, str](result)) { ret result; }
            }
        }

    } or (is_reg(dst) && is_label(src)) {
        # mov r, label (for loading symbol addresses)
        # always use full 64-bit encoding: REX.W B8+r imm64
        val dst_reg: i32 = dst.reg;
        val rex_b: bool = needs_rex_b(dst_reg);

        result = emit_rex(alloc, sec, true, false, false, rex_b);  # REX.W
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xB8 + reg_low(dst_reg));
        if (result_is_err[usize, str](result)) { ret result; }

        # record offset for relocation, then emit 8 bytes of zeros
        val reloc_offset: usize = section.current_offset(sec);
        result = emit_imm64(alloc, sec, 0);
        if (result_is_err[usize, str](result)) { ret result; }

        # add RELOC_64 relocation for the label
        section.add_relocation(alloc, sec, reloc_offset, src.label, section.RELOC_64, 0);

    } or (is_mem(dst) && is_imm(src)) {
        # mov m, i (MI)
        val sz: usize = dst.size;
        val imm: i64 = src.imm;
        val w: bool = sz == 8;
        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        if (sz == 1) {
            result = emit_rex(alloc, sec, false, false, rex_x, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }

            result = section.emit_byte(alloc, sec, 0xC6);
            if (result_is_err[usize, str](result)) { ret result; }

        } or {
            result = emit_rex(alloc, sec, w, false, rex_x, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }

            result = section.emit_byte(alloc, sec, 0xC7);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, 0);
        if (result_is_err[usize, str](result)) { ret result; }

        # emit immediate value
        if (sz == 1) {
            result = section.emit_byte(alloc, sec, imm::i8::u8);
        } or (sz == 2) {
            result = emit_imm16(alloc, sec, imm::i16);
        } or {
            result = emit_imm32(alloc, sec, imm::i32);
        }
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operands for mov");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_push: encode push instruction.
pub fun encode_push(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_reg(op)) {
        # push r
        val r: i32 = op.reg;
        val rex_b: bool = needs_rex_b(r);

        result = emit_rex(alloc, sec, false, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x50 + reg_low(r));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_imm(op)) {
        # push imm
        val imm: i64 = op.imm;

        if (imm >= -128 && imm <= 127) {
            result = section.emit_byte(alloc, sec, 0x6A);
            if (result_is_err[usize, str](result)) { ret result; }

            result = section.emit_byte(alloc, sec, imm::i8::u8);
            if (result_is_err[usize, str](result)) { ret result; }

        } or {
            result = section.emit_byte(alloc, sec, 0x68);
            if (result_is_err[usize, str](result)) { ret result; }

            result = emit_imm32(alloc, sec, imm::i32);
            if (result_is_err[usize, str](result)) { ret result; }
        }

    } or (is_mem(op)) {
        # push m
        val rex_x: bool = needs_rex_x(op.index);
        val rex_b: bool = needs_rex_b(op.base);

        result = emit_rex(alloc, sec, false, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, op.base, op.index, op.scale, op.disp, 6);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operand for push");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_pop: encode pop instruction.
pub fun encode_pop(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_reg(op)) {
        # pop r
        val r: i32 = op.reg;
        val rex_b: bool = needs_rex_b(r);

        result = emit_rex(alloc, sec, false, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x58 + reg_low(r));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(op)) {
        # pop m
        val rex_x: bool = needs_rex_x(op.index);
        val rex_b: bool = needs_rex_b(op.base);

        result = emit_rex(alloc, sec, false, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x8F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, op.base, op.index, op.scale, op.disp, 0);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operand for pop");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_lea: encode lea instruction.
pub fun encode_lea(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_reg(dst) || !is_mem(src)) {
        ret err[usize, str]("lea requires register destination and memory source");
    }

    val dst_reg: i32 = dst.reg;
    val w: bool = dst.size == 8;
    val rex_r: bool = needs_rex_r(dst_reg);
    val rex_x: bool = needs_rex_x(src.index);
    val rex_b: bool = needs_rex_b(src.base);

    result = emit_rex(alloc, sec, w, rex_r, rex_x, rex_b);
    if (result_is_err[usize, str](result)) { ret result; }

    result = section.emit_byte(alloc, sec, 0x8D);
    if (result_is_err[usize, str](result)) { ret result; }

    result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
    if (result_is_err[usize, str](result)) { ret result; }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# ARITHMETIC ENCODING
# ============================================================================

# encode_add: encode add instruction.
# x86 opcodes: 0x00=MR byte, 0x01=MR word, 0x02=RM byte, 0x03=RM word
pub fun encode_add(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x00, 0x02, 0x01, 0x03, 0);
}

# encode_sub: encode sub instruction.
# opcodes: byte_mr=0x28, byte_rm=0x2A, word_mr=0x29, word_rm=0x2B
pub fun encode_sub(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x28, 0x2A, 0x29, 0x2B, 5);
}

# encode_adc: encode adc (add with carry) instruction.
# x86 opcodes: 0x10=MR byte, 0x11=MR word, 0x12=RM byte, 0x13=RM word
pub fun encode_adc(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x10, 0x12, 0x11, 0x13, 2);
}

# encode_sbb: encode sbb (subtract with borrow) instruction.
# x86 opcodes: 0x18=MR byte, 0x19=MR word, 0x1A=RM byte, 0x1B=RM word
pub fun encode_sbb(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x18, 0x1A, 0x19, 0x1B, 3);
}

# encode_alu: helper for encoding ALU instructions (add, sub, and, or, xor, cmp, test).
# opcodes: byte_mr, byte_rm, word_mr, word_rm, subop (for immediate)
fun encode_alu(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand,
               byte_mr: u8, byte_rm: u8, word_mr: u8, word_rm: u8, subop: u8) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_reg(dst) && is_reg(src)) {
        # r, r (MR form: op r/m, r -> becomes dst, src)
        val dst_reg: i32 = dst.reg;
        val src_reg: i32 = src.reg;
        val sz: usize = dst.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(src_reg);
        val rex_b: bool = needs_rex_b(dst_reg);
        val rex_force: bool = byte && (needs_rex_force_byte(src_reg) || needs_rex_force_byte(dst_reg));

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = word_mr;
        if (byte) { opcode = byte_mr; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(src_reg), reg_low(dst_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst) && is_reg(src)) {
        # m, r (MR form)
        val src_reg: i32 = src.reg;
        val sz: usize = src.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(src_reg);
        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);
        val rex_force: bool = byte && needs_rex_force_byte(src_reg);

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = word_mr;
        if (byte) { opcode = byte_mr; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, src_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_mem(src)) {
        # r, m (RM form)
        val dst_reg: i32 = dst.reg;
        val sz: usize = dst.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(dst_reg);
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);
        val rex_force: bool = byte && needs_rex_force_byte(dst_reg);

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = word_rm;
        if (byte) { opcode = byte_rm; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_imm(src)) {
        # r, i (RI form using group 1: 80/81/83)
        val dst_reg: i32 = dst.reg;
        val sz: usize = dst.size;
        val imm: i64 = src.imm;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;
        val imm8_opt: bool = imm >= -128 && imm <= 127;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_b: bool = needs_rex_b(dst_reg);
        val rex_force: bool = byte && needs_rex_force_byte(dst_reg);

        # select opcode based on size and immediate range
        var opcode: u8 = 0x81;  # default 32-bit imm
        if (byte) {
            opcode = 0x80;
        } or (imm8_opt) {
            opcode = 0x83;
        }

        result = emit_rex_force(alloc, sec, rex_force, w, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, subop, reg_low(dst_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

        # emit immediate
        if (byte || imm8_opt) {
            result = section.emit_byte(alloc, sec, imm::i8::u8);
        } or (sz == 2) {
            result = emit_imm16(alloc, sec, imm::i16);
        } or {
            result = emit_imm32(alloc, sec, imm::i32);
        }
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst) && is_imm(src)) {
        # m, i (MI form using group 1)
        val sz: usize = dst.size;
        val imm: i64 = src.imm;
        val w: bool = sz == 8;
        val imm8_opt: bool = imm >= -128 && imm <= 127;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);

        var opcode: u8 = 0x81;
        if (sz == 1) {
            opcode = 0x80;
        } or (imm8_opt) {
            opcode = 0x83;
        }

        result = emit_rex(alloc, sec, w, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, subop::i32);
        if (result_is_err[usize, str](result)) { ret result; }

        # emit immediate
        if (sz == 1 || imm8_opt) {
            result = section.emit_byte(alloc, sec, imm::i8::u8);
        } or (sz == 2) {
            result = emit_imm16(alloc, sec, imm::i16);
        } or {
            result = emit_imm32(alloc, sec, imm::i32);
        }
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operands for ALU instruction");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_mul: encode mul (unsigned multiply) instruction.
pub fun encode_mul(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    ret encode_unary_mul_div(alloc, sec, op, 4);
}

# encode_imul: encode imul (signed multiply) instruction.
pub fun encode_imul(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, imm: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_reg(dst) && is_reg(src) && is_none(imm)) {
        # imul r, r (two-operand form)
        val dst_reg: i32 = dst.reg;
        val src_reg: i32 = src.reg;
        val w: bool = dst.size == 8;

        result = emit_rex(alloc, sec, w, needs_rex_r(dst_reg), false, needs_rex_b(src_reg));
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xAF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_reg), reg_low(src_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_mem(src) && is_none(imm)) {
        # imul r, m
        val dst_reg: i32 = dst.reg;
        val w: bool = dst.size == 8;

        result = emit_rex(alloc, sec, w, needs_rex_r(dst_reg), needs_rex_x(src.index), needs_rex_b(src.base));
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xAF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_reg(src) && is_imm(imm)) {
        # imul r, r, imm (three-operand form)
        val dst_reg: i32 = dst.reg;
        val src_reg: i32 = src.reg;
        val imm_val: i64 = imm.imm;
        val w: bool = dst.size == 8;
        val imm8: bool = imm_val >= -128 && imm_val <= 127;

        result = emit_rex(alloc, sec, w, needs_rex_r(dst_reg), false, needs_rex_b(src_reg));
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x69;
        if (imm8) { opcode = 0x6B; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_reg), reg_low(src_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

        if (imm8) {
            result = section.emit_byte(alloc, sec, imm_val::i8::u8);
        } or (dst.size == 2) {
            result = emit_imm16(alloc, sec, imm_val::i16);
        } or {
            result = emit_imm32(alloc, sec, imm_val::i32);
        }
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_mem(src) && is_imm(imm)) {
        # imul r, m, imm
        val dst_reg: i32 = dst.reg;
        val imm_val: i64 = imm.imm;
        val w: bool = dst.size == 8;
        val imm8: bool = imm_val >= -128 && imm_val <= 127;

        result = emit_rex(alloc, sec, w, needs_rex_r(dst_reg), needs_rex_x(src.index), needs_rex_b(src.base));
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x69;
        if (imm8) { opcode = 0x6B; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

        if (imm8) {
            result = section.emit_byte(alloc, sec, imm_val::i8::u8);
        } or (dst.size == 2) {
            result = emit_imm16(alloc, sec, imm_val::i16);
        } or {
            result = emit_imm32(alloc, sec, imm_val::i32);
        }
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operands for imul");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_div: encode div (unsigned divide) instruction.
pub fun encode_div(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    ret encode_unary_mul_div(alloc, sec, op, 6);
}

# encode_idiv: encode idiv (signed divide) instruction.
pub fun encode_idiv(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    ret encode_unary_mul_div(alloc, sec, op, 7);
}

# encode_unary_mul_div: helper for mul/div/idiv (group 3 instructions).
fun encode_unary_mul_div(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand, subop: u8) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    var sz: usize = 0;
    if (is_reg(op)) {
        sz = op.size;
    } or (is_mem(op)) {
        sz = op.size;
    } or {
        ret err[usize, str]("invalid operand for mul/div");
    }

    val byte: bool = sz == 1;
    val w: bool = sz == 8;

    result = emit_operand_size_prefix(alloc, sec, sz);
    if (result_is_err[usize, str](result)) { ret result; }

    if (is_reg(op)) {
        val r: i32 = op.reg;
        val rex_b: bool = needs_rex_b(r);
        val rex_force: bool = byte && needs_rex_force_byte(r);

        result = emit_rex_force(alloc, sec, rex_force, w, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0xF7;
        if (byte) { opcode = 0xF6; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, subop, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(op)) {
        val rex_x: bool = needs_rex_x(op.index);
        val rex_b: bool = needs_rex_b(op.base);

        result = emit_rex(alloc, sec, w, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0xF7;
        if (byte) { opcode = 0xF6; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, op.base, op.index, op.scale, op.disp, subop::i32);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_neg: encode neg instruction.
pub fun encode_neg(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    ret encode_unary_group3(alloc, sec, op, 3);
}

# encode_not: encode not instruction.
pub fun encode_not(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    ret encode_unary_group3(alloc, sec, op, 2);
}

# encode_inc: encode inc instruction.
pub fun encode_inc(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    # note: in 64-bit mode, inc r is encoded as FF /0 (group 4/5) not 40+r
    ret encode_unary_group4_5(alloc, sec, op, 0);
}

# encode_dec: encode dec instruction.
pub fun encode_dec(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand) Result[usize, str] {
    ret encode_unary_group4_5(alloc, sec, op, 1);
}

# encode_unary_group3: encode unary group 3 instructions (neg, not).
fun encode_unary_group3(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand, subop: u8) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    var sz: usize = 0;
    if (is_reg(op)) {
        sz = op.size;
    } or (is_mem(op)) {
        sz = op.size;
    } or {
        ret err[usize, str]("invalid operand for unary operation");
    }

    val byte: bool = sz == 1;
    val w: bool = sz == 8;

    result = emit_operand_size_prefix(alloc, sec, sz);
    if (result_is_err[usize, str](result)) { ret result; }

    if (is_reg(op)) {
        val r: i32 = op.reg;
        val rex_b: bool = needs_rex_b(r);
        val rex_force: bool = byte && needs_rex_force_byte(r);

        result = emit_rex_force(alloc, sec, rex_force, w, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0xF7;
        if (byte) { opcode = 0xF6; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, subop, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(op)) {
        val rex_x: bool = needs_rex_x(op.index);
        val rex_b: bool = needs_rex_b(op.base);

        result = emit_rex(alloc, sec, w, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0xF7;
        if (byte) { opcode = 0xF6; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, op.base, op.index, op.scale, op.disp, subop::i32);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_unary_group4_5: encode inc/dec using group 4/5 (FF /0 or /1).
fun encode_unary_group4_5(alloc: *allocator.Allocator, sec: *section.Section, op: operand.Operand, subop: u8) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    var sz: usize = 0;
    if (is_reg(op)) {
        sz = op.size;
    } or (is_mem(op)) {
        sz = op.size;
    } or {
        ret err[usize, str]("invalid operand for inc/dec");
    }

    val w: bool = sz == 8;

    result = emit_operand_size_prefix(alloc, sec, sz);
    if (result_is_err[usize, str](result)) { ret result; }

    if (is_reg(op)) {
        val r: i32 = op.reg;
        val rex_b: bool = needs_rex_b(r);

        result = emit_rex(alloc, sec, w, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, subop, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(op)) {
        val rex_x: bool = needs_rex_x(op.index);
        val rex_b: bool = needs_rex_b(op.base);

        result = emit_rex(alloc, sec, w, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, op.base, op.index, op.scale, op.disp, subop::i32);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# BITWISE OPERATIONS ENCODING
# ============================================================================

# encode_and: encode and instruction.
# x86 opcodes: 0x20=MR byte, 0x21=MR word, 0x22=RM byte, 0x23=RM word
pub fun encode_and(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x20, 0x22, 0x21, 0x23, 4);
}

# encode_or: encode or instruction.
# x86 opcodes: 0x08=MR byte, 0x09=MR word, 0x0A=RM byte, 0x0B=RM word
pub fun encode_or(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x08, 0x0A, 0x09, 0x0B, 1);
}

# encode_xor: encode xor instruction.
# x86 opcodes: 0x30=MR byte, 0x31=MR word, 0x32=RM byte, 0x33=RM word
pub fun encode_xor(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x30, 0x32, 0x31, 0x33, 6);
}

# encode_shl: encode shl (shift left logical) instruction.
pub fun encode_shl(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, count: operand.Operand) Result[usize, str] {
    ret encode_shift(alloc, sec, dst, count, 4);
}

# encode_shr: encode shr (shift right logical) instruction.
pub fun encode_shr(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, count: operand.Operand) Result[usize, str] {
    ret encode_shift(alloc, sec, dst, count, 5);
}

# encode_sar: encode sar (shift right arithmetic) instruction.
pub fun encode_sar(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, count: operand.Operand) Result[usize, str] {
    ret encode_shift(alloc, sec, dst, count, 7);
}

# encode_shift: helper for encoding shift instructions.
fun encode_shift(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, count: operand.Operand, subop: u8) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    var sz: usize = 0;
    if (is_reg(dst)) {
        sz = dst.size;
    } or (is_mem(dst)) {
        sz = dst.size;
    } or {
        ret err[usize, str]("invalid destination for shift");
    }

    val byte: bool = sz == 1;
    val w: bool = sz == 8;
    val is_cl: bool = is_reg(count) && count.reg == 1;  # CL register
    var imm: i64 = 0;
    if (is_imm(count)) { imm = count.imm; }

    result = emit_operand_size_prefix(alloc, sec, sz);
    if (result_is_err[usize, str](result)) { ret result; }

    # select opcode based on operand size and count type
    var opcode: u8 = 0;
    if (is_cl) {
        # shift by CL: D2 (byte) or D3 (word)
        opcode = 0xD3;
        if (byte) { opcode = 0xD2; }
    } or (imm == 1) {
        # shift by 1: D0 (byte) or D1 (word)
        opcode = 0xD1;
        if (byte) { opcode = 0xD0; }
    } or {
        # shift by immediate: C0 (byte) or C1 (word)
        opcode = 0xC1;
        if (byte) { opcode = 0xC0; }
    }

    if (is_reg(dst)) {
        val r: i32 = dst.reg;
        val rex_b: bool = needs_rex_b(r);
        val rex_force: bool = byte && needs_rex_force_byte(r);

        result = emit_rex_force(alloc, sec, rex_force, w, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, subop, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst)) {
        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);

        result = emit_rex(alloc, sec, w, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, subop::i32);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    # emit immediate count if not CL and not 1
    if (!is_cl && imm != 1) {
        result = section.emit_byte(alloc, sec, imm::i8::u8);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# COMPARISON ENCODING
# ============================================================================

# encode_cmp: encode cmp instruction.
# x86 opcodes: 0x38=MR byte, 0x39=MR word, 0x3A=RM byte, 0x3B=RM word
pub fun encode_cmp(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    ret encode_alu(alloc, sec, dst, src, 0x38, 0x3A, 0x39, 0x3B, 7);
}

# encode_test: encode test instruction.
pub fun encode_test(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    # test is special - it's commutative but encoded differently depending on operands
    if (is_reg(dst) && is_reg(src)) {
        val dst_reg: i32 = dst.reg;
        val src_reg: i32 = src.reg;
        val sz: usize = dst.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(src_reg);
        val rex_b: bool = needs_rex_b(dst_reg);
        val rex_force: bool = byte && (needs_rex_force_byte(src_reg) || needs_rex_force_byte(dst_reg));

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x85;
        if (byte) { opcode = 0x84; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(src_reg), reg_low(dst_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst) && is_reg(src)) {
        val src_reg: i32 = src.reg;
        val sz: usize = src.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(src_reg);
        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);
        val rex_force: bool = byte && needs_rex_force_byte(src_reg);

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x85;
        if (byte) { opcode = 0x84; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, src_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(dst) && is_imm(src)) {
        val dst_reg: i32 = dst.reg;
        val sz: usize = dst.size;
        val imm: i64 = src.imm;
        val byte: bool = sz == 1;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_b: bool = needs_rex_b(dst_reg);
        val rex_force: bool = byte && needs_rex_force_byte(dst_reg);

        result = emit_rex_force(alloc, sec, rex_force, sz == 8, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0xF7;
        if (byte) { opcode = 0xF6; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, 0, reg_low(dst_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

        if (byte) {
            result = section.emit_byte(alloc, sec, imm::i8::u8);
        } or (sz == 2) {
            result = emit_imm16(alloc, sec, imm::i16);
        } or {
            result = emit_imm32(alloc, sec, imm::i32);
        }
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operands for test");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_setcc: encode setcc instructions (set byte on condition).
pub fun encode_setcc(alloc: *allocator.Allocator, sec: *section.Section, cond: u8, dst: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_reg(dst) && !is_mem(dst)) {
        ret err[usize, str]("setcc requires register or memory destination");
    }

    # setcc always operates on byte
    if (is_reg(dst)) {
        val r: i32 = dst.reg;
        # spl, bpl, sil, dil need forced REX
        val rex_force: bool = needs_rex_force_byte(r);
        val rex_b: bool = needs_rex_b(r);

        if (rex_force || rex_b) {
            result = emit_rex_force(alloc, sec, rex_force, false, false, false, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, cond);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, 0, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst)) {
        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, cond);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, 0);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_sete: encode sete (set if equal) instruction.
pub fun encode_sete(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand) Result[usize, str] {
    ret encode_setcc(alloc, sec, CC_E, dst);
