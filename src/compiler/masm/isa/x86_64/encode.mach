
# encode_instruction_from_spec: wrapper to encode from spec.Instruction record.
# ---
# matches the API expected by isel.mach
# alloc: allocator
# sec:   section to emit into  
# instr: spec.Instruction record
# ret:   Ok(bytes) on success, Err(str) on failure
pub fun encode_instruction_from_spec(alloc: *allocator.Allocator, sec: *section.Section, instr: *spec.Instruction) Result[usize, str] {
    if (instr == nil) {
        ret err[usize, str]("instruction is nil");
    }
    
    # extract opcode and operands from spec.Instruction
    val opcode: i32 = instr.opcode;
    var ops: [3]operand.Operand;
    var count: usize = 0;
    
    # add dst if present
    if (!instr.dst.is_none()) {
        ops[count] = instr.dst;
        count = count + 1;
    }
    
    # add src1 if present
    if (!instr.src1.is_none()) {
        ops[count] = instr.src1;
        count = count + 1;
    }
    
    # add src2 if present
    if (!instr.src2.is_none()) {
        ops[count] = instr.src2;
        count = count + 1;
    }
    
    # dispatch to main encoder
    ret encode_instruction(alloc, sec, opcode, ?ops[0], count);
}
