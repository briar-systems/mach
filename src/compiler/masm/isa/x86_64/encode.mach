}

# encode_jae: encode jae (jump if above or equal / unsigned greater or equal) instruction.
pub fun encode_jae(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
    ret encode_jcc(alloc, sec, 0x83, target);
}

# encode_call: encode call instruction.
pub fun encode_call(alloc: *allocator.Allocator, sec: *section.Section, target: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_imm(target)) {
        # call rel32
        result = section.emit_byte(alloc, sec, 0xE8);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_imm32(alloc, sec, target.imm::i32);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(target)) {
        # call r (indirect)
        val r: i32 = target.reg;
        val rex_b: bool = needs_rex_b(r);

        result = emit_rex(alloc, sec, false, false, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, 2, reg_low(r)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(target)) {
        # call m (indirect)
        val rex_x: bool = needs_rex_x(target.index);
        val rex_b: bool = needs_rex_b(target.base);

        result = emit_rex(alloc, sec, false, false, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0xFF);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, target.base, target.index, target.scale, target.disp, 2);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_label(target)) {
        # call rel32 with relocation
        result = section.emit_byte(alloc, sec, 0xE8);
        if (result_is_err[usize, str](result)) { ret result; }

        # record offset for relocation (points to the 4-byte displacement)
        val reloc_offset: usize = section.current_offset(sec);

        # emit placeholder (will be patched by linker/ELF emitter)
        result = emit_imm32(alloc, sec, 0);
        if (result_is_err[usize, str](result)) { ret result; }

        # add PC-relative relocation (addend -4 because displacement is relative to end of instruction)
        val reloc_res: Result[bool, str] = section.add_relocation(alloc, sec, reloc_offset, target.label, section.RELOC_PC32, -4);
        if (result_is_err[bool, str](reloc_res)) { ret err[usize, str]("failed to add call relocation"); }

    } or {
        ret err[usize, str]("invalid target for call");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_ret: encode ret instruction.
pub fun encode_ret(alloc: *allocator.Allocator, sec: *section.Section, pop_bytes: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_none(pop_bytes)) {
        # ret (no pop)
        result = section.emit_byte(alloc, sec, 0xC3);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_imm(pop_bytes)) {
        # ret imm16 (pop bytes from stack)
        result = section.emit_byte(alloc, sec, 0xC2);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_imm16(alloc, sec, pop_bytes.imm::i16);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operand for ret");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# SYSTEM INSTRUCTIONS ENCODING
# ============================================================================

# encode_syscall: encode syscall instruction.
pub fun encode_syscall(alloc: *allocator.Allocator, sec: *section.Section) Result[usize, str] {
    var result: Result[usize, str];
    result = section.emit_byte(alloc, sec, 0x0F);
    if (result_is_err[usize, str](result)) { ret result; }
    result = section.emit_byte(alloc, sec, 0x05);
    if (result_is_err[usize, str](result)) { ret result; }
    ret ok[usize, str](2);
}

# encode_int: encode int (interrupt) instruction.
pub fun encode_int(alloc: *allocator.Allocator, sec: *section.Section, vector: u8) Result[usize, str] {
    var result: Result[usize, str];

    if (vector == 0x03) {
        # int 3 is a special one-byte encoding
        result = section.emit_byte(alloc, sec, 0xCC);
    } or {
        result = section.emit_byte(alloc, sec, 0xCD);
        if (result_is_err[usize, str](result)) { ret result; }
        result = section.emit_byte(alloc, sec, vector);
    }

    if (result_is_err[usize, str](result)) { ret result; }
    var sz: usize = 2;
    if (vector == 0x03) { sz = 1; }
    ret ok[usize, str](sz);
}

# encode_hlt: encode hlt (halt) instruction.
pub fun encode_hlt(alloc: *allocator.Allocator, sec: *section.Section) Result[usize, str] {
    ret section.emit_byte(alloc, sec, 0xF4);
}

# ============================================================================
# FLOATING POINT ENCODING (SSE2)
# ============================================================================

# is_xmm: check if operand is an XMM register.
fun is_xmm(op: operand.Operand) bool {
    ret is_reg(op) && op.size == 16;
}

# encode_fmov: encode floating point mov (movsd, movss, movq).
pub fun encode_fmov(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    var prefix: u8 = 0xF3;
    if (double_prec) { prefix = 0xF2; }
    val opbyte: u8 = 0x10;  # movsd/movss

    result = section.emit_byte(alloc, sec, prefix);
    if (result_is_err[usize, str](result)) { ret result; }

    if (is_xmm(dst) && is_xmm(src)) {
        # xmm, xmm
        val dst_id: i32 = dst.reg;
        val src_id: i32 = src.reg;
        val rex_r: bool = needs_rex_r(dst_id);
        val rex_b: bool = needs_rex_b(src_id);

        if (rex_r || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, false, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opbyte);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_id), reg_low(src_id)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_xmm(dst) && is_mem(src)) {
        # xmm, m64/m32
        val dst_id: i32 = dst.reg;
        val rex_r: bool = needs_rex_r(dst_id);
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);

        if (rex_r || rex_x || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, rex_x, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opbyte);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_id);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(dst) && is_xmm(src)) {
        # m64/m32, xmm (store)
        val src_id: i32 = src.reg;
        val rex_r: bool = needs_rex_r(src_id);
        val rex_x: bool = needs_rex_x(dst.index);
        val rex_b: bool = needs_rex_b(dst.base);

        if (rex_r || rex_x || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, rex_x, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x11);  # movsd/movss store
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, dst.base, dst.index, dst.scale, dst.disp, src_id);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid operands for floating point mov");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_fadd: encode floating point add (addsd, addss).
pub fun encode_fadd(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool) Result[usize, str] {
    ret encode_farith(alloc, sec, dst, src, double_prec, 0x58);
}

# encode_fsub: encode floating point sub (subsd, subss).
pub fun encode_fsub(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool) Result[usize, str] {
    ret encode_farith(alloc, sec, dst, src, double_prec, 0x5C);
}

# encode_fmul: encode floating point mul (mulsd, mulss).
pub fun encode_fmul(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool) Result[usize, str] {
    ret encode_farith(alloc, sec, dst, src, double_prec, 0x59);
}

# encode_fdiv: encode floating point div (divsd, divss).
pub fun encode_fdiv(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool) Result[usize, str] {
    ret encode_farith(alloc, sec, dst, src, double_prec, 0x5E);
}

# encode_farith: helper for floating point arithmetic.
fun encode_farith(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool, opbyte: u8) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_xmm(dst)) {
        ret err[usize, str]("floating point arithmetic requires XMM destination");
    }

    var prefix: u8 = 0xF3;
    if (double_prec) { prefix = 0xF2; }
    val dst_id: i32 = dst.reg;
    val rex_r: bool = needs_rex_r(dst_id);

    result = section.emit_byte(alloc, sec, prefix);
    if (result_is_err[usize, str](result)) { ret result; }

    if (is_xmm(src)) {
        # xmm, xmm
        val src_id: i32 = src.reg;
        val rex_b: bool = needs_rex_b(src_id);

        if (rex_r || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, false, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opbyte);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_id), reg_low(src_id)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(src)) {
        # xmm, m64/m32
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);

        if (rex_r || rex_x || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, rex_x, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opbyte);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_id);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid source operand for floating point arithmetic");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_fcmp: encode floating point compare (ucomisd, ucomiss, comisd, comiss).
pub fun encode_fcmp(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand, double_prec: bool, ordered: bool) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_xmm(dst)) {
        ret err[usize, str]("floating point compare requires XMM destination");
    }

    var prefix: u8 = 0x00;
    if (double_prec) { prefix = 0x66; }  # comisd needs 66 prefix
    var opbyte: u8 = 0x2E;  # ucomisd
    if (ordered) { opbyte = 0x2F; }  # comisd vs ucomisd
    val dst_id: i32 = dst.reg;
    val rex_r: bool = needs_rex_r(dst_id);

    if (double_prec && ordered) {
        result = section.emit_byte(alloc, sec, prefix);
        if (result_is_err[usize, str](result)) { ret result; }
    }

    if (is_xmm(src)) {
        # xmm, xmm
        val src_id: i32 = src.reg;
        val rex_b: bool = needs_rex_b(src_id);

        if (rex_r || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, false, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opbyte);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_id), reg_low(src_id)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(src)) {
        # xmm, m64/m32
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);

        if (rex_r || rex_x || rex_b) {
            result = emit_rex(alloc, sec, false, rex_r, rex_x, rex_b);
            if (result_is_err[usize, str](result)) { ret result; }
        }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, opbyte);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_id);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid source operand for floating point compare");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# CONVERSION INSTRUCTIONS
# ============================================================================

# encode_movsx: encode movsx (sign-extend move).
pub fun encode_movsx(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_reg(dst)) {
        ret err[usize, str]("movsx requires register destination");
    }

    val dst_reg: i32 = dst.reg;
    val w: bool = dst.size == 8;
    val rex_r: bool = needs_rex_r(dst_reg);

    if (is_reg(src)) {
        # movsx r, r
        val src_reg: i32 = src.reg;
        val src_sz: usize = src.size;
        val rex_b: bool = needs_rex_b(src_reg);
        val rex_force: bool = src_sz == 1 && needs_rex_force_byte(src_reg);

        var ext_op: u8 = 0xBE;  # 8-bit
        if (src_sz == 2) { ext_op = 0xBF; }  # 16-bit

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, ext_op);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_reg), reg_low(src_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(src)) {
        # movsx r, m
        val src_sz: usize = src.size;
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);

        var ext_op: u8 = 0xBE;  # 8-bit
        if (src_sz == 2) { ext_op = 0xBF; }  # 16-bit

        result = emit_rex(alloc, sec, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, ext_op);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid source operand for movsx");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_movzx: encode movzx (zero-extend move).
pub fun encode_movzx(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_reg(dst)) {
        ret err[usize, str]("movzx requires register destination");
    }

    val dst_reg: i32 = dst.reg;
    val w: bool = dst.size == 8;
    val rex_r: bool = needs_rex_r(dst_reg);

    if (is_reg(src)) {
        # movzx r, r
        val src_reg: i32 = src.reg;
        val src_sz: usize = src.size;
        val rex_b: bool = needs_rex_b(src_reg);
        val rex_force: bool = src_sz == 1 && needs_rex_force_byte(src_reg);

        var ext_op: u8 = 0xB6;  # 8-bit
        if (src_sz == 2) { ext_op = 0xB7; }  # 16-bit

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, ext_op);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_reg), reg_low(src_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(src)) {
        # movzx r, m
        val src_sz: usize = src.size;
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);

        var ext_op: u8 = 0xB6;  # 8-bit
        if (src_sz == 2) { ext_op = 0xB7; }  # 16-bit

        result = emit_rex(alloc, sec, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x0F);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, ext_op);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid source operand for movzx");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# encode_movsxd: encode movsxd (sign-extend 32 to 64).
pub fun encode_movsxd(alloc: *allocator.Allocator, sec: *section.Section, dst: operand.Operand, src: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (!is_reg(dst) || dst.size != 8) {
        ret err[usize, str]("movsxd requires 64-bit register destination");
    }

    val dst_reg: i32 = dst.reg;
    val rex_r: bool = needs_rex_r(dst_reg);

    if (is_reg(src)) {
        # movsxd r64, r32
        val src_reg: i32 = src.reg;
        val rex_b: bool = needs_rex_b(src_reg);

        result = emit_rex(alloc, sec, true, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x63);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(dst_reg), reg_low(src_reg)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(src)) {
        # movsxd r64, m32
        val rex_x: bool = needs_rex_x(src.index);
        val rex_b: bool = needs_rex_b(src.base);

        result = emit_rex(alloc, sec, true, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, 0x63);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, src.base, src.index, src.scale, src.disp, dst_reg);
        if (result_is_err[usize, str](result)) { ret result; }

    } or {
        ret err[usize, str]("invalid source operand for movsxd");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# EXCHANGE INSTRUCTIONS
# ============================================================================

# encode_xchg: encode xchg instruction.
pub fun encode_xchg(alloc: *allocator.Allocator, sec: *section.Section, op1: operand.Operand, op2: operand.Operand) Result[usize, str] {
    var start: usize = section.current_offset(sec);
    var result: Result[usize, str];

    if (is_reg(op1) && is_reg(op2)) {
        # xchg r, r
        val r1: i32 = op1.reg;
        val r2: i32 = op2.reg;
        val sz: usize = op1.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(r2);
        val rex_b: bool = needs_rex_b(r1);
        val rex_force: bool = byte && (needs_rex_force_byte(r1) || needs_rex_force_byte(r2));

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, false, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x87;
        if (byte) { opcode = 0x86; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = section.emit_byte(alloc, sec, encode_modrm(MOD_REG, reg_low(r2), reg_low(r1)));
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_mem(op1) && is_reg(op2)) {
        # xchg m, r
        val r: i32 = op2.reg;
        val sz: usize = op2.size;
        val byte: bool = sz == 1;
        val w: bool = sz == 8;

        result = emit_operand_size_prefix(alloc, sec, sz);
        if (result_is_err[usize, str](result)) { ret result; }

        val rex_r: bool = needs_rex_r(r);
        val rex_x: bool = needs_rex_x(op1.index);
        val rex_b: bool = needs_rex_b(op1.base);
        val rex_force: bool = byte && needs_rex_force_byte(r);

        result = emit_rex_force(alloc, sec, rex_force, w, rex_r, rex_x, rex_b);
        if (result_is_err[usize, str](result)) { ret result; }

        var opcode: u8 = 0x87;
        if (byte) { opcode = 0x86; }
        result = section.emit_byte(alloc, sec, opcode);
        if (result_is_err[usize, str](result)) { ret result; }

        result = emit_mem(alloc, sec, op1.base, op1.index, op1.scale, op1.disp, r);
        if (result_is_err[usize, str](result)) { ret result; }

    } or (is_reg(op1) && is_mem(op2)) {
        # xchg r, m (symmetric, just swap)
        ret encode_xchg(alloc, sec, op2, op1);

    } or {
        ret err[usize, str]("invalid operands for xchg");
    }

    ret ok[usize, str](section.current_offset(sec) - start);
}

# ============================================================================
# MAIN ENCODE FUNCTION
# ============================================================================

# encode_instruction: encode a single instruction based on the spec.Instruction record.
# ---
# instr:   instruction to encode (spec.Instruction)
# sec:     section to emit to
# alloc:   allocator for section growth
# ret:     Ok(bytes_emitted) on success, Err(str) on failure
pub fun encode_instruction(instr: *spec.Instruction, sec: *section.Section, alloc: *allocator.Allocator) Result[usize, str] {
    if (instr == nil) {
        ret err[usize, str]("instruction is nil");
    }

    val opc: i32 = instr.opcode;

    # create array of operands from instruction record
    # maximum 3 operands: dst, src1, src2
    var ops: [3]operand.Operand;
    ops[0] = instr.dst;
    ops[1] = instr.src1;
    ops[2] = instr.src2;

    # count valid operands
    var count: i32 = 0;
    if (!is_none(instr.dst)) { count = count + 1; }
    if (!is_none(instr.src1)) { count = count + 1; }
    if (!is_none(instr.src2)) { count = count + 1; }

    # use the instruction-specific encoder
    ret encode_opcode_instruction(alloc, sec, opc, ?ops[0], count);
}

# encode_opcode_instruction: internal helper to encode based on opcode.
# ---
# alloc:   allocator for section growth
# sec:     section to emit to
# opcode:  instruction opcode value
# ops:     pointer to first operand
# count:   number of operands
# ret:     Ok(bytes_emitted) on success, Err(str) on failure
fun encode_opcode_instruction(alloc: *allocator.Allocator, sec: *section.Section, opc: i32, ops: *operand.Operand, count: i32) Result[usize, str] {
    # data movement
    if (opc == opcode.OP_MOV) {
        if (count < 2) { ret err[usize, str]("mov requires 2 operands"); }
        ret encode_mov(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.PUSH) {
        if (count < 1) { ret err[usize, str]("push requires 1 operand"); }
        ret encode_push(alloc, sec, ops[0]);
    }

    if (opc == opcode.POP) {
        if (count < 1) { ret err[usize, str]("pop requires 1 operand"); }
        ret encode_pop(alloc, sec, ops[0]);
    }

    if (opc == opcode.LEA) {
        if (count < 2) { ret err[usize, str]("lea requires 2 operands"); }
        ret encode_lea(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.MOVSX) {
        if (count < 2) { ret err[usize, str]("movsx requires 2 operands"); }
        ret encode_movsx(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.MOVZX) {
        if (count < 2) { ret err[usize, str]("movzx requires 2 operands"); }
        ret encode_movzx(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.CWD) {
        var result: Result[usize, str];
        result = section.emit_byte(alloc, sec, 0x66);
        if (result_is_err[usize, str](result)) { ret result; }
        result = section.emit_byte(alloc, sec, 0x98);
        if (result_is_err[usize, str](result)) { ret result; }
        ret ok[usize, str](2);
    }

    if (opc == opcode.CDQ) {
        ret section.emit_byte(alloc, sec, 0x99);
    }

    if (opc == opcode.CQO) {
        var result: Result[usize, str];
        result = section.emit_byte(alloc, sec, 0x48);
        if (result_is_err[usize, str](result)) { ret result; }
        result = section.emit_byte(alloc, sec, 0x99);
        if (result_is_err[usize, str](result)) { ret result; }
        ret ok[usize, str](2);
    }

    if (opc == opcode.XCHG) {
        if (count < 2) { ret err[usize, str]("xchg requires 2 operands"); }
        ret encode_xchg(alloc, sec, ops[0], ops[1]);
    }

    # arithmetic
    if (opc == opcode.ADD) {
        if (count < 2) { ret err[usize, str]("add requires 2 operands"); }
        ret encode_add(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.SUB) {
        if (count < 2) { ret err[usize, str]("sub requires 2 operands"); }
        ret encode_sub(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.ADC) {
        if (count < 2) { ret err[usize, str]("adc requires 2 operands"); }
        ret encode_adc(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.SBB) {
        if (count < 2) { ret err[usize, str]("sbb requires 2 operands"); }
        ret encode_sbb(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.NEG) {
        if (count < 1) { ret err[usize, str]("neg requires 1 operand"); }
        ret encode_neg(alloc, sec, ops[0]);
    }

    if (opc == opcode.MUL) {
        if (count < 1) { ret err[usize, str]("mul requires 1 operand"); }
        ret encode_mul(alloc, sec, ops[0]);
    }

    if (opc == opcode.IMUL) {
        if (count == 2) {
            ret encode_imul(alloc, sec, ops[0], ops[1], operand.none());
        } or (count == 3) {
            ret encode_imul(alloc, sec, ops[0], ops[1], ops[2]);
        } or {
            ret err[usize, str]("imul requires 2 or 3 operands");
        }
    }

    if (opc == opcode.DIV) {
        if (count < 1) { ret err[usize, str]("div requires 1 operand"); }
        ret encode_div(alloc, sec, ops[0]);
    }

    if (opc == opcode.IDIV) {
        if (count < 1) { ret err[usize, str]("idiv requires 1 operand"); }
        ret encode_idiv(alloc, sec, ops[0]);
    }

    if (opc == opcode.INC) {
        if (count < 1) { ret err[usize, str]("inc requires 1 operand"); }
        ret encode_inc(alloc, sec, ops[0]);
    }

    if (opc == opcode.DEC) {
        if (count < 1) { ret err[usize, str]("dec requires 1 operand"); }
        ret encode_dec(alloc, sec, ops[0]);
    }

    # bitwise
    if (opc == opcode.AND) {
        if (count < 2) { ret err[usize, str]("and requires 2 operands"); }
        ret encode_and(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.OR) {
        if (count < 2) { ret err[usize, str]("or requires 2 operands"); }
        ret encode_or(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.XOR) {
        if (count < 2) { ret err[usize, str]("xor requires 2 operands"); }
        ret encode_xor(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.NOT) {
        if (count < 1) { ret err[usize, str]("not requires 1 operand"); }
        ret encode_not(alloc, sec, ops[0]);
    }

    if (opc == opcode.SHL) {
        if (count < 2) { ret err[usize, str]("shl requires 2 operands"); }
        ret encode_shl(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.SHR) {
        if (count < 2) { ret err[usize, str]("shr requires 2 operands"); }
        ret encode_shr(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.SAR) {
        if (count < 2) { ret err[usize, str]("sar requires 2 operands"); }
        ret encode_sar(alloc, sec, ops[0], ops[1]);
    }

    # comparison
    if (opc == opcode.CMP) {
        if (count < 2) { ret err[usize, str]("cmp requires 2 operands"); }
        ret encode_cmp(alloc, sec, ops[0], ops[1]);
    }

    if (opc == opcode.TEST) {
        if (count < 2) { ret err[usize, str]("test requires 2 operands"); }
        ret encode_test(alloc, sec, ops[0], ops[1]);
    }

    # setcc variants
    if (opc == opcode.SETE) {
        if (count < 1) { ret err[usize, str]("sete requires 1 operand"); }
        ret encode_sete(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETNE) {
        if (count < 1) { ret err[usize, str]("setne requires 1 operand"); }
        ret encode_setne(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETL) {
        if (count < 1) { ret err[usize, str]("setl requires 1 operand"); }
        ret encode_setl(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETLE) {
        if (count < 1) { ret err[usize, str]("setle requires 1 operand"); }
        ret encode_setle(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETG) {
        if (count < 1) { ret err[usize, str]("setg requires 1 operand"); }
        ret encode_setg(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETGE) {
        if (count < 1) { ret err[usize, str]("setge requires 1 operand"); }
        ret encode_setge(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETB) {
        if (count < 1) { ret err[usize, str]("setb requires 1 operand"); }
        ret encode_setb(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETBE) {
        if (count < 1) { ret err[usize, str]("setbe requires 1 operand"); }
        ret encode_setbe(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETA) {
        if (count < 1) { ret err[usize, str]("seta requires 1 operand"); }
        ret encode_seta(alloc, sec, ops[0]);
    }

    if (opc == opcode.SETAE) {
        if (count < 1) { ret err[usize, str]("setae requires 1 operand"); }
        ret encode_setae(alloc, sec, ops[0]);
    }

    # control flow
    if (opc == opcode.JMP) {
        if (count < 1) { ret err[usize, str]("jmp requires 1 operand"); }
        ret encode_jmp(alloc, sec, ops[0]);
    }

    if (opc == opcode.JE) {
        if (count < 1) { ret err[usize, str]("je requires 1 operand"); }
        ret encode_je(alloc, sec, ops[0]);
    }

    if (opc == opcode.JNE) {
        if (count < 1) { ret err[usize, str]("jne requires 1 operand"); }
        ret encode_jne(alloc, sec, ops[0]);
    }

    if (opc == opcode.JL) {
        if (count < 1) { ret err[usize, str]("jl requires 1 operand"); }
        ret encode_jl(alloc, sec, ops[0]);
    }

    if (opc == opcode.JLE) {
        if (count < 1) { ret err[usize, str]("jle requires 1 operand"); }
        ret encode_jle(alloc, sec, ops[0]);
    }

    if (opc == opcode.JG) {
        if (count < 1) { ret err[usize, str]("jg requires 1 operand"); }
        ret encode_jg(alloc, sec, ops[0]);
    }

    if (opc == opcode.JGE) {
        if (count < 1) { ret err[usize, str]("jge requires 1 operand"); }
        ret encode_jge(alloc, sec, ops[0]);
    }

    if (opc == opcode.JB) {
        if (count < 1) { ret err[usize, str]("jb requires 1 operand"); }
        ret encode_jb(alloc, sec, ops[0]);
    }

    if (opc == opcode.JBE) {
        if (count < 1) { ret err[usize, str]("jbe requires 1 operand"); }
        ret encode_jbe(alloc, sec, ops[0]);
    }

    if (opc == opcode.JA) {
        if (count < 1) { ret err[usize, str]("ja requires 1 operand"); }
        ret encode_ja(alloc, sec, ops[0]);
    }

    if (opc == opcode.JAE) {
        if (count < 1) { ret err[usize, str]("jae requires 1 operand"); }
        ret encode_jae(alloc, sec, ops[0]);
    }

    if (opc == opcode.CALL) {
        if (count < 1) { ret err[usize, str]("call requires 1 operand"); }
        ret encode_call(alloc, sec, ops[0]);
    }

    if (opc == opcode.RET) {
        if (count == 0) {
            ret encode_ret(alloc, sec, operand.none());
        } or (count == 1) {
            ret encode_ret(alloc, sec, ops[0]);
        } or {
            ret err[usize, str]("ret requires 0 or 1 operands");
        }
    }

    # system
    if (opc == opcode.SYSCALL) {
        ret encode_syscall(alloc, sec);
    }

    if (opc == opcode.INT) {
        if (count < 1) { ret err[usize, str]("int requires 1 operand"); }
        ret encode_int(alloc, sec, ops[0].imm::u8);
    }

    if (opc == opcode.HLT) {
        ret encode_hlt(alloc, sec);
    }

    # floating point
    if (opc == opcode.MOVSD) {
        if (count < 2) { ret err[usize, str]("movsd requires 2 operands"); }
        ret encode_fmov(alloc, sec, ops[0], ops[1], true);
    }

    if (opc == opcode.MOVSS) {
        if (count < 2) { ret err[usize, str]("movss requires 2 operands"); }
        ret encode_fmov(alloc, sec, ops[0], ops[1], false);
    }

    if (opc == opcode.ADDSD) {
        if (count < 2) { ret err[usize, str]("addsd requires 2 operands"); }
        ret encode_fadd(alloc, sec, ops[0], ops[1], true);
    }

    if (opc == opcode.ADDSS) {
        if (count < 2) { ret err[usize, str]("addss requires 2 operands"); }
        ret encode_fadd(alloc, sec, ops[0], ops[1], false);
    }

    if (opc == opcode.SUBSD) {
        if (count < 2) { ret err[usize, str]("subsd requires 2 operands"); }
        ret encode_fsub(alloc, sec, ops[0], ops[1], true);
    }

    if (opc == opcode.SUBSS) {
        if (count < 2) { ret err[usize, str]("subss requires 2 operands"); }
        ret encode_fsub(alloc, sec, ops[0], ops[1], false);
    }

    if (opc == opcode.MULSD) {
        if (count < 2) { ret err[usize, str]("mulsd requires 2 operands"); }
        ret encode_fmul(alloc, sec, ops[0], ops[1], true);
    }

    if (opc == opcode.MULSS) {
        if (count < 2) { ret err[usize, str]("mulss requires 2 operands"); }
        ret encode_fmul(alloc, sec, ops[0], ops[1], false);
    }

    if (opc == opcode.DIVSD) {
        if (count < 2) { ret err[usize, str]("divsd requires 2 operands"); }
        ret encode_fdiv(alloc, sec, ops[0], ops[1], true);
    }

    if (opc == opcode.DIVSS) {
        if (count < 2) { ret err[usize, str]("divss requires 2 operands"); }
        ret encode_fdiv(alloc, sec, ops[0], ops[1], false);
    }

    if (opc == opcode.UCOMISD) {
        if (count < 2) { ret err[usize, str]("ucomisd requires 2 operands"); }
        ret encode_fcmp(alloc, sec, ops[0], ops[1], true, false);
    }

    if (opc == opcode.UCOMISS) {
        if (count < 2) { ret err[usize, str]("ucomiss requires 2 operands"); }
        ret encode_fcmp(alloc, sec, ops[0], ops[1], false, false);
    }

    if (opc == opcode.COMISD) {
        if (count < 2) { ret err[usize, str]("comisd requires 2 operands"); }
        ret encode_fcmp(alloc, sec, ops[0], ops[1], true, true);
    }

    if (opc == opcode.COMISS) {
        if (count < 2) { ret err[usize, str]("comiss requires 2 operands"); }
        ret encode_fcmp(alloc, sec, ops[0], ops[1], false, true);
    }

    # unknown opcode
    ret err[usize, str]("unknown or unsupported opcode");
}
