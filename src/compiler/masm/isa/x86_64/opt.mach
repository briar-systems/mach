# opt.mach: x86_64 peephole optimizer on buffered instructions.
# ---
# runs pattern-matching rules over an InstrBuffer to eliminate redundancy
# before final encoding. operates in a fixed-point loop so that rules
# can enable each other (e.g. push/pop elimination creates a mov,
# which self-move elimination then catches).

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use x86:       mach.compiler.masm.isa.x86_64.opcode;
use x86_buf:   mach.compiler.masm.isa.x86_64.buf;
use operand:   mach.compiler.masm.operand;
use spec:      mach.compiler.masm.isa.spec;

# X86OptContext: peephole optimizer state.
pub rec X86OptContext {
    alloc:      *allocator.Allocator;
    eliminated: i32;
}

# opt_init: create a new optimizer context.
pub fun opt_init(alloc: *allocator.Allocator) X86OptContext {
    var ctx: X86OptContext;
    ctx.alloc = alloc;
    ctx.eliminated = 0;
    ret ctx;
}

# optimize_buffer: run all peephole rules on the instruction buffer.
# iterates until no more changes are made (fixed-point), then compacts.
pub fun optimize_buffer(ctx: *X86OptContext, buf: *x86_buf.InstrBuffer) {
    if (ctx == nil || buf == nil || buf.count == 0) {
        ret;
    }

    var changed: bool = true;
    for (changed) {
        changed = false;

        if (rule_self_move(buf)) { changed = true; }
        if (rule_zero_via_xor(buf)) { changed = true; }
        if (rule_push_pop_pair(buf)) { changed = true; }
        if (rule_redundant_reverse_mov(buf)) { changed = true; }
    }

    x86_buf.buf_compact(buf);
}

# --- peephole rules ---
# each rule returns true if it made any change.

# rule_self_move: eliminate mov rX, rX (register to itself).
fun rule_self_move(buf: *x86_buf.InstrBuffer) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count) {
        val instr: *spec.Instruction = x86_buf.buf_get(buf, i);
        if (instr != nil && instr.opcode == x86.OP_MOV) {
            # both operands must be registers with the same number
            if (instr.dst.kind.tag == operand.OP_REG &&
                instr.src1.kind.tag == operand.OP_REG &&
                instr.dst.reg == instr.src1.reg) {
                x86_buf.buf_mark_nop(buf, i);
                changed = true;
            }
        }
        i = i + 1;
    }
    ret changed;
}

# rule_zero_via_xor: replace mov rX, 0 with xor rX, rX (smaller encoding).
fun rule_zero_via_xor(buf: *x86_buf.InstrBuffer) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count) {
        val instr: *spec.Instruction = x86_buf.buf_get(buf, i);
        if (instr != nil && instr.opcode == x86.OP_MOV) {
            # mov reg, imm(0)
            if (instr.dst.kind.tag == operand.OP_REG &&
                instr.src1.kind.tag == operand.OP_IMM &&
                instr.src1.imm == 0) {
                # replace with xor rX, rX
                val r: i32 = instr.dst.reg;
                val sz: usize = instr.dst.size;
                instr.opcode = x86.XOR;
                instr.dst = operand.reg(r, sz);
                instr.src1 = operand.reg(r, sz);
                instr.src2 = operand.none();
                # xor r32,r32 zero-extends to 64-bit on x86_64 and is smaller
                if (sz == 8) {
                    instr.dst.size = 4;
                    instr.src1.size = 4;
                    instr.size = 4;
                    instr.flags = 0;
                }
                changed = true;
            }
        }
        i = i + 1;
    }
    ret changed;
}

# rule_push_pop_pair: optimize adjacent push/pop pairs.
# push rX; pop rX -> NOP both
# push rX; pop rY -> mov rY, rX
fun rule_push_pop_pair(buf: *x86_buf.InstrBuffer) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count - 1) {
        val a: *spec.Instruction = x86_buf.buf_get(buf, i);
        val b: *spec.Instruction = x86_buf.buf_get(buf, i + 1);

        if (a != nil && b != nil &&
            a.opcode == x86.PUSH && b.opcode == x86.POP &&
            a.dst.kind.tag == operand.OP_REG && b.dst.kind.tag == operand.OP_REG) {

            if (a.dst.reg == b.dst.reg) {
                # push rX; pop rX -> NOP both
                x86_buf.buf_mark_nop(buf, i);
                x86_buf.buf_mark_nop(buf, i + 1);
                changed = true;
            } or {
                # push rX; pop rY -> mov rY, rX
                val src_reg: i32 = a.dst.reg;
                val dst_reg: i32 = b.dst.reg;
                b.opcode = x86.OP_MOV;
                b.dst = operand.reg(dst_reg, 8);
                b.src1 = operand.reg(src_reg, 8);
                b.src2 = operand.none();
                b.size = 8;
                b.flags = spec.FLAG_REX_W;
                x86_buf.buf_mark_nop(buf, i);
                changed = true;
            }
        }
        i = i + 1;
    }
    ret changed;
}

# rule_redundant_reverse_mov: eliminate mov rY, rX after mov rX, rY.
# mov rX, rY; mov rY, rX -> keep first only (second is redundant).
fun rule_redundant_reverse_mov(buf: *x86_buf.InstrBuffer) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count - 1) {
        val a: *spec.Instruction = x86_buf.buf_get(buf, i);
        val b: *spec.Instruction = x86_buf.buf_get(buf, i + 1);

        if (a != nil && b != nil &&
            a.opcode == x86.OP_MOV && b.opcode == x86.OP_MOV &&
            a.dst.kind.tag == operand.OP_REG && a.src1.kind.tag == operand.OP_REG &&
            b.dst.kind.tag == operand.OP_REG && b.src1.kind.tag == operand.OP_REG) {

            # check for reverse pattern: a.dst == b.src1, a.src1 == b.dst
            if (a.dst.reg == b.src1.reg && a.src1.reg == b.dst.reg) {
                x86_buf.buf_mark_nop(buf, i + 1);
                changed = true;
            }
        }
        i = i + 1;
    }
    ret changed;
}
