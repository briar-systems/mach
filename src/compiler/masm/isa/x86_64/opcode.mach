use std.types.bool;
use std.types.size;
use std.types.string;

# mach.compiler.masm.isa.x86_64.opcode: x86-64 instruction opcodes.
# ---
# defines the complete x86-64 instruction set as generic opcodes.
# 
# design philosophy: opcodes represent intent, not encoding details.
# operand types (reg-reg, reg-imm, reg-mem, etc.) are carried by operands,
# not encoded in the opcode name.
#
# examples:
#   mov rax, rbx  -> opcode: MOV, dst: reg(rax), src1: reg(rbx)
#   mov rax, 42   -> opcode: MOV, dst: reg(rax), src1: imm(42)
#   mov rax, [rbx] -> opcode: MOV, dst: reg(rax), src1: mem(rbx, 0)

# register numbers (matching sysv64 ABI)
pub val RAX: i32 = 0;
pub val RCX: i32 = 1;
pub val RDX: i32 = 2;
pub val RBX: i32 = 3;
pub val RSP: i32 = 4;
pub val RBP: i32 = 5;
pub val RSI: i32 = 6;
pub val RDI: i32 = 7;
pub val R8:  i32 = 8;
pub val R9:  i32 = 9;
pub val R10: i32 = 10;
pub val R11: i32 = 11;
pub val R12: i32 = 12;
pub val R13: i32 = 13;
pub val R14: i32 = 14;
pub val R15: i32 = 15;

# xmm register numbers
pub val XMM0:  i32 = 0;
pub val XMM1:  i32 = 1;
pub val XMM2:  i32 = 2;
pub val XMM3:  i32 = 3;
pub val XMM4:  i32 = 4;
pub val XMM5:  i32 = 5;
pub val XMM6:  i32 = 6;
pub val XMM7:  i32 = 7;
pub val XMM8:  i32 = 8;
pub val XMM9:  i32 = 9;
pub val XMM10: i32 = 10;
pub val XMM11: i32 = 11;
pub val XMM12: i32 = 12;
pub val XMM13: i32 = 13;
pub val XMM14: i32 = 14;
pub val XMM15: i32 = 15;

# === instruction opcodes ===

# data movement
pub val OP_NOP:    i32 = 0;   # no operation
pub val OP_MOV:    i32 = 1;   # mov (all variants: rr, ri, rm, mr)
pub val MOVSX:     i32 = 2;   # mov with sign extension
pub val MOVZX:     i32 = 3;   # mov with zero extension
pub val LEA:       i32 = 4;   # load effective address
pub val PUSH:      i32 = 5;   # push
pub val POP:       i32 = 6;   # pop
pub val CWD:       i32 = 7;   # convert word to dword (ax -> dx:ax)
pub val CDQ:       i32 = 8;   # convert dword to qword (eax -> edx:eax)
pub val CQO:       i32 = 9;   # convert qword to oword (rax -> rdx:rax)

# integer arithmetic
pub val ADD:       i32 = 10;  # add
pub val ADC:       i32 = 11;  # add with carry
pub val SUB:       i32 = 12;  # subtract
pub val SBB:       i32 = 13;  # subtract with borrow
pub val INC:       i32 = 14;  # increment
pub val DEC:       i32 = 15;  # decrement
pub val NEG:       i32 = 16;  # negate
pub val MUL:       i32 = 17;  # unsigned multiply
pub val IMUL:      i32 = 18;  # signed multiply (all forms)
pub val DIV:       i32 = 19;  # unsigned divide
pub val IDIV:      i32 = 20;  # signed divide

# bitwise operations
pub val AND:       i32 = 21;  # and
pub val OR:        i32 = 22;  # or
pub val XOR:       i32 = 23;  # xor
pub val NOT:       i32 = 24;  # not
pub val SHL:       i32 = 25;  # shift left
pub val SHR:       i32 = 26;  # shift right (logical)
pub val SAR:       i32 = 27;  # shift right (arithmetic)
pub val ROL:       i32 = 28;  # rotate left
pub val ROR:       i32 = 29;  # rotate right
pub val RCL:       i32 = 30;  # rotate left through carry
pub val RCR:       i32 = 31;  # rotate right through carry
pub val BT:        i32 = 32;  # bit test
pub val BTS:       i32 = 33;  # bit test and set
pub val BTR:       i32 = 34;  # bit test and reset
pub val BTC:       i32 = 35;  # bit test and complement

# comparison and test
pub val CMP:       i32 = 36;  # compare
pub val TEST:      i32 = 37;  # test

# control flow - unconditional
pub val JMP:       i32 = 38;  # jump
pub val CALL:      i32 = 39;  # call
pub val RET:       i32 = 40;  # return
pub val IRET:      i32 = 41;  # interrupt return

# control flow - conditional
pub val JE:        i32 = 42;  # jump if equal / zero
pub val JNE:       i32 = 43;  # jump if not equal / not zero
pub val JL:        i32 = 44;  # jump if less (signed)
pub val JLE:       i32 = 45;  # jump if less or equal (signed)
pub val JG:        i32 = 46;  # jump if greater (signed)
pub val JGE:       i32 = 47;  # jump if greater or equal (signed)
pub val JB:        i32 = 48;  # jump if below (unsigned)
pub val JBE:       i32 = 49;  # jump if below or equal (unsigned)
pub val JA:        i32 = 50;  # jump if above (unsigned)
pub val JAE:       i32 = 51;  # jump if above or equal (unsigned)
pub val JC:        i32 = 52;  # jump if carry
pub val JNC:       i32 = 53;  # jump if not carry
pub val JO:        i32 = 54;  # jump if overflow
pub val JNO:       i32 = 55;  # jump if not overflow
pub val JS:        i32 = 56;  # jump if sign
pub val JNS:       i32 = 57;  # jump if not sign
pub val JPO:       i32 = 58;  # jump if parity odd
pub val JPE:       i32 = 59;  # jump if parity even
pub val JCXZ:      i32 = 60;  # jump if cx zero
pub val JECXZ:     i32 = 61;  # jump if ecx zero
pub val JRCXZ:     i32 = 62;  # jump if rcx zero

# setcc instructions (set byte on condition)
pub val SETE:      i32 = 63;  # set if equal
pub val SETNE:     i32 = 64;  # set if not equal
pub val SETL:      i32 = 65;  # set if less (signed)
pub val SETLE:     i32 = 66;  # set if less or equal (signed)
pub val SETG:      i32 = 67;  # set if greater (signed)
pub val SETGE:     i32 = 68;  # set if greater or equal (signed)
pub val SETB:      i32 = 69;  # set if below (unsigned)
pub val SETBE:     i32 = 70;  # set if below or equal (unsigned)
pub val SETA:      i32 = 71;  # set if above (unsigned)
pub val SETAE:     i32 = 72;  # set if above or equal (unsigned)
pub val SETC:      i32 = 73;  # set if carry
pub val SETNC:     i32 = 74;  # set if not carry
pub val SETO:      i32 = 75;  # set if overflow
pub val SETNO:     i32 = 76;  # set if not overflow
pub val SETS:      i32 = 77;  # set if sign
pub val SETNS:     i32 = 78;  # set if not sign
pub val SETP:      i32 = 79;  # set if parity
pub val SETNP:     i32 = 80;  # set if not parity

# cmovcc instructions (conditional move)
pub val CMOVE:     i32 = 81;  # conditional move if equal
pub val CMOVNE:    i32 = 82;  # conditional move if not equal
pub val CMOVL:     i32 = 83;  # conditional move if less
pub val CMOVLE:    i32 = 84;  # conditional move if less or equal
pub val CMOVG:     i32 = 85;  # conditional move if greater
pub val CMOVGE:    i32 = 86;  # conditional move if greater or equal
pub val CMOVB:     i32 = 87;  # conditional move if below
pub val CMOVBE:    i32 = 88;  # conditional move if below or equal
pub val CMOVA:     i32 = 89;  # conditional move if above
pub val CMOVAE:    i32 = 90;  # conditional move if above or equal

# floating point - data movement
pub val MOVSS:     i32 = 91;  # move scalar single
pub val MOVSD:     i32 = 92;  # move scalar double
pub val MOVAPS:    i32 = 93;  # move aligned packed single
pub val MOVAPD:    i32 = 94;  # move aligned packed double
pub val MOVD:      i32 = 95;  # move dword/quadword from gpr to xmm
pub val MOVQ:      i32 = 96;  # move quadword

# floating point - arithmetic
pub val ADDSS:     i32 = 97;  # add scalar single
pub val ADDSD:     i32 = 98;  # add scalar double
pub val SUBSS:     i32 = 99;  # subtract scalar single
pub val SUBSD:     i32 = 100; # subtract scalar double
pub val MULSS:     i32 = 101; # multiply scalar single
pub val MULSD:     i32 = 102; # multiply scalar double
pub val DIVSS:     i32 = 103; # divide scalar single
pub val DIVSD:     i32 = 104; # divide scalar double
pub val SQRTSS:    i32 = 105; # square root scalar single
pub val SQRTSD:    i32 = 106; # square root scalar double
pub val MINSS:     i32 = 107; # minimum scalar single
pub val MINSD:     i32 = 108; # minimum scalar double
pub val MAXSS:     i32 = 109; # maximum scalar single
pub val MAXSD:     i32 = 110; # maximum scalar double

# floating point - comparison
pub val COMISS:    i32 = 111; # compare scalar single (ordered)
pub val COMISD:    i32 = 112; # compare scalar double (ordered)
pub val UCOMISS:   i32 = 113; # unordered compare scalar single
pub val UCOMISD:   i32 = 114; # unordered compare scalar double

# floating point - conversion
pub val CVTSI2SS:  i32 = 115; # convert signed integer to scalar single
pub val CVTSI2SD:  i32 = 116; # convert signed integer to scalar double
pub val CVTSS2SI:  i32 = 117; # convert scalar single to signed integer
pub val CVTSD2SI:  i32 = 118; # convert scalar double to signed integer
pub val CVTTSS2SI: i32 = 119; # truncate scalar single to signed integer
pub val CVTTSD2SI: i32 = 120; # truncate scalar double to signed integer
pub val CVTSS2SD:  i32 = 121; # convert scalar single to scalar double
pub val CVTSD2SS:  i32 = 122; # convert scalar double to scalar single

# system instructions
pub val SYSCALL:   i32 = 123; # system call
pub val SYSRET:    i32 = 124; # system return
pub val INT:       i32 = 125; # software interrupt
pub val INTO:      i32 = 126; # interrupt on overflow
pub val IRETD:     i32 = 127; # interrupt return (32-bit)
pub val IRETQ:     i32 = 128; # interrupt return (64-bit)
pub val CLI:       i32 = 129; # clear interrupt flag
pub val STI:       i32 = 130; # set interrupt flag
pub val HLT:       i32 = 131; # halt
pub val PAUSE:     i32 = 132; # pause (spin loop hint)
pub val CPUID:     i32 = 133; # cpu identification
pub val RDTSC:     i32 = 134; # read time-stamp counter
pub val RDTSCP:    i32 = 135; # read time-stamp counter and processor id
pub val RDMSR:     i32 = 136; # read model-specific register
pub val WRMSR:     i32 = 137; # write model-specific register
pub val XGETBV:    i32 = 138; # get extended control register
pub val XSETBV:    i32 = 139; # set extended control register

# atomic/memory operations
pub val XCHG:      i32 = 140; # exchange
pub val CMPXCHG:   i32 = 141; # compare and exchange
pub val CMPXCHG8B: i32 = 142; # compare and exchange 8 bytes
pub val CMPXCHG16B: i32 = 143; # compare and exchange 16 bytes
pub val XADD:      i32 = 144; # exchange and add

# string operations
pub val MOVS:      i32 = 145; # move string
pub val STOS:      i32 = 146; # store string
pub val LODS:      i32 = 147; # load string
pub val SCAS:      i32 = 148; # scan string
pub val CMPS:      i32 = 149; # compare string

# misc
pub val BSWAP:     i32 = 150; # byte swap
pub val BSF:       i32 = 151; # bit scan forward
pub val BSR:       i32 = 152; # bit scan reverse
pub val TZCNT:     i32 = 153; # count trailing zeros
pub val LZCNT:     i32 = 154; # count leading zeros
pub val POPCNT:    i32 = 155; # population count

# synchronization
pub val LFENCE:    i32 = 156; # load fence
pub val SFENCE:    i32 = 157; # store fence
pub val MFENCE:    i32 = 158; # memory fence

# extensions / special
pub val ENDBR64:   i32 = 159; # end branch 64 (CET)
pub val PREFIX_LOCK: i32 = 160; # lock prefix (for atomic ops)
pub val PREFIX_REP:  i32 = 161; # rep prefix
pub val PREFIX_REPE: i32 = 162; # repe/repz prefix
pub val PREFIX_REPNE: i32 = 163; # repne/repnz prefix

# === instruction count ===
pub val OPCODE_COUNT: i32 = 164;

# === opcode metadata ===

# instruction category for organization/debugging
pub val CAT_DATA_MOV:    u8 = 0;
pub val CAT_ARITHMETIC:  u8 = 1;
pub val CAT_BITWISE:     u8 = 2;
pub val CAT_COMPARE:     u8 = 3;
pub val CAT_CONTROL:     u8 = 4;
pub val CAT_FLOAT:       u8 = 5;
pub val CAT_SYSTEM:      u8 = 6;
pub val CAT_ATOMIC:      u8 = 7;
pub val CAT_MISC:        u8 = 8;

# opcode info record
pub rec OpcodeInfo {
    name:     str;
    category: u8;
    has_modrm: bool;   # uses modr/m byte
    has_imm:   bool;   # has immediate operand
    imm_size:  usize;   # immediate size (0, 1, 2, 4, 8)
}

# get_opcode_name: get the name string for an opcode.
# ---
# opcode: the opcode value
# ret:    the name string
pub fun get_name(opcode: i32) str {
    # data movement
    if (opcode == OP_NOP)    { ret "nop"; }
    if (opcode == OP_MOV)    { ret "mov"; }
    if (opcode == MOVSX)     { ret "movsx"; }
    if (opcode == MOVZX)     { ret "movzx"; }
    if (opcode == LEA)       { ret "lea"; }
    if (opcode == PUSH)      { ret "push"; }
    if (opcode == POP)       { ret "pop"; }
    if (opcode == CWD)       { ret "cwd"; }
    if (opcode == CDQ)       { ret "cdq"; }
    if (opcode == CQO)       { ret "cqo"; }
    
    # arithmetic
    if (opcode == ADD)       { ret "add"; }
    if (opcode == ADC)       { ret "adc"; }
    if (opcode == SUB)       { ret "sub"; }
    if (opcode == SBB)       { ret "sbb"; }
    if (opcode == INC)       { ret "inc"; }
    if (opcode == DEC)       { ret "dec"; }
    if (opcode == NEG)       { ret "neg"; }
    if (opcode == MUL)       { ret "mul"; }
    if (opcode == IMUL)      { ret "imul"; }
    if (opcode == DIV)       { ret "div"; }
    if (opcode == IDIV)      { ret "idiv"; }
    
    # bitwise
    if (opcode == AND)       { ret "and"; }
    if (opcode == OR)        { ret "or"; }
    if (opcode == XOR)       { ret "xor"; }
    if (opcode == NOT)       { ret "not"; }
    if (opcode == SHL)       { ret "shl"; }
    if (opcode == SHR)       { ret "shr"; }
    if (opcode == SAR)       { ret "sar"; }
    if (opcode == ROL)       { ret "rol"; }
    if (opcode == ROR)       { ret "ror"; }
    if (opcode == RCL)       { ret "rcl"; }
    if (opcode == RCR)       { ret "rcr"; }
    if (opcode == BT)        { ret "bt"; }
    if (opcode == BTS)       { ret "bts"; }
    if (opcode == BTR)       { ret "btr"; }
    if (opcode == BTC)       { ret "btc"; }
    
    # comparison
    if (opcode == CMP)       { ret "cmp"; }
    if (opcode == TEST)      { ret "test"; }
    
    # control flow
    if (opcode == JMP)       { ret "jmp"; }
    if (opcode == CALL)      { ret "call"; }
    if (opcode == RET)       { ret "ret"; }
    if (opcode == IRET)      { ret "iret"; }
    if (opcode == JE)        { ret "je"; }
    if (opcode == JNE)       { ret "jne"; }
    if (opcode == JL)        { ret "jl"; }
    if (opcode == JLE)       { ret "jle"; }
    if (opcode == JG)        { ret "jg"; }
    if (opcode == JGE)       { ret "jge"; }
    if (opcode == JB)        { ret "jb"; }
    if (opcode == JBE)       { ret "jbe"; }
    if (opcode == JA)        { ret "ja"; }
    if (opcode == JAE)       { ret "jae"; }
    if (opcode == JC)        { ret "jc"; }
    if (opcode == JNC)       { ret "jnc"; }
    if (opcode == JO)        { ret "jo"; }
    if (opcode == JNO)       { ret "jno"; }
    if (opcode == JS)        { ret "js"; }
    if (opcode == JNS)       { ret "jns"; }
    if (opcode == JPO)       { ret "jpo"; }
    if (opcode == JPE)       { ret "jpe"; }
    if (opcode == JCXZ)      { ret "jcxz"; }
    if (opcode == JECXZ)     { ret "jecxz"; }
    if (opcode == JRCXZ)     { ret "jrcxz"; }
    
    # setcc
    if (opcode == SETE)      { ret "sete"; }
    if (opcode == SETNE)     { ret "setne"; }
    if (opcode == SETL)      { ret "setl"; }
    if (opcode == SETLE)     { ret "setle"; }
    if (opcode == SETG)      { ret "setg"; }
    if (opcode == SETGE)     { ret "setge"; }
    if (opcode == SETB)      { ret "setb"; }
    if (opcode == SETBE)     { ret "setbe"; }
    if (opcode == SETA)      { ret "seta"; }
    if (opcode == SETAE)     { ret "setae"; }
    if (opcode == SETC)      { ret "setc"; }
    if (opcode == SETNC)     { ret "setnc"; }
    if (opcode == SETO)      { ret "seto"; }
    if (opcode == SETNO)     { ret "setno"; }
    if (opcode == SETS)      { ret "sets"; }
    if (opcode == SETNS)     { ret "setns"; }
    if (opcode == SETP)      { ret "setp"; }
    if (opcode == SETNP)     { ret "setnp"; }
    
    # cmovcc
    if (opcode == CMOVE)     { ret "cmove"; }
    if (opcode == CMOVNE)    { ret "cmovne"; }
    if (opcode == CMOVL)     { ret "cmovl"; }
    if (opcode == CMOVLE)    { ret "cmovle"; }
    if (opcode == CMOVG)     { ret "cmovg"; }
    if (opcode == CMOVGE)    { ret "cmovge"; }
    if (opcode == CMOVB)     { ret "cmovb"; }
    if (opcode == CMOVBE)    { ret "cmovbe"; }
    if (opcode == CMOVA)     { ret "cmova"; }
    if (opcode == CMOVAE)    { ret "cmovae"; }
    
    # floating point
    if (opcode == MOVSS)     { ret "movss"; }
    if (opcode == MOVSD)     { ret "movsd"; }
    if (opcode == MOVAPS)    { ret "movaps"; }
    if (opcode == MOVAPD)    { ret "movapd"; }
    if (opcode == MOVD)      { ret "movd"; }
    if (opcode == MOVQ)      { ret "movq"; }
    if (opcode == ADDSS)     { ret "addss"; }
    if (opcode == ADDSD)     { ret "addsd"; }
    if (opcode == SUBSS)     { ret "subss"; }
    if (opcode == SUBSD)     { ret "subsd"; }
    if (opcode == MULSS)     { ret "mulss"; }
    if (opcode == MULSD)     { ret "mulsd"; }
    if (opcode == DIVSS)     { ret "divss"; }
    if (opcode == DIVSD)     { ret "divsd"; }
    if (opcode == SQRTSS)    { ret "sqrtss"; }
    if (opcode == SQRTSD)    { ret "sqrtsd"; }
    if (opcode == MINSS)     { ret "minss"; }
    if (opcode == MINSD)     { ret "minsd"; }
    if (opcode == MAXSS)     { ret "maxss"; }
    if (opcode == MAXSD)     { ret "maxsd"; }
    if (opcode == COMISS)    { ret "comiss"; }
    if (opcode == COMISD)    { ret "comisd"; }
    if (opcode == UCOMISS)   { ret "ucomiss"; }
    if (opcode == UCOMISD)   { ret "ucomisd"; }
    if (opcode == CVTSI2SS)  { ret "cvtsi2ss"; }
    if (opcode == CVTSI2SD)  { ret "cvtsi2sd"; }
    if (opcode == CVTSS2SI)  { ret "cvtss2si"; }
    if (opcode == CVTSD2SI)  { ret "cvtsd2si"; }
    if (opcode == CVTTSS2SI) { ret "cvttss2si"; }
    if (opcode == CVTTSD2SI) { ret "cvttsd2si"; }
    if (opcode == CVTSS2SD)  { ret "cvtss2sd"; }
    if (opcode == CVTSD2SS)  { ret "cvtsd2ss"; }
    
    # system
    if (opcode == SYSCALL)   { ret "syscall"; }
    if (opcode == SYSRET)    { ret "sysret"; }
    if (opcode == INT)       { ret "int"; }
    if (opcode == INTO)      { ret "into"; }
    if (opcode == IRETD)     { ret "iretd"; }
    if (opcode == IRETQ)     { ret "iretq"; }
    if (opcode == CLI)       { ret "cli"; }
    if (opcode == STI)       { ret "sti"; }
    if (opcode == HLT)       { ret "hlt"; }
    if (opcode == PAUSE)     { ret "pause"; }
    if (opcode == CPUID)     { ret "cpuid"; }
    if (opcode == RDTSC)     { ret "rdtsc"; }
    if (opcode == RDTSCP)    { ret "rdtscp"; }
    if (opcode == RDMSR)     { ret "rdmsr"; }
    if (opcode == WRMSR)     { ret "wrmsr"; }
    if (opcode == XGETBV)    { ret "xgetbv"; }
    if (opcode == XSETBV)    { ret "xsetbv"; }
    
    # atomic
    if (opcode == XCHG)      { ret "xchg"; }
    if (opcode == CMPXCHG)   { ret "cmpxchg"; }
    if (opcode == CMPXCHG8B) { ret "cmpxchg8b"; }
    if (opcode == CMPXCHG16B) { ret "cmpxchg16b"; }
    if (opcode == XADD)      { ret "xadd"; }
    
    # string
    if (opcode == MOVS)      { ret "movs"; }
    if (opcode == STOS)      { ret "stos"; }
    if (opcode == LODS)      { ret "lods"; }
    if (opcode == SCAS)      { ret "scas"; }
    if (opcode == CMPS)      { ret "cmps"; }
    
    # misc
    if (opcode == BSWAP)     { ret "bswap"; }
    if (opcode == BSF)       { ret "bsf"; }
    if (opcode == BSR)       { ret "bsr"; }
    if (opcode == TZCNT)     { ret "tzcnt"; }
    if (opcode == LZCNT)     { ret "lzcnt"; }
    if (opcode == POPCNT)    { ret "popcnt"; }
    
    # fences
    if (opcode == LFENCE)    { ret "lfence"; }
    if (opcode == SFENCE)    { ret "sfence"; }
    if (opcode == MFENCE)    { ret "mfence"; }
    
    # cet
    if (opcode == ENDBR64)   { ret "endbr64"; }
    
    # prefixes
    if (opcode == PREFIX_LOCK)  { ret "lock"; }
    if (opcode == PREFIX_REP)   { ret "rep"; }
    if (opcode == PREFIX_REPE)  { ret "repe"; }
    if (opcode == PREFIX_REPNE) { ret "repne"; }
    
    ret "unknown";
}

# get_category: get the instruction category for an opcode.
# ---
# opcode: the opcode value
# ret:    the category
pub fun get_category(opcode: i32) u8 {
    # data movement
    if (opcode >= OP_NOP && opcode <= CQO) {
        ret CAT_DATA_MOV;
    }
    
    # arithmetic
    if (opcode >= ADD && opcode <= IDIV) {
        ret CAT_ARITHMETIC;
    }
    
    # bitwise
    if (opcode >= AND && opcode <= BTC) {
        ret CAT_BITWISE;
    }
    
    # comparison
    if (opcode >= CMP && opcode <= SETNP) {
        ret CAT_COMPARE;
    }
    
    # control flow
    if (opcode >= CMOVE && opcode <= JRCXZ) {
        ret CAT_CONTROL;
    }
    
    # floating point
    if (opcode >= MOVSS && opcode <= CVTSD2SS) {
        ret CAT_FLOAT;
    }
    
    # system
    if (opcode >= SYSCALL && opcode <= XSETBV) {
        ret CAT_SYSTEM;
    }
    
    # atomic
    if (opcode >= XCHG && opcode <= XADD) {
        ret CAT_ATOMIC;
    }
    
    # string
    if (opcode >= MOVS && opcode <= CMPS) {
        ret CAT_MISC;
    }
    
    # misc + fences + cet + prefixes
    ret CAT_MISC;
}
