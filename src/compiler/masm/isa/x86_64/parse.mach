use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use op:       mach.compiler.masm.isa.x86_64.opcode;
use operand:  mach.compiler.masm.operand;
use spec:     mach.compiler.masm.isa.spec;

# mach.compiler.masm.isa.x86_64.parse: x86-64 inline assembly parser.
# ---
# parses intel syntax inline assembly and emits instruction records.
# creates spec.Instruction objects with opcodes and operands (not bytes).

# InstructionArray: holds the result of parsing (pointer + count).
# ---
# data: pointer to allocated instructions
# len:  number of instructions
pub rec InstructionArray {
    data: *spec.Instruction;
    len:  usize;
}

# empty_array: create an empty instruction array.
# ---
# ret: empty array
pub fun empty_array() InstructionArray {
    var arr: InstructionArray;
    arr.data = nil;
    arr.len = 0;
    ret arr;
}

# ParseContext: holds parsing state and results.
rec ParseContext {
    content:     str;
    pos:         usize;
    instructions: *spec.Instruction;
    count:       usize;
    capacity:    usize;
    alloc:       *allocator.Allocator;
}

# init_context: initialize a parse context.
fun init_context(ctx: *ParseContext, content: str, alloc: *allocator.Allocator) bool {
    if (ctx == nil || alloc == nil) {
        ret false;
    }
    ctx.content = content;
    ctx.pos = 0;
    ctx.count = 0;
    ctx.capacity = 16;
    ctx.alloc = alloc;

    val r: Result[*spec.Instruction, allocator.AllocError] = allocator.allocator_alloc[spec.Instruction](alloc, ctx.capacity);
    if (result_is_err[*spec.Instruction, allocator.AllocError](r)) {
        ret false;
    }
    ctx.instructions = result_unwrap_ok[*spec.Instruction, allocator.AllocError](r);
    ret true;
}

# grow_instructions: grow the instructions array if needed.
fun grow_instructions(ctx: *ParseContext) bool {
    if (ctx == nil) {
        ret false;
    }
    if (ctx.count < ctx.capacity) {
        ret true;
    }

    val new_cap: usize = ctx.capacity * 2;
    val r: Result[*spec.Instruction, allocator.AllocError] = allocator.allocator_resize[spec.Instruction](
        ctx.alloc, ctx.instructions, ctx.capacity, new_cap
    );
    if (result_is_err[*spec.Instruction, allocator.AllocError](r)) {
        ret false;
    }
    ctx.instructions = result_unwrap_ok[*spec.Instruction, allocator.AllocError](r);
    ctx.capacity = new_cap;
    ret true;
}

# add_instruction: add an instruction to the context.
fun add_instruction(ctx: *ParseContext, instr: spec.Instruction) bool {
    if (ctx == nil) {
        ret false;
    }
    if (!grow_instructions(ctx)) {
        ret false;
    }
    ctx.instructions[ctx.count] = instr;
    ctx.count = ctx.count + 1;
    ret true;
}

# is_digit: check if character is a digit.
fun is_digit(c: u8) bool {
    ret c >= '0' && c <= '9';
}

# is_alpha: check if character is alphabetic.
fun is_alpha(c: u8) bool {
    ret (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_';
}

# is_alnum: check if character is alphanumeric.
fun is_alnum(c: u8) bool {
    ret is_alpha(c) || is_digit(c);
}

# is_whitespace: check if character is whitespace.
fun is_whitespace(c: u8) bool {
    ret c == ' ' || c == '\t' || c == '\n' || c == '\r';
}

# skip_whitespace: skip whitespace characters.
fun skip_whitespace(ctx: *ParseContext) {
    if (ctx == nil) {
        ret;
    }
    val len: usize = str_len(ctx.content);
    for (ctx.pos < len && is_whitespace(ctx.content[ctx.pos])) {
        ctx.pos = ctx.pos + 1;
    }
}

# parse_int: parse an integer from current position.
fun parse_int(ctx: *ParseContext) i64 {
    if (ctx == nil) {
        ret 0;
    }

    val len: usize = str_len(ctx.content);
    var neg: bool = false;
    var result: i64 = 0;

    # check for negative
    if (ctx.pos < len && ctx.content[ctx.pos] == '-') {
        neg = true;
        ctx.pos = ctx.pos + 1;
    }

    # parse digits
    for (ctx.pos < len && is_digit(ctx.content[ctx.pos])) {
        result = result * 10 + (ctx.content[ctx.pos] - '0')::i64;
        ctx.pos = ctx.pos + 1;
    }

    if (neg) {
        ret -result;
    }
    ret result;
}

# extract_word: extract a word (identifier) from current position.
fun extract_word(ctx: *ParseContext) str {
    if (ctx == nil) {
        ret nil;
    }

    val start: usize = ctx.pos;
    val len: usize = str_len(ctx.content);

    for (ctx.pos < len && is_alnum(ctx.content[ctx.pos])) {
        ctx.pos = ctx.pos + 1;
    }

    val word_len: usize = ctx.pos - start;
    if (word_len == 0) {
        ret nil;
    }

    # allocate and copy
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](ctx.alloc, word_len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) {
        ret nil;
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    var i: usize = 0;
    for (i < word_len) {
        buf[i] = ctx.content[start + i];
        i = i + 1;
    }
    buf[word_len] = 0;
    ret buf::str;
}

# parse_reg: parse a register name and return operand.
fun parse_reg(name: str) operand.Operand {
    if (name == nil) {
        ret operand.none();
    }

    # 64-bit registers
    if (str_equals(name, "rax")) { ret operand.reg(op.RAX, 8); }
    if (str_equals(name, "rbx")) { ret operand.reg(op.RBX, 8); }
    if (str_equals(name, "rcx")) { ret operand.reg(op.RCX, 8); }
    if (str_equals(name, "rdx")) { ret operand.reg(op.RDX, 8); }
    if (str_equals(name, "rsi")) { ret operand.reg(op.RSI, 8); }
    if (str_equals(name, "rdi")) { ret operand.reg(op.RDI, 8); }
    if (str_equals(name, "rbp")) { ret operand.reg(op.RBP, 8); }
    if (str_equals(name, "rsp")) { ret operand.reg(op.RSP, 8); }
    if (str_equals(name, "r8"))  { ret operand.reg(op.R8, 8); }
    if (str_equals(name, "r9"))  { ret operand.reg(op.R9, 8); }
    if (str_equals(name, "r10")) { ret operand.reg(op.R10, 8); }
    if (str_equals(name, "r11")) { ret operand.reg(op.R11, 8); }
    if (str_equals(name, "r12")) { ret operand.reg(op.R12, 8); }
    if (str_equals(name, "r13")) { ret operand.reg(op.R13, 8); }
    if (str_equals(name, "r14")) { ret operand.reg(op.R14, 8); }
    if (str_equals(name, "r15")) { ret operand.reg(op.R15, 8); }

    # 32-bit registers
    if (str_equals(name, "eax")) { ret operand.reg(op.RAX, 4); }
    if (str_equals(name, "ebx")) { ret operand.reg(op.RBX, 4); }
    if (str_equals(name, "ecx")) { ret operand.reg(op.RCX, 4); }
    if (str_equals(name, "edx")) { ret operand.reg(op.RDX, 4); }
    if (str_equals(name, "esi")) { ret operand.reg(op.RSI, 4); }
    if (str_equals(name, "edi")) { ret operand.reg(op.RDI, 4); }
    if (str_equals(name, "ebp")) { ret operand.reg(op.RBP, 4); }
    if (str_equals(name, "esp")) { ret operand.reg(op.RSP, 4); }
    if (str_equals(name, "r8d"))  { ret operand.reg(op.R8, 4); }
    if (str_equals(name, "r9d"))  { ret operand.reg(op.R9, 4); }
    if (str_equals(name, "r10d")) { ret operand.reg(op.R10, 4); }
    if (str_equals(name, "r11d")) { ret operand.reg(op.R11, 4); }
    if (str_equals(name, "r12d")) { ret operand.reg(op.R12, 4); }
    if (str_equals(name, "r13d")) { ret operand.reg(op.R13, 4); }
    if (str_equals(name, "r14d")) { ret operand.reg(op.R14, 4); }
    if (str_equals(name, "r15d")) { ret operand.reg(op.R15, 4); }

    # 16-bit registers
    if (str_equals(name, "ax")) { ret operand.reg(op.RAX, 2); }
    if (str_equals(name, "bx")) { ret operand.reg(op.RBX, 2); }
    if (str_equals(name, "cx")) { ret operand.reg(op.RCX, 2); }
    if (str_equals(name, "dx")) { ret operand.reg(op.RDX, 2); }
    if (str_equals(name, "si")) { ret operand.reg(op.RSI, 2); }
    if (str_equals(name, "di")) { ret operand.reg(op.RDI, 2); }
    if (str_equals(name, "bp")) { ret operand.reg(op.RBP, 2); }
    if (str_equals(name, "sp")) { ret operand.reg(op.RSP, 2); }
    if (str_equals(name, "r8w"))  { ret operand.reg(op.R8, 2); }
    if (str_equals(name, "r9w"))  { ret operand.reg(op.R9, 2); }
    if (str_equals(name, "r10w")) { ret operand.reg(op.R10, 2); }
    if (str_equals(name, "r11w")) { ret operand.reg(op.R11, 2); }
    if (str_equals(name, "r12w")) { ret operand.reg(op.R12, 2); }
    if (str_equals(name, "r13w")) { ret operand.reg(op.R13, 2); }
    if (str_equals(name, "r14w")) { ret operand.reg(op.R14, 2); }
    if (str_equals(name, "r15w")) { ret operand.reg(op.R15, 2); }

    # 8-bit registers (low)
    if (str_equals(name, "al")) { ret operand.reg(op.RAX, 1); }
    if (str_equals(name, "bl")) { ret operand.reg(op.RBX, 1); }
    if (str_equals(name, "cl")) { ret operand.reg(op.RCX, 1); }
    if (str_equals(name, "dl")) { ret operand.reg(op.RDX, 1); }
    if (str_equals(name, "sil")) { ret operand.reg(op.RSI, 1); }
    if (str_equals(name, "dil")) { ret operand.reg(op.RDI, 1); }
    if (str_equals(name, "bpl")) { ret operand.reg(op.RBP, 1); }
    if (str_equals(name, "spl")) { ret operand.reg(op.RSP, 1); }
    if (str_equals(name, "r8b"))  { ret operand.reg(op.R8, 1); }
    if (str_equals(name, "r9b"))  { ret operand.reg(op.R9, 1); }
    if (str_equals(name, "r10b")) { ret operand.reg(op.R10, 1); }
    if (str_equals(name, "r11b")) { ret operand.reg(op.R11, 1); }
    if (str_equals(name, "r12b")) { ret operand.reg(op.R12, 1); }
    if (str_equals(name, "r13b")) { ret operand.reg(op.R13, 1); }
    if (str_equals(name, "r14b")) { ret operand.reg(op.R14, 1); }
    if (str_equals(name, "r15b")) { ret operand.reg(op.R15, 1); }

    # xmm registers
    if (str_equals(name, "xmm0"))  { ret operand.reg(op.XMM0, 16); }
    if (str_equals(name, "xmm1"))  { ret operand.reg(op.XMM1, 16); }
    if (str_equals(name, "xmm2"))  { ret operand.reg(op.XMM2, 16); }
    if (str_equals(name, "xmm3"))  { ret operand.reg(op.XMM3, 16); }
    if (str_equals(name, "xmm4"))  { ret operand.reg(op.XMM4, 16); }
    if (str_equals(name, "xmm5"))  { ret operand.reg(op.XMM5, 16); }
    if (str_equals(name, "xmm6"))  { ret operand.reg(op.XMM6, 16); }
    if (str_equals(name, "xmm7"))  { ret operand.reg(op.XMM7, 16); }
    if (str_equals(name, "xmm8"))  { ret operand.reg(op.XMM8, 16); }
    if (str_equals(name, "xmm9"))  { ret operand.reg(op.XMM9, 16); }
    if (str_equals(name, "xmm10")) { ret operand.reg(op.XMM10, 16); }
    if (str_equals(name, "xmm11")) { ret operand.reg(op.XMM11, 16); }
    if (str_equals(name, "xmm12")) { ret operand.reg(op.XMM12, 16); }
    if (str_equals(name, "xmm13")) { ret operand.reg(op.XMM13, 16); }
    if (str_equals(name, "xmm14")) { ret operand.reg(op.XMM14, 16); }
    if (str_equals(name, "xmm15")) { ret operand.reg(op.XMM15, 16); }

    ret operand.none();
}

# parse_operand: parse an operand (register, immediate, memory, or label).
fun parse_operand(ctx: *ParseContext) operand.Operand {
    if (ctx == nil) {
        ret operand.none();
    }

    skip_whitespace(ctx);

    val len: usize = str_len(ctx.content);
    if (ctx.pos >= len) {
        ret operand.none();
    }

    # check for memory operand [base+disp] or [base]
    if (ctx.content[ctx.pos] == '[') {
        ctx.pos = ctx.pos + 1;
        skip_whitespace(ctx);

        # parse base register
        val base_word: str = extract_word(ctx);
        if (base_word == nil) {
            ret operand.none();
        }

        val base_op: operand.Operand = parse_reg(base_word);
        if (!operand.operand_is_reg(?base_op)) {
            ret operand.none();
        }

        skip_whitespace(ctx);

        var disp: i64 = 0;

        # check for +/- displacement
        if (ctx.pos < len && (ctx.content[ctx.pos] == '+' || ctx.content[ctx.pos] == '-')) {
            val neg: bool = ctx.content[ctx.pos] == '-';
            ctx.pos = ctx.pos + 1;
            skip_whitespace(ctx);

            # parse displacement number
            var disp_val: i64 = 0;
            for (ctx.pos < len && is_digit(ctx.content[ctx.pos])) {
                disp_val = disp_val * 10 + (ctx.content[ctx.pos] - '0')::i64;
                ctx.pos = ctx.pos + 1;
            }
            disp = disp_val;
            if (neg) {
                disp = -disp;
            }
        }

        skip_whitespace(ctx);
        if (ctx.pos >= len || ctx.content[ctx.pos] != ']') {
            ret operand.none();
        }
        ctx.pos = ctx.pos + 1;

        # default to 8 bytes
        ret operand.mem(base_op.reg, disp, 8);
    }

    # check for immediate (number or hex)
    if (is_digit(ctx.content[ctx.pos]) || (ctx.content[ctx.pos] == '-' && (ctx.pos + 1 < len) && is_digit(ctx.content[ctx.pos + 1]))) {
        val imm_val: i64 = parse_int(ctx);
        ret operand.imm(imm_val, 8);
    }

    # check for hex immediate
    if (ctx.content[ctx.pos] == '0' && (ctx.pos + 1 < len) && (ctx.content[ctx.pos + 1] == 'x' || ctx.content[ctx.pos + 1] == 'X')) {
        ctx.pos = ctx.pos + 2;
        var hex_val: i64 = 0;
        for (ctx.pos < len) {
            val c: u8 = ctx.content[ctx.pos];
            if (c >= '0' && c <= '9') {
                hex_val = hex_val * 16 + (c - '0')::i64;
            } or (c >= 'a' && c <= 'f') {
                hex_val = hex_val * 16 + (c - 'a' + 10)::i64;
            } or (c >= 'A' && c <= 'F') {
                hex_val = hex_val * 16 + (c - 'A' + 10)::i64;
            } or {
                brk;
            }
            ctx.pos = ctx.pos + 1;
        }
        ret operand.imm(hex_val, 8);
    }

    # try register or label
    val word: str = extract_word(ctx);
    if (word == nil) {
        ret operand.none();
    }

    val reg_op: operand.Operand = parse_reg(word);
    if (operand.operand_is_reg(?reg_op)) {
        ret reg_op;
    }

    # must be a label
    ret operand.label(word);
}

# create_instruction: create an instruction record.
fun create_instruction(opcode: i32, dst: operand.Operand, src1: operand.Operand, src2: operand.Operand, size: usize) spec.Instruction {
    var instr: spec.Instruction;
    instr.opcode = opcode;
    instr.dst = dst;
    instr.src1 = src1;
    instr.src2 = src2;
    instr.size = size;
    instr.flags = 0;
    if (size == 8) {
        instr.flags = spec.FLAG_REX_W;
    }
    ret instr;
}

# parse_simple_instr: parse instructions with no operands.
fun parse_simple_instr(ctx: *ParseContext, opcode: i32) bool {
    val instr: spec.Instruction = create_instruction(opcode, operand.none(), operand.none(), operand.none(), 0);
    ret add_instruction(ctx, instr);
}

# parse_unary_instr: parse instructions with one operand.
fun parse_unary_instr(ctx: *ParseContext, opcode: i32, lineEnd: usize) bool {
    val op1: operand.Operand = parse_operand(ctx);
    var size: usize = op1.size;
    if (size == 0) {
        size = 8;
    }
    val instr: spec.Instruction = create_instruction(opcode, op1, operand.none(), operand.none(), size);
    ret add_instruction(ctx, instr);
}

# parse_binary_instr: parse instructions with two operands.
fun parse_binary_instr(ctx: *ParseContext, opcode: i32, lineEnd: usize) bool {
    val dst: operand.Operand = parse_operand(ctx);
    skip_whitespace(ctx);

    if (ctx.pos < lineEnd && ctx.content[ctx.pos] == ',') {
        ctx.pos = ctx.pos + 1;
    }
    skip_whitespace(ctx);

    val src: operand.Operand = parse_operand(ctx);
    var size: usize = dst.size;
    if (size == 0) {
        size = src.size;
    }
    if (size == 0) {
        size = 8;
    }

    val instr: spec.Instruction = create_instruction(opcode, dst, src, operand.none(), size);
    ret add_instruction(ctx, instr);
}

# handle_instruction: handle a mnemonic and its operands.
fun handle_instruction(ctx: *ParseContext, mnemonic: str, line_start: usize, line_end: usize) bool {
    ctx.pos = line_start;

    # skip mnemonic
    val word: str = extract_word(ctx);
    if (word == nil) {
        ret false;
    }
    skip_whitespace(ctx);

    # zero-operand instructions
    if (str_equals(mnemonic, "nop")) { ret parse_simple_instr(ctx, op.OP_NOP); }
    if (str_equals(mnemonic, "syscall")) { ret parse_simple_instr(ctx, op.SYSCALL); }
    if (str_equals(mnemonic, "ret")) { ret parse_simple_instr(ctx, op.RET); }
    if (str_equals(mnemonic, "hlt")) { ret parse_simple_instr(ctx, op.HLT); }
    if (str_equals(mnemonic, "pause")) { ret parse_simple_instr(ctx, op.PAUSE); }
    if (str_equals(mnemonic, "cpuid")) { ret parse_simple_instr(ctx, op.CPUID); }
    if (str_equals(mnemonic, "rdtsc")) { ret parse_simple_instr(ctx, op.RDTSC); }
    if (str_equals(mnemonic, "lfence")) { ret parse_simple_instr(ctx, op.LFENCE); }
    if (str_equals(mnemonic, "sfence")) { ret parse_simple_instr(ctx, op.SFENCE); }
    if (str_equals(mnemonic, "mfence")) { ret parse_simple_instr(ctx, op.MFENCE); }
    if (str_equals(mnemonic, "cwd")) { ret parse_simple_instr(ctx, op.CWD); }
    if (str_equals(mnemonic, "cdq")) { ret parse_simple_instr(ctx, op.CDQ); }
    if (str_equals(mnemonic, "cqo")) { ret parse_simple_instr(ctx, op.CQO); }

    # one-operand instructions
    if (str_equals(mnemonic, "push")) { ret parse_unary_instr(ctx, op.PUSH, line_end); }
    if (str_equals(mnemonic, "pop")) { ret parse_unary_instr(ctx, op.POP, line_end); }
    if (str_equals(mnemonic, "inc")) { ret parse_unary_instr(ctx, op.INC, line_end); }
    if (str_equals(mnemonic, "dec")) { ret parse_unary_instr(ctx, op.DEC, line_end); }
    if (str_equals(mnemonic, "neg")) { ret parse_unary_instr(ctx, op.NEG, line_end); }
    if (str_equals(mnemonic, "not")) { ret parse_unary_instr(ctx, op.NOT, line_end); }
    if (str_equals(mnemonic, "mul")) { ret parse_unary_instr(ctx, op.MUL, line_end); }
    if (str_equals(mnemonic, "div")) { ret parse_unary_instr(ctx, op.DIV, line_end); }
    if (str_equals(mnemonic, "idiv")) { ret parse_unary_instr(ctx, op.IDIV, line_end); }
    if (str_equals(mnemonic, "jmp")) { ret parse_unary_instr(ctx, op.JMP, line_end); }
    if (str_equals(mnemonic, "call")) { ret parse_unary_instr(ctx, op.CALL, line_end); }
    if (str_equals(mnemonic, "je")) { ret parse_unary_instr(ctx, op.JE, line_end); }
    if (str_equals(mnemonic, "jne")) { ret parse_unary_instr(ctx, op.JNE, line_end); }
    if (str_equals(mnemonic, "jl")) { ret parse_unary_instr(ctx, op.JL, line_end); }
    if (str_equals(mnemonic, "jle")) { ret parse_unary_instr(ctx, op.JLE, line_end); }
    if (str_equals(mnemonic, "jg")) { ret parse_unary_instr(ctx, op.JG, line_end); }
    if (str_equals(mnemonic, "jge")) { ret parse_unary_instr(ctx, op.JGE, line_end); }
    if (str_equals(mnemonic, "jb")) { ret parse_unary_instr(ctx, op.JB, line_end); }
    if (str_equals(mnemonic, "jbe")) { ret parse_unary_instr(ctx, op.JBE, line_end); }
    if (str_equals(mnemonic, "ja")) { ret parse_unary_instr(ctx, op.JA, line_end); }
    if (str_equals(mnemonic, "jae")) { ret parse_unary_instr(ctx, op.JAE, line_end); }
    if (str_equals(mnemonic, "jc")) { ret parse_unary_instr(ctx, op.JC, line_end); }
    if (str_equals(mnemonic, "jnc")) { ret parse_unary_instr(ctx, op.JNC, line_end); }
    if (str_equals(mnemonic, "jo")) { ret parse_unary_instr(ctx, op.JO, line_end); }
    if (str_equals(mnemonic, "jno")) { ret parse_unary_instr(ctx, op.JNO, line_end); }
    if (str_equals(mnemonic, "js")) { ret parse_unary_instr(ctx, op.JS, line_end); }
    if (str_equals(mnemonic, "jns")) { ret parse_unary_instr(ctx, op.JNS, line_end); }
    if (str_equals(mnemonic, "sete")) { ret parse_unary_instr(ctx, op.SETE, line_end); }
    if (str_equals(mnemonic, "setne")) { ret parse_unary_instr(ctx, op.SETNE, line_end); }
    if (str_equals(mnemonic, "setl")) { ret parse_unary_instr(ctx, op.SETL, line_end); }
    if (str_equals(mnemonic, "setle")) { ret parse_unary_instr(ctx, op.SETLE, line_end); }
    if (str_equals(mnemonic, "setg")) { ret parse_unary_instr(ctx, op.SETG, line_end); }
    if (str_equals(mnemonic, "setge")) { ret parse_unary_instr(ctx, op.SETGE, line_end); }
    if (str_equals(mnemonic, "setb")) { ret parse_unary_instr(ctx, op.SETB, line_end); }
    if (str_equals(mnemonic, "setbe")) { ret parse_unary_instr(ctx, op.SETBE, line_end); }
    if (str_equals(mnemonic, "seta")) { ret parse_unary_instr(ctx, op.SETA, line_end); }
    if (str_equals(mnemonic, "setae")) { ret parse_unary_instr(ctx, op.SETAE, line_end); }

    # two-operand instructions
    if (str_equals(mnemonic, "mov")) { ret parse_binary_instr(ctx, op.OP_MOV, line_end); }
    if (str_equals(mnemonic, "movq")) { ret parse_binary_instr(ctx, op.MOVQ, line_end); }
    if (str_equals(mnemonic, "movd")) { ret parse_binary_instr(ctx, op.MOVD, line_end); }
    if (str_equals(mnemonic, "movsx")) { ret parse_binary_instr(ctx, op.MOVSX, line_end); }
    if (str_equals(mnemonic, "movzx")) { ret parse_binary_instr(ctx, op.MOVZX, line_end); }
    if (str_equals(mnemonic, "lea")) { ret parse_binary_instr(ctx, op.LEA, line_end); }
    if (str_equals(mnemonic, "add")) { ret parse_binary_instr(ctx, op.ADD, line_end); }
    if (str_equals(mnemonic, "adc")) { ret parse_binary_instr(ctx, op.ADC, line_end); }
    if (str_equals(mnemonic, "sub")) { ret parse_binary_instr(ctx, op.SUB, line_end); }
    if (str_equals(mnemonic, "sbb")) { ret parse_binary_instr(ctx, op.SBB, line_end); }
    if (str_equals(mnemonic, "imul")) { ret parse_binary_instr(ctx, op.IMUL, line_end); }
    if (str_equals(mnemonic, "and")) { ret parse_binary_instr(ctx, op.AND, line_end); }
    if (str_equals(mnemonic, "or")) { ret parse_binary_instr(ctx, op.OR, line_end); }
    if (str_equals(mnemonic, "xor")) { ret parse_binary_instr(ctx, op.XOR, line_end); }
    if (str_equals(mnemonic, "shl")) { ret parse_binary_instr(ctx, op.SHL, line_end); }
    if (str_equals(mnemonic, "shr")) { ret parse_binary_instr(ctx, op.SHR, line_end); }
    if (str_equals(mnemonic, "sar")) { ret parse_binary_instr(ctx, op.SAR, line_end); }
    if (str_equals(mnemonic, "cmp")) { ret parse_binary_instr(ctx, op.CMP, line_end); }
    if (str_equals(mnemonic, "test")) { ret parse_binary_instr(ctx, op.TEST, line_end); }
    if (str_equals(mnemonic, "xchg")) { ret parse_binary_instr(ctx, op.XCHG, line_end); }
    if (str_equals(mnemonic, "cmpxchg")) { ret parse_binary_instr(ctx, op.CMPXCHG, line_end); }
    if (str_equals(mnemonic, "xadd")) { ret parse_binary_instr(ctx, op.XADD, line_end); }
    if (str_equals(mnemonic, "bt")) { ret parse_binary_instr(ctx, op.BT, line_end); }
    if (str_equals(mnemonic, "bts")) { ret parse_binary_instr(ctx, op.BTS, line_end); }
    if (str_equals(mnemonic, "btr")) { ret parse_binary_instr(ctx, op.BTR, line_end); }
    if (str_equals(mnemonic, "btc")) { ret parse_binary_instr(ctx, op.BTC, line_end); }
    if (str_equals(mnemonic, "bsf")) { ret parse_binary_instr(ctx, op.BSF, line_end); }
    if (str_equals(mnemonic, "bsr")) { ret parse_binary_instr(ctx, op.BSR, line_end); }
    if (str_equals(mnemonic, "rol")) { ret parse_binary_instr(ctx, op.ROL, line_end); }
    if (str_equals(mnemonic, "ror")) { ret parse_binary_instr(ctx, op.ROR, line_end); }
    if (str_equals(mnemonic, "rcl")) { ret parse_binary_instr(ctx, op.RCL, line_end); }
    if (str_equals(mnemonic, "rcr")) { ret parse_binary_instr(ctx, op.RCR, line_end); }
    if (str_equals(mnemonic, "cmove")) { ret parse_binary_instr(ctx, op.CMOVE, line_end); }
    if (str_equals(mnemonic, "cmovne")) { ret parse_binary_instr(ctx, op.CMOVNE, line_end); }
    if (str_equals(mnemonic, "cmovl")) { ret parse_binary_instr(ctx, op.CMOVL, line_end); }
    if (str_equals(mnemonic, "cmovle")) { ret parse_binary_instr(ctx, op.CMOVLE, line_end); }
    if (str_equals(mnemonic, "cmovg")) { ret parse_binary_instr(ctx, op.CMOVG, line_end); }
    if (str_equals(mnemonic, "cmovge")) { ret parse_binary_instr(ctx, op.CMOVGE, line_end); }
    if (str_equals(mnemonic, "cmovb")) { ret parse_binary_instr(ctx, op.CMOVB, line_end); }
    if (str_equals(mnemonic, "cmovbe")) { ret parse_binary_instr(ctx, op.CMOVBE, line_end); }
    if (str_equals(mnemonic, "cmova")) { ret parse_binary_instr(ctx, op.CMOVA, line_end); }
    if (str_equals(mnemonic, "cmovae")) { ret parse_binary_instr(ctx, op.CMOVAE, line_end); }

    # floating point
    if (str_equals(mnemonic, "movss")) { ret parse_binary_instr(ctx, op.MOVSS, line_end); }
    if (str_equals(mnemonic, "movsd")) { ret parse_binary_instr(ctx, op.MOVSD, line_end); }
    if (str_equals(mnemonic, "movaps")) { ret parse_binary_instr(ctx, op.MOVAPS, line_end); }
    if (str_equals(mnemonic, "movapd")) { ret parse_binary_instr(ctx, op.MOVAPD, line_end); }
    if (str_equals(mnemonic, "addss")) { ret parse_binary_instr(ctx, op.ADDSS, line_end); }
    if (str_equals(mnemonic, "addsd")) { ret parse_binary_instr(ctx, op.ADDSD, line_end); }
    if (str_equals(mnemonic, "subss")) { ret parse_binary_instr(ctx, op.SUBSS, line_end); }
    if (str_equals(mnemonic, "subsd")) { ret parse_binary_instr(ctx, op.SUBSD, line_end); }
    if (str_equals(mnemonic, "mulss")) { ret parse_binary_instr(ctx, op.MULSS, line_end); }
    if (str_equals(mnemonic, "mulsd")) { ret parse_binary_instr(ctx, op.MULSD, line_end); }
    if (str_equals(mnemonic, "divss")) { ret parse_binary_instr(ctx, op.DIVSS, line_end); }
    if (str_equals(mnemonic, "divsd")) { ret parse_binary_instr(ctx, op.DIVSD, line_end); }
    if (str_equals(mnemonic, "sqrtss")) { ret parse_binary_instr(ctx, op.SQRTSS, line_end); }
    if (str_equals(mnemonic, "sqrtsd")) { ret parse_binary_instr(ctx, op.SQRTSD, line_end); }
    if (str_equals(mnemonic, "minss")) { ret parse_binary_instr(ctx, op.MINSS, line_end); }
    if (str_equals(mnemonic, "minsd")) { ret parse_binary_instr(ctx, op.MINSD, line_end); }
    if (str_equals(mnemonic, "maxss")) { ret parse_binary_instr(ctx, op.MAXSS, line_end); }
    if (str_equals(mnemonic, "maxsd")) { ret parse_binary_instr(ctx, op.MAXSD, line_end); }
    if (str_equals(mnemonic, "comiss")) { ret parse_binary_instr(ctx, op.COMISS, line_end); }
    if (str_equals(mnemonic, "comisd")) { ret parse_binary_instr(ctx, op.COMISD, line_end); }
    if (str_equals(mnemonic, "ucomiss")) { ret parse_binary_instr(ctx, op.UCOMISS, line_end); }
    if (str_equals(mnemonic, "ucomisd")) { ret parse_binary_instr(ctx, op.UCOMISD, line_end); }
    if (str_equals(mnemonic, "cvtsi2ss")) { ret parse_binary_instr(ctx, op.CVTSI2SS, line_end); }
    if (str_equals(mnemonic, "cvtsi2sd")) { ret parse_binary_instr(ctx, op.CVTSI2SD, line_end); }
    if (str_equals(mnemonic, "cvtss2si")) { ret parse_binary_instr(ctx, op.CVTSS2SI, line_end); }
    if (str_equals(mnemonic, "cvtsd2si")) { ret parse_binary_instr(ctx, op.CVTSD2SI, line_end); }
    if (str_equals(mnemonic, "cvttss2si")) { ret parse_binary_instr(ctx, op.CVTTSS2SI, line_end); }
    if (str_equals(mnemonic, "cvttsd2si")) { ret parse_binary_instr(ctx, op.CVTTSD2SI, line_end); }
    if (str_equals(mnemonic, "cvtss2sd")) { ret parse_binary_instr(ctx, op.CVTSS2SD, line_end); }
    if (str_equals(mnemonic, "cvtsd2ss")) { ret parse_binary_instr(ctx, op.CVTSD2SS, line_end); }

    ret false;
}

# parse_line: parse a single line of assembly.
fun parse_line(ctx: *ParseContext, line_start: usize, line_end: usize) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("context is nil");
    }

    ctx.pos = line_start;

    # skip leading whitespace
    skip_whitespace(ctx);
    if (ctx.pos >= line_end) {
        ret ok[bool, str](true);
    }

    # check for comment
    if (ctx.content[ctx.pos] == '#' || ctx.content[ctx.pos] == ';') {
        ret ok[bool, str](true);
    }

    # check for label definition (name:)
    var label_end: usize = ctx.pos;
    for (label_end < line_end && is_alnum(ctx.content[label_end])) {
        label_end = label_end + 1;
    }

    if (label_end > ctx.pos && label_end < line_end && ctx.content[label_end] == ':') {
        # label definition
        val label_name: str = extract_word(ctx);
        val label_instr: spec.Instruction = create_instruction(op.OP_NOP, operand.label(label_name), operand.none(), operand.none(), 0);
        if (!add_instruction(ctx, label_instr)) {
            ret err[bool, str]("failed to add label instruction");
        }
        ret ok[bool, str](true);
    }

    # skip directive (starts with .)
    if (ctx.content[ctx.pos] == '.') {
        ret ok[bool, str](true);
    }

    # extract mnemonic (save start position first)
    val mnemonic_start: usize = ctx.pos;
    val mnemonic: str = extract_word(ctx);
    if (mnemonic == nil) {
        ret ok[bool, str](true);
    }

    # handle instruction (pass mnemonic_start, not current ctx.pos)
    if (!handle_instruction(ctx, mnemonic, mnemonic_start, line_end)) {
        # unknown instruction - skip silently
        ret ok[bool, str](true);
    }

    ret ok[bool, str](true);
}

# get_results: return the parse results as an array struct.
# ---
# ctx: parse context
# ret: instruction array
fun get_results(ctx: *ParseContext) InstructionArray {
    if (ctx == nil || ctx.count == 0) {
        ret empty_array();
    }

    var arr: InstructionArray;
    arr.data = ctx.instructions;
    arr.len = ctx.count;
    ret arr;
}

# parse_x86_64_asm: parse x86_64 inline assembly and return instructions.
# ---
# content: raw asm text
# alloc:   allocator
# ret:     Result with instruction array or error string
pub fun parse_x86_64_asm(content: str, alloc: *allocator.Allocator) Result[InstructionArray, str] {
    if (content == nil || alloc == nil) {
        ret err[InstructionArray, str]("invalid arguments");
    }

    var ctx: ParseContext;
    if (!init_context(?ctx, content, alloc)) {
        ret err[InstructionArray, str]("failed to initialize parse context");
    }

    var i: usize = 0;
    val len: usize = str_len(content);

    for (i < len) {
        # skip whitespace at line start
        for (i < len && is_whitespace(content[i])) {
            i = i + 1;
        }

        if (i >= len) {
            brk;
        }

        # find end of line
        var line_end: usize = i;
        for (line_end < len && content[line_end] != '\n') {
            line_end = line_end + 1;
        }

        # strip comments (# or ;)
        var comment_pos: usize = i;
        for (comment_pos < line_end) {
            if (content[comment_pos] == '#' || content[comment_pos] == ';') {
                line_end = comment_pos;
                brk;
            }
            comment_pos = comment_pos + 1;
        }

        # trim trailing whitespace
        for (line_end > i && is_whitespace(content[line_end - 1])) {
            line_end = line_end - 1;
        }

        # parse the line if non-empty
        if (i < line_end) {
            val res: Result[bool, str] = parse_line(?ctx, i, line_end);
            if (result_is_err[bool, str](res)) {
                # return partial results on error
                ret err[InstructionArray, str](result_unwrap_err[bool, str](res));
            }
        }

        i = line_end + 1;
    }

    # return the instructions
    val results: InstructionArray = get_results(?ctx);
    ret ok[InstructionArray, str](results);
}
