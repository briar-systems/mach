# emit_xor_reg_reg: emit XOR reg, reg instruction (zero register).
# ---
# ctx: isel context
# r:   register to zero
pub fun emit_xor_reg_reg(ctx: *ISelContext, r: i32) {
    val op: operand.Operand = operand.reg(r, 8);
    val instr: spec.Instruction = make_instruction(x86.XOR, op, op, op, 8);
    emit_instr(ctx, instr);
}

# emit_ret: emit RET instruction.
# ---
# ctx: isel context
pub fun emit_ret(ctx: *ISelContext) {
    val instr: spec.Instruction = make_instruction(x86.RET, operand.none(), operand.none(), operand.none(), 0);
    emit_instr(ctx, instr);
}

# emit_syscall: emit SYSCALL instruction.
# ---
# ctx: isel context
pub fun emit_syscall(ctx: *ISelContext) {
    val instr: spec.Instruction = make_instruction(x86.SYSCALL, operand.none(), operand.none(), operand.none(), 0);
    emit_instr(ctx, instr);
}

# emit_rep_stosb: emit REP STOSB (0xF3 0xAA).
# ---
# ctx: isel context
# requires: RDI=dest, AL=fill byte, RCX=count
pub fun emit_rep_stosb(ctx: *ISelContext) {
    val rep: spec.Instruction = make_instruction(x86.PREFIX_REP, operand.none(), operand.none(), operand.none(), 0);
    emit_instr(ctx, rep);
    val stos: spec.Instruction = make_instruction(x86.STOS, operand.none(), operand.none(), operand.none(), 1);
    emit_instr(ctx, stos);
}

# select_memset: emit REP STOSB for an IR MEMSET instruction.
# ---
# IR MEMSET: dst=array_mem, src1=fill_value, src2=count
# x86 REP STOSB: RDI=dest addr, AL=fill byte, RCX=count
pub fun select_memset(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) { ret; }

    val dst: ir.IRValue = instr.dst;
    val fill: ir.IRValue = instr.src1;
    val count: ir.IRValue = instr.src2;

    # load destination address into RDI
    if (dst.kind == ir.VAL_MEM && is_simple_mem(dst)) {
        emit_lea(ctx, x86.RDI, dst.base_reg, dst.offset, 8);
    } or (dst.kind == ir.VAL_MEM) {
        compute_addr_rax(ctx, dst);
        emit_mov_reg_reg(ctx, x86.RDI, x86.RAX, 8);
    } or {
        load_operand(ctx, dst, x86.RDI);
    }

    # load fill value into RAX (STOSB uses AL)
    load_operand(ctx, fill, x86.RAX);

    # load count into RCX
    load_operand(ctx, count, x86.RCX);

    # emit REP STOSB
    emit_rep_stosb(ctx);
}

# emit_nop: emit NOP instruction.
# ---
# ctx: isel context
pub fun emit_nop(ctx: *ISelContext) {
    val instr: spec.Instruction = make_instruction(x86.OP_NOP, operand.none(), operand.none(), operand.none(), 0);
    emit_instr(ctx, instr);
}

