use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use ir:      mach.compiler.masm.ir;
use section: mach.compiler.masm.section;
use masm:    mach.compiler.masm.masm;
use x86:     mach.compiler.masm.isa.x86_64.opcode;
use x86_enc: mach.compiler.masm.isa.x86_64.encode;
use x86_buf: mach.compiler.masm.isa.x86_64.buf;
use x86_opt: mach.compiler.masm.isa.x86_64.opt;
use operand: mach.compiler.masm.operand;
use spec:    mach.compiler.masm.isa.spec;
use sym:     mach.compiler.masm.symbol;
use print:   std.print;

# mach.compiler.masm.isa.x86_64.isel: x86_64 instruction selection.
# ---
# converts IR instructions to x86_64 machine instructions.
# encoder converts instructions to bytes.

# virtual register threshold - registers >= this are virtual
pub val VREG_START: i32 = 1024;

# liveness array layout: 5 i32 fields per vreg, interleaved
val LV_STRIDE:    usize = 5;
val LV_FIRST_DEF: usize = 0;
val LV_LAST_USE:  usize = 1;
val LV_BLOCK_MIN: usize = 2;
val LV_BLOCK_MAX: usize = 3;
val LV_SIZES:     usize = 4;
val LV_FLOAT_BIT: i32 = 0x40000000; # high bit flag in LV_SIZES for float vregs

# register pool: callee-saved registers available for allocation
val REG_POOL_SIZE: i32 = 5;

fun reg_pool_at(idx: i32) i32 {
    if (idx == 0) { ret 3; }  # RBX
    if (idx == 1) { ret 12; } # R12
    if (idx == 2) { ret 13; } # R13
    if (idx == 3) { ret 14; } # R14
    ret 15;                    # R15
}

# ISelContext: context for instruction selection.
# ---
# alloc:            allocator for memory allocation
# text:             text section to emit to
# vreg_offsets:     map vreg_id -> stack offset (rbp - offset)
# vreg_cap:         capacity of vreg_offsets array
# max_vreg_index:   highest vreg index seen in current function
# next_vreg_slot:   next available vreg slot index (8-byte slots)
# base_stack_size:  stack size from STACK_FRAME instruction
# total_stack_size: total stack size including vregs
# ptr_size:         pointer size (8 for x86_64)
# liveness:         interleaved liveness data (5 i32s per vreg)
# liveness_cap:     capacity in vreg count (array has liveness_cap * LV_STRIDE elements)
# used_vregs:       indices of vregs touched in current function (for targeted reset)
# used_count:       number of entries in used_vregs
# used_cap:         capacity of used_vregs array
# free_offsets:     LIFO stack of reusable stack offsets
# free_count:       entries in free stack
# free_cap:         capacity of free stack
pub rec ISelContext {
    alloc:            *allocator.Allocator;
    text:             *section.Section;
    vreg_offsets:     *i32;
    vreg_cap:         usize;
    max_vreg_index:   usize;
    next_vreg_slot:   usize;
    base_stack_size:  usize;
    total_stack_size: usize;
    ptr_size:         usize;
    m:                *masm.Masm;
    instr_buf:        x86_buf.InstrBuffer;
    liveness:         *i32;
    liveness_cap:     usize;
    used_vregs:       *i32;
    used_count:       i32;
    used_cap:         i32;
    free_offsets:     *i32;
    free_count:       i32;
    free_cap:         i32;
    vreg_phys_reg:    *i32;
    vreg_phys_cap:    usize;
    callee_saved_mask:  i32;
    callee_saved_count: i32;
    func_name:        str;
}

# init: create a new instruction selection context.
# ---
# alloc: allocator to use
# text:  text section to emit to
# m:     masm context
# ret:   initialized ISelContext
pub fun init(alloc: *allocator.Allocator, text: *section.Section, m: *masm.Masm) ISelContext {
    var ctx: ISelContext;
    ctx.alloc = alloc;
    ctx.text = text;
    ctx.vreg_offsets = nil;
    ctx.vreg_cap = 0;
    ctx.max_vreg_index = 0;
    ctx.next_vreg_slot = 0;
    ctx.base_stack_size = 0;
    ctx.total_stack_size = 0;
    ctx.ptr_size = 8;
    ctx.m = m;
    ctx.instr_buf = x86_buf.buf_init(alloc);
    ctx.liveness = nil;
    ctx.liveness_cap = 0;
    ctx.used_vregs = nil;
    ctx.used_count = 0;
    ctx.used_cap = 0;
    ctx.free_offsets = nil;
    ctx.free_count = 0;
    ctx.free_cap = 0;
    ctx.vreg_phys_reg = nil;
    ctx.vreg_phys_cap = 0;
    ctx.callee_saved_mask = 0;
    ctx.callee_saved_count = 0;
    ctx.func_name = nil;
    ret ctx;
}

# reset: reset context for a new function.
# ---
# ctx: context to reset
pub fun reset(ctx: *ISelContext) {
    if (ctx == nil) {
        ret;
    }
    # don't free vreg_offsets - reuse the buffer
    # vreg_offsets, liveness, and vreg_phys_reg clearing handled by scan_function using used_vregs list
    ctx.max_vreg_index = 0;
    ctx.next_vreg_slot = 0;
    ctx.base_stack_size = 0;
    ctx.total_stack_size = 0;
    ctx.free_count = 0;
    ctx.callee_saved_mask = 0;
    ctx.callee_saved_count = 0;
}

# imm_fits_i32: check if an i64 value fits in a sign-extended 32-bit immediate.
# ---
# x86-64 ALU/CMP instructions encode immediates as sign-extended 32-bit values.
# values outside [-2147483648, 2147483647] must be materialized in a register.
pub fun imm_fits_i32(v: i64) bool {
    ret v >= -2147483648 && v <= 2147483647;
}

# get_vreg_offset: get or assign stack offset for a virtual register.
# ---
# ctx:     isel context
# vreg_id: virtual register id
# size:    vreg size in bytes
# ret:     stack offset from rbp (positive value, used as rbp - offset)
pub fun get_vreg_offset(ctx: *ISelContext, vreg_id: i32, size: usize) i32 {
    if (ctx == nil) {
        ret 0;
    }
    if (vreg_id < VREG_START) {
        ret 0;
    }

    val idx: usize = (vreg_id - VREG_START)::usize;

    # grow array if needed
    if (idx >= ctx.vreg_cap) {
        var new_cap: usize = (idx + 1) * 2;
        if (new_cap < 64) {
            new_cap = 64;
        }

        val r: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
            ctx.alloc, ctx.vreg_offsets, ctx.vreg_cap, new_cap
        );
        if (result_is_err[*i32, allocator.AllocError](r)) {
            ret 0;
        }

        val new_buf: *i32 = result_unwrap_ok[*i32, allocator.AllocError](r);
        # zero new slots
        var i: usize = ctx.vreg_cap;
        for (i < new_cap) {
            new_buf[i] = 0;
            i = i + 1;
        }
        ctx.vreg_offsets = new_buf;
        ctx.vreg_cap = new_cap;
    }

    # assign offset if not yet assigned
    if (ctx.vreg_offsets[idx] == 0) {
        var slots: usize = 1;
        if (size > 8) {
            slots = ((size + 7) / 8)::usize;
        }
        ctx.vreg_offsets[idx] = (ctx.base_stack_size + (ctx.next_vreg_slot + 1) * 8)::i32;
        ctx.next_vreg_slot = ctx.next_vreg_slot + slots;
    }

    # shift past callee-saved push area (pushes occupy [rbp-8..rbp-N*8])
    val callee_push_adj: i32 = ctx.callee_saved_count * 8;
    ret ctx.vreg_offsets[idx] + callee_push_adj;
}

# ensure_liveness_cap: grow interleaved liveness array to accommodate idx.
fun ensure_liveness_cap(ctx: *ISelContext, idx: usize) {
    if (idx < ctx.liveness_cap) {
        ret;
    }
    var new_cap: usize = (idx + 1) * 2;
    if (new_cap < 64) {
        new_cap = 64;
    }

    val old_elems: usize = ctx.liveness_cap * LV_STRIDE;
    val new_elems: usize = new_cap * LV_STRIDE;

    val r: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
        ctx.alloc, ctx.liveness, old_elems, new_elems
    );
    if (result_is_err[*i32, allocator.AllocError](r)) { ret; }
    ctx.liveness = result_unwrap_ok[*i32, allocator.AllocError](r);

    # init new slots to -1
    var i: usize = old_elems;
    for (i < new_elems) {
        ctx.liveness[i] = -1;
        i = i + 1;
    }
    ctx.liveness_cap = new_cap;
}

# record_vreg_ref: record a vreg reference for liveness tracking.
fun record_vreg_ref(ctx: *ISelContext, vreg_id: i32, size: usize, pos: i32, block_idx: i32) {
    if (vreg_id < VREG_START) {
        ret;
    }
    val idx: usize = (vreg_id - VREG_START)::usize;
    ensure_liveness_cap(ctx, idx);

    if (idx > ctx.max_vreg_index) {
        ctx.max_vreg_index = idx;
    }

    val base: usize = idx * LV_STRIDE;
    if (ctx.liveness[base + LV_FIRST_DEF] == -1) {
        ctx.liveness[base + LV_FIRST_DEF] = pos;
        ctx.liveness[base + LV_BLOCK_MIN] = block_idx;

        # track this vreg for targeted reset
        if (ctx.used_count >= ctx.used_cap) {
            var new_ucap: i32 = ctx.used_cap * 2;
            if (new_ucap < 64) {
                new_ucap = 64;
            }
            val ur: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
                ctx.alloc, ctx.used_vregs, ctx.used_cap::usize, new_ucap::usize
            );
            if (result_is_err[*i32, allocator.AllocError](ur)) { ret; }
            ctx.used_vregs = result_unwrap_ok[*i32, allocator.AllocError](ur);
            ctx.used_cap = new_ucap;
        }
        ctx.used_vregs[ctx.used_count] = idx::i32;
        ctx.used_count = ctx.used_count + 1;
    }
    ctx.liveness[base + LV_LAST_USE] = pos;
    ctx.liveness[base + LV_BLOCK_MAX] = block_idx;

    var slots: i32 = 1;
    if (size > 8) {
        slots = ((size + 7) / 8)::i32;
    }
    if (slots > ctx.liveness[base + LV_SIZES]) {
        ctx.liveness[base + LV_SIZES] = slots;
    }
}

# push_free_slot: push a reusable stack offset onto the free list.
fun push_free_slot(ctx: *ISelContext, offset: i32) {
    if (ctx.free_count >= ctx.free_cap) {
        var new_cap: i32 = ctx.free_cap * 2;
        if (new_cap < 64) {
            new_cap = 64;
        }
        val r: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
            ctx.alloc, ctx.free_offsets, ctx.free_cap::usize, new_cap::usize
        );
        if (result_is_err[*i32, allocator.AllocError](r)) { ret; }
        ctx.free_offsets = result_unwrap_ok[*i32, allocator.AllocError](r);
        ctx.free_cap = new_cap;
    }
    ctx.free_offsets[ctx.free_count] = offset;
    ctx.free_count = ctx.free_count + 1;
}

# pop_free_slot: pop a reusable stack offset from the free list.
# ret: stack offset or -1 if empty.
fun pop_free_slot(ctx: *ISelContext) i32 {
    if (ctx.free_count <= 0) {
        ret -1;
    }
    ctx.free_count = ctx.free_count - 1;
    ret ctx.free_offsets[ctx.free_count];
}

# ensure_phys_reg_cap: grow vreg_phys_reg array to accommodate idx.
fun ensure_phys_reg_cap(ctx: *ISelContext, idx: usize) {
    if (idx < ctx.vreg_phys_cap) {
        ret;
    }
    var new_cap: usize = (idx + 1) * 2;
    if (new_cap < 64) {
        new_cap = 64;
    }
    val r: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
        ctx.alloc, ctx.vreg_phys_reg, ctx.vreg_phys_cap, new_cap
    );
    if (result_is_err[*i32, allocator.AllocError](r)) { ret; }
    val new_buf: *i32 = result_unwrap_ok[*i32, allocator.AllocError](r);
    var i: usize = ctx.vreg_phys_cap;
    for (i < new_cap) {
        new_buf[i] = -1;
        i = i + 1;
    }
    ctx.vreg_phys_reg = new_buf;
    ctx.vreg_phys_cap = new_cap;
}

# get_vreg_phys_reg: get the physical register assigned to a vreg.
# ret: physical register index, or -1 if not register-allocated.
pub fun get_vreg_phys_reg(ctx: *ISelContext, vreg_id: i32) i32 {
    if (ctx == nil || vreg_id < VREG_START) {
        ret -1;
    }
    val idx: usize = (vreg_id - VREG_START)::usize;
    if (idx >= ctx.vreg_phys_cap) {
        ret -1;
    }
    ret ctx.vreg_phys_reg[idx];
}

# scan_function: pre-scan function to find max vreg and compute stack size.
# ---
# ctx:  isel context
# func: IR function to scan
pub fun scan_function(ctx: *ISelContext, func: *ir.IRFunction) {
    if (ctx == nil || func == nil) {
        ret;
    }

    # clear liveness + vreg_offsets from previous function (targeted, not full sweep)
    var ci: i32 = 0;
    for (ci < ctx.used_count) {
        val ui: usize = ctx.used_vregs[ci]::usize;
        val cb: usize = ui * LV_STRIDE;
        ctx.liveness[cb + LV_FIRST_DEF] = -1;
        ctx.liveness[cb + LV_LAST_USE] = -1;
        ctx.liveness[cb + LV_BLOCK_MIN] = -1;
        ctx.liveness[cb + LV_BLOCK_MAX] = -1;
        ctx.liveness[cb + LV_SIZES] = -1;
        if (ui < ctx.vreg_cap) {
            ctx.vreg_offsets[ui] = 0;
        }
        if (ui < ctx.vreg_phys_cap) {
            ctx.vreg_phys_reg[ui] = -1;
        }
        ci = ci + 1;
    }
    ctx.used_count = 0;
    ctx.max_vreg_index = 0;
    ctx.next_vreg_slot = 0;

    # --- pass 1: compute liveness ---
    var pos: i32 = 0;
    var bi: i32 = 0;
    for (bi < func.block_count) {
        val block: *ir.IRBlock = func.blocks[bi];
        if (block == nil) {
            bi = bi + 1;
            cnt;
        }

        var ii: i32 = 0;
        for (ii < block.instr_count) {
            val instr: *ir.Instr = ?block.instrs[ii];

            # check dst reg
            if (instr.dst.kind == ir.VAL_REG && instr.dst.reg >= VREG_START) {
                record_vreg_ref(ctx, instr.dst.reg, instr.dst.size, pos, bi);
            }
            # check src1 reg
            if (instr.src1.kind == ir.VAL_REG && instr.src1.reg >= VREG_START) {
                record_vreg_ref(ctx, instr.src1.reg, instr.src1.size, pos, bi);
            }
            # check src2 reg
            if (instr.src2.kind == ir.VAL_REG && instr.src2.reg >= VREG_START) {
                record_vreg_ref(ctx, instr.src2.reg, instr.src2.size, pos, bi);
            }
            # check memory operands (use pointer size)
            if (instr.dst.kind == ir.VAL_MEM && instr.dst.base_reg >= VREG_START) {
                record_vreg_ref(ctx, instr.dst.base_reg, ctx.ptr_size, pos, bi);
            }
            if (instr.dst.kind == ir.VAL_MEM && instr.dst.index_reg >= VREG_START) {
                record_vreg_ref(ctx, instr.dst.index_reg, ctx.ptr_size, pos, bi);
            }
            if (instr.src1.kind == ir.VAL_MEM && instr.src1.base_reg >= VREG_START) {
                record_vreg_ref(ctx, instr.src1.base_reg, ctx.ptr_size, pos, bi);
            }
            if (instr.src1.kind == ir.VAL_MEM && instr.src1.index_reg >= VREG_START) {
                record_vreg_ref(ctx, instr.src1.index_reg, ctx.ptr_size, pos, bi);
            }

            # flag vregs in float instructions (excluded from GPR allocation)
            val op_scan: u8 = ir.get_op_tag(?instr.op);
            if (op_scan == ir.OP_FADD || op_scan == ir.OP_FSUB || op_scan == ir.OP_FMUL ||
                op_scan == ir.OP_FDIV || op_scan == ir.OP_FCMP || op_scan == ir.OP_ITOF ||
                op_scan == ir.OP_FTOI || op_scan == ir.OP_FEXT || op_scan == ir.OP_FTRUNC) {
                if (instr.dst.kind == ir.VAL_REG && instr.dst.reg >= VREG_START) {
                    val fi: usize = (instr.dst.reg - VREG_START)::usize;
                    ctx.liveness[fi * LV_STRIDE + LV_SIZES] = ctx.liveness[fi * LV_STRIDE + LV_SIZES] | LV_FLOAT_BIT;
                }
                if (instr.src1.kind == ir.VAL_REG && instr.src1.reg >= VREG_START) {
                    val fi: usize = (instr.src1.reg - VREG_START)::usize;
                    ctx.liveness[fi * LV_STRIDE + LV_SIZES] = ctx.liveness[fi * LV_STRIDE + LV_SIZES] | LV_FLOAT_BIT;
                }
                if (instr.src2.kind == ir.VAL_REG && instr.src2.reg >= VREG_START) {
                    val fi: usize = (instr.src2.reg - VREG_START)::usize;
                    ctx.liveness[fi * LV_STRIDE + LV_SIZES] = ctx.liveness[fi * LV_STRIDE + LV_SIZES] | LV_FLOAT_BIT;
                }
            }

            pos = pos + 1;
            ii = ii + 1;
        }

        bi = bi + 1;
    }

    val total_instr_count: i32 = pos;

    # skip liveness analysis and allocation if no vregs were found
    # (e.g. functions with only inline assembly like _start)
    if (ctx.used_count > 0) {
        # conservative cross-block extension: if a vreg spans multiple blocks,
        # extend its last_use to end of function (handles loops/control flow safely)
        var vi: usize = 0;
        for (vi <= ctx.max_vreg_index) {
            val vb: usize = vi * LV_STRIDE;
            if (ctx.liveness[vb + LV_FIRST_DEF] >= 0 && ctx.liveness[vb + LV_BLOCK_MIN] != ctx.liveness[vb + LV_BLOCK_MAX]) {
                ctx.liveness[vb + LV_LAST_USE] = total_instr_count;
            }
            vi = vi + 1;
        }

        # grow vreg_offsets to accommodate max_vreg_index
        if (ctx.max_vreg_index >= ctx.vreg_cap) {
            var new_cap: usize = (ctx.max_vreg_index + 1) * 2;
            if (new_cap < 64) {
                new_cap = 64;
            }
            val r: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
                ctx.alloc, ctx.vreg_offsets, ctx.vreg_cap, new_cap
            );
            if (result_is_err[*i32, allocator.AllocError](r)) { ret; }
            val new_buf: *i32 = result_unwrap_ok[*i32, allocator.AllocError](r);
            var zi: usize = ctx.vreg_cap;
            for (zi < new_cap) {
                new_buf[zi] = 0;
                zi = zi + 1;
            }
            ctx.vreg_offsets = new_buf;
            ctx.vreg_cap = new_cap;
        }

        # --- pass 2: register allocation + stack slot allocation ---
        # ensure vreg_phys_reg can hold all vregs
        ensure_phys_reg_cap(ctx, ctx.max_vreg_index);

        # register allocation state
        var reg_free_mask: i32 = 31; # bits 0-4: pool regs 0-4 free (0x1F)
        var reg_active: *i32 = nil;
        var reg_active_count: i32 = 0;
        var reg_active_cap: i32 = 0;

        # stack slot active set
        var active: *i32 = nil;
        var active_count: i32 = 0;
        var active_cap: i32 = 0;

        # iterate used_vregs (in first-def order) for correct linear scan
        ci = 0;
        for (ci < ctx.used_count) {
            vi = ctx.used_vregs[ci]::usize;
            val vb2: usize = vi * LV_STRIDE;
            val cur_def: i32 = ctx.liveness[vb2 + LV_FIRST_DEF];
            val raw_sizes: i32 = ctx.liveness[vb2 + LV_SIZES];
            val is_float: bool = (raw_sizes & LV_FLOAT_BIT) != 0;
            val slot_count: i32 = raw_sizes & 0x3FFFFFFF;

            # expire registers: free regs from vregs whose last_use < cur_def
            var ri: i32 = 0;
            for (ri < reg_active_count) {
                val rv: i32 = reg_active[ri];
                if (ctx.liveness[rv::usize * LV_STRIDE + LV_LAST_USE] < cur_def) {
                    val freed_reg: i32 = ctx.vreg_phys_reg[rv::usize];
                    var pi: i32 = 0;
                    for (pi < REG_POOL_SIZE) {
                        if (reg_pool_at(pi) == freed_reg) {
                            reg_free_mask = reg_free_mask | (1 << pi::usize);
                            pi = REG_POOL_SIZE;
                        }
                        pi = pi + 1;
                    }
                    reg_active_count = reg_active_count - 1;
                    reg_active[ri] = reg_active[reg_active_count];
                } or {
                    ri = ri + 1;
                }
            }

            # expire stack slots: free slots from vregs whose last_use < cur_def
            var ai: i32 = 0;
            for (ai < active_count) {
                val av: i32 = active[ai];
                if (ctx.liveness[av::usize * LV_STRIDE + LV_LAST_USE] < cur_def) {
                    push_free_slot(ctx, ctx.vreg_offsets[av::usize]);
                    active_count = active_count - 1;
                    active[ai] = active[active_count];
                } or {
                    ai = ai + 1;
                }
            }

            # try register allocation for eligible vregs (1-slot, not float)
            if (slot_count == 1 && !is_float) {
                if (reg_free_mask != 0) {
                    # find lowest free register in pool
                    var pi: i32 = 0;
                    for (pi < REG_POOL_SIZE) {
                        if ((reg_free_mask & (1 << pi::usize)) != 0) {
                            ctx.vreg_phys_reg[vi] = reg_pool_at(pi);
                            reg_free_mask = reg_free_mask ^ (1 << pi::usize);
                            pi = REG_POOL_SIZE;
                        }
                        pi = pi + 1;
                    }
                } or {
                    # spill: evict the active vreg with furthest last_use
                    var evict_idx: i32 = -1;
                    var evict_last: i32 = -1;
                    ri = 0;
                    for (ri < reg_active_count) {
                        val rv2: i32 = reg_active[ri];
                        val rv_last: i32 = ctx.liveness[rv2::usize * LV_STRIDE + LV_LAST_USE];
                        if (rv_last > evict_last) {
                            evict_last = rv_last;
                            evict_idx = ri;
                        }
                        ri = ri + 1;
                    }
                    val cur_last: i32 = ctx.liveness[vb2 + LV_LAST_USE];
                    if (evict_idx >= 0 && evict_last > cur_last) {
                        val evicted: i32 = reg_active[evict_idx];
                        val stolen_reg: i32 = ctx.vreg_phys_reg[evicted::usize];
                        ctx.vreg_phys_reg[evicted::usize] = -1;
                        ctx.vreg_phys_reg[vi] = stolen_reg;
                        reg_active_count = reg_active_count - 1;
                        reg_active[evict_idx] = reg_active[reg_active_count];

                        # assign fresh stack slot to evicted vreg
                        val ev_reused: i32 = pop_free_slot(ctx);
                        if (ev_reused >= 0) {
                            ctx.vreg_offsets[evicted::usize] = ev_reused;
                        } or {
                            ctx.vreg_offsets[evicted::usize] = (ctx.base_stack_size + (ctx.next_vreg_slot + 1) * 8)::i32;
                            ctx.next_vreg_slot = ctx.next_vreg_slot + 1;
                        }
                        # add evicted vreg to stack active set
                        if (active_count >= active_cap) {
                            var ev_acap: i32 = active_cap * 2;
                            if (ev_acap < 64) {
                                ev_acap = 64;
                            }
                            val ev_ar: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
                                ctx.alloc, active, active_cap::usize, ev_acap::usize
                            );
                            if (!result_is_err[*i32, allocator.AllocError](ev_ar)) {
                                active = result_unwrap_ok[*i32, allocator.AllocError](ev_ar);
                                active_cap = ev_acap;
                            }
                        }
                        if (active_count < active_cap) {
                            active[active_count] = evicted;
                            active_count = active_count + 1;
                        }
                    }
                }
            }

            # add to reg_active if assigned a register
            if (ctx.vreg_phys_reg[vi] >= 0) {
                if (reg_active_count >= reg_active_cap) {
                    var new_racap: i32 = reg_active_cap * 2;
                    if (new_racap < 16) {
                        new_racap = 16;
                    }
                    val rar: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
                        ctx.alloc, reg_active, reg_active_cap::usize, new_racap::usize
                    );
                    if (!result_is_err[*i32, allocator.AllocError](rar)) {
                        reg_active = result_unwrap_ok[*i32, allocator.AllocError](rar);
                        reg_active_cap = new_racap;
                    }
                }
                if (reg_active_count < reg_active_cap) {
                    reg_active[reg_active_count] = vi::i32;
                    reg_active_count = reg_active_count + 1;
                }
            }

            # stack slot allocation: skip register-allocated vregs
            if (ctx.vreg_phys_reg[vi] >= 0) {
                ctx.vreg_offsets[vi] = -1;
            } or (slot_count == 1) {
                val reused: i32 = pop_free_slot(ctx);
                if (reused >= 0) {
                    ctx.vreg_offsets[vi] = reused;
                } or {
                    ctx.vreg_offsets[vi] = (ctx.base_stack_size + (ctx.next_vreg_slot + 1) * 8)::i32;
                    ctx.next_vreg_slot = ctx.next_vreg_slot + 1;
                }

                # add to stack active set (only non-register vregs)
                if (active_count >= active_cap) {
                    var new_acap: i32 = active_cap * 2;
                    if (new_acap < 64) {
                        new_acap = 64;
                    }
                    val ar: Result[*i32, allocator.AllocError] = allocator.allocator_resize[i32](
                        ctx.alloc, active, active_cap::usize, new_acap::usize
                    );
                    if (!result_is_err[*i32, allocator.AllocError](ar)) {
                        active = result_unwrap_ok[*i32, allocator.AllocError](ar);
                        active_cap = new_acap;
                    }
                }
                if (active_count < active_cap) {
                    active[active_count] = vi::i32;
                    active_count = active_count + 1;
                }
            } or {
                val slots: usize = slot_count::usize;
                ctx.vreg_offsets[vi] = (ctx.base_stack_size + (ctx.next_vreg_slot + 1) * 8)::i32;
                ctx.next_vreg_slot = ctx.next_vreg_slot + slots;
            }

            ci = ci + 1;
        }

        # compute callee_saved_mask and callee_saved_count from assigned registers
        ci = 0;
        for (ci < ctx.used_count) {
            vi = ctx.used_vregs[ci]::usize;
            if (vi < ctx.vreg_phys_cap) {
                val phys: i32 = ctx.vreg_phys_reg[vi];
                if (phys >= 0) {
                    if ((ctx.callee_saved_mask & (1 << phys::usize)) == 0) {
                        ctx.callee_saved_mask = ctx.callee_saved_mask | (1 << phys::usize);
                        ctx.callee_saved_count = ctx.callee_saved_count + 1;
                    }
                }
            }
            ci = ci + 1;
        }
    }

    # calculate total stack size: locals + vregs only
    # callee-saved regs are saved via push after frame setup (not in sub rsp)
    ctx.total_stack_size = ctx.base_stack_size + (ctx.next_vreg_slot * 8);

    # align to 16 bytes, accounting for callee-saved pushes
    # after call (ret addr) + push rbp + N callee pushes: (2+N) pushes total
    # if N is odd: RSP is 8-misaligned before sub rsp, need total_stack_size % 16 == 8
    # if N is even: RSP is 16-aligned before sub rsp, need total_stack_size % 16 == 0
    if ((ctx.callee_saved_count % 2) != 0) {
        if (ctx.total_stack_size % 16 == 0) {
            ctx.total_stack_size = ctx.total_stack_size + 8;
        }
    } or {
        if (ctx.total_stack_size % 16 != 0) {
            ctx.total_stack_size = ctx.total_stack_size + (16 - (ctx.total_stack_size % 16));
        }
    }
}

# needs_chunked_move: true if size is not 1/2/4/8 bytes.
# ---
pub fun needs_chunked_move(size: usize) bool {
    ret size != 0 && size != 1 && size != 2 && size != 4 && size != 8;
}

# make_instruction: create an instruction record.
# ---
# opcode: instruction opcode from x86_64 module
# dst:    destination operand
# src1:   first source operand
# src2:   second source operand
# size:   operand size in bytes
# ret:    Instruction record
pub fun make_instruction(opcode: i32, dst: operand.Operand, src1: operand.Operand, src2: operand.Operand, size: usize) spec.Instruction {
    var instr: spec.Instruction;
    instr.opcode = opcode;
    instr.dst = dst;
    instr.src1 = src1;
    instr.src2 = src2;
    instr.size = size;
    instr.flags = 0;
    if (size == 8) {
        instr.flags = spec.FLAG_REX_W;
    }
    ret instr;
}

# emit_instr: buffer an instruction for deferred encoding.
# ---
# ctx:   isel context
# instr: instruction to emit
pub fun emit_instr(ctx: *ISelContext, instr: spec.Instruction) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }
    x86_buf.buf_append(?ctx.instr_buf, instr);
}

# flush_buffer: run x86 peephole optimization, then encode all buffered
# instructions to the text section. label markers are resolved to symbol
# definitions at the current section offset during encoding.
pub fun flush_buffer(ctx: *ISelContext) {
    if (ctx == nil || ctx.text == nil || ctx.alloc == nil) {
        ret;
    }

    # run x86 peephole optimization on the buffer
    var opt_ctx: x86_opt.X86OptContext = x86_opt.opt_init(ctx.alloc);
    x86_opt.optimize_buffer(?opt_ctx, ?ctx.instr_buf);

    # encode all instructions in order
    var i: i32 = 0;
    for (i < ctx.instr_buf.count) {
        val instr: *spec.Instruction = x86_buf.buf_get(?ctx.instr_buf, i);
        if (instr == nil) {
            i = i + 1;
            cnt;
        }

        # handle debug line markers: record debug line at current section offset
        if (instr.opcode == x86_buf.DEBUG_LINE_MARKER) {
            if (ctx.m != nil) {
                masm.add_debug_line(ctx.m,
                    section.current_offset(ctx.text),
                    instr.dst.imm::u16,
                    instr.src1.imm::i32
                );
            }
            i = i + 1;
            cnt;
        }

        # handle label markers: define symbol at current section offset
        if (instr.opcode == x86_buf.LABEL_MARKER) {
            val label_name: str = instr.dst.label;
            if (label_name != nil && ctx.m != nil) {
                val existing: *sym.Symbol = masm.get_symbol(ctx.m, label_name);
                if (existing != nil) {
                    if (existing.sym_type.tag != sym.SYM_FUNC) {
                        sym.define(existing, ctx.text, section.current_offset(ctx.text), 0);
                    }
                } or {
                    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.m.alloc, label_name);
                    if (result_is_ok[*sym.Symbol, str](sym_res)) {
                        val s: *sym.Symbol = result_unwrap_ok[*sym.Symbol, str](sym_res);
                        sym.set_binding(s, sym.bind_local());
                        sym.set_type(s, sym.sym_none());
                        sym.define(s, ctx.text, section.current_offset(ctx.text), 0);
                        masm.add_symbol(ctx.m, s);
                    }
                }
            }
            i = i + 1;
            cnt;
        }

        # skip NOPs with size 0 (eliminated by peephole)
        if (instr.opcode == 0 && instr.size == 0 && instr.dst.kind.tag == operand.OP_NONE) {
            i = i + 1;
            cnt;
        }

        # encode instruction to text section
        x86_enc.encode_instruction(instr, ctx.text, ctx.alloc);
        i = i + 1;
    }

    # clear buffer for next function
    x86_buf.buf_clear(?ctx.instr_buf);
}

# emit_mov_reg_imm: emit MOV reg, imm instruction.
# ---
# ctx:  isel context
# r:    destination register
# v:    immediate value
# size: operand size
pub fun emit_mov_reg_imm(ctx: *ISelContext, r: i32, v: i64, size: usize) {
    val dst: operand.Operand = operand.reg(r, size);
    val src: operand.Operand = operand.imm(v, size);
    val instr: spec.Instruction = make_instruction(x86.OP_MOV, dst, src, operand.none(), size);
    emit_instr(ctx, instr);
}

# emit_mov_reg_label: emit MOV reg, label instruction (for loading symbol addresses).
# ---
# ctx:   isel context
# r:     destination register
# label: label name
# size:  operand size (should be 8 for 64-bit addresses)
pub fun emit_mov_reg_label(ctx: *ISelContext, r: i32, lbl: str, size: usize) {
    val dst: operand.Operand = operand.reg(r, size);
    var src: operand.Operand = operand.label(lbl);
    src.size = size;
    val instr: spec.Instruction = make_instruction(x86.OP_MOV, dst, src, operand.none(), size);
    emit_instr(ctx, instr);
}

# emit_mov_reg_reg: emit MOV reg, reg instruction.
# ---
# ctx: isel context
# dst: destination register
# src: source register
# size: operand size
pub fun emit_mov_reg_reg(ctx: *ISelContext, dst: i32, src: i32, size: usize) {
    val dst_op: operand.Operand = operand.reg(dst, size);
    val src_op: operand.Operand = operand.reg(src, size);
    val instr: spec.Instruction = make_instruction(x86.OP_MOV, dst_op, src_op, operand.none(), size);
    emit_instr(ctx, instr);
}

# emit_alu_reg_imm: emit ALU op reg, imm instruction.
# ---
# ctx:    isel context
# opcode: ALU opcode (ADD, SUB, AND, OR, XOR)
# r:      destination register
# v:      immediate value
# size:   operand size
pub fun emit_alu_reg_imm(ctx: *ISelContext, opcode: i32, r: i32, v: i64, size: usize) {
    val dst: operand.Operand = operand.reg(r, size);
    val src: operand.Operand = operand.imm(v, size);
    # dst goes in both dst and src1 for two-operand ALU form (op dst, src)
    val instr: spec.Instruction = make_instruction(opcode, dst, src, operand.none(), size);
    emit_instr(ctx, instr);
}

# emit_alu_reg_reg: emit ALU op reg, reg instruction.
# ---
# ctx:    isel context
# opcode: ALU opcode
# dst:    destination register
# src:    source register
# size:   operand size
pub fun emit_alu_reg_reg(ctx: *ISelContext, opcode: i32, dst: i32, src: i32, size: usize) {
    val dst_op: operand.Operand = operand.reg(dst, size);
    val src_op: operand.Operand = operand.reg(src, size);
    # two-operand form: op dst, src - encoder expects dst in ops[0], src in ops[1]
    val instr: spec.Instruction = make_instruction(opcode, dst_op, src_op, operand.none(), size);
    emit_instr(ctx, instr);
}

# emit_push_reg: emit PUSH reg instruction.
# ---
# ctx: isel context
# r:   register to push
pub fun emit_push_reg(ctx: *ISelContext, r: i32) {
    val dst: operand.Operand = operand.reg(r, 8);
    val instr: spec.Instruction = make_instruction(x86.PUSH, dst, operand.none(), operand.none(), 8);
    emit_instr(ctx, instr);
}

# emit_pop_reg: emit POP reg instruction.
# ---
# ctx: isel context
# r:   register to pop
pub fun emit_pop_reg(ctx: *ISelContext, r: i32) {
    val dst: operand.Operand = operand.reg(r, 8);
    val instr: spec.Instruction = make_instruction(x86.POP, dst, operand.none(), operand.none(), 8);
    emit_instr(ctx, instr);
}

# emit_sub_reg_imm: emit SUB reg, imm instruction.
# ---
# ctx:  isel context
# r:    register
# v:    immediate value
# size: operand size
pub fun emit_sub_reg_imm(ctx: *ISelContext, r: i32, v: i64, size: usize) {
    if (v == 0) {
        ret;
    }
    val dst: operand.Operand = operand.reg(r, size);
    val src: operand.Operand = operand.imm(v, size);
    # two-operand form: sub dst, imm
    val instr: spec.Instruction = make_instruction(x86.SUB, dst, src, operand.none(), size);
    emit_instr(ctx, instr);
}

# emit_add_reg_imm: emit ADD reg, imm instruction.
# ---
# ctx:  isel context
# r:    register
# v:    immediate value
# size: operand size
pub fun emit_add_reg_imm(ctx: *ISelContext, r: i32, v: i64, size: usize) {
    if (v == 0) {
        ret;
    }
    val dst: operand.Operand = operand.reg(r, size);
    val src: operand.Operand = operand.imm(v, size);
    # two-operand form: add dst, imm
    val instr: spec.Instruction = make_instruction(x86.ADD, dst, src, operand.none(), size);
    emit_instr(ctx, instr);
