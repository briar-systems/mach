use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use operand: mach.compiler.masm.operand;
use section: mach.compiler.masm.section;

# mach.compiler.masm.isa.spec: ISA specification interface.
# ---
# defines the interface for instruction set architecture implementations.

# ISA: instruction set architecture specification.
# ---
# name:           ISA name (e.g. "x86_64", "aarch64")
# word_size:      native word size in bytes
# ptr_size:       pointer size in bytes
# reg_count:      number of general-purpose registers
# float_reg_count: number of floating-point registers
# endian_big:     true if big-endian
pub rec ISA {
    name:            str;
    word_size:       usize;
    ptr_size:        usize;
    reg_count:       i32;
    float_reg_count: i32;
    endian_big:      bool;
}

# Instruction: a machine instruction to be encoded.
# ---
# opcode:  instruction opcode/mnemonic identifier
# dst:     destination operand
# src1:    first source operand
# src2:    second source operand
# size:    operand size in bytes
# flags:   instruction-specific flags
pub rec Instruction {
    opcode: i32;
    dst:    operand.Operand;
    src1:   operand.Operand;
    src2:   operand.Operand;
    size:   usize;
    flags:  u32;
}

# common instruction flags
pub val FLAG_REX_W:     u32 = 1;   # 64-bit operand size (x86-64)
pub val FLAG_LOCK:      u32 = 2;   # lock prefix
pub val FLAG_REP:       u32 = 4;   # rep prefix
pub val FLAG_NEAR_JUMP: u32 = 8;   # near jump (not short)
pub val FLAG_INDIRECT:  u32 = 16;  # indirect call/jump

# encode: encode an instruction into machine code.
# ---
# isa:   ISA specification
# instr: instruction to encode
# sec:   section to emit into
# alloc: allocator for section growth
# ret:   Ok(bytes emitted) on success, Err(str) on failure
pub fun encode(isa: *ISA, instr: *Instruction, sec: *section.Section, alloc: *allocator.Allocator) Result[usize, str] {
    if (isa == nil) {
        ret err[usize, str]("ISA is nil");
    }

    if (instr == nil) {
        ret err[usize, str]("instruction is nil");
    }

    if (sec == nil) {
        ret err[usize, str]("section is nil");
    }

    # dispatch to ISA-specific encoder
    if (isa.name == "x86_64") {
        # TODO: fix module alias - encoder called directly by isel for now
        ret err[usize, str]("use x86.encode_instruction directly");
    }

    # future: aarch64, riscv-v here
    # if (isa.name == "aarch64") { ... }

    ret err[usize, str]("unsupported ISA");
}

# get_reg_name: get the name of a register.
# ---
# isa:  ISA specification
# reg:  register number
# size: register size in bytes
# ret:  register name string
pub fun get_reg_name(isa: *ISA, reg: i32, size: usize) str {
    if (isa == nil) {
        ret "?";
    }

    # TODO: dispatch to ISA-specific register names
    ret "?";
}

# is_valid_operand_size: check if an operand size is valid for the ISA.
# ---
# isa:  ISA specification
# size: operand size in bytes
# ret:  true if the size is valid
pub fun is_valid_operand_size(isa: *ISA, size: usize) bool {
    if (isa == nil) {
        ret false;
    }

    # common sizes for most ISAs
    if (size == 1) { ret true; }
    if (size == 2) { ret true; }
    if (size == 4) { ret true; }
    if (size == 8) { ret true; }

    ret false;
}

# max_instruction_size: get the maximum encoded instruction size.
# ---
# isa: ISA specification
# ret: maximum instruction size in bytes
pub fun max_instruction_size(isa: *ISA) usize {
    if (isa == nil) {
        ret 16;
    }

    # x86-64 instructions can be up to 15 bytes
    # most RISC ISAs have fixed 4-byte instructions
    ret 16;
}

# needs_alignment: check if an instruction needs alignment.
# ---
# isa:    ISA specification
# opcode: instruction opcode
# ret:    required alignment (1 = no alignment needed)
pub fun needs_alignment(isa: *ISA, opcode: i32) usize {
    if (isa == nil) {
        ret 1;
    }

    # TODO: check for instructions that need alignment (e.g. SIMD)
    ret 1;
}

# create_nop: create a NOP instruction of the specified size.
# ---
# size: desired NOP size in bytes
# ret:  Instruction for the NOP
pub fun create_nop(size: usize) Instruction {
    var instr: Instruction;
    instr.opcode = 0; # generic NOP - ISA-specific encoder maps to correct opcode
    instr.dst = operand.none();
    instr.src1 = operand.none();
    instr.src2 = operand.none();
    instr.size = size;
    instr.flags = 0;
    ret instr;
}
