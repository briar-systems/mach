use std.types.bool;
use std.types.result;
use std.types.size;
use std.types.string;

use allocator: std.allocator;
use ir:        mach.compiler.masm.ir;
use masm_mod:  mach.compiler.masm.masm;
use section:   mach.compiler.masm.section;
use target:    mach.compiler.masm.target;
use sym:       mach.compiler.masm.symbol;
use operand:   mach.compiler.masm.operand;
use spec:      mach.compiler.masm.isa.spec;
use print:     std.print;

# x86_64 backend
use x86_isel:    mach.compiler.masm.isa.x86_64.isel;
use x86parse:    mach.compiler.masm.isa.x86_64.parse;
use x86encode:   mach.compiler.masm.isa.x86_64.encode;
use x86opcode:   mach.compiler.masm.isa.x86_64.opcode;

# mach.compiler.masm.isa.dispatch: ISA dispatch layer.
# ---
# routes instruction selection and inline assembly to the correct
# ISA-specific backend based on the target configuration.
# to add a new ISA: import the new modules and add dispatch cases.

# --- instruction selection ---

# run_isel: dispatch instruction selection to the target ISA backend.
# ---
# m:     masm context
# funcs: array of IR functions to select instructions for
# count: number of IR functions
# alloc: allocator
# ret:   Ok(true) on success, Err(str) on failure
pub fun run_isel(m: *masm_mod.Masm, funcs: **ir.IRFunction, count: i32,
                 alloc: *allocator.Allocator) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("masm context is nil");
    }
    if (m.tgt.isa.tag == target.ISA_X86_64) {
        ret x86_isel.run_isel(m, funcs, count, alloc);
    }
    ret err[bool, str]("unsupported ISA for instruction selection");
}

# --- inline assembly ---

# assemble: parse and encode inline assembly for the target ISA.
# ---
# handles parsing, label creation, and encoding in one call.
# tgt:     target configuration
# content: inline assembly text
# sec:     section to emit into
# m:       masm context (for symbol registration)
# alloc:   allocator
# ret:     Ok(bytes_emitted) or Err(diagnostic_string)
pub fun assemble(tgt: *target.Target, content: str, sec: *section.Section,
                 m: *masm_mod.Masm, alloc: *allocator.Allocator) Result[usize, str] {
    if (tgt == nil || content == nil || sec == nil) {
        ret err[usize, str]("invalid arguments to assemble");
    }

    if (tgt.isa.tag == target.ISA_X86_64) {
        ret assemble_x86_64(content, sec, m, alloc);
    }

    ret err[usize, str]("unsupported ISA for inline assembly");
}

# assemble_x86_64: x86_64 inline assembly implementation.
fun assemble_x86_64(content: str, sec: *section.Section,
                     m: *masm_mod.Masm, alloc: *allocator.Allocator) Result[usize, str] {
    val parse_res: Result[x86parse.InstructionArray, str] = x86parse.parse_x86_64_asm(content, alloc);
    if (parse_res.is_err()) {
        ret err[usize, str](parse_res.unwrap_err());
    }
    val instrs: x86parse.InstructionArray = parse_res.unwrap_ok();

    var total_bytes: usize = 0;
    var i: usize = 0;
    for (i < instrs.len) {
        val instr: *spec.Instruction = ?instrs.data[i];

        # handle label definitions
        if (instr.opcode == x86opcode.OP_NOP && instr.dst.kind.tag == operand.OP_LABEL) {
            val label_name: str = instr.dst.label;
            if (label_name != nil) {
                val sym_res: Result[*sym.Symbol, str] = sym.create(alloc, label_name);
                if (sym_res.is_ok()) {
                    val s: *sym.Symbol = sym_res.unwrap_ok();
                    sym.set_binding(s, sym.bind_local());
                    sym.set_type(s, sym.sym_none());
                    sym.define(s, sec, sec.size, 0);
                    masm_mod.add_symbol(m, s);
                }
            }
            i = i + 1;
            cnt;
        }

        val enc_res: Result[usize, str] = x86encode.encode_instruction(instr, sec, alloc);
        if (enc_res.is_err()) {
            print.eprint("error: inline asm: ");
            print.eprint(enc_res.unwrap_err());
            print.eprint(" (opcode: ");
            print.eprint(x86opcode.get_name(instr.opcode));
            print.eprintln(")");
            ret err[usize, str](enc_res.unwrap_err());
        }
        total_bytes = total_bytes + enc_res.unwrap_ok();
        i = i + 1;
    }
    ret ok[usize, str](total_bytes);
}
