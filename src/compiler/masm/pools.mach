use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use dbg:       std.print;

# mach.compiler.masm.pools: per-function data pools for compact IR.
# ---
# provides ConstPool (64-bit program constants), DataPool (width-agnostic
# byte pool for instruction metadata), and LabelTable (label name interning).
# all pools use index-based lookup and deduplicate on intern.

# ================================================================
# constant pool (per-function)
# ================================================================

pub rec ConstPool {
    values: *u64;
    count:  i32;
    cap:    i32;
}

val CONST_POOL_INITIAL_CAP: i32 = 8;

pub fun const_pool_init() ConstPool {
    var p: ConstPool;
    p.values = nil;
    p.count = 0;
    p.cap = 0;
    ret p;
}

# const_intern: add a value to the constant pool, returning its index.
# deduplicates: returns existing index if value already present.
# traps on allocation failure rather than returning a silent -1.
pub fun const_intern(alloc: *allocator.Allocator, pool: *ConstPool, value: u64) i32 {
    if (alloc == nil || pool == nil) {
        dbg.eprintln("[masm] const_intern: nil allocator or pool");
        ret -1;
    }

    var i: i32 = 0;
    for (i < pool.count) {
        if (pool.values[i] == value) { ret i; }
        i = i + 1;
    }

    if (pool.count >= pool.cap) {
        var new_cap: i32 = CONST_POOL_INITIAL_CAP;
        if (pool.cap > 0) { new_cap = pool.cap * 2; }
        val r: Result[*u64, allocator.AllocError] =
            allocator.allocator_resize[u64](alloc, pool.values,
                pool.cap::usize, new_cap::usize);
        if (result_is_err[*u64, allocator.AllocError](r)) {
            dbg.eprintln("[masm] const_intern: allocation failed");
            ret -1;
        }
        pool.values = result_unwrap_ok[*u64, allocator.AllocError](r);
        pool.cap = new_cap;
    }

    val idx: i32 = pool.count;
    pool.values[idx] = value;
    pool.count = pool.count + 1;
    ret idx;
}

pub fun const_get(pool: *ConstPool, idx: i32) u64 {
    if (pool == nil || idx < 0 || idx >= pool.count) { ret 0; }
    ret pool.values[idx];
}

# const_pool_destroy: free all memory owned by a constant pool.
pub fun const_pool_destroy(alloc: *allocator.Allocator, pool: *ConstPool) {
    if (alloc == nil || pool == nil) { ret; }
    if (pool.values != nil) {
        allocator.allocator_free[u64](alloc, pool.values, pool.cap::usize);
        pool.values = nil;
    }
    pool.count = 0;
    pool.cap = 0;
}

# ================================================================
# label table (per-function)
# ================================================================

pub rec LabelTable {
    names: *str;
    count: i32;
    cap:   i32;
}

val LABEL_TABLE_INITIAL_CAP: i32 = 16;

pub fun label_table_init() LabelTable {
    var t: LabelTable;
    t.names = nil;
    t.count = 0;
    t.cap = 0;
    ret t;
}

# label_intern: add a label name, returning its index.
# deduplicates by string equality.
# traps on allocation failure rather than returning a silent -1.
pub fun label_intern(alloc: *allocator.Allocator, tbl: *LabelTable, name: str) i32 {
    if (alloc == nil || tbl == nil) {
        dbg.eprintln("[masm] label_intern: nil allocator or table");
        ret -1;
    }

    var i: i32 = 0;
    for (i < tbl.count) {
        if (str_equals(tbl.names[i], name)) { ret i; }
        i = i + 1;
    }

    if (tbl.count >= tbl.cap) {
        var new_cap: i32 = LABEL_TABLE_INITIAL_CAP;
        if (tbl.cap > 0) { new_cap = tbl.cap * 2; }
        val r: Result[*str, allocator.AllocError] =
            allocator.allocator_resize[str](alloc, tbl.names,
                tbl.cap::usize, new_cap::usize);
        if (result_is_err[*str, allocator.AllocError](r)) {
            dbg.eprintln("[masm] label_intern: allocation failed");
            ret -1;
        }
        tbl.names = result_unwrap_ok[*str, allocator.AllocError](r);
        tbl.cap = new_cap;
    }

    val idx: i32 = tbl.count;
    tbl.names[idx] = name;
    tbl.count = tbl.count + 1;
    ret idx;
}

pub fun label_get(tbl: *LabelTable, idx: i32) str {
    if (tbl == nil || idx < 0 || idx >= tbl.count) { ret nil; }
    ret tbl.names[idx];
}

# label_table_destroy: free all memory owned by a label table.
pub fun label_table_destroy(alloc: *allocator.Allocator, tbl: *LabelTable) {
    if (alloc == nil || tbl == nil) { ret; }
    if (tbl.names != nil) {
        allocator.allocator_free[str](alloc, tbl.names, tbl.cap::usize);
        tbl.names = nil;
    }
    tbl.count = 0;
    tbl.cap = 0;
}

# ================================================================
# data pool (per-function)
# ================================================================

# width-agnostic byte pool for instruction metadata (displacements,
# packed ABI descriptors, packed indexed memory, etc.)
# ---
# entries are 8-byte aligned so typed reads via pointer cast are safe.
pub rec DataPool {
    data:     *u8;
    offsets:  *i32;
    sizes:    *i32;
    count:    i32;
    cap:      i32;
    data_len: i32;
    data_cap: i32;
}

val DATA_POOL_INITIAL_CAP:      i32 = 16;
val DATA_POOL_INITIAL_DATA_CAP: i32 = 128;

pub fun data_pool_init() DataPool {
    var p: DataPool;
    p.data = nil;
    p.offsets = nil;
    p.sizes = nil;
    p.count = 0;
    p.cap = 0;
    p.data_len = 0;
    p.data_cap = 0;
    ret p;
}

fun data_bytes_equal(a: *u8, b: *u8, len: i32) bool {
    var i: i32 = 0;
    for (i < len) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

# data_intern: intern arbitrary bytes, returning a deduped index.
# traps on allocation failure rather than returning a silent -1.
pub fun data_intern(alloc: *allocator.Allocator, pool: *DataPool, ptr: *u8, size: i32) i32 {
    if (alloc == nil || pool == nil || ptr == nil || size <= 0) {
        dbg.eprintln("[masm] data_intern: nil argument or invalid size");
        ret -1;
    }

    var i: i32 = 0;
    for (i < pool.count) {
        if (pool.sizes[i] == size) {
            if (data_bytes_equal(?pool.data[pool.offsets[i]], ptr, size)) {
                ret i;
            }
        }
        i = i + 1;
    }

    val aligned: i32 = (pool.data_len + 7) & -8;
    val needed: i32 = aligned + size;

    if (needed > pool.data_cap) {
        var new_cap: i32 = DATA_POOL_INITIAL_DATA_CAP;
        if (pool.data_cap > 0) { new_cap = pool.data_cap * 2; }
        for (new_cap < needed) { new_cap = new_cap * 2; }
        val r: Result[*u8, allocator.AllocError] =
            allocator.allocator_resize[u8](alloc, pool.data,
                pool.data_cap::usize, new_cap::usize);
        if (result_is_err[*u8, allocator.AllocError](r)) {
            dbg.eprintln("[masm] data_intern: data buffer allocation failed");
            ret -1;
        }
        pool.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        pool.data_cap = new_cap;
    }

    if (pool.count >= pool.cap) {
        var new_cap: i32 = DATA_POOL_INITIAL_CAP;
        if (pool.cap > 0) { new_cap = pool.cap * 2; }

        val r1: Result[*i32, allocator.AllocError] =
            allocator.allocator_resize[i32](alloc, pool.offsets,
                pool.cap::usize, new_cap::usize);
        if (result_is_err[*i32, allocator.AllocError](r1)) {
            dbg.eprintln("[masm] data_intern: offsets allocation failed");
            ret -1;
        }
        pool.offsets = result_unwrap_ok[*i32, allocator.AllocError](r1);

        val r2: Result[*i32, allocator.AllocError] =
            allocator.allocator_resize[i32](alloc, pool.sizes,
                pool.cap::usize, new_cap::usize);
        if (result_is_err[*i32, allocator.AllocError](r2)) {
            dbg.eprintln("[masm] data_intern: sizes allocation failed");
            ret -1;
        }
        pool.sizes = result_unwrap_ok[*i32, allocator.AllocError](r2);

        pool.cap = new_cap;
    }

    var j: i32 = 0;
    for (j < size) {
        pool.data[aligned + j] = ptr[j];
        j = j + 1;
    }

    val idx: i32 = pool.count;
    pool.offsets[idx] = aligned;
    pool.sizes[idx] = size;
    pool.count = pool.count + 1;
    pool.data_len = needed;
    ret idx;
}

pub fun data_get(pool: *DataPool, idx: i32) *u8 {
    if (pool == nil || idx < 0 || idx >= pool.count) { ret nil; }
    ret ?pool.data[pool.offsets[idx]];
}

pub fun data_intern_i32(alloc: *allocator.Allocator, pool: *DataPool, value: i32) i32 {
    var v: i32 = value;
    ret data_intern(alloc, pool, (?v)::*u8, 4);
}

pub fun data_get_i32(pool: *DataPool, idx: i32) i32 {
    val ptr: *u8 = data_get(pool, idx);
    if (ptr == nil) { ret 0; }
    ret @(ptr::*i32);
}

# data_pool_destroy: free all memory owned by a data pool.
pub fun data_pool_destroy(alloc: *allocator.Allocator, pool: *DataPool) {
    if (alloc == nil || pool == nil) { ret; }
    if (pool.data != nil) {
        allocator.allocator_free[u8](alloc, pool.data, pool.data_cap::usize);
        pool.data = nil;
    }
    if (pool.offsets != nil) {
        allocator.allocator_free[i32](alloc, pool.offsets, pool.cap::usize);
        pool.offsets = nil;
    }
    if (pool.sizes != nil) {
        allocator.allocator_free[i32](alloc, pool.sizes, pool.cap::usize);
        pool.sizes = nil;
    }
    pool.count = 0;
    pool.cap = 0;
    pool.data_len = 0;
    pool.data_cap = 0;
}

# ================================================================
# string comparison helper
# ================================================================

fun str_equals(a: str, b: str) bool {
    if (a == nil && b == nil) { ret true; }
    if (a == nil || b == nil) { ret false; }
    if (a == b) { ret true; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}
