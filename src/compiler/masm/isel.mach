    emit_instr(ctx, instr);
}

# emit_jmp_label: emit JMP label instruction.
# ---
# ctx:    isel context
# target: target label name
pub fun emit_jmp_label(ctx: *ISelContext, target: str) {
    val dst: operand.Operand = operand.label(target);
    var instr: spec.Instruction = make_instruction(x86.OP_JMP, dst, operand.none(), operand.none(), 0);
    instr.flags = instr.flags | spec.FLAG_NEAR_JUMP;
    emit_instr(ctx, instr);
}

# emit_jcc_label: emit conditional JMP label instruction.
# ---
# ctx:       isel context
# cc_opcode: condition code (JE, JNE, JL, etc.)
# target:    target label name
pub fun emit_jcc_label(ctx: *ISelContext, cc_opcode: i32, target: str) {
    val dst: operand.Operand = operand.label(target);
    var instr: spec.Instruction = make_instruction(cc_opcode, dst, operand.none(), operand.none(), 0);
    instr.flags = instr.flags | spec.FLAG_NEAR_JUMP;
    emit_instr(ctx, instr);
}

# emit_call_label: emit CALL label instruction.
# ---
# ctx:    isel context
# target: target label name
pub fun emit_call_label(ctx: *ISelContext, target: str) {
    val dst: operand.Operand = operand.label(target);
    var instr: spec.Instruction = make_instruction(x86.OP_CALL, dst, operand.none(), operand.none(), 0);
    instr.flags = instr.flags | spec.FLAG_NEAR_JUMP;
    emit_instr(ctx, instr);
}

# emit_call_reg: emit indirect CALL reg instruction.
# ---
# ctx: isel context
# reg: register containing function address
pub fun emit_call_reg(ctx: *ISelContext, reg: i32) {
    val src: operand.Operand = operand.reg(reg, 8);
    var instr: spec.Instruction = make_instruction(x86.OP_CALL, operand.none(), src, operand.none(), 8);
    instr.flags = instr.flags | spec.FLAG_INDIRECT;
    emit_instr(ctx, instr);
}

# emit_load_mem_chunked: load odd-size value into register using scratch.
# ---
# ctx:      isel context
# base_reg: base register
# disp:     displacement
# size:     size to load
# dest:     destination register (0=RAX, 1=RCX)
pub fun emit_load_mem_chunked(ctx: *ISelContext, base_reg: i32, disp: i64, size: usize, dest: i32) {
    if (ctx == nil) {
        ret;
    }

    # zero destination register
    emit_xor_reg_reg(ctx, dest);

    var remaining: usize = size;
    var offset: i64 = 0;
    val scratch: i32 = x86.REG_RDX;

    for (remaining > 0) {
        var chunk: usize = 1;
        if (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        val chunk_disp: i64 = disp + offset;
        if (chunk == 4) {
            emit_mov_reg_mem(ctx, scratch, base_reg, chunk_disp, 4);
        } or {
            emit_movzx_reg_mem(ctx, scratch, base_reg, chunk_disp, chunk, 4);
        }

        if (offset > 0) {
            emit_shl_reg_imm(ctx, scratch, offset * 8);
        }

        emit_or_reg_reg(ctx, dest, scratch);

        offset = offset + chunk::i64;
        remaining = remaining - chunk;
    }
}

# emit_store_mem_chunked: store odd-size value from register using scratch.
# ---
# ctx:      isel context
# base_reg: base register
# disp:     displacement
# size:     size to store
# src:      source register (0=RAX, 1=RCX)
pub fun emit_store_mem_chunked(ctx: *ISelContext, base_reg: i32, disp: i64, size: usize, src: i32) {
    if (ctx == nil) {
        ret;
    }

    var remaining: usize = size;
    var offset: i64 = 0;
    val scratch: i32 = x86.REG_RDX;

    for (remaining > 0) {
        var chunk: usize = 1;
        if (remaining >= 4) {
            chunk = 4;
        } or (remaining >= 2) {
            chunk = 2;
        }

        emit_mov_reg_reg(ctx, scratch, src, 8);
        if (offset > 0) {
            emit_shr_reg_imm(ctx, scratch, offset * 8);
        }

        val chunk_disp: i64 = disp + offset;
        if (chunk == 1) {
            # store byte - need to handle specially
            emit_mov_mem_reg(ctx, base_reg, chunk_disp, scratch, 1);
        } or (chunk == 2) {
            emit_mov_mem_reg(ctx, base_reg, chunk_disp, scratch, 2);
        } or {
            emit_mov_mem_reg(ctx, base_reg, chunk_disp, scratch, 4);
        }

        offset = offset + chunk::i64;
        remaining = remaining - chunk;
    }
}

# load_vreg_to_rax: load a virtual register's value into RAX.
# ---
# ctx:     isel context
# vreg_id: virtual register id
# size:    operand size
pub fun load_vreg_to_rax(ctx: *ISelContext, vreg_id: i32, size: usize) {
    if (ctx == nil) {
        ret;
    }

    val off: i32 = get_vreg_offset(ctx, vreg_id, size);
    val disp: i64 = -off::i64;

    if (needs_chunked_move(size)) {
        emit_load_mem_chunked(ctx, x86.REG_RBP, disp, size, x86.REG_RAX);
        ret;
    }

    if (size == 1) {
        emit_movzx_reg_mem(ctx, x86.REG_RAX, x86.REG_RBP, disp, 1, 8);
    } or (size == 2) {
        emit_movzx_reg_mem(ctx, x86.REG_RAX, x86.REG_RBP, disp, 2, 8);
    } or (size == 4) {
        emit_mov_reg_mem(ctx, x86.REG_RAX, x86.REG_RBP, disp, 4);
    } or {
        emit_mov_reg_mem(ctx, x86.REG_RAX, x86.REG_RBP, disp, 8);
    }
}

# store_rax_to_vreg: store RAX value to a virtual register's stack slot.
# ---
# ctx:     isel context
# vreg_id: virtual register id
# size:    operand size
pub fun store_rax_to_vreg(ctx: *ISelContext, vreg_id: i32, size: usize) {
    if (ctx == nil) {
        ret;
    }

    val off: i32 = get_vreg_offset(ctx, vreg_id, size);
    val disp: i64 = -off::i64;

    if (needs_chunked_move(size)) {
        emit_store_mem_chunked(ctx, x86.REG_RBP, disp, size, x86.REG_RAX);
        ret;
    }

    emit_mov_mem_reg(ctx, x86.REG_RBP, disp, x86.REG_RAX, size);
}

# load_vreg_to_rcx: load a virtual register's value into RCX.
# ---
# ctx:     isel context
# vreg_id: virtual register id
# size:    operand size
pub fun load_vreg_to_rcx(ctx: *ISelContext, vreg_id: i32, size: usize) {
    if (ctx == nil) {
        ret;
    }

    val off: i32 = get_vreg_offset(ctx, vreg_id, size);
    val disp: i64 = -off::i64;

    if (needs_chunked_move(size)) {
        emit_load_mem_chunked(ctx, x86.REG_RBP, disp, size, x86.REG_RCX);
        ret;
    }

    if (size == 1) {
        emit_movzx_reg_mem(ctx, x86.REG_RCX, x86.REG_RBP, disp, 1, 8);
    } or (size == 2) {
        emit_movzx_reg_mem(ctx, x86.REG_RCX, x86.REG_RBP, disp, 2, 8);
    } or (size == 4) {
        emit_mov_reg_mem(ctx, x86.REG_RCX, x86.REG_RBP, disp, 4);
    } or {
        emit_mov_reg_mem(ctx, x86.REG_RCX, x86.REG_RBP, disp, 8);
    }
}

# select_mov: handle MOV instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_mov(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    # handle immediate source
    if (src.kind == ir.VAL_IMM) {
        # MOV dst, imm
        if (dst.kind == ir.VAL_REG && dst.reg < VREG_START) {
            emit_mov_reg_imm(ctx, dst.reg, src.imm, dst.size);
        } or {
            emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
            if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
                store_rax_to_vreg(ctx, dst.reg, dst.size);
            }
        }
        ret;
    }

    # handle label source
    if (src.kind == ir.VAL_LABEL) {
        # load address into physical reg
        emit_mov_reg_imm(ctx, x86.REG_RAX, 0, 8);
        # add relocation for absolute address
        val reloc_offset: usize = section.current_offset(ctx.text) - 8;
        section.add_relocation(ctx.alloc, ctx.text, reloc_offset, src.label, section.RELOC_64, 0);
        if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
            store_rax_to_vreg(ctx, dst.reg, dst.size);
        }
        ret;
    }

    # handle register source
    if (src.kind == ir.VAL_REG) {
        # reg -> reg/vreg
        if (dst.kind == ir.VAL_REG && dst.reg < VREG_START && src.reg < VREG_START) {
            if (dst.reg != src.reg) {
                emit_mov_reg_reg(ctx, dst.reg, src.reg, dst.size);
            }
            ret;
        }

        if (src.reg >= VREG_START) {
            # load vreg to RAX
            load_vreg_to_rax(ctx, src.reg, src.size);
        } or {
            if (src.reg != x86.REG_RAX) {
                emit_mov_reg_reg(ctx, x86.REG_RAX, src.reg, src.size);
            }
        }

        if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
            store_rax_to_vreg(ctx, dst.reg, dst.size);
        } or (dst.kind == ir.VAL_REG && dst.reg < VREG_START) {
            if (dst.reg != x86.REG_RAX) {
                emit_mov_reg_reg(ctx, dst.reg, x86.REG_RAX, dst.size);
            }
        }
    }
}

# compute_addr_rcx: compute effective address of mem operand into RCX.
# ---
# uses RAX as scratch for index scaling.
pub fun compute_addr_rcx(ctx: *ISelContext, mem: ir.IRValue) {
    if (ctx == nil) {
        ret;
    }

    # base
    if (mem.base_reg >= VREG_START) {
        load_vreg_to_rcx(ctx, mem.base_reg, ctx.ptr_size);
    } or (mem.base_reg >= 0) {
        emit_mov_reg_reg(ctx, x86.REG_RCX, mem.base_reg, 8);
    } or {
        # no base: zero RCX
        emit_xor_reg_reg(ctx, x86.REG_RCX);
    }

    # index
    if (mem.index_reg == mem.base_reg) {
        emit_add_reg_imm(ctx, x86.REG_RCX, mem.offset::i64, 8);
        ret;
    }
    if (mem.index_reg >= VREG_START) {
        load_vreg_to_rax(ctx, mem.index_reg, ctx.ptr_size);
    } or (mem.index_reg >= 0) {
        emit_mov_reg_reg(ctx, x86.REG_RAX, mem.index_reg, 8);
    } or {
        # no index
        emit_add_reg_imm(ctx, x86.REG_RCX, mem.offset::i64, 8);
        ret;
    }

    # apply scale
    if (mem.scale == 2) {
        emit_shl_reg_imm(ctx, x86.REG_RAX, 1);
    }
    if (mem.scale == 4) {
        emit_shl_reg_imm(ctx, x86.REG_RAX, 2);
    }
    if (mem.scale == 8) {
        emit_shl_reg_imm(ctx, x86.REG_RAX, 3);
    }

    # add index into base
    emit_alu_reg_reg(ctx, x86.OP_ADD, x86.REG_RCX, x86.REG_RAX, 8);

    # add offset
    emit_add_reg_imm(ctx, x86.REG_RCX, mem.offset::i64, 8);
}

# compute_addr_rax: compute effective address of mem operand into RAX.
# ---
# uses RCX as scratch for index.
pub fun compute_addr_rax(ctx: *ISelContext, mem: ir.IRValue) {
    if (ctx == nil) {
        ret;
    }

    # base
    if (mem.base_reg >= VREG_START) {
        load_vreg_to_rax(ctx, mem.base_reg, ctx.ptr_size);
    } or (mem.base_reg >= 0) {
        emit_mov_reg_reg(ctx, x86.REG_RAX, mem.base_reg, 8);
    } or {
        # zero RAX
        emit_xor_reg_reg(ctx, x86.REG_RAX);
    }

    # index
    if (mem.index_reg == mem.base_reg) {
        emit_add_reg_imm(ctx, x86.REG_RAX, mem.offset::i64, 8);
        ret;
    }
    if (mem.index_reg >= VREG_START) {
        load_vreg_to_rcx(ctx, mem.index_reg, ctx.ptr_size);
    } or (mem.index_reg >= 0) {
        emit_mov_reg_reg(ctx, x86.REG_RCX, mem.index_reg, 8);
    } or {
        emit_add_reg_imm(ctx, x86.REG_RAX, mem.offset::i64, 8);
        ret;
    }

    if (mem.scale == 2) {
        emit_shl_reg_imm(ctx, x86.REG_RCX, 1);
    }
    if (mem.scale == 4) {
        emit_shl_reg_imm(ctx, x86.REG_RCX, 2);
    }
    if (mem.scale == 8) {
        emit_shl_reg_imm(ctx, x86.REG_RCX, 3);
    }

    # add rcx into rax
    emit_alu_reg_reg(ctx, x86.OP_ADD, x86.REG_RAX, x86.REG_RCX, 8);

    emit_add_reg_imm(ctx, x86.REG_RAX, mem.offset::i64, 8);
}

# select_load: handle LOAD instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_load(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    # handle memory source
    if (src.kind == ir.VAL_MEM) {
        if (needs_chunked_move(src.size)) {
            compute_addr_rcx(ctx, src);
            emit_load_mem_chunked(ctx, x86.REG_RCX, 0, src.size, x86.REG_RAX);
        } or {
            compute_addr_rax(ctx, src);
            # load from [RAX] with size
            if (src.size == 1) {
                emit_movzx_reg_mem(ctx, x86.REG_RAX, x86.REG_RAX, 0, 1, 8);
            } or (src.size == 2) {
                emit_movzx_reg_mem(ctx, x86.REG_RAX, x86.REG_RAX, 0, 2, 8);
            } or (src.size == 4) {
                emit_mov_reg_mem(ctx, x86.REG_RAX, x86.REG_RAX, 0, 4);
            } or {
                emit_mov_reg_mem(ctx, x86.REG_RAX, x86.REG_RAX, 0, 8);
            }
        }
    }

    # store result
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_store: handle STORE instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_store(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val addr: ir.IRValue = instr.dst;   # destination address
    val value: ir.IRValue = instr.src1; # value to store

    # load value into RAX
    if (value.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, value.imm, 8);
    } or (value.kind == ir.VAL_REG && value.reg >= VREG_START) {
        load_vreg_to_rax(ctx, value.reg, value.size);
    } or (value.kind == ir.VAL_REG && value.reg < VREG_START) {
        if (value.reg != x86.REG_RAX) {
            emit_mov_reg_reg(ctx, x86.REG_RAX, value.reg, value.size);
        }
    }

    # load address into RCX
    if (addr.kind == ir.VAL_REG && addr.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, addr.reg, 8);
    } or (addr.kind == ir.VAL_REG && addr.reg >= 0) {
        emit_mov_reg_reg(ctx, x86.REG_RCX, addr.reg, 8);
    } or (addr.kind == ir.VAL_MEM) {
        compute_addr_rcx(ctx, addr);
    }

    if (needs_chunked_move(value.size)) {
        emit_store_mem_chunked(ctx, x86.REG_RCX, 0, value.size, x86.REG_RAX);
        ret;
    }

    # MOV [RCX], RAX (size-aware)
    emit_mov_mem_reg(ctx, x86.REG_RCX, 0, x86.REG_RAX, value.size);
}

# select_add: handle ADD instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_add(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    # load lhs into RAX
    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    # add rhs
    if (rhs.kind == ir.VAL_IMM) {
        emit_alu_reg_imm(ctx, x86.OP_ADD, x86.REG_RAX, rhs.imm, 8);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_alu_reg_reg(ctx, x86.OP_ADD, x86.REG_RAX, x86.REG_RCX, 8);
    }

    # store result
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_sub: handle SUB instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_sub(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    # load lhs into RAX
    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    # sub rhs
    if (rhs.kind == ir.VAL_IMM) {
        emit_alu_reg_imm(ctx, x86.OP_SUB, x86.REG_RAX, rhs.imm, 8);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_alu_reg_reg(ctx, x86.OP_SUB, x86.REG_RAX, x86.REG_RCX, 8);
    }

    # store result
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    } or (dst.kind == ir.VAL_REG && dst.reg < VREG_START) {
        if (dst.reg != x86.REG_RAX) {
            emit_mov_reg_reg(ctx, dst.reg, x86.REG_RAX, 8);
        }
    }
}

# select_lea: handle LEA instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_lea(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    # LEA loads an address, not the value at that address
    if (src.kind == ir.VAL_MEM) {
        compute_addr_rax(ctx, src);
    }

    # store result
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_mul: handle MUL instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_mul(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    # load lhs into RAX
    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_imul_reg_reg(ctx, x86.REG_RAX, x86.REG_RCX, 8);
    } or (rhs.kind == ir.VAL_IMM) {
        emit_imul_reg_imm(ctx, x86.REG_RAX, rhs.imm, 8);
    }

    # store result
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_div: handle DIV instruction (signed).
# ---
# ctx:    isel context
# instr:  IR instruction
# signed: true for IDIV, false for DIV
pub fun select_div(ctx: *ISelContext, instr: *ir.Instr, signed: bool) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    # load dividend into RAX
    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    # sign-extend RAX into RDX:RAX with CQO
    emit_cqo(ctx);

    # load divisor into RCX
    if (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
    } or (rhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RCX, rhs.imm, 8);
    }

    # IDIV RCX
    emit_idiv_reg(ctx, x86.REG_RCX, 8);

    # quotient is in RAX
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_mod: handle MOD instruction.
# ---
# ctx:    isel context
# instr:  IR instruction
# signed: true for signed mod
pub fun select_mod(ctx: *ISelContext, instr: *ir.Instr, signed: bool) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    # load dividend into RAX
    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    # CQO
    emit_cqo(ctx);

    # load divisor into RCX
    if (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
    } or (rhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RCX, rhs.imm, 8);
    }

    # IDIV RCX
    emit_idiv_reg(ctx, x86.REG_RCX, 8);

    # remainder is in RDX - move to RAX
    emit_mov_reg_reg(ctx, x86.REG_RAX, x86.REG_RDX, 8);

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_neg: handle NEG instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_neg(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    if (src.kind == ir.VAL_REG && src.reg >= VREG_START) {
        load_vreg_to_rax(ctx, src.reg, src.size);
    } or (src.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
    }

    emit_neg_reg(ctx, x86.REG_RAX, 8);

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_and: handle AND instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_and(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_IMM) {
        emit_alu_reg_imm(ctx, x86.OP_AND, x86.REG_RAX, rhs.imm, 8);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_alu_reg_reg(ctx, x86.OP_AND, x86.REG_RAX, x86.REG_RCX, 8);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_or: handle OR instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_or(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_IMM) {
        emit_alu_reg_imm(ctx, x86.OP_OR, x86.REG_RAX, rhs.imm, 8);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_alu_reg_reg(ctx, x86.OP_OR, x86.REG_RAX, x86.REG_RCX, 8);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_xor: handle XOR instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_xor(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_IMM) {
        emit_alu_reg_imm(ctx, x86.OP_XOR, x86.REG_RAX, rhs.imm, 8);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_alu_reg_reg(ctx, x86.OP_XOR, x86.REG_RAX, x86.REG_RCX, 8);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_not: handle NOT instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_not(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    if (src.kind == ir.VAL_REG && src.reg >= VREG_START) {
        load_vreg_to_rax(ctx, src.reg, src.size);
    } or (src.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
    }

    emit_not_reg(ctx, x86.REG_RAX, 8);

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_shl: handle SHL instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_shl(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_IMM) {
        emit_shl_reg_imm(ctx, x86.REG_RAX, rhs.imm);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        # shift amount must be in CL
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        # emit SHL RAX, CL using encoder
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.reg(x86.REG_RCX, 1);
        val instr_op: spec.Instruction = make_instruction(x86.OP_SHL, dst_op, dst_op, src_op, 8);
        emit_instr(ctx, instr_op);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_shr: handle SHR instruction (logical).
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_shr(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_IMM) {
        emit_shr_reg_imm(ctx, x86.REG_RAX, rhs.imm);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.reg(x86.REG_RCX, 1);
        val instr_op: spec.Instruction = make_instruction(x86.OP_SHR, dst_op, dst_op, src_op, 8);
        emit_instr(ctx, instr_op);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_sar: handle SAR instruction (arithmetic).
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_sar(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    if (rhs.kind == ir.VAL_IMM) {
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.imm(rhs.imm, 1);
        val instr_op: spec.Instruction = make_instruction(x86.OP_SAR, dst_op, dst_op, src_op, 8);
        emit_instr(ctx, instr_op);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.reg(x86.REG_RCX, 1);
        val instr_op: spec.Instruction = make_instruction(x86.OP_SAR, dst_op, dst_op, src_op, 8);
        emit_instr(ctx, instr_op);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_jmp: handle JMP instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_jmp(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    # target is in dst or src1 as label
    var target: str = nil;
    if (instr.dst.kind == ir.VAL_LABEL) {
        target = instr.dst.label;
    } or (instr.src1.kind == ir.VAL_LABEL) {
        target = instr.src1.label;
    }

    if (target != nil) {
        emit_jmp_label(ctx, target);
    }
}

# select_jcc: handle conditional jump instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_jcc(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    # target label
    var target: str = nil;
    if (instr.dst.kind == ir.VAL_LABEL) {
        target = instr.dst.label;
    }

    if (target == nil) {
        ret;
    }

    # map condition to x86 Jcc opcode
    var cc_opcode: i32 = x86.OP_JE;  # default

    val cond: i32 = instr.cond::i32;
    if (cond == 0) {        # E
        cc_opcode = x86.OP_JE;
    } or (cond == 1) {      # NE
        cc_opcode = x86.OP_JNE;
    } or (cond == 2) {      # L
        cc_opcode = x86.OP_JL;
    } or (cond == 3) {      # LE
        cc_opcode = x86.OP_JLE;
    } or (cond == 4) {      # G
        cc_opcode = x86.OP_JG;
    } or (cond == 5) {      # GE
        cc_opcode = x86.OP_JGE;
    } or (cond == 6) {      # B
        cc_opcode = x86.OP_JB;
    } or (cond == 7) {      # BE
        cc_opcode = x86.OP_JBE;
    } or (cond == 8) {      # A
        cc_opcode = x86.OP_JA;
    } or (cond == 9) {      # AE
        cc_opcode = x86.OP_JAE;
    }

    emit_jcc_label(ctx, cc_opcode, target);
}

# select_call: handle CALL instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_call(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    # target is typically a label
    var target: str = nil;
    if (instr.src1.kind == ir.VAL_LABEL) {
        target = instr.src1.label;
    } or (instr.dst.kind == ir.VAL_LABEL) {
        target = instr.dst.label;
    }

    if (target != nil) {
        emit_call_label(ctx, target);
    } or {
        # indirect call through register
        if (instr.src1.kind == ir.VAL_REG && instr.src1.reg >= VREG_START) {
            load_vreg_to_rax(ctx, instr.src1.reg, 8);
            emit_call_reg(ctx, x86.REG_RAX);
        }
    }
}

# select_push: handle PUSH instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_push(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val src: ir.IRValue = instr.src1;

    if (src.kind == ir.VAL_REG && src.reg >= VREG_START) {
        load_vreg_to_rax(ctx, src.reg, 8);
        emit_push_reg(ctx, x86.REG_RAX);
    } or (src.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
        emit_push_reg(ctx, x86.REG_RAX);
    }
}

# select_pop: handle POP instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_pop(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;

    emit_pop_reg(ctx, x86.REG_RAX);

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_setcc: handle SETcc instruction.
# ---
# ctx:      isel context
# instr:    IR instruction
# cc_byte:  x86 SETcc byte (e.g. 0x94 for SETE)
pub fun select_setcc(ctx: *ISelContext, instr: *ir.Instr, cc_byte: u8) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;

    # emit SETcc AL followed by MOVZX RAX, AL
    # for now emit as NOP - need more complex encoding support
    emit_nop(ctx);

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_zext: handle zero extension.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_zext(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    # load source
    if (src.kind == ir.VAL_REG && src.reg >= VREG_START) {
        load_vreg_to_rax(ctx, src.reg, src.size);
    } or (src.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
    }

    # mask to source size bits
    if (src.size == 1) {
        emit_movzx_reg_mem(ctx, x86.REG_RAX, x86.REG_RAX, 0, 1, 8);
    } or (src.size == 2) {
        emit_movzx_reg_mem(ctx, x86.REG_RAX, x86.REG_RAX, 0, 2, 8);
    } or (src.size == 4) {
        # MOV EAX, EAX (zero-extends to 64-bit)
        emit_mov_reg_reg(ctx, x86.REG_RAX, x86.REG_RAX, 4);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_sext: handle sign extension.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_sext(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    if (src.kind == ir.VAL_REG && src.reg >= VREG_START) {
        load_vreg_to_rax(ctx, src.reg, src.size);
    } or (src.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
    }

    # sign extend based on source size
    # MOVSX RAX, reg - using MOVSX opcode
    if (src.size == 1) {
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.reg(x86.REG_RAX, 1);
        val instr_op: spec.Instruction = make_instruction(x86.OP_MOVSX, dst_op, src_op, operand.none(), 8);
        emit_instr(ctx, instr_op);
    } or (src.size == 2) {
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.reg(x86.REG_RAX, 2);
        val instr_op: spec.Instruction = make_instruction(x86.OP_MOVSX, dst_op, src_op, operand.none(), 8);
        emit_instr(ctx, instr_op);
    } or (src.size == 4) {
        # MOVSXD RAX, EAX
        val dst_op: operand.Operand = operand.reg(x86.REG_RAX, 8);
        val src_op: operand.Operand = operand.reg(x86.REG_RAX, 4);
        val instr_op: spec.Instruction = make_instruction(x86.OP_MOVSX, dst_op, src_op, operand.none(), 8);
        emit_instr(ctx, instr_op);
    }

    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_trunc: handle truncation.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_trunc(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val dst: ir.IRValue = instr.dst;
    val src: ir.IRValue = instr.src1;

    # load source (truncation is just using the lower bits)
    if (src.kind == ir.VAL_REG && src.reg >= VREG_START) {
        load_vreg_to_rax(ctx, src.reg, src.size);
    } or (src.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, src.imm, 8);
    }

    # no masking needed - just store to smaller destination
    if (dst.kind == ir.VAL_REG && dst.reg >= VREG_START) {
        store_rax_to_vreg(ctx, dst.reg, dst.size);
    }
}

# select_cmp: handle CMP instruction.
# ---
# ctx:   isel context
# instr: IR instruction
pub fun select_cmp(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    val lhs: ir.IRValue = instr.src1;
    val rhs: ir.IRValue = instr.src2;

    # load lhs into RAX
    if (lhs.kind == ir.VAL_REG && lhs.reg >= VREG_START) {
        load_vreg_to_rax(ctx, lhs.reg, lhs.size);
    } or (lhs.kind == ir.VAL_IMM) {
        emit_mov_reg_imm(ctx, x86.REG_RAX, lhs.imm, 8);
    }

    # cmp with rhs
    if (rhs.kind == ir.VAL_IMM) {
        emit_cmp_reg_imm(ctx, x86.REG_RAX, rhs.imm, 8);
    } or (rhs.kind == ir.VAL_REG && rhs.reg >= VREG_START) {
        load_vreg_to_rcx(ctx, rhs.reg, rhs.size);
        emit_cmp_reg_reg(ctx, x86.REG_RAX, x86.REG_RCX, 8);
    }
}

# select_instr: convert a single IR instruction to machine code.
# ---
# ctx:   isel context
# instr: IR instruction to convert
pub fun select_instr(ctx: *ISelContext, instr: *ir.Instr) {
    if (ctx == nil || instr == nil) {
        ret;
    }

    # get opcode tag from union
    val op_tag: u8 = ir.get_op_tag(?instr.op);

    if (op_tag == ir.OP_LABEL) {
        # label pseudo-instruction - record current offset as symbol
        if (instr.dst.kind == ir.VAL_LABEL && instr.dst.label != nil) {
            val label_name: str = instr.dst.label;
            if (ctx.m != nil) {
                val existing: *sym.Symbol = masm.get_symbol(ctx.m, label_name);
                if (existing != nil) {
                    if (existing.sym_type.tag != sym.SYM_FUNC) {
                        existing.offset = section.current_offset(ctx.text);
                    }
                } or {
                    val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, label_name);
                    if (sym_res.is_ok()) {
                        val s: *sym.Symbol = sym_res.unwrap_ok();
                        s.offset = section.current_offset(ctx.text);
                        sym.set_binding(s, sym.bind_local());
                        sym.set_type(s, sym.sym_none());
                        masm.add_symbol(ctx.m, s);
                    }
                }
            }
        }
    }
    or (op_tag == ir.OP_NOP) {
        emit_nop(ctx);
    }
    or (op_tag == ir.OP_MOV) {
        select_mov(ctx, instr);
    }
    or (op_tag == ir.OP_LOAD) {
        select_load(ctx, instr);
    }
    or (op_tag == ir.OP_STORE) {
        select_store(ctx, instr);
    }
    or (op_tag == ir.OP_LEA) {
        select_lea(ctx, instr);
    }
    or (op_tag == ir.OP_ADD) {
        select_add(ctx, instr);
    }
    or (op_tag == ir.OP_SUB) {
        select_sub(ctx, instr);
    }
    or (op_tag == ir.OP_MUL) {
        select_mul(ctx, instr);
    }
    or (op_tag == ir.OP_DIV) {
        select_div(ctx, instr, true);  # signed
    }
    or (op_tag == ir.OP_MOD) {
        select_mod(ctx, instr, true);  # signed
    }
    or (op_tag == ir.OP_NEG) {
        select_neg(ctx, instr);
    }
    or (op_tag == ir.OP_AND) {
        select_and(ctx, instr);
    }
    or (op_tag == ir.OP_OR) {
        select_or(ctx, instr);
    }
    or (op_tag == ir.OP_XOR) {
        select_xor(ctx, instr);
    }
    or (op_tag == ir.OP_NOT) {
        select_not(ctx, instr);
    }
    or (op_tag == ir.OP_SHL) {
        select_shl(ctx, instr);
    }
    or (op_tag == ir.OP_SHR) {
        select_shr(ctx, instr);
    }
    or (op_tag == ir.OP_SAR) {
        select_sar(ctx, instr);
    }
    or (op_tag == ir.OP_CMP) {
        select_cmp(ctx, instr);
    }
    or (op_tag == ir.OP_JMP) {
        select_jmp(ctx, instr);
    }
    or (op_tag == ir.OP_JCC) {
        select_jcc(ctx, instr);
    }
    or (op_tag == ir.OP_CALL) {
        select_call(ctx, instr);
    }
    or (op_tag == ir.OP_SYSCALL) {
        emit_syscall(ctx);
    }
    or (op_tag == ir.OP_RET) {
        # epilogue handles stack cleanup and RET, but we need to move
        # return value to RAX if one is provided in instr.dst
        val ret_val: ir.IRValue = instr.dst;
        if (ret_val.kind != ir.VAL_NONE) {
            # there's a return value to put in RAX
            if (ret_val.kind == ir.VAL_IMM) {
                # move immediate to RAX
                emit_mov_reg_imm(ctx, x86.REG_RAX, ret_val.imm, 8);
            } or (ret_val.kind == ir.VAL_REG) {
                if (ret_val.reg >= VREG_START) {
                    # load virtual register to RAX
                    load_vreg_to_rax(ctx, ret_val.reg, ret_val.size);
                } or (ret_val.reg != x86.REG_RAX) {
                    # physical register that's not RAX, move to RAX
                    emit_mov_reg_reg(ctx, x86.REG_RAX, ret_val.reg, 8);
                }
                # else: already in RAX, nothing to do
            }
        }
    }
    or (op_tag == ir.OP_PUSH) {
        select_push(ctx, instr);
    }
    or (op_tag == ir.OP_POP) {
        select_pop(ctx, instr);
    }
    or (op_tag == ir.OP_SETE) {
        select_setcc(ctx, instr, 148);  # 0x94 = SETE
    }
    or (op_tag == ir.OP_SETNE) {
        select_setcc(ctx, instr, 149);  # 0x95 = SETNE
    }
    or (op_tag == ir.OP_SETL) {
        select_setcc(ctx, instr, 156);  # 0x9C = SETL
    }
    or (op_tag == ir.OP_SETLE) {
        select_setcc(ctx, instr, 158);  # 0x9E = SETLE
    }
    or (op_tag == ir.OP_SETG) {
        select_setcc(ctx, instr, 159);  # 0x9F = SETG
    }
    or (op_tag == ir.OP_SETGE) {
        select_setcc(ctx, instr, 157);  # 0x9D = SETGE
    }
    or (op_tag == ir.OP_SETB) {
        select_setcc(ctx, instr, 146);  # 0x92 = SETB
    }
    or (op_tag == ir.OP_SETBE) {
        select_setcc(ctx, instr, 150);  # 0x96 = SETBE
    }
    or (op_tag == ir.OP_SETA) {
        select_setcc(ctx, instr, 151);  # 0x97 = SETA
    }
    or (op_tag == ir.OP_SETAE) {
        select_setcc(ctx, instr, 147);  # 0x93 = SETAE
    }
    or (op_tag == ir.OP_ZEXT) {
        select_zext(ctx, instr);
    }
    or (op_tag == ir.OP_SEXT) {
        select_sext(ctx, instr);
    }
    or (op_tag == ir.OP_TRUNC) {
        select_trunc(ctx, instr);
    }
    or {
        # unhandled opcode - emit NOP as placeholder
        emit_nop(ctx);
    }
}

# select_block: convert a basic block to machine code.
# ---
# ctx:   isel context
# block: IR block to convert
pub fun select_block(ctx: *ISelContext, block: *ir.IRBlock) {
    if (ctx == nil || block == nil) {
        ret;
    }

    # emit block label if present
    if (block.label != nil && ctx.m != nil) {
        val sym_res: Result[*sym.Symbol, str] = sym.create(ctx.alloc, block.label);
        if (sym_res.is_ok()) {
            val s: *sym.Symbol = sym_res.unwrap_ok();
            s.offset = section.current_offset(ctx.text);
            sym.set_binding(s, sym.bind_local());
            sym.set_type(s, sym.sym_none());
            masm.add_symbol(ctx.m, s);
        }
    }

    # process each instruction
    var i: i32 = 0;
    for (i < block.instr_count) {
        select_instr(ctx, ?block.instrs[i]);
        i = i + 1;
    }
}

# emit_prologue: emit function prologue.
# ---
# ctx:       isel context
# stack_size: total stack size to allocate
pub fun emit_prologue(ctx: *ISelContext, stack_size: usize) {
    emit_push_reg(ctx, x86.REG_RBP);
    emit_mov_reg_reg(ctx, x86.REG_RBP, x86.REG_RSP, 8);
    if (stack_size > 0) {
        emit_sub_reg_imm(ctx, x86.REG_RSP, stack_size::i64, 8);
    }
}

# emit_epilogue: emit function epilogue.
# ---
# ctx:       isel context
# stack_size: total stack size to deallocate
pub fun emit_epilogue(ctx: *ISelContext, stack_size: usize) {
    if (stack_size > 0) {
        emit_add_reg_imm(ctx, x86.REG_RSP, stack_size::i64, 8);
    }
    emit_pop_reg(ctx, x86.REG_RBP);
    emit_ret(ctx);
}

# select_function: convert an IR function to machine code.
# ---
# ctx:  isel context
# func: IR function to convert
# ret:  Ok(true) on success, Err(str) on failure
pub fun select_function(ctx: *ISelContext, func: *ir.IRFunction) Result[bool, str] {
    if (ctx == nil) {
        ret err[bool, str]("isel context is nil");
    }
    if (func == nil) {
        ret err[bool, str]("function is nil");
    }
    if (ctx.text == nil) {
        ret err[bool, str]("text section is nil");
    }

    # reset context for new function
    reset(ctx);

    # record function symbol offset
    if (func.name != nil && ctx.m != nil) {
        val existing: *sym.Symbol = masm.get_symbol(ctx.m, func.name);
        if (existing != nil) {
            existing.offset = section.current_offset(ctx.text);
        }
    }

    # scan function to compute stack requirements
    ctx.base_stack_size = func.local_size;
    scan_function(ctx, func);

    # check if this is entry point
    var is_entry: bool = false;
    if (func.name != nil && func.name.equals("_start")) {
        is_entry = true;
    }

    # emit prologue (unless entry point)
    if (!is_entry) {
        emit_prologue(ctx, ctx.total_stack_size);
    }

    # process each block
    var bi: i32 = 0;
    for (bi < func.block_count) {
        val block: *ir.IRBlock = func.blocks[bi];
        if (block != nil) {
            select_block(ctx, block);
        }
        bi = bi + 1;
    }

    # emit epilogue (unless entry point - _start should exit via syscall)
    if (!is_entry) {
        emit_epilogue(ctx, ctx.total_stack_size);
    }

    ret ok[bool, str](true);
}

# run_isel: run instruction selection on all functions in Masm context.
# ---
# m:     masm context
# funcs: array of IR functions
# count: number of functions
# alloc: allocator
# ret:   Ok(true) on success, Err(str) on failure
pub fun run_isel(m: *masm.Masm, funcs: **ir.IRFunction, count: i32, alloc: *allocator.Allocator) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("masm context is nil");
    }
    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    # get or create text section
    val text_res: Result[*section.Section, str] = masm.get_or_create_section(m, ".text", section.section_text());
    if (text_res.is_err()) {
        ret err[bool, str](text_res.unwrap_err());
    }
    val text: *section.Section = text_res.unwrap_ok();

    # create isel context
    var ctx: ISelContext = init(alloc, text, m);

    # process each function
    var i: i32 = 0;
    for (i < count) {
        val func: *ir.IRFunction = funcs[i];
        if (func != nil) {
            val res: Result[bool, str] = select_function(?ctx, func);
            if (res.is_err()) {
                ret res;
            }
        }
        i = i + 1;
    }

    ret ok[bool, str](true);
}
