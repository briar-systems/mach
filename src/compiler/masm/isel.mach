# emit_xor_reg_reg: emit XOR reg, reg instruction (zero register).
# ---
# ctx: isel context
# reg: register to zero
pub fun emit_xor_reg_reg(ctx: *ISelContext, reg: i32) {
    val op: operand.Operand = operand.reg(reg, 8);
    val instr: spec.Instruction = make_instruction(x86.OP_XOR, op, op, op, 8);
    emit_instr(ctx, instr);
}

