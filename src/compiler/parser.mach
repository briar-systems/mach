# synchronize: recover from an error by skipping to a synchronization point.
# ---
# ret: none
pub fun (this: *Parser) synchronize() {
    if (this == nil) {
        ret;
    }

    this.advance();

    for (!this.is_at_end()) {
        # TODO: check for statement boundaries (semicolons, keywords)
        # for now, just advance to EOF
        this.advance();
    }
}

# get_error_count: get the number of parsing errors.
# ---
# ret: error count
pub fun (this: *Parser) get_error_count() i32 {
    if (this == nil) {
        ret 0;
    }
    ret this.error_count;
}
