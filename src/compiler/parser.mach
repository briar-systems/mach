use std.types.size;
use std.types.string;
use std.types.result;
use alloc: std.allocator;
use fmt: std.fmt;
use stream: std.stream;
use stdio: std.system.stdio;

use token: mach.compiler.token;
use lexer: mach.compiler.lexer;
use ast: mach.compiler.ast;

# parser error linked list
pub rec ParserError {
    pos: usize;
    len: usize;
    msg: str;
    next: *ParserError;
}

pub rec Parser {
    lexer: *lexer.Lexer;
    current: token.Token;
    previous: token.Token;
    had_error: bool;
    errors: *ParserError;
}

pub fun init(p: *Parser, lx: *lexer.Lexer) {
    if (p == nil) { ret; }
    p.lexer = lx;
    p.had_error = false;
    p.errors = nil;

    # prime the parser
    p.current = lexer.next(lx);
    if (p.current.kind == token.TOKEN_COMMENT) {
        # ensure we start on a non-comment token
        advance(p);
    }
}

fun at_end(p: *Parser) bool {
    if (p == nil) { ret true; }
    ret (p.current.kind == token.TOKEN_EOF);
}

fun advance(p: *Parser) {
    if (p == nil) { ret; }
    p.previous = p.current;
    for {
        p.current = lexer.next(p.lexer);
        if (p.current.kind != token.TOKEN_COMMENT) { brk; }
        if (p.current.kind == token.TOKEN_EOF) { brk; }
    }
}

fun check(p: *Parser, kind: i32) bool {
    if (p == nil) { ret false; }
    ret (p.current.kind == kind);
}

fun match_token(p: *Parser, kind: i32) bool {
    if (check(p, kind)) { advance(p); ret true; }
    ret false;
}

fun push_error(p: *Parser, pos: usize, len: usize, msg: str) {
    if (p == nil) { ret; }
    p.had_error = true;
    val r: Result[*ParserError, alloc.AllocError] = alloc.default().zalloc[ParserError](1);
    if (r.is_err()) { ret; }
    val e: *ParserError = r.unwrap_ok();
    e.pos = pos;
    e.len = len;
    e.msg = msg;
    e.next = p.errors;
    p.errors = e;
}

fun error_at_current(p: *Parser, msg: str) {
    if (p == nil) { ret; }
    push_error(p, p.current.pos, p.current.len, msg);
}

fun synchronize(p: *Parser) {
    if (p == nil) { ret; }
    advance(p);

    for (!at_end(p)) {
        if (p.previous.kind == token.TOKEN_SEMICOLON) { ret; }

        if (p.current.kind == token.TOKEN_KW_FUN) { ret; }
        if (p.current.kind == token.TOKEN_KW_VAL) { ret; }
        if (p.current.kind == token.TOKEN_KW_VAR) { ret; }
        if (p.current.kind == token.TOKEN_KW_USE) { ret; }

        advance(p);
    }
}

# copy a slice of the source into a new nul-terminated str
fun slice_to_str(p: *Parser, start: usize, len: usize) str {
    if (p == nil || p.lexer == nil || p.lexer.source == nil) { ret nil; }
    val allocr: Result[ptr, alloc.AllocError] = alloc.default().alloc_bytes(len + 1, 1);
    if (allocr.is_err()) { ret nil; }
    val buf: ptr = allocr.unwrap_ok();

    var dst: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < len) {
        dst[i] = p.lexer.source[start + i];
        i = i + 1;
    }
    dst[len] = 0;

    ret buf::str;
}

fun parse_stmt_top(p: *Parser) *ast.AstNode;
fun parse_stmt(p: *Parser) *ast.AstNode;
fun parse_block(p: *Parser) *ast.AstNode;
fun parse_expr(p: *Parser) *ast.AstNode;

# public parse entry
pub fun parse(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }
    val program: *ast.AstNode = ast.alloc_node(ast.AST_PROGRAM, p.current.pos, p.current.len);
    if (program == nil) { ret nil; }

    for (!at_end(p)) {
        val stmt: *ast.AstNode = parse_stmt_top(p);
        if (stmt != nil) { ast.append_child(program, stmt); }
    }

    ret program;
}

fun parse_stmt_top(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }

    # optional pub (currently ignored in this minimal frontend)
    match_token(p, token.TOKEN_KW_PUB);

    if (p.current.kind == token.TOKEN_KW_USE) {
        advance(p); # consume 'use'
        if (p.current.kind != token.TOKEN_IDENTIFIER) {
            error_at_current(p, "expected identifier after 'use'");
            synchronize(p);
            ret nil;
        }

        val name_start: usize = p.current.pos;
        var name_end: usize = p.current.pos + p.current.len;
        advance(p);

        for (match_token(p, token.TOKEN_DOT)) {
            if (p.current.kind != token.TOKEN_IDENTIFIER) {
                error_at_current(p, "expected identifier after '.'");
                synchronize(p);
                ret nil;
            }
            name_end = p.current.pos + p.current.len;
            advance(p);
        }

        val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_USE, name_start, name_end - name_start);
        if (node == nil) { ret nil; }
        node.text = slice_to_str(p, name_start, name_end - name_start);

        match_token(p, token.TOKEN_SEMICOLON);
        ret node;
    }

    if (p.current.kind == token.TOKEN_KW_FUN) {
        advance(p); # consume 'fun'
        if (p.current.kind != token.TOKEN_IDENTIFIER) {
            error_at_current(p, "expected function name");
            synchronize(p);
            ret nil;
        }

        val name_start: usize = p.current.pos;
        val name_len: usize = p.current.len;
        val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_FUN, name_start, name_len);
        if (node == nil) { ret nil; }
        node.text = slice_to_str(p, name_start, name_len);

        advance(p); # consume name

        # skip parameters
        if (!match_token(p, token.TOKEN_L_PAREN)) {
            error_at_current(p, "expected '(' after function name");
            synchronize(p);
            ret nil;
        }

        for (!match_token(p, token.TOKEN_R_PAREN) && !at_end(p)) {
            advance(p);
        }

        # optional return type: skip tokens until '{' (minimal)
        for (!at_end(p) && p.current.kind != token.TOKEN_L_BRACE) {
            advance(p);
        }

        val body: *ast.AstNode = parse_block(p);
        if (body == nil) {
            error_at_current(p, "expected function body");
            ret nil;
        }
        ast.append_child(node, body);
        ret node;
    }

    if (p.current.kind == token.TOKEN_DOLLAR) {
        # minimal directive handling: skip '$' and, if it looks like '$if ... { ... }', parse the block
        advance(p);
        if (p.current.kind == token.TOKEN_KW_IF) {
            for (!at_end(p) && p.current.kind != token.TOKEN_L_BRACE) {
                advance(p);
            }
            val b: *ast.AstNode = parse_block(p);
            ret b;
        }
        advance(p);
        ret nil;
    }

    error_at_current(p, "expected top-level declaration");
    synchronize(p);
    ret nil;
}

fun parse_block(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }

    if (!match_token(p, token.TOKEN_L_BRACE)) {
        error_at_current(p, "expected '{'");
        ret nil;
    }

    val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_BLOCK, p.previous.pos, p.previous.len);
    if (node == nil) { ret nil; }

    for (!check(p, token.TOKEN_R_BRACE) && !at_end(p)) {
        val s: *ast.AstNode = parse_stmt(p);
        if (s != nil) { ast.append_child(node, s); }
    }

    if (!match_token(p, token.TOKEN_R_BRACE)) {
        error_at_current(p, "expected '}' after block");
        ret nil;
    }

    ret node;
}

fun parse_stmt(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }

    if (p.current.kind == token.TOKEN_KW_VAL || p.current.kind == token.TOKEN_KW_VAR) {
        val is_val: bool = (p.current.kind == token.TOKEN_KW_VAL);
        advance(p);

        if (p.current.kind != token.TOKEN_IDENTIFIER) {
            error_at_current(p, "expected identifier");
            synchronize(p);
            ret nil;
        }

        val name_pos: usize = p.current.pos;
        val name_len: usize = p.current.len;
        val node: *ast.AstNode = ast.alloc_node(is_val ? ast.AST_STMT_VAL : ast.AST_STMT_VAR, name_pos, name_len);
        if (node == nil) { ret nil; }
        node.text = slice_to_str(p, name_pos, name_len);

        advance(p);

        if (match_token(p, token.TOKEN_EQUAL)) {
            val rhs: *ast.AstNode = parse_expr(p);
            if (rhs != nil) { ast.append_child(node, rhs); }
        }

        if (!match_token(p, token.TOKEN_SEMICOLON)) {
            error_at_current(p, "expected ';' after declaration");
            synchronize(p);
        }

        ret node;
    }

    if (p.current.kind == token.TOKEN_KW_RET) {
        advance(p);
        val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_RET, p.previous.pos, p.previous.len);
        if (node == nil) { ret nil; }

        val e: *ast.AstNode = parse_expr(p);
        if (e != nil) { ast.append_child(node, e); }

        if (!match_token(p, token.TOKEN_SEMICOLON)) {
            error_at_current(p, "expected ';' after return");
            synchronize(p);
        }

        ret node;
    }

    # expression statement
    val e2: *ast.AstNode = parse_expr(p);
    if (e2 == nil) {
        synchronize(p);
        ret nil;
    }

    val node2: *ast.AstNode = ast.alloc_node(ast.AST_STMT_EXPR, e2.token_pos, e2.token_len);
    if (node2 == nil) { ret nil; }
    ast.append_child(node2, e2);

    if (!match_token(p, token.TOKEN_SEMICOLON)) {
        error_at_current(p, "expected ';' after statement");
        synchronize(p);
    }

    ret node2;
}

fun parse_expr(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }

    var left: *ast.AstNode = nil;

    if (p.current.kind == token.TOKEN_IDENTIFIER) {
        val name_start: usize = p.current.pos;
        val name_len: usize = p.current.len;
        left = ast.alloc_node(ast.AST_EXPR_IDENT, name_start, name_len);
        if (left != nil) { left.text = slice_to_str(p, name_start, name_len); }
        advance(p);
    }
    or (p.current.kind == token.TOKEN_LIT_STRING) {
        val start: usize = p.current.pos;
        val l: usize = p.current.len;
        left = ast.alloc_node(ast.AST_EXPR_LIT_STRING, start, l);
        if (left != nil) { left.text = slice_to_str(p, start, l); }
        advance(p);
    }
    or (p.current.kind == token.TOKEN_LIT_INT) {
        val start2: usize = p.current.pos;
        val l2: usize = p.current.len;
        left = ast.alloc_node(ast.AST_EXPR_LIT_INT, start2, l2);
        if (left != nil) { left.text = slice_to_str(p, start2, l2); }
        advance(p);
    }
    or (p.current.kind == token.TOKEN_L_PAREN) {
        advance(p);
        left = parse_expr(p);
        if (!match_token(p, token.TOKEN_R_PAREN)) {
            error_at_current(p, "expected ')'");
        }
    }
    or {
        error_at_current(p, "expected expression");
        ret nil;
    }

    # handle calls and field accesses
    for {
        if (check(p, token.TOKEN_L_PAREN)) {
            # call
            advance(p); # consume '('
            val call_node: *ast.AstNode = ast.alloc_node(ast.AST_EXPR_CALL, left.token_pos, left.token_len);
            if (call_node == nil) { ret left; }
            ast.append_child(call_node, left);

            # parse args
            for (!check(p, token.TOKEN_R_PAREN) && !at_end(p)) {
                val arg: *ast.AstNode = parse_expr(p);
                if (arg != nil) { ast.append_child(call_node, arg); }

                if (!check(p, token.TOKEN_R_PAREN)) {
                    if (!match_token(p, token.TOKEN_COMMA)) {
                        error_at_current(p, "expected ',' between arguments");
                        synchronize(p);
                        brk;
                    }
                }
            }

            if (!match_token(p, token.TOKEN_R_PAREN)) {
                error_at_current(p, "expected ')' after call");
            }

            left = call_node;
            cnt;
        }

        if (match_token(p, token.TOKEN_DOT)) {
            if (p.current.kind != token.TOKEN_IDENTIFIER) {
                error_at_current(p, "expected identifier after '.'");
                ret left;
            }

            val fld_start: usize = p.current.pos;
            val fld_len: usize = p.current.len;
            val fld_node: *ast.AstNode = ast.alloc_node(ast.AST_EXPR_FIELD, fld_start, fld_len);
            if (fld_node != nil) { fld_node.text = slice_to_str(p, fld_start, fld_len); }
            advance(p);

            ast.append_child(fld_node, left);
            left = fld_node;
            cnt;
        }

        brk;
    }

    ret left;
}

# print parser errors similar to bootstrap format
pub fun print_errors(p: *Parser, file_path: str) {
    if (p == nil) { ret; }
    var w: stream.Writer = stdio.stderr();

    var e: *ParserError = p.errors;
    for (e != nil) {
        val line: usize = lexer.get_pos_line(p.lexer, e.pos);
        val col: usize = lexer.get_pos_line_offset(p.lexer, e.pos);

        fmt.write_str(?w, file_path);
        fmt.write_str(?w, ":");
        fmt.write_u64(?w, line::u64 + 1::u64);
        fmt.write_str(?w, ":");
        fmt.write_u64(?w, col::u64 + 1::u64);
        fmt.write_str(?w, ": ");
        fmt.write_str(?w, e.msg);
        fmt.write_newline(?w);

        val line_text: str = lexer.get_line_text(p.lexer, line);
        if (line_text != nil) {
            fmt.write_str(?w, line_text);
            fmt.write_newline(?w);

            var i: usize = 0;
            for (i < col) { fmt.write_str(?w, " "); i = i + 1; }

            var caret_count: usize = 1;
            if (e.len > 0) { caret_count = e.len; }

            var j: usize = 0;
            for (j < caret_count) { fmt.write_str(?w, "^"); j = j + 1; }
            fmt.write_newline(?w);
        }

        e = e.next;
    }
}    lexer: *lexer.Lexer;
    current: token.Token;
    previous: token.Token;
    had_error: bool;
    errors: *ParserError;
}

pub fun init(p: *Parser, lx: *lexer.Lexer) {
    if (p == nil) { ret; }
    p.lexer = lx;
    p.had_error = false;
    p.errors = nil;
    # prime the parser
    p.current = lexer.next(lx);
}

fun at_end(p: *Parser) bool {
    if (p == nil) { ret true; }
    ret (p.current.kind == token.TOKEN_EOF);
}

fun advance(p: *Parser) {
    if (p == nil) { ret; }
    p.previous = p.current;
    for (;;) {
        p.current = lexer.next(p.lexer);
        if (p.current.kind != token.TOKEN_COMMENT) { brk; }
        if (p.current.kind == token.TOKEN_EOF) { brk; }
    }
}

fun check(p: *Parser, kind: i32) bool {
    if (p == nil) { ret false; }
    ret (p.current.kind == kind);
}

fun match_token(p: *Parser, kind: i32) bool {
    if (check(p, kind)) { advance(p); ret true; }
    ret false;
}

fun push_error(p: *Parser, pos: usize, len: usize, msg: str) {
    if (p == nil) { ret; }
    p.had_error = true;
    val r: Result[*ParserError, alloc.AllocError] = alloc.default().zalloc[ParserError](1);
    if (r.is_err()) { ret; }
    val e: *ParserError = r.unwrap_ok();
    e.pos = pos;
    e.len = len;
    e.msg = msg;
    e.next = p.errors;
    p.errors = e;
}

fun error_at_current(p: *Parser, msg: str) {
    if (p == nil) { ret; }
    push_error(p, p.current.pos, p.current.len, msg);
}

fun synchronize(p: *Parser) {
    if (p == nil) { ret; }
    advance(p);
    while (!at_end(p)) {
        if (p.previous.kind == token.TOKEN_SEMICOLON) { ret; }
        switch (p.current.kind) {
        case token.TOKEN_KW_FUN; case token.TOKEN_KW_VAL; case token.TOKEN_KW_VAR; case token.TOKEN_KW_USE;
            ret;
        default:
            advance(p);
        }
    }
}

# helper to copy a slice of the source into a new nul-terminated str
fun slice_to_str(p: *Parser, start: usize, len: usize) str {
    if (p == nil || p.lexer == nil || p.lexer.source == nil) { ret nil; }
    val allocr: Result[ptr, alloc.AllocError] = alloc.default().alloc_bytes(len + 1, 1);
    if (allocr.is_err()) { ret nil; }
    val buf: ptr = allocr.unwrap_ok();
    var dst: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < len) {
        dst[i] = p.lexer.source[start + i];
        i = i + 1;
    }
    dst[len] = 0;
    ret buf::str;
}

# forward declarations
fun parse_program(p: *Parser) *ast.AstNode;
fun parse_stmt_top(p: *Parser) *ast.AstNode;
fun parse_stmt(p: *Parser) *ast.AstNode;
fun parse_block(p: *Parser) *ast.AstNode;
fun parse_expr(p: *Parser) *ast.AstNode;

# public parse entry
pub fun parse(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }
    val program: *ast.AstNode = ast.alloc_node(ast.AST_PROGRAM, p.current.pos, p.current.len);
    if (program == nil) { ret nil; }

    while (!at_end(p)) {
        val stmt: *ast.AstNode = parse_stmt_top(p);
        if (stmt != nil) { ast.append_child(program, stmt); }
    }

    ret program;
}

fun parse_stmt_top(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }
    var is_pub: bool = false;
    if (match_token(p, token.TOKEN_KW_PUB)) { is_pub = true; }

    switch (p.current.kind) {
    case token.TOKEN_KW_USE:
        return (function() *ast.AstNode {
            advance(p); # consume 'use'
            if (p.current.kind != token.TOKEN_IDENTIFIER) { error_at_current(p, "expected identifier after 'use'"); synchronize(p); ret nil; }
            val name_start: usize = p.current.pos;
            var name_end: usize = p.current.pos + p.current.len;
            # consume first identifier
            advance(p);
            # allow dotted path
            while (match_token(p, token.TOKEN_DOT)) {
                if (p.current.kind != token.TOKEN_IDENTIFIER) { error_at_current(p, "expected identifier after '.'"); synchronize(p); ret nil; }
                name_end = p.current.pos + p.current.len;
                advance(p);
            }
            val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_USE, name_start, name_end - name_start);
            if (node == nil) { ret nil; }
            node.text = slice_to_str(p, name_start, name_end - name_start);
            match_token(p, token.TOKEN_SEMICOLON);
            ret node;
        })();
    case token.TOKEN_KW_FUN:
        return (function() *ast.AstNode {
            advance(p); # consume fun
            if (p.current.kind != token.TOKEN_IDENTIFIER) { error_at_current(p, "expected function name"); synchronize(p); ret nil; }
            val name_start: usize = p.current.pos;
            val name_len: usize = p.current.len;
            val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_FUN, name_start, name_len);
            if (node == nil) { ret nil; }
            node.text = slice_to_str(p, name_start, name_len);

            advance(p); # consume name
            # skip params
            if (!match_token(p, token.TOKEN_L_PAREN)) { error_at_current(p, "expected '(' after function name"); synchronize(p); ret nil; }
            while (!match_token(p, token.TOKEN_R_PAREN) && !at_end(p)) { advance(p); }

            # optional return type: skip single token after ':'
            if (match_token(p, token.TOKEN_COLON)) { advance(p); }

            val body: *ast.AstNode = parse_block(p);
            if (body == nil) { error_at_current(p, "expected function body"); ret nil; }
            ast.append_child(node, body);
            ret node;
        })();
    case token.TOKEN_DOLLAR:
        # simple directive: skip one expression or block
        advance(p);
        if (p.current.kind == token.TOKEN_KW_IF) {
            # parse a $if (...) { ... } structure at a high level by skipping
            while (!at_end(p) && p.current.kind != token.TOKEN_L_BRACE) { advance(p); }
            val b: *ast.AstNode = parse_block(p);
            ret b;
        }
        advance(p);
        ret nil;
    default:
        error_at_current(p, "expected top-level declaration");
        synchronize(p);
        ret nil;
    }
}

fun parse_block(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }
    if (!match_token(p, token.TOKEN_L_BRACE)) { error_at_current(p, "expected '{'"); ret nil; }
    val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_BLOCK, p.previous.pos, p.previous.len);
    if (node == nil) { ret nil; }

    while (!check(p, token.TOKEN_R_BRACE) && !at_end(p)) {
        val s: *ast.AstNode = parse_stmt(p);
        if (s != nil) { ast.append_child(node, s); }
    }

    if (!match_token(p, token.TOKEN_R_BRACE)) { error_at_current(p, "expected '}' after block"); ret nil; }
    ret node;
}

fun parse_stmt(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }

    switch (p.current.kind) {
    case token.TOKEN_KW_VAL:
    case token.TOKEN_KW_VAR:
        {
            val is_val: bool = (p.current.kind == token.TOKEN_KW_VAL);
            advance(p);
            if (p.current.kind != token.TOKEN_IDENTIFIER) { error_at_current(p, "expected identifier"); synchronize(p); ret nil; }
            val name_pos: usize = p.current.pos; val name_len: usize = p.current.len;
            val node: *ast.AstNode = ast.alloc_node(is_val ? ast.AST_STMT_VAL : ast.AST_STMT_VAR, name_pos, name_len);
            node.text = slice_to_str(p, name_pos, name_len);
            advance(p);
            if (match_token(p, token.TOKEN_EQUAL)) {
                val rhs: *ast.AstNode = parse_expr(p);
                if (rhs != nil) { ast.append_child(node, rhs); }
            }
            if (!match_token(p, token.TOKEN_SEMICOLON)) { error_at_current(p, "expected ';' after declaration"); synchronize(p); }
            ret node;
        }
    case token.TOKEN_KW_RET:
        {
            advance(p);
            val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_RET, p.previous.pos, p.previous.len);
            val e: *ast.AstNode = parse_expr(p);
            if (e != nil) { ast.append_child(node, e); }
            if (!match_token(p, token.TOKEN_SEMICOLON)) { error_at_current(p, "expected ';' after return"); synchronize(p); }
            ret node;
        }
    default:
        {
            val e: *ast.AstNode = parse_expr(p);
            if (e == nil) { synchronize(p); ret nil; }
            val node: *ast.AstNode = ast.alloc_node(ast.AST_STMT_EXPR, e.token_pos, e.token_len);
            ast.append_child(node, e);
            if (!match_token(p, token.TOKEN_SEMICOLON)) { error_at_current(p, "expected ';' after statement"); synchronize(p); }
            ret node;
        }
    }
}

fun parse_expr(p: *Parser) *ast.AstNode {
    if (p == nil) { ret nil; }

    # parse primary
    var left: *ast.AstNode = nil;
    switch (p.current.kind) {
    case token.TOKEN_IDENTIFIER:
        val name_start: usize = p.current.pos; val name_len: usize = p.current.len;
        left = ast.alloc_node(ast.AST_EXPR_IDENT, name_start, name_len);
        if (left != nil) { left.text = slice_to_str(p, name_start, name_len); }
        advance(p);
        break;
    case token.TOKEN_LIT_STRING:
        {
            val start: usize = p.current.pos; val l: usize = p.current.len;
            left = ast.alloc_node(ast.AST_EXPR_LIT_STRING, start, l);
            if (left != nil) { left.text = slice_to_str(p, start, l); }
            advance(p);
            break;
        }
    case token.TOKEN_LIT_INT:
        {
            val start: usize = p.current.pos; val l: usize = p.current.len;
            left = ast.alloc_node(ast.AST_EXPR_LIT_INT, start, l);
            if (left != nil) { left.text = slice_to_str(p, start, l); }
            advance(p);
            break;
        }
    case token.TOKEN_L_PAREN:
        advance(p);
        left = parse_expr(p);
        if (!match_token(p, token.TOKEN_R_PAREN)) { error_at_current(p, "expected ')'"); }
        break;
    default:
        error_at_current(p, "expected expression"); ret nil;
    }

    # handle calls and field accesses
    for (;;) {
        if (check(p, token.TOKEN_L_PAREN)) {
            # call
            advance(p); # consume '('
            val call_node: *ast.AstNode = ast.alloc_node(ast.AST_EXPR_CALL, left.token_pos, left.token_len);
            if (call_node == nil) { ret left; }
            ast.append_child(call_node, left);

            # parse args
            while (!check(p, token.TOKEN_R_PAREN) && !at_end(p)) {
                val arg: *ast.AstNode = parse_expr(p);
                if (arg != nil) { ast.append_child(call_node, arg); }
                if (!check(p, token.TOKEN_R_PAREN)) {
                    if (!match_token(p, token.TOKEN_COMMA)) { error_at_current(p, "expected ',' between arguments"); synchronize(p); break; }
                }
            }

            if (!match_token(p, token.TOKEN_R_PAREN)) { error_at_current(p, "expected ')' after call"); }
            left = call_node;
            continue;
        }

        if (match_token(p, token.TOKEN_DOT)) {
            if (p.current.kind != token.TOKEN_IDENTIFIER) { error_at_current(p, "expected identifier after '.'"); ret left; }
            val fld_start: usize = p.current.pos; val fld_len: usize = p.current.len;
            val fld_node: *ast.AstNode = ast.alloc_node(ast.AST_EXPR_FIELD, fld_start, fld_len);
            if (fld_node != nil) { fld_node.text = slice_to_str(p, fld_start, fld_len); }
            advance(p);
            # attach left as first child
            ast.append_child(fld_node, left);
            left = fld_node;
            continue;
        }

        break;
    }

    ret left;
}

# print parser errors similar to bootstrap format
pub fun print_errors(p: *Parser, file_path: str) {
    if (p == nil) { ret; }
    var w: stream.Writer = stdio.stderr();

    var e: *ParserError = p.errors;
    while (e != nil) {
        val line: usize = lexer.get_pos_line(p.lexer, e.pos);
        val col: usize = lexer.get_pos_line_offset(p.lexer, e.pos);

        fmt.write_str(?w, file_path);
        fmt.write_str(?w, ":");
        fmt.write_u64(?w, line::u64 + 1::u64); # one-based line
        fmt.write_str(?w, ":");
        fmt.write_u64(?w, col::u64 + 1::u64); # one-based column
        fmt.write_str(?w, ": ");
        fmt.write_str(?w, e.msg);
        fmt.write_newline(?w);

        # print line text
        val line_text: str = lexer.get_line_text(p.lexer, line);
        if (line_text != nil) {
            fmt.write_str(?w, line_text);
            fmt.write_newline(?w);
            # caret
            var i: usize = 0;
            for (i < col) { fmt.write_str(?w, " "); i = i + 1; }
            var j: usize = 0;
            var caret_count: usize = (e.len > 0) ? e.len : 1;
            for (j < caret_count) { fmt.write_str(?w, "^"); j = j + 1; }
            fmt.write_newline(?w);
        }

        e = e.next;
    }
}
