# ---
# ret: Ok(*ast.Node) with statement AST, or Err(str) on failure
pub fun (this: *Parser) parse_stmt() Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    # TODO: dispatch based on current token kind
    # - if: parse if statement
    # - for: parse for loop
    # - ret: parse return statement
    # - brk: parse break statement
    # - cnt: parse continue statement
    # - fin: parse defer statement
    # - masm: parse inline masm
    # - {: parse block
    # - val/var: parse local variable
    # - otherwise: parse expression statement

    ret err[*ast.Node, str]("parse_stmt not yet implemented");
}

