use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use mem: std.memory;
use print: std.print;

use ast:   mach.compiler.ast;
use lexer: mach.compiler.lexer;
use token: mach.compiler.token;

# mach.compiler.parser: recursive descent parser for Mach source code.
# ---
# converts a stream of tokens into an abstract syntax tree.

# ParserError: a parsing error with location information.
# ---
# tok:     token where error occurred
# message: error description
pub rec ParserError {
    tok:     token.Token;
    message: str;
}

# Parser: parser state.
# ---
# lex:        lexer providing tokens
# source:     original source text (for extracting token text)
# alloc:      allocator for AST nodes
# current:    current token
# previous:   previous token
# had_error:  true if any error occurred
# errors:     list of errors
# error_count: number of errors
pub rec Parser {
    lex:         lexer.Lexer;
    source:      str;
    alloc:       *allocator.Allocator;
    current:     token.Token;
    previous:    token.Token;
    had_error:   bool;
    errors:      *ParserError;
    error_count: i32;
    error_cap:   i32;
}

# init: create a new parser for a source string.
# ---
# source: source text to parse
# alloc:  allocator for AST nodes
# ret:    initialized Parser
pub fun init(source: str, alloc: *allocator.Allocator) Parser {
    var p: Parser;
    p.lex = lexer.init(source);
    p.source = source;
    p.alloc = alloc;
    p.current = lexer.lexer_next(?p.lex);
    p.previous = p.current;
    p.had_error = false;
    p.errors = nil;
    p.error_count = 0;
    p.error_cap = 0;
    ret p;
}

# dnit: clean up parser resources.
# ---
# ret: none
pub fun parser_dnit(this: *Parser) {
    if (this == nil) {
        ret;
    }

    lexer.lexer_dnit(?this.lex);

    if (this.errors != nil && this.alloc != nil) {
        allocator.allocator_free[ParserError](this.alloc, this.errors, this.error_cap::usize);
    }
}

# advance: consume the current token and get the next one.
# ---
# ret: none
pub fun parser_advance(this: *Parser) {
    if (this == nil) {
        ret;
    }

    this.previous = this.current;
    this.current = lexer.lexer_next(?this.lex);
}

# check: check if the current token has the given tag.
# ---
# tag: token tag to check for
# ret: true if current token matches tag
pub fun parser_check(this: &Parser, tag: u8) bool {
    if (this == nil) {
        ret false;
    }
    ret this.current.tag == tag;
}

# check_any: check if current token matches any of several tags.
# ---
# returns true if current matches tag1 or tag2
pub fun parser_check2(this: &Parser, tag1: u8, tag2: u8) bool {
    if (this == nil) {
        ret false;
    }
    ret this.current.tag == tag1 || this.current.tag == tag2;
}

# check3: check if current token matches any of three tags.
pub fun parser_check3(this: &Parser, tag1: u8, tag2: u8, tag3: u8) bool {
    if (this == nil) {
        ret false;
    }
    val t: u8 = this.current.tag;
    ret t == tag1 || t == tag2 || t == tag3;
}

# match_tag: if current token matches tag, consume it and return true.
# ---
# tag: token tag to match
# ret: true if matched and consumed, false otherwise
pub fun parser_match_tag(this: *Parser, tag: u8) bool {
    if (!parser_check(this, tag)) {
        ret false;
    }

    parser_advance(this);
    ret true;
}

# consume: consume current token if it matches tag, otherwise error.
# ---
# tag:     expected token tag
# message: error message if token doesn't match
# ret:     true if consumed successfully, false on error
pub fun parser_consume(this: *Parser, tag: u8, message: str) bool {
    if (parser_check(this, tag)) {
        parser_advance(this);
        ret true;
    }

    parser_error(this, message);
    ret false;
}

# error: record a parsing error at the current token.
# ---
# message: error description
# ret:     none
pub fun parser_error(this: *Parser, message: str) {
    if (this == nil) {
        ret;
    }

    this.had_error = true;
    parser_add_error(this, this.current, message);
}

# error_at: record a parsing error at a specific token.
# ---
# tok:     token where error occurred
# message: error description
# ret:     none
pub fun parser_error_at(this: *Parser, tok: token.Token, message: str) {
    if (this == nil) {
        ret;
    }

    this.had_error = true;
    parser_add_error(this, tok, message);
}

# add_error: append error to error list.
fun parser_add_error(this: *Parser, tok: token.Token, message: str) {
    if (this == nil || this.alloc == nil) {
        # set error_cap to -1 to signal nil issue
        if (this != nil) {
            this.error_cap = -1;
        }
        ret;
    }

    # grow errors array if needed
    if (this.error_count >= this.error_cap) {
        var new_cap: i32 = 8;
        if (this.error_cap > 0) {
            new_cap = this.error_cap * 2;
        }

        val r: Result[*ParserError, allocator.AllocError] = allocator.allocator_resize[ParserError](
            this.alloc,
            this.errors,
            this.error_cap::usize,
            new_cap::usize
        );

        if (result_is_err[*ParserError, allocator.AllocError](r)) {
            # set error_cap to -2 to signal resize failure
            this.error_cap = -2;
            ret;
        }

        this.errors = result_unwrap_ok[*ParserError, allocator.AllocError](r);
        this.error_cap = new_cap;
    }

    val idx: i32 = this.error_count;
    this.errors[idx].tok = tok;
    this.errors[idx].message = message;
    this.error_count = this.error_count + 1;
}

# is_at_end: check if parser has reached end of input.
# ---
# ret: true if at end of file
pub fun parser_is_at_end(this: &Parser) bool {
    if (this == nil) {
        ret true;
    }
    ret this.current.tag == token.TAG_EOF;
}

# get_token_text: extract the text of a token from source.
# ---
# tok: token to get text for
# ret: pointer to start of token text (use tok.len for length)
pub fun parser_get_token_text(this: &Parser, tok: token.Token) str {
    if (this == nil || this.source == nil) {
        ret nil;
    }

    if (tok.pos < 0 || tok.len <= 0) {
        ret nil;
    }

    # pointer arithmetic: source base + offset
    ret (this.source::u64 + tok.pos::u64)::str;
}

# current_text: get the text of the current token.
pub fun parser_current_text(this: &Parser) str {
    ret parser_get_token_text(this, this.current);
}

# previous_text: get the text of the previous token.
pub fun parser_previous_text(this: &Parser) str {
    ret parser_get_token_text(this, this.previous);
}

# alloc_token_text: allocate a null-terminated copy of a token's text.
# ---
# tok: token to get text for
# ret: Ok(str) with allocated null-terminated string, Err on failure
pub fun parser_alloc_token_text(this: *Parser, tok: token.Token) Result[str, str] {
    if (this == nil || this.source == nil || this.alloc == nil) {
        ret err[str, str]("parser or allocator is nil");
    }

    if (tok.pos < 0 || tok.len <= 0) {
        ret err[str, str]("invalid token position or length");
    }

    val len: usize = tok.len::usize;

    # allocate buffer for string + null terminator
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](this.alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) {
        ret err[str, str](result_unwrap_err[*u8, allocator.AllocError](r));
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    val src: ptr = (this.source::u64 + tok.pos::u64)::ptr;
    mem.raw_copy(buf::ptr, src, len);
    buf[len] = 0;
    ret ok[str, str](buf::str);
}

# alloc_current_text: allocate a null-terminated copy of the current token's text.
# ---
# ret: Ok(str) with allocated null-terminated string, Err on failure
pub fun parser_alloc_current_text(this: *Parser) Result[str, str] {
    ret parser_alloc_token_text(this, this.current);
}

# alloc_current_text_or_nil: allocate a null-terminated copy of current token text.
# ---
# returns nil on failure (simpler interface when allocation failure is non-fatal)
pub fun parser_alloc_current_text_or_nil(this: *Parser) str {
    val r: Result[str, str] = parser_alloc_current_text(this);
    if (result_is_err[str, str](r)) {
        ret nil;
    }
    ret result_unwrap_ok[str, str](r);
}

# should_parse_type_args: check if `[...]` should be parsed as type arguments.
# ---
# uses lookahead to check if the closing `]` is followed by `(` (call) or `{` (struct literal).
# if so, the brackets contain type arguments, not an index expression.
# ret: true if we should parse as type arguments, false for index expression
pub fun parser_should_parse_type_args(this: *Parser) bool {
    if (this == nil || !parser_check(this, token.TAG_LBRACKET)) {
        ret false;
    }

    # save lexer position for lookahead
    val saved_pos: i32 = lexer.lexer_save_pos(?this.lex);
    val saved_current: token.Token = this.current;

    # skip past the opening `[`
    parser_advance(this);

    # track bracket depth
    var depth: i32 = 1;
    var has_content: bool = false;

    # scan until we find the matching `]` or hit EOF/semicolon
    for (depth > 0 && !parser_is_at_end(this)) {
        val tag: u8 = this.current.tag;

        if (tag == token.TAG_LBRACKET) {
            depth = depth + 1;
        } or {
            if (tag == token.TAG_RBRACKET) {
                depth = depth - 1;
            } or {
                if (tag == token.TAG_SEMI || tag == token.TAG_EOF) {
                    # hit statement boundary, not type args
                    lexer.lexer_restore_pos(?this.lex, saved_pos);
                    this.current = saved_current;
                    ret false;
                } or {
                    has_content = true;
                }
            }
        }

        if (depth > 0) {
            parser_advance(this);
        }
    }

    # check what follows the closing `]`
    var is_type_args: bool = false;
    if (depth == 0 && has_content) {
        parser_advance(this);  # consume the `]`
        val follow_tag: u8 = this.current.tag;
        if (follow_tag == token.TAG_LPAREN || follow_tag == token.TAG_LBRACE) {
            is_type_args = true;
        }
    }

    # restore lexer position
    lexer.lexer_restore_pos(?this.lex, saved_pos);
    this.current = saved_current;

    ret is_type_args;
}

# should_parse_struct_lit_type: check if an ident path is followed by a struct literal.
# ---
# ret: true if the upcoming tokens form Type{...} or Type[T]{...}
pub fun parser_should_parse_struct_lit_type(this: *Parser) bool {
    if (this == nil || !parser_check(this, token.TAG_IDENT)) {
        ret false;
    }

    # save lexer position for lookahead
    val saved_pos: i32 = lexer.lexer_save_pos(?this.lex);
    val saved_current: token.Token = this.current;
    val saved_previous: token.Token = this.previous;

    # consume path
    parser_advance(this);
    for (parser_check(this, token.TAG_DOT)) {
        parser_advance(this);
        if (!parser_check(this, token.TAG_IDENT)) {
            lexer.lexer_restore_pos(?this.lex, saved_pos);
            this.current = saved_current;
            this.previous = saved_previous;
            ret false;
        }
        parser_advance(this);
    }

    # optional generic args
    if (parser_check(this, token.TAG_LBRACKET)) {
        parser_advance(this);
        var depth: i32 = 1;

        for (depth > 0 && !parser_is_at_end(this)) {
            val tag: u8 = this.current.tag;
            if (tag == token.TAG_LBRACKET) {
                depth = depth + 1;
            } or {
                if (tag == token.TAG_RBRACKET) {
                    depth = depth - 1;
                }
            }

            if (depth > 0) {
                parser_advance(this);
            }
        }

        if (depth == 0) {
            parser_advance(this);
        }
    }

    var is_struct: bool = false;
    if (parser_check(this, token.TAG_LBRACE)) {
        is_struct = true;
    }

    # restore lexer position
    lexer.lexer_restore_pos(?this.lex, saved_pos);
    this.current = saved_current;
    this.previous = saved_previous;

    ret is_struct;
}

# --- top-level parsing ---

# parse_program: parse an entire program (top-level declarations).
# ---
# ret: Ok(*ast.Node) with program AST, or Err(str) on failure
pub fun parser_parse_program(this: *Parser) Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    if (this.alloc == nil) {
        ret err[*ast.Node, str]("allocator is nil");
    }

    # create program node
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_PROGRAM,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val program: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # create list for top-level declarations
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val decls: *ast.List = result_unwrap_ok[*ast.List, str](list_res);



    # parse declarations until EOF
    for (!parser_is_at_end(this)) {
        val decl_res: Result[*ast.Node, str] = parser_parse_decl(this);

        if (result_is_err[*ast.Node, str](decl_res)) {
            # try to recover and continue
            parser_synchronize(this);
            cnt;
        }

        val decl: *ast.Node = result_unwrap_ok[*ast.Node, str](decl_res);
        if (decl != nil) {
            val append_res: Result[bool, str] = ast.list_append(decls, this.alloc, decl);
            if (result_is_err[bool, str](append_res)) {
                ret err[*ast.Node, str](result_unwrap_err[bool, str](append_res));
            }
        }
    }

    program.info.block_stmt.stmts = decls;

    ret ok[*ast.Node, str](program);
}

# parse_decl: parse a top-level declaration.
# ---
# ret: Ok(*ast.Node) with declaration AST, or Err(str) on failure
pub fun parser_parse_decl(this: *Parser) Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    val tag: u8 = this.current.tag;

    # use statement
    if (tag == token.TAG_KW_USE) {
        ret parser_parse_use(this);
    }

    # pub modifier
    if (tag == token.TAG_KW_PUB) {
        ret parser_parse_pub(this);
    }

    # ext declaration
    if (tag == token.TAG_KW_EXT) {
        ret parser_parse_ext(this);
    }

    # def type alias
    if (tag == token.TAG_KW_DEF) {
        ret parser_parse_def(this);
    }

    # rec record
    if (tag == token.TAG_KW_REC) {
        ret parser_parse_rec(this, false, false);  # is_type=false for declaration context
    }

    # uni union
    if (tag == token.TAG_KW_UNI) {
        ret parser_parse_uni(this, false, false);  # is_type=false for declaration context
    }

    # val constant
    if (tag == token.TAG_KW_VAL) {
        ret parser_parse_val(this, false);
    }

    # var global
    if (tag == token.TAG_KW_VAR) {
        ret parser_parse_var(this, false);
    }

    # fun function
    if (tag == token.TAG_KW_FUN) {
        ret parser_parse_fun(this, false);
    }

    # test block
    if (tag == token.TAG_KW_TEST) {
        ret parser_parse_test(this);
    }

    # comptime: $if, $error, attribute
    if (tag == token.TAG_DOLLAR) {
        ret parser_parse_comptime(this, true);
    }

    # comment (hash at top level is already skipped by lexer)
    # if we see hash here, skip the line
    if (tag == token.TAG_HASH) {
        parser_skip_to_newline(this);
        ret ok[*ast.Node, str](nil);
    }

    parser_error(this, "expected declaration");
    ret err[*ast.Node, str]("expected declaration");
}

# skip_to_newline: skip tokens until newline or EOF.
fun parser_skip_to_newline(this: *Parser) {
    for (!parser_is_at_end(this)) {
        if (this.current.tag == token.TAG_NEWLINE) {
            parser_advance(this);
            ret;
        }
        parser_advance(this);
    }
}

# --- use statement ---

# parse_use: parse a use statement.
# use module.path;
# use alias: module.path;
pub fun parser_parse_use(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'use'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_USE,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # check for alias: path syntax
    var has_alias: bool = false;
    var alias_tok: token.Token = this.current;

    if (parser_check(this, token.TAG_IDENT)) {
        # peek ahead for colon
        val id_tok: token.Token = this.current;
        parser_advance(this);

        if (parser_check(this, token.TAG_COLON)) {
            # this is alias: path
            has_alias = true;
            alias_tok = id_tok;
            parser_advance(this);  # consume ':'
        } or {
            # no alias, put back by parsing as path
            # actually we already consumed the ident, treat as first part of path
            # we need to build path starting with this ident
            node.info.use_decl.path = parser_parse_path_after_first(this, id_tok);
            if (!parser_consume(this, token.TAG_SEMI, "expected ';' after use statement")) {
                ret err[*ast.Node, str]("expected ';' after use statement");
            }
            ret ok[*ast.Node, str](node);
        }
    }

    # parse the module path
    val path: str = parser_parse_path(this);
    if (path == nil && this.had_error) {
        ret err[*ast.Node, str]("expected module path");
    }

    # store path and alias in node
    node.info.use_decl.path = path;
    if (has_alias) {
        # store alias text (null-terminated)
        val alias_res: Result[str, str] = parser_alloc_token_text(this, alias_tok);
        if (result_is_ok[str, str](alias_res)) {
            node.info.use_decl.alias = result_unwrap_ok[str, str](alias_res);
        }
    }

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after use statement")) {
        ret err[*ast.Node, str]("expected ';' after use statement");
    }

    ret ok[*ast.Node, str](node);
}

# parse_path: parse a dotted identifier path (e.g., std.types.bool).
# ret: the path as a string (null-terminated, allocated)
fun parser_parse_path(this: *Parser) str {
    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected identifier in path");
        ret nil;
    }

    val start_pos: i32 = this.current.pos;
    var end_pos: i32 = this.current.pos + this.current.len;

    parser_advance(this);  # consume first ident

    # continue with .ident
    for (parser_check(this, token.TAG_DOT)) {
        parser_advance(this);  # consume '.'

        if (!parser_check(this, token.TAG_IDENT)) {
            parser_error(this, "expected identifier after '.'");
            ret nil;
        }

        end_pos = this.current.pos + this.current.len;
        parser_advance(this);  # consume ident
    }

    # allocate null-terminated copy
    val len: usize = (end_pos - start_pos)::usize;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](this.alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) {
        ret nil;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    val src: ptr = (this.source::u64 + start_pos::u64)::ptr;
    mem.raw_copy(buf::ptr, src, len);
    buf[len] = 0;
    ret buf::str;
}

# parse_path_after_first: build path after first ident already consumed.
fun parser_parse_path_after_first(this: *Parser, first: token.Token) str {
    val start_pos: i32 = first.pos;
    var end_pos: i32 = first.pos + first.len;

    # continue with .ident
    for (parser_check(this, token.TAG_DOT)) {
        parser_advance(this);  # consume '.'

        if (!parser_check(this, token.TAG_IDENT)) {
            parser_error(this, "expected identifier after '.'");
            ret nil;
        }

        end_pos = this.current.pos + this.current.len;
        parser_advance(this);  # consume ident
    }

    # allocate null-terminated copy
    val len: usize = (end_pos - start_pos)::usize;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](this.alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](r)) {
        ret nil;
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);
    val src: ptr = (this.source::u64 + start_pos::u64)::ptr;
    mem.raw_copy(buf::ptr, src, len);
    buf[len] = 0;
    ret buf::str;
}

# --- pub modifier ---

# parse_pub: parse a pub declaration.
# pub fun/rec/uni/val/var/ext/def ...
# Creates a NODE_DECL_PUB wrapper node with the actual declaration as children.
pub fun parser_parse_pub(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'pub'

    # create the pub wrapper node
    val pub_node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_PUB,
        start_tok
    );

    if (result_is_err[*ast.Node, str](pub_node_res)) {
        ret pub_node_res;
    }

    val pub_node: *ast.Node = result_unwrap_ok[*ast.Node, str](pub_node_res);

    val tag: u8 = this.current.tag;

    # dispatch to actual declaration
    var inner_res: Result[*ast.Node, str] = err[*ast.Node, str]("expected declaration after 'pub'");

    if (tag == token.TAG_KW_FUN) {
        inner_res = parser_parse_fun(this, true);
    } or {
        if (tag == token.TAG_KW_REC) {
            inner_res = parser_parse_rec(this, true, false);  # is_type=false for declaration context
        } or {
            if (tag == token.TAG_KW_UNI) {
                inner_res = parser_parse_uni(this, true, false);  # is_type=false for declaration context
            } or {
                if (tag == token.TAG_KW_VAL) {
                    inner_res = parser_parse_val(this, true);
                } or {
                    if (tag == token.TAG_KW_VAR) {
                        inner_res = parser_parse_var(this, true);
                    } or {
                        if (tag == token.TAG_KW_EXT) {
                            inner_res = parser_parse_ext(this);
                        } or {
                            if (tag == token.TAG_KW_DEF) {
                                inner_res = parser_parse_def(this);
                            } or {
                                parser_error(this, "expected declaration after 'pub'");
                                ret err[*ast.Node, str]("expected declaration after 'pub'");
                            }
                        }
                    }
                }
            }
        }
    }

    if (result_is_err[*ast.Node, str](inner_res)) {
        ret inner_res;
    }

    # wrap the inner declaration in the pub node
    pub_node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](inner_res);

    ret ok[*ast.Node, str](pub_node);
}

# --- ext declaration ---

# parse_ext: parse an ext (external) declaration.
# ext fun name(...) type;
# ext val name: type;
pub fun parser_parse_ext(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'ext'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_EXT,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val tag: u8 = this.current.tag;

    if (tag == token.TAG_KW_FUN) {
        # parse external function signature
        val fun_res: Result[*ast.Node, str] = parser_parse_fun_signature(this);
        if (result_is_err[*ast.Node, str](fun_res)) {
            ret fun_res;
        }
        node.info.ext_decl.inner = result_unwrap_ok[*ast.Node, str](fun_res);
    } or {
        if (tag == token.TAG_KW_VAL || tag == token.TAG_KW_VAR) {
            # parse external variable
            parser_advance(this);  # consume val/var

            if (!parser_check(this, token.TAG_IDENT)) {
                parser_error(this, "expected identifier in ext declaration");
                ret err[*ast.Node, str]("expected identifier");
            }

            node.info.ext_decl.name = parser_alloc_current_text_or_nil(this);
            parser_advance(this);

            if (!parser_consume(this, token.TAG_COLON, "expected ':' after identifier")) {
                ret err[*ast.Node, str]("expected ':'");
            }

            val type_res: Result[*ast.Node, str] = parser_parse_type(this);
            if (result_is_err[*ast.Node, str](type_res)) {
                ret type_res;
            }
            node.info.ext_decl.inner = result_unwrap_ok[*ast.Node, str](type_res);
        } or {
            parser_error(this, "expected 'fun', 'val', or 'var' after 'ext'");
            ret err[*ast.Node, str]("expected 'fun', 'val', or 'var' after 'ext'");
        }
    }

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after ext declaration")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- def type alias ---

# parse_def: parse a type alias definition.
# def Name = Type;
pub fun parser_parse_def(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'def'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_DEF,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected identifier after 'def'");
        ret err[*ast.Node, str]("expected identifier");
    }

    node.info.def_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # optional generic parameters
    if (parser_check(this, token.TAG_LBRACKET)) {
        val generics_res: Result[*ast.Node, str] = parser_parse_generic_params(this);
        if (result_is_err[*ast.Node, str](generics_res)) {
            ret generics_res;
        }
        node.info.def_decl.generics = result_unwrap_ok[*ast.Node, str](generics_res);
    }

    if (!parser_consume(this, token.TAG_COLON, "expected ':' after type name")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](type_res)) {
        ret type_res;
    }

    node.info.def_decl.type_node = result_unwrap_ok[*ast.Node, str](type_res);

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after def")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- rec declaration ---

# parse_rec: parse a record declaration or type.
# rec Name { field: type; ... }
# is_type: true if parsing as a type expression (anonymous), false if declaration
pub fun parser_parse_rec(this: *Parser, is_pub: bool, is_type: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'rec'

    # use type node if parsing as type expression, otherwise declaration node
    var node_kind: ast.NodeKind = ast.NODE_DECL_REC;
    if (is_type) {
        node_kind = ast.NODE_TYPE_REC;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        node_kind,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # check for named or anonymous record
    if (parser_check(this, token.TAG_IDENT)) {
        node.info.type_decl.name = parser_alloc_current_text_or_nil(this);
        parser_advance(this);

        # optional generic parameters
        if (parser_check(this, token.TAG_LBRACKET)) {
            val generics_res: Result[*ast.Node, str] = parser_parse_generic_params(this);
            if (result_is_err[*ast.Node, str](generics_res)) {
                ret generics_res;
            }
            node.info.type_decl.generics = result_unwrap_ok[*ast.Node, str](generics_res);
        }
    }

    if (!parser_consume(this, token.TAG_LBRACE, "expected '{' in record definition")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    # parse fields
    val fields_res: Result[*ast.List, str] = parser_parse_fields(this);
    if (result_is_err[*ast.List, str](fields_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](fields_res));
    }

    node.info.type_decl.fields = result_unwrap_ok[*ast.List, str](fields_res);

    if (!parser_consume(this, token.TAG_RBRACE, "expected '}' after record fields")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_fields: parse field declarations inside rec or uni.
fun parser_parse_fields(this: *Parser) Result[*ast.List, str] {
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret list_res;
    }

    val fields: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    for (!parser_check(this, token.TAG_RBRACE) && !parser_is_at_end(this)) {
        val field_res: Result[*ast.Node, str] = parser_parse_field(this);
        if (result_is_err[*ast.Node, str](field_res)) {
            ret err[*ast.List, str](result_unwrap_err[*ast.Node, str](field_res));
        }

        val append_res: Result[bool, str] = ast.list_append(fields, this.alloc, result_unwrap_ok[*ast.Node, str](field_res));
        if (result_is_err[bool, str](append_res)) {
            ret err[*ast.List, str](result_unwrap_err[bool, str](append_res));
        }
    }

    ret ok[*ast.List, str](fields);
}

# parse_field: parse a single field declaration.
# name: type;
fun parser_parse_field(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected field name");
        ret err[*ast.Node, str]("expected field name");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_FIELD,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.field_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    if (!parser_consume(this, token.TAG_COLON, "expected ':' after ext fun name")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](type_res)) {
        ret type_res;
    }

    node.info.field_decl.type_node = result_unwrap_ok[*ast.Node, str](type_res);

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after field type")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- uni declaration ---

# parse_uni: parse a union declaration or type.
# uni Name { variant: type; ... }
# is_type: true if parsing as a type expression (anonymous), false if declaration
pub fun parser_parse_uni(this: *Parser, is_pub: bool, is_type: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'uni'

    # use type node if parsing as type expression, otherwise declaration node
    var node_kind: ast.NodeKind = ast.NODE_DECL_UNI;
    if (is_type) {
        node_kind = ast.NODE_TYPE_UNI;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        node_kind,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # check for named or anonymous union
    if (parser_check(this, token.TAG_IDENT)) {
        node.info.type_decl.name = parser_alloc_current_text_or_nil(this);
        parser_advance(this);

        # optional generic parameters
        if (parser_check(this, token.TAG_LBRACKET)) {
            val generics_res: Result[*ast.Node, str] = parser_parse_generic_params(this);
            if (result_is_err[*ast.Node, str](generics_res)) {
                ret generics_res;
            }
            node.info.type_decl.generics = result_unwrap_ok[*ast.Node, str](generics_res);
        }
    }

    if (!parser_consume(this, token.TAG_LBRACE, "expected '{' in union definition")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    # parse variants (same as fields)
    val fields_res: Result[*ast.List, str] = parser_parse_fields(this);
    if (result_is_err[*ast.List, str](fields_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](fields_res));
    }

    node.info.type_decl.fields = result_unwrap_ok[*ast.List, str](fields_res);

    if (!parser_consume(this, token.TAG_RBRACE, "expected '}' after union variants")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    ret ok[*ast.Node, str](node);
}

# --- val declaration ---

# parse_val: parse a val (immutable) declaration.
# val name: type = expr;
# val name = expr;
# AST structure:
#   info.var_decl.name      = name (str)
#   info.var_decl.type_node = type node (or nil if no annotation)
#   info.var_decl.init      = initializer expression
pub fun parser_parse_val(this: *Parser, is_pub: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'val'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_VAL,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected identifier after 'val'");
        ret err[*ast.Node, str]("expected identifier");
    }

    node.info.var_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # optional type annotation
    if (parser_check(this, token.TAG_COLON)) {
        parser_advance(this);  # consume ':'

        val type_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](type_res)) {
            ret type_res;
        }

        node.info.var_decl.type_node = result_unwrap_ok[*ast.Node, str](type_res);
    }

    # initializer
    if (!parser_consume(this, token.TAG_EQ, "expected '=' in val declaration")) {
        ret err[*ast.Node, str]("expected '='");
    }

    val expr_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](expr_res)) {
        ret expr_res;
    }

    node.info.var_decl.init = result_unwrap_ok[*ast.Node, str](expr_res);

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after val declaration")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- var declaration ---

# parse_var: parse a var (mutable) declaration.
# var name: type;
# var name: type = expr;
# var name = expr;
# AST structure:
#   info.var_decl.name      = name (str)
#   info.var_decl.type_node = type node (or nil if no annotation)
#   info.var_decl.init      = initializer expression (or nil if no initializer)
pub fun parser_parse_var(this: *Parser, is_pub: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'var'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_VAR,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected identifier after 'var'");
        ret err[*ast.Node, str]("expected identifier");
    }

    node.info.var_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # type annotation
    if (parser_check(this, token.TAG_COLON)) {
        parser_advance(this);  # consume ':'

        val type_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](type_res)) {
            ret type_res;
        }

        node.info.var_decl.type_node = result_unwrap_ok[*ast.Node, str](type_res);
    }

    # optional initializer
    if (parser_check(this, token.TAG_EQ)) {
        parser_advance(this);  # consume '='

        val expr_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](expr_res)) {
            ret expr_res;
        }

        node.info.var_decl.init = result_unwrap_ok[*ast.Node, str](expr_res);
    }

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after var declaration")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- fun declaration ---

# parse_fun: parse a function declaration.
# fun name(...) type { body }
# fun (self: *Type) name(...) type { body }
pub fun parser_parse_fun(this: *Parser, is_pub: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'fun'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_FUN,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # function name
    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected function name");
        ret err[*ast.Node, str]("expected function name");
    }

    node.info.fun_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # optional generic parameters
    if (parser_check(this, token.TAG_LBRACKET)) {
        val generics_res: Result[*ast.Node, str] = parser_parse_generic_params(this);
        if (result_is_err[*ast.Node, str](generics_res)) {
            ret generics_res;
        }
        node.info.fun_decl.generics = result_unwrap_ok[*ast.Node, str](generics_res);
    }

    # parameters
    if (!parser_consume(this, token.TAG_LPAREN, "expected '(' after function name")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val params_res: Result[*ast.List, str] = parser_parse_params(this);
    if (result_is_err[*ast.List, str](params_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](params_res));
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after parameters")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # store params
    node.info.fun_decl.params = result_unwrap_ok[*ast.List, str](params_res);

    # return type (optional for void)
    if (!parser_check(this, token.TAG_LBRACE) && !parser_check(this, token.TAG_SEMI)) {
        val type_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](type_res)) {
            ret type_res;
        }
        node.info.fun_decl.ret_type = result_unwrap_ok[*ast.Node, str](type_res);
    }

    # function body or just signature (for ext)
    if (parser_check(this, token.TAG_LBRACE)) {
        val body_res: Result[*ast.Node, str] = parser_parse_block(this);
        if (result_is_err[*ast.Node, str](body_res)) {
            ret body_res;
        }
        node.info.fun_decl.body = result_unwrap_ok[*ast.Node, str](body_res);
    }

    ret ok[*ast.Node, str](node);
}

# parse_fun_signature: parse just a function signature (for ext).
fun parser_parse_fun_signature(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'fun'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_FUN,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # function name
    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected function name");
        ret err[*ast.Node, str]("expected function name");
    }

    node.info.fun_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # parameters
    if (!parser_consume(this, token.TAG_LPAREN, "expected '(' after function name")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val params_res: Result[*ast.List, str] = parser_parse_params(this);
    if (result_is_err[*ast.List, str](params_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](params_res));
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after parameters")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # store params
    node.info.fun_decl.params = result_unwrap_ok[*ast.List, str](params_res);

    # return type
    if (!parser_check(this, token.TAG_SEMI)) {
        val type_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](type_res)) {
            ret type_res;
        }
        node.info.fun_decl.ret_type = result_unwrap_ok[*ast.Node, str](type_res);
    }

    ret ok[*ast.Node, str](node);
}

# parse_params: parse function parameter list.
fun parser_parse_params(this: *Parser) Result[*ast.List, str] {
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret list_res;
    }

    val params: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    # empty parameter list
    if (parser_check(this, token.TAG_RPAREN)) {
        ret ok[*ast.List, str](params);
    }

    # first parameter
    val first_res: Result[*ast.Node, str] = parser_parse_param(this);
    if (result_is_err[*ast.Node, str](first_res)) {
        ret err[*ast.List, str](result_unwrap_err[*ast.Node, str](first_res));
    }

    val append_res: Result[bool, str] = ast.list_append(params, this.alloc, result_unwrap_ok[*ast.Node, str](first_res));
    if (result_is_err[bool, str](append_res)) {
        ret err[*ast.List, str](result_unwrap_err[bool, str](append_res));
    }

    # remaining parameters
    for (parser_check(this, token.TAG_COMMA)) {
        parser_advance(this);  # consume ','

        val param_res: Result[*ast.Node, str] = parser_parse_param(this);
        if (result_is_err[*ast.Node, str](param_res)) {
            ret err[*ast.List, str](result_unwrap_err[*ast.Node, str](param_res));
        }

        val a_res: Result[bool, str] = ast.list_append(params, this.alloc, result_unwrap_ok[*ast.Node, str](param_res));
        if (result_is_err[bool, str](a_res)) {
            ret err[*ast.List, str](result_unwrap_err[bool, str](a_res));
        }
    }

    ret ok[*ast.List, str](params);
}

# parse_param: parse a single function parameter.
# name: type
# or variadic: ...
fun parser_parse_param(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    # check for variadic ...
    if (parser_check(this, token.TAG_DOT)) {
        # consume three dots
        parser_advance(this);  # first dot
        if (!parser_check(this, token.TAG_DOT)) {
            parser_error(this, "expected '...' for variadic parameter");
            ret err[*ast.Node, str]("expected '...'");
        }
        parser_advance(this);  # second dot
        if (!parser_check(this, token.TAG_DOT)) {
            parser_error(this, "expected '...' for variadic parameter");
            ret err[*ast.Node, str]("expected '...'");
        }
        parser_advance(this);  # third dot

        # create variadic node
        val variadic_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_VARIADIC,
            start_tok
        );
        if (result_is_err[*ast.Node, str](variadic_res)) {
            ret variadic_res;
        }
        ret ok[*ast.Node, str](result_unwrap_ok[*ast.Node, str](variadic_res));
    }

    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected parameter name");
        ret err[*ast.Node, str]("expected parameter name");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_PARAM,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.field_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # check for type parameter list: [T, U, ...]
    if (!parser_consume(this, token.TAG_COLON, "expected ':' after parameter name")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](type_res)) {
        ret type_res;
    }

    node.info.field_decl.type_node = result_unwrap_ok[*ast.Node, str](type_res);

    ret ok[*ast.Node, str](node);
}

# parse_generic_params: parse generic type parameters [T, U, ...].
fun parser_parse_generic_params(this: *Parser) Result[*ast.Node, str] {
    parser_advance(this);  # consume '['

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_GENERIC,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val params: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    # first param
    if (parser_check(this, token.TAG_IDENT)) {
        val param_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_TYPE_NAME,
            this.current
        );
        if (result_is_err[*ast.Node, str](param_res)) {
            ret param_res;
        }
        val p: *ast.Node = result_unwrap_ok[*ast.Node, str](param_res);
        p.info.type_name.path = parser_alloc_current_text_or_nil(this);
        parser_advance(this);

        val a_res: Result[bool, str] = ast.list_append(params, this.alloc, p);
        if (result_is_err[bool, str](a_res)) {
            ret err[*ast.Node, str](result_unwrap_err[bool, str](a_res));
        }

        # more params
        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            if (!parser_check(this, token.TAG_IDENT)) {
                parser_error(this, "expected type parameter name");
                ret err[*ast.Node, str]("expected type parameter name");
            }

            val p2_res: Result[*ast.Node, str] = ast.create_node(
                this.alloc,
                ast.NODE_TYPE_NAME,
                this.current
            );
            if (result_is_err[*ast.Node, str](p2_res)) {
                ret p2_res;
            }
            val p2: *ast.Node = result_unwrap_ok[*ast.Node, str](p2_res);
            p2.info.type_name.path = parser_alloc_current_text_or_nil(this);
            parser_advance(this);

            val a2_res: Result[bool, str] = ast.list_append(params, this.alloc, p2);
            if (result_is_err[bool, str](a2_res)) {
                ret err[*ast.Node, str](result_unwrap_err[bool, str](a2_res));
            }
        }
    }

    if (!parser_consume(this, token.TAG_RBRACKET, "expected ']' after generic parameters")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    node.info.generic_node.args = params;
    ret ok[*ast.Node, str](node);
}

# --- test declaration ---

# parse_test: parse a test block.
# test "name" { body }
pub fun parser_parse_test(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'test'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_TEST,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # test name (string literal)
    if (!parser_check(this, token.TAG_LIT_STRING)) {
        parser_error(this, "expected test name (string literal)");
        ret err[*ast.Node, str]("expected test name");
    }

    node.info.test_decl.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # test body
    val body_res: Result[*ast.Node, str] = parser_parse_block(this);
    if (result_is_err[*ast.Node, str](body_res)) {
        ret body_res;
    }

    node.info.test_decl.body = result_unwrap_ok[*ast.Node, str](body_res);

    ret ok[*ast.Node, str](node);
}

# --- comptime ---

# parse_comptime: parse comptime construct ($if, $error, attribute).
pub fun parser_parse_comptime(this: *Parser, is_top: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '$'

    # check what follows
    if (parser_check(this, token.TAG_KW_IF)) {
        ret parser_parse_comptime_if(this, is_top);
    }

    # attribute: $name.field = value;
    if (parser_check(this, token.TAG_IDENT)) {
        ret parser_parse_attribute(this);
    }

    parser_error(this, "expected comptime construct after '$'");
    ret err[*ast.Node, str]("expected comptime construct");
}

# parse_comptime_if: parse $if (cond) { ... } $or { ... }
fun parser_parse_comptime_if(this: *Parser, is_top: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'if'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_COMPTIME_IF,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # condition (in parentheses)
    if (!parser_consume(this, token.TAG_LPAREN, "expected '(' after '$if'")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val cond_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](cond_res)) {
        ret cond_res;
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after condition")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # body block (top-level uses decls, statement context uses stmts)
    var body_res: Result[*ast.Node, str];
    if (is_top) {
        body_res = parser_parse_block_top(this);
    } or {
        body_res = parser_parse_block(this);
    }
    if (result_is_err[*ast.Node, str](body_res)) {
        ret body_res;
    }

    # store condition and body
    node.info.cond_stmt.cond = result_unwrap_ok[*ast.Node, str](cond_res);
    node.info.cond_stmt.body = result_unwrap_ok[*ast.Node, str](body_res);

    # handle $or chains - use extra field to store the linked list
    var current: *ast.Node = node;
    for (parser_check(this, token.TAG_DOLLAR)) {
        # peek ahead to see if next is 'or'
        parser_advance(this);  # consume '$'

        if (!parser_check(this, token.TAG_KW_OR)) {
            # not an $or, put back by going back
            # unfortunately we can't easily unadvance, so error
            parser_error(this, "expected 'or' after '$' in comptime chain");
            ret err[*ast.Node, str]("expected 'or' after '$'");
        }

        parser_advance(this);  # consume 'or'

        val or_node_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_COMPTIME_OR,
            this.previous
        );

        if (result_is_err[*ast.Node, str](or_node_res)) {
            ret or_node_res;
        }

        val or_node: *ast.Node = result_unwrap_ok[*ast.Node, str](or_node_res);

        # optional condition
        if (parser_check(this, token.TAG_LPAREN)) {
            parser_advance(this);  # consume '('

            val or_cond_res: Result[*ast.Node, str] = parser_parse_expr(this);
            if (result_is_err[*ast.Node, str](or_cond_res)) {
                ret or_cond_res;
            }

            if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after '$or' condition")) {
                ret err[*ast.Node, str]("expected ')'");
            }

            or_node.info.cond_stmt.cond = result_unwrap_ok[*ast.Node, str](or_cond_res);
        }

        # body block
        var or_body_res: Result[*ast.Node, str];
        if (is_top) {
            or_body_res = parser_parse_block_top(this);
        } or {
            or_body_res = parser_parse_block(this);
        }
        if (result_is_err[*ast.Node, str](or_body_res)) {
            ret or_body_res;
        }

        or_node.info.cond_stmt.body = result_unwrap_ok[*ast.Node, str](or_body_res);

        # link into chain via or_branch field
        current.info.cond_stmt.or_branch = or_node;
        current = or_node;
    }

    ret ok[*ast.Node, str](node);
}

# parse_attribute: parse $name.field = value;
fun parser_parse_attribute(this: *Parser) Result[*ast.Node, str] {
    # build a comptime node with the inner expression after '$'
    val start_tok: token.Token = this.previous;

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_COMPTIME,
        start_tok
    );
    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val inner_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](inner_res)) {
        ret inner_res;
    }

    node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](inner_res);

    if (parser_check(this, token.TAG_SEMI)) {
        parser_advance(this);
    }

    ret ok[*ast.Node, str](node);
}

# --- statements ---

# parse_block: parse a block of statements.
# { stmt* }
pub fun parser_parse_block(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    if (!parser_consume(this, token.TAG_LBRACE, "expected '{'")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_BLOCK,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val stmts: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    for (!parser_check(this, token.TAG_RBRACE) && !parser_is_at_end(this)) {
        val stmt_res: Result[*ast.Node, str] = parser_parse_stmt(this);
        if (result_is_err[*ast.Node, str](stmt_res)) {
            parser_synchronize(this);
            cnt;
        }

        val stmt: *ast.Node = result_unwrap_ok[*ast.Node, str](stmt_res);
        if (stmt != nil) {
            val a_res: Result[bool, str] = ast.list_append(stmts, this.alloc, stmt);
            if (result_is_err[bool, str](a_res)) {
                ret err[*ast.Node, str](result_unwrap_err[bool, str](a_res));
            }
        }
    }

    if (!parser_consume(this, token.TAG_RBRACE, "expected '}'")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    node.info.block_stmt.stmts = stmts;

    ret ok[*ast.Node, str](node);
}

# parse_block_top: parse a block containing top-level declarations.
# Used for $if blocks at the module level, which contain declarations not statements.
pub fun parser_parse_block_top(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    if (!parser_consume(this, token.TAG_LBRACE, "expected '{'")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_BLOCK,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val decls: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    for (!parser_check(this, token.TAG_RBRACE) && !parser_is_at_end(this)) {
        val decl_res: Result[*ast.Node, str] = parser_parse_decl(this);
        if (result_is_err[*ast.Node, str](decl_res)) {
            parser_synchronize(this);
            cnt;
        }

        val decl: *ast.Node = result_unwrap_ok[*ast.Node, str](decl_res);
        if (decl != nil) {
            val a_res: Result[bool, str] = ast.list_append(decls, this.alloc, decl);
            if (result_is_err[bool, str](a_res)) {
                ret err[*ast.Node, str](result_unwrap_err[bool, str](a_res));
            }
        }
    }

    if (!parser_consume(this, token.TAG_RBRACE, "expected '}'")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    node.info.block_stmt.stmts = decls;

    ret ok[*ast.Node, str](node);
}

# parse_stmt: parse a statement.
# ---
# ret: Ok(*ast.Node) with statement AST, or Err(str) on failure
pub fun parser_parse_stmt(this: *Parser) Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    val tag: u8 = this.current.tag;

    # if statement
    if (tag == token.TAG_KW_IF) {
        ret parser_parse_if(this);
    }

    # for loop
    if (tag == token.TAG_KW_FOR) {
        ret parser_parse_for(this);
    }

    # ret statement
    if (tag == token.TAG_KW_RET) {
        ret parser_parse_ret(this);
    }

    # brk statement
    if (tag == token.TAG_KW_BRK) {
        ret parser_parse_brk(this);
    }

    # cnt statement
    if (tag == token.TAG_KW_CNT) {
        ret parser_parse_cnt(this);
    }

    # fin (defer) statement
    if (tag == token.TAG_KW_FIN) {
        ret parser_parse_fin(this);
    }

    # comptime statement
    if (tag == token.TAG_DOLLAR) {
        ret parser_parse_comptime(this, false);
    }

    # asm block
    if (tag == token.TAG_KW_ASM) {
        ret parser_parse_asm(this);
    }

    # block
    if (tag == token.TAG_LBRACE) {
        ret parser_parse_block(this);
    }

    # val declaration
    if (tag == token.TAG_KW_VAL) {
        ret parser_parse_val(this, false);
    }

    # var declaration
    if (tag == token.TAG_KW_VAR) {
        ret parser_parse_var(this, false);
    }

    # expression statement
    ret parser_parse_expr_stmt(this);
}

# parse_if: parse an if statement.
# if (cond) { then } or { else }
fun parser_parse_if(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'if'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_IF,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # condition (in parentheses)
    if (!parser_consume(this, token.TAG_LPAREN, "expected '(' after 'if'")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val cond_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](cond_res)) {
        ret cond_res;
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after condition")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # then block
    val then_res: Result[*ast.Node, str] = parser_parse_block(this);
    if (result_is_err[*ast.Node, str](then_res)) {
        ret then_res;
    }

    node.info.cond_stmt.cond = result_unwrap_ok[*ast.Node, str](cond_res);
    node.info.cond_stmt.body = result_unwrap_ok[*ast.Node, str](then_res);

    # handle or chains: or { ... }, or (cond) { ... }, or if (...)
    var or_chain_head: *ast.Node = nil;
    var or_chain_current: *ast.Node = nil;

    for (parser_check(this, token.TAG_KW_OR)) {
        parser_advance(this);  # consume 'or'

        if (parser_check(this, token.TAG_KW_IF)) {
            # or if (...) - recursive if becomes part of chain
            val elif_res: Result[*ast.Node, str] = parser_parse_if(this);
            if (result_is_err[*ast.Node, str](elif_res)) {
                ret elif_res;
            }
            # store as the else branch
            if (or_chain_current != nil) {
                or_chain_current.info.cond_stmt.or_branch = result_unwrap_ok[*ast.Node, str](elif_res);
            } or {
                or_chain_head = result_unwrap_ok[*ast.Node, str](elif_res);
            }
            brk;
        }

        # create or node (NODE_STMT_OR)
        val or_node_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_STMT_OR,
            this.previous
        );

        if (result_is_err[*ast.Node, str](or_node_res)) {
            ret or_node_res;
        }

        val or_node: *ast.Node = result_unwrap_ok[*ast.Node, str](or_node_res);

        # optional condition: or (cond) { ... }
        if (parser_check(this, token.TAG_LPAREN)) {
            parser_advance(this);  # consume '('

            val or_cond_res: Result[*ast.Node, str] = parser_parse_expr(this);
            if (result_is_err[*ast.Node, str](or_cond_res)) {
                ret or_cond_res;
            }

            if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after 'or' condition")) {
                ret err[*ast.Node, str]("expected ')'");
            }

            or_node.info.cond_stmt.cond = result_unwrap_ok[*ast.Node, str](or_cond_res);
        }

        # body block
        val or_body_res: Result[*ast.Node, str] = parser_parse_block(this);
        if (result_is_err[*ast.Node, str](or_body_res)) {
            ret or_body_res;
        }

        or_node.info.cond_stmt.body = result_unwrap_ok[*ast.Node, str](or_body_res);

        # link into chain
        if (or_chain_head == nil) {
            or_chain_head = or_node;
            or_chain_current = or_node;
        } or {
            or_chain_current.info.cond_stmt.or_branch = or_node;
            or_chain_current = or_node;
        }
    }

    # if we have an or chain, store it
    if (or_chain_head != nil) {
        node.info.cond_stmt.or_branch = or_chain_head;
    }

    ret ok[*ast.Node, str](node);
}

# parse_for: parse a for loop.
# for (cond) { body }
# for { body }  (infinite loop)
fun parser_parse_for(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'for'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_FOR,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # optional condition (nil if no condition / infinite loop)
    if (parser_check(this, token.TAG_LPAREN)) {
        parser_advance(this);  # consume '('

        val cond_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](cond_res)) {
            ret cond_res;
        }

        if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after condition")) {
            ret err[*ast.Node, str]("expected ')'");
        }

        node.info.for_stmt.cond = result_unwrap_ok[*ast.Node, str](cond_res);
    }

    # body
    val body_res: Result[*ast.Node, str] = parser_parse_block(this);
    if (result_is_err[*ast.Node, str](body_res)) {
        ret body_res;
    }

    node.info.for_stmt.body = result_unwrap_ok[*ast.Node, str](body_res);

    ret ok[*ast.Node, str](node);
}

# parse_ret: parse a return statement.
# ret;
# ret expr;
fun parser_parse_ret(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'ret'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_RET,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # optional return value
    if (!parser_check(this, token.TAG_SEMI)) {
        val expr_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](expr_res)) {
            ret expr_res;
        }
        node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](expr_res);
    }

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after return")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_brk: parse a break statement.
fun parser_parse_brk(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'brk'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_BRK,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after break")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret node_res;
}

# parse_cnt: parse a continue statement.
fun parser_parse_cnt(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'cnt'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_CNT,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after continue")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret node_res;
}

# parse_fin: parse a defer statement.
# fin { body }
# fin expr;
fun parser_parse_fin(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'fin'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_FIN,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (parser_check(this, token.TAG_LBRACE)) {
        val body_res: Result[*ast.Node, str] = parser_parse_block(this);
        if (result_is_err[*ast.Node, str](body_res)) {
            ret body_res;
        }
        node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](body_res);
    } or {
        val expr_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](expr_res)) {
            ret expr_res;
        }
        node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](expr_res);

        if (!parser_consume(this, token.TAG_SEMI, "expected ';' after defer expression")) {
            ret err[*ast.Node, str]("expected ';'");
        }
    }

    ret ok[*ast.Node, str](node);
}

# parse_asm: parse an inline assembly block.
# asm { ... }
# the content between braces is extracted and stored in node.info.masm_stmt.content
fun parser_parse_asm(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'asm'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_MASM,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (!parser_consume(this, token.TAG_LBRACE, "expected '{' after 'asm'")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    # record start position of asm content (after the '{')
    val content_start: i32 = this.current.pos;

    # skip the asm content by matching braces
    var depth: i32 = 1;
    var content_end: i32 = content_start;
    for (depth > 0 && !parser_is_at_end(this)) {
        if (parser_check(this, token.TAG_LBRACE)) {
            depth = depth + 1;
        }
        if (parser_check(this, token.TAG_RBRACE)) {
            depth = depth - 1;
            if (depth == 0) {
                # record end position before the final '}'
                content_end = this.current.pos;
            }
        }
        if (depth > 0) {
            parser_advance(this);
        }
    }

    # extract the asm content string
    if (content_end > content_start && this.source != nil) {
        val content_len: usize = (content_end - content_start)::usize;
        val alloc_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](this.alloc, content_len + 1);
        if (result_is_ok[*u8, allocator.AllocError](alloc_res)) {
            val content: *u8 = result_unwrap_ok[*u8, allocator.AllocError](alloc_res);
            var i: usize = 0;
            for (i < content_len) {
                content[i] = this.source[content_start::usize + i];
                i = i + 1;
            }
            content[content_len] = 0;  # null-terminate
            node.info.masm_stmt.content = content::str;
        }
    }

    if (!parser_consume(this, token.TAG_RBRACE, "expected '}' after asm block")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_expr_stmt: parse an expression statement.
# expr;
# or assignment: lvalue = expr;
fun parser_parse_expr_stmt(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_EXPR,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val expr_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](expr_res)) {
        ret expr_res;
    }

    node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](expr_res);

    if (!parser_consume(this, token.TAG_SEMI, "expected ';' after expression")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- expressions ---

# parse_expr: parse an expression.
# uses Pratt parsing with precedence climbing.
pub fun parser_parse_expr(this: *Parser) Result[*ast.Node, str] {
    ret parser_parse_precedence(this, token.PREC_ASSIGN);
}

# parse_precedence: parse expression with minimum precedence.
fun parser_parse_precedence(this: *Parser, min_prec: u8) Result[*ast.Node, str] {
    # parse prefix (primary or unary)
    var left_res: Result[*ast.Node, str] = parser_parse_prefix(this);
    if (result_is_err[*ast.Node, str](left_res)) {
        ret left_res;
    }

    var left: *ast.Node = result_unwrap_ok[*ast.Node, str](left_res);

    # parse infix operators
    for (!parser_is_at_end(this)) {
        val prec: u8 = parser_get_precedence(this, this.current.tag);
        if (prec < min_prec) {
            brk;
        }

        val op_tok: token.Token = this.current;

        # check if `[` should be parsed as type args (followed by `(` or `{`)
        var is_type_args: bool = false;
        if (op_tok.tag == token.TAG_LBRACKET) {
            is_type_args = parser_should_parse_type_args(this);
        }

        parser_advance(this);  # consume operator

        # handle postfix operators at PREC_CALL level
        if (prec == token.PREC_CALL) {
            # if this is type args followed by call, handle specially
            if (is_type_args) {
                val generic_call_res: Result[*ast.Node, str] = parser_parse_generic_call(this, left, op_tok);
                if (result_is_err[*ast.Node, str](generic_call_res)) {
                    ret generic_call_res;
                }
                left = result_unwrap_ok[*ast.Node, str](generic_call_res);
                cnt;
            }

            val postfix_res: Result[*ast.Node, str] = parser_parse_postfix(this, left, op_tok);
            if (result_is_err[*ast.Node, str](postfix_res)) {
                ret postfix_res;
            }
            left = result_unwrap_ok[*ast.Node, str](postfix_res);
            cnt;
        }

        # handle assignment (right-associative)
        var next_prec: u8 = prec + 1;
        if (op_tok.tag == token.TAG_EQ) {
            next_prec = prec;  # right-associative
        }

        val right_res: Result[*ast.Node, str] = parser_parse_precedence(this, next_prec);
        if (result_is_err[*ast.Node, str](right_res)) {
            ret right_res;
        }

        # create binary node
        val bin_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_EXPR_BINARY,
            op_tok
        );

        if (result_is_err[*ast.Node, str](bin_res)) {
            ret bin_res;
        }

        val bin: *ast.Node = result_unwrap_ok[*ast.Node, str](bin_res);

        # store operator tag and operands
        bin.info.binary_expr.op = op_tok.tag;
        bin.info.binary_expr.left = left;
        bin.info.binary_expr.right = result_unwrap_ok[*ast.Node, str](right_res);

        left = bin;
    }

    ret ok[*ast.Node, str](left);
}

# get_precedence: get the precedence of a token.
fun parser_get_precedence(this: *Parser, tag: u8) u8 {
    # assignment
    if (tag == token.TAG_EQ) {
        ret token.PREC_ASSIGN;
    }

    # logical or
    if (tag == token.TAG_PIPE_PIPE) {
        ret token.PREC_OR;
    }

    # logical and
    if (tag == token.TAG_AMP_AMP) {
        ret token.PREC_AND;
    }

    # bitwise or
    if (tag == token.TAG_PIPE) {
        ret token.PREC_BITOR;
    }

    # bitwise xor
    if (tag == token.TAG_CARET) {
        ret token.PREC_BITXOR;
    }

    # bitwise and
    if (tag == token.TAG_AMP) {
        ret token.PREC_BITAND;
    }

    # equality
    if (tag == token.TAG_EQ_EQ || tag == token.TAG_BANG_EQ) {
        ret token.PREC_EQUALITY;
    }

    # comparison
    if (tag == token.TAG_LT || tag == token.TAG_LT_EQ ||
        tag == token.TAG_GT || tag == token.TAG_GT_EQ) {
        ret token.PREC_COMPARISON;
    }

    # shift
    if (tag == token.TAG_LT_LT || tag == token.TAG_GT_GT) {
        ret token.PREC_SHIFT;
    }

    # term
    if (tag == token.TAG_PLUS || tag == token.TAG_MINUS) {
        ret token.PREC_TERM;
    }

    # factor
    if (tag == token.TAG_STAR || tag == token.TAG_SLASH || tag == token.TAG_PERCENT) {
        ret token.PREC_FACTOR;
    }

    # postfix / call
    if (tag == token.TAG_LPAREN || tag == token.TAG_LBRACKET ||
        tag == token.TAG_DOT || tag == token.TAG_COLON_COLON) {
        ret token.PREC_CALL;
    }

    ret token.PREC_NONE;
}

# parse_prefix: parse prefix expression (unary or primary).
fun parser_parse_prefix(this: *Parser) Result[*ast.Node, str] {
    val tag: u8 = this.current.tag;

    # unary operators
    if (tag == token.TAG_BANG || tag == token.TAG_MINUS ||
        tag == token.TAG_TILDE || tag == token.TAG_QUESTION ||
        tag == token.TAG_AT || tag == token.TAG_AMP ||
        tag == token.TAG_STAR) {
        ret parser_parse_unary(this);
    }

    # primary
    ret parser_parse_primary(this);
}

# parse_unary: parse a unary expression.
# !expr, -expr, ~expr, ?ptr, @addr, &ref, *deref
fun parser_parse_unary(this: *Parser) Result[*ast.Node, str] {
    val op_tok: token.Token = this.current;
    parser_advance(this);  # consume operator

    var kind: ast.NodeKind = ast.NODE_EXPR_UNARY;

    # special cases for address-of and dereference
    if (op_tok.tag == token.TAG_QUESTION) {
        kind = ast.NODE_EXPR_ADDR;
    }
    if (op_tok.tag == token.TAG_AT) {
        kind = ast.NODE_EXPR_DEREF;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        kind,
        op_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # store operator tag and operand
    node.info.unary_expr.op = op_tok.tag;

    val operand_res: Result[*ast.Node, str] = parser_parse_precedence(this, token.PREC_UNARY);
    if (result_is_err[*ast.Node, str](operand_res)) {
        ret operand_res;
    }

    node.info.unary_expr.expr = result_unwrap_ok[*ast.Node, str](operand_res);

    ret ok[*ast.Node, str](node);
}

# parse_primary: parse a primary expression.
fun parser_parse_primary(this: *Parser) Result[*ast.Node, str] {
    val tag: u8 = this.current.tag;

    # integer literal
    if (tag == token.TAG_LIT_INT) {
        ret parser_parse_int_literal(this);
    }

    # float literal
    if (tag == token.TAG_LIT_FLOAT) {
        ret parser_parse_float_literal(this);
    }

    # char literal
    if (tag == token.TAG_LIT_CHAR) {
        ret parser_parse_char_literal(this);
    }

    # string literal
    if (tag == token.TAG_LIT_STRING) {
        ret parser_parse_string_literal(this);
    }

    # nil
    if (tag == token.TAG_KW_NIL) {
        ret parser_parse_nil(this);
    }

    # identifier (variable, function, type)
    if (tag == token.TAG_IDENT) {
        if (parser_should_parse_struct_lit_type(this)) {
            val type_res: Result[*ast.Node, str] = parser_parse_named_type(this);
            if (result_is_err[*ast.Node, str](type_res)) {
                ret type_res;
            }
            ret parser_parse_struct_literal(this, result_unwrap_ok[*ast.Node, str](type_res));
        }
        ret parser_parse_ident_expr(this);
    }

    # parenthesized expression
    if (tag == token.TAG_LPAREN) {
        ret parser_parse_paren_expr(this);
    }

    # array literal [...]
    if (tag == token.TAG_LBRACKET) {
        ret parser_parse_array_literal(this);
    }

    # comptime expression $mach.xxx or similar
    if (tag == token.TAG_DOLLAR) {
        ret parser_parse_comptime_expr(this);
    }

    # record literal Name { ... }
    # (handled in parse_ident_expr when followed by {)

    parser_error(this, "expected expression");
    ret err[*ast.Node, str]("expected expression");
}

# parse_comptime_expr: parse a comptime expression ($mach.xxx, etc.).
fun parser_parse_comptime_expr(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '$'

    # expect identifier after $
    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected identifier after '$'");
        ret err[*ast.Node, str]("expected identifier after '$'");
    }

    # create a comptime node
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_COMPTIME,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # parse the identifier path (e.g., mach.build.target.pointer_width)
    val path_res: Result[*ast.Node, str] = parser_parse_ident_expr(this);
    if (result_is_err[*ast.Node, str](path_res)) {
        ret path_res;
    }

    node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](path_res);

    ret ok[*ast.Node, str](node);
}

# parse_int_literal: parse integer literal.
fun parser_parse_int_literal(this: *Parser) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_INT,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.lit_expr.text = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    ret ok[*ast.Node, str](node);
}

# parse_literal_str: parse a string literal.
# parse_float_literal: parse float literal.
fun parser_parse_float_literal(this: *Parser) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_FLOAT,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.lit_expr.text = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    ret ok[*ast.Node, str](node);
}

# parse_literal_char: parse a character literal.
# parse_char_literal: parse character literal.
fun parser_parse_char_literal(this: *Parser) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_CHAR,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.lit_expr.text = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    ret ok[*ast.Node, str](node);
}

# parse_literal_nil: parse the nil literal.
# parse_string_literal: parse string literal.
fun parser_parse_string_literal(this: *Parser) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_STR,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.lit_expr.text = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    ret ok[*ast.Node, str](node);
}

# --- expression parsing ---
# parse_nil: parse nil literal.
fun parser_parse_nil(this: *Parser) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_NIL,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    parser_advance(this);
    ret node_res;
}

# parse_ident_expr: parse identifier expression.
# parses only a single identifier; dots are handled by postfix field access.
fun parser_parse_ident_expr(this: *Parser) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_IDENT,
        this.current
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # parse single identifier only (dots handled as field access in parse_postfix)
    node.info.ident_expr.name = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    # check for struct literal (generic args handled by precedence loop)
    if (parser_check(this, token.TAG_LBRACE) && node.kind != ast.NODE_EXPR_ARRAY_LIT) {
        # struct literal: Type { field: value, ... }
        ret parser_parse_struct_literal(this, node);
    }

    ret ok[*ast.Node, str](node);
}

# parse_generic_args: parse generic type arguments [T, U].
fun parser_parse_generic_args(this: *Parser) Result[*ast.Node, str] {
    parser_advance(this);  # consume '['

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val args: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    # first arg
    if (!parser_check(this, token.TAG_RBRACKET)) {
        val type_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](type_res)) {
            ret type_res;
        }
        ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](type_res));

        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            val t_res: Result[*ast.Node, str] = parser_parse_type(this);
            if (result_is_err[*ast.Node, str](t_res)) {
                ret t_res;
            }
            ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](t_res));
        }
    }

    if (!parser_consume(this, token.TAG_RBRACKET, "expected ']' after generic arguments")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_GENERIC,
        this.previous
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.generic_node.args = args;

    ret ok[*ast.Node, str](node);
}

# parse_struct_literal: parse struct literal { field: value, ... }.
fun parser_parse_struct_literal(this: *Parser, type_node: *ast.Node) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '{'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_STRUCT_LIT,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.struct_lit.type_node = type_node;

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val fields: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    # parse field initializers
    for (!parser_check(this, token.TAG_RBRACE) && !parser_is_at_end(this)) {
        if (!parser_check(this, token.TAG_IDENT)) {
            parser_error(this, "expected field name");
            ret err[*ast.Node, str]("expected field name");
        }

        val field_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_FIELD,
            this.current
        );

        if (result_is_err[*ast.Node, str](field_res)) {
            ret field_res;
        }

        val field: *ast.Node = result_unwrap_ok[*ast.Node, str](field_res);
        field.info.field_decl.name = parser_alloc_current_text_or_nil(this);
        parser_advance(this);

        if (!parser_consume(this, token.TAG_COLON, "expected ':' after field name")) {
            ret err[*ast.Node, str]("expected ':'");
        }

        val value_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](value_res)) {
            ret value_res;
        }

        field.info.field_decl.type_node = result_unwrap_ok[*ast.Node, str](value_res);

        ast.list_append(fields, this.alloc, field);

        if (!parser_check(this, token.TAG_RBRACE)) {
            if (!parser_consume(this, token.TAG_COMMA, "expected ',' or '}' in struct literal")) {
                ret err[*ast.Node, str]("expected ','");
            }
        }
    }

    if (!parser_consume(this, token.TAG_RBRACE, "expected '}' after struct literal")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    node.info.struct_lit.fields = fields;

    ret ok[*ast.Node, str](node);
}

# parse_paren_expr: parse parenthesized expression.
fun parser_parse_paren_expr(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '('

    val expr_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](expr_res)) {
        ret expr_res;
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after expression")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_PAREN,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.wrapper.inner = result_unwrap_ok[*ast.Node, str](expr_res);

    ret ok[*ast.Node, str](node);
}

# parse_array_literal: parse array literal.
# supports:
#   [a, b, c]
#   [N]T{a, b, c}
fun parser_parse_array_literal(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '['

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_ARRAY_LIT,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val elements: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    if (!parser_check(this, token.TAG_RBRACKET)) {
        val first_start: i32 = this.current.pos;
        val first_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](first_res)) {
            ret first_res;
        }

        if (parser_check(this, token.TAG_RBRACKET)) {
            parser_advance(this);

            # require no whitespace between '[' and first token for typed array literal
            val is_typed_array: bool = first_start == start_tok.pos + 1;

            # check for typed array literal: [N]T{...}
            if (is_typed_array && (parser_check(this, token.TAG_IDENT) || parser_check(this, token.TAG_STAR) || parser_check(this, token.TAG_AMP) ||
                parser_check(this, token.TAG_AMP_AMP) || parser_check(this, token.TAG_LBRACKET))) {
                val type_res: Result[*ast.Node, str] = parser_parse_type(this);
                if (result_is_err[*ast.Node, str](type_res)) {
                    ret type_res;
                }
                val type_node: *ast.Node = result_unwrap_ok[*ast.Node, str](type_res);

                if (!parser_consume(this, token.TAG_LBRACE, "expected '{' to start array literal")) {
                    ret err[*ast.Node, str]("expected '{'");
                }

                # parse elements inside braces
                if (!parser_check(this, token.TAG_RBRACE)) {
                    val elem_res: Result[*ast.Node, str] = parser_parse_expr(this);
                    if (result_is_err[*ast.Node, str](elem_res)) {
                        ret elem_res;
                    }
                    ast.list_append(elements, this.alloc, result_unwrap_ok[*ast.Node, str](elem_res));

                    for (parser_check(this, token.TAG_COMMA)) {
                        parser_advance(this);
                        if (parser_check(this, token.TAG_RBRACE)) {
                            brk;
                        }
                        val elem2_res: Result[*ast.Node, str] = parser_parse_expr(this);
                        if (result_is_err[*ast.Node, str](elem2_res)) {
                            ret elem2_res;
                        }
                        ast.list_append(elements, this.alloc, result_unwrap_ok[*ast.Node, str](elem2_res));
                    }
                }

                if (!parser_consume(this, token.TAG_RBRACE, "expected '}' after array elements")) {
                    ret err[*ast.Node, str]("expected '}'");
                }

                # store size, element type, and elements
                node.info.array_lit.type_node = type_node;
                node.info.array_lit.size = result_unwrap_ok[*ast.Node, str](first_res);
                node.info.array_lit.elements = elements;
                ret ok[*ast.Node, str](node);
            }

            # not a typed literal, treat as [a] list
            ast.list_append(elements, this.alloc, result_unwrap_ok[*ast.Node, str](first_res));
            node.info.array_lit.elements = elements;
            ret ok[*ast.Node, str](node);
        }

        ast.list_append(elements, this.alloc, result_unwrap_ok[*ast.Node, str](first_res));

        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            if (parser_check(this, token.TAG_RBRACKET)) {
                brk;  # trailing comma
            }

            val elem_res: Result[*ast.Node, str] = parser_parse_expr(this);
            if (result_is_err[*ast.Node, str](elem_res)) {
                ret elem_res;
            }
            ast.list_append(elements, this.alloc, result_unwrap_ok[*ast.Node, str](elem_res));
        }
    }

    if (!parser_consume(this, token.TAG_RBRACKET, "expected ']' after array literal")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    node.info.array_lit.elements = elements;

    ret ok[*ast.Node, str](node);
}

# parse_postfix: parse postfix expression (call, index, field, cast).
fun parser_parse_postfix(this: *Parser, left: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val tag: u8 = op_tok.tag;

    # function call: expr(args)
    if (tag == token.TAG_LPAREN) {
        ret parser_parse_call(this, left, op_tok);
    }

    # index: expr[index]
    if (tag == token.TAG_LBRACKET) {
        ret parser_parse_index(this, left, op_tok);
    }

    # field access: expr.field
    if (tag == token.TAG_DOT) {
        ret parser_parse_field_access(this, left, op_tok);
    }

    # cast: expr::type
    if (tag == token.TAG_COLON_COLON) {
        ret parser_parse_cast(this, left, op_tok);
    }

    parser_error(this, "unexpected postfix operator");
    ret err[*ast.Node, str]("unexpected postfix operator");
}

# parse_call: parse function call.
# AST structure:
#   info.call_expr.callee = callee expression (single node)
#   info.call_expr.args   = arguments list (*ast.List)
fun parser_parse_call(this: *Parser, callee: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_CALL,
        op_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # callee
    node.info.call_expr.callee = callee;

    # parse arguments into a separate list
    val args_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](args_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](args_res));
    }

    val args: *ast.List = result_unwrap_ok[*ast.List, str](args_res);

    # parse arguments
    if (!parser_check(this, token.TAG_RPAREN)) {
        val first_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](first_res)) {
            ret first_res;
        }
        ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](first_res));

        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            val arg_res: Result[*ast.Node, str] = parser_parse_expr(this);
            if (result_is_err[*ast.Node, str](arg_res)) {
                ret arg_res;
            }
            ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](arg_res));
        }
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after arguments")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    node.info.call_expr.args = args;

    ret ok[*ast.Node, str](node);
}

# parse_generic_call: parse generic function call (func[T](args)).
# ---
# called when we've detected `[...]` followed by `(` - this is a generic call, not index.
# callee: the function expression being called
# op_tok: the `[` token
# ret: call expression with type args attached
fun parser_parse_generic_call(this: *Parser, callee: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    # we've already consumed the `[`, now parse type arguments
    val type_args_res: Result[*ast.Node, str] = parser_parse_generic_args_after_bracket(this);
    if (result_is_err[*ast.Node, str](type_args_res)) {
        ret type_args_res;
    }

    val type_args: *ast.Node = result_unwrap_ok[*ast.Node, str](type_args_res);

    # now we should have `(` for the call
    if (!parser_check(this, token.TAG_LPAREN)) {
        # might be `{` for struct literal - treat callee as type
        if (parser_check(this, token.TAG_LBRACE)) {
            # this is a typed struct literal like Type[T]{ ... }
            # attach type args to callee and parse struct literal
            callee.info.type_name.args = type_args;
            ret parser_parse_struct_literal(this, callee);
        }

        parser_error(this, "expected '(' after generic type arguments");
        ret err[*ast.Node, str]("expected '(' after generic type arguments");
    }

    # consume '(' and parse call
    val call_tok: token.Token = this.current;
    parser_advance(this);

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_CALL,
        call_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # attach type args to the call node
    node.info.call_expr.type_args = type_args;

    # callee
    node.info.call_expr.callee = callee;

    # parse arguments into a separate list
    val args_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](args_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](args_res));
    }

    val args: *ast.List = result_unwrap_ok[*ast.List, str](args_res);

    # parse arguments
    if (!parser_check(this, token.TAG_RPAREN)) {
        val first_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](first_res)) {
            ret first_res;
        }
        ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](first_res));

        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            val arg_res: Result[*ast.Node, str] = parser_parse_expr(this);
            if (result_is_err[*ast.Node, str](arg_res)) {
                ret arg_res;
            }
            ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](arg_res));
        }
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after arguments")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    node.info.call_expr.args = args;

    ret ok[*ast.Node, str](node);
}

# parse_generic_args_after_bracket: parse generic args when `[` already consumed.
fun parser_parse_generic_args_after_bracket(this: *Parser) Result[*ast.Node, str] {
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val args: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    # first arg
    if (!parser_check(this, token.TAG_RBRACKET)) {
        val type_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](type_res)) {
            ret type_res;
        }
        ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](type_res));

        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            val t_res: Result[*ast.Node, str] = parser_parse_type(this);
            if (result_is_err[*ast.Node, str](t_res)) {
                ret t_res;
            }
            ast.list_append(args, this.alloc, result_unwrap_ok[*ast.Node, str](t_res));
        }
    }

    if (!parser_consume(this, token.TAG_RBRACKET, "expected ']' after generic arguments")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_GENERIC,
        this.previous
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);
    node.info.generic_node.args = args;

    ret ok[*ast.Node, str](node);
}

# parse_index: parse array/pointer index.
fun parser_parse_index(this: *Parser, base: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_INDEX,
        op_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val index_res: Result[*ast.Node, str] = parser_parse_expr(this);
    if (result_is_err[*ast.Node, str](index_res)) {
        ret index_res;
    }

    if (!parser_consume(this, token.TAG_RBRACKET, "expected ']' after index")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    node.info.index_expr.base = base;
    node.info.index_expr.index = result_unwrap_ok[*ast.Node, str](index_res);

    ret ok[*ast.Node, str](node);
}

# parse_field_access: parse field access expression.
fun parser_parse_field_access(this: *Parser, base: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_FIELD,
        op_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (!parser_check(this, token.TAG_IDENT)) {
        parser_error(this, "expected field name after '.'");
        ret err[*ast.Node, str]("expected field name");
    }

    node.info.field_expr.field = parser_alloc_current_text_or_nil(this);
    parser_advance(this);

    node.info.field_expr.object = base;

    ret ok[*ast.Node, str](node);
}

# parse_cast: parse type cast.
fun parser_parse_cast(this: *Parser, expr: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_CAST,
        op_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val type_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](type_res)) {
        ret type_res;
    }

    node.info.cast_expr.expr = expr;
    node.info.cast_expr.type_node = result_unwrap_ok[*ast.Node, str](type_res);

    ret ok[*ast.Node, str](node);
}

# --- type parsing ---

# parse_type: parse a type expression.
# ---
# ret: Ok(*ast.Node) with type AST, or Err(str) on failure
pub fun parser_parse_type(this: *Parser) Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    val tag: u8 = this.current.tag;

    # mutable pointer: *T
    if (tag == token.TAG_STAR) {
        ret parser_parse_ptr_type(this, true);
    }

    # readonly pointer: &T
    if (tag == token.TAG_AMP) {
        ret parser_parse_ptr_type(this, false);
    }

    # double readonly pointer: &&T
    if (tag == token.TAG_AMP_AMP) {
        ret parser_parse_double_ptr_type(this);
    }

    # array type: [N]T
    if (tag == token.TAG_LBRACKET) {
        ret parser_parse_array_type(this);
    }

    # function type: fun(...) T
    if (tag == token.TAG_KW_FUN) {
        ret parser_parse_fun_type(this);
    }

    # anonymous record: rec { ... }
    if (tag == token.TAG_KW_REC) {
        ret parser_parse_rec(this, false, true);  # is_type=true for type context
    }

    # anonymous union: uni { ... }
    if (tag == token.TAG_KW_UNI) {
        ret parser_parse_uni(this, false, true);  # is_type=true for type context
    }

    # named type or primitive (including dotted paths)
    if (tag == token.TAG_IDENT) {
        ret parser_parse_named_type(this);
    }

    parser_error(this, "expected type");
    ret err[*ast.Node, str]("expected type");
}

# parse_ptr_type: parse pointer type *T or &T.
fun parser_parse_ptr_type(this: *Parser, is_mutable: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume * or &

    var kind: ast.NodeKind = ast.NODE_TYPE_REF;
    if (is_mutable) {
        kind = ast.NODE_TYPE_PTR;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        kind,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    val inner_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](inner_res)) {
        ret inner_res;
    }

    node.info.type_ptr.inner = result_unwrap_ok[*ast.Node, str](inner_res);

    ret ok[*ast.Node, str](node);
}

# parse_double_ptr_type: parse double readonly pointer type &&T.
# This handles the case where && is lexed as a single token.
fun parser_parse_double_ptr_type(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '&&'

    # create outer &
    val outer_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_REF,
        start_tok
    );

    if (result_is_err[*ast.Node, str](outer_res)) {
        ret outer_res;
    }

    val outer: *ast.Node = result_unwrap_ok[*ast.Node, str](outer_res);

    # create inner &
    val inner_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_REF,
        start_tok
    );

    if (result_is_err[*ast.Node, str](inner_res)) {
        ret inner_res;
    }

    val inner: *ast.Node = result_unwrap_ok[*ast.Node, str](inner_res);

    # parse the base type
    val base_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](base_res)) {
        ret base_res;
    }

    # link: outer -> inner -> base
    inner.info.type_ptr.inner = result_unwrap_ok[*ast.Node, str](base_res);
    outer.info.type_ptr.inner = inner;

    ret ok[*ast.Node, str](outer);
}

# parse_array_type: parse array type [N]T.
fun parser_parse_array_type(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume '['

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_ARRAY,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # array size (expression or empty for inferred)
    if (!parser_check(this, token.TAG_RBRACKET)) {
        val size_res: Result[*ast.Node, str] = parser_parse_expr(this);
        if (result_is_err[*ast.Node, str](size_res)) {
            ret size_res;
        }
        node.info.type_array.size = result_unwrap_ok[*ast.Node, str](size_res);
    }

    if (!parser_consume(this, token.TAG_RBRACKET, "expected ']' after array size")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val inner_res: Result[*ast.Node, str] = parser_parse_type(this);
    if (result_is_err[*ast.Node, str](inner_res)) {
        ret inner_res;
    }

    node.info.type_array.elem_type = result_unwrap_ok[*ast.Node, str](inner_res);

    ret ok[*ast.Node, str](node);
}

# parse_fun_type: parse function type fun(...) T.
fun parser_parse_fun_type(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    parser_advance(this);  # consume 'fun'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_FUN,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    if (!parser_consume(this, token.TAG_LPAREN, "expected '(' in function type")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (result_is_err[*ast.List, str](list_res)) {
        ret err[*ast.Node, str](result_unwrap_err[*ast.List, str](list_res));
    }

    val params: *ast.List = result_unwrap_ok[*ast.List, str](list_res);

    # parse parameter types
    if (!parser_check(this, token.TAG_RPAREN)) {
        val first_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](first_res)) {
            ret first_res;
        }
        ast.list_append(params, this.alloc, result_unwrap_ok[*ast.Node, str](first_res));

        for (parser_check(this, token.TAG_COMMA)) {
            parser_advance(this);

            val t_res: Result[*ast.Node, str] = parser_parse_type(this);
            if (result_is_err[*ast.Node, str](t_res)) {
                ret t_res;
            }
            ast.list_append(params, this.alloc, result_unwrap_ok[*ast.Node, str](t_res));
        }
    }

    if (!parser_consume(this, token.TAG_RPAREN, "expected ')' after parameter types")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # return type (optional — void if followed by terminator)
    node.info.type_fun.params = params;
    if (!parser_check(this, token.TAG_SEMI) && !parser_check(this, token.TAG_COMMA)
        && !parser_check(this, token.TAG_RPAREN)) {
        val ret_res: Result[*ast.Node, str] = parser_parse_type(this);
        if (result_is_err[*ast.Node, str](ret_res)) {
            ret ret_res;
        }
        node.info.type_fun.ret_type = result_unwrap_ok[*ast.Node, str](ret_res);
    }

    ret ok[*ast.Node, str](node);
}

# parse_named_type: parse named type (identifier, possibly with generics).
fun parser_parse_named_type(this: *Parser) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_NAME,
        start_tok
    );

    if (result_is_err[*ast.Node, str](node_res)) {
        ret node_res;
    }

    val node: *ast.Node = result_unwrap_ok[*ast.Node, str](node_res);

    # parse path (possibly dotted)
    val path: str = parser_parse_path(this);
    node.info.type_name.path = path;

    # check for generic args
    if (parser_check(this, token.TAG_LBRACKET)) {
        val args_res: Result[*ast.Node, str] = parser_parse_generic_args(this);
        if (result_is_err[*ast.Node, str](args_res)) {
            ret args_res;
        }
        node.info.type_name.args = result_unwrap_ok[*ast.Node, str](args_res);
    }

    ret ok[*ast.Node, str](node);
}

# --- error recovery ---

# synchronize: recover from an error by skipping to a synchronization point.
# ---
# ret: none
pub fun parser_synchronize(this: *Parser) {
    if (this == nil) {
        ret;
    }

    parser_advance(this);

    for (!parser_is_at_end(this)) {
        # stop at statement boundaries
        if (this.previous.tag == token.TAG_SEMI) {
            ret;
        }

        # stop at top-level declaration keywords
        val tag: u8 = this.current.tag;
        if (tag == token.TAG_KW_FUN ||
            tag == token.TAG_KW_REC ||
            tag == token.TAG_KW_UNI ||
            tag == token.TAG_KW_USE ||
            tag == token.TAG_KW_PUB ||
            tag == token.TAG_KW_VAL ||
            tag == token.TAG_KW_VAR ||
            tag == token.TAG_KW_TEST) {
            ret;
        }

        parser_advance(this);
    }
}

# get_error_count: get the number of parsing errors.
# ---
# ret: error count
pub fun parser_get_error_count(this: &Parser) i32 {
    if (this == nil) {
        ret 0;
    }
    ret this.error_count;
}

# has_errors: check if any errors occurred.
pub fun parser_has_errors(this: &Parser) bool {
    ret this.had_error;
}

# get_error: get a specific error by index.
# ---
# index: error index (0-based)
# ret:   Option[ParserError] - some if index is valid, none otherwise
pub fun parser_get_error(this: &Parser, index: i32) Option[ParserError] {
    if (this == nil || this.errors == nil || index < 0 || index >= this.error_count) {
        ret none[ParserError]();
    }
    ret some[ParserError](this.errors[index]);
}
