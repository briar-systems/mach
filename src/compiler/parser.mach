# parse_type: parse a type expression.
# ---
# ret: Ok(*ast.Node) with type AST, or Err(str) on failure
pub fun (this: *Parser) parse_type() Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    # TODO: parse type expressions
    # - *T: mutable pointer
    # - &T: readonly pointer
    # - [N]T: array type
    # - fun(...) T: function type
    # - rec { ... }: anonymous record
    # - uni { ... }: anonymous union
    # - identifier: named type
    # - identifier[T, ...]: generic instantiation

    ret err[*ast.Node, str]("parse_type not yet implemented");
