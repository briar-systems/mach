use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use mem: std.memory;
use print: std.print;

use ast:   mach.compiler.ast;
use lexer: mach.compiler.lexer;
use token: mach.compiler.token;

# mach.compiler.parser: recursive descent parser for Mach source code.
# ---
# converts a stream of tokens into an abstract syntax tree.

# ParserError: a parsing error with location information.
# ---
# tok:     token where error occurred
# message: error description
pub rec ParserError {
    tok:     token.Token;
    message: str;
}

# Parser: parser state.
# ---
# lex:        lexer providing tokens
# source:     original source text (for extracting token text)
# alloc:      allocator for AST nodes
# current:    current token
# previous:   previous token
# had_error:  true if any error occurred
# errors:     list of errors
# error_count: number of errors
pub rec Parser {
    lex:         lexer.Lexer;
    source:      str;
    alloc:       *allocator.Allocator;
    current:     token.Token;
    previous:    token.Token;
    had_error:   bool;
    errors:      *ParserError;
    error_count: i32;
    error_cap:   i32;
}

# init: create a new parser for a source string.
# ---
# source: source text to parse
# alloc:  allocator for AST nodes
# ret:    initialized Parser
pub fun init(source: str, alloc: *allocator.Allocator) Parser {
    var p: Parser;
    p.lex = lexer.init(source);
    p.source = source;
    p.alloc = alloc;
    p.current = p.lex.next();
    p.previous = p.current;
    p.had_error = false;
    p.errors = nil;
    p.error_count = 0;
    p.error_cap = 0;
    ret p;
}

# deinit: clean up parser resources.
# ---
# ret: none
pub fun (this: *Parser) deinit() {
    if (this == nil) {
        ret;
    }

    this.lex.deinit();

    if (this.errors != nil && this.alloc != nil) {
        this.alloc.free[ParserError](this.errors, this.error_cap::usize);
    }
}

# advance: consume the current token and get the next one.
# ---
# ret: none
pub fun (this: *Parser) advance() {
    if (this == nil) {
        ret;
    }

    this.previous = this.current;
    this.current = this.lex.next();
}

# check: check if the current token has the given tag.
# ---
# tag: token tag to check for
# ret: true if current token matches tag
pub fun (this: &Parser) check(tag: u8) bool {
    if (this == nil) {
        ret false;
    }
    ret this.current.tag == tag;
}

# check_any: check if current token matches any of several tags.
# ---
# returns true if current matches tag1 or tag2
pub fun (this: &Parser) check2(tag1: u8, tag2: u8) bool {
    if (this == nil) {
        ret false;
    }
    ret this.current.tag == tag1 || this.current.tag == tag2;
}

# check3: check if current token matches any of three tags.
pub fun (this: &Parser) check3(tag1: u8, tag2: u8, tag3: u8) bool {
    if (this == nil) {
        ret false;
    }
    val t: u8 = this.current.tag;
    ret t == tag1 || t == tag2 || t == tag3;
}

# match_tag: if current token matches tag, consume it and return true.
# ---
# tag: token tag to match
# ret: true if matched and consumed, false otherwise
pub fun (this: *Parser) match_tag(tag: u8) bool {
    if (!this.check(tag)) {
        ret false;
    }

    this.advance();
    ret true;
}

# consume: consume current token if it matches tag, otherwise error.
# ---
# tag:     expected token tag
# message: error message if token doesn't match
# ret:     true if consumed successfully, false on error
pub fun (this: *Parser) consume(tag: u8, message: str) bool {
    if (this.check(tag)) {
        this.advance();
        ret true;
    }

    this.error(message);
    ret false;
}

# error: record a parsing error at the current token.
# ---
# message: error description
# ret:     none
pub fun (this: *Parser) error(message: str) {
    if (this == nil) {
        ret;
    }

    this.had_error = true;
    this.add_error(this.current, message);
}

# error_at: record a parsing error at a specific token.
# ---
# tok:     token where error occurred
# message: error description
# ret:     none
pub fun (this: *Parser) error_at(tok: token.Token, message: str) {
    if (this == nil) {
        ret;
    }

    this.had_error = true;
    this.add_error(tok, message);
}

# add_error: append error to error list.
fun (this: *Parser) add_error(tok: token.Token, message: str) {
    if (this == nil || this.alloc == nil) {
        # set error_cap to -1 to signal nil issue
        if (this != nil) {
            this.error_cap = -1;
        }
        ret;
    }

    # grow errors array if needed
    if (this.error_count >= this.error_cap) {
        var new_cap: i32 = 8;
        if (this.error_cap > 0) {
            new_cap = this.error_cap * 2;
        }

        val r: Result[*ParserError, allocator.AllocError] = this.alloc.resize[ParserError](
            this.errors,
            this.error_cap::usize,
            new_cap::usize
        );

        if (r.is_err()) {
            # set error_cap to -2 to signal resize failure
            this.error_cap = -2;
            ret;
        }

        this.errors = r.unwrap_ok();
        this.error_cap = new_cap;
    }

    val idx: i32 = this.error_count;
    this.errors[idx].tok = tok;
    this.errors[idx].message = message;
    this.error_count = this.error_count + 1;
}

# is_at_end: check if parser has reached end of input.
# ---
# ret: true if at end of file
pub fun (this: &Parser) is_at_end() bool {
    if (this == nil) {
        ret true;
    }
    ret this.current.tag == token.TAG_EOF;
}

# get_token_text: extract the text of a token from source.
# ---
# tok: token to get text for
# ret: pointer to start of token text (use tok.len for length)
pub fun (this: &Parser) get_token_text(tok: token.Token) str {
    if (this == nil || this.source == nil) {
        ret nil;
    }

    if (tok.pos < 0 || tok.len <= 0) {
        ret nil;
    }

    # pointer arithmetic: source base + offset
    ret (this.source::u64 + tok.pos::u64)::str;
}

# current_text: get the text of the current token.
pub fun (this: &Parser) current_text() str {
    ret this.get_token_text(this.current);
}

# previous_text: get the text of the previous token.
pub fun (this: &Parser) previous_text() str {
    ret this.get_token_text(this.previous);
}

# alloc_token_text: allocate a null-terminated copy of a token's text.
# ---
# tok: token to get text for
# ret: Ok(str) with allocated null-terminated string, Err on failure
pub fun (this: *Parser) alloc_token_text(tok: token.Token) Result[str, str] {
    if (this == nil || this.source == nil || this.alloc == nil) {
        ret err[str, str]("parser or allocator is nil");
    }

    if (tok.pos < 0 || tok.len <= 0) {
        ret err[str, str]("invalid token position or length");
    }

    val len: usize = tok.len::usize;

    # allocate buffer for string + null terminator
    val r: Result[*u8, allocator.AllocError] = this.alloc.alloc[u8](len + 1);
    if (r.is_err()) {
        ret err[str, str](r.unwrap_err());
    }

    val buf: *u8 = r.unwrap_ok();
    val src: ptr = (this.source::u64 + tok.pos::u64)::ptr;
    mem.raw_copy(buf::ptr, src, len);
    buf[len] = 0;
    ret ok[str, str](buf::str);
}

# alloc_current_text: allocate a null-terminated copy of the current token's text.
# ---
# ret: Ok(str) with allocated null-terminated string, Err on failure
pub fun (this: *Parser) alloc_current_text() Result[str, str] {
    ret this.alloc_token_text(this.current);
}

# alloc_current_text_or_nil: allocate a null-terminated copy of current token text.
# ---
# returns nil on failure (simpler interface when allocation failure is non-fatal)
pub fun (this: *Parser) alloc_current_text_or_nil() str {
    val r: Result[str, str] = this.alloc_current_text();
    if (r.is_err()) {
        ret nil;
    }
    ret r.unwrap_ok();
}

# should_parse_type_args: check if `[...]` should be parsed as type arguments.
# ---
# uses lookahead to check if the closing `]` is followed by `(` (call) or `{` (struct literal).
# if so, the brackets contain type arguments, not an index expression.
# ret: true if we should parse as type arguments, false for index expression
pub fun (this: *Parser) should_parse_type_args() bool {
    if (this == nil || !this.check(token.TAG_LBRACKET)) {
        ret false;
    }

    # save lexer position for lookahead
    val saved_pos: i32 = this.lex.save_pos();
    val saved_current: token.Token = this.current;

    # skip past the opening `[`
    this.advance();

    # track bracket depth
    var depth: i32 = 1;
    var has_content: bool = false;

    # scan until we find the matching `]` or hit EOF/semicolon
    for (depth > 0 && !this.is_at_end()) {
        val tag: u8 = this.current.tag;

        if (tag == token.TAG_LBRACKET) {
            depth = depth + 1;
        } or {
            if (tag == token.TAG_RBRACKET) {
                depth = depth - 1;
            } or {
                if (tag == token.TAG_SEMI || tag == token.TAG_EOF) {
                    # hit statement boundary, not type args
                    this.lex.restore_pos(saved_pos);
                    this.current = saved_current;
                    ret false;
                } or {
                    has_content = true;
                }
            }
        }

        if (depth > 0) {
            this.advance();
        }
    }

    # check what follows the closing `]`
    var is_type_args: bool = false;
    if (depth == 0 && has_content) {
        this.advance();  # consume the `]`
        val follow_tag: u8 = this.current.tag;
        if (follow_tag == token.TAG_LPAREN || follow_tag == token.TAG_LBRACE) {
            is_type_args = true;
        }
    }

    # restore lexer position
    this.lex.restore_pos(saved_pos);
    this.current = saved_current;

    ret is_type_args;
}

# --- top-level parsing ---

# parse_program: parse an entire program (top-level declarations).
# ---
# ret: Ok(*ast.Node) with program AST, or Err(str) on failure
pub fun (this: *Parser) parse_program() Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    if (this.alloc == nil) {
        ret err[*ast.Node, str]("allocator is nil");
    }

    # create program node
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_PROGRAM,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val program: *ast.Node = node_res.unwrap_ok();

    # create list for top-level declarations
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val decls: *ast.List = list_res.unwrap_ok();

    # parse declarations until EOF
    for (!this.is_at_end()) {
        val decl_res: Result[*ast.Node, str] = this.parse_decl();

        if (decl_res.is_err()) {
            # try to recover and continue
            this.synchronize();
            cnt;
        }

        val decl: *ast.Node = decl_res.unwrap_ok();
        if (decl != nil) {
            val append_res: Result[bool, str] = decls.append(this.alloc, decl);
            if (append_res.is_err()) {
                ret err[*ast.Node, str](append_res.unwrap_err());
            }
        }
    }

    program.data = decls::ptr;

    ret ok[*ast.Node, str](program);
}

# parse_decl: parse a top-level declaration.
# ---
# ret: Ok(*ast.Node) with declaration AST, or Err(str) on failure
pub fun (this: *Parser) parse_decl() Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    val tag: u8 = this.current.tag;

    # use statement
    if (tag == token.TAG_KW_USE) {
        ret this.parse_use();
    }

    # pub modifier
    if (tag == token.TAG_KW_PUB) {
        ret this.parse_pub();
    }

    # ext declaration
    if (tag == token.TAG_KW_EXT) {
        ret this.parse_ext();
    }

    # def type alias
    if (tag == token.TAG_KW_DEF) {
        ret this.parse_def();
    }

    # rec record
    if (tag == token.TAG_KW_REC) {
        ret this.parse_rec(false, false);  # is_type=false for declaration context
    }

    # uni union
    if (tag == token.TAG_KW_UNI) {
        ret this.parse_uni(false, false);  # is_type=false for declaration context
    }

    # val constant
    if (tag == token.TAG_KW_VAL) {
        ret this.parse_val(false);
    }

    # var global
    if (tag == token.TAG_KW_VAR) {
        ret this.parse_var(false);
    }

    # fun function
    if (tag == token.TAG_KW_FUN) {
        ret this.parse_fun(false);
    }

    # test block
    if (tag == token.TAG_KW_TEST) {
        ret this.parse_test();
    }

    # comptime: $if, $error, attribute
    if (tag == token.TAG_DOLLAR) {
        ret this.parse_comptime();
    }

    # comment (hash at top level is already skipped by lexer)
    # if we see hash here, skip the line
    if (tag == token.TAG_HASH) {
        this.skip_to_newline();
        ret ok[*ast.Node, str](nil);
    }

    this.error("expected declaration");
    ret err[*ast.Node, str]("expected declaration");
}

# skip_to_newline: skip tokens until newline or EOF.
fun (this: *Parser) skip_to_newline() {
    for (!this.is_at_end()) {
        if (this.current.tag == token.TAG_NEWLINE) {
            this.advance();
            ret;
        }
        this.advance();
    }
}

# --- use statement ---

# parse_use: parse a use statement.
# use module.path;
# use alias: module.path;
pub fun (this: *Parser) parse_use() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'use'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_USE,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # check for alias: path syntax
    var has_alias: bool = false;
    var alias_tok: token.Token = this.current;

    if (this.check(token.TAG_IDENT)) {
        # peek ahead for colon
        val id_tok: token.Token = this.current;
        this.advance();

        if (this.check(token.TAG_COLON)) {
            # this is alias: path
            has_alias = true;
            alias_tok = id_tok;
            this.advance();  # consume ':'
        } or {
            # no alias, put back by parsing as path
            # actually we already consumed the ident, treat as first part of path
            # we need to build path starting with this ident
            node.data = this.parse_path_after_first(id_tok)::ptr;
            if (!this.consume(token.TAG_SEMI, "expected ';' after use statement")) {
                ret err[*ast.Node, str]("expected ';' after use statement");
            }
            ret ok[*ast.Node, str](node);
        }
    }

    # parse the module path
    val path: str = this.parse_path();
    if (path == nil && this.had_error) {
        ret err[*ast.Node, str]("expected module path");
    }

    # store path and alias in node
    node.data = path::ptr;
    if (has_alias) {
        # store alias text in extra field (null-terminated)
        val alias_res: Result[str, str] = this.alloc_token_text(alias_tok);
        if (alias_res.is_ok()) {
            node.extra = alias_res.unwrap_ok()::ptr;
            node.count = 1;  # marker that alias exists
        }
    }

    if (!this.consume(token.TAG_SEMI, "expected ';' after use statement")) {
        ret err[*ast.Node, str]("expected ';' after use statement");
    }

    ret ok[*ast.Node, str](node);
}

# parse_path: parse a dotted identifier path (e.g., std.types.bool).
# ret: the path as a string (null-terminated, allocated)
fun (this: *Parser) parse_path() str {
    if (!this.check(token.TAG_IDENT)) {
        this.error("expected identifier in path");
        ret nil;
    }

    val start_pos: i32 = this.current.pos;
    var end_pos: i32 = this.current.pos + this.current.len;

    this.advance();  # consume first ident

    # continue with .ident
    for (this.check(token.TAG_DOT)) {
        this.advance();  # consume '.'

        if (!this.check(token.TAG_IDENT)) {
            this.error("expected identifier after '.'");
            ret nil;
        }

        end_pos = this.current.pos + this.current.len;
        this.advance();  # consume ident
    }

    # allocate null-terminated copy
    val len: usize = (end_pos - start_pos)::usize;
    val r: Result[*u8, allocator.AllocError] = this.alloc.alloc[u8](len + 1);
    if (r.is_err()) {
        ret nil;
    }
    val buf: *u8 = r.unwrap_ok();
    val src: ptr = (this.source::u64 + start_pos::u64)::ptr;
    mem.raw_copy(buf::ptr, src, len);
    buf[len] = 0;
    ret buf::str;
}

# parse_path_after_first: build path after first ident already consumed.
fun (this: *Parser) parse_path_after_first(first: token.Token) str {
    val start_pos: i32 = first.pos;
    var end_pos: i32 = first.pos + first.len;

    # continue with .ident
    for (this.check(token.TAG_DOT)) {
        this.advance();  # consume '.'

        if (!this.check(token.TAG_IDENT)) {
            this.error("expected identifier after '.'");
            ret nil;
        }

        end_pos = this.current.pos + this.current.len;
        this.advance();  # consume ident
    }

    # allocate null-terminated copy
    val len: usize = (end_pos - start_pos)::usize;
    val r: Result[*u8, allocator.AllocError] = this.alloc.alloc[u8](len + 1);
    if (r.is_err()) {
        ret nil;
    }
    val buf: *u8 = r.unwrap_ok();
    val src: ptr = (this.source::u64 + start_pos::u64)::ptr;
    mem.raw_copy(buf::ptr, src, len);
    buf[len] = 0;
    ret buf::str;
}

# --- pub modifier ---

# parse_pub: parse a pub declaration.
# pub fun/rec/uni/val/var/ext/def ...
# Creates a NODE_DECL_PUB wrapper node with the actual declaration as children.
pub fun (this: *Parser) parse_pub() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'pub'

    # create the pub wrapper node
    val pub_node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_PUB,
        start_tok
    );

    if (pub_node_res.is_err()) {
        ret pub_node_res;
    }

    val pub_node: *ast.Node = pub_node_res.unwrap_ok();

    val tag: u8 = this.current.tag;

    # dispatch to actual declaration
    var inner_res: Result[*ast.Node, str] = err[*ast.Node, str]("expected declaration after 'pub'");

    if (tag == token.TAG_KW_FUN) {
        inner_res = this.parse_fun(true);
    } or {
        if (tag == token.TAG_KW_REC) {
            inner_res = this.parse_rec(true, false);  # is_type=false for declaration context
        } or {
            if (tag == token.TAG_KW_UNI) {
                inner_res = this.parse_uni(true, false);  # is_type=false for declaration context
            } or {
                if (tag == token.TAG_KW_VAL) {
                    inner_res = this.parse_val(true);
                } or {
                    if (tag == token.TAG_KW_VAR) {
                        inner_res = this.parse_var(true);
                    } or {
                        if (tag == token.TAG_KW_EXT) {
                            inner_res = this.parse_ext();
                        } or {
                            if (tag == token.TAG_KW_DEF) {
                                inner_res = this.parse_def();
                            } or {
                                this.error("expected declaration after 'pub'");
                                ret err[*ast.Node, str]("expected declaration after 'pub'");
                            }
                        }
                    }
                }
            }
        }
    }

    if (inner_res.is_err()) {
        ret inner_res;
    }

    # wrap the inner declaration in the pub node
    pub_node.children = inner_res.unwrap_ok();
    pub_node.count = 1;

    ret ok[*ast.Node, str](pub_node);
}

# --- ext declaration ---

# parse_ext: parse an ext (external) declaration.
# ext fun name(...) type;
# ext val name: type;
pub fun (this: *Parser) parse_ext() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'ext'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_EXT,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val tag: u8 = this.current.tag;

    if (tag == token.TAG_KW_FUN) {
        # parse external function signature
        val fun_res: Result[*ast.Node, str] = this.parse_fun_signature();
        if (fun_res.is_err()) {
            ret fun_res;
        }
        node.children = fun_res.unwrap_ok();
        node.count = 1;
    } or {
        if (tag == token.TAG_KW_VAL || tag == token.TAG_KW_VAR) {
            # parse external variable
            this.advance();  # consume val/var

            if (!this.check(token.TAG_IDENT)) {
                this.error("expected identifier in ext declaration");
                ret err[*ast.Node, str]("expected identifier");
            }

            node.data = this.alloc_current_text_or_nil()::ptr;
            this.advance();

            if (!this.consume(token.TAG_COLON, "expected ':' after identifier")) {
                ret err[*ast.Node, str]("expected ':'");
            }

            val type_res: Result[*ast.Node, str] = this.parse_type();
            if (type_res.is_err()) {
                ret type_res;
            }
            node.children = type_res.unwrap_ok();
            node.count = 1;
        } or {
            this.error("expected 'fun', 'val', or 'var' after 'ext'");
            ret err[*ast.Node, str]("expected 'fun', 'val', or 'var' after 'ext'");
        }
    }

    if (!this.consume(token.TAG_SEMI, "expected ';' after ext declaration")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- def type alias ---

# parse_def: parse a type alias definition.
# def Name = Type;
pub fun (this: *Parser) parse_def() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'def'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_DEF,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected identifier after 'def'");
        ret err[*ast.Node, str]("expected identifier");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # optional generic parameters
    if (this.check(token.TAG_LBRACKET)) {
        val generics_res: Result[*ast.Node, str] = this.parse_generic_params();
        if (generics_res.is_err()) {
            ret generics_res;
        }
        # store generics in children[0]
    }

    if (!this.consume(token.TAG_COLON, "expected ':' after type name")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = this.parse_type();
    if (type_res.is_err()) {
        ret type_res;
    }

    node.children = type_res.unwrap_ok();
    node.count = 1;

    if (!this.consume(token.TAG_SEMI, "expected ';' after def")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- rec declaration ---

# parse_rec: parse a record declaration or type.
# rec Name { field: type; ... }
# is_type: true if parsing as a type expression (anonymous), false if declaration
pub fun (this: *Parser) parse_rec(is_pub: bool, is_type: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'rec'

    # use type node if parsing as type expression, otherwise declaration node
    var node_kind: ast.NodeKind = ast.NODE_DECL_REC;
    if (is_type) {
        node_kind = ast.NODE_TYPE_REC;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        node_kind,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # check for named or anonymous record
    if (this.check(token.TAG_IDENT)) {
        node.data = this.alloc_current_text_or_nil()::ptr;
        this.advance();

        # optional generic parameters
        if (this.check(token.TAG_LBRACKET)) {
            val generics_res: Result[*ast.Node, str] = this.parse_generic_params();
            if (generics_res.is_err()) {
                ret generics_res;
            }
            node.generics = generics_res.unwrap_ok();
        }
    }

    if (!this.consume(token.TAG_LBRACE, "expected '{' in record definition")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    # parse fields
    val fields_res: Result[*ast.List, str] = this.parse_fields();
    if (fields_res.is_err()) {
        ret err[*ast.Node, str](fields_res.unwrap_err());
    }

    node.children = fields_res.unwrap_ok()::*ast.Node;

    if (!this.consume(token.TAG_RBRACE, "expected '}' after record fields")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_fields: parse field declarations inside rec or uni.
fun (this: *Parser) parse_fields() Result[*ast.List, str] {
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret list_res;
    }

    val fields: *ast.List = list_res.unwrap_ok();

    for (!this.check(token.TAG_RBRACE) && !this.is_at_end()) {
        val field_res: Result[*ast.Node, str] = this.parse_field();
        if (field_res.is_err()) {
            ret err[*ast.List, str](field_res.unwrap_err());
        }

        val append_res: Result[bool, str] = fields.append(this.alloc, field_res.unwrap_ok());
        if (append_res.is_err()) {
            ret err[*ast.List, str](append_res.unwrap_err());
        }
    }

    ret ok[*ast.List, str](fields);
}

# parse_field: parse a single field declaration.
# name: type;
fun (this: *Parser) parse_field() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected field name");
        ret err[*ast.Node, str]("expected field name");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_FIELD,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    if (!this.consume(token.TAG_COLON, "expected ':' after ext fun name")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = this.parse_type();
    if (type_res.is_err()) {
        ret type_res;
    }

    node.children = type_res.unwrap_ok();
    node.count = 1;

    if (!this.consume(token.TAG_SEMI, "expected ';' after field type")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- uni declaration ---

# parse_uni: parse a union declaration or type.
# uni Name { variant: type; ... }
# is_type: true if parsing as a type expression (anonymous), false if declaration
pub fun (this: *Parser) parse_uni(is_pub: bool, is_type: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'uni'

    # use type node if parsing as type expression, otherwise declaration node
    var node_kind: ast.NodeKind = ast.NODE_DECL_UNI;
    if (is_type) {
        node_kind = ast.NODE_TYPE_UNI;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        node_kind,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # check for named or anonymous union
    if (this.check(token.TAG_IDENT)) {
        node.data = this.alloc_current_text_or_nil()::ptr;
        this.advance();

        # optional generic parameters
        if (this.check(token.TAG_LBRACKET)) {
            val generics_res: Result[*ast.Node, str] = this.parse_generic_params();
            if (generics_res.is_err()) {
                ret generics_res;
            }
            node.generics = generics_res.unwrap_ok();
        }
    }

    if (!this.consume(token.TAG_LBRACE, "expected '{' in union definition")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    # parse variants (same as fields)
    val fields_res: Result[*ast.List, str] = this.parse_fields();
    if (fields_res.is_err()) {
        ret err[*ast.Node, str](fields_res.unwrap_err());
    }

    node.children = fields_res.unwrap_ok()::*ast.Node;

    if (!this.consume(token.TAG_RBRACE, "expected '}' after union variants")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    ret ok[*ast.Node, str](node);
}

# --- val declaration ---

# parse_val: parse a val (immutable) declaration.
# val name: type = expr;
# val name = expr;
# AST structure:
#   data     = name (str)
#   extra    = type node (or nil if no annotation)
#   children = initializer expression
pub fun (this: *Parser) parse_val(is_pub: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'val'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_VAL,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected identifier after 'val'");
        ret err[*ast.Node, str]("expected identifier");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # optional type annotation - store in extra
    if (this.check(token.TAG_COLON)) {
        this.advance();  # consume ':'

        val type_res: Result[*ast.Node, str] = this.parse_type();
        if (type_res.is_err()) {
            ret type_res;
        }

        node.extra = type_res.unwrap_ok()::ptr;
    }

    # initializer - store in children
    if (!this.consume(token.TAG_EQ, "expected '=' in val declaration")) {
        ret err[*ast.Node, str]("expected '='");
    }

    val expr_res: Result[*ast.Node, str] = this.parse_expr();
    if (expr_res.is_err()) {
        ret expr_res;
    }

    node.children = expr_res.unwrap_ok();

    if (!this.consume(token.TAG_SEMI, "expected ';' after val declaration")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- var declaration ---

# parse_var: parse a var (mutable) declaration.
# var name: type;
# var name: type = expr;
# var name = expr;
# AST structure:
#   data     = name (str)
#   extra    = type node (or nil if no annotation)
#   children = initializer expression (or nil if no initializer)
pub fun (this: *Parser) parse_var(is_pub: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'var'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_VAR,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected identifier after 'var'");
        ret err[*ast.Node, str]("expected identifier");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # type annotation - store in extra
    if (this.check(token.TAG_COLON)) {
        this.advance();  # consume ':'

        val type_res: Result[*ast.Node, str] = this.parse_type();
        if (type_res.is_err()) {
            ret type_res;
        }

        node.extra = type_res.unwrap_ok()::ptr;
    }

    # optional initializer - store in children
    if (this.check(token.TAG_EQ)) {
        this.advance();  # consume '='

        val expr_res: Result[*ast.Node, str] = this.parse_expr();
        if (expr_res.is_err()) {
            ret expr_res;
        }

        node.children = expr_res.unwrap_ok();
    }

    if (!this.consume(token.TAG_SEMI, "expected ';' after var declaration")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- fun declaration ---

# parse_fun: parse a function declaration.
# fun name(...) type { body }
# fun (self: *Type) name(...) type { body }
pub fun (this: *Parser) parse_fun(is_pub: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'fun'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_FUN,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # check for method receiver: (self: *Type)
    if (this.check(token.TAG_LPAREN)) {
        val receiver_res: Result[*ast.Node, str] = this.parse_receiver();
        if (receiver_res.is_err()) {
            ret receiver_res;
        }
        node.receiver = receiver_res.unwrap_ok();
    }

    # function name
    if (!this.check(token.TAG_IDENT)) {
        this.error("expected function name");
        ret err[*ast.Node, str]("expected function name");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # optional generic parameters
    if (this.check(token.TAG_LBRACKET)) {
        val generics_res: Result[*ast.Node, str] = this.parse_generic_params();
        if (generics_res.is_err()) {
            ret generics_res;
        }
        node.generics = generics_res.unwrap_ok();
    }

    # parameters
    if (!this.consume(token.TAG_LPAREN, "expected '(' after function name")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val params_res: Result[*ast.List, str] = this.parse_params();
    if (params_res.is_err()) {
        ret err[*ast.Node, str](params_res.unwrap_err());
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after parameters")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # store params in extra
    node.extra = params_res.unwrap_ok()::ptr;

    # return type (optional for void)
    if (!this.check(token.TAG_LBRACE) && !this.check(token.TAG_SEMI)) {
        val type_res: Result[*ast.Node, str] = this.parse_type();
        if (type_res.is_err()) {
            ret type_res;
        }
        node.ret_type = type_res.unwrap_ok();
    }

    # function body or just signature (for ext)
    if (this.check(token.TAG_LBRACE)) {
        val body_res: Result[*ast.Node, str] = this.parse_block();
        if (body_res.is_err()) {
            ret body_res;
        }
        node.children = body_res.unwrap_ok();
        node.count = 1;
    }

    ret ok[*ast.Node, str](node);
}

# parse_fun_signature: parse just a function signature (for ext).
fun (this: *Parser) parse_fun_signature() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'fun'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_FUN,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # function name
    if (!this.check(token.TAG_IDENT)) {
        this.error("expected function name");
        ret err[*ast.Node, str]("expected function name");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # parameters
    if (!this.consume(token.TAG_LPAREN, "expected '(' after function name")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val params_res: Result[*ast.List, str] = this.parse_params();
    if (params_res.is_err()) {
        ret err[*ast.Node, str](params_res.unwrap_err());
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after parameters")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # store params in extra
    node.extra = params_res.unwrap_ok()::ptr;

    # return type
    if (!this.check(token.TAG_SEMI)) {
        val type_res: Result[*ast.Node, str] = this.parse_type();
        if (type_res.is_err()) {
            ret type_res;
        }
        node.ret_type = type_res.unwrap_ok();
    }

    ret ok[*ast.Node, str](node);
}

# parse_receiver: parse method receiver (self: *Type).
fun (this: *Parser) parse_receiver() Result[*ast.Node, str] {
    this.advance();  # consume '('

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_PARAM,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected receiver name");
        ret err[*ast.Node, str]("expected receiver name");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    if (!this.consume(token.TAG_COLON, "expected ':' after label")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = this.parse_type();
    if (type_res.is_err()) {
        ret type_res;
    }

    node.children = type_res.unwrap_ok();
    node.count = 1;

    if (!this.consume(token.TAG_RPAREN, "expected ')' after receiver")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_params: parse function parameter list.
fun (this: *Parser) parse_params() Result[*ast.List, str] {
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret list_res;
    }

    val params: *ast.List = list_res.unwrap_ok();

    # empty parameter list
    if (this.check(token.TAG_RPAREN)) {
        ret ok[*ast.List, str](params);
    }

    # first parameter
    val first_res: Result[*ast.Node, str] = this.parse_param();
    if (first_res.is_err()) {
        ret err[*ast.List, str](first_res.unwrap_err());
    }

    val append_res: Result[bool, str] = params.append(this.alloc, first_res.unwrap_ok());
    if (append_res.is_err()) {
        ret err[*ast.List, str](append_res.unwrap_err());
    }

    # remaining parameters
    for (this.check(token.TAG_COMMA)) {
        this.advance();  # consume ','

        val param_res: Result[*ast.Node, str] = this.parse_param();
        if (param_res.is_err()) {
            ret err[*ast.List, str](param_res.unwrap_err());
        }

        val a_res: Result[bool, str] = params.append(this.alloc, param_res.unwrap_ok());
        if (a_res.is_err()) {
            ret err[*ast.List, str](a_res.unwrap_err());
        }
    }

    ret ok[*ast.List, str](params);
}

# parse_param: parse a single function parameter.
# name: type
# or variadic: ...
fun (this: *Parser) parse_param() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    # check for variadic ...
    if (this.check(token.TAG_DOT)) {
        # consume three dots
        this.advance();  # first dot
        if (!this.check(token.TAG_DOT)) {
            this.error("expected '...' for variadic parameter");
            ret err[*ast.Node, str]("expected '...'");
        }
        this.advance();  # second dot
        if (!this.check(token.TAG_DOT)) {
            this.error("expected '...' for variadic parameter");
            ret err[*ast.Node, str]("expected '...'");
        }
        this.advance();  # third dot

        # create variadic node
        val variadic_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_VARIADIC,
            start_tok
        );
        if (variadic_res.is_err()) {
            ret variadic_res;
        }
        ret ok[*ast.Node, str](variadic_res.unwrap_ok());
    }

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected parameter name");
        ret err[*ast.Node, str]("expected parameter name");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_PARAM,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # check for type parameter list: [T, U, ...]
    if (!this.consume(token.TAG_COLON, "expected ':' after parameter name")) {
        ret err[*ast.Node, str]("expected ':'");
    }

    val type_res: Result[*ast.Node, str] = this.parse_type();
    if (type_res.is_err()) {
        ret type_res;
    }

    node.children = type_res.unwrap_ok();
    node.count = 1;

    ret ok[*ast.Node, str](node);
}

# parse_generic_params: parse generic type parameters [T, U, ...].
fun (this: *Parser) parse_generic_params() Result[*ast.Node, str] {
    this.advance();  # consume '['

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_GENERIC,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val params: *ast.List = list_res.unwrap_ok();

    # first param
    if (this.check(token.TAG_IDENT)) {
        val param_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_TYPE_NAME,
            this.current
        );
        if (param_res.is_err()) {
            ret param_res;
        }
        val p: *ast.Node = param_res.unwrap_ok();
        p.data = this.alloc_current_text_or_nil()::ptr;
        this.advance();

        val a_res: Result[bool, str] = params.append(this.alloc, p);
        if (a_res.is_err()) {
            ret err[*ast.Node, str](a_res.unwrap_err());
        }

        # more params
        for (this.check(token.TAG_COMMA)) {
            this.advance();

            if (!this.check(token.TAG_IDENT)) {
                this.error("expected type parameter name");
                ret err[*ast.Node, str]("expected type parameter name");
            }

            val p2_res: Result[*ast.Node, str] = ast.create_node(
                this.alloc,
                ast.NODE_TYPE_NAME,
                this.current
            );
            if (p2_res.is_err()) {
                ret p2_res;
            }
            val p2: *ast.Node = p2_res.unwrap_ok();
            p2.data = this.alloc_current_text_or_nil()::ptr;
            this.advance();

            val a2_res: Result[bool, str] = params.append(this.alloc, p2);
            if (a2_res.is_err()) {
                ret err[*ast.Node, str](a2_res.unwrap_err());
            }
        }
    }

    if (!this.consume(token.TAG_RBRACKET, "expected ']' after generic parameters")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    node.children = params::*ast.Node;
    ret ok[*ast.Node, str](node);
}

# --- test declaration ---

# parse_test: parse a test block.
# test "name" { body }
pub fun (this: *Parser) parse_test() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'test'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_DECL_TEST,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # test name (string literal)
    if (!this.check(token.TAG_LIT_STRING)) {
        this.error("expected test name (string literal)");
        ret err[*ast.Node, str]("expected test name");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # test body
    val body_res: Result[*ast.Node, str] = this.parse_block();
    if (body_res.is_err()) {
        ret body_res;
    }

    node.children = body_res.unwrap_ok();
    node.count = 1;

    ret ok[*ast.Node, str](node);
}

# --- comptime ---

# parse_comptime: parse comptime construct ($if, $error, attribute).
pub fun (this: *Parser) parse_comptime() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume '$'

    # check what follows
    if (this.check(token.TAG_KW_IF)) {
        ret this.parse_comptime_if();
    }

    # attribute: $name.field = value;
    if (this.check(token.TAG_IDENT)) {
        ret this.parse_attribute();
    }

    this.error("expected comptime construct after '$'");
    ret err[*ast.Node, str]("expected comptime construct");
}

# parse_comptime_if: parse $if (cond) { ... } $or { ... }
fun (this: *Parser) parse_comptime_if() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'if'

    # TODO: implement comptime if
    # for now, skip until matching brace

    this.error("$if not yet implemented in parser");
    ret err[*ast.Node, str]("$if not yet implemented");
}

# parse_attribute: parse $name.field = value;
fun (this: *Parser) parse_attribute() Result[*ast.Node, str] {
    # this is a comptime attribute like $main.symbol = "main";
    # for now, skip the whole statement

    for (!this.is_at_end() && !this.check(token.TAG_SEMI)) {
        this.advance();
    }

    if (this.check(token.TAG_SEMI)) {
        this.advance();
    }

    # return nil node (attribute processed)
    ret ok[*ast.Node, str](nil);
}

# --- statements ---

# parse_block: parse a block of statements.
# { stmt* }
pub fun (this: *Parser) parse_block() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    if (!this.consume(token.TAG_LBRACE, "expected '{'")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_BLOCK,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val stmts: *ast.List = list_res.unwrap_ok();

    for (!this.check(token.TAG_RBRACE) && !this.is_at_end()) {
        val stmt_res: Result[*ast.Node, str] = this.parse_stmt();
        if (stmt_res.is_err()) {
            this.synchronize();
            cnt;
        }

        val stmt: *ast.Node = stmt_res.unwrap_ok();
        if (stmt != nil) {
            val a_res: Result[bool, str] = stmts.append(this.alloc, stmt);
            if (a_res.is_err()) {
                ret err[*ast.Node, str](a_res.unwrap_err());
            }
        }
    }

    if (!this.consume(token.TAG_RBRACE, "expected '}'")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    node.data = stmts::ptr;

    ret ok[*ast.Node, str](node);
}

# parse_stmt: parse a statement.
# ---
# ret: Ok(*ast.Node) with statement AST, or Err(str) on failure
pub fun (this: *Parser) parse_stmt() Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    val tag: u8 = this.current.tag;

    # if statement
    if (tag == token.TAG_KW_IF) {
        ret this.parse_if();
    }

    # for loop
    if (tag == token.TAG_KW_FOR) {
        ret this.parse_for();
    }

    # ret statement
    if (tag == token.TAG_KW_RET) {
        ret this.parse_ret();
    }

    # brk statement
    if (tag == token.TAG_KW_BRK) {
        ret this.parse_brk();
    }

    # cnt statement
    if (tag == token.TAG_KW_CNT) {
        ret this.parse_cnt();
    }

    # fin (defer) statement
    if (tag == token.TAG_KW_FIN) {
        ret this.parse_fin();
    }

    # asm block
    if (tag == token.TAG_KW_ASM) {
        ret this.parse_asm();
    }

    # block
    if (tag == token.TAG_LBRACE) {
        ret this.parse_block();
    }

    # val declaration
    if (tag == token.TAG_KW_VAL) {
        ret this.parse_val(false);
    }

    # var declaration
    if (tag == token.TAG_KW_VAR) {
        ret this.parse_var(false);
    }

    # expression statement
    ret this.parse_expr_stmt();
}

# parse_if: parse an if statement.
# if (cond) { then } or { else }
fun (this: *Parser) parse_if() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'if'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_IF,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # condition (in parentheses)
    if (!this.consume(token.TAG_LPAREN, "expected '(' after 'if'")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val cond_res: Result[*ast.Node, str] = this.parse_expr();
    if (cond_res.is_err()) {
        ret cond_res;
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after condition")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # then block
    val then_res: Result[*ast.Node, str] = this.parse_block();
    if (then_res.is_err()) {
        ret then_res;
    }

    # create list for condition, then, else
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val children: *ast.List = list_res.unwrap_ok();

    children.append(this.alloc, cond_res.unwrap_ok());
    children.append(this.alloc, then_res.unwrap_ok());

    # optional else: or { ... } or or if (...)
    if (this.check(token.TAG_KW_OR)) {
        this.advance();  # consume 'or'

        if (this.check(token.TAG_KW_IF)) {
            # else if
            val elif_res: Result[*ast.Node, str] = this.parse_if();
            if (elif_res.is_err()) {
                ret elif_res;
            }
            children.append(this.alloc, elif_res.unwrap_ok());
        } or {
            # else block
            val else_res: Result[*ast.Node, str] = this.parse_block();
            if (else_res.is_err()) {
                ret else_res;
            }
            children.append(this.alloc, else_res.unwrap_ok());
        }
    }

    node.children = children::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_for: parse a for loop.
# for (cond) { body }
# for { body }  (infinite loop)
fun (this: *Parser) parse_for() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'for'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_FOR,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val children: *ast.List = list_res.unwrap_ok();

    # optional condition
    if (this.check(token.TAG_LPAREN)) {
        this.advance();  # consume '('

        val cond_res: Result[*ast.Node, str] = this.parse_expr();
        if (cond_res.is_err()) {
            ret cond_res;
        }

        if (!this.consume(token.TAG_RPAREN, "expected ')' after condition")) {
            ret err[*ast.Node, str]("expected ')'");
        }

        children.append(this.alloc, cond_res.unwrap_ok());
    }

    # body
    val body_res: Result[*ast.Node, str] = this.parse_block();
    if (body_res.is_err()) {
        ret body_res;
    }

    children.append(this.alloc, body_res.unwrap_ok());

    node.children = children::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_ret: parse a return statement.
# ret;
# ret expr;
fun (this: *Parser) parse_ret() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'ret'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_RET,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # optional return value
    if (!this.check(token.TAG_SEMI)) {
        val expr_res: Result[*ast.Node, str] = this.parse_expr();
        if (expr_res.is_err()) {
            ret expr_res;
        }
        node.children = expr_res.unwrap_ok();
        node.count = 1;
    }

    if (!this.consume(token.TAG_SEMI, "expected ';' after return")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_brk: parse a break statement.
fun (this: *Parser) parse_brk() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'brk'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_BRK,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    if (!this.consume(token.TAG_SEMI, "expected ';' after break")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret node_res;
}

# parse_cnt: parse a continue statement.
fun (this: *Parser) parse_cnt() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'cnt'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_CNT,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    if (!this.consume(token.TAG_SEMI, "expected ';' after continue")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret node_res;
}

# parse_fin: parse a defer statement.
# fin { body }
# fin expr;
fun (this: *Parser) parse_fin() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'fin'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_FIN,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (this.check(token.TAG_LBRACE)) {
        val body_res: Result[*ast.Node, str] = this.parse_block();
        if (body_res.is_err()) {
            ret body_res;
        }
        node.children = body_res.unwrap_ok();
        node.count = 1;
    } or {
        val expr_res: Result[*ast.Node, str] = this.parse_expr();
        if (expr_res.is_err()) {
            ret expr_res;
        }
        node.children = expr_res.unwrap_ok();
        node.count = 1;

        if (!this.consume(token.TAG_SEMI, "expected ';' after defer expression")) {
            ret err[*ast.Node, str]("expected ';'");
        }
    }

    ret ok[*ast.Node, str](node);
}

# parse_asm: parse an inline assembly block.
# asm { target { ... } }
fun (this: *Parser) parse_asm() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'asm'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_MASM,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.consume(token.TAG_LBRACE, "expected '{' after 'asm'")) {
        ret err[*ast.Node, str]("expected '{'");
    }

    # for now, skip the asm content by matching braces
    var depth: i32 = 1;
    for (depth > 0 && !this.is_at_end()) {
        if (this.check(token.TAG_LBRACE)) {
            depth = depth + 1;
        }
        if (this.check(token.TAG_RBRACE)) {
            depth = depth - 1;
        }
        if (depth > 0) {
            this.advance();
        }
    }

    if (!this.consume(token.TAG_RBRACE, "expected '}' after asm block")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    ret ok[*ast.Node, str](node);
}

# parse_expr_stmt: parse an expression statement.
# expr;
# or assignment: lvalue = expr;
fun (this: *Parser) parse_expr_stmt() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_STMT_EXPR,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val expr_res: Result[*ast.Node, str] = this.parse_expr();
    if (expr_res.is_err()) {
        ret expr_res;
    }

    node.children = expr_res.unwrap_ok();
    node.count = 1;

    if (!this.consume(token.TAG_SEMI, "expected ';' after expression")) {
        ret err[*ast.Node, str]("expected ';'");
    }

    ret ok[*ast.Node, str](node);
}

# --- expressions ---

# parse_expr: parse an expression.
# uses Pratt parsing with precedence climbing.
pub fun (this: *Parser) parse_expr() Result[*ast.Node, str] {
    ret this.parse_precedence(token.PREC_ASSIGN);
}

# parse_precedence: parse expression with minimum precedence.
fun (this: *Parser) parse_precedence(min_prec: u8) Result[*ast.Node, str] {
    # parse prefix (primary or unary)
    var left_res: Result[*ast.Node, str] = this.parse_prefix();
    if (left_res.is_err()) {
        ret left_res;
    }

    var left: *ast.Node = left_res.unwrap_ok();

    # parse infix operators
    for (!this.is_at_end()) {
        val prec: u8 = this.get_precedence(this.current.tag);
        if (prec < min_prec) {
            brk;
        }

        val op_tok: token.Token = this.current;

        # check if `[` should be parsed as type args (followed by `(` or `{`)
        var is_type_args: bool = false;
        if (op_tok.tag == token.TAG_LBRACKET) {
            is_type_args = this.should_parse_type_args();
        }

        this.advance();  # consume operator

        # handle postfix operators at PREC_CALL level
        if (prec == token.PREC_CALL) {
            # if this is type args followed by call, handle specially
            if (is_type_args) {
                val generic_call_res: Result[*ast.Node, str] = this.parse_generic_call(left, op_tok);
                if (generic_call_res.is_err()) {
                    ret generic_call_res;
                }
                left = generic_call_res.unwrap_ok();
                cnt;
            }

            val postfix_res: Result[*ast.Node, str] = this.parse_postfix(left, op_tok);
            if (postfix_res.is_err()) {
                ret postfix_res;
            }
            left = postfix_res.unwrap_ok();
            cnt;
        }

        # handle assignment (right-associative)
        var next_prec: u8 = prec + 1;
        if (op_tok.tag == token.TAG_EQ) {
            next_prec = prec;  # right-associative
        }

        val right_res: Result[*ast.Node, str] = this.parse_precedence(next_prec);
        if (right_res.is_err()) {
            ret right_res;
        }

        # create binary node
        val bin_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_EXPR_BINARY,
            op_tok
        );

        if (bin_res.is_err()) {
            ret bin_res;
        }

        val bin: *ast.Node = bin_res.unwrap_ok();

        # store operator tag in data for sema to check
        bin.data = op_tok.tag::ptr;

        val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
        if (list_res.is_err()) {
            ret err[*ast.Node, str](list_res.unwrap_err());
        }

        val children: *ast.List = list_res.unwrap_ok();
        children.append(this.alloc, left);
        children.append(this.alloc, right_res.unwrap_ok());

        bin.children = children::*ast.Node;
        left = bin;
    }

    ret ok[*ast.Node, str](left);
}

# get_precedence: get the precedence of a token.
fun (this: *Parser) get_precedence(tag: u8) u8 {
    # assignment
    if (tag == token.TAG_EQ) {
        ret token.PREC_ASSIGN;
    }

    # logical or
    if (tag == token.TAG_PIPE_PIPE) {
        ret token.PREC_OR;
    }

    # logical and
    if (tag == token.TAG_AMP_AMP) {
        ret token.PREC_AND;
    }

    # bitwise or
    if (tag == token.TAG_PIPE) {
        ret token.PREC_BITOR;
    }

    # bitwise xor
    if (tag == token.TAG_CARET) {
        ret token.PREC_BITXOR;
    }

    # bitwise and
    if (tag == token.TAG_AMP) {
        ret token.PREC_BITAND;
    }

    # equality
    if (tag == token.TAG_EQ_EQ || tag == token.TAG_BANG_EQ) {
        ret token.PREC_EQUALITY;
    }

    # comparison
    if (tag == token.TAG_LT || tag == token.TAG_LT_EQ ||
        tag == token.TAG_GT || tag == token.TAG_GT_EQ) {
        ret token.PREC_COMPARISON;
    }

    # shift
    if (tag == token.TAG_LT_LT || tag == token.TAG_GT_GT) {
        ret token.PREC_SHIFT;
    }

    # term
    if (tag == token.TAG_PLUS || tag == token.TAG_MINUS) {
        ret token.PREC_TERM;
    }

    # factor
    if (tag == token.TAG_STAR || tag == token.TAG_SLASH || tag == token.TAG_PERCENT) {
        ret token.PREC_FACTOR;
    }

    # postfix / call
    if (tag == token.TAG_LPAREN || tag == token.TAG_LBRACKET ||
        tag == token.TAG_DOT || tag == token.TAG_COLON_COLON) {
        ret token.PREC_CALL;
    }

    ret token.PREC_NONE;
}

# parse_prefix: parse prefix expression (unary or primary).
fun (this: *Parser) parse_prefix() Result[*ast.Node, str] {
    val tag: u8 = this.current.tag;

    # unary operators
    if (tag == token.TAG_BANG || tag == token.TAG_MINUS ||
        tag == token.TAG_TILDE || tag == token.TAG_QUESTION ||
        tag == token.TAG_AT || tag == token.TAG_AMP ||
        tag == token.TAG_STAR) {
        ret this.parse_unary();
    }

    # primary
    ret this.parse_primary();
}

# parse_unary: parse a unary expression.
# !expr, -expr, ~expr, ?ptr, @addr, &ref, *deref
fun (this: *Parser) parse_unary() Result[*ast.Node, str] {
    val op_tok: token.Token = this.current;
    this.advance();  # consume operator

    var kind: ast.NodeKind = ast.NODE_EXPR_UNARY;

    # special cases for address-of and dereference
    if (op_tok.tag == token.TAG_QUESTION) {
        kind = ast.NODE_EXPR_ADDR;
    }
    if (op_tok.tag == token.TAG_AT) {
        kind = ast.NODE_EXPR_DEREF;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        kind,
        op_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # store operator tag in data for sema to check
    node.data = op_tok.tag::ptr;

    val operand_res: Result[*ast.Node, str] = this.parse_precedence(token.PREC_UNARY);
    if (operand_res.is_err()) {
        ret operand_res;
    }

    node.children = operand_res.unwrap_ok();
    node.count = 1;

    ret ok[*ast.Node, str](node);
}

# parse_primary: parse a primary expression.
fun (this: *Parser) parse_primary() Result[*ast.Node, str] {
    val tag: u8 = this.current.tag;

    # integer literal
    if (tag == token.TAG_LIT_INT) {
        ret this.parse_int_literal();
    }

    # float literal
    if (tag == token.TAG_LIT_FLOAT) {
        ret this.parse_float_literal();
    }

    # char literal
    if (tag == token.TAG_LIT_CHAR) {
        ret this.parse_char_literal();
    }

    # string literal
    if (tag == token.TAG_LIT_STRING) {
        ret this.parse_string_literal();
    }

    # nil
    if (tag == token.TAG_KW_NIL) {
        ret this.parse_nil();
    }

    # true/false
    if (tag == token.TAG_KW_TRUE || tag == token.TAG_KW_FALSE) {
        ret this.parse_bool_literal();
    }

    # identifier (variable, function, type)
    if (tag == token.TAG_IDENT) {
        ret this.parse_ident_expr();
    }

    # parenthesized expression
    if (tag == token.TAG_LPAREN) {
        ret this.parse_paren_expr();
    }

    # array literal [...]
    if (tag == token.TAG_LBRACKET) {
        ret this.parse_array_literal();
    }

    # record literal Name { ... }
    # (handled in parse_ident_expr when followed by {)

    this.error("expected expression");
    ret err[*ast.Node, str]("expected expression");
}

# parse_int_literal: parse integer literal.
fun (this: *Parser) parse_int_literal() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_INT,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    ret ok[*ast.Node, str](node);
}

# parse_literal_str: parse a string literal.
# parse_float_literal: parse float literal.
fun (this: *Parser) parse_float_literal() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_FLOAT,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    ret ok[*ast.Node, str](node);
}

# parse_literal_char: parse a character literal.
# parse_char_literal: parse character literal.
fun (this: *Parser) parse_char_literal() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_CHAR,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    ret ok[*ast.Node, str](node);
}

# parse_literal_nil: parse the nil literal.
# parse_string_literal: parse string literal.
fun (this: *Parser) parse_string_literal() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_STR,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    ret ok[*ast.Node, str](node);
}

# --- expression parsing ---
# parse_nil: parse nil literal.
fun (this: *Parser) parse_nil() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_NIL,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    this.advance();
    ret node_res;
}

# parse_bool_literal: parse true/false literal.
fun (this: *Parser) parse_bool_literal() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_LIT_BOOL,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    # store 1 for true, 0 for false
    if (this.current.tag == token.TAG_KW_TRUE) {
        node.count = 1;
    } or {
        node.count = 0;
    }

    this.advance();
    ret ok[*ast.Node, str](node);
}

# parse_ident_expr: parse identifier expression.
# parses only a single identifier; dots are handled by postfix field access.
fun (this: *Parser) parse_ident_expr() Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_IDENT,
        this.current
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # parse single identifier only (dots handled as field access in parse_postfix)
    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # check for struct literal (generic args handled by precedence loop)
    if (this.check(token.TAG_LBRACE)) {
        # struct literal: Type { field: value, ... }
        ret this.parse_struct_literal(node);
    }

    ret ok[*ast.Node, str](node);
}

# parse_generic_args: parse generic type arguments [T, U].
fun (this: *Parser) parse_generic_args() Result[*ast.Node, str] {
    this.advance();  # consume '['

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val args: *ast.List = list_res.unwrap_ok();

    # first arg
    if (!this.check(token.TAG_RBRACKET)) {
        val type_res: Result[*ast.Node, str] = this.parse_type();
        if (type_res.is_err()) {
            ret type_res;
        }
        args.append(this.alloc, type_res.unwrap_ok());

        for (this.check(token.TAG_COMMA)) {
            this.advance();

            val t_res: Result[*ast.Node, str] = this.parse_type();
            if (t_res.is_err()) {
                ret t_res;
            }
            args.append(this.alloc, t_res.unwrap_ok());
        }
    }

    if (!this.consume(token.TAG_RBRACKET, "expected ']' after generic arguments")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_GENERIC,
        this.previous
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.children = args::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_struct_literal: parse struct literal { field: value, ... }.
fun (this: *Parser) parse_struct_literal(type_node: *ast.Node) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume '{'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_STRUCT_LIT,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.data = type_node.data;  # copy type name

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val fields: *ast.List = list_res.unwrap_ok();

    # parse field initializers
    for (!this.check(token.TAG_RBRACE) && !this.is_at_end()) {
        if (!this.check(token.TAG_IDENT)) {
            this.error("expected field name");
            ret err[*ast.Node, str]("expected field name");
        }

        val field_res: Result[*ast.Node, str] = ast.create_node(
            this.alloc,
            ast.NODE_FIELD,
            this.current
        );

        if (field_res.is_err()) {
            ret field_res;
        }

        val field: *ast.Node = field_res.unwrap_ok();
        field.data = this.alloc_current_text_or_nil()::ptr;
        this.advance();

        if (!this.consume(token.TAG_COLON, "expected ':' after field name")) {
            ret err[*ast.Node, str]("expected ':'");
        }

        val value_res: Result[*ast.Node, str] = this.parse_expr();
        if (value_res.is_err()) {
            ret value_res;
        }

        field.children = value_res.unwrap_ok();
        field.count = 1;

        fields.append(this.alloc, field);

        if (!this.check(token.TAG_RBRACE)) {
            if (!this.consume(token.TAG_COMMA, "expected ',' or '}' in struct literal")) {
                ret err[*ast.Node, str]("expected ','");
            }
        }
    }

    if (!this.consume(token.TAG_RBRACE, "expected '}' after struct literal")) {
        ret err[*ast.Node, str]("expected '}'");
    }

    node.children = fields::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_paren_expr: parse parenthesized expression.
fun (this: *Parser) parse_paren_expr() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume '('

    val expr_res: Result[*ast.Node, str] = this.parse_expr();
    if (expr_res.is_err()) {
        ret expr_res;
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after expression")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_PAREN,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.children = expr_res.unwrap_ok();
    node.count = 1;

    ret ok[*ast.Node, str](node);
}

# parse_array_literal: parse array literal [a, b, c].
fun (this: *Parser) parse_array_literal() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume '['

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_ARRAY_LIT,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val elements: *ast.List = list_res.unwrap_ok();

    if (!this.check(token.TAG_RBRACKET)) {
        val first_res: Result[*ast.Node, str] = this.parse_expr();
        if (first_res.is_err()) {
            ret first_res;
        }
        elements.append(this.alloc, first_res.unwrap_ok());

        for (this.check(token.TAG_COMMA)) {
            this.advance();

            if (this.check(token.TAG_RBRACKET)) {
                brk;  # trailing comma
            }

            val elem_res: Result[*ast.Node, str] = this.parse_expr();
            if (elem_res.is_err()) {
                ret elem_res;
            }
            elements.append(this.alloc, elem_res.unwrap_ok());
        }
    }

    if (!this.consume(token.TAG_RBRACKET, "expected ']' after array literal")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    node.children = elements::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_postfix: parse postfix expression (call, index, field, cast).
fun (this: *Parser) parse_postfix(left: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val tag: u8 = op_tok.tag;

    # function call: expr(args)
    if (tag == token.TAG_LPAREN) {
        ret this.parse_call(left, op_tok);
    }

    # index: expr[index]
    if (tag == token.TAG_LBRACKET) {
        ret this.parse_index(left, op_tok);
    }

    # field access: expr.field
    if (tag == token.TAG_DOT) {
        ret this.parse_field_access(left, op_tok);
    }

    # cast: expr::type
    if (tag == token.TAG_COLON_COLON) {
        ret this.parse_cast(left, op_tok);
    }

    this.error("unexpected postfix operator");
    ret err[*ast.Node, str]("unexpected postfix operator");
}

# parse_call: parse function call.
# AST structure:
#   children = callee expression (single node)
#   data     = arguments list (*ast.List)
fun (this: *Parser) parse_call(callee: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_CALL,
        op_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # callee is stored in children (single node)
    node.children = callee;
    node.count = 1;

    # parse arguments into a separate list stored in data
    val args_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (args_res.is_err()) {
        ret err[*ast.Node, str](args_res.unwrap_err());
    }

    val args: *ast.List = args_res.unwrap_ok();

    # parse arguments
    if (!this.check(token.TAG_RPAREN)) {
        val first_res: Result[*ast.Node, str] = this.parse_expr();
        if (first_res.is_err()) {
            ret first_res;
        }
        args.append(this.alloc, first_res.unwrap_ok());

        for (this.check(token.TAG_COMMA)) {
            this.advance();

            val arg_res: Result[*ast.Node, str] = this.parse_expr();
            if (arg_res.is_err()) {
                ret arg_res;
            }
            args.append(this.alloc, arg_res.unwrap_ok());
        }
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after arguments")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    node.data = args::ptr;

    ret ok[*ast.Node, str](node);
}

# parse_generic_call: parse generic function call (func[T](args)).
# ---
# called when we've detected `[...]` followed by `(` - this is a generic call, not index.
# callee: the function expression being called
# op_tok: the `[` token
# ret: call expression with type args attached
fun (this: *Parser) parse_generic_call(callee: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    # we've already consumed the `[`, now parse type arguments
    val type_args_res: Result[*ast.Node, str] = this.parse_generic_args_after_bracket();
    if (type_args_res.is_err()) {
        ret type_args_res;
    }

    val type_args: *ast.Node = type_args_res.unwrap_ok();

    # now we should have `(` for the call
    if (!this.check(token.TAG_LPAREN)) {
        # might be `{` for struct literal - treat callee as type
        if (this.check(token.TAG_LBRACE)) {
            # this is a typed struct literal like Type[T]{ ... }
            # attach type args to callee and parse struct literal
            callee.children = type_args;
            callee.count = 1;
            ret this.parse_struct_literal(callee);
        }

        this.error("expected '(' after generic type arguments");
        ret err[*ast.Node, str]("expected '(' after generic type arguments");
    }

    # consume '(' and parse call
    val call_tok: token.Token = this.current;
    this.advance();

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_CALL,
        call_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # attach type args to the call node
    node.generics = type_args;

    # callee is stored in children (single node)
    node.children = callee;
    node.count = 1;

    # parse arguments into a separate list stored in data
    val args_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (args_res.is_err()) {
        ret err[*ast.Node, str](args_res.unwrap_err());
    }

    val args: *ast.List = args_res.unwrap_ok();

    # parse arguments
    if (!this.check(token.TAG_RPAREN)) {
        val first_res: Result[*ast.Node, str] = this.parse_expr();
        if (first_res.is_err()) {
            ret first_res;
        }
        args.append(this.alloc, first_res.unwrap_ok());

        for (this.check(token.TAG_COMMA)) {
            this.advance();

            val arg_res: Result[*ast.Node, str] = this.parse_expr();
            if (arg_res.is_err()) {
                ret arg_res;
            }
            args.append(this.alloc, arg_res.unwrap_ok());
        }
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after arguments")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    node.data = args::ptr;

    ret ok[*ast.Node, str](node);
}

# parse_generic_args_after_bracket: parse generic args when `[` already consumed.
fun (this: *Parser) parse_generic_args_after_bracket() Result[*ast.Node, str] {
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val args: *ast.List = list_res.unwrap_ok();

    # first arg
    if (!this.check(token.TAG_RBRACKET)) {
        val type_res: Result[*ast.Node, str] = this.parse_type();
        if (type_res.is_err()) {
            ret type_res;
        }
        args.append(this.alloc, type_res.unwrap_ok());

        for (this.check(token.TAG_COMMA)) {
            this.advance();

            val t_res: Result[*ast.Node, str] = this.parse_type();
            if (t_res.is_err()) {
                ret t_res;
            }
            args.append(this.alloc, t_res.unwrap_ok());
        }
    }

    if (!this.consume(token.TAG_RBRACKET, "expected ']' after generic arguments")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_GENERIC,
        this.previous
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();
    node.children = args::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_index: parse array/pointer index.
fun (this: *Parser) parse_index(base: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_INDEX,
        op_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val index_res: Result[*ast.Node, str] = this.parse_expr();
    if (index_res.is_err()) {
        ret index_res;
    }

    if (!this.consume(token.TAG_RBRACKET, "expected ']' after index")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val children: *ast.List = list_res.unwrap_ok();
    children.append(this.alloc, base);
    children.append(this.alloc, index_res.unwrap_ok());

    node.children = children::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_field_access: parse field access expression.
fun (this: *Parser) parse_field_access(base: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_FIELD,
        op_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.check(token.TAG_IDENT)) {
        this.error("expected field name after '.'");
        ret err[*ast.Node, str]("expected field name");
    }

    node.data = this.alloc_current_text_or_nil()::ptr;
    this.advance();

    # store base in children list for consistency with get_child
    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }
    val children: *ast.List = list_res.unwrap_ok();
    children.append(this.alloc, base);
    node.children = children::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_cast: parse type cast.
fun (this: *Parser) parse_cast(expr: *ast.Node, op_tok: token.Token) Result[*ast.Node, str] {
    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_EXPR_CAST,
        op_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val type_res: Result[*ast.Node, str] = this.parse_type();
    if (type_res.is_err()) {
        ret type_res;
    }

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val children: *ast.List = list_res.unwrap_ok();
    children.append(this.alloc, expr);
    children.append(this.alloc, type_res.unwrap_ok());

    node.children = children::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# --- type parsing ---

# parse_type: parse a type expression.
# ---
# ret: Ok(*ast.Node) with type AST, or Err(str) on failure
pub fun (this: *Parser) parse_type() Result[*ast.Node, str] {
    if (this == nil) {
        ret err[*ast.Node, str]("parser is nil");
    }

    val tag: u8 = this.current.tag;

    # mutable pointer: *T
    if (tag == token.TAG_STAR) {
        ret this.parse_ptr_type(true);
    }

    # readonly pointer: &T
    if (tag == token.TAG_AMP) {
        ret this.parse_ptr_type(false);
    }

    # double readonly pointer: &&T
    if (tag == token.TAG_AMP_AMP) {
        ret this.parse_double_ptr_type();
    }

    # array type: [N]T
    if (tag == token.TAG_LBRACKET) {
        ret this.parse_array_type();
    }

    # function type: fun(...) T
    if (tag == token.TAG_KW_FUN) {
        ret this.parse_fun_type();
    }

    # anonymous record: rec { ... }
    if (tag == token.TAG_KW_REC) {
        ret this.parse_rec(false, true);  # is_type=true for type context
    }

    # anonymous union: uni { ... }
    if (tag == token.TAG_KW_UNI) {
        ret this.parse_uni(false, true);  # is_type=true for type context
    }

    # named type or primitive
    if (tag == token.TAG_IDENT) {
        ret this.parse_named_type();
    }

    this.error("expected type");
    ret err[*ast.Node, str]("expected type");
}

# parse_ptr_type: parse pointer type *T or &T.
fun (this: *Parser) parse_ptr_type(is_mutable: bool) Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume * or &

    var kind: ast.NodeKind = ast.NODE_TYPE_REF;
    if (is_mutable) {
        kind = ast.NODE_TYPE_PTR;
    }

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        kind,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    val inner_res: Result[*ast.Node, str] = this.parse_type();
    if (inner_res.is_err()) {
        ret inner_res;
    }

    node.children = inner_res.unwrap_ok();
    node.count = 1;

    ret ok[*ast.Node, str](node);
}

# parse_double_ptr_type: parse double readonly pointer type &&T.
# This handles the case where && is lexed as a single token.
fun (this: *Parser) parse_double_ptr_type() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume '&&'

    # create outer &
    val outer_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_REF,
        start_tok
    );

    if (outer_res.is_err()) {
        ret outer_res;
    }

    val outer: *ast.Node = outer_res.unwrap_ok();

    # create inner &
    val inner_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_REF,
        start_tok
    );

    if (inner_res.is_err()) {
        ret inner_res;
    }

    val inner: *ast.Node = inner_res.unwrap_ok();

    # parse the base type
    val base_res: Result[*ast.Node, str] = this.parse_type();
    if (base_res.is_err()) {
        ret base_res;
    }

    # link: outer -> inner -> base
    inner.children = base_res.unwrap_ok();
    inner.count = 1;
    outer.children = inner;
    outer.count = 1;

    ret ok[*ast.Node, str](outer);
}

# parse_array_type: parse array type [N]T.
fun (this: *Parser) parse_array_type() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume '['

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_ARRAY,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # array size (expression or empty for inferred)
    if (!this.check(token.TAG_RBRACKET)) {
        val size_res: Result[*ast.Node, str] = this.parse_expr();
        if (size_res.is_err()) {
            ret size_res;
        }
        node.data = size_res.unwrap_ok()::ptr;
    }

    if (!this.consume(token.TAG_RBRACKET, "expected ']' after array size")) {
        ret err[*ast.Node, str]("expected ']'");
    }

    val inner_res: Result[*ast.Node, str] = this.parse_type();
    if (inner_res.is_err()) {
        ret inner_res;
    }

    node.children = inner_res.unwrap_ok();
    node.count = 1;

    ret ok[*ast.Node, str](node);
}

# parse_fun_type: parse function type fun(...) T.
fun (this: *Parser) parse_fun_type() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;
    this.advance();  # consume 'fun'

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_FUN,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    if (!this.consume(token.TAG_LPAREN, "expected '(' in function type")) {
        ret err[*ast.Node, str]("expected '('");
    }

    val list_res: Result[*ast.List, str] = ast.create_list(this.alloc);
    if (list_res.is_err()) {
        ret err[*ast.Node, str](list_res.unwrap_err());
    }

    val params: *ast.List = list_res.unwrap_ok();

    # parse parameter types
    if (!this.check(token.TAG_RPAREN)) {
        val first_res: Result[*ast.Node, str] = this.parse_type();
        if (first_res.is_err()) {
            ret first_res;
        }
        params.append(this.alloc, first_res.unwrap_ok());

        for (this.check(token.TAG_COMMA)) {
            this.advance();

            val t_res: Result[*ast.Node, str] = this.parse_type();
            if (t_res.is_err()) {
                ret t_res;
            }
            params.append(this.alloc, t_res.unwrap_ok());
        }
    }

    if (!this.consume(token.TAG_RPAREN, "expected ')' after parameter types")) {
        ret err[*ast.Node, str]("expected ')'");
    }

    # return type
    val ret_res: Result[*ast.Node, str] = this.parse_type();
    if (ret_res.is_err()) {
        ret ret_res;
    }

    params.append(this.alloc, ret_res.unwrap_ok());

    node.children = params::*ast.Node;

    ret ok[*ast.Node, str](node);
}

# parse_named_type: parse named type (identifier, possibly with generics).
fun (this: *Parser) parse_named_type() Result[*ast.Node, str] {
    val start_tok: token.Token = this.current;

    val node_res: Result[*ast.Node, str] = ast.create_node(
        this.alloc,
        ast.NODE_TYPE_NAME,
        start_tok
    );

    if (node_res.is_err()) {
        ret node_res;
    }

    val node: *ast.Node = node_res.unwrap_ok();

    # parse path (possibly dotted)
    val path: str = this.parse_path();
    node.data = path::ptr;

    # check for generic args
    if (this.check(token.TAG_LBRACKET)) {
        val args_res: Result[*ast.Node, str] = this.parse_generic_args();
        if (args_res.is_err()) {
            ret args_res;
        }
        node.children = args_res.unwrap_ok();
        node.count = 1;
    }

    ret ok[*ast.Node, str](node);
}

# --- error recovery ---

# synchronize: recover from an error by skipping to a synchronization point.
# ---
# ret: none
pub fun (this: *Parser) synchronize() {
    if (this == nil) {
        ret;
    }

    this.advance();

    for (!this.is_at_end()) {
        # stop at statement boundaries
        if (this.previous.tag == token.TAG_SEMI) {
            ret;
        }

        # stop at declaration keywords
        val tag: u8 = this.current.tag;
        if (tag == token.TAG_KW_USE ||
            tag == token.TAG_KW_PUB ||
            tag == token.TAG_KW_EXT ||
            tag == token.TAG_KW_DEF ||
            tag == token.TAG_KW_REC ||
            tag == token.TAG_KW_UNI ||
            tag == token.TAG_KW_VAL ||
            tag == token.TAG_KW_VAR ||
            tag == token.TAG_KW_FUN ||
            tag == token.TAG_KW_TEST) {
            ret;
        }

        this.advance();
    }
}

# get_error_count: get the number of parsing errors.
# ---
# ret: error count
pub fun (this: &Parser) get_error_count() i32 {
    if (this == nil) {
        ret 0;
    }
    ret this.error_count;
}

# has_errors: check if any errors occurred.
pub fun (this: &Parser) has_errors() bool {
    ret this.had_error;
}
