use std.types.bool;
use std.types.result;
use std.types.string;

use mach.compiler.stages;
use mach.compiler.compilation_unit;
use stage_lexer: mach.compiler.stage_lexer;

fun ensure_stage(cu: *CompilationUnit, stage: PipelineStage) Result[bool, string] {
    if (cu.reached_stage(stage)) {
        ret ok[bool, string](true);
    }

    if (stage == STAGE_LEXER) {
        ret stage_lexer.run(cu);
    }
    or (stage == STAGE_PARSER) {
        ret err[bool, string]("parser stage not implemented");
    }
    or (stage == STAGE_SEMANTIC) {
        ret err[bool, string]("semantic stage not implemented");
    }
    or (stage == STAGE_CODEGEN) {
        ret err[bool, string]("codegen stage not implemented");
    }

    ret err[bool, string]("unsupported pipeline stage");
}

pub fun compile(cu: *CompilationUnit, target_stage: PipelineStage) Result[bool, string] {
    if (target_stage <= STAGE_NONE) {
        ret ok[bool, string](true);
    }

    var stage_result: Result[bool, string];

    if (target_stage >= STAGE_LEXER) {
        stage_result = ensure_stage(cu, STAGE_LEXER);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, string](false);
        }
    }

    if (target_stage >= STAGE_PARSER) {
        stage_result = ensure_stage(cu, STAGE_PARSER);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, string](false);
        }
    }

    if (target_stage >= STAGE_SEMANTIC) {
        stage_result = ensure_stage(cu, STAGE_SEMANTIC);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, string](false);
        }
    }

    if (target_stage >= STAGE_CODEGEN) {
        stage_result = ensure_stage(cu, STAGE_CODEGEN);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, string](false);
        }
    }

    if (target_stage >= STAGE_COMPLETE && cu.reached_stage(STAGE_CODEGEN) && cu.is_ok()) {
        cu.mark_stage(STAGE_COMPLETE);
    }

    ret ok[bool, string](cu.is_ok());
}

pub fun run_lexer(cu: *CompilationUnit) Result[bool, string] {
    ret ensure_stage(cu, STAGE_LEXER);
}
