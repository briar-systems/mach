use std.types.bool;
use std.types.option;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;

use config:   mach.config.config;
use ast:      mach.compiler.ast;
use parser:   mach.compiler.parser;
use sema:     mach.compiler.sema;
use sema_a:   mach.compiler.sema.analyze;
use sema_e:   mach.compiler.sema.errors;
use symbol:   mach.compiler.symbol;
use type:       mach.compiler.type;
use comptime: mach.compiler.comptime;
use target:   mach.compiler.target;
use masm:     mach.compiler.masm;
use ir:       mach.compiler.masm.ir;
use section:  mach.compiler.masm.section;
use sym:      mach.compiler.masm.symbol;
use isa:      mach.compiler.isa;
use abi:      mach.compiler.abi;
use ir_peep:  mach.compiler.masm.opt.peephole;
use lower:    mach.compiler.lower;
use ldecl:    mach.compiler.lower.decl;
use regalloc: mach.compiler.regalloc;
use cemit:    mach.compiler.emit;
use linker:   mach.compiler.linker;
use mangle:   mach.compiler.masm.mangle;
use utilfs:   mach.util.filesystem;

# mach.compiler.pipeline: compiler orchestrator.
# ---
# wires all compiler phases together and serves as the primary public API.
# each phase is independently callable with explicit inputs/outputs.
# external consumers (CLI, LSP, build tools) interact through this module.

# --- phase alias ---

pub def Phase: u8;
pub val PHASE_ALL:   Phase = 0;
pub val PHASE_LEX:   Phase = 1;
pub val PHASE_PARSE: Phase = 2;
pub val PHASE_SEMA:  Phase = 3;
pub val PHASE_LOWER: Phase = 4;
pub val PHASE_EMIT:  Phase = 5;

# --- configuration ---

pub rec CompileOptions {
    target:          target.Target;
    alloc:           *allocator.Allocator;
    project_id:      str;
    src_root:        str;
    dep_root:        str;
    deps:            *config.Dep;
    dep_count:       i32;
    includes:        *config.IncludePath;
    include_count:   i32;
    enable_comptime: bool;
    stop_after:      Phase;
    emit_debug:      bool;
    verbose:         bool;
    output_path:     str;   # final executable/library path
    obj_path:        str;   # optional: write .o artifact here for inspection
    obj_dir:         str;   # per-module .o directory (nil = monolithic mode)
}

# --- result types ---

pub rec ParseResult {
    root: *ast.Node;
    ok:   bool;
}

pub rec SemaResult {
    root:    *ast.Node;
    symbols: *symbol.Table;
    types:   *type.TypeCache;
    sema:    sema.Sema;
    ok:      bool;
}

pub rec LowerResult {
    mctx: *masm.Context;
    ok:   bool;
}

pub rec CompileResult {
    mctx:        *masm.Context;
    output_path: str;
    ok:          bool;
}

# --- individual phase functions ---

# parse_source: lex and parse source text into an AST.
pub fun parse_source(source: str, alloc: *allocator.Allocator, verbose: bool) ParseResult {
    var result: ParseResult;
    result.root = nil;
    result.ok = false;

    if (source == nil || alloc == nil) { ret result; }

    if (verbose) { print.eprint("[verbose] parse: starting\n"); }

    var p: parser.Parser = parser.init(source, alloc);
    val parse_res: Result[*ast.Node, str] = parser.parser_parse_program(?p);

    if (result_is_err[*ast.Node, str](parse_res) || p.had_error) {
        if (verbose) { print.eprint("[verbose] parse: failed\n"); }
        parser.parser_dnit(?p);
        ret result;
    }

    result.root = result_unwrap_ok[*ast.Node, str](parse_res);
    result.ok = true;
    if (verbose) { print.eprint("[verbose] parse: complete\n"); }
    parser.parser_dnit(?p);
    ret result;
}

# analyze: run semantic analysis on a parsed AST.
pub fun analyze(root: *ast.Node, file_path: str, source: str,
                opts: *CompileOptions) SemaResult {
    var result: SemaResult;
    result.root = nil;
    result.symbols = nil;
    result.types = nil;
    result.ok = false;

    if (root == nil || opts == nil || opts.alloc == nil) { ret result; }

    if (opts.verbose) {
        print.eprintf("[verbose] sema: starting analysis of '%s'\n", file_path);
    }

    var sem: sema.Sema = sema.init(opts.alloc, opts.target);

    # set module roots for project mode
    if (opts.project_id != nil && opts.src_root != nil) {
        if (opts.verbose) {
            print.eprintf("[verbose] sema: project='%s' src_root='%s'\n",
                opts.project_id, opts.src_root);
        }
        sema.set_module_roots(?sem, opts.project_id, opts.src_root, opts.dep_root,
            opts.deps, opts.dep_count);
    }

    if (opts.includes != nil && opts.include_count > 0) {
        sema.set_includes(?sem, opts.includes, opts.include_count);
    }

    # ensure symbol table exists
    if (sem.symbols == nil) {
        val table_res: Result[symbol.Table, str] = symbol.init(opts.alloc);
        if (result_is_err[symbol.Table, str](table_res)) {
            sema.dnit(?sem);
            ret result;
        }

        val table_ptr_res: Result[*symbol.Table, allocator.AllocError] =
            allocator.allocator_alloc[symbol.Table](opts.alloc, 1);
        if (result_is_err[*symbol.Table, allocator.AllocError](table_ptr_res)) {
            sema.dnit(?sem);
            ret result;
        }
        val table_ptr: *symbol.Table = result_unwrap_ok[*symbol.Table, allocator.AllocError](table_ptr_res);
        @table_ptr = result_unwrap_ok[symbol.Table, str](table_res);
        sem.symbols = table_ptr;
    }

    # optionally create comptime context
    var cctx_ptr: *comptime.ComptimeContext = nil;
    if (opts.enable_comptime) {
        if (opts.verbose) { print.eprint("[verbose] sema: creating comptime context\n"); }
        val cctx_alloc_res: Result[*comptime.ComptimeContext, allocator.AllocError] =
            allocator.allocator_alloc[comptime.ComptimeContext](opts.alloc, 1);
        if (result_is_err[*comptime.ComptimeContext, allocator.AllocError](cctx_alloc_res)) {
            sema.dnit(?sem);
            ret result;
        }
        cctx_ptr = result_unwrap_ok[*comptime.ComptimeContext, allocator.AllocError](cctx_alloc_res);
        comptime.init(cctx_ptr, opts.alloc, sem.symbols, sem.types, ?opts.target);
    }

    if (opts.verbose) { print.eprint("[verbose] sema: running 4-pass analysis\n"); }
    val analyze_res: Result[bool, str] = sema_a.analyze(?sem, root, file_path, source, cctx_ptr);
    if (result_is_err[bool, str](analyze_res)) {
        if (opts.verbose) { print.eprint("[verbose] sema: analysis returned error\n"); }
        sema.dnit(?sem);
        ret result;
    }

    if (sema_e.has_errors(?sem)) {
        if (opts.verbose) {
            print.eprintf("[verbose] sema: %d errors found\n", sem.error_count::i64);
        }
        sema_e.print_errors(?sem);
        sema.dnit(?sem);
        ret result;
    }

    if (opts.verbose) { print.eprint("[verbose] sema: complete (no errors)\n"); }

    result.root = root;
    result.symbols = sema.get_symbol_table(?sem);
    result.types = sema.get_type_cache(?sem);
    result.sema = sem;
    result.ok = true;
    ret result;
}

# lower_module: lower a typed AST into MASM IR.
# lowers the entry module and all imported modules into a single MASM context.
pub fun lower_module(root: *ast.Node, symbols: *symbol.Table,
                     tgt: *target.Target, alloc: *allocator.Allocator,
                     sem: *sema.Sema, verbose: bool) LowerResult {
    var result: LowerResult;
    result.mctx = nil;
    result.ok = false;

    if (root == nil || tgt == nil || alloc == nil) { ret result; }

    if (verbose) { print.eprint("[verbose] lower: creating MASM context\n"); }

    # create MASM context
    val mctx_res: Result[masm.Context, str] = masm.create(alloc, @tgt);
    if (result_is_err[masm.Context, str](mctx_res)) { ret result; }

    val mctx_ptr_res: Result[*masm.Context, allocator.AllocError] =
        allocator.allocator_alloc[masm.Context](alloc, 1);
    if (result_is_err[*masm.Context, allocator.AllocError](mctx_ptr_res)) { ret result; }
    val mctx: *masm.Context = result_unwrap_ok[*masm.Context, allocator.AllocError](mctx_ptr_res);
    @mctx = result_unwrap_ok[masm.Context, str](mctx_res);

    # lower entry module
    if (verbose) { print.eprint("[verbose] lower: lowering entry module\n"); }
    val lctx_res: Result[lower.LowerContext, str] = lower.create(alloc, tgt, mctx, symbols, nil);
    if (result_is_err[lower.LowerContext, str](lctx_res)) { ret result; }

    var lctx: lower.LowerContext = result_unwrap_ok[lower.LowerContext, str](lctx_res);
    ldecl.lower_module(?lctx, root);

    # lower imported modules into the same MASM context
    if (sem != nil) {
        val max_mods: i32 = 512;
        val mods_r: Result[**sema.SemaModule, allocator.AllocError] =
            allocator.allocator_alloc[*sema.SemaModule](alloc, max_mods::usize);
        if (result_is_ok[**sema.SemaModule, allocator.AllocError](mods_r)) {
            val mods: **sema.SemaModule = result_unwrap_ok[**sema.SemaModule, allocator.AllocError](mods_r);
            val mod_count: i32 = sema.get_loaded_modules(sem, mods, max_mods);

            if (mod_count >= max_mods) {
                print.eprint("error: project exceeds maximum module limit (");
                print.eu64(max_mods::u64);
                print.eprint(" modules)\n");
                ret result;
            }

            if (verbose) {
                print.eprintf("[verbose] lower: lowering %d imported modules\n", mod_count::i64);
            }

            var mi: i32 = 0;
            for (mi < mod_count) {
                val m: *sema.SemaModule = mods[mi];
                if (m != nil && m.ast != nil && m.is_analyzed) {
                    if (verbose) {
                        print.eprintf("[verbose] lower:   module[%d] '%s'\n",
                            mi::i64, m.path);
                    }
                    val mlctx_res: Result[lower.LowerContext, str] =
                        lower.create(alloc, tgt, mctx, m.table, nil);
                    if (result_is_ok[lower.LowerContext, str](mlctx_res)) {
                        var mlctx: lower.LowerContext =
                            result_unwrap_ok[lower.LowerContext, str](mlctx_res);
                        ldecl.lower_module(?mlctx, m.ast);
                    }
                }
                mi = mi + 1;
            }
        }
    }

    if (verbose) {
        print.eprintf("[verbose] lower: complete (%d IR functions)\n",
            mctx.ir_func_count::i64);
    }

    result.mctx = mctx;
    result.ok = true;
    ret result;
}

# --- codegen: ISel + regalloc + encode ---

# codegen: run instruction selection, register allocation, and encoding.
# processes each function as a unit: ISel all → regalloc → encode all.
# populates the .text section with encoded machine code.
fun codegen(mctx: *masm.Context, tgt: *target.Target,
            alloc: *allocator.Allocator, verbose: bool) bool {
    if (mctx == nil || tgt == nil || alloc == nil) { ret false; }

    val i: *isa.ISA = ?tgt.isa;
    val a: *abi.ABI = ?tgt.abi;

    if (verbose) {
        print.eprintf("[verbose] codegen: starting (%d IR functions)\n",
            mctx.ir_func_count::i64);
    }

    # ensure .text section exists
    val text_res: Result[*section.Section, str] = masm.get_or_create_section(
        mctx, ".text", section.SEC_TEXT);
    if (result_is_err[*section.Section, str](text_res)) { ret false; }
    val text_sec: *section.Section = result_unwrap_ok[*section.Section, str](text_res);

    val text_idx: i32 = masm.get_section_index(mctx, ".text");

    var inst_buf: isa.MachInstBuf = isa.buf_create(alloc);
    var func_buf: isa.MachInstBuf = isa.buf_create(alloc);

    var fi: i32 = 0;
    for (fi < mctx.ir_func_count) {
        val func: *ir.Function = mctx.ir_funcs[fi];
        if (func == nil) { fi = fi + 1; cnt; }

        if (verbose) {
            print.eprintf("[verbose] codegen: func[%d] '%s'\n",
                fi::i64, func.name);
        }

        # === Phase A: ISel entire function → func_buf ===
        isa.buf_clear(?func_buf);
        var ir_count: i32 = 0;

        var bi: i32 = 0;
        for (bi < func.block_count) {
            val block: *ir.Block = func.blocks[bi];
            if (block == nil) { bi = bi + 1; cnt; }

            var ii: i32 = 0;
            for (ii < block.inst_count) {
                val ir_inst: *ir.Inst = ?block.insts[ii];
                ir_count = ir_count + 1;

                if (ir_inst.op == ir.OP_LABEL) {
                    # insert MACHINST_LABEL marker into func_buf
                    var label_mi: isa.MachInst;
                    label_mi.opcode = isa.MACHINST_LABEL;
                    label_mi.dst = ir_inst.dst; # carries the label operand
                    label_mi.size = 0;
                    label_mi.flags = 0;
                    isa.buf_append(?func_buf, label_mi);
                } or {
                    # ISel → per-inst buf → peephole → append to func_buf
                    isa.buf_clear(?inst_buf);
                    i.isel(i.ctx, ir_inst, ?inst_buf);
                    i.peephole(i.ctx, ?inst_buf);

                    var mi: i32 = 0;
                    for (mi < inst_buf.count) {
                        val minst: *isa.MachInst = isa.buf_get(?inst_buf, mi);
                        if (minst != nil) {
                            isa.buf_append(?func_buf, @minst);
                        }
                        mi = mi + 1;
                    }
                }

                ii = ii + 1;
            }
            bi = bi + 1;
        }

        if (verbose) {
            print.eprintf("[verbose] codegen:   ISel: %d IR -> %d MachInst\n",
                ir_count::i64, func_buf.count::i64);
        }

        # === Phase B: Register allocation ===
        var ra: regalloc.RegAllocResult = regalloc.alloc_function(
            alloc, i, a, ?func_buf, func.local_size);

        if (!ra.ok) {
            if (verbose) {
                print.eprintf("[verbose] codegen:   regalloc FAILED for '%s'\n",
                    func.name);
            }
            fi = fi + 1;
            cnt;
        }

        if (verbose) {
            print.eprintf("[verbose] codegen:   regalloc: out=%d spill=%d callee_mask=0x%x\n",
                ra.out.count::i64, ra.spill_size::i64, ra.callee_mask::i64);
        }

        # === Phase C: Compute frame, emit prologue ===
        # count callee-saved registers used (for alignment)
        var callee_push_count: i32 = 0;
        var cmask_tmp: u32 = ra.callee_mask;
        for (cmask_tmp != 0) {
            callee_push_count = callee_push_count + (cmask_tmp & 1)::i32;
            cmask_tmp = cmask_tmp >> 1;
        }

        val callee_save_size: usize = callee_push_count::usize * 8;
        var total_frame: usize = func.local_size + ra.spill_size
                                 + func.call_area_size;
        # align stack: return addr + push rbp + N callee pushes + frame
        # total pushed values = 2 + callee_push_count
        # (2 + N) * 8 + frame must be ≡ 0 (mod stack_align)
        val pushed_bytes: usize = (2 + callee_push_count::usize) * 8;
        val stack_al: usize = a.stack_align(a.ctx);
        val al_mask: usize = stack_al - 1;
        val align_rem: usize = (pushed_bytes + total_frame) & al_mask;
        if (align_rem != 0) {
            total_frame = total_frame + (stack_al - align_rem);
        }

        val has_frame: bool = total_frame > 0 || ra.callee_mask != 0;
        val func_start: usize = section.current_offset(text_sec);

        if (verbose) {
            print.eprintf("[verbose] codegen:   frame: locals=%d spill=%d call_area=%d total=%d\n",
                func.local_size::i64, ra.spill_size::i64,
                func.call_area_size::i64, total_frame::i64);
        }

        # resolve VREG_SP operands: [VREG_SP + offset] → [FP - total_frame + offset]
        val fp_reg: i32 = i.frame_reg(i.ctx);
        var si: i32 = 0;
        for (si < ra.out.count) {
            val sinst: *isa.MachInst = isa.buf_get(?ra.out, si);
            if (sinst != nil) {
                fixup_sp_operand(?sinst.dst,  fp_reg, total_frame);
                fixup_sp_operand(?sinst.src1, fp_reg, total_frame);
                fixup_sp_operand(?sinst.src2, fp_reg, total_frame);
            }
            si = si + 1;
        }

        # shift FP-relative negative displacements past callee-save area
        var si2: i32 = 0;
        for (si2 < ra.out.count) {
            val sinst: *isa.MachInst = isa.buf_get(?ra.out, si2);
            if (sinst != nil) {
                fixup_fp_callee_offset(?sinst.dst,  fp_reg, callee_save_size);
                fixup_fp_callee_offset(?sinst.src1, fp_reg, callee_save_size);
                fixup_fp_callee_offset(?sinst.src2, fp_reg, callee_save_size);
            }
            si2 = si2 + 1;
        }

        if (has_frame) {
            i.prologue(i.ctx, total_frame, ra.callee_mask, text_sec, alloc);
        }

        # === Phase D: Encode regalloc output ===
        var encode_fails: i32 = 0;
        var encode_ok: i32 = 0;
        var ei: i32 = 0;
        for (ei < ra.out.count) {
            val minst: *isa.MachInst = isa.buf_get(?ra.out, ei);
            if (minst == nil) { ei = ei + 1; cnt; }

            if (minst.opcode == isa.MACHINST_LABEL) {
                # register label symbol at current section offset
                register_label_symbol(mctx, minst, text_sec, text_idx, alloc);
            } or (i.is_ret(i.ctx, minst) && has_frame) {
                # emit epilogue (includes ret) instead of bare ret
                i.epilogue(i.ctx, ra.callee_mask, text_sec, alloc);
                encode_ok = encode_ok + 1;
            } or {
                val enc_r: i32 = i.encode(i.ctx, minst, text_sec, alloc);
                if (enc_r < 0) {
                    print.eprintf("  ENCODE FAIL '%s' #%d opc=%d dst.k=%d s1.k=%d s2.k=%d sz=%d\n",
                        func.name, ei::i64, minst.opcode::i64,
                        minst.dst.kind::i64, minst.src1.kind::i64,
                        minst.src2.kind::i64, minst.size::i64);
                    encode_fails = encode_fails + 1;
                } or {
                    encode_ok = encode_ok + 1;
                }
            }

            ei = ei + 1;
        }
        if (encode_fails > 0) {
            print.eprintf("  TOTAL ENCODE FAILS for '%s': %d\n",
                func.name, encode_fails::i64);
        }
        if (verbose) {
            print.eprintf("[verbose] codegen:   encode: %d/%d ok",
                encode_ok::i64, ra.out.count::i64);
            if (encode_fails > 0) {
                print.eprintf(", %d FAILED", encode_fails::i64);
            }
            print.eprint("\n");
        }

        # === Phase E: Symbol fixup ===
        val func_end: usize = section.current_offset(text_sec);
        fixup_symbol_offset(mctx, func.name, func_start, func_end - func_start, text_idx);

        if (verbose) {
            print.eprintf("[verbose] codegen:   symbol '%s' offset=%d size=%d\n",
                func.name, func_start::i64, (func_end - func_start)::i64);
        }

        isa.buf_destroy(?ra.out);
        fi = fi + 1;
    }

    if (verbose) { print.eprint("[verbose] codegen: complete\n"); }

    isa.buf_destroy(?inst_buf);
    isa.buf_destroy(?func_buf);
    ret true;
}

# fixup_symbol_offset: update a symbol's offset, size, and section to match its position in .text.
fun fixup_symbol_offset(mctx: *masm.Context, name: str, offset: usize, size: usize, text_idx: i32) {
    val s: *sym.Symbol = masm.get_symbol(mctx, name);
    if (s != nil) {
        s.offset = offset;
        s.size = size;
        if (text_idx >= 0) {
            s.section = text_idx::u64;
        }
    }
}

# register_label_symbol: register a label at the current section offset.
fun register_label_symbol(mctx: *masm.Context, inst: *isa.MachInst,
                          sec: *section.Section, text_idx: i32,
                          alloc: *allocator.Allocator) {
    if (inst == nil || inst.dst.label == nil) { ret; }

    val offset: usize = section.current_offset(sec);
    val name: str = inst.dst.label;

    # check if symbol already exists (from lowering)
    val existing: *sym.Symbol = masm.get_symbol(mctx, name);
    if (existing != nil) {
        existing.offset = offset;
        if (text_idx >= 0) {
            existing.section = text_idx::u64;
        }
        ret;
    }

    # create a new local symbol for this label
    val sym_r: Result[*sym.Symbol, str] = sym.create(alloc, name);
    if (result_is_err[*sym.Symbol, str](sym_r)) { ret; }

    val s: *sym.Symbol = result_unwrap_ok[*sym.Symbol, str](sym_r);
    s.binding = sym.BIND_LOCAL;
    s.sym_type = sym.SYM_FUNC;
    s.offset = offset;
    s.defined = true;
    if (text_idx >= 0) {
        s.section = text_idx::u64;
    }

    masm.add_symbol(mctx, s);
}

# fixup_sp_operand: resolve VREG_SP memory operands to FP-relative.
# [VREG_SP + offset] becomes [fp_reg + (offset - total_frame)],
# which at runtime equals [RSP + offset].
fun fixup_sp_operand(op: *ir.Operand, fp_reg: i32, total_frame: usize) {
    if (op == nil || op.kind != ir.OPK_MEM) { ret; }
    if (op.base == ir.VREG_SP) {
        op.base = fp_reg;
        op.disp = op.disp - total_frame::i64;
    }
}

# fixup_fp_callee_offset: shift FP-relative negative displacements past
# the callee-save area. With standard RBP frames, callee-saved registers
# are pushed between RBP and the local frame, so all negative FP-relative
# offsets (locals, spills, call area) must be shifted down by callee_size.
# Positive displacements (caller's stack args above RBP) are unchanged.
fun fixup_fp_callee_offset(op: *ir.Operand, fp_reg: i32, callee_size: usize) {
    if (op == nil || op.kind != ir.OPK_MEM) { ret; }
    if (op.base == fp_reg && op.disp < 0) {
        op.disp = op.disp - callee_size::i64;
    }
}

# --- per-module compilation ---

# resolve_externs: add undefined symbols for cross-module references.
# scans all section relocations; for any relocation referencing a symbol name
# not in the MASM context, adds an undefined global symbol.
fun resolve_externs(mctx: *masm.Context, alloc: *allocator.Allocator) {
    if (mctx == nil || alloc == nil) { ret; }

    var si: i32 = 0;
    for (si < mctx.section_count) {
        val sec: *section.Section = mctx.sections[si];
        if (sec == nil || sec.reloc_count == 0) {
            si = si + 1;
            cnt;
        }

        var ri: i32 = 0;
        for (ri < sec.reloc_count) {
            val name: str = sec.relocs[ri].symbol_name;
            if (name != nil && masm.get_symbol(mctx, name) == nil) {
                # symbol not in this module — add as undefined external
                val s_r: Result[*sym.Symbol, str] = sym.create(alloc, name);
                if (result_is_ok[*sym.Symbol, str](s_r)) {
                    val s: *sym.Symbol = result_unwrap_ok[*sym.Symbol, str](s_r);
                    s.binding = sym.BIND_GLOBAL;
                    s.sym_type = sym.SYM_NONE;
                    s.defined = false;
                    masm.add_symbol(mctx, s);
                }
            }
            ri = ri + 1;
        }
        si = si + 1;
    }
}

# module_path_to_obj_path: convert a module path to an artifact .o file path.
# strips project_id prefix if present, replaces dots with '/', appends ".o",
# prepends obj_dir.
# e.g. (project_id="mach", obj_dir="out/obj"):
#   "mach.cli.args" → "out/obj/cli/args.o"
#   "std.runtime"   → "out/obj/std/runtime.o"
fun module_path_to_obj_path(mod_path: str, project_id: str, obj_dir: str,
                            alloc: *allocator.Allocator) str {
    if (mod_path == nil || obj_dir == nil || alloc == nil) { ret nil; }

    # determine the relative part (strip project_id prefix if present)
    var rel: str = mod_path;
    if (project_id != nil) {
        val pid_len: usize = str_len(project_id);
        val mp_len: usize = str_len(mod_path);
        if (mp_len > pid_len + 1 && str_starts_with(mod_path, project_id)
            && mod_path[pid_len] == '.') {
            rel = (mod_path::usize + pid_len + 1)::str;
        }
    }

    # compute output: obj_dir + "/" + rel (dots→slashes) + ".o"
    val rel_len: usize = str_len(rel);
    val dir_len: usize = str_len(obj_dir);
    val total: usize = dir_len + 1 + rel_len + 2 + 1;

    val r: Result[*u8, allocator.AllocError] =
        allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    var p: usize = 0;

    # copy obj_dir
    var i: usize = 0;
    for (i < dir_len) {
        buf[p] = obj_dir[i];
        p = p + 1;
        i = i + 1;
    }

    # separator
    if (dir_len > 0 && obj_dir[dir_len - 1] != '/') {
        buf[p] = '/';
        p = p + 1;
    }

    # copy rel, replacing dots with slashes
    i = 0;
    for (i < rel_len) {
        if (rel[i] == '.') {
            buf[p] = '/';
        } or {
            buf[p] = rel[i];
        }
        p = p + 1;
        i = i + 1;
    }

    # append ".o"
    buf[p] = '.';
    p = p + 1;
    buf[p] = 'o';
    p = p + 1;
    buf[p] = 0;

    ret buf::&u8;
}

# compile_module: compile a single module into a .o file.
# creates a fresh MASM context, lowers the module, runs peephole + codegen,
# resolves external references, and emits a .o file.
# returns true if a .o was emitted, false if module was type-only or failed.
# smod: the SemaModule for this module (used to match generic instantiations)
# func_insts: linked list of all generic function instantiations from sema
fun compile_module(root: *ast.Node, symbols: *symbol.Table,
                   tgt: *target.Target, alloc: *allocator.Allocator,
                   obj_path: str, smod: *sema.SemaModule,
                   func_insts: *sema.FunctionInstantiation,
                   verbose: bool) bool {
    if (root == nil || tgt == nil || alloc == nil || obj_path == nil) { ret false; }

    if (verbose) {
        print.eprintf("[verbose] compile_module: '%s'\n", obj_path);
    }

    # 1. create fresh MASM context
    val mctx_res: Result[masm.Context, str] = masm.create(alloc, @tgt);
    if (result_is_err[masm.Context, str](mctx_res)) { ret false; }

    val mctx_ptr_res: Result[*masm.Context, allocator.AllocError] =
        allocator.allocator_alloc[masm.Context](alloc, 1);
    if (result_is_err[*masm.Context, allocator.AllocError](mctx_ptr_res)) { ret false; }
    val mctx: *masm.Context =
        result_unwrap_ok[*masm.Context, allocator.AllocError](mctx_ptr_res);
    @mctx = result_unwrap_ok[masm.Context, str](mctx_res);

    # 2. lower this module
    val lctx_res: Result[lower.LowerContext, str] =
        lower.create(alloc, tgt, mctx, symbols, nil);
    if (result_is_err[lower.LowerContext, str](lctx_res)) { ret false; }

    var lctx: lower.LowerContext =
        result_unwrap_ok[lower.LowerContext, str](lctx_res);
    ldecl.lower_module(?lctx, root);

    # 2b. lower generic function instantiations that belong to this module
    var finst: *sema.FunctionInstantiation = func_insts;
    var inst_count: i32 = 0;
    for (finst != nil) {
        if (finst.origin_module == smod && finst.func_ast != nil) {
            # look up the instantiation's symbol in the module's table
            var inst_sym: *symbol.Symbol = nil;
            if (symbols != nil) {
                val sym_opt: Option[*symbol.Symbol] =
                    symbol.table_lookup(symbols, finst.mangled_name);
                if (option_is_some[*symbol.Symbol](sym_opt)) {
                    inst_sym = option_unwrap[*symbol.Symbol](sym_opt);
                }
            }

            # compute full mangled name (module prefix + short mangled name)
            var full_name: str = finst.mangled_name;
            if (inst_sym != nil && inst_sym.module_path != nil) {
                full_name = mangle.mangle(alloc, inst_sym.module_path, finst.mangled_name);
            }

            ldecl.lower_func_inst(?lctx, finst.func_ast, full_name, inst_sym);
            inst_count = inst_count + 1;
        }
        finst = finst.next;
    }

    if (verbose && inst_count > 0) {
        print.eprintf("[verbose] compile_module:   lowered %d generic instantiations\n",
            inst_count::i64);
    }

    # 3. check if type-only (no IR functions and no section data)
    if (mctx.ir_func_count == 0) {
        var has_data: bool = false;
        var si: i32 = 0;
        for (si < mctx.section_count) {
            if (mctx.sections[si] != nil && mctx.sections[si].size > 0) {
                has_data = true;
                brk;
            }
            si = si + 1;
        }
        if (!has_data) {
            if (verbose) {
                print.eprintf("[verbose] compile_module:   type-only, skipping\n");
            }
            ret false;
        }
    }

    if (verbose) {
        print.eprintf("[verbose] compile_module:   %d IR functions\n",
            mctx.ir_func_count::i64);
    }

    # 4. peephole optimization
    var opt_ctx: ir_peep.OptContext = ir_peep.init(alloc);
    var oi: i32 = 0;
    for (oi < mctx.ir_func_count) {
        val func: *ir.Function = mctx.ir_funcs[oi];
        if (func != nil) {
            ir_peep.optimize_function(?opt_ctx, func);
        }
        oi = oi + 1;
    }

    # 5. codegen (ISel + encode)
    if (!codegen(mctx, tgt, alloc, verbose)) { ret false; }

    # 6. resolve external references
    resolve_externs(mctx, alloc);

    # 7. emit .o file
    if (verbose) {
        print.eprintf("[verbose] compile_module:   emitting '%s'\n", obj_path);
    }
    val emit_res: i64 = cemit.emit(mctx, tgt, obj_path, alloc);
    if (emit_res != 0) { ret false; }

    ret true;
}

# compile_per_module: per-module compilation and linking.
# compiles each module to its own .o, then links them into the final executable.
fun compile_per_module(root: *ast.Node, symbols: *symbol.Table,
                       sem: *sema.Sema, module_path: str,
                       opts: *CompileOptions) Result[CompileResult, str] {
    val alloc: *allocator.Allocator = opts.alloc;
    val tgt: *target.Target = ?opts.target;

    # get generic function instantiations
    val func_insts: *sema.FunctionInstantiation = sema.get_func_insts(sem);

    # get entry module's SemaModule (for matching instantiations)
    val entry_smod: *sema.SemaModule = sem.current_module;

    # collect imported modules
    val max_mods: i32 = 512;
    val mods_r: Result[**sema.SemaModule, allocator.AllocError] =
        allocator.allocator_alloc[*sema.SemaModule](alloc, max_mods::usize);
    if (result_is_err[**sema.SemaModule, allocator.AllocError](mods_r)) {
        sema.dnit(sem);
        ret err[CompileResult, str]("out of memory");
    }
    val mods: **sema.SemaModule =
        result_unwrap_ok[**sema.SemaModule, allocator.AllocError](mods_r);
    val mod_count: i32 = sema.get_loaded_modules(sem, mods, max_mods);

    if (mod_count >= max_mods) {
        sema.dnit(sem);
        ret err[CompileResult, str]("project exceeds maximum module limit");
    }

    # allocate array for .o paths (entry + imports)
    val max_obj: i32 = 1 + mod_count;
    val paths_r: Result[*str, allocator.AllocError] =
        allocator.allocator_zalloc[str](alloc, max_obj::usize);
    if (result_is_err[*str, allocator.AllocError](paths_r)) {
        sema.dnit(sem);
        ret err[CompileResult, str]("out of memory");
    }
    val obj_paths: *str = result_unwrap_ok[*str, allocator.AllocError](paths_r);
    var obj_count: i32 = 0;

    val verbose: bool = opts.verbose;

    if (verbose) {
        print.eprintf("[verbose] per-module: compiling entry + %d imported modules\n",
            mod_count::i64);
    }

    # compile entry module
    val entry_obj: str = module_path_to_obj_path(module_path, opts.project_id,
        opts.obj_dir, alloc);
    if (entry_obj != nil) {
        val entry_dir: str = utilfs.get_output_dir(entry_obj, alloc);
        if (entry_dir != nil) {
            utilfs.ensure_dir(entry_dir, alloc);
        }
        if (compile_module(root, symbols, tgt, alloc, entry_obj,
                           entry_smod, func_insts, verbose)) {
            obj_paths[obj_count] = entry_obj;
            obj_count = obj_count + 1;
        }
    }

    # compile imported modules
    var mi: i32 = 0;
    for (mi < mod_count) {
        val m: *sema.SemaModule = mods[mi];
        if (m != nil && m.ast != nil && m.is_analyzed) {
            val mobj: str = module_path_to_obj_path(m.path, opts.project_id,
                opts.obj_dir, alloc);
            if (mobj != nil) {
                val mdir: str = utilfs.get_output_dir(mobj, alloc);
                if (mdir != nil) {
                    utilfs.ensure_dir(mdir, alloc);
                }
                if (compile_module(m.ast, m.table, tgt, alloc, mobj,
                                   m, func_insts, verbose)) {
                    obj_paths[obj_count] = mobj;
                    obj_count = obj_count + 1;
                }
            }
        }
        mi = mi + 1;
    }

    sema.dnit(sem);

    if (opts.stop_after == PHASE_EMIT) {
        if (verbose) {
            print.eprintf("[verbose] per-module: emitted %d object files\n",
                obj_count::i64);
        }
        val r: CompileResult = CompileResult{mctx: nil, output_path: opts.obj_dir, ok: true};
        ret ok[CompileResult, str](r);
    }

    # link all .o files into the final executable
    if (opts.output_path == nil) {
        ret err[CompileResult, str]("output path is nil");
    }

    if (verbose) {
        print.eprintf("[verbose] link: linking %d objects -> '%s'\n",
            obj_count::i64, opts.output_path);
    }

    val link_res: i64 = linker.link_objects(obj_paths, obj_count, tgt,
        opts.output_path, alloc);
    if (link_res != 0) {
        ret err[CompileResult, str]("linking failed");
    }

    if (verbose) { print.eprint("[verbose] link: complete\n"); }

    val r: CompileResult = CompileResult{mctx: nil, output_path: opts.output_path, ok: true};
    ret ok[CompileResult, str](r);
}

# --- full compilation ---

# compile_from_sema: run phases 3+ (lower, optimize, codegen, link) from a sema result.
# ---
# root:        typed AST root
# symbols:     resolved symbol table
# sem:         sema context (cleaned up by this function before returning)
# module_path: module path for per-module compilation
# opts:        compilation options
# ret:         compile result
fun compile_from_sema(root: *ast.Node, symbols: *symbol.Table, sem: *sema.Sema,
    module_path: str, opts: *CompileOptions) Result[CompileResult, str] {

    # --- Phase 3+: Per-module or monolithic ---

    if (opts.obj_dir != nil) {
        if (opts.verbose) { print.eprint("[verbose] compile: using per-module compilation\n"); }
        ret compile_per_module(root, symbols, sem, module_path, opts);
    }

    # --- Monolithic fallback (no obj_dir set) ---
    if (opts.verbose) { print.eprint("[verbose] compile: using monolithic compilation\n"); }

    val lr: LowerResult = lower_module(root, symbols, ?opts.target, opts.alloc, sem,
        opts.verbose);
    sema.dnit(sem);

    if (!lr.ok) {
        ret err[CompileResult, str]("lowering failed");
    }

    if (opts.stop_after == PHASE_LOWER) {
        val r: CompileResult = CompileResult{mctx: lr.mctx, output_path: nil, ok: true};
        ret ok[CompileResult, str](r);
    }

    if (opts.verbose) { print.eprint("[verbose] peephole: optimizing IR\n"); }
    var opt_ctx: ir_peep.OptContext = ir_peep.init(opts.alloc);
    var oi: i32 = 0;
    for (oi < lr.mctx.ir_func_count) {
        val func: *ir.Function = lr.mctx.ir_funcs[oi];
        if (func != nil) {
            ir_peep.optimize_function(?opt_ctx, func);
        }
        oi = oi + 1;
    }

    if (!codegen(lr.mctx, ?opts.target, opts.alloc, opts.verbose)) {
        ret err[CompileResult, str]("code generation failed");
    }

    if (opts.obj_path != nil) {
        if (opts.verbose) {
            print.eprintf("[verbose] emit: writing object to '%s'\n", opts.obj_path);
        }
        val emit_res: i64 = cemit.emit(lr.mctx, ?opts.target, opts.obj_path, opts.alloc);
        if (emit_res != 0) {
            ret err[CompileResult, str]("object emission failed");
        }
    }

    if (opts.stop_after == PHASE_EMIT) {
        var out: str = opts.obj_path;
        if (out == nil) { out = opts.output_path; }
        val r: CompileResult = CompileResult{mctx: lr.mctx, output_path: out, ok: true};
        ret ok[CompileResult, str](r);
    }

    if (opts.output_path == nil) {
        ret err[CompileResult, str]("output path is nil");
    }

    if (opts.verbose) {
        print.eprintf("[verbose] link: linking -> '%s'\n", opts.output_path);
    }
    val link_res: i64 = linker.link(lr.mctx, ?opts.target, opts.output_path, opts.alloc);
    if (link_res != 0) {
        ret err[CompileResult, str]("linking failed");
    }

    if (opts.verbose) { print.eprint("[verbose] link: complete\n"); }

    val r: CompileResult = CompileResult{mctx: lr.mctx, output_path: opts.output_path, ok: true};
    ret ok[CompileResult, str](r);
}

# compile: run all phases from source to executable/object.
pub fun compile(source: str, file_path: str, module_path: str,
    opts: *CompileOptions) Result[CompileResult, str] {

    if (source == nil) {
        ret err[CompileResult, str]("source is nil");
    }
    if (opts.alloc == nil) {
        ret err[CompileResult, str]("allocator is nil");
    }

    if (opts.verbose) {
        print.eprintf("[verbose] compile: '%s' (module='%s')\n",
            file_path, module_path);
    }

    # --- Phase 1: Parse ---

    val pr: ParseResult = parse_source(source, opts.alloc, opts.verbose);
    if (!pr.ok) {
        ret err[CompileResult, str]("parsing failed");
    }

    if (opts.stop_after == PHASE_PARSE) {
        val r: CompileResult = CompileResult{mctx: nil, output_path: nil, ok: true};
        ret ok[CompileResult, str](r);
    }

    # --- Phase 2: Sema ---

    var sr: SemaResult = analyze(pr.root, file_path, source, opts);
    if (!sr.ok) {
        ret err[CompileResult, str]("semantic analysis failed");
    }

    if (opts.stop_after == PHASE_SEMA) {
        sema.dnit(?sr.sema);
        val r: CompileResult = CompileResult{mctx: nil, output_path: nil, ok: true};
        ret ok[CompileResult, str](r);
    }

    ret compile_from_sema(sr.root, sr.symbols, ?sr.sema, module_path, opts);
}

# compile_ast: run the pipeline from a pre-parsed AST.
pub fun compile_ast(root: *ast.Node, file_path: str, module_path: str,
    source: str, opts: *CompileOptions) Result[CompileResult, str] {

    if (root == nil) {
        ret err[CompileResult, str]("root AST node is nil");
    }
    if (opts.alloc == nil) {
        ret err[CompileResult, str]("allocator is nil");
    }

    if (opts.verbose) {
        print.eprintf("[verbose] compile_ast: '%s' (module='%s')\n",
            file_path, module_path);
    }

    # --- Phase 2: Sema ---

    var sr: SemaResult = analyze(root, file_path, source, opts);
    if (!sr.ok) {
        ret err[CompileResult, str]("semantic analysis failed");
    }

    if (opts.stop_after == PHASE_SEMA) {
        sema.dnit(?sr.sema);
        val r: CompileResult = CompileResult{mctx: nil, output_path: nil, ok: true};
        ret ok[CompileResult, str](r);
    }

    ret compile_from_sema(sr.root, sr.symbols, ?sr.sema, module_path, opts);
}

# --- helpers ---

# pos_to_line: convert byte offset to 1-based line number.
pub fun pos_to_line(source: str, pos: i32) i32 {
    if (source == nil || pos <= 0) { ret 1; }
    var line: i32 = 1;
    var i: i32 = 0;
    for (i < pos) {
        if (source[i] == '\n') { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

# pos_to_col: convert byte offset to 1-based column number.
pub fun pos_to_col(source: str, pos: i32) i32 {
    if (source == nil || pos <= 0) { ret 1; }
    var col: i32 = 1;
    var i: i32 = pos - 1;
    for (i >= 0) {
        if (source[i] == '\n') { ret col; }
        col = col + 1;
        i = i - 1;
    }
    ret col;
}
