use      std.types.list;
use      std.types.usize;
use      std.types.result;
use      std.types.option;
use      std.types.string;
use mem: std.system.memory;

use mach.compiler.pipeline.stage;

val PIPELINE_INITIAL_CAPACITY: usize = 8;

## Pipeline represents a sequence of stages to be executed.
## Each stage performs a specific task in the compilation process.
## Stages are executed in the order they are added to the pipeline.
pub rec Pipeline {
    stages: List[Stage];
}

## Initializes a pipeline instance.
##
## ret: An error message if initialization fails, otherwise none.
pub fun (this: *Pipeline) init() Option[str]{
    mem.zero[Pipeline](this, 1);

    val opt_stages_init: Option[str] = this.stages.init(PIPELINE_INITIAL_CAPACITY);
    if (opt_stages_init.is_some()) {
        ret opt_stages_init;
    }

    ret none[str]();
}

## Deinitializes a pipeline instance
pub fun (this: *Pipeline) dnit() {
    this.stages.dnit();
    mem.zero[Pipeline](this, 1);
}

## Adds a stage to the pipeline.
##
## stage: The stage to add.
## ret:   An error message if adding the stage fails, otherwise none.
pub fun (this: *Pipeline) add_stage(stage: Stage) Option[str] {
    if (this == nil) {
        ret some[str]("pipeline is nil");
    }

    if (this.stages.data == nil) {
        ret some[str]("pipeline stages not initialized");
    }

    ret this.stages.push(stage);
}

## Runs the pipeline by executing each stage in order.
##
## session: The compilation session context.
## ret:     An error message if any stage fails, otherwise none.
pub fun (this: *Pipeline) run(session: *Session) Option[str] {
    if (this == nil) {
        ret some[str]("pipeline is nil");
    }

    if (this.stages.is_empty()) {
        ret some[str]("pipeline has no stages");
    }

    var i: usize = 0;
    for (i < this.stages.len) {
        val res: Option[str] = this.stages.data[i].run(session);
        if (res.is_some()) {
            ret res;
        }
        i = i + 1;
    }

    ret none[str]();
}
