use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast: mach.compiler.ast;
use ty:  mach.compiler.type;

# mach.compiler.symbol: symbol table for semantic analysis.
# ---
# provides symbol storage and lookup for variables, functions, types, etc.

# SymbolKind: type alias for symbol kind tags.
pub def SymbolKind: u8;

# SymbolKind tag constants for efficient comparison.
pub val SYM_VAL:     SymbolKind = 0;   # immutable value binding
pub val SYM_VAR:     SymbolKind = 1;   # mutable variable binding
pub val SYM_FUN:     SymbolKind = 2;   # function
pub val SYM_TYPE:    SymbolKind = 3;   # type alias (def)
pub val SYM_REC:     SymbolKind = 4;   # record type
pub val SYM_UNI:     SymbolKind = 5;   # union type
pub val SYM_FIELD:   SymbolKind = 6;   # record/union field
pub val SYM_PARAM:   SymbolKind = 7;   # function parameter
pub val SYM_EXT:     SymbolKind = 8;   # external binding
pub val SYM_MODULE:  SymbolKind = 9;   # module
pub val SYM_GENERIC: SymbolKind = 10;  # generic type parameter

# SymbolKind: the kind of entity a symbol represents.
# ---
# each variant represents a different category of named entity.
pub uni SymbolKind {
    sym_val:      u8;  # immutable value binding
    sym_var:      u8;  # mutable variable binding
    sym_fun:      u8;  # function
    sym_type:     u8;  # type alias (def)
    sym_rec:      u8;  # record type
    sym_uni:      u8;  # union type
    sym_field:    u8;  # record/union field
    sym_param:    u8;  # function parameter
    sym_ext:      u8;  # external binding
    sym_module:   u8;  # module
    sym_generic:  u8;  # generic type parameter
}

# Symbol: a named entity in the program.
# ---
# name:         symbol name
# kind:         what kind of symbol this is (SYM_* constant)
# type_node:    AST node for the symbol's type (or nil)
# decl_node:    AST node where this symbol was declared
# resolved_type: resolved Type after semantic analysis (or nil)
# is_public:    true if exported from module
# is_mutable:   true for var, false for val
# scope:        owning scope (for nested lookup)
pub rec Symbol {
    name:          str;
    kind:          SymbolKind;
    type_node:     *ast.Node;
    decl_node:     *ast.Node;
    resolved_type: *ty.Type;
    is_public:     bool;
    is_mutable:    bool;
    scope:         *Scope;
}

# Scope: a lexical scope containing symbols.
# ---
# parent:       enclosing scope (or nil for module scope)
# symbols:      array of symbols in this scope
# symbol_count: number of symbols
# symbol_cap:   allocated capacity
pub rec Scope {
    parent:       *Scope;
    symbols:      *Symbol;
    symbol_count: i32;
    symbol_cap:   i32;
}

# Table: a symbol table managing multiple scopes.
# ---
# alloc:   allocator for symbols and scopes
# current: current active scope
# root:    root (module) scope
pub rec Table {
    alloc:   *allocator.Allocator;
    current: *Scope;
    root:    *Scope;
}

# init: create a new symbol table.
# ---
# alloc: allocator to use for symbols and scopes
# ret:   Ok(Table) on success, Err(str) on failure
pub fun init(alloc: *allocator.Allocator) Result[Table, str] {
    if (alloc == nil) {
        ret err[Table, str]("allocator is nil");
    }

    # create root scope
    val scope_res: Result[*Scope, allocator.AllocError] = alloc.zalloc[Scope](1);
    if (scope_res.is_err()) {
        ret err[Table, str](scope_res.unwrap_err());
    }

    val root: *Scope = scope_res.unwrap_ok();
    root.parent = nil;
    root.symbols = nil;
    root.symbol_count = 0;
    root.symbol_cap = 0;

    var table: Table;
    table.alloc = alloc;
    table.current = root;
    table.root = root;

    ret ok[Table, str](table);
}

# deinit: free all resources associated with a symbol table.
# ---
# table: table to clean up
# ret:   none
pub fun deinit(table: *Table) {
    if (table == nil || table.alloc == nil) {
        ret;
    }

    # TODO: recursively free all scopes and symbols
}

# push_scope: enter a new nested scope.
# ---
# table: symbol table
# ret:   Ok(true) on success, Err(str) on failure
pub fun push_scope(table: *Table) Result[bool, str] {
    if (table == nil) {
        ret err[bool, str]("table is nil");
    }

    if (table.alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    val scope_res: Result[*Scope, allocator.AllocError] = table.alloc.zalloc[Scope](1);
    if (scope_res.is_err()) {
        ret err[bool, str](scope_res.unwrap_err());
    }

    val scope: *Scope = scope_res.unwrap_ok();
    scope.parent = table.current;
    scope.symbols = nil;
    scope.symbol_count = 0;
    scope.symbol_cap = 0;

    table.current = scope;
    ret ok[bool, str](true);
}

# pop_scope: exit the current scope and return to the parent.
# ---
# table: symbol table
# ret:   Ok(true) on success, Err(str) if at root scope
pub fun pop_scope(table: *Table) Result[bool, str] {
    if (table == nil) {
        ret err[bool, str]("table is nil");
    }

    if (table.current == nil || table.current.parent == nil) {
        ret err[bool, str]("cannot pop root scope");
    }

    table.current = table.current.parent;
    ret ok[bool, str](true);
}

# define: add a symbol to the current scope.
# ---
# table: symbol table
# name:  symbol name
# kind:  symbol kind (SYM_* constant)
# ret:   Ok(*Symbol) on success, Err(str) if already defined or allocation fails
pub fun define(table: *Table, name: str, kind: SymbolKind) Result[*Symbol, str] {
    if (table == nil) {
        ret err[*Symbol, str]("table is nil");
    }

    if (table.current == nil) {
        ret err[*Symbol, str]("no current scope");
    }

    if (table.alloc == nil) {
        ret err[*Symbol, str]("allocator is nil");
    }

    # check for duplicate in current scope
    val existing: Option[*Symbol] = lookup_local(table.current, name);
    if (existing.is_some()) {
        ret err[*Symbol, str]("symbol already defined in scope");
    }

    # grow symbols array if needed
    if (table.current.symbol_count >= table.current.symbol_cap) {
        var new_cap: i32 = 8;
        if (table.current.symbol_cap > 0) {
            new_cap = table.current.symbol_cap * 2;
        }

        val r: Result[*Symbol, allocator.AllocError] = table.alloc.resize[Symbol](
            table.current.symbols,
            table.current.symbol_cap::usize,
            new_cap::usize
        );

        if (r.is_err()) {
            ret err[*Symbol, str](r.unwrap_err());
        }

        table.current.symbols = r.unwrap_ok();
        table.current.symbol_cap = new_cap;
    }

    # add symbol
    val idx: i32 = table.current.symbol_count;
    val sym: *Symbol = ?table.current.symbols[idx];
    sym.name = name;
    sym.kind = kind;
    sym.type_node = nil;
    sym.decl_node = nil;
    sym.resolved_type = nil;
    sym.is_public = false;
    sym.is_mutable = kind == SYM_VAR;
    sym.scope = table.current;

    table.current.symbol_count = table.current.symbol_count + 1;

    ret ok[*Symbol, str](sym);
}

# kind_name: get a string representation of a symbol kind.
# ---
# kind: symbol kind tag
# ret:  string name of the kind
pub fun kind_name(kind: SymbolKind) str {
    if (kind == SYM_VAL)     { ret "val"; }
    if (kind == SYM_VAR)     { ret "var"; }
    if (kind == SYM_FUN)     { ret "function"; }
    if (kind == SYM_TYPE)    { ret "type"; }
    if (kind == SYM_REC)     { ret "record"; }
    if (kind == SYM_UNI)     { ret "union"; }
    if (kind == SYM_FIELD)   { ret "field"; }
    if (kind == SYM_PARAM)   { ret "parameter"; }
    if (kind == SYM_EXT)     { ret "external"; }
    if (kind == SYM_MODULE)  { ret "module"; }
    if (kind == SYM_GENERIC) { ret "generic"; }
    ret "unknown";
}

# is_type_symbol: check if a symbol represents a type.
# ---
# sym: symbol to check
# ret: true if symbol is a type
pub fun is_type_symbol(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }
    ret sym.kind == SYM_TYPE || sym.kind == SYM_REC || sym.kind == SYM_UNI || sym.kind == SYM_GENERIC;
}

# is_value_symbol: check if a symbol represents a value (variable/constant).
# ---
# sym: symbol to check
# ret: true if symbol is a value
pub fun is_value_symbol(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }
    ret sym.kind == SYM_VAL || sym.kind == SYM_VAR || sym.kind == SYM_PARAM;
}

# is_callable: check if a symbol can be called as a function.
# ---
# sym: symbol to check
# ret: true if symbol is callable
pub fun is_callable(sym: *Symbol) bool {
    if (sym == nil) {
        ret false;
    }
    ret sym.kind == SYM_FUN || sym.kind == SYM_EXT;
}

# lookup: find a symbol by name, searching up through parent scopes.
# ---
# table: symbol table
# name:  symbol name to find
# ret:   Some(*Symbol) if found, None if not found
pub fun lookup(table: *Table, name: str) Option[*Symbol] {
    if (table == nil || table.current == nil) {
        ret none[*Symbol]();
    }

    var scope: *Scope = table.current;
    for (scope != nil) {
        val result: Option[*Symbol] = lookup_local(scope, name);
        if (result.is_some()) {
            ret result;
        }
        scope = scope.parent;
    }

    ret none[*Symbol]();
}

# lookup_local: find a symbol in a specific scope only (no parent search).
# ---
# scope: scope to search
# name:  symbol name to find
# ret:   Some(*Symbol) if found, None if not found
pub fun lookup_local(scope: *Scope, name: str) Option[*Symbol] {
    if (scope == nil || scope.symbols == nil || name == nil) {
        ret none[*Symbol]();
    }

    var i: i32 = 0;
    for (i < scope.symbol_count) {
        val sym: *Symbol = ?scope.symbols[i];
        if (sym.name != nil && sym.name.equals(name)) {
            ret some[*Symbol](sym);
        }
        i = i + 1;
    }

    ret none[*Symbol]();
}

# current_scope: get the current scope.
# ---
# table: symbol table
# ret:   current scope or nil
pub fun current_scope(table: *Table) *Scope {
    if (table == nil) {
        ret nil;
    }
    ret table.current;
}

# root_scope: get the root (module) scope.
# ---
# table: symbol table
# ret:   root scope or nil
pub fun root_scope(table: *Table) *Scope {
    if (table == nil) {
        ret nil;
    }
    ret table.root;
}
