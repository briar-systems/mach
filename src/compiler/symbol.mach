use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast: mach.compiler.ast;
use ty:  mach.compiler.type;

# mach.compiler.symbol: symbol table for semantic analysis.
# ---
# provides symbol storage and lookup for variables, functions, types, etc.

# SymbolKind: type alias for symbol kind tags.
pub def SymbolKind: u8;

# SymbolKind tag constants for efficient comparison.
pub val SYM_VAL:     SymbolKind = 0;   # immutable value binding
pub val SYM_VAR:     SymbolKind = 1;   # mutable variable binding
pub val SYM_FUN:     SymbolKind = 2;   # function
pub val SYM_TYPE:    SymbolKind = 3;   # type alias (def)
pub val SYM_REC:     SymbolKind = 4;   # record type
pub val SYM_UNI:     SymbolKind = 5;   # union type
pub val SYM_FIELD:   SymbolKind = 6;   # record/union field
pub val SYM_PARAM:   SymbolKind = 7;   # function parameter
pub val SYM_EXT:     SymbolKind = 8;   # external binding
pub val SYM_MODULE:  SymbolKind = 9;   # module
pub val SYM_GENERIC: SymbolKind = 10;  # generic type parameter

# Symbol: a named entity in the program.
# ---
# name:         symbol name
# kind:         what kind of symbol this is (SYM_* constant)
# type_node:    AST node for the symbol's type (or nil)
# decl_node:    AST node where this symbol was declared
# resolved_type: resolved Type after semantic analysis (or nil)
# is_public:    true if exported from module
# is_mutable:   true for var, false for val
# is_generic:   true if this is a generic declaration (has type parameters)
# generic_node: AST node containing generic parameters (NODE_GENERIC)
# scope:        owning scope (for nested lookup)
pub rec Symbol {
    name:           str;
    kind:           SymbolKind;
    type_node:      *ast.Node;
    decl_node:      *ast.Node;
    resolved_type:  *ty.Type;
    module_path:    str;      # module path where symbol is defined (for cross-module resolution)
    export_name:    str;      # optional linkage name override
    is_public:      bool;
    is_mutable:     bool;
    is_being_resolved: bool;  # true while type is being resolved (cycle detection)
    is_generic:     bool;     # true if this is a generic declaration
    generic_node:   *ast.Node; # NODE_GENERIC node with type params (or nil)
    scope:          *Scope;
}

# Scope: a lexical scope containing symbols.
# ---
# parent:       enclosing scope (or nil for module scope)
# symbols:      array of symbols in this scope
# symbol_count: number of symbols
# symbol_cap:   allocated capacity
pub rec Scope {
    parent:       *Scope;
    symbols:      *Symbol;
    symbol_count: i32;
    symbol_cap:   i32;
}

# Table: a symbol table managing multiple scopes.
# ---
# alloc:   allocator for symbols and scopes
# current: current active scope
# root:    root (module) scope
pub rec Table {
    alloc:   *allocator.Allocator;
    current: *Scope;
    root:    *Scope;
}

# init: create a new symbol table.
# ---
# alloc: allocator to use for symbols and scopes
# ret:   Ok(Table) on success, Err(str) on failure
pub fun init(alloc: *allocator.Allocator) Result[Table, str] {
    if (alloc == nil) {
        ret err[Table, str]("allocator is nil");
    }

    # create root scope
    val scope_res: Result[*Scope, allocator.AllocError] = allocator.allocator_zalloc[Scope](alloc, 1);
    if (result_is_err[*Scope, allocator.AllocError](scope_res)) {
        ret err[Table, str](result_unwrap_err[*Scope, allocator.AllocError](scope_res));
    }

    val root: *Scope = result_unwrap_ok[*Scope, allocator.AllocError](scope_res);
    root.parent = nil;
    root.symbols = nil;
    root.symbol_count = 0;
    root.symbol_cap = 0;

    var table: Table;
    table.alloc = alloc;
    table.current = root;
    table.root = root;

    ret ok[Table, str](table);
}

# dnit: free all resources associated with a symbol table.
# ---
# ret: none
pub fun table_dnit(this: *Table) {
    if (this == nil || this.alloc == nil) {
        ret;
    }

    # walk the scope chain from current back to root, freeing each scope
    var scope: *Scope = this.current;
    for (scope != nil) {
        val parent: *Scope = scope.parent;

        # free the symbols array for this scope
        if (scope.symbols != nil && scope.symbol_cap > 0) {
            allocator.allocator_free[Symbol](this.alloc, scope.symbols, scope.symbol_cap::usize);
        }

        # free the scope struct itself
        allocator.allocator_free[Scope](this.alloc, scope, 1);

        scope = parent;
    }

    this.current = nil;
    this.root = nil;
}

# push_scope: enter a new nested scope.
# ---
# ret: Ok(true) on success, Err(str) on failure
pub fun table_push_scope(this: *Table) Result[bool, str] {
    if (this == nil) {
        ret err[bool, str]("table is nil");
    }

    if (this.alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    val scope_res: Result[*Scope, allocator.AllocError] = allocator.allocator_zalloc[Scope](this.alloc, 1);
    if (result_is_err[*Scope, allocator.AllocError](scope_res)) {
        ret err[bool, str](result_unwrap_err[*Scope, allocator.AllocError](scope_res));
    }

    val scope: *Scope = result_unwrap_ok[*Scope, allocator.AllocError](scope_res);
    scope.parent = this.current;
    scope.symbols = nil;
    scope.symbol_count = 0;
    scope.symbol_cap = 0;

    this.current = scope;
    ret ok[bool, str](true);
}

# pop_scope: exit the current scope and return to the parent.
# ---
# ret: Ok(true) on success, Err(str) if at root scope
pub fun table_pop_scope(this: *Table) Result[bool, str] {
    if (this == nil) {
        ret err[bool, str]("table is nil");
    }

    if (this.current == nil || this.current.parent == nil) {
        ret err[bool, str]("cannot pop root scope");
    }

    this.current = this.current.parent;
    ret ok[bool, str](true);
}

# define: add a symbol to the current scope.
# ---
# name: symbol name
# kind: symbol kind (SYM_* constant)
# ret:  Ok(*Symbol) on success, Err(str) if already defined or allocation fails
pub fun table_define(this: *Table, name: str, kind: SymbolKind) Result[*Symbol, str] {
    if (this == nil) {
        ret err[*Symbol, str]("table is nil");
    }

    if (this.current == nil) {
        ret err[*Symbol, str]("no current scope");
    }

    if (this.alloc == nil) {
        ret err[*Symbol, str]("allocator is nil");
    }

    # check for duplicate in current scope
    val existing: Option[*Symbol] = scope_lookup_local(this.current, name);
    if (option_is_some[*Symbol](existing)) {
        ret err[*Symbol, str]("symbol already defined in scope");
    }

    # grow symbols array if needed
    if (this.current.symbol_count >= this.current.symbol_cap) {
        var new_cap: i32 = 8;
        if (this.current.symbol_cap > 0) {
            new_cap = this.current.symbol_cap * 2;
        }

        val old_cap_usize: usize = this.current.symbol_cap::usize;
        val new_cap_usize: usize = new_cap::usize;

        val r: Result[*Symbol, allocator.AllocError] = allocator.allocator_resize[Symbol](
            this.alloc,
            this.current.symbols,
            old_cap_usize,
            new_cap_usize
        );

        if (result_is_err[*Symbol, allocator.AllocError](r)) {
            ret err[*Symbol, str](result_unwrap_err[*Symbol, allocator.AllocError](r));
        }

        this.current.symbols = result_unwrap_ok[*Symbol, allocator.AllocError](r);
        this.current.symbol_cap = new_cap;
    }

    # add symbol
    val idx: i32 = this.current.symbol_count;
    val symbols_base: *Symbol = this.current.symbols;

    if (symbols_base == nil) {
        ret err[*Symbol, str]("symbols array is nil");
    }

    val idx_usize: usize = idx::usize;
    val sym: *Symbol = ?symbols_base[idx_usize];

    if (sym == nil) {
        ret err[*Symbol, str]("computed symbol pointer is nil");
    }

    sym.name = name;
    sym.kind = kind;
    sym.type_node = nil;
    sym.decl_node = nil;
    sym.resolved_type = nil;
    sym.export_name = nil;
    sym.is_public = false;
    sym.is_mutable = kind == SYM_VAR;
    sym.scope = this.current;

    this.current.symbol_count = this.current.symbol_count + 1;

    ret ok[*Symbol, str](sym);
}

# kind_name: get a string representation of a symbol kind.
# ---
# kind: symbol kind tag
# ret:  string name of the kind
pub fun kind_name(kind: SymbolKind) str {
    if (kind == SYM_VAL)     { ret "val"; }
    if (kind == SYM_VAR)     { ret "var"; }
    if (kind == SYM_FUN)     { ret "function"; }
    if (kind == SYM_TYPE)    { ret "type"; }
    if (kind == SYM_REC)     { ret "record"; }
    if (kind == SYM_UNI)     { ret "union"; }
    if (kind == SYM_FIELD)   { ret "field"; }
    if (kind == SYM_PARAM)   { ret "parameter"; }
    if (kind == SYM_EXT)     { ret "external"; }
    if (kind == SYM_MODULE)  { ret "module"; }
    if (kind == SYM_GENERIC) { ret "generic"; }
    ret "unknown";
}

# is_type_symbol: check if this symbol represents a type.
# ---
# ret: true if symbol is a type
pub fun symbol_is_type_symbol(this: &Symbol) bool {
    if (this == nil) {
        ret false;
    }
    ret this.kind == SYM_TYPE || this.kind == SYM_REC || this.kind == SYM_UNI || this.kind == SYM_GENERIC;
}

# is_value_symbol: check if this symbol represents a value (variable/constant).
# ---
# ret: true if symbol is a value
pub fun symbol_is_value_symbol(this: &Symbol) bool {
    if (this == nil) {
        ret false;
    }
    ret this.kind == SYM_VAL || this.kind == SYM_VAR || this.kind == SYM_PARAM;
}

# is_callable: check if this symbol can be called as a function.
# ---
# ret: true if symbol is callable
pub fun symbol_is_callable(this: &Symbol) bool {
    if (this == nil) {
        ret false;
    }
    ret this.kind == SYM_FUN || this.kind == SYM_EXT;
}

# lookup: find a symbol by name, searching up through parent scopes.
# ---
# name: symbol name to find
# ret:  Some(*Symbol) if found, None if not found
pub fun table_lookup(this: &Table, name: str) Option[*Symbol] {
    if (this == nil || this.current == nil) {
        ret none[*Symbol]();
    }

    var scope: *Scope = this.current;
    for (scope != nil) {
        val result: Option[*Symbol] = scope_lookup_local(scope, name);
        if (option_is_some[*Symbol](result)) {
            ret result;
        }
        scope = scope.parent;
    }

    ret none[*Symbol]();
}

# lookup_local: find a symbol in this scope only (no parent search).
# ---
# name: symbol name to find
# ret:  Some(*Symbol) if found, None if not found
pub fun scope_lookup_local(this: &Scope, name: str) Option[*Symbol] {
    if (this == nil || this.symbols == nil || name == nil) {
        ret none[*Symbol]();
    }

    var i: i32 = 0;
    # NOTE: using explicit pointer arithmetic to work around codegen bug
    val symbols_base: *Symbol = this.symbols;
    for (i < this.symbol_count) {
        val i_usize: usize = i::usize;
        val sym: *Symbol = ?symbols_base[i_usize];
        if (sym.name != nil && str_equals(sym.name, name)) {
            ret some[*Symbol](sym);
        }
        i = i + 1;
    }

    ret none[*Symbol]();
}

# scope_depth: get the current scope depth (0 = root).
# ---
# ret: number of scopes from root to current
pub fun table_scope_depth(this: &Table) i32 {
    if (this == nil) {
        ret 0;
    }
    var depth: i32 = 0;
    var scope: *Scope = this.current;
    for (scope != nil && scope != this.root) {
        depth = depth + 1;
        scope = scope.parent;
    }
    ret depth;
}

# current_scope: get the current scope.
# ---
# ret: current scope or nil
pub fun table_current_scope(this: &Table) *Scope {
    if (this == nil) {
        ret nil;
    }
    ret this.current;
}

# root_scope: get the root (module) scope.
# ---
# ret: root scope or nil
pub fun table_root_scope(this: &Table) *Scope {
    if (this == nil) {
        ret nil;
    }
    ret this.root;
}
