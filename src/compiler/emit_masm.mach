use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use fs:     std.filesystem;
use stream: std.stream;
use fmt:    std.fmt;

use masm: mach.compiler.masm;
use ir:   mach.compiler.masm.ir;

# mach.compiler.emit_masm: emit target-independent IR as text.
# ---
# writes a .masm file containing a human-readable representation
# of the IR for all functions in a MASM context.

# emit: write all IR functions from mctx to output_path as text.
pub fun emit(mctx: *masm.Context, output_path: str) i64 {
    if (mctx == nil || output_path == nil) { ret -1; }

    val f_res: Result[fs.File, str] = fs.create(output_path, 438);
    if (result_is_err[fs.File, str](f_res)) { ret -1; }

    var f: fs.File = result_unwrap_ok[fs.File, str](f_res);
    var w: stream.Writer = stream.writer(f.fd);

    var fi: i32 = 0;
    for (fi < mctx.ir_func_count) {
        val func: *ir.Function = mctx.ir_funcs[fi];
        if (func != nil) {
            emit_function(?w, func);
        }
        fi = fi + 1;
    }

    fs.file_close(?f);
    ret 0;
}

# emit_function: write a single IR function.
fun emit_function(w: *stream.Writer, func: *ir.Function) {
    if (func == nil) { ret; }

    # function header
    fmt.write_str(w, "fn ");
    fmt.write_str(w, func.name);
    fmt.write_str(w, ":\n");

    var bi: i32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = func.blocks[bi];
        if (block != nil) {
            emit_block(w, block);
        }
        bi = bi + 1;
    }

    fmt.write_newline(w);
}

# emit_block: write a single basic block.
fun emit_block(w: *stream.Writer, block: *ir.Block) {
    if (block == nil) { ret; }

    # block label
    fmt.write_str(w, "  ");
    if (block.label != nil) {
        fmt.write_str(w, block.label);
    } or {
        fmt.write_str(w, ".block");
    }
    fmt.write_str(w, ":\n");

    var ii: i32 = 0;
    for (ii < block.inst_count) {
        emit_inst(w, ?block.insts[ii]);
        ii = ii + 1;
    }
}

# emit_inst: write a single IR instruction.
fun emit_inst(w: *stream.Writer, inst: *ir.Inst) {
    if (inst == nil) { ret; }

    fmt.write_str(w, "    ");

    # opcode name
    fmt.write_str(w, ir.op_name(inst.op));

    # condition code suffix
    if (inst.cc != ir.CC_NONE) {
        fmt.write_str(w, ".");
        fmt.write_str(w, ir.cc_name(inst.cc));
    }

    # size suffix
    if (inst.size > 0) {
        fmt.write_str(w, ".");
        fmt.write_u64(w, inst.size::u64);
    }

    # operands
    var has_op: bool = false;

    if (inst.dst.kind != ir.OPK_NONE) {
        fmt.write_str(w, " ");
        emit_operand(w, ?inst.dst);
        has_op = true;
    }

    if (inst.src1.kind != ir.OPK_NONE) {
        if (has_op) { fmt.write_str(w, ", "); }
        or { fmt.write_str(w, " "); }
        emit_operand(w, ?inst.src1);
        has_op = true;
    }

    if (inst.src2.kind != ir.OPK_NONE) {
        if (has_op) { fmt.write_str(w, ", "); }
        or { fmt.write_str(w, " "); }
        emit_operand(w, ?inst.src2);
    }

    fmt.write_newline(w);
}

# emit_operand: write a single IR operand.
fun emit_operand(w: *stream.Writer, op: *ir.Operand) {
    if (op == nil) { ret; }

    if (op.kind == ir.OPK_REG) {
        emit_reg_name(w, op.reg);
    }
    or (op.kind == ir.OPK_IMM) {
        fmt.write_i64(w, op.imm);
    }
    or (op.kind == ir.OPK_MEM) {
        fmt.write_str(w, "[");
        emit_reg_name(w, op.base);
        if (op.index >= 0) {
            fmt.write_str(w, " + ");
            emit_reg_name(w, op.index);
            if (op.scale > 1) {
                fmt.write_str(w, "*");
                fmt.write_u64(w, op.scale::u64);
            }
        }
        if (op.disp > 0) {
            fmt.write_str(w, " + ");
            fmt.write_i64(w, op.disp);
        } or (op.disp < 0) {
            fmt.write_str(w, " - ");
            fmt.write_i64(w, -op.disp);
        }
        fmt.write_str(w, "]");
    }
    or (op.kind == ir.OPK_LABEL) {
        if (op.label != nil) {
            fmt.write_str(w, op.label);
        } or {
            fmt.write_str(w, "<nil>");
        }
    }
    or (op.kind == ir.OPK_SYM) {
        fmt.write_str(w, "sym(");
        fmt.write_u64(w, op.sym_id);
        fmt.write_str(w, ")");
    }
}

# emit_reg_name: write a register name for IR display.
fun emit_reg_name(w: *stream.Writer, reg: i32) {
    if (reg == ir.VREG_FP) {
        fmt.write_str(w, "$fp");
    }
    or (reg == ir.VREG_SP) {
        fmt.write_str(w, "$sp");
    }
    or (ir.is_vreg(reg)) {
        fmt.write_str(w, "v");
        fmt.write_u64(w, (reg - ir.VREG_START)::u64);
    }
    or {
        fmt.write_str(w, "p");
        fmt.write_u64(w, reg::u64);
    }
}
