# mach.compiler.session: compilation session and shared state
#
# owns all compilation state: diagnostics, module table, symbol table, type
# table, monomorphization cache, and target. the string pool interns strings
# by pointer with dedup via hash map, so repeated lookups return the same
# pointer without additional allocation.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use map:       std.collections.map;
use page:      std.allocator.page;

use diag:    mach.compiler.diag;
use module:  mach.compiler.sema.module;
use scope:   mach.compiler.sema.scope;
use type:    mach.compiler.sema.type;
use mono:    mach.compiler.sema.mono;
use sema:    mach.compiler.sema.sema;
use resolve: mach.compiler.sema.resolve;
use check:   mach.compiler.sema.check;
use st:      mach.compiler.sema.sidetable;
use ast:     mach.compiler.parse.ast;
use lower:   mach.compiler.lower.lower;
use lctx:    mach.compiler.lower.ctx;
use codegen: mach.compiler.codegen;
use linker:  mach.compiler.linker;
use target:  mach.compiler.target.target;
use of:      mach.compiler.target.of;
use pass:    mach.compiler.opt.pass;
use masm_mod: masm.module;
use masm.function;
use masm_fn:  masm.function;
use masm.op;
use masm_op:  masm.op;
use path:     std.types.path;
use print:    std.print;
use fs:       std.filesystem;

# options controlling compilation behavior
# ---
# release:   enable release-mode optimizations
# emit_masm: dump MASM IR to files
# emit_asm:  dump final assembly to files
# verbose:   enable verbose diagnostic output
# verify_ir: run IR verification passes
# opt_level: optimization level (0-3)
# jobs:      number of parallel compilation jobs
pub rec CompileOpts {
    release:   bool;
    emit_masm: bool;
    emit_asm:  bool;
    verbose:   bool;
    verify_ir: bool;
    opt_level: u8;
    jobs:      u32;
}

# result of a compilation run
# ---
# ok:        true if compilation succeeded
# obj_paths: array of emitted object file paths
# obj_count: number of object files
# binary:    path to the linked binary (or nil)
pub rec CompileResult {
    ok:        bool;
    obj_paths: *str;
    obj_count: i32;
    binary:    str;
}

# deduplicated string pool backed by a hash map
# ---
# alloc:   backing allocator
# strings: flat array of interned string pointers
# count:   number of strings in the pool
# cap:     allocated capacity of the strings array
# dedup:   map from string content to pool index
pub rec StringPool {
    alloc:   &allocator.Allocator;
    strings: *str;
    count:   u32;
    cap:     u32;
    dedup:   map.Map[str, u32];
}

# top-level compilation session
# ---
# alloc:   backing allocator
# strings: shared string pool
# diag:    diagnostic list
# modules: module table
# symbols: symbol table
# types:   type table
# mono:    monomorphization cache
# target:  resolved compilation target
# opts:    compilation options
pub rec Session {
    alloc:   *allocator.Allocator;
    strings: StringPool;
    diag:    diag.DiagList;
    modules: module.ModuleTable;
    symbols: scope.SymbolTable;
    types:   type.TypeTable;
    mono:    mono.MonoCache;
    target:  *target.Target;
    opts:    CompileOpts;
}

# init: create a new compilation session.
# ---
# alloc:    allocator for all session-owned storage
# opts:     compilation options
# ptr_size: pointer size in bytes for the target
# ret:      initialized Session
pub fun init(alloc: *allocator.Allocator, opts: CompileOpts, ptr_size: u32) Session {
    var s: Session;
    s.alloc  = alloc;
    s.opts   = opts;
    s.target = nil;

    s.strings.alloc   = alloc;
    s.strings.strings = nil;
    s.strings.count   = 0;
    s.strings.cap     = 0;
    s.strings.dedup   = map.init[str, u32](alloc, map.hash_str, map.eq_str);

    s.diag    = diag.init(alloc);
    s.modules = module.init(alloc);
    s.symbols = scope.init(alloc);
    s.types   = type.init(alloc, ptr_size, ptr_size);
    s.mono    = mono.init(alloc);

    ret s;
}

# dnit: destroy a session, freeing all owned storage.
# ---
# s: session to destroy
pub fun dnit(s: *Session) {
    if (s == nil) { ret; }

    mono.dnit(?s.mono);
    scope.dnit(?s.symbols);
    type.dnit(?s.types);
    module.dnit(?s.modules);
    diag.dnit(?s.diag);

    if (s.strings.strings != nil && s.strings.cap > 0) {
        allocator.deallocate[str](s.strings.alloc, s.strings.strings, s.strings.cap::usize);
        s.strings.strings = nil;
    }
    s.strings.count = 0;
    s.strings.cap   = 0;

    map.dnit[str, u32](?s.strings.dedup);
}

# pool_intern: intern a string into the pool, returning the canonical pointer.
#
# if the string was already interned, returns the existing pointer without
# allocating. otherwise appends it to the pool and records it in the dedup
# map.
# ---
# pool: string pool to intern into
# text: string to intern
# ret:  the canonical interned pointer for this string
pub fun pool_intern(pool: *StringPool, text: str) str {
    val key: str = text;
    val res_get: Result[*u32, str] = map.get[str, u32](?pool.dedup, ?key);
    if (is_ok[*u32, str](res_get)) {
        val idx: u32 = @unwrap_ok[*u32, str](res_get);
        ret pool.strings[idx];
    }

    if (pool.count >= pool.cap) {
        var new_cap: u32 = 64;
        if (pool.cap > 0) {
            new_cap = pool.cap * 2;
        }

        val res_reallocate: Result[*str, str] = allocator.reallocate[str](
            pool.alloc, pool.strings, pool.cap::usize, new_cap::usize
        );
        if (is_err[*str, str](res_reallocate)) {
            ret text;
        }

        pool.strings = unwrap_ok[*str, str](res_reallocate);
        pool.cap = new_cap;
    }

    val idx: u32 = pool.count;
    pool.strings[idx] = text;
    pool.count = pool.count + 1;

    map.insert[str, u32](?pool.dedup, text, idx);

    ret text;
}

# default_opts: return default compilation options.
#
# all flags are false/zero except verify_ir which defaults to true.
# ---
# ret: default CompileOpts
pub fun default_opts() CompileOpts {
    var opts: CompileOpts;
    opts.release   = false;
    opts.emit_masm = false;
    opts.emit_asm  = false;
    opts.verbose   = false;
    opts.verify_ir = true;
    opts.opt_level = 0;
    opts.jobs      = 0;
    ret opts;
}

# load: load a root module and its dependency graph into the session.
# ---
# s:          session
# root_path:  dot-separated module path for the root
# file_path:  filesystem path to the root source file
# source:     source text of the root file
# src_dir:    source root directory
# dep_dir:    dependency root directory
# project_id: project identifier string
# deps:       dependency mappings (project_id → dir_name + dir_src)
# dep_count:  number of dependency mappings
pub fun load(s: *Session, root_path: str, file_path: str, source: str,
             src_dir: str, dep_dir: str, project_id: str,
             deps: *module.DepMapping, dep_count: u32) {
    val root_id: module.ModuleId = module.create(?s.modules, root_path, file_path, source);
    if (root_id::u32 == module.MOD_NIL::u32) { ret; }
    module.load_graph(?s.modules, root_id, src_dir, dep_dir, project_id, deps, dep_count);
}

# analyze: run all four semantic analysis phases.
# ---
# s: session
pub fun analyze(s: *Session) {
    var sa: sema.Sema;
    sa.alloc   = s.alloc;
    sa.modules = ?s.modules;
    sa.symbols = ?s.symbols;
    sa.types   = ?s.types;
    sa.mono    = ?s.mono;
    sa.diag    = ?s.diag;
    sa.strings = ?s.strings;

    resolve.collect_all(?sa);
    if (diag.had_errors(?s.diag)) { ret; }

    resolve.resolve_all(?sa);
    if (diag.had_errors(?s.diag)) { ret; }

    check.resolve_bodies(?sa);
    check.resolve_instantiation_bodies(?sa);
    if (diag.had_errors(?s.diag)) { ret; }

    check.check_all(?sa);
}

# lower_all: lower all modules in topological order into MASM IR.
# ---
# s:       session
# builder: masm module builder to populate
pub fun lower_all(s: *Session, builder: *masm_mod.ModuleBuilder) {
    var sa: sema.Sema;
    sa.alloc   = s.alloc;
    sa.modules = ?s.modules;
    sa.symbols = ?s.symbols;
    sa.types   = ?s.types;
    sa.mono    = ?s.mono;
    sa.diag    = ?s.diag;
    sa.strings = ?s.strings;

    val res_lower: Result[lctx.LowerContext, str] = lower.init(
        s.alloc, s.target::ptr, builder, ?sa
    );
    if (is_err[lctx.LowerContext, str](res_lower)) { ret; }
    var lower_ctx: lctx.LowerContext = unwrap_ok[lctx.LowerContext, str](res_lower);

    var i: u32 = 0;
    for (i < module.order_count(?s.modules)) {
        val mod_id: module.ModuleId = module.order_at(?s.modules, i);
        lower.lower_module(?lower_ctx, mod_id);
        i = i + 1;
    }

    lower.dnit(?lower_ctx);
}

# compile: compile all functions in an IR module through the backend.
# ---
# s:         session
# ir_module: masm module containing lowered functions
# ret:       compilation result
pub fun compile(s: *Session, ir_module: *masm_mod.Module, artifacts_dir: str) CompileResult {
    var result: CompileResult;
    result.ok        = false;
    result.obj_paths = nil;
    result.obj_count = 0;
    result.binary    = nil;

    if (s.target == nil) { ret result; }

    val add_section_fn: fun(ptr, str, u8, u32, usize) i32 = s.target.of.obj.add_section;
    if (add_section_fn == nil) { ret result; }

    val text_idx: i32 = add_section_fn(s.target.of.obj.ctx, ".text", of.SK_TEXT::u8, 6, 16);
    if (text_idx < 0) { ret result; }

    var pipeline: pass.PassPipeline = pass.default_pipeline(s.alloc, s.opts.opt_level);

    var compile_ok: bool = true;
    var fi: usize = 0;
    for (fi < ir_module.functions.len) {
        val fn_ptr: ptr = ir_module.functions.data[fi]::ptr;
        if (fn_ptr != nil) {
            val cg_result: codegen.CodegenResult = codegen.compile_function(
                ir_module.functions.data[fi], 0, s.target, ?pipeline, s.alloc, ?s.target.of.obj
            );
            if (!cg_result.ok) {
                compile_ok = false;
            }
        }
        fi = fi + 1;
    }

    # finalize debug info into the object writer
    val debug_finalize: fun(ptr, *of.ObjWriter) bool = s.target.of.debug.finalize;
    if (debug_finalize != nil && s.target.of.debug.ctx != nil) {
        debug_finalize(s.target.of.debug.ctx, ?s.target.of.obj);
    }

    var art_dir: str = artifacts_dir;
    if (art_dir == nil) { art_dir = "out"; }

    val res_obj_dir: Result[path.Path, str] = path.join(s.alloc, art_dir, "obj");
    var obj_dir: str = art_dir;
    if (is_ok[path.Path, str](res_obj_dir)) {
        obj_dir = unwrap_ok[path.Path, str](res_obj_dir);
    }
    if (!fs.is_dir(obj_dir)) {
        fs.create_dir_all(s.alloc, obj_dir, 0o755);
    }

    val res_obj_path: Result[path.Path, str] = path.join(s.alloc, obj_dir, "mach.o");
    var obj_path: str = "mach.o";
    if (is_ok[path.Path, str](res_obj_path)) {
        obj_path = unwrap_ok[path.Path, str](res_obj_path);
    }

    val finalize_fn: fun(ptr, str) bool = s.target.of.obj.finalize;
    if (finalize_fn != nil) {
        val fin_ok: bool = finalize_fn(s.target.of.obj.ctx, obj_path);
        if (fin_ok) {
            val res_paths: Result[*str, str] = allocator.allocate[str](s.alloc, 1);
            if (is_ok[*str, str](res_paths)) {
                result.obj_paths = unwrap_ok[*str, str](res_paths);
                result.obj_paths[0] = obj_path;
                result.obj_count = 1;
            }
        }
    }

    if (s.opts.emit_masm) {
        val res_masm_dir: Result[path.Path, str] = path.join(s.alloc, art_dir, "masm");
        if (is_ok[path.Path, str](res_masm_dir)) {
            val masm_dir: str = unwrap_ok[path.Path, str](res_masm_dir);
            if (!fs.is_dir(masm_dir)) {
                fs.create_dir_all(s.alloc, masm_dir, 0o755);
            }
            emit_masm_files(s, ir_module, masm_dir);
        }
    }

    if (s.opts.emit_asm) {
        val res_asm_dir: Result[path.Path, str] = path.join(s.alloc, art_dir, "asm");
        if (is_ok[path.Path, str](res_asm_dir)) {
            val asm_dir: str = unwrap_ok[path.Path, str](res_asm_dir);
            if (!fs.is_dir(asm_dir)) {
                fs.create_dir_all(s.alloc, asm_dir, 0o755);
            }
        }
    }

    pass.dnit(?pipeline);
    result.ok = true;
    ret result;
}

# link_all: link object files into a final binary.
# ---
# s:           session
# obj_paths:   array of object file paths
# obj_count:   number of object files
# output_path: path for the output binary
# ret:         link result
pub fun link_all(s: *Session, obj_paths: *str, obj_count: i32, output_path: str) linker.LinkResult {
    ret linker.link(s.alloc, obj_paths, obj_count, output_path, s.target);
}

# diagnostics: return a read-only reference to the session's diagnostic list.
# ---
# s:   session
# ret: reference to the diagnostic list
pub fun diagnostics(s: &Session) &diag.DiagList {
    ret ?s.diag;
}

# get_type: look up a type by id.
# ---
# s:  session
# id: type id
# ret: reference to the type
pub fun get_type(s: &Session, id: type.TypeId) &type.Type {
    ret type.get(?s.types, id);
}

# get_symbol: look up a symbol by id.
# ---
# s:  session
# id: symbol id
# ret: reference to the symbol
pub fun get_symbol(s: &Session, id: scope.SymbolId) &scope.Symbol {
    ret scope.get_sym(?s.symbols, id);
}

# node_type: get the resolved type for an AST node in a module.
# ---
# s:       session
# mod_id:  module containing the node
# node_id: AST node id
# ret:     resolved TypeId, or TYPE_NIL if not set
pub fun node_type(s: &Session, mod_id: module.ModuleId, node_id: ast.NodeId) type.TypeId {
    val m: &module.Module = module.get(?s.modules, mod_id);
    ret st.get_type(?m.expr_types, node_id);
}

test "session: pool_intern deduplicates strings" {
    var a: allocator.Allocator;
    page.make(?a);

    var s: Session = init(?a, default_opts(), 8);

    val first:  str = pool_intern(?s.strings, "hello");
    val second: str = pool_intern(?s.strings, "hello");

    if (first::usize != second::usize) { ret 0; }
    if (s.strings.count != 1) { ret 0; }

    val other: str = pool_intern(?s.strings, "world");
    if (s.strings.count != 2) { ret 0; }
    if (first::usize == other::usize) { ret 0; }

    dnit(?s);
    ret 1;
}

fun emit_masm_files(s: *Session, ir_module: *masm_mod.Module, masm_dir: str) {
    val res_path: Result[path.Path, str] = path.join(s.alloc, masm_dir, "module.masm");
    if (is_err[path.Path, str](res_path)) { ret; }
    val out_path: str = unwrap_ok[path.Path, str](res_path);

    val res_file: Result[fs.File, str] = fs.create(out_path, 0o644);
    if (is_err[fs.File, str](res_file)) { ret; }
    var f: fs.File = unwrap_ok[fs.File, str](res_file);

    var fi: usize = 0;
    for (fi < ir_module.functions.len) {
        val fn_ptr: *masm_fn.Function = ir_module.functions.data[fi];
        if (fn_ptr != nil && fn_ptr.name != nil) {
            var hdr: [256]u8;
            hdr[0] = 'f'; hdr[1] = 'n'; hdr[2] = ' ';
            var pos: usize = 3;
            var ni: usize = 0;
            for (fn_ptr.name[ni] != 0 && pos < 250) {
                hdr[pos] = fn_ptr.name[ni];
                pos = pos + 1;
                ni = ni + 1;
            }
            hdr[pos] = '\n'; pos = pos + 1;
            fs.write(?f, ?hdr[0], pos);

            var bi: usize = 0;
            for (bi < fn_ptr.blocks.len) {
                val blk: *masm_fn.Block = fn_ptr.blocks.data[bi];
                if (blk != nil) {
                    var ii: i32 = 0;
                    for (ii < blk.inst_count) {
                        val opn: str = op_name(blk.insts[ii].op);
                        if (opn != nil) {
                            var line: [128]u8;
                            line[0] = ' '; line[1] = ' ';
                            var lp: usize = 2;
                            var oi: usize = 0;
                            for (opn[oi] != 0 && lp < 120) {
                                line[lp] = opn[oi];
                                lp = lp + 1;
                                oi = oi + 1;
                            }
                            line[lp] = '\n'; lp = lp + 1;
                            fs.write(?f, ?line[0], lp);
                        }
                        ii = ii + 1;
                    }
                }
                bi = bi + 1;
            }
        }
        fi = fi + 1;
    }

    fs.close(?f);
}
