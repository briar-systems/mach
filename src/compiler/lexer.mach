use std.types.size;
use std.types.result;
use std.types.string;
use std.types.bool;
use ascii: std.text.ascii;
use pmem: std.system.platform.memory;

use token: mach.compiler.token;

pub rec Lexer {
    source: str;
    pos: usize;
    source_len: usize;
}

pub fun init(this: *Lexer, source: str) {
    if (this == nil) { ret; }
    this.source = source;
    this.pos = 0;
    if (source == nil) {
        this.source_len = 0;
    }
    or {
        this.source_len = this.source.len();
    }
}

fun token_error_kind() i32 {
    # avoid relying on negative global constants; the bootstrap toolchain
    # currently misinitializes some negative `pub val` values.
    var k: i32 = 0;
    k = k - 1;
    ret k;
}

fun is_space_char(c: char) bool {
    # avoid std.text.ascii.is_space: the bootstrap toolchain currently miscompiles
    # long `||` chains. implement whitespace check with simple branches.
    if (c == ' ') { ret true; }
    if (c >= 9 && c <= 13) { ret true; }
    ret false;
}

fun at_end(this: *Lexer) bool {
    if (this == nil) { ret true; }
    if (this.source == nil) { ret true; }
    val s: str = this.source;
    if (this.pos >= this.source_len) { ret true; }
    ret s[this.pos] == 0;
}

fun current(this: *Lexer) char {
    if (this == nil) { ret 0; }
    if (this.source == nil) { ret 0; }
    val s: str = this.source;
    if (this.pos >= this.source_len) { ret 0; }
    ret s[this.pos];
}

fun peek(this: *Lexer, offset: usize) char {
    if (this == nil) { ret 0; }
    if (this.source == nil) { ret 0; }
    val s: str = this.source;
    val i: usize = this.pos + offset;
    if (i >= this.source_len) { ret 0; }
    ret s[i];
}

fun advance(this: *Lexer) {
    if (this == nil) { ret; }
    if (this.source == nil) { ret; }
    val s: str = this.source;
    if (this.pos < this.source_len) { this.pos = this.pos + 1; }
}

# helpers to compute line/col and extract line text for diagnostics
pub fun get_pos_line(this: *Lexer, pos: usize) usize {
    if (this == nil) { ret 0; }
    if (this.source == nil) { ret 0; }
    val s: str = this.source;
    var line: usize = 0;
    var i: usize = 0;
    for (i < pos && i < this.source_len) {
        if (s[i] == '\n') { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

pub fun get_pos_line_offset(this: *Lexer, pos: usize) usize {
    if (this == nil) { ret 0; }
    if (this.source == nil) { ret 0; }
    val s: str = this.source;
    var offset: usize = 0;
    var i: usize = 0;
    for (i < pos && i < this.source_len) {
        if (s[i] == '\n') { offset = 0; }
        or { offset = offset + 1; }
        i = i + 1;
    }
    ret offset;
}

pub fun get_line_text(this: *Lexer, line: usize) str {
    if (this == nil) { ret ""; }
    if (this.source == nil) { ret ""; }
    val s: str = this.source;

    var line_start: usize = 0;
    var current_line: usize = 0;
    for (current_line < line && line_start < this.source_len) {
        if (s[line_start] == '\n') {
            current_line = current_line + 1;
        }
        line_start = line_start + 1;
    }

    if (line_start >= this.source_len) { ret ""; }

    var line_end: usize = line_start;
    for (line_end < this.source_len && s[line_end] != '\n' && s[line_end] != 0) {
        line_end = line_end + 1;
    }

    val line_len: usize = line_end - line_start;
    if (line_len == 0) { ret ""; }

    val p: ptr = pmem.allocate(line_len + 1);
    if (p == nil) { ret ""; }
    val buf: ptr = p;
    var dst: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < line_len) {
        dst[i] = s[line_start + i];
        i = i + 1;
    }
    dst[line_len] = 0;

    ret buf::str;
}

# parse type suffixes: i8/i16/i32/i64, u8/u16/u32/u64, f32/f64
fun parse_type_suffix(this: *Lexer) str {
    if (this == nil) { ret nil; }
    if (this.source == nil) { ret nil; }
    val s: str = this.source;
    val start: usize = this.pos;
    val c: char = current(this);
    if (c != 'i' && c != 'u' && c != 'f') { ret nil; }

    advance(this);
    val width_start: usize = this.pos;
    for (this.pos < this.source_len && ascii.is_digit(current(this))) {
        advance(this);
    }

    val width_len: usize = this.pos - width_start;
    if (width_len == 0) {
        this.pos = start;
        ret nil;
    }

    val suff_len: usize = this.pos - start;
    val p: ptr = pmem.allocate(suff_len + 1);
    if (p == nil) { this.pos = start; ret nil; }
    val buf: ptr = p;
    var bytes: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < suff_len) {
        bytes[i] = s[start + i];
        i = i + 1;
    }
    bytes[suff_len] = 0;

    val suff: str = buf::str;
    if (suff == "u8" || suff == "u16" || suff == "u32" || suff == "u64" || suff == "i8" || suff == "i16" || suff == "i32" || suff == "i64" || suff == "f32" || suff == "f64") {
        ret suff;
    }

    this.pos = start;
    ret nil;
}

fun token_set(t: *token.Token, kind: i32, pos: usize, len: usize) {
    if (t == nil) { ret; }
    token.token_init(t, kind, pos, len);
} 

fun emit_at(this: *Lexer, out: *token.Token, kind: i32, start: usize, len: usize) {
    token_set(out, kind, start, len);
    this.pos = start + len;
    ret;
}

fun parse_identifier(this: *Lexer, out: *token.Token) {
    if (out == nil) { ret; }
    val start: usize = this.pos;
    for (!at_end(this) && (ascii.is_alnum(current(this)) || current(this) == '_')) {
        advance(this);
    }
    val len: usize = this.pos - start;

    val kind: i32 = token.kind_from_identifier(this.source, start, len);
    token_set(out, kind, start, len);
    ret;
}

fun parse_number(this: *Lexer, out: *token.Token) {
    if (out == nil) { ret; }
    val start: usize = this.pos;

    if (current(this) == '0') {
        val p: char = peek(this, 1);
        if (p == 'x' || p == 'X') {
            advance(this); advance(this);
            for (!at_end(this) && ((ascii.digit_val(current(this)) >= 0 && ascii.digit_val(current(this)) < 16) || current(this) == '_')) {
                advance(this);
            }
            emit_at(this, out, token.TOKEN_LIT_INT, start, this.pos - start);
            out.type_suffix = parse_type_suffix(this);
            ret;
        }
        if (p == 'b' || p == 'B') {
            advance(this); advance(this);
            for (!at_end(this) && (current(this) == '0' || current(this) == '1' || current(this) == '_')) {
                advance(this);
            }
            emit_at(this, out, token.TOKEN_LIT_INT, start, this.pos - start);
            out.type_suffix = parse_type_suffix(this);
            ret;
        }
        if (p == 'o' || p == 'O') {
            advance(this); advance(this);
            for (!at_end(this) && ((current(this) >= '0' && current(this) <= '7') || current(this) == '_')) {
                advance(this);
            }
            emit_at(this, out, token.TOKEN_LIT_INT, start, this.pos - start);
            out.type_suffix = parse_type_suffix(this);
            ret;
        }
    }

    for (!at_end(this) && (ascii.is_digit(current(this)) || current(this) == '_')) { advance(this); }

    if (current(this) == '.') {
        advance(this);
        for (!at_end(this) && (ascii.is_digit(current(this)) || current(this) == '_')) { advance(this); }
        emit_at(this, out, token.TOKEN_LIT_FLOAT, start, this.pos - start);
        out.type_suffix = parse_type_suffix(this);
        ret;
    }

    emit_at(this, out, token.TOKEN_LIT_INT, start, this.pos - start);
    out.type_suffix = parse_type_suffix(this);
    ret;
}

fun is_valid_escape(c: char) bool {
    if (c == '\'' || c == '"' || c == '\\') { ret true; }
    if (c == 'n' || c == 't' || c == 'r' || c == '0') { ret true; }
    ret false;
}

fun parse_char(this: *Lexer, out: *token.Token) {
    if (out == nil) { ret; }
    val start: usize = this.pos;
    val c0: char = current(this);
    if (c0 != '\'') {
        emit_at(this, out, token_error_kind(), start, 1);
        ret;
    }

    advance(this); # opening '
    if (at_end(this)) {
        emit_at(this, out, token_error_kind(), start, this.pos - start);
        ret;
    }

    val c1: char = current(this);
    if (c1 == '\\') {
        advance(this);
        if (at_end(this)) {
            emit_at(this, out, token_error_kind(), start, this.pos - start);
            ret;
        }
        val esc: char = current(this);
        if (!is_valid_escape(esc)) {
            emit_at(this, out, token_error_kind(), start, this.pos - start);
            ret;
        }
        advance(this);
    }
    or {
        advance(this);
    }

    if (at_end(this)) {
        emit_at(this, out, token_error_kind(), start, this.pos - start);
        ret;
    }
    val c2: char = current(this);
    if (c2 != '\'') {
        emit_at(this, out, token_error_kind(), start, this.pos - start);
        ret;
    }

    advance(this); # closing '
    emit_at(this, out, token.TOKEN_LIT_CHAR, start, this.pos - start);
    ret;
}

fun parse_string(this: *Lexer, out: *token.Token) {
    if (out == nil) { ret; }
    val start: usize = this.pos;
    val c0: char = current(this);
    if (c0 != '"') {
        emit_at(this, out, token_error_kind(), start, 1);
        ret;
    }

    advance(this); # opening "
    for (!at_end(this)) {
        val c: char = current(this);
        if (c == '"') { brk; }

        if (c == '\\') {
            advance(this);
            if (at_end(this)) {
                emit_at(this, out, token_error_kind(), start, this.pos - start);
                ret;
            }
            val esc: char = current(this);
            if (!is_valid_escape(esc)) {
                emit_at(this, out, token_error_kind(), start, this.pos - start);
                ret;
            }
            advance(this);
        }
        or {
            advance(this);
        }
    }

    if (at_end(this)) {
        emit_at(this, out, token_error_kind(), start, this.pos - start);
        ret;
    }
    val c1: char = current(this);
    if (c1 != '"') {
        emit_at(this, out, token_error_kind(), start, this.pos - start);
        ret;
    }

    advance(this); # closing "
    emit_at(this, out, token.TOKEN_LIT_STRING, start, this.pos - start);
    ret;
}

pub fun next(this: *Lexer, out: *token.Token) {
    if (out == nil) { ret; }
    if (this == nil) {
        token.token_init(out, token.TOKEN_EOF, 0, 0);
        ret;
    }
    if (this.source == nil) {
        token.token_init(out, token.TOKEN_EOF, 0, 0);
        ret;
    }

    # skip whitespace
    for (!at_end(this) && is_space_char(current(this))) {
        advance(this);
    }

    val start: usize = this.pos;
    val ch: char = current(this);

    if (ch == 0) {
        token.token_init(out, token.TOKEN_EOF, start, 0);
        ret;
    }

    # comments
    if (ch == '#') {
        for (!at_end(this) && current(this) != '\n') { advance(this); }
        val len: usize = this.pos - start;
        if (!at_end(this) && current(this) == '\n') { advance(this); }

        token.token_init(out, token.TOKEN_COMMENT, start, len);
        ret;
    }

    # literals
    if (ch == '\'') { parse_char(this, out); ret; }
    if (ch == '"') { parse_string(this, out); ret; }

    if (ascii.is_digit(ch)) { parse_number(this, out); ret; }
    if (ascii.is_alpha(ch) || ch == '_') { parse_identifier(this, out); ret; }

    # multi-char operators / punctuation
    if (ch == ':' && peek(this, 1) == ':') { emit_at(this, out, token.TOKEN_COLON_COLON, start, 2); ret; }
    if (ch == '.' && peek(this, 1) == '.' && peek(this, 2) == '.') { emit_at(this, out, token.TOKEN_ELLIPSIS, start, 3); ret; }

    if (ch == '=' && peek(this, 1) == '=') { emit_at(this, out, token.TOKEN_EQUAL_EQUAL, start, 2); ret; }
    if (ch == '!' && peek(this, 1) == '=') { emit_at(this, out, token.TOKEN_BANG_EQUAL, start, 2); ret; }
    if (ch == '<' && peek(this, 1) == '=') { emit_at(this, out, token.TOKEN_LESS_EQUAL, start, 2); ret; }
    if (ch == '>' && peek(this, 1) == '=') { emit_at(this, out, token.TOKEN_GREATER_EQUAL, start, 2); ret; }
    if (ch == '<' && peek(this, 1) == '<') { emit_at(this, out, token.TOKEN_LESS_LESS, start, 2); ret; }
    if (ch == '>' && peek(this, 1) == '>') { emit_at(this, out, token.TOKEN_GREATER_GREATER, start, 2); ret; }
    if (ch == '&' && peek(this, 1) == '&') { emit_at(this, out, token.TOKEN_AMPERSAND_AMPERSAND, start, 2); ret; }
    if (ch == '|' && peek(this, 1) == '|') { emit_at(this, out, token.TOKEN_PIPE_PIPE, start, 2); ret; }

    # single-char punctuation
    if (ch == '(') { emit_at(this, out, token.TOKEN_L_PAREN, start, 1); ret; }
    if (ch == ')') { emit_at(this, out, token.TOKEN_R_PAREN, start, 1); ret; }
    if (ch == '[') { emit_at(this, out, token.TOKEN_L_BRACKET, start, 1); ret; }
    if (ch == ']') { emit_at(this, out, token.TOKEN_R_BRACKET, start, 1); ret; }
    if (ch == '{') { emit_at(this, out, token.TOKEN_L_BRACE, start, 1); ret; }
    if (ch == '}') { emit_at(this, out, token.TOKEN_R_BRACE, start, 1); ret; }
    if (ch == ':') { emit_at(this, out, token.TOKEN_COLON, start, 1); ret; }
    if (ch == ';') { emit_at(this, out, token.TOKEN_SEMICOLON, start, 1); ret; }
    if (ch == '?') { emit_at(this, out, token.TOKEN_QUESTION, start, 1); ret; }
    if (ch == '@') { emit_at(this, out, token.TOKEN_AT, start, 1); ret; }
    if (ch == '$') { emit_at(this, out, token.TOKEN_DOLLAR, start, 1); ret; }
    if (ch == '.') { emit_at(this, out, token.TOKEN_DOT, start, 1); ret; }
    if (ch == ',') { emit_at(this, out, token.TOKEN_COMMA, start, 1); ret; }

    # single-char operators
    if (ch == '+') { emit_at(this, out, token.TOKEN_PLUS, start, 1); ret; }
    if (ch == '-') { emit_at(this, out, token.TOKEN_MINUS, start, 1); ret; }
    if (ch == '*') { emit_at(this, out, token.TOKEN_STAR, start, 1); ret; }
    if (ch == '%') { emit_at(this, out, token.TOKEN_PERCENT, start, 1); ret; }
    if (ch == '^') { emit_at(this, out, token.TOKEN_CARET, start, 1); ret; }
    if (ch == '&') { emit_at(this, out, token.TOKEN_AMPERSAND, start, 1); ret; }
    if (ch == '|') { emit_at(this, out, token.TOKEN_PIPE, start, 1); ret; }
    if (ch == '~') { emit_at(this, out, token.TOKEN_TILDE, start, 1); ret; }
    if (ch == '<') { emit_at(this, out, token.TOKEN_LESS, start, 1); ret; }
    if (ch == '>') { emit_at(this, out, token.TOKEN_GREATER, start, 1); ret; }
    if (ch == '=') { emit_at(this, out, token.TOKEN_EQUAL, start, 1); ret; }
    if (ch == '!') { emit_at(this, out, token.TOKEN_BANG, start, 1); ret; }
    if (ch == '/') { emit_at(this, out, token.TOKEN_SLASH, start, 1); ret; }

    # unknown character
    emit_at(this, out, token_error_kind(), start, 1);
    ret;
}
