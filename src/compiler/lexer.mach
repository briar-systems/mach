use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;

use allocator: std.allocator;

use token: mach.compiler.token;

# mach.compiler.lexer: lexical analyzer for Mach source code.
# ---
# converts source text into a stream of tokens.

# Lexer: lexical analyzer state.
# ---
# source: source text being tokenized
# pos:    current byte position in source
# len:    total length of source in bytes
pub rec Lexer {
    source: str;
    pos:    i32;
    len:    i32;
}

# init: create a new lexer for a source string.
# ---
# source: source text to tokenize
# ret:    initialized Lexer
pub fun init(source: str) Lexer {
    var lex: Lexer;
    lex.source = source;
    lex.pos = 0;
    if (source != nil) {
        lex.len = source.len()::i32;
    } or {
        lex.len = 0;
    }
    ret lex;
}

# deinit: clean up lexer resources.
# ---
# ret: none
pub fun (this: *Lexer) deinit() {
    # lexer doesn't own the source, nothing to free
}

# at_end: check if the lexer has reached the end of input.
# ---
# ret: true if at end of source
pub fun (this: *Lexer) at_end() bool {
    if (this == nil) {
        ret true;
    }
    ret this.pos >= this.len;
}

# current: get the current character without advancing.
# ---
# ret: current character, or 0 if at end
pub fun (this: *Lexer) current() u8 {
    if (this == nil || this.at_end()) {
        ret 0;
    }
    ret this.source[this.pos];
}

# peek: look ahead by offset characters.
# ---
# offset: number of characters ahead to look
# ret:    character at pos+offset, or 0 if out of bounds
pub fun (this: *Lexer) peek(offset: i32) u8 {
    if (this == nil) {
        ret 0;
    }

    val target: i32 = this.pos + offset;
    if (target < 0 || target >= this.len) {
        ret 0;
    }

    ret this.source[target];
}

# advance: consume and return the current character.
# ---
# ret: the character that was consumed, or 0 if at end
pub fun (this: *Lexer) advance() u8 {
    if (this == nil || this.at_end()) {
        ret 0;
    }

    val c: u8 = this.source[this.pos];
    this.pos = this.pos + 1;
    ret c;
}

# skip_whitespace: skip whitespace and comments.
# ---
# ret: none
pub fun (this: *Lexer) skip_whitespace() {
    if (this == nil) {
        ret;
    }

    for (!this.at_end()) {
        val c: u8 = this.current();

        # space, tab, carriage return
        if (c == 32 || c == 9 || c == 13) {
            this.advance();
            cnt;
        }

        # newline
        if (c == 10) {
            this.advance();
            cnt;
        }

        # comment: # to end of line
        if (c == 35) {
            for (!this.at_end() && this.current() != 10) {
                this.advance();
            }
            cnt;
        }

        brk;
    }
}

# next: get the next token from the source.
# ---
# ret: next Token
pub fun (this: *Lexer) next() token.Token {
    if (this == nil) {
        ret token.create(token.TokenKind { eof: 0 }, 0, 0);
    }

    this.skip_whitespace();

    if (this.at_end()) {
        ret token.create(token.TokenKind { eof: 0 }, this.pos, 0);
    }

    val start: i32 = this.pos;
    val c: u8 = this.advance();

    # identifier or keyword
    if (is_alpha(c) || c == 95) {
        ret this.scan_identifier(start);
    }

    # number literal
    if (is_digit(c)) {
        ret this.scan_number(start);
    }

    # string literal
    if (c == 34) {
        ret this.scan_string(start);
    }

    # character literal
    if (c == 39) {
        ret this.scan_char(start);
    }

    # punctuation and operators
    ret this.scan_punctuation(start, c);
}

# scan_identifier: scan an identifier or keyword.
# ---
# start: starting position of the token
# ret:   Token for identifier or keyword
fun (this: *Lexer) scan_identifier(start: i32) token.Token {
    for (!this.at_end()) {
        val c: u8 = this.current();
        if (!is_alpha(c) && !is_digit(c) && c != 95) {
            brk;
        }
        this.advance();
    }

    val len: i32 = this.pos - start;

    # TODO: extract substring and check for keyword
    # for now, return as identifier
    ret token.create(token.TokenKind { ident: 0 }, start, len);
}

# scan_number: scan a numeric literal.
# ---
# start: starting position of the token
# ret:   Token for integer or float literal
fun (this: *Lexer) scan_number(start: i32) token.Token {
    # scan integer part
    for (!this.at_end() && is_digit(this.current())) {
        this.advance();
    }

    # check for float
    if (this.current() == 46 && is_digit(this.peek(1))) {
        this.advance(); # consume '.'
        for (!this.at_end() && is_digit(this.current())) {
            this.advance();
        }
        val len: i32 = this.pos - start;
        ret token.create(token.TokenKind { lit_float: 0 }, start, len);
    }

    val len: i32 = this.pos - start;
    ret token.create(token.TokenKind { lit_int: 0 }, start, len);
}

# scan_string: scan a string literal.
# ---
# start: starting position (at opening quote)
# ret:   Token for string literal
fun (this: *Lexer) scan_string(start: i32) token.Token {
    for (!this.at_end() && this.current() != 34) {
        if (this.current() == 92) {
            this.advance(); # skip backslash
            if (!this.at_end()) {
                this.advance(); # skip escaped char
            }
        } or {
            this.advance();
        }
    }

    if (this.at_end()) {
        # unterminated string
        val len: i32 = this.pos - start;
        ret token.create(token.TokenKind { error: 0 }, start, len);
    }

    this.advance(); # consume closing quote
    val len: i32 = this.pos - start;
    ret token.create(token.TokenKind { lit_string: 0 }, start, len);
}

# scan_char: scan a character literal.
# ---
# start: starting position (at opening quote)
# ret:   Token for char literal
fun (this: *Lexer) scan_char(start: i32) token.Token {
    if (this.current() == 92) {
        this.advance(); # backslash
        if (!this.at_end()) {
            this.advance(); # escaped char
        }
    } or (!this.at_end()) {
        this.advance(); # regular char
    }

    if (this.current() != 39) {
        # unterminated or invalid char literal
        val len: i32 = this.pos - start;
        ret token.create(token.TokenKind { error: 0 }, start, len);
    }

    this.advance(); # consume closing quote
    val len: i32 = this.pos - start;
    ret token.create(token.TokenKind { lit_char: 0 }, start, len);
}

# scan_punctuation: scan punctuation and operators.
# ---
# start: starting position
# c:     first character already consumed
# ret:   Token for punctuation/operator
fun (this: *Lexer) scan_punctuation(start: i32, c: u8) token.Token {
    # single character tokens
    if (c == 40) { ret token.create(token.TokenKind { lparen: 0 }, start, 1); }
    if (c == 41) { ret token.create(token.TokenKind { rparen: 0 }, start, 1); }
    if (c == 123) { ret token.create(token.TokenKind { lbrace: 0 }, start, 1); }
    if (c == 125) { ret token.create(token.TokenKind { rbrace: 0 }, start, 1); }
    if (c == 91) { ret token.create(token.TokenKind { lbracket: 0 }, start, 1); }
    if (c == 93) { ret token.create(token.TokenKind { rbracket: 0 }, start, 1); }
    if (c == 59) { ret token.create(token.TokenKind { semi: 0 }, start, 1); }
    if (c == 44) { ret token.create(token.TokenKind { comma: 0 }, start, 1); }
    if (c == 46) { ret token.create(token.TokenKind { dot: 0 }, start, 1); }
    if (c == 63) { ret token.create(token.TokenKind { question: 0 }, start, 1); }
    if (c == 64) { ret token.create(token.TokenKind { at: 0 }, start, 1); }
    if (c == 36) { ret token.create(token.TokenKind { dollar: 0 }, start, 1); }
    if (c == 126) { ret token.create(token.TokenKind { tilde: 0 }, start, 1); }
    if (c == 94) { ret token.create(token.TokenKind { caret: 0 }, start, 1); }
    if (c == 37) { ret token.create(token.TokenKind { percent: 0 }, start, 1); }
    if (c == 43) { ret token.create(token.TokenKind { plus: 0 }, start, 1); }
    if (c == 45) { ret token.create(token.TokenKind { minus: 0 }, start, 1); }
    if (c == 47) { ret token.create(token.TokenKind { slash: 0 }, start, 1); }

    # multi-character tokens
    if (c == 58) { # :
        if (this.current() == 58) {
            this.advance();
            ret token.create(token.TokenKind { colon_colon: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { colon: 0 }, start, 1);
    }

    if (c == 42) { # *
        ret token.create(token.TokenKind { star: 0 }, start, 1);
    }

    if (c == 38) { # &
        if (this.current() == 38) {
            this.advance();
            ret token.create(token.TokenKind { amp_amp: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { amp: 0 }, start, 1);
    }

    if (c == 124) { # |
        if (this.current() == 124) {
            this.advance();
            ret token.create(token.TokenKind { pipe_pipe: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { pipe: 0 }, start, 1);
    }

    if (c == 61) { # =
        if (this.current() == 61) {
            this.advance();
            ret token.create(token.TokenKind { eq_eq: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { eq: 0 }, start, 1);
    }

    if (c == 33) { # !
        if (this.current() == 61) {
            this.advance();
            ret token.create(token.TokenKind { bang_eq: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { bang: 0 }, start, 1);
    }

    if (c == 60) { # <
        if (this.current() == 61) {
            this.advance();
            ret token.create(token.TokenKind { lt_eq: 0 }, start, 2);
        }
        if (this.current() == 60) {
            this.advance();
            ret token.create(token.TokenKind { lt_lt: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { lt: 0 }, start, 1);
    }

    if (c == 62) { # >
        if (this.current() == 61) {
            this.advance();
            ret token.create(token.TokenKind { gt_eq: 0 }, start, 2);
        }
        if (this.current() == 62) {
            this.advance();
            ret token.create(token.TokenKind { gt_gt: 0 }, start, 2);
        }
        ret token.create(token.TokenKind { gt: 0 }, start, 1);
    }

    # unknown character
    ret token.create(token.TokenKind { error: 0 }, start, 1);
}

# get_line: get the line number for a position.
# ---
# pos: byte position in source
# ret: 1-based line number
pub fun (this: *Lexer) get_line(pos: i32) i32 {
    if (this == nil || this.source == nil) {
        ret 1;
    }

    var line: i32 = 1;
    var i: i32 = 0;
    for (i < pos && i < this.len) {
        if (this.source[i] == 10) {
            line = line + 1;
        }
        i = i + 1;
    }

    ret line;
}

# get_column: get the column number for a position.
# ---
# pos: byte position in source
# ret: 1-based column number
pub fun (this: *Lexer) get_column(pos: i32) i32 {
    if (this == nil || this.source == nil) {
        ret 1;
    }

    var col: i32 = 1;
    var i: i32 = pos - 1;
    for (i >= 0) {
        if (this.source[i] == 10) {
            brk;
        }
        col = col + 1;
        i = i - 1;
    }

    ret col;
}

# raw_value: extract the raw text of a token from source.
# ---
# tok: token to extract
# ret: pointer to start of token text (not null-terminated)
pub fun (this: *Lexer) raw_value(tok: token.Token) str {
    if (this == nil || this.source == nil) {
        ret nil;
    }

    ret (this.source::usize + tok.pos::usize)::str;
}

# helper: check if character is alphabetic or underscore
fun is_alpha(c: u8) bool {
    ret (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95;
}

# helper: check if character is a digit
fun is_digit(c: u8) bool {
    ret c >= 48 && c <= 57;
}
