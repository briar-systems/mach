use std.types.size;
use std.types.result;
use std.types.string;
use ascii: std.text.ascii;
use mem: std.memory;
use alloc: std.allocator;

use token: mach.compiler.token;

pub rec Lexer {
    source: str;
    pos: usize;
}

pub fun init(this: *Lexer, source: str) {
    if (this == nil) { ret; }
    this.source = source;
    this.pos = 0;
}

fun at_end(this: *Lexer) bool {
    if (this == nil || this.source == nil) { ret true; }
    if (this.pos >= this.source.len()) { ret true; }
    ret this.source[this.pos] == 0;
}

fun current(this: *Lexer) char {
    if (this == nil || this.source == nil) { ret 0; }
    if (this.pos >= this.source.len()) { ret 0; }
    ret this.source[this.pos];
}

fun peek(this: *Lexer, offset: usize) char {
    if (this == nil || this.source == nil) { ret 0; }
    val i: usize = this.pos + offset;
    if (i >= this.source.len()) { ret 0; }
    ret this.source[i];
}

fun advance(this: *Lexer) {
    if (this == nil || this.source == nil) { ret; }
    if (this.pos < this.source.len()) { this.pos = this.pos + 1; }
}

# helpers to compute line/col and extract line text for diagnostics
pub fun get_pos_line(this: *Lexer, pos: usize) usize {
    if (this == nil || this.source == nil) { ret 0; }
    var line: usize = 0;
    var i: usize = 0;
    for (i < pos && i < this.source.len()) {
        if (this.source[i] == '\n') { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

pub fun get_pos_line_offset(this: *Lexer, pos: usize) usize {
    if (this == nil || this.source == nil) { ret 0; }
    var offset: usize = 0;
    var i: usize = 0;
    for (i < pos && i < this.source.len()) {
        if (this.source[i] == '\n') { offset = 0; }
        or { offset = offset + 1; }
        i = i + 1;
    }
    ret offset;
}

pub fun get_line_text(this: *Lexer, line: usize) str {
    if (this == nil || this.source == nil) { ret ""; }

    var line_start: usize = 0;
    var current_line: usize = 0;
    for (current_line < line && line_start < this.source.len()) {
        if (this.source[line_start] == '\n') {
            current_line = current_line + 1;
        }
        line_start = line_start + 1;
    }

    if (line_start >= this.source.len()) { ret ""; }

    var line_end: usize = line_start;
    for (line_end < this.source.len() && this.source[line_end] != '\n' && this.source[line_end] != 0) {
        line_end = line_end + 1;
    }

    val line_len: usize = line_end - line_start;
    if (line_len == 0) { ret ""; }

    val allocr: Result[ptr, alloc.AllocError] = alloc.default().alloc_bytes(line_len + 1, 1);
    if (allocr.is_err()) { ret ""; }

    val buf: ptr = allocr.unwrap_ok();
    var dst: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < line_len) {
        dst[i] = this.source[line_start + i];
        i = i + 1;
    }
    dst[line_len] = 0;

    ret buf::str;
}

# parse type suffixes: i8/i16/i32/i64, u8/u16/u32/u64, f32/f64
fun parse_type_suffix(this: *Lexer) str {
    if (this == nil) { ret nil; }
    val start: usize = this.pos;
    val c: char = current(this);
    if (c != 'i' && c != 'u' && c != 'f') { ret nil; }

    advance(this);
    val width_start: usize = this.pos;
    for (this.pos < this.source.len() && ascii.is_digit(current(this))) {
        advance(this);
    }

    val width_len: usize = this.pos - width_start;
    if (width_len == 0) {
        this.pos = start;
        ret nil;
    }

    val suff_len: usize = this.pos - start;
    val allocr: Result[ptr, alloc.AllocError] = alloc.default().alloc_bytes(suff_len + 1, 1);
    if (allocr.is_err()) { this.pos = start; ret nil; }
    val buf: ptr = allocr.unwrap_ok();
    var bytes: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < suff_len) {
        bytes[i] = this.source[start + i];
        i = i + 1;
    }
    bytes[suff_len] = 0;

    val s: str = buf::str;
    if (s == "u8" || s == "u16" || s == "u32" || s == "u64" || s == "i8" || s == "i16" || s == "i32" || s == "i64" || s == "f32" || s == "f64") {
        ret s;
    }

    this.pos = start;
    ret nil;
}

fun emit_at(this: *Lexer, kind: i32, start: usize, len: usize) token.Token {
    var t: token.Token;
    token.token_init(?t, kind, start, len);
    this.pos = start + len;
    ret t;
}

fun parse_identifier(this: *Lexer) token.Token {
    val start: usize = this.pos;
    for (!at_end(this) && (ascii.is_alnum(current(this)) || current(this) == '_')) {
        advance(this);
    }
    val len: usize = this.pos - start;

    val kind: i32 = token.kind_from_identifier(this.source, start, len);
    var t: token.Token;
    token.token_init(?t, kind, start, len);
    ret t;
}

fun parse_number(this: *Lexer) token.Token {
    val start: usize = this.pos;

    if (current(this) == '0') {
        val p: char = peek(this, 1);
        if (p == 'x' || p == 'X') {
            advance(this); advance(this);
            for (!at_end(this) && ((ascii.digit_val(current(this)) >= 0 && ascii.digit_val(current(this)) < 16) || current(this) == '_')) {
                advance(this);
            }
            var t: token.Token = emit_at(this, token.TOKEN_LIT_INT, start, this.pos - start);
            t.type_suffix = parse_type_suffix(this);
            ret t;
        }
        if (p == 'b' || p == 'B') {
            advance(this); advance(this);
            for (!at_end(this) && (current(this) == '0' || current(this) == '1' || current(this) == '_')) {
                advance(this);
            }
            var t2: token.Token = emit_at(this, token.TOKEN_LIT_INT, start, this.pos - start);
            t2.type_suffix = parse_type_suffix(this);
            ret t2;
        }
        if (p == 'o' || p == 'O') {
            advance(this); advance(this);
            for (!at_end(this) && ((current(this) >= '0' && current(this) <= '7') || current(this) == '_')) {
                advance(this);
            }
            var t3: token.Token = emit_at(this, token.TOKEN_LIT_INT, start, this.pos - start);
            t3.type_suffix = parse_type_suffix(this);
            ret t3;
        }
    }

    for (!at_end(this) && (ascii.is_digit(current(this)) || current(this) == '_')) { advance(this); }

    if (current(this) == '.') {
        advance(this);
        for (!at_end(this) && (ascii.is_digit(current(this)) || current(this) == '_')) { advance(this); }
        var ft: token.Token = emit_at(this, token.TOKEN_LIT_FLOAT, start, this.pos - start);
        ft.type_suffix = parse_type_suffix(this);
        ret ft;
    }

    var it: token.Token = emit_at(this, token.TOKEN_LIT_INT, start, this.pos - start);
    it.type_suffix = parse_type_suffix(this);
    ret it;
}

fun is_valid_escape(c: char) bool {
    if (c == '\'' || c == '"' || c == '\\') { ret true; }
    if (c == 'n' || c == 't' || c == 'r' || c == '0') { ret true; }
    ret false;
}

fun parse_char(this: *Lexer) token.Token {
    val start: usize = this.pos;
    if (current(this) != '\'') {
        ret emit_at(this, token.TOKEN_ERROR, start, 1);
    }

    advance(this); # opening '
    if (at_end(this)) {
        ret emit_at(this, token.TOKEN_ERROR, start, this.pos - start);
    }

    if (current(this) == '\\') {
        advance(this);
        if (at_end(this) || !is_valid_escape(current(this))) {
            ret emit_at(this, token.TOKEN_ERROR, start, this.pos - start);
        }
        advance(this);
    }
    or {
        advance(this);
    }

    if (at_end(this) || current(this) != '\'') {
        ret emit_at(this, token.TOKEN_ERROR, start, this.pos - start);
    }

    advance(this); # closing '
    ret emit_at(this, token.TOKEN_LIT_CHAR, start, this.pos - start);
}

fun parse_string(this: *Lexer) token.Token {
    val start: usize = this.pos;
    if (current(this) != '"') {
        ret emit_at(this, token.TOKEN_ERROR, start, 1);
    }

    advance(this); # opening "
    for (!at_end(this) && current(this) != '"') {
        if (current(this) == '\\') {
            advance(this);
            if (at_end(this) || !is_valid_escape(current(this))) {
                ret emit_at(this, token.TOKEN_ERROR, start, this.pos - start);
            }
            advance(this);
        }
        or {
            advance(this);
        }
    }

    if (at_end(this) || current(this) != '"') {
        ret emit_at(this, token.TOKEN_ERROR, start, this.pos - start);
    }

    advance(this); # closing "
    ret emit_at(this, token.TOKEN_LIT_STRING, start, this.pos - start);
}

pub fun next(this: *Lexer) token.Token {
    if (this == nil || this.source == nil) {
        var e: token.Token;
        token.token_init(?e, token.TOKEN_EOF, 0, 0);
        ret e;
    }

    # skip whitespace
    for (!at_end(this) && ascii.is_space(current(this))) {
        advance(this);
    }

    val start: usize = this.pos;
    val ch: char = current(this);

    if (ch == 0) {
        var t0: token.Token;
        token.token_init(?t0, token.TOKEN_EOF, start, 0);
        ret t0;
    }

    # comments
    if (ch == '#') {
        for (!at_end(this) && current(this) != '\n') { advance(this); }
        val len: usize = this.pos - start;
        if (!at_end(this) && current(this) == '\n') { advance(this); }

        var c: token.Token;
        token.token_init(?c, token.TOKEN_COMMENT, start, len);
        ret c;
    }

    # literals
    if (ch == '\'') { ret parse_char(this); }
    if (ch == '"') { ret parse_string(this); }

    if (ascii.is_digit(ch)) { ret parse_number(this); }
    if (ascii.is_alpha(ch) || ch == '_') { ret parse_identifier(this); }

    # multi-char operators / punctuation
    if (ch == ':' && peek(this, 1) == ':') { ret emit_at(this, token.TOKEN_COLON_COLON, start, 2); }
    if (ch == '.' && peek(this, 1) == '.' && peek(this, 2) == '.') { ret emit_at(this, token.TOKEN_ELLIPSIS, start, 3); }

    if (ch == '=' && peek(this, 1) == '=') { ret emit_at(this, token.TOKEN_EQUAL_EQUAL, start, 2); }
    if (ch == '!' && peek(this, 1) == '=') { ret emit_at(this, token.TOKEN_BANG_EQUAL, start, 2); }
    if (ch == '<' && peek(this, 1) == '=') { ret emit_at(this, token.TOKEN_LESS_EQUAL, start, 2); }
    if (ch == '>' && peek(this, 1) == '=') { ret emit_at(this, token.TOKEN_GREATER_EQUAL, start, 2); }
    if (ch == '<' && peek(this, 1) == '<') { ret emit_at(this, token.TOKEN_LESS_LESS, start, 2); }
    if (ch == '>' && peek(this, 1) == '>') { ret emit_at(this, token.TOKEN_GREATER_GREATER, start, 2); }
    if (ch == '&' && peek(this, 1) == '&') { ret emit_at(this, token.TOKEN_AMPERSAND_AMPERSAND, start, 2); }
    if (ch == '|' && peek(this, 1) == '|') { ret emit_at(this, token.TOKEN_PIPE_PIPE, start, 2); }

    # single-char punctuation
    if (ch == '(') { ret emit_at(this, token.TOKEN_L_PAREN, start, 1); }
    if (ch == ')') { ret emit_at(this, token.TOKEN_R_PAREN, start, 1); }
    if (ch == '[') { ret emit_at(this, token.TOKEN_L_BRACKET, start, 1); }
    if (ch == ']') { ret emit_at(this, token.TOKEN_R_BRACKET, start, 1); }
    if (ch == '{') { ret emit_at(this, token.TOKEN_L_BRACE, start, 1); }
    if (ch == '}') { ret emit_at(this, token.TOKEN_R_BRACE, start, 1); }
    if (ch == ':') { ret emit_at(this, token.TOKEN_COLON, start, 1); }
    if (ch == ';') { ret emit_at(this, token.TOKEN_SEMICOLON, start, 1); }
    if (ch == '?') { ret emit_at(this, token.TOKEN_QUESTION, start, 1); }
    if (ch == '@') { ret emit_at(this, token.TOKEN_AT, start, 1); }
    if (ch == '$') { ret emit_at(this, token.TOKEN_DOLLAR, start, 1); }
    if (ch == '.') { ret emit_at(this, token.TOKEN_DOT, start, 1); }
    if (ch == ',') { ret emit_at(this, token.TOKEN_COMMA, start, 1); }

    # single-char operators
    if (ch == '+') { ret emit_at(this, token.TOKEN_PLUS, start, 1); }
    if (ch == '-') { ret emit_at(this, token.TOKEN_MINUS, start, 1); }
    if (ch == '*') { ret emit_at(this, token.TOKEN_STAR, start, 1); }
    if (ch == '%') { ret emit_at(this, token.TOKEN_PERCENT, start, 1); }
    if (ch == '^') { ret emit_at(this, token.TOKEN_CARET, start, 1); }
    if (ch == '&') { ret emit_at(this, token.TOKEN_AMPERSAND, start, 1); }
    if (ch == '|') { ret emit_at(this, token.TOKEN_PIPE, start, 1); }
    if (ch == '~') { ret emit_at(this, token.TOKEN_TILDE, start, 1); }
    if (ch == '<') { ret emit_at(this, token.TOKEN_LESS, start, 1); }
    if (ch == '>') { ret emit_at(this, token.TOKEN_GREATER, start, 1); }
    if (ch == '=') { ret emit_at(this, token.TOKEN_EQUAL, start, 1); }
    if (ch == '!') { ret emit_at(this, token.TOKEN_BANG, start, 1); }
    if (ch == '/') { ret emit_at(this, token.TOKEN_SLASH, start, 1); }

    # unknown character
    ret emit_at(this, token.TOKEN_ERROR, start, 1);
}    if (i >= this.source.len()) { ret 0; }
    ret this.source[i];
}

fun advance(this: *Lexer) char {
    if (this == nil || this.source == nil) { ret 0; }
    if (this.pos < this.source.len()) { this.pos = this.pos + 1; }
    ret current(this);
}

# helpers to compute line/col and extract line text for diagnostics
pub fun get_pos_line(this: *Lexer, pos: usize) usize {
    if (this == nil || this.source == nil) { ret 0; }
    var line: usize = 0;
    var i: usize = 0;
    for (i < pos && i < this.source.len()) {
        if (this.source[i] == '\n') { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

pub fun get_pos_line_offset(this: *Lexer, pos: usize) usize {
    if (this == nil || this.source == nil) { ret 0; }
    var offset: usize = 0;
    var i: usize = 0;
    for (i < pos && i < this.source.len()) {
        if (this.source[i] == '\n') { offset = 0; }
        else { offset = offset + 1; }
        i = i + 1;
    }
    ret offset;
}

pub fun get_line_text(this: *Lexer, line: usize) str {
    if (this == nil || this.source == nil) { ret ""; }

    var line_start: usize = 0;
    var current_line: usize = 0;
    while (current_line < line && line_start < this.source.len()) {
        if (this.source[line_start] == '\n') {
            current_line = current_line + 1;
        }
        line_start = line_start + 1;
    }

    if (line_start >= this.source.len()) { ret ""; }

    var line_end: usize = line_start;
    while (line_end < this.source.len() && this.source[line_end] != '\n') {
        line_end = line_end + 1;
    }

    val line_len: usize = (line_end - line_start);
    if (line_len == 0) { ret ""; }

    val allocr: Result[ptr, str] = alloc.default().alloc_bytes(line_len + 1, 1);
    if (allocr.is_err()) { ret ""; }

    val buf: ptr = allocr.unwrap_ok();
    mem.raw_copy(buf, (this.source::ptr), line_len); # copy from source start (we'll copy slice manually below)
    # correct copy: copy starting at line_start
    var dst_bytes: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < line_len) {
        dst_bytes[i] = this.source[line_start + i];
        i = i + 1;
    }
    dst_bytes[line_len] = 0;

    ret buf::str;
}

# parse type suffixes: i8/i16/i32/i64, u8/u16/u32/u64, f32/f64
fun parse_type_suffix(this: *Lexer) str {
    if (this == nil) { ret nil; }
    val start: usize = this.pos;
    val c: char = current(this);
    if (c != 'i' && c != 'u' && c != 'f') { ret nil; }

    advance(this);
    var width_start: usize = this.pos;
    while (this.pos < this.source.len() && ascii.is_digit(current(this))) {
        advance(this);
    }

    val width_len: usize = this.pos - width_start;
    if (width_len == 0) {
        # reset
        this.pos = start;
        ret nil;
    }

    val suff_len: usize = this.pos - start;
    # copy suffix to a new buffer
    val allocr: Result[ptr, str] = alloc.default().alloc_bytes(suff_len + 1, 1);
    if (allocr.is_err()) { this.pos = start; ret nil; }
    val buf: ptr = allocr.unwrap_ok();
    var bytes: *u8 = buf::*u8;
    var i: usize = 0;
    for (i < suff_len) {
        bytes[i] = this.source[start + i];
        i = i + 1;
    }
    bytes[suff_len] = 0;

    val s: str = buf::str;
    # validate known suffixes
    if (s == "u8" || s == "u16" || s == "u32" || s == "u64" || s == "i8" || s == "i16" || s == "i32" || s == "i64" || s == "f32" || s == "f64") {
        ret s;
    }

    # not a known suffix: roll back
    this.pos = start;
    ret nil;
}

fun emit(this: *Lexer, kind: i32, len: usize) token.Token {
    var t: token.Token;
    token.token_init(?t, kind, this.pos, len);
    this.pos = this.pos + len;
    ret t;
}

# parse identifier and keywords
fun parse_identifier(this: *Lexer) token.Token {
    val start: usize = this.pos;
    while (!at_end(this) && (ascii.is_alnum(current(this)) || current(this) == '_')) {
        advance(this);
    }
    val len: usize = this.pos - start;
    val kind: i32 = token.kind_from_identifier(this.source, start, len);
    var t: token.Token;
    token.token_init(?t, kind, start, len);
    ret t;
}

# parse numbers (int/float with prefixes and underscores)
fun parse_number(this: *Lexer) token.Token {
    val start: usize = this.pos;

    if (current(this) == '0') {
        val p: char = peek(this, 1);
        if (p == 'x' || p == 'X') {
            advance(this); advance(this);
            while (!at_end(this) && (ascii.digit_val(current(this)) >= 0 && ascii.digit_val(current(this)) < 16 || current(this) == '_')) { advance(this); }
            val t: token.Token = emit(this, token.TOKEN_LIT_INT, this.pos - start);
            t.type_suffix = parse_type_suffix(this);
            ret t;
        }
        if (p == 'b' || p == 'B') {
            advance(this); advance(this);
            while (!at_end(this) && (current(this) == '0' || current(this) == '1' || current(this) == '_')) { advance(this); }
            val t: token.Token = emit(this, token.TOKEN_LIT_INT, this.pos - start);
            t.type_suffix = parse_type_suffix(this);
            ret t;
        }
        if (p == 'o' || p == 'O') {
            advance(this); advance(this);
            while (!at_end(this) && ((current(this) >= '0' && current(this) <= '7') || current(this) == '_')) { advance(this); }
            val t: token.Token = emit(this, token.TOKEN_LIT_INT, this.pos - start);
            t.type_suffix = parse_type_suffix(this);
            ret t;
        }
        # fall-through to decimal
    }

    while (!at_end(this) && (ascii.is_digit(current(this)) || current(this) == '_')) { advance(this); }

    if (current(this) == '.') {
        advance(this);
        while (!at_end(this) && (ascii.is_digit(current(this)) || current(this) == '_')) { advance(this); }
        var t: token.Token = emit(this, token.TOKEN_LIT_FLOAT, this.pos - start);
        t.type_suffix = parse_type_suffix(this);
        ret t;
    }

    var t2: token.Token = emit(this, token.TOKEN_LIT_INT, this.pos - start);
    t2.type_suffix = parse_type_suffix(this);
    ret t2;
}

# parse char literal
fun parse_char(this: *Lexer) token.Token {
    val start: usize = this.pos;
    if (current(this) != '\'') {
        var e: token.Token;
        token.token_init(?e, token.TOKEN_ERROR, start, 1);
        ret e;
    }

    advance(this);
    if (at_end(this)) { var e2: token.Token; token.token_init(?e2, token.TOKEN_ERROR, start, 1); ret e2; }

    if (current(this) == '\\') {
        advance(this);
        if (at_end(this)) { var e3: token.Token; token.token_init(?e3, token.TOKEN_ERROR, start, 1); ret e3; }
        val c: char = current(this);
        switch (c) {
        case '\'':; case '\"'; case '\\'; case 'n'; case 't'; case 'r'; case '0';
            advance(this);
            break;
        default:
            var errt: token.Token; token.token_init(?errt, token.TOKEN_ERROR, start, this.pos - start); ret errt;
        }
    } else {
        advance(this);
    }

    if (at_end(this) || current(this) != '\'') { var et: token.Token; token.token_init(?et, token.TOKEN_ERROR, start, this.pos - start); ret et; }

    advance(this);
    var out: token.Token = emit(this, token.TOKEN_LIT_CHAR, this.pos - start);
    ret out;
}

# parse string literal
fun parse_string(this: *Lexer) token.Token {
    val start: usize = this.pos;
    if (current(this) != '"') { var e: token.Token; token.token_init(?e, token.TOKEN_ERROR, start, 1); ret e; }

    advance(this);

    while (!at_end(this) && current(this) != '"') {
        if (current(this) == '\\') {
            advance(this);
            if (at_end(this)) { var e3: token.Token; token.token_init(?e3, token.TOKEN_ERROR, start, this.pos - start); ret e3; }
            val c: char = current(this);
            switch (c) {
            case '\'':; case '\"'; case '\\'; case 'n'; case 't'; case 'r'; case '0';
                advance(this);
                break;
            default:
                var errt: token.Token; token.token_init(?errt, token.TOKEN_ERROR, start, this.pos - start); ret errt;
            }
        } else {
            advance(this);
        }
    }

    if (at_end(this) || current(this) != '"') { var e2: token.Token; token.token_init(?e2, token.TOKEN_ERROR, start, this.pos - start); ret e2; }

    advance(this);
    var out: token.Token = emit(this, token.TOKEN_LIT_STRING, this.pos - start);
    ret out;
}

# main tokenization entrypoint
pub fun next(this: *Lexer) token.Token {
    if (this == nil || this.source == nil) {
        var e: token.Token; token.token_init(?e, token.TOKEN_EOF, 0, 0); ret e;
    }

    # skip whitespace
    while (!at_end(this) && ascii.is_space(current(this))) {
        advance(this);
    }

    val ch: char = current(this);

    switch (ch) {
    case '\0':
        var t0: token.Token = emit(this, token.TOKEN_EOF, 1);
        ret t0;
    case '#':
        val start: usize = this.pos;
        while (!at_end(this) && current(this) != '\n') { advance(this); }
        val len: usize = this.pos - start;
        # consume newline if present
        if (!at_end(this) && current(this) == '\n') { advance(this); }
        var c: token.Token;
        token.token_init(?c, token.TOKEN_COMMENT, start, len);
        ret c;
    case '\'':
        return parse_char(this);
    case '\"':
        return parse_string(this);
    case '(':
        return emit(this, token.TOKEN_L_PAREN, 1);
    case ')':
        return emit(this, token.TOKEN_R_PAREN, 1);
    case '[':
        return emit(this, token.TOKEN_L_BRACKET, 1);
    case ']':
        return emit(this, token.TOKEN_R_BRACKET, 1);
    case '{':
        return emit(this, token.TOKEN_L_BRACE, 1);
    case '}':
        return emit(this, token.TOKEN_R_BRACE, 1);
    case ':':
        if (peek(this, 1) == ':') { return emit(this, token.TOKEN_COLON_COLON, 2); }
        return emit(this, token.TOKEN_COLON, 1);
    case ';':
        return emit(this, token.TOKEN_SEMICOLON, 1);
    case '?':
        return emit(this, token.TOKEN_QUESTION, 1);
    case '@':
        return emit(this, token.TOKEN_AT, 1);
    case '$':
        return emit(this, token.TOKEN_DOLLAR, 1);
    case '.':
        if (peek(this, 1) == '.' && peek(this, 2) == '.') { return emit(this, token.TOKEN_ELLIPSIS, 3); }
        return emit(this, token.TOKEN_DOT, 1);
    case ',':
        return emit(this, token.TOKEN_COMMA, 1);
    case '+':
        return emit(this, token.TOKEN_PLUS, 1);
    case '-':
        return emit(this, token.TOKEN_MINUS, 1);
    case '*':
        return emit(this, token.TOKEN_STAR, 1);
    case '%':
        return emit(this, token.TOKEN_PERCENT, 1);
    case '^':
        return emit(this, token.TOKEN_CARET, 1);
    case '&':
        if (peek(this, 1) == '&') { return emit(this, token.TOKEN_AMPERSAND_AMPERSAND, 2); }
        return emit(this, token.TOKEN_AMPERSAND, 1);
    case '|':
        if (peek(this, 1) == '|') { return emit(this, token.TOKEN_PIPE_PIPE, 2); }
        return emit(this, token.TOKEN_PIPE, 1);
    case '~':
        return emit(this, token.TOKEN_TILDE, 1);
    case '<':
        if (peek(this, 1) == '<') { return emit(this, token.TOKEN_LESS_LESS, 2); }
        if (peek(this, 1) == '=') { return emit(this, token.TOKEN_LESS_EQUAL, 2); }
        return emit(this, token.TOKEN_LESS, 1);
    case '>':
        if (peek(this, 1) == '>') { return emit(this, token.TOKEN_GREATER_GREATER, 2); }
        if (peek(this, 1) == '=') { return emit(this, token.TOKEN_GREATER_EQUAL, 2); }
        return emit(this, token.TOKEN_GREATER, 1);
    case '=':
        if (peek(this, 1) == '=') { return emit(this, token.TOKEN_EQUAL_EQUAL, 2); }
        return emit(this, token.TOKEN_EQUAL, 1);
    case '!':
        if (peek(this, 1) == '=') { return emit(this, token.TOKEN_BANG_EQUAL, 2); }
        return emit(this, token.TOKEN_BANG, 1);
    case '/':
        return emit(this, token.TOKEN_SLASH, 1);
    default:
        if (ascii.is_digit(ch)) { return parse_number(this); }
        if (ascii.is_alpha(ch) || ch == '_') { return parse_identifier(this); }
        return emit(this, token.TOKEN_ERROR, 1);
    }
}
