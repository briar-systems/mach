use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ty:     mach.compiler.type;
use target: mach.compiler.masm.target;

# mach.compiler.type_context: type construction, caching, and context management.
# ---
# provides TypeContext for allocating and caching types during compilation.

# number of entries in the primitive type cache (covers TY_VOID through TY_GENERIC_PARAM).
val PRIM_CACHE_SIZE: usize = 22;

# PrimitiveMeta: static metadata for a primitive type kind.
rec PrimitiveMeta {
    name:  str;
    size:  usize;
    align: usize;
}

# TypeContext: context for type resolution and caching.
# ---
# alloc:       allocator for type allocations
# types:       array of all allocated types
# type_count:  number of types
# type_cap:    allocated capacity
# primitives:  cached primitive types
pub rec TypeContext {
    alloc:      *allocator.Allocator;
    types:      **ty.Type;
    type_count: i32;
    type_cap:   i32;
    tgt:        *target.Target;

    # cached primitive types (indexed by TY_* constants)
    primitives: **ty.Type;

    # cached alias types (not indexed by kind — constructed on first use)
    cached_str: *ty.Type;  # &u8
}

# init_context: create a new type context.
# ---
# alloc: allocator to use
# tgt:   target configuration
# ret:   Ok(TypeContext) on success, Err(str) on failure
pub fun init_context(alloc: *allocator.Allocator, tgt: *target.Target) Result[TypeContext, str] {
    if (alloc == nil) {
        ret err[TypeContext, str]("allocator is nil");
    }

    var ctx: TypeContext;
    ctx.alloc = alloc;
    ctx.types = nil;
    ctx.type_count = 0;
    ctx.type_cap = 0;
    ctx.tgt = tgt;
    ctx.cached_str = nil;

    # allocate primitive cache (zero-initialized = all nil)
    val prim_res: Result[**ty.Type, allocator.AllocError] = allocator.allocator_zalloc[*ty.Type](alloc, PRIM_CACHE_SIZE);
    if (result_is_err[**ty.Type, allocator.AllocError](prim_res)) {
        ret err[TypeContext, str]("failed to allocate primitive cache");
    }
    ctx.primitives = result_unwrap_ok[**ty.Type, allocator.AllocError](prim_res);

    ret ok[TypeContext, str](ctx);
}

# deinit_context: free all resources in a type context.
# ---
# ctx: context to clean up
# ret: none
pub fun deinit_context(ctx: *TypeContext) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }

    # free all types in the types array
    var i: i32 = 0;
    for (i < ctx.type_count) {
        if (ctx.types[i] != nil) {
            val t: *ty.Type = ctx.types[i];
            # free fields array if present
            if (t.fields != nil && t.field_count > 0) {
                allocator.allocator_free[ty.Field](ctx.alloc, t.fields, t.field_count::usize);
            }
            # free params array if present
            if (t.params != nil && t.param_count > 0) {
                allocator.allocator_free[*ty.Type](ctx.alloc, t.params, t.param_count::usize);
            }
            allocator.allocator_free[ty.Type](ctx.alloc, t, 1);
        }
        i = i + 1;
    }

    if (ctx.types != nil) {
        allocator.allocator_free[*ty.Type](ctx.alloc, ctx.types, ctx.type_cap::usize);
    }

    # free primitive cache array
    if (ctx.primitives != nil) {
        allocator.allocator_free[*ty.Type](ctx.alloc, ctx.primitives, PRIM_CACHE_SIZE);
    }
}

# register_type: add a type to the context's type list.
fun register_type(ctx: *TypeContext, t: *ty.Type) Result[bool, str] {
    if (ctx == nil || t == nil) {
        ret err[bool, str]("nil context or type");
    }

    # grow types array if needed
    if (ctx.type_count >= ctx.type_cap) {
        var new_cap: i32 = 16;
        if (ctx.type_cap > 0) {
            new_cap = ctx.type_cap * 2;
        }

        val r: Result[**ty.Type, allocator.AllocError] = allocator.allocator_resize[*ty.Type](
            ctx.alloc,
            ctx.types,
            ctx.type_cap::usize,
            new_cap::usize
        );

        if (result_is_err[**ty.Type, allocator.AllocError](r)) {
            ret err[bool, str](result_unwrap_err[**ty.Type, allocator.AllocError](r));
        }

        ctx.types = result_unwrap_ok[**ty.Type, allocator.AllocError](r);
        ctx.type_cap = new_cap;
    }

    ctx.types[ctx.type_count] = t;
    ctx.type_count = ctx.type_count + 1;

    ret ok[bool, str](true);
}

# create_type: allocate a new type with the given kind.
# ---
# ctx:  type context
# kind: type kind tag (TY_* constant)
# ret:  Ok(*Type) on success, Err(str) on failure
pub fun create_type(ctx: *TypeContext, kind: ty.TypeKind) Result[*ty.Type, str] {
    if (ctx == nil) {
        ret err[*ty.Type, str]("context is nil");
    }

    if (ctx.alloc == nil) {
        ret err[*ty.Type, str]("allocator is nil");
    }

    val type_res: Result[*ty.Type, allocator.AllocError] = allocator.allocator_zalloc[ty.Type](ctx.alloc, 1);
    if (result_is_err[*ty.Type, allocator.AllocError](type_res)) {
        ret err[*ty.Type, str](result_unwrap_err[*ty.Type, allocator.AllocError](type_res));
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, allocator.AllocError](type_res);
    t.kind = kind;
    t.name = nil;
    t.inner = nil;
    t.size = 0;
    t.align = 0;
    t.is_mutable = false;
    t.fields = nil;
    t.field_count = 0;
    t.params = nil;
    t.param_count = 0;
    t.ret_type = nil;
    t.array_len = 0;

    # set default size/alignment based on kind
    if (kind == ty.TY_VOID) {
        t.size = 0;
        t.align = 1;
    } or {
        if (kind == ty.TY_U8 || kind == ty.TY_I8) {
            t.size = 1;
            t.align = 1;
        } or {
            if (kind == ty.TY_U16 || kind == ty.TY_I16) {
                t.size = 2;
                t.align = 2;
            } or {
                if (kind == ty.TY_U32 || kind == ty.TY_I32 || kind == ty.TY_F32) {
                    t.size = 4;
                    t.align = 4;
                } or {
                    if (kind == ty.TY_U64 || kind == ty.TY_I64 || kind == ty.TY_F64 ||
                        kind == ty.TY_PTR || kind == ty.TY_POINTER) {
                        t.size = 8;
                        t.align = 8;
                    } or {
                        if (kind == ty.TY_NIL) {
                            t.size = 0;
                            t.align = 1;
                        }
                    }
                }
            }
        }
    }

    # register type in context
    val reg_res: Result[bool, str] = register_type(ctx, t);
    if (result_is_err[bool, str](reg_res)) {
        allocator.allocator_free[ty.Type](ctx.alloc, t, 1);
        ret err[*ty.Type, str](result_unwrap_err[bool, str](reg_res));
    }

    ret ok[*ty.Type, str](t);
}

# primitive_meta: get static metadata for a primitive type kind.
# ---
# kind: type kind tag
# ret:  metadata with name/size/align (name is nil for non-primitive kinds)
fun primitive_meta(kind: ty.TypeKind) PrimitiveMeta {
    var m: PrimitiveMeta;
    m.name = nil;
    m.size = 0;
    m.align = 0;

    if (kind == ty.TY_VOID)  { m.name = "void";  m.size = 0; m.align = 1; ret m; }
    if (kind == ty.TY_U8)    { m.name = "u8";    m.size = 1; m.align = 1; ret m; }
    if (kind == ty.TY_U16)   { m.name = "u16";   m.size = 2; m.align = 2; ret m; }
    if (kind == ty.TY_U32)   { m.name = "u32";   m.size = 4; m.align = 4; ret m; }
    if (kind == ty.TY_U64)   { m.name = "u64";   m.size = 8; m.align = 8; ret m; }
    if (kind == ty.TY_I8)    { m.name = "i8";    m.size = 1; m.align = 1; ret m; }
    if (kind == ty.TY_I16)   { m.name = "i16";   m.size = 2; m.align = 2; ret m; }
    if (kind == ty.TY_I32)   { m.name = "i32";   m.size = 4; m.align = 4; ret m; }
    if (kind == ty.TY_I64)   { m.name = "i64";   m.size = 8; m.align = 8; ret m; }
    if (kind == ty.TY_F32)   { m.name = "f32";   m.size = 4; m.align = 4; ret m; }
    if (kind == ty.TY_F64)   { m.name = "f64";   m.size = 8; m.align = 8; ret m; }
    if (kind == ty.TY_PTR)   { m.name = "ptr";   m.size = 8; m.align = 8; ret m; }
    if (kind == ty.TY_NIL)   { m.name = "nil";   m.size = 0; m.align = 1; ret m; }
    if (kind == ty.TY_ERROR) { m.name = "error"; m.size = 0; m.align = 0; ret m; }

    ret m;
}

# primitive_type: get a cached primitive type by kind.
# ---
# ctx:  type context
# kind: primitive type kind (TY_* constant)
# ret:  Ok(*Type) on success, Err(str) on failure
pub fun primitive_type(ctx: *TypeContext, kind: ty.TypeKind) Result[*ty.Type, str] {
    if (ctx == nil) {
        ret err[*ty.Type, str]("context is nil");
    }

    # validate this is a primitive kind
    val meta: PrimitiveMeta = primitive_meta(kind);
    if (meta.name == nil) {
        ret err[*ty.Type, str]("not a primitive type kind");
    }

    # check cache
    if (ctx.primitives[kind::usize] != nil) {
        ret ok[*ty.Type, str](ctx.primitives[kind::usize]);
    }

    # create and cache
    val res: Result[*ty.Type, str] = create_type(ctx, kind);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = meta.name;
    ctx.primitives[kind::usize] = t;

    ret ok[*ty.Type, str](t);
}

# pointer_type: create a pointer type.
# ---
# ctx:     type context
# inner:   type being pointed to
# mutable: true for *T, false for &T
# ret:     Ok(*Type) on success, Err(str) on failure
pub fun pointer_type(ctx: *TypeContext, inner: *ty.Type, mutable: bool) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_POINTER);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.inner = inner;
    t.is_mutable = mutable;
    t.size = 8;
    t.align = 8;

    ret ok[*ty.Type, str](t);
}

# array_type: create an array type.
# ---
# ctx:   type context
# inner: element type
# len:   number of elements
# ret:   Ok(*Type) on success, Err(str) on failure
pub fun array_type(ctx: *TypeContext, inner: *ty.Type, len: usize) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_ARRAY);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.inner = inner;
    t.array_len = len;

    if (inner != nil) {
        t.size = inner.size * len;
        t.align = inner.align;
    }

    ret ok[*ty.Type, str](t);
}

# function_type: create a function type.
# ---
# ctx:         type context
# params:      array of parameter types
# param_count: number of parameters
# ret_type:    return type
# ret:         Ok(*Type) on success, Err(str) on failure
pub fun function_type(ctx: *TypeContext, params: **ty.Type, param_count: i32, ret_ty: *ty.Type) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_FUN);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.params = params;
    t.param_count = param_count;
    t.ret_type = ret_ty;
    t.size = 8;  # function pointers are 8 bytes
    t.align = 8;

    ret ok[*ty.Type, str](t);
}

# record_type: create a record type.
# ---
# ctx:         type context
# name:        record name (or nil for anonymous)
# fields:      array of fields
# field_count: number of fields
# ret:         Ok(*Type) on success, Err(str) on failure
pub fun record_type(ctx: *TypeContext, name: str, fields: *ty.Field, field_count: i32) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_RECORD);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    t.fields = fields;
    t.field_count = field_count;

    # calculate size and alignment
    var offset: usize = 0;
    var max_align: usize = 1;

    var i: i32 = 0;
    for (i < field_count) {
        val field: *ty.Field = ?fields[i];
        val ft: *ty.Type = field.ty;

        if (ft != nil) {
            val field_align: usize = ft.align;
            if (field_align > max_align) {
                max_align = field_align;
            }

            # align offset
            if (field_align > 0) {
                offset = (offset + field_align - 1) & ~(field_align - 1);
            }

            field.offset = offset;
            offset = offset + ft.size;
        }

        i = i + 1;
    }

    # final padding
    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    t.size = offset;
    t.align = max_align;

    ret ok[*ty.Type, str](t);
}

# union_type: create a union type.
# ---
# ctx:         type context
# name:        union name (or nil for anonymous)
# fields:      array of fields (variants)
# field_count: number of fields
# ret:         Ok(*Type) on success, Err(str) on failure
pub fun union_type(ctx: *TypeContext, name: str, fields: *ty.Field, field_count: i32) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_UNION);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    t.fields = fields;
    t.field_count = field_count;

    # union size is max of field sizes, alignment is max of alignments
    var max_size: usize = 0;
    var max_align: usize = 1;

    var i: i32 = 0;
    for (i < field_count) {
        val field: *ty.Field = ?fields[i];
        val ft: *ty.Type = field.ty;

        if (ft != nil) {
            if (ft.size > max_size) {
                max_size = ft.size;
            }
            if (ft.align > max_align) {
                max_align = ft.align;
            }
        }

        field.offset = 0;  # all union fields start at offset 0
        i = i + 1;
    }

    # align size
    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    # mach unions are untagged (like C unions) - no tag bytes
    t.size = max_size;
    t.align = max_align;

    ret ok[*ty.Type, str](t);
}

# generic_type: create a generic type parameter.
# ---
# ctx:  type context
# name: parameter name
# ret:  Ok(*Type) on success, Err(str) on failure
pub fun generic_type(ctx: *TypeContext, name: str) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_GENERIC);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    t.size = 0;  # unknown until instantiated
    t.align = 0;

    ret ok[*ty.Type, str](t);
}

# generic_param_type: create a generic parameter reference type.
# ---
# ctx:  type context
# name: parameter name (e.g., "T")
# ret:  Ok(*Type) on success, Err(str) on failure
pub fun generic_param_type(ctx: *TypeContext, name: str) Result[*ty.Type, str] {
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_GENERIC_PARAM);
    if (result_is_err[*ty.Type, str](res)) {
        ret res;
    }

    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    t.size = 8;  # default to pointer-sized for layout computation
    t.align = 8;

    ret ok[*ty.Type, str](t);
}

# --- generic type helpers ---

# is_generic_decl: check if a type is a generic declaration (has type parameters).
# ---
# t: type to check
# ret: true if t has generic parameters
pub fun is_generic_decl(t: *ty.Type) bool {
    if (t == nil) {
        ret false;
    }
    ret t.generic_param_count > 0;
}

# get_generic_param_count: get the number of generic parameters.
# ---
# t: type to check
# ret: number of generic parameters, or 0 if not generic
pub fun get_generic_param_count(t: *ty.Type) i32 {
    if (t == nil) {
        ret 0;
    }
    ret t.generic_param_count;
}

# is_generic_instantiation: check if a type is an instantiated generic type.
# ---
# t: type to check
# ret: true if this is an instantiated generic type (has base_generic or generic_args)
pub fun is_generic_instantiation(t: *ty.Type) bool {
    if (t == nil) {
        ret false;
    }
    ret t.base_generic != nil || t.generic_arg_count > 0;
}

# get_generic_arg_count: get the number of generic arguments (for instantiated types).
# ---
# t: type to check
# ret: number of generic arguments, or 0 if not instantiated
pub fun get_generic_arg_count(t: *ty.Type) i32 {
    if (t == nil) {
        ret 0;
    }
    ret t.generic_arg_count;
}

# get_generic_arg: get a generic argument by index.
# ---
# t:   instantiated type
# idx: argument index
# ret: the concrete type at that index, or nil
pub fun get_generic_arg(t: *ty.Type, idx: i32) *ty.Type {
    if (t == nil || t.generic_args == nil || idx < 0 || idx >= t.generic_arg_count) {
        ret nil;
    }
    ret t.generic_args[idx];
}

# get_generic_param_name: get a generic parameter name by index.
# ---
# t:   generic type
# idx: parameter index
# ret: the parameter name, or nil
pub fun get_generic_param_name(t: *ty.Type, idx: i32) str {
    if (t == nil || t.generic_params == nil || idx < 0 || idx >= t.generic_param_count) {
        ret nil;
    }
    ret t.generic_params[idx].name;
}

# set_generic_params: set the generic parameters on a type.
# ---
# ctx:    type context (for allocation)
# t:      type to modify
# names:  array of parameter names
# count:  number of parameters
# ret:    true on success
pub fun set_generic_params(ctx: *TypeContext, t: *ty.Type, names: *str, count: i32) bool {
    if (ctx == nil || t == nil || count <= 0) {
        ret false;
    }

    val alloc_res: Result[*ty.GenericParam, allocator.AllocError] = allocator.allocator_zalloc[ty.GenericParam](ctx.alloc, count::usize);
    if (result_is_err[*ty.GenericParam, allocator.AllocError](alloc_res)) {
        ret false;
    }

    t.generic_params = result_unwrap_ok[*ty.GenericParam, allocator.AllocError](alloc_res);
    t.generic_param_count = count;

    var i: i32 = 0;
    for (i < count) {
        t.generic_params[i].name = names[i];
        i = i + 1;
    }

    ret true;
}

# set_generic_args: set the generic arguments on an instantiated type.
# ---
# ctx:   type context (for allocation)
# t:     type to modify
# args:  array of concrete types
# count: number of arguments
# ret:   true on success
pub fun set_generic_args(ctx: *TypeContext, t: *ty.Type, args: **ty.Type, count: i32) bool {
    if (ctx == nil || t == nil || count <= 0) {
        ret false;
    }

    val alloc_res: Result[**ty.Type, allocator.AllocError] = allocator.allocator_alloc[*ty.Type](ctx.alloc, count::usize);
    if (result_is_err[**ty.Type, allocator.AllocError](alloc_res)) {
        ret false;
    }

    t.generic_args = result_unwrap_ok[**ty.Type, allocator.AllocError](alloc_res);
    t.generic_arg_count = count;

    var i: i32 = 0;
    for (i < count) {
        t.generic_args[i] = args[i];
        i = i + 1;
    }

    ret true;
}

# set_base_generic: link an instantiated type to its generic base.
# ---
# t:    instantiated type
# base: the original generic type
pub fun set_base_generic(t: *ty.Type, base: *ty.Type) {
    if (t != nil) {
        t.base_generic = base;
    }
}

# get_base_generic: get the base generic type for an instantiated type.
# ---
# t: instantiated type
# ret: the base generic type, or nil
pub fun get_base_generic(t: *ty.Type) *ty.Type {
    if (t == nil) {
        ret nil;
    }
    ret t.base_generic;
}

# get_primitive: get a cached primitive type by kind.
# ---
# ctx:  type context
# kind: primitive type kind
# ret:  the primitive type, or nil on error
pub fun get_primitive(ctx: *TypeContext, kind: ty.TypeKind) *ty.Type {
    val r: Result[*ty.Type, str] = primitive_type(ctx, kind);
    if (result_is_ok[*ty.Type, str](r)) { ret result_unwrap_ok[*ty.Type, str](r); }
    ret nil;
}

# primitive type getter wrappers.
pub fun get_void(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_VOID); }
pub fun get_u8(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_U8); }
pub fun get_u16(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_U16); }
pub fun get_u32(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_U32); }
pub fun get_u64(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_U64); }
pub fun get_i8(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_I8); }
pub fun get_i16(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_I16); }
pub fun get_i32(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_I32); }
pub fun get_i64(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_I64); }
pub fun get_f32(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_F32); }
pub fun get_f64(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_F64); }
pub fun get_ptr(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_PTR); }
pub fun get_nil(ctx: *TypeContext) *ty.Type { ret get_primitive(ctx, ty.TY_NIL); }

# type alias getters — resolve to underlying representations.
pub fun get_bool(ctx: *TypeContext) *ty.Type { ret get_u8(ctx); }

pub fun get_usize(ctx: *TypeContext) *ty.Type {
    if (target.pointer_size(ctx.tgt) == 4) { ret get_u32(ctx); }
    ret get_u64(ctx);
}

pub fun get_isize(ctx: *TypeContext) *ty.Type {
    if (target.pointer_size(ctx.tgt) == 4) { ret get_i32(ctx); }
    ret get_i64(ctx);
}

pub fun get_str(ctx: *TypeContext) *ty.Type {
    if (ctx.cached_str != nil) { ret ctx.cached_str; }
    val r: Result[*ty.Type, str] = pointer_type(ctx, get_u8(ctx), false);
    if (result_is_ok[*ty.Type, str](r)) {
        ctx.cached_str = result_unwrap_ok[*ty.Type, str](r);
        ret ctx.cached_str;
    }
    ret nil;
}
