use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use ty:     mach.compiler.type;
use target: mach.compiler.target;

# mach.compiler.type_context: type factory and cache.
# ---
# provides canonical type instances for primitives and constructors for
# composite types (pointers, arrays, records, unions, functions, generics).
# all type creation goes through this module to enable deduplication.

pub rec TypeContext {
    alloc:      *allocator.Allocator;
    tgt:        target.Target;

    # cached primitive types
    void_type:  *ty.Type;
    u8_type:    *ty.Type;
    u16_type:   *ty.Type;
    u32_type:   *ty.Type;
    u64_type:   *ty.Type;
    i8_type:    *ty.Type;
    i16_type:   *ty.Type;
    i32_type:   *ty.Type;
    i64_type:   *ty.Type;
    f32_type:   *ty.Type;
    f64_type:   *ty.Type;
    ptr_type:   *ty.Type;
    nil_type:   *ty.Type;
    error_type: *ty.Type;
}

# --- initialization ---

pub fun init_context(alloc: *allocator.Allocator, tgt: target.Target) Result[TypeContext, str] {
    if (alloc == nil) {
        ret err[TypeContext, str]("allocator is nil");
    }

    var ctx: TypeContext;
    ctx.alloc = alloc;
    ctx.tgt = tgt;

    # create all primitive types
    val void_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_VOID, "void", 0, 1);
    if (result_is_err[*ty.Type, str](void_res)) { ret err[TypeContext, str]("failed to create void type"); }
    ctx.void_type = result_unwrap_ok[*ty.Type, str](void_res);

    val u8_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_U8, "u8", 1, 1);
    if (result_is_err[*ty.Type, str](u8_res)) { ret err[TypeContext, str]("failed to create u8 type"); }
    ctx.u8_type = result_unwrap_ok[*ty.Type, str](u8_res);

    val u16_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_U16, "u16", 2, 2);
    if (result_is_err[*ty.Type, str](u16_res)) { ret err[TypeContext, str]("failed to create u16 type"); }
    ctx.u16_type = result_unwrap_ok[*ty.Type, str](u16_res);

    val u32_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_U32, "u32", 4, 4);
    if (result_is_err[*ty.Type, str](u32_res)) { ret err[TypeContext, str]("failed to create u32 type"); }
    ctx.u32_type = result_unwrap_ok[*ty.Type, str](u32_res);

    val u64_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_U64, "u64", 8, 8);
    if (result_is_err[*ty.Type, str](u64_res)) { ret err[TypeContext, str]("failed to create u64 type"); }
    ctx.u64_type = result_unwrap_ok[*ty.Type, str](u64_res);

    val i8_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_I8, "i8", 1, 1);
    if (result_is_err[*ty.Type, str](i8_res)) { ret err[TypeContext, str]("failed to create i8 type"); }
    ctx.i8_type = result_unwrap_ok[*ty.Type, str](i8_res);

    val i16_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_I16, "i16", 2, 2);
    if (result_is_err[*ty.Type, str](i16_res)) { ret err[TypeContext, str]("failed to create i16 type"); }
    ctx.i16_type = result_unwrap_ok[*ty.Type, str](i16_res);

    val i32_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_I32, "i32", 4, 4);
    if (result_is_err[*ty.Type, str](i32_res)) { ret err[TypeContext, str]("failed to create i32 type"); }
    ctx.i32_type = result_unwrap_ok[*ty.Type, str](i32_res);

    val i64_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_I64, "i64", 8, 8);
    if (result_is_err[*ty.Type, str](i64_res)) { ret err[TypeContext, str]("failed to create i64 type"); }
    ctx.i64_type = result_unwrap_ok[*ty.Type, str](i64_res);

    val f32_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_F32, "f32", 4, 4);
    if (result_is_err[*ty.Type, str](f32_res)) { ret err[TypeContext, str]("failed to create f32 type"); }
    ctx.f32_type = result_unwrap_ok[*ty.Type, str](f32_res);

    val f64_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_F64, "f64", 8, 8);
    if (result_is_err[*ty.Type, str](f64_res)) { ret err[TypeContext, str]("failed to create f64 type"); }
    ctx.f64_type = result_unwrap_ok[*ty.Type, str](f64_res);

    val ptr_sz: usize = target.pointer_size(?tgt);
    val ptr_al: usize = target.pointer_align(?tgt);

    val ptr_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_PTR, "ptr", ptr_sz, ptr_al);
    if (result_is_err[*ty.Type, str](ptr_res)) { ret err[TypeContext, str]("failed to create ptr type"); }
    ctx.ptr_type = result_unwrap_ok[*ty.Type, str](ptr_res);

    val nil_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_NIL, "nil", 0, 1);
    if (result_is_err[*ty.Type, str](nil_res)) { ret err[TypeContext, str]("failed to create nil type"); }
    ctx.nil_type = result_unwrap_ok[*ty.Type, str](nil_res);

    val err_res: Result[*ty.Type, str] = make_primitive(alloc, ty.TY_ERROR, "<error>", 0, 1);
    if (result_is_err[*ty.Type, str](err_res)) { ret err[TypeContext, str]("failed to create error type"); }
    ctx.error_type = result_unwrap_ok[*ty.Type, str](err_res);

    ret ok[TypeContext, str](ctx);
}

# --- primitive getters ---

pub fun get_void(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.void_type; }
pub fun get_u8(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.u8_type; }
pub fun get_u16(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.u16_type; }
pub fun get_u32(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.u32_type; }
pub fun get_u64(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.u64_type; }
pub fun get_i8(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.i8_type; }
pub fun get_i16(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.i16_type; }
pub fun get_i32(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.i32_type; }
pub fun get_i64(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.i64_type; }
pub fun get_f32(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.f32_type; }
pub fun get_f64(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.f64_type; }
pub fun get_ptr(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.ptr_type; }
pub fun get_nil(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.nil_type; }
pub fun get_error(ctx: *TypeContext) *ty.Type { if (ctx == nil) { ret nil; } ret ctx.error_type; }

# convenience aliases for std types (resolved via def, but these are common)
pub fun get_bool(ctx: *TypeContext) *ty.Type { ret get_u8(ctx); }
pub fun get_usize(ctx: *TypeContext) *ty.Type { ret get_u64(ctx); }
pub fun get_isize(ctx: *TypeContext) *ty.Type { ret get_i64(ctx); }
pub fun get_str(ctx: *TypeContext) *ty.Type { ret get_ptr(ctx); }

# get_primitive: look up a cached primitive by kind.
pub fun get_primitive(ctx: *TypeContext, kind: ty.TypeKind) *ty.Type {
    if (ctx == nil) { ret nil; }
    if (kind == ty.TY_VOID) { ret ctx.void_type; }
    if (kind == ty.TY_U8)   { ret ctx.u8_type; }
    if (kind == ty.TY_U16)  { ret ctx.u16_type; }
    if (kind == ty.TY_U32)  { ret ctx.u32_type; }
    if (kind == ty.TY_U64)  { ret ctx.u64_type; }
    if (kind == ty.TY_I8)   { ret ctx.i8_type; }
    if (kind == ty.TY_I16)  { ret ctx.i16_type; }
    if (kind == ty.TY_I32)  { ret ctx.i32_type; }
    if (kind == ty.TY_I64)  { ret ctx.i64_type; }
    if (kind == ty.TY_F32)  { ret ctx.f32_type; }
    if (kind == ty.TY_F64)  { ret ctx.f64_type; }
    if (kind == ty.TY_PTR)  { ret ctx.ptr_type; }
    if (kind == ty.TY_NIL)  { ret ctx.nil_type; }
    if (kind == ty.TY_ERROR) { ret ctx.error_type; }
    ret nil;
}

# --- type constructors ---

# create_type: allocate a new type with the given kind.
pub fun create_type(ctx: *TypeContext, kind: ty.TypeKind) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, allocator.AllocError] = allocator.allocator_zalloc[ty.Type](ctx.alloc, 1);
    if (result_is_err[*ty.Type, allocator.AllocError](res)) {
        ret err[*ty.Type, str]("out of memory");
    }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, allocator.AllocError](res);
    t.kind = kind;
    ret ok[*ty.Type, str](t);
}

# pointer_type: create a pointer type (*T or &T).
pub fun pointer_type(ctx: *TypeContext, inner: *ty.Type, is_mutable: bool) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_POINTER);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.inner = inner;
    t.is_mutable = is_mutable;
    t.size = target.pointer_size(?ctx.tgt);
    t.align = target.pointer_align(?ctx.tgt);
    ret ok[*ty.Type, str](t);
}

# array_type: create an array type [N]T.
pub fun array_type(ctx: *TypeContext, elem: *ty.Type, len: usize) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_ARRAY);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.inner = elem;
    t.array_len = len;
    if (elem != nil) {
        t.align = elem.align;
        t.size = elem.size * len;
    }
    ret ok[*ty.Type, str](t);
}

# record_type: create a record type.
pub fun record_type(ctx: *TypeContext, name: str, fields: *ty.Field, field_count: i32) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_RECORD);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    t.fields = fields;
    t.field_count = field_count;
    ret ok[*ty.Type, str](t);
}

# union_type: create a union type.
pub fun union_type(ctx: *TypeContext, name: str, fields: *ty.Field, field_count: i32) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_UNION);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    t.fields = fields;
    t.field_count = field_count;
    ret ok[*ty.Type, str](t);
}

# function_type: create a function type.
pub fun function_type(ctx: *TypeContext, params: **ty.Type, param_count: i32, ret_type: *ty.Type) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_FUN);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.params = params;
    t.param_count = param_count;
    t.ret_type = ret_type;
    t.size = target.pointer_size(?ctx.tgt);
    t.align = target.pointer_align(?ctx.tgt);
    ret ok[*ty.Type, str](t);
}

# generic_type: create a generic type placeholder.
pub fun generic_type(ctx: *TypeContext, name: str) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_GENERIC);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    ret ok[*ty.Type, str](t);
}

# generic_param_type: create a generic parameter reference.
pub fun generic_param_type(ctx: *TypeContext, name: str) Result[*ty.Type, str] {
    if (ctx == nil) { ret err[*ty.Type, str]("type context is nil"); }
    val res: Result[*ty.Type, str] = create_type(ctx, ty.TY_GENERIC_PARAM);
    if (result_is_err[*ty.Type, str](res)) { ret res; }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, str](res);
    t.name = name;
    ret ok[*ty.Type, str](t);
}

# --- generic type support ---

# set_generic_args: set the concrete type arguments on an instantiated type.
pub fun set_generic_args(ctx: *TypeContext, t: *ty.Type, args: *ty.Type, count: i32) {
    if (t == nil || ctx == nil) { ret; }
    # args is a pointer to the first element of a **Type array
    # we need to cast it to **Type
    t.generic_args = args::ptr::**ty.Type;
    t.generic_arg_count = count;
}

# set_base_generic: link an instantiated type back to its generic definition.
pub fun set_base_generic(t: *ty.Type, base: *ty.Type) {
    if (t == nil) { ret; }
    t.base_generic = base;
}

# alloc_fields: allocate an array of fields.
pub fun alloc_fields(ctx: *TypeContext, count: i32) Result[*ty.Field, str] {
    if (ctx == nil) { ret err[*ty.Field, str]("type context is nil"); }
    if (count <= 0) { ret ok[*ty.Field, str](nil); }
    val res: Result[*ty.Field, allocator.AllocError] = allocator.allocator_zalloc[ty.Field](ctx.alloc, count::usize);
    if (result_is_err[*ty.Field, allocator.AllocError](res)) {
        ret err[*ty.Field, str]("out of memory");
    }
    ret ok[*ty.Field, str](result_unwrap_ok[*ty.Field, allocator.AllocError](res));
}

# alloc_params: allocate an array of type pointers for function parameters.
pub fun alloc_params(ctx: *TypeContext, count: i32) Result[**ty.Type, str] {
    if (ctx == nil) { ret err[**ty.Type, str]("type context is nil"); }
    if (count <= 0) { ret ok[**ty.Type, str](nil); }
    val res: Result[**ty.Type, allocator.AllocError] = allocator.allocator_zalloc[*ty.Type](ctx.alloc, count::usize);
    if (result_is_err[**ty.Type, allocator.AllocError](res)) {
        ret err[**ty.Type, str]("out of memory");
    }
    ret ok[**ty.Type, str](result_unwrap_ok[**ty.Type, allocator.AllocError](res));
}

# alloc_generic_params: allocate an array of generic parameter records.
pub fun alloc_generic_params(ctx: *TypeContext, count: i32) Result[*ty.GenericParam, str] {
    if (ctx == nil) { ret err[*ty.GenericParam, str]("type context is nil"); }
    if (count <= 0) { ret ok[*ty.GenericParam, str](nil); }
    val res: Result[*ty.GenericParam, allocator.AllocError] = allocator.allocator_zalloc[ty.GenericParam](ctx.alloc, count::usize);
    if (result_is_err[*ty.GenericParam, allocator.AllocError](res)) {
        ret err[*ty.GenericParam, str]("out of memory");
    }
    ret ok[*ty.GenericParam, str](result_unwrap_ok[*ty.GenericParam, allocator.AllocError](res));
}

# --- internal helpers ---

fun make_primitive(alloc: *allocator.Allocator, kind: ty.TypeKind, name: str, size: usize, align: usize) Result[*ty.Type, str] {
    val res: Result[*ty.Type, allocator.AllocError] = allocator.allocator_zalloc[ty.Type](alloc, 1);
    if (result_is_err[*ty.Type, allocator.AllocError](res)) {
        ret err[*ty.Type, str]("out of memory");
    }
    val t: *ty.Type = result_unwrap_ok[*ty.Type, allocator.AllocError](res);
    t.kind = kind;
    t.name = name;
    t.size = size;
    t.align = align;
    ret ok[*ty.Type, str](t);
}
