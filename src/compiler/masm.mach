use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;
use target:    mach.compiler.target;
use ir:        mach.compiler.masm.ir;
use section:   mach.compiler.masm.section;
use sym:       mach.compiler.masm.symbol;

# mach.compiler.masm: machine assembler context.
# ---
# provides the top-level context for machine code generation.
# manages sections, symbols (with O(1) hash map lookup), and debug info.

# initial capacity constants
val INITIAL_SECTION_CAP:    i32 = 8;
val INITIAL_SYMBOL_CAP:     i32 = 8;
val INITIAL_DEBUG_FILE_CAP: i32 = 8;
val INITIAL_DEBUG_LINE_CAP: i32 = 64;

# hash map constants
val SYMMAP_INITIAL_CAP: i32 = 256;
val SYMMAP_EMPTY:       u8 = 0;
val SYMMAP_OCCUPIED:    u8 = 1;
val SYMMAP_TOMBSTONE:   u8 = 2;
val SYMMAP_LOAD_PCT:    i32 = 70;

# SymMap: purpose-built open-addressing hash map for str -> *sym.Symbol.
rec SymMap {
    keys:   *str;
    vals:   **sym.Symbol;
    states: *u8;
    len:    i32;
    cap:    i32;
    alloc:  *allocator.Allocator;
}

# DebugLineEntry: a source-level line mapping for debug info.
# ---
# code_offset: byte offset within .text section
# file_idx:    1-based index into debug file table
# line:        1-based source line number
pub rec DebugLineEntry {
    code_offset: usize;
    file_idx:    u16;
    line:        i32;
}

# Context: the main MASM context.
# ---
# holds all state for machine code generation: sections, symbols, and
# debug information. created per compilation unit, merged by the linker.
pub rec Context {
    alloc:         *allocator.Allocator;
    tgt:           target.Target;
    sections:      **section.Section;
    section_count: i32;
    section_cap:   i32;
    symbols:       **sym.Symbol;
    symbol_count:  i32;
    symbol_cap:    i32;
    sym_map:       SymMap;

    # IR functions (populated by lowering, consumed by ISel/encode)
    ir_funcs:      **ir.Function;
    ir_func_count: i32;
    ir_func_cap:   i32;

    # debug info
    debug_lines:      *DebugLineEntry;
    debug_line_count: i32;
    debug_line_cap:   i32;
    debug_files:      *str;
    debug_file_count: i32;
    debug_file_cap:   i32;
}

# --- context lifecycle ---

# create: create a new MASM context.
pub fun create(alloc: *allocator.Allocator, tgt: target.Target) Result[Context, str] {
    if (alloc == nil) {
        ret err[Context, str]("allocator is nil");
    }

    var m: Context;
    m.alloc = alloc;
    m.tgt = tgt;
    m.sections = nil;
    m.section_count = 0;
    m.section_cap = 0;
    m.symbols = nil;
    m.symbol_count = 0;
    m.symbol_cap = 0;
    m.sym_map = symmap_init(alloc);

    m.ir_funcs = nil;
    m.ir_func_count = 0;
    m.ir_func_cap = 0;

    m.debug_lines = nil;
    m.debug_line_count = 0;
    m.debug_line_cap = 0;
    m.debug_files = nil;
    m.debug_file_count = 0;
    m.debug_file_cap = 0;

    ret ok[Context, str](m);
}

# destroy: free all resources associated with a context.
pub fun destroy(m: *Context) {
    if (m == nil || m.alloc == nil) {
        ret;
    }

    var si: i32 = 0;
    for (si < m.section_count) {
        section.destroy(m.alloc, m.sections[si]);
        si = si + 1;
    }

    var syi: i32 = 0;
    for (syi < m.symbol_count) {
        sym.destroy(m.alloc, m.symbols[syi]);
        syi = syi + 1;
    }

    if (m.sections != nil) {
        allocator.allocator_free[*section.Section](m.alloc, m.sections, m.section_cap::usize);
    }

    if (m.symbols != nil) {
        allocator.allocator_free[*sym.Symbol](m.alloc, m.symbols, m.symbol_cap::usize);
    }

    symmap_dnit(?m.sym_map);

    if (m.ir_funcs != nil) {
        allocator.allocator_free[*ir.Function](m.alloc, m.ir_funcs, m.ir_func_cap::usize);
    }

    if (m.debug_lines != nil) {
        allocator.allocator_free[DebugLineEntry](m.alloc, m.debug_lines, m.debug_line_cap::usize);
    }

    if (m.debug_files != nil) {
        allocator.allocator_free[str](m.alloc, m.debug_files, m.debug_file_cap::usize);
    }
}

# --- section management ---

# get_section: find a section by name.
pub fun get_section(m: *Context, name: str) *section.Section {
    if (m == nil || m.sections == nil || name == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < m.section_count) {
        val s: *section.Section = m.sections[i];
        if (s != nil && s.name != nil && str_equals(s.name, name)) {
            ret s;
        }
        i = i + 1;
    }

    ret nil;
}

# get_section_index: find the index of a section by name.
pub fun get_section_index(m: *Context, name: str) i32 {
    if (m == nil || m.sections == nil || name == nil) {
        ret -1;
    }

    var i: i32 = 0;
    for (i < m.section_count) {
        val s: *section.Section = m.sections[i];
        if (s != nil && s.name != nil && str_equals(s.name, name)) {
            ret i;
        }
        i = i + 1;
    }

    ret -1;
}

# get_or_create_section: find a section by name, or create it if it doesn't exist.
pub fun get_or_create_section(m: *Context, name: str, kind: section.SectionKind) Result[*section.Section, str] {
    if (m == nil) {
        ret err[*section.Section, str]("context is nil");
    }

    val existing: *section.Section = get_section(m, name);
    if (existing != nil) {
        ret ok[*section.Section, str](existing);
    }

    if (m.alloc == nil) {
        ret err[*section.Section, str]("allocator is nil");
    }

    val sec_res: Result[*section.Section, str] = section.create(m.alloc, name, kind, m.tgt.endian);
    if (result_is_err[*section.Section, str](sec_res)) {
        ret sec_res;
    }

    val sec: *section.Section = result_unwrap_ok[*section.Section, str](sec_res);

    # add to sections array
    if (m.section_count >= m.section_cap) {
        var new_cap: i32 = INITIAL_SECTION_CAP;
        if (m.section_cap > 0) {
            new_cap = m.section_cap * 2;
        }

        val r: Result[**section.Section, allocator.AllocError] = allocator.allocator_resize[*section.Section](
            m.alloc, m.sections, m.section_cap::usize, new_cap::usize
        );
        if (result_is_err[**section.Section, allocator.AllocError](r)) {
            ret err[*section.Section, str](result_unwrap_err[**section.Section, allocator.AllocError](r));
        }

        m.sections = result_unwrap_ok[**section.Section, allocator.AllocError](r);
        m.section_cap = new_cap;
    }

    m.sections[m.section_count] = sec;
    m.section_count = m.section_count + 1;

    ret ok[*section.Section, str](sec);
}

# --- symbol management ---

# get_symbol: find a symbol by name using the hash map.
pub fun get_symbol(m: *Context, name: str) *sym.Symbol {
    if (m == nil || name == nil) {
        ret nil;
    }

    ret symmap_get(?m.sym_map, name);
}

# add_symbol: add a symbol to the context.
pub fun add_symbol(m: *Context, s: *sym.Symbol) Result[bool, str] {
    if (m == nil) {
        ret err[bool, str]("context is nil");
    }
    if (s == nil) {
        ret err[bool, str]("symbol is nil");
    }

    # deduplicate via hash map
    if (s.name != nil) {
        if (symmap_get(?m.sym_map, s.name) != nil) {
            ret ok[bool, str](true);
        }
    }

    # grow array if needed
    if (m.symbol_count >= m.symbol_cap) {
        var new_cap: i32 = INITIAL_SYMBOL_CAP;
        if (m.symbol_cap > 0) {
            new_cap = m.symbol_cap * 2;
        }

        val r: Result[**sym.Symbol, allocator.AllocError] = allocator.allocator_resize[*sym.Symbol](
            m.alloc, m.symbols, m.symbol_cap::usize, new_cap::usize
        );
        if (result_is_err[**sym.Symbol, allocator.AllocError](r)) {
            ret err[bool, str](result_unwrap_err[**sym.Symbol, allocator.AllocError](r));
        }

        m.symbols = result_unwrap_ok[**sym.Symbol, allocator.AllocError](r);
        m.symbol_cap = new_cap;
    }

    m.symbols[m.symbol_count] = s;
    m.symbol_count = m.symbol_count + 1;

    # insert into hash map
    if (s.name != nil) {
        symmap_put(?m.sym_map, s.name, s);
    }

    ret ok[bool, str](true);
}

# --- IR function management ---

val INITIAL_IR_FUNC_CAP: i32 = 32;

# add_ir_function: register an IR function in the context.
pub fun add_ir_function(m: *Context, func: *ir.Function) Result[bool, str] {
    if (m == nil || func == nil) { ret err[bool, str]("nil argument"); }

    if (m.ir_func_count >= m.ir_func_cap) {
        var new_cap: i32 = INITIAL_IR_FUNC_CAP;
        if (m.ir_func_cap > 0) { new_cap = m.ir_func_cap * 2; }

        val r: Result[**ir.Function, allocator.AllocError] =
            allocator.allocator_resize[*ir.Function](m.alloc, m.ir_funcs,
                m.ir_func_cap::usize, new_cap::usize);
        if (result_is_err[**ir.Function, allocator.AllocError](r)) {
            ret err[bool, str]("out of memory");
        }
        m.ir_funcs = result_unwrap_ok[**ir.Function, allocator.AllocError](r);
        m.ir_func_cap = new_cap;
    }

    m.ir_funcs[m.ir_func_count] = func;
    m.ir_func_count = m.ir_func_count + 1;
    ret ok[bool, str](true);
}

# --- debug info ---

# add_debug_file: register a source file for debug info.
# ---
# deduplicates: returns existing index if path already registered.
# ret: 1-based file index (0 on error)
pub fun add_debug_file(m: *Context, path: str) u16 {
    if (m == nil || path == nil || m.alloc == nil) {
        ret 0;
    }

    # check for existing entry
    var i: i32 = 0;
    for (i < m.debug_file_count) {
        if (m.debug_files[i] != nil && str_equals(m.debug_files[i], path)) {
            ret (i + 1)::u16;
        }
        i = i + 1;
    }

    # grow array if needed
    if (m.debug_file_count >= m.debug_file_cap) {
        var new_cap: i32 = INITIAL_DEBUG_FILE_CAP;
        if (m.debug_file_cap > 0) {
            new_cap = m.debug_file_cap * 2;
        }
        val r: Result[*str, allocator.AllocError] = allocator.allocator_resize[str](
            m.alloc, m.debug_files, m.debug_file_cap::usize, new_cap::usize
        );
        if (result_is_err[*str, allocator.AllocError](r)) {
            ret 0;
        }
        m.debug_files = result_unwrap_ok[*str, allocator.AllocError](r);
        m.debug_file_cap = new_cap;
    }

    val idx: i32 = m.debug_file_count;
    m.debug_files[idx] = path;
    m.debug_file_count = m.debug_file_count + 1;

    ret (idx + 1)::u16;
}

# add_debug_line: record a debug line entry mapping code offset to source location.
pub fun add_debug_line(m: *Context, code_offset: usize, file_idx: u16, line: i32) {
    if (m == nil || m.alloc == nil || file_idx == 0 || line <= 0) {
        ret;
    }

    # grow array if needed
    if (m.debug_line_count >= m.debug_line_cap) {
        var new_cap: i32 = INITIAL_DEBUG_LINE_CAP;
        if (m.debug_line_cap > 0) {
            new_cap = m.debug_line_cap * 2;
        }
        val r: Result[*DebugLineEntry, allocator.AllocError] = allocator.allocator_resize[DebugLineEntry](
            m.alloc, m.debug_lines, m.debug_line_cap::usize, new_cap::usize
        );
        if (result_is_err[*DebugLineEntry, allocator.AllocError](r)) {
            ret;
        }
        m.debug_lines = result_unwrap_ok[*DebugLineEntry, allocator.AllocError](r);
        m.debug_line_cap = new_cap;
    }

    val idx: i32 = m.debug_line_count;
    m.debug_lines[idx].code_offset = code_offset;
    m.debug_lines[idx].file_idx = file_idx;
    m.debug_lines[idx].line = line;
    m.debug_line_count = m.debug_line_count + 1;
}

# --- SymMap: inline str -> *sym.Symbol hash map ---

fun fnv1a_str(s: str) u64 {
    var h: u64 = 14695981039346656037;
    if (s == nil) {
        ret h;
    }
    var i: i32 = 0;
    for (s[i] != 0) {
        h = h ^ s[i]::u64;
        h = h * 1099511628211;
        i = i + 1;
    }
    ret h;
}

fun symmap_init(alloc: *allocator.Allocator) SymMap {
    var m: SymMap;
    m.alloc = alloc;
    m.keys = nil;
    m.vals = nil;
    m.states = nil;
    m.len = 0;
    m.cap = 0;
    ret m;
}

fun symmap_dnit(m: *SymMap) {
    if (m == nil || m.alloc == nil) {
        ret;
    }
    if (m.keys != nil) {
        allocator.allocator_free[str](m.alloc, m.keys, m.cap::usize);
    }
    if (m.vals != nil) {
        allocator.allocator_free[*sym.Symbol](m.alloc, m.vals, m.cap::usize);
    }
    if (m.states != nil) {
        allocator.allocator_free[u8](m.alloc, m.states, m.cap::usize);
    }
    m.keys = nil;
    m.vals = nil;
    m.states = nil;
    m.len = 0;
    m.cap = 0;
}

fun symmap_get(m: *SymMap, key: str) *sym.Symbol {
    if (m == nil || m.cap == 0 || key == nil) {
        ret nil;
    }
    val h: u64 = fnv1a_str(key);
    var idx: i32 = (h % m.cap::u64)::i32;
    var probes: i32 = 0;
    for (probes < m.cap) {
        if (m.states[idx] == SYMMAP_EMPTY) {
            ret nil;
        }
        if (m.states[idx] == SYMMAP_OCCUPIED && str_equals(m.keys[idx], key)) {
            ret m.vals[idx];
        }
        idx = idx + 1;
        if (idx >= m.cap) {
            idx = 0;
        }
        probes = probes + 1;
    }
    ret nil;
}

fun symmap_put(m: *SymMap, key: str, value: *sym.Symbol) {
    if (m == nil || key == nil) {
        ret;
    }

    # grow if needed
    if (m.cap == 0 || (m.len + 1) * 100 > m.cap * SYMMAP_LOAD_PCT) {
        symmap_grow(m);
    }
    if (m.cap == 0) {
        ret;
    }

    val h: u64 = fnv1a_str(key);
    var idx: i32 = (h % m.cap::u64)::i32;
    var probes: i32 = 0;
    for (probes < m.cap) {
        if (m.states[idx] == SYMMAP_EMPTY || m.states[idx] == SYMMAP_TOMBSTONE) {
            m.keys[idx] = key;
            m.vals[idx] = value;
            m.states[idx] = SYMMAP_OCCUPIED;
            m.len = m.len + 1;
            ret;
        }
        if (m.states[idx] == SYMMAP_OCCUPIED && str_equals(m.keys[idx], key)) {
            m.vals[idx] = value;
            ret;
        }
        idx = idx + 1;
        if (idx >= m.cap) {
            idx = 0;
        }
        probes = probes + 1;
    }
}

fun symmap_grow(m: *SymMap) {
    var new_cap: i32 = SYMMAP_INITIAL_CAP;
    if (m.cap > 0) {
        new_cap = m.cap * 2;
    }

    val kr: Result[*str, allocator.AllocError] = allocator.allocator_alloc[str](m.alloc, new_cap::usize);
    if (result_is_err[*str, allocator.AllocError](kr)) {
        ret;
    }
    val new_keys: *str = result_unwrap_ok[*str, allocator.AllocError](kr);

    val vr: Result[**sym.Symbol, allocator.AllocError] = allocator.allocator_alloc[*sym.Symbol](m.alloc, new_cap::usize);
    if (result_is_err[**sym.Symbol, allocator.AllocError](vr)) {
        allocator.allocator_free[str](m.alloc, new_keys, new_cap::usize);
        ret;
    }
    val new_vals: **sym.Symbol = result_unwrap_ok[**sym.Symbol, allocator.AllocError](vr);

    val sr: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](m.alloc, new_cap::usize);
    if (result_is_err[*u8, allocator.AllocError](sr)) {
        allocator.allocator_free[str](m.alloc, new_keys, new_cap::usize);
        allocator.allocator_free[*sym.Symbol](m.alloc, new_vals, new_cap::usize);
        ret;
    }
    val new_states: *u8 = result_unwrap_ok[*u8, allocator.AllocError](sr);

    # zero the states array
    mem.raw_zero(new_states::ptr, new_cap::usize);

    # rehash existing entries
    val old_keys: *str = m.keys;
    val old_vals: **sym.Symbol = m.vals;
    val old_states: *u8 = m.states;
    val old_cap: i32 = m.cap;

    m.keys = new_keys;
    m.vals = new_vals;
    m.states = new_states;
    m.cap = new_cap;
    m.len = 0;

    if (old_keys != nil) {
        var i: i32 = 0;
        for (i < old_cap) {
            if (old_states[i] == SYMMAP_OCCUPIED) {
                symmap_put(m, old_keys[i], old_vals[i]);
            }
            i = i + 1;
        }

        allocator.allocator_free[str](m.alloc, old_keys, old_cap::usize);
        allocator.allocator_free[*sym.Symbol](m.alloc, old_vals, old_cap::usize);
        allocator.allocator_free[u8](m.alloc, old_states, old_cap::usize);
    }
}
