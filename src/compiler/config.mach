use      std.types.bool;
use      std.types.string;
use      std.types.list;
use      std.types.size;
use      std.types.result;
use      std.types.option;
use      std.types.semver;
use      std.data.toml;
use mem: std.system.memory;

use fs:      std.io.filesystem;
use console: std.io.console;

val CONFIG_DEPENDENCY_INITIAL_CAPACITY: usize = 4;
val CONFIG_TARGET_INITIAL_CAPACITY:     usize = 4;

pub def ConfigTargetMode:              str;
pub val CONFIG_TARGET_MODE_EXECUTABLE: ConfigTargetMode = "executable";
pub val CONFIG_TARGET_MODE_LIBRARY:    ConfigTargetMode = "library";
pub val CONFIG_TARGET_MODE_SHARED:     ConfigTargetMode = "shared";

pub fun (this: ConfigTargetMode) is_valid() bool {
    if ((this::str).equals(CONFIG_TARGET_MODE_EXECUTABLE)) { ret true; }
    if ((this::str).equals(CONFIG_TARGET_MODE_LIBRARY))    { ret true; }
    if ((this::str).equals(CONFIG_TARGET_MODE_SHARED))     { ret true; }
    ret false;
}

## Project configuration structure.
## Stores information related to the [project] section of the config file.
pub rec ConfigProject {
    id:      str;    ## unique project identifier
    name:    str;    ## human readable project name
    version: Semver; ## project version
    src:     str;    ## source directory
    dep:     str;    ## dependency directory
    target:  str;    ## selected build target
}

## Build target configuration structure.
## Stores information related to individual build targets defined in the config file.
pub rec ConfigTarget {
    name:          str;               ## target name
    triple:        str;               ## target triple
    entrypoint:    str;               ## entrypoint file
    artifacts:     str;               ## output artifacts directory
    output:        str;               ## output binary path
    mode:          ConfigTargetMode;  ## build mode (executable|library|shared)
    debug:         bool;              ## enable debug info for this target
    optimize:      bool;              ## enable optimizations for this target
    emit_ast:      bool;              ## emit AST files
    emit_ir:       bool;              ## emit intermediate representation files
    emit_asm:      bool;              ## emit assembly files
    emit_obj:      bool;              ## emit object files
    no_pie:        bool;              ## disable position-independent executable generation
}

pub def ConfigDependencyType:          str;
pub val CONFIG_DEPENDENCY_TYPE_REMOTE: ConfigDependencyType = "remote";
pub val CONFIG_DEPENDENCY_TYPE_LOCAL:  ConfigDependencyType = "local";

pub fun (this: ConfigDependencyType) is_valid() bool {
    if ((this::str).equals(CONFIG_DEPENDENCY_TYPE_REMOTE)) { ret true; }
    if ((this::str).equals(CONFIG_DEPENDENCY_TYPE_LOCAL))  { ret true; }
    ret false;
}

## Represents a dependency version or selector.
## Possible values:
## - semantic version (e.g., "1.2.3")
## - branch name (e.g., "branch/main")
## - commit hash (e.g., "commit/abc123def")
pub def ConfigDependencyVersionType:           u8;
pub val CONFIG_DEPENDENCY_VERSION_TYPE_SEMVER: ConfigDependencyVersionType = 1;
pub val CONFIG_DEPENDENCY_VERSION_TYPE_BRANCH: ConfigDependencyVersionType = 3;
pub val CONFIG_DEPENDENCY_VERSION_TYPE_COMMIT: ConfigDependencyVersionType = 4;

pub rec ConfigDependencyVersion {
    type: ConfigDependencyVersionType;
    data: uni {
        semver: Semver;
        branch: str;
        commit: str;
    }
}

## Dependency configuration structure.
## Stores information related to individual dependencies defined in the config file.
pub rec ConfigDependency {
    name:    str;                     # dependency key (alias)
    type:    ConfigDependencyType;    # dependency type: remote|local
    path:    str;                     # source path or URL (used by dep tooling)
    version: ConfigDependencyVersion; # optional semantic version/selector (required for remote)
}

## Main configuration structure.
## Stores information from a Mach project configuration file.
pub rec Config {
    source:       String; ## raw source of the config file

    project:      ConfigProject;          ## [project] section
    targets:      List[ConfigTarget];     ## [targets] tables
    dependencies: List[ConfigDependency]; ## [deps] tables
}

## Initializes a Config record.
## ---
## ret: optional error message on failure
pub fun (this: *Config) init() Option[str] {
    mem.zero[Config](this, 1);

    val opt_targets_init: Option[str] = this.targets.init(CONFIG_TARGET_INITIAL_CAPACITY);
    if (opt_targets_init.is_some()) {
        ret opt_targets_init;
    }

    val opt_dependencies_init: Option[str] = this.dependencies.init(CONFIG_DEPENDENCY_INITIAL_CAPACITY);
    if (opt_dependencies_init.is_some()) {
        ret opt_dependencies_init;
    }

    ret none[str]();
}

## Deinitializes a Config record.
pub fun (this: *Config) dnit() {
    this.source.dnit();
    this.dependencies.dnit();
    this.targets.dnit();

    mem.zero[Config](this, 1);
}

## Find a target by name.
## ---
## name: target name
## ret:  optional pointer to the ConfigTarget if found
pub fun (this: *Config) target_find(name: str) Option[*ConfigTarget] {
    var i: usize = 0;
    for (i < this.targets.len) {
        val opt_targets_get: Option[*ConfigTarget] = this.targets.get_ptr(i);
        if (opt_targets_get.is_some()) {
            val target: *ConfigTarget = opt_targets_get.unwrap();
            if (target.name.equals(name)) {
                ret some[*ConfigTarget](target);
            }
        }
        i = i + 1;
    }
    ret none[*ConfigTarget]();
}

## Parse the [project] section of the config file.
## ---
## project_table: pointer to the list of TomlProperty representing the project table
## ret:           Result containing ConfigProject or error message on failure
fun parse_project_section(project_table: *List[TomlProperty]) Result[ConfigProject, str] {
    var project: ConfigProject;

    # [project].id
    val opt_id: Option[str] = get_string_from_table(project_table, "id");
    if (opt_id.is_none()) {
        ret err[ConfigProject, str]("project section missing 'id'");
    }
    project.id = opt_id.unwrap();

    # [project].name
    val opt_name: Option[str] = get_string_from_table(project_table, "name");
    if (opt_name.is_none()) {
        ret err[ConfigProject, str]("project section missing 'name'");
    }
    project.name = opt_name.unwrap();

    # [project].version
    val opt_version: Option[str] = get_string_from_table(project_table, "version");
    if (opt_version.is_none()) {
        ret err[ConfigProject, str]("project section missing 'version'");
    }
    val opt_version_parse: Result[Semver, str] = semver_parse(opt_version.unwrap());
    if (opt_version_parse.is_err()) {
        ret err[ConfigProject, str](opt_version_parse.unwrap_err());
    }
    project.version = opt_version_parse.unwrap_ok();

    # [project].src
    val opt_src: Option[str] = get_string_from_table(project_table, "src");
    if (opt_src.is_none()) {
        ret err[ConfigProject, str]("project section missing 'src'");
    }
    project.src = opt_src.unwrap();

    # [project].dep
    val opt_dep: Option[str] = get_string_from_table(project_table, "dep");
    if (opt_dep.is_none()) {
        ret err[ConfigProject, str]("project section missing 'dep'");
    }
    project.dep = opt_dep.unwrap();

    # [project].target
    val opt_target: Option[str] = get_string_from_table(project_table, "target");
    if (opt_target.is_none()) {
        ret err[ConfigProject, str]("project section missing 'target'");
    }
    project.target = opt_target.unwrap();

    ret ok[ConfigProject, str](project);
}

## Parse a dependency entry from the config file.
## ---
## dep_name:  name of the dependency
## dep_table: pointer to the list of TomlProperty representing the dependency table
## ret:       Result containing ConfigDependency or error message on failure
fun parse_dependency(dep_name: str, dep_table: *List[TomlProperty]) Result[ConfigDependency, str] {
    var dep: ConfigDependency;
    dep.name = dep_name;

    # [dep.<name>].type
    val opt_type: Option[str] = get_string_from_table(dep_table, "type");
    if (opt_type.is_none()) {
        ret err[ConfigDependency, str]("dependency missing 'type' field");
    }
    val type_value: ConfigDependencyType = opt_type.unwrap();
    if (type_value.is_valid() == false) {
        ret err[ConfigDependency, str]("dependency 'type' must be 'remote' or 'local'");
    }
    dep.type = type_value;

    # [dep.<name>].path
    val opt_path: Option[str] = get_string_from_table(dep_table, "path");
    if (opt_path.is_none()) {
        ret err[ConfigDependency, str]("dependency missing 'path' field");
    }
    dep.path = opt_path.unwrap();

    # [dep.<name>].version
    if ((dep.type::str).equals(CONFIG_DEPENDENCY_TYPE_REMOTE)) {
        val opt_version: Option[str] = get_string_from_table(dep_table, "version");
        if (opt_version.is_none()) {
            ret err[ConfigDependency, str]("remote dependency missing 'version'");
        }

        # raw version string
        val version: str = opt_version.unwrap();

        if (version.starts_with("branch/")) {
            # handle 'branch/' prefix
            val opt_substring: Option[str] = version.substring(7, version.len);
            if (opt_substring.is_none() || opt_substring.unwrap().len == 0) {
                ret err[ConfigDependency, str]("invalid branch name in dependency version");
            }

            dep.version.type        = CONFIG_DEPENDENCY_VERSION_TYPE_BRANCH;
            dep.version.data.branch = opt_substring.unwrap();
        }
        or (version.starts_with("commit/")) {
            # handle 'commit/' prefix
            val opt_substring: Option[str] = version.substring(7, version.len);
            if (opt_substring.is_none() || opt_substring.unwrap().len == 0) {
                ret err[ConfigDependency, str]("invalid commit hash in dependency version");
            }

            dep.version.type        = CONFIG_DEPENDENCY_VERSION_TYPE_COMMIT;
            dep.version.data.commit = opt_substring.unwrap();
        }
        or {
            # assume semantic version
            val res_semver_parse: Result[Semver, str] = semver_parse(version);
            if (res_semver_parse.is_err()) {
                ret err[ConfigDependency, str](res_semver_parse.unwrap_err());
            }
            
            # double-check validity
            val semver: Semver = res_semver_parse.unwrap_ok();
            if (semver.is_valid() == false) {
                ret err[ConfigDependency, str]("invalid semantic version in dependency version");
            }

            dep.version.type        = CONFIG_DEPENDENCY_VERSION_TYPE_SEMVER;
            dep.version.data.semver = semver;
        }
    } or {
        ret err[ConfigDependency, str]("local dependencies cannot have a 'version' field");
    }

    ret ok[ConfigDependency, str](dep);
}

## Parse a target entry from the config file.
## ---
## target_name:  name of the target
## target_table: pointer to the list of TomlProperty representing the target table
## ret:          Result containing ConfigTarget or error message on failure
fun parse_target(target_name: str, target_table: *List[TomlProperty]) Result[ConfigTarget, str] {
    var target: ConfigTarget;
    target.name = target_name;

    # [target.<name>].triple
    val opt_triple: Option[str] = get_string_from_table(target_table, "triple");
    if (opt_triple.is_none()) {
        ret err[ConfigTarget, str]("target missing 'triple' field");
    }
    target.triple = opt_triple.unwrap();

    # [target.<name>].entrypoint
    val opt_entrypoint: Option[str] = get_string_from_table(target_table, "entrypoint");
    if (opt_entrypoint.is_none()) {
        ret err[ConfigTarget, str]("target missing 'entrypoint' field");
    }
    target.entrypoint = opt_entrypoint.unwrap();

    # [target.<name>].artifacts
    val opt_artifacts: Option[str] = get_string_from_table(target_table, "artifacts");
    if (opt_artifacts.is_none()) {
        ret err[ConfigTarget, str]("target missing 'artifacts' field");
    }
    target.artifacts = opt_artifacts.unwrap();

    # [target.<name>].output
    val opt_output: Option[str] = get_string_from_table(target_table, "output");
    if (opt_output.is_none()) {
        ret err[ConfigTarget, str]("target missing 'output' field");
    }
    target.output = opt_output.unwrap();

    # [target.<name>].mode
    val opt_mode: Option[str] = get_string_from_table(target_table, "mode");
    if (opt_mode.is_none()) {
        ret err[ConfigTarget, str]("target missing 'mode' field");
    }
    val mode_value: ConfigTargetMode = opt_mode.unwrap();
    if (mode_value.is_valid() == false) {
        ret err[ConfigTarget, str]("target 'mode' must be 'executable', 'library', or 'shared'");
    }
    target.mode = mode_value;

    # [target.<name>].debug
    val opt_debug: Option[bool] = get_bool_from_table(target_table, "debug");
    if (opt_debug.is_none()) {
        ret err[ConfigTarget, str]("target missing 'debug' field");
    }
    target.debug = opt_debug.unwrap();

    # [target.<name>].optimize
    val opt_optimize: Option[bool] = get_bool_from_table(target_table, "optimize");
    if (opt_optimize.is_none()) {
        ret err[ConfigTarget, str]("target missing 'optimize' field");
    }
    target.optimize = opt_optimize.unwrap();

    # [target.<name>].emit-ast
    val opt_emit_ast: Option[bool] = get_bool_from_table(target_table, "emit-ast");
    if (opt_emit_ast.is_none()) {
        ret err[ConfigTarget, str]("target missing 'emit-ast' field");
    }
    target.emit_ast = opt_emit_ast.unwrap();

    # [target.<name>].emit-ir
    val opt_emit_ir: Option[bool] = get_bool_from_table(target_table, "emit-ir");
    if (opt_emit_ir.is_none()) {
        ret err[ConfigTarget, str]("target missing 'emit-ir' field");
    }
    target.emit_ir = opt_emit_ir.unwrap();

    # [target.<name>].emit-asm
    val opt_emit_asm: Option[bool] = get_bool_from_table(target_table, "emit-asm");
    if (opt_emit_asm.is_none()) {
        ret err[ConfigTarget, str]("target missing 'emit-asm' field");
    }
    target.emit_asm = opt_emit_asm.unwrap();

    # [target.<name>].emit-obj
    val opt_emit_obj: Option[bool] = get_bool_from_table(target_table, "emit-obj");
    if (opt_emit_obj.is_none()) {
        ret err[ConfigTarget, str]("target missing 'emit-obj' field");
    }
    target.emit_obj = opt_emit_obj.unwrap();

    # [target.<name>].no-pie
    val no_pie_opt: Option[bool] = get_bool_from_table(target_table, "no-pie");
    if (no_pie_opt.is_none()) {
        ret err[ConfigTarget, str]("target missing 'no-pie' field");
    }
    target.no_pie = no_pie_opt.unwrap();

    ret ok[ConfigTarget, str](target);
}

## Handle config parsing error by deinitializing and returning an error.
## ---
## config:  pointer to the Config record
## message: error message
## ret:     Result containing error message
fun config_error(config: *Config, message: str) Result[Config, str] {
    config.dnit();
    ret err[Config, str](message);
}

## Reads and parses a Mach project configuration file.
## ---
## path: path to the configuration file
## ret:  Result containing the parsed Config or an error message on failure
pub fun config_read(path: str) Result[Config, str] {
    var config: Config;
    config.init();

    # read file contents
    val res_read_all: Result[[]u8, str] = fs.read_all(path);
    if (res_read_all.is_err()) {
        ret err[Config, str](res_read_all.unwrap_err());
    }

    config.source = res_read_all.unwrap_ok();
    
    # parse toml
    val res_parse_toml: Result[TomlValue, str] = parse_toml(config.source.as_str());
    if (res_parse_toml.is_err()) {
        ret err[Config, str](res_parse_toml.unwrap_err());
    }

    # process root table
    val root: TomlValue = res_parse_toml.unwrap_ok();

    val opt_root_table: Option[*List[TomlProperty]] = root.as_table();
    if (opt_root_table.is_none()) {
        root.dnit();
        ret err[Config, str]("invalid config: expected table at root");
    }
    
    val root_table: *List[TomlProperty] = opt_root_table.unwrap();
    
    var project_section_seen: bool  = false;
    val deps_prefix:          str   = "deps.";
    val targets_prefix:       str   = "targets.";

    var i: usize = 0;
    for (i < root_table.len) {
        val opt_get_prop: Option[TomlProperty] = root_table.get(i);
        if (opt_get_prop.is_none()) {
            i = i + 1;
            cnt;
        }

        val prop: TomlProperty = opt_get_prop.unwrap();

        # process [project] section
        if (prop.key.equals("project")) {
            if (project_section_seen) {
                ret config_error(?config, "duplicate [project] section");
            }

            val project_table_opt: Option[*List[TomlProperty]] = prop.value.as_table();
            if (project_table_opt.is_none()) {
                ret config_error(?config, "[project] must be a table");
            }

            val project_res: Result[ConfigProject, str] = parse_project_section(project_table_opt.unwrap());
            if (project_res.is_err()) {
                ret config_error(?config, project_res.unwrap_err());
            }
            config.project = project_res.unwrap_ok();
            
            project_section_seen = true;

            i = i + 1;
            cnt;
        }

        # process individual dependency entries
        if (prop.key.starts_with(deps_prefix)) {
            val deps_table_opt: Option[*List[TomlProperty]] = prop.value.as_table();
            if (deps_table_opt.is_none()) {
                ret config_error(?config, "dependency entry must be a table");
            }

            val dep_name_opt: Option[str] = prop.key.substring(deps_prefix.len, prop.key.len);
            if (dep_name_opt.is_none()) {
                ret config_error(?config, "invalid dependency name");
            }

            val dep_name: str = dep_name_opt.unwrap();
            if (dep_name.len == 0) {
                ret config_error(?config, "dependency name cannot be empty");
            }

            val dep_res: Result[ConfigDependency, str] = parse_dependency(dep_name, deps_table_opt.unwrap());
            if (dep_res.is_err()) {
                ret config_error(?config, dep_res.unwrap_err());
            }

            val opt_push: Option[str] = config.dependencies.push(dep_res.unwrap_ok());
            if (opt_push.is_some()) {
                ret config_error(?config, opt_push.unwrap());
            }

            i = i + 1;
            cnt;
        }

        # process individual target entries
        if (prop.key.starts_with(targets_prefix)) {
            val target_table_opt: Option[*List[TomlProperty]] = prop.value.as_table();
            if (target_table_opt.is_none()) {
                ret config_error(?config, "target entry must be a table");
            }

            val opt_name: Option[str] = prop.key.substring(targets_prefix.len, prop.key.len);
            if (opt_name.is_none()) {
                ret config_error(?config, "invalid target name");
            }

            var target_name: str = opt_name.unwrap();

            val target_res: Result[ConfigTarget, str] = parse_target(target_name, target_table_opt.unwrap());
            if (target_res.is_err()) {
                ret config_error(?config, target_res.unwrap_err());
            }

            val opt_push: Option[str] = config.targets.push(target_res.unwrap_ok());
            if (opt_push.is_some()) {
                ret config_error(?config, opt_push.unwrap());
            }

            i = i + 1;
            cnt;
        }

        i = i + 1;
    }

    if (project_section_seen == false) {
        ret config_error(?config, "missing [project] section");
    }

    if (config.targets.len == 0) {
        ret config_error(?config, "project configuration missing targets");
    }

    ret ok[Config, str](config);
}

## Retrieve a string value from a TOML table.
## ---
## table: pointer to the list of TomlProperty
## key:   key to look for
## ret:   optional value if found
fun get_string_from_table(table: *List[TomlProperty], key: str) Option[str] {
    var i: usize = 0;
    for (i < table.len) {
        val opt_get_prop: Option[TomlProperty] = table.get(i);
        if (opt_get_prop.is_some()) {
            val prop: TomlProperty = opt_get_prop.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_string();
            }
        }
        i = i + 1;
    }
    ret none[str]();
}

## Retrieve an integer value from a TOML table.
## ---
## table: pointer to the list of TomlProperty
## key:   key to look for
## ret:   optional value if found
fun get_integer_from_table(table: *List[TomlProperty], key: str) Option[i64] {
    var i: usize = 0;
    for (i < table.len) {
        val opt_get_prop: Option[TomlProperty] = table.get(i);
        if (opt_get_prop.is_some()) {
            val prop: TomlProperty = opt_get_prop.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_integer();
            }
        }
        i = i + 1;
    }
    ret none[i64]();
}

## Retrieve a boolean value from a TOML table.
## ---
## table: pointer to the list of TomlProperty
## key:   key to look for
## ret:   optional value if found
fun get_bool_from_table(table: *List[TomlProperty], key: str) Option[bool] {
    var i: usize = 0;
    for (i < table.len) {
        val opt_get_prop: Option[TomlProperty] = table.get(i);
        if (opt_get_prop.is_some()) {
            val prop: TomlProperty = opt_get_prop.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_bool();
            }
        }
        i = i + 1;
    }
    ret none[bool]();
}

## Retrieve a table value from a TOML table.
## ---
## table: pointer to the list of TomlProperty
## key:   key to look for
## ret:   optional value if found
fun get_table_from_table(table: *List[TomlProperty], key: str) Option[*List[TomlProperty]] {
    var i: usize = 0;
    for (i < table.len) {
        val opt_get_prop: Option[TomlProperty] = table.get(i);
        if (opt_get_prop.is_some()) {
            val prop: TomlProperty = opt_get_prop.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_table();
            }
        }
        i = i + 1;
    }
    ret none[*List[TomlProperty]]();
}

## Retrieve an array value from a TOML table.
## ---
## table: pointer to the list of TomlProperty
## key:   key to look for
## ret:   optional value if found
fun get_array_from_table(table: *List[TomlProperty], key: str) Option[*List[TomlValue]] {
    var i: usize = 0;
    for (i < table.len) {
        val opt_get_prop: Option[TomlProperty] = table.get(i);
        if (opt_get_prop.is_some()) {
            val prop: TomlProperty = opt_get_prop.unwrap();
            if (prop.key.equals(key)) {
                ret prop.value.as_array();
            }
        }
        i = i + 1;
    }
    ret none[*List[TomlValue]]();
}
