# mach.compiler.target.abi: calling convention interface
#
# defines the abstract ABI interface as a function-pointer record. concrete
# implementations (sysv64, win64, etc.) populate the record with their own
# classification and register assignment logic.

use std.types.bool;
use std.types.size;
use std.types.string;

use isa: mach.compiler.target.isa;

pub def ParamClass: u8;
pub val CLASS_GP:    ParamClass = 0;
pub val CLASS_FP:    ParamClass = 1;
pub val CLASS_STACK: ParamClass = 2;
pub val CLASS_SRET:  ParamClass = 3;
pub val CLASS_BYREF: ParamClass = 4;

# describes where a single parameter or return value is placed
# ---
# class:  classification (CLASS_GP, CLASS_FP, CLASS_STACK, etc.)
# reg:    register id if passed in register (-1 if stack)
# offset: stack offset in bytes if passed on stack
# size:   size in bytes of this slot
pub rec ParamSlot {
    class:  ParamClass;
    reg:    i32;
    reg2:   i32;
    offset: i64;
    size:   usize;
}

# calling convention interface
#
# all function pointers take ctx as first argument, allowing the backend to
# carry ABI-specific state.
# ---
# ctx:             opaque backend state
# name:            ABI name ("sysv64", "win64", etc.)
# classify_param:  classify parameter: (ctx, index, size, align, is_float, is_aggregate, gp_used, fp_used) -> ParamSlot
# classify_return: classify return value: (ctx, size, align, is_float, is_aggregate) -> ParamSlot
# gp_param_regs:   return GP registers used for parameter passing
# fp_param_regs:   return FP registers used for parameter passing
# callee_saved:    return callee-saved registers
# stack_align:     return required stack alignment in bytes
# red_zone:        return red zone size in bytes (0 if none)
pub rec ABI {
    ctx:             ptr;
    name:            str;
    classify_param:  fun(ptr, i32, usize, usize, bool, bool, i32, i32) ParamSlot;
    classify_return: fun(ptr, usize, usize, bool, bool) ParamSlot;
    gp_param_regs:   fun(ptr) isa.RegisterFile;
    fp_param_regs:   fun(ptr) isa.RegisterFile;
    callee_saved:    fun(ptr) isa.RegisterFile;
    stack_align:     fun(ptr) usize;
    red_zone:        fun(ptr) usize;
    init_va_list:    fun(ptr, ptr);
    va_save_size:    fun(ptr) usize;
    emit_va_save:    fun(ptr, *isa.InstBuf, i32, i64);
}
