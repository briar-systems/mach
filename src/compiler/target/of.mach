use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use mach.compiler.target.of.buf;

# mach.compiler.target.of: object format and debug information interfaces.
# ---
# abstracts all object file writing and debug info generation behind
# function pointers. the emission stage works identically regardless
# of output format (ELF, Mach-O, PE/COFF, raw binary) or debug format
# (DWARF, CodeView).
#
# OF defines record shapes (OFSymbol, OFReloc, DISubprogram, etc.)
# but NO constants. binding, kind, and relocation type values come
# from MASM and are passed through as opaque u8/u32 values.
# OF implementations map them internally to format-specific values.

# OFSymbol: a symbol to be written to the object file.
# binding and kind use abstract constants defined by MASM.
pub rec OFSymbol {
    name:    str;
    section: u64;    # section index (0 = undefined/external)
    offset:  usize;  # offset within section
    size:    usize;
    binding: u8;     # abstract binding (local/global/weak)
    kind:    u8;     # abstract kind (func/object/section/file)
}

# OFReloc: a relocation entry.
# rtype uses abstract relocation constants defined by MASM.
pub rec OFReloc {
    section: u64;    # section the reloc applies to
    offset:  usize;  # offset within that section
    symbol:  u64;    # symbol index
    rtype:   u32;    # abstract relocation type
    addend:  i64;
}

# ObjSection: a section read from an object file.
pub rec ObjSection {
    name:  str;
    kind:  u8;       # abstract section kind (SEC_TEXT, SEC_DATA, etc.)
    flags: u32;      # abstract section flags (FLAG_WRITE, FLAG_EXEC, FLAG_ALLOC)
    data:  *u8;
    size:  usize;
    align: usize;
}

# ObjSymbol: a symbol read from an object file.
pub rec ObjSymbol {
    name:    str;
    binding: u8;     # abstract binding (BIND_LOCAL, BIND_GLOBAL, BIND_WEAK)
    kind:    u8;     # abstract kind (SYM_FUNC, SYM_OBJECT, etc.)
    section: i32;    # section index (-1 = undefined/external)
    offset:  usize;
    size:    usize;
    defined: bool;
}

# ObjReloc: a relocation read from an object file.
pub rec ObjReloc {
    section:     i32;    # index into ObjFile.sections
    offset:      usize;  # offset within that section
    symbol_name: str;    # resolved symbol name (not an index)
    rtype:       u8;     # abstract relocation type (RELOC_*)
    addend:      i64;
}

# ObjFile: a complete parsed object file.
pub rec ObjFile {
    sections:    *ObjSection;
    sec_count:   i32;
    symbols:     *ObjSymbol;
    sym_count:   i32;
    relocs:      *ObjReloc;
    reloc_count: i32;
    source_path: str;
    alloc:       *allocator.Allocator;
}

# ObjectReader: interface for reading relocatable object files.
# ---
# mirrors ObjWriter. selected per-target.
# the linker uses this interface — no format-specific code.
pub rec ObjectReader {
    ctx: ptr;

    # read a .o file from disk into an ObjFile.
    read: fun(ptr, str, *allocator.Allocator) *ObjFile;

    # free all memory associated with an ObjFile.
    destroy_obj: fun(ptr, *ObjFile);

    # release all reader resources.
    destroy: fun(ptr);
}

# --- debug information ---

# DISubprogram: a function/subprogram entry for debug info.
pub rec DISubprogram {
    name:     str;    # function name (mangled)
    file_idx: u16;    # index returned by add_file()
    line:     i32;    # source line of function definition
    low_pc:  u64;     # start virtual address
    high_pc: u64;     # end virtual address (exclusive)
}

# DILineEntry: a source line → code address mapping.
pub rec DILineEntry {
    address:  u64;    # virtual address of instruction
    file_idx: u16;    # index returned by add_file()
    line:     i32;    # 1-based source line number
}

# DebugSection: a serialized debug section ready for embedding.
pub rec DebugSection {
    name: str;        # section name (e.g. ".debug_info", ".debug_line")
    data: *u8;
    size: usize;
}

# --- executable format ---

# ExecSection: a section with a resolved virtual address for executable emission.
pub rec ExecSection {
    name:   str;    # section name (e.g. ".text", ".rodata")
    data:   *u8;
    size:   usize;
    vaddr:  u64;
    flags:  u32;    # abstract section flags (FLAG_WRITE, FLAG_EXEC, FLAG_ALLOC)
    align:  usize;
}

# ExecSymbol: a symbol for the executable symbol table.
# uses abstract binding/kind values from MASM (same as OFSymbol).
pub rec ExecSymbol {
    name:    str;
    binding: u8;     # abstract binding (local/global/weak)
    kind:    u8;     # abstract kind (func/object/section/file)
    section: i32;    # index into ExecSection array (-1 = absolute)
    value:   u64;    # virtual address
    size:    usize;
}

# ExecFormat: executable file format interface.
# ---
# parallel to ObjWriter (which produces relocatable .o files).
# ExecFormat produces linked executables or shared libraries.
# all sections are pre-resolved — relocations have been applied.
pub rec ExecFormat {
    ctx: ptr;

    # compute the total header size (file header + per-section headers)
    # given the number of loadable sections. the linker uses this to
    # reserve space before section data begins.
    header_size: fun(ptr, i32) usize;

    # add a symbol for the executable symbol table.
    add_symbol: fun(ptr, *ExecSymbol);

    # add non-loadable debug sections (e.g. .debug_info, .debug_line).
    # these appear in section headers but not in PT_LOAD segments.
    add_debug_sections: fun(ptr, *DebugSection, i32);

    # emit an executable from resolved sections.
    # entry: virtual address of the entry point symbol.
    # base: virtual address base for the executable (OS-defined).
    emit: fun(ptr, *ExecSection, i32, u64, u64, *OutputBuffer);

    # release all resources.
    destroy: fun(ptr);
}

# --- debug information interface ---

# DebugInfo: debug information format interface.
# ---
# the linker populates this with file, subprogram, and line data,
# then calls finalize() to serialize and get_sections() to retrieve
# the resulting debug sections for embedding in the executable.
pub rec DebugInfo {
    ctx: ptr;

    # register a source file. returns a file index for use in
    # add_subprogram() and add_line(). path is the file path,
    # dir is the compilation directory.
    add_file: fun(ptr, str, str) u16;

    # register a function/subprogram with its address range.
    add_subprogram: fun(ptr, *DISubprogram);

    # register a line → address mapping.
    add_line: fun(ptr, *DILineEntry);

    # read a serialized .debug_info section from a .o file.
    # extracts subprogram entries and adjusts addresses by addr_offset.
    # alloc is used for temporary string allocations.
    read_info: fun(ptr, *u8, usize, u64, *allocator.Allocator);

    # read a serialized .debug_line section from a .o file.
    # extracts file entries and line mappings, adjusting addresses by addr_offset.
    # alloc is used for temporary string allocations.
    read_line: fun(ptr, *u8, usize, u64, *allocator.Allocator);

    # serialize all accumulated data into debug sections.
    finalize: fun(ptr, *allocator.Allocator);

    # retrieve the serialized debug sections.
    # returns a pointer to the section array and sets count.
    get_sections: fun(ptr, *i32) *DebugSection;

    # release all resources.
    destroy: fun(ptr);
}

# ObjWriter: relocatable object file writer interface.
pub rec ObjWriter {
    ctx:  ptr;
    name: str;

    # add a section. returns section index.
    # flags are abstract section flag values from MASM.
    add_section: fun(ptr, str, u8, u32, usize) u64;

    # append data to a section.
    write: fun(ptr, u64, *u8, usize);

    # set total size of a section without writing data (BSS-like).
    set_size: fun(ptr, u64, usize);

    # get current write offset within a section.
    section_offset: fun(ptr, u64) usize;

    # add a symbol. returns symbol index.
    add_symbol: fun(ptr, *OFSymbol) u64;

    # add a relocation.
    add_reloc: fun(ptr, *OFReloc);

    # finalize: resolve references, write headers, produce output.
    finalize: fun(ptr, *OutputBuffer);

    # release all resources.
    destroy: fun(ptr);
}

# ObjectFormat: fully composed object format interface.
# ---
# groups all format-related interfaces for a compilation target.
# downstream code receives this — nothing calls format selectors directly.
pub rec ObjectFormat {
    name:   str;
    obj:    ObjWriter;
    exec:   ExecFormat;
    reader: ObjectReader;
    di:     DebugInfo;
}

