# mach.compiler.target.of: object format interface
#
# defines the abstract interfaces for object file writing (relocatable .o) and
# executable linking. backends (ELF, Mach-O, PE) implement these via
# function-pointer records.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

pub def SectionKind: u8;
pub val SK_TEXT:   SectionKind = 0;
pub val SK_DATA:   SectionKind = 1;
pub val SK_RODATA: SectionKind = 2;
pub val SK_BSS:    SectionKind = 3;

pub def RelocKind: u8;
pub val RK_ABS64:     RelocKind = 0;
pub val RK_PC32:      RelocKind = 1;
pub val RK_PLT32:     RelocKind = 2;
pub val RK_GOTPCREL:  RelocKind = 3;

# an output section in the object file
# ---
# name:  section name (".text", ".data", etc.)
# kind:  section type
# flags: section flags (alloc, write, exec)
# data:  section content bytes
# size:  current size of content
# cap:   allocated capacity of data
# align: required alignment
pub rec Section {
    name:  str;
    kind:  SectionKind;
    flags: u32;
    data:  *u8;
    size:  usize;
    cap:   usize;
    align: usize;
}

# a relocation entry
# ---
# offset:  byte offset within the section
# kind:    relocation type
# sym_id:  target symbol id
# addend:  addend value
pub rec Reloc {
    offset: usize;
    kind:   RelocKind;
    sym_id: u32;
    addend: i64;
}

# object file writer interface (relocatable .o emission)
# ---
# ctx:            opaque backend state
# name:           format name ("elf", "macho", "pe")
# add_section:    create a new section: (ctx, name, kind, flags, align) -> i32
# get_section:    get section by index: (ctx, i32) -> *Section
# emit_bytes:     append raw bytes to a section: (ctx, i32, *u8, usize) -> bool
# add_symbol:     define a symbol: (ctx, name, section_idx, offset, size, is_global) -> u32
# add_reloc:      record a relocation: (ctx, section_idx, offset, kind, sym_id, addend) -> bool
# finalize:       write the object file to disk: (ctx, path) -> bool
pub rec ObjWriter {
    ctx:         ptr;
    name:        str;
    add_section: fun(ptr, str, u8, u32, usize) i32;
    get_section: fun(ptr, i32) *Section;
    emit_bytes:  fun(ptr, i32, *u8, usize) bool;
    add_symbol:  fun(ptr, str, i32, usize, usize, bool) u32;
    add_reloc:   fun(ptr, i32, usize, u8, u32, i64) bool;
    finalize:    fun(ptr, str) bool;
}

# executable format writer interface (linked binary emission)
# ---
# ctx:        opaque backend state
# add_load:   add a loadable segment: (ctx, vaddr, filesz, memsz, flags) -> i32
# set_entry:  set the entry point address: (ctx, addr) -> void
# finalize:   write the executable to disk: (ctx, path) -> bool
pub rec ExecFormat {
    ctx:       ptr;
    add_load:  fun(ptr, u64, usize, usize, u32) i32;
    set_entry: fun(ptr, u64);
    finalize:  fun(ptr, str) bool;
}

# composed object format with both writer and exec support
# ---
# name: format name
# obj:  relocatable object writer
# exec: executable linker
pub rec ObjectFormat {
    name: str;
    obj:  ObjWriter;
    exec: ExecFormat;
}
