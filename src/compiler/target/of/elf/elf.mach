use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use of:        mach.compiler.of;
use di:        mach.compiler.di;

# mach.compiler.of.elf: ELF object file format implementation.
# ---
# produces relocatable ELF object files. target-specific details
# (machine type, class, endianness, relocation mapping) are provided
# via an ElfTarget record passed to create() / create_exec().

# --- ELF constants ---

# e_ident
val EI_MAG0:    u8 = 0x7f;
val EI_MAG1:    u8 = 0x45; # 'E'
val EI_MAG2:    u8 = 0x4c; # 'L'
val EI_MAG3:    u8 = 0x46; # 'F'

pub val ELFCLASS32:    u8 = 1;
pub val ELFCLASS64:    u8 = 2;
pub val ELFDATA2LSB:   u8 = 1;
pub val ELFDATA2MSB:   u8 = 2;
val EV_CURRENT:    u8 = 1;
val ELFOSABI_NONE: u8 = 0;

# e_type
val ET_REL:  u16 = 1;
val ET_EXEC: u16 = 2;
val ET_DYN:  u16 = 3;

# well-known e_machine values (for use by callers constructing ElfTarget)
pub val EM_X86_64:  u16 = 62;
pub val EM_AARCH64: u16 = 183;
pub val EM_RISCV:   u16 = 243;

# section header types
val SHT_NULL:     u32 = 0;
val SHT_PROGBITS: u32 = 1;
val SHT_SYMTAB:   u32 = 2;
val SHT_STRTAB:   u32 = 3;
val SHT_RELA:     u32 = 4;
val SHT_NOBITS:   u32 = 8;

# section header flags
val SHF_WRITE:     u64 = 1;
val SHF_ALLOC:     u64 = 2;
val SHF_EXECINSTR: u64 = 4;

# symbol binding (ELF values)
val STB_LOCAL:  u8 = 0;
val STB_GLOBAL: u8 = 1;
val STB_WEAK:   u8 = 2;

# symbol type (ELF values)
val STT_NOTYPE:  u8 = 0;
val STT_OBJECT:  u8 = 1;
val STT_FUNC:    u8 = 2;
val STT_SECTION: u8 = 3;
val STT_FILE:    u8 = 4;

# well-known x86_64 relocation types (for use by callers constructing ElfTarget)
pub val R_X86_64_NONE:  u32 = 0;
pub val R_X86_64_64:    u32 = 1;
pub val R_X86_64_PC32:  u32 = 2;
pub val R_X86_64_PLT32: u32 = 4;
pub val R_X86_64_32:    u32 = 10;
pub val R_X86_64_32S:   u32 = 11;

# --- target metadata ---

# ElfTarget: all target-specific ELF parameters.
# callers construct this with the appropriate values for their ISA.
pub rec ElfTarget {
    e_machine: u16;     # ELF e_machine value (e.g. EM_X86_64)
    ei_class:  u8;      # ELF class (ELFCLASS32 or ELFCLASS64)
    ei_data:   u8;      # ELF data encoding (ELFDATA2LSB or ELFDATA2MSB)

    # map abstract MASM relocation type (RELOC_*) → ELF relocation type.
    # abstract: 0=none, 1=abs64, 2=rel32, 3=call32, 4=abs32, 5=abs32s
    map_reloc:   fun(u32) u32;

    # reverse map: ELF relocation type → abstract MASM relocation type.
    unmap_reloc: fun(u32) u8;
}

# --- x86_64 relocation mapping functions ---

# map_reloc_x86_64: abstract MASM reloc type → ELF R_X86_64_*
pub fun map_reloc_x86_64(rtype: u32) u32 {
    if (rtype == 1) { ret R_X86_64_64; }
    if (rtype == 2) { ret R_X86_64_PC32; }
    if (rtype == 3) { ret R_X86_64_PLT32; }
    if (rtype == 4) { ret R_X86_64_32; }
    if (rtype == 5) { ret R_X86_64_32S; }
    ret R_X86_64_NONE;
}

# unmap_reloc_x86_64: ELF R_X86_64_* → abstract MASM reloc type
pub fun unmap_reloc_x86_64(elf_rtype: u32) u8 {
    if (elf_rtype == R_X86_64_64)    { ret 1; }
    if (elf_rtype == R_X86_64_PC32)  { ret 2; }
    if (elf_rtype == R_X86_64_PLT32) { ret 3; }
    if (elf_rtype == R_X86_64_32)    { ret 4; }
    if (elf_rtype == R_X86_64_32S)   { ret 5; }
    ret 0;
}

# target_x86_64: convenience constructor for x86_64 ELF target metadata.
pub fun target_x86_64() ElfTarget {
    var t: ElfTarget;
    t.e_machine = EM_X86_64;
    t.ei_class = ELFCLASS64;
    t.ei_data = ELFDATA2LSB;
    t.map_reloc = map_reloc_x86_64;
    t.unmap_reloc = unmap_reloc_x86_64;
    ret t;
}

# program header types
val PT_NULL: u32 = 0;
val PT_LOAD: u32 = 1;

# program header flags
val PF_X: u32 = 1;
val PF_W: u32 = 2;
val PF_R: u32 = 4;

# structure sizes
val EHDR_SIZE: usize = 64;
val PHDR_SIZE: usize = 56;
val SHDR_SIZE: usize = 64;
val SYM_SIZE:  usize = 24;
val RELA_SIZE: usize = 24;

# initial capacities
val INITIAL_SEC_CAP:  i32 = 8;
val INITIAL_SYM_CAP:  i32 = 64;
val INITIAL_REL_CAP:  i32 = 64;
val INITIAL_STR_CAP:  usize = 256;

# --- internal records ---

rec ElfSection {
    name:       str;
    data:       *u8;
    size:       usize;
    cap:        usize;
    kind:       u8;     # abstract section kind from caller
    flags:      u32;    # abstract flags from caller
    align:      usize;
    name_off:   u32;    # offset in .shstrtab (set during finalize)
}

rec ElfSymbol {
    name:       str;
    section:    u64;
    offset:     usize;
    size:       usize;
    binding:    u8;     # abstract binding
    kind:       u8;     # abstract kind
    name_off:   u32;    # offset in .strtab (set during finalize)
}

rec ElfReloc {
    section:    u64;
    offset:     usize;
    symbol:     u64;
    rtype:      u32;    # abstract relocation type
    addend:     i64;
}

rec ElfContext {
    alloc:      *allocator.Allocator;
    target:     ElfTarget;

    sections:   *ElfSection;
    sec_count:  i32;
    sec_cap:    i32;

    symbols:    *ElfSymbol;
    sym_count:  i32;
    sym_cap:    i32;

    relocs:     *ElfReloc;
    rel_count:  i32;
    rel_cap:    i32;
}

# create: construct the ELF object format.
# target provides machine type, class, endianness, and relocation mappers.
pub fun create(alloc: *allocator.Allocator, target: ElfTarget) Result[of.ObjectFormat, str] {
    if (alloc == nil) {
        ret err[of.ObjectFormat, str]("allocator is nil");
    }

    val ctx_r: Result[*ElfContext, allocator.AllocError] =
        allocator.allocator_zalloc[ElfContext](alloc, 1);
    if (result_is_err[*ElfContext, allocator.AllocError](ctx_r)) {
        ret err[of.ObjectFormat, str]("out of memory");
    }
    val ctx: *ElfContext = result_unwrap_ok[*ElfContext, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;
    ctx.target = target;

    # pre-allocate arrays
    val sr: Result[*ElfSection, allocator.AllocError] =
        allocator.allocator_zalloc[ElfSection](alloc, INITIAL_SEC_CAP::usize);
    if (result_is_err[*ElfSection, allocator.AllocError](sr)) {
        ret err[of.ObjectFormat, str]("out of memory");
    }
    ctx.sections = result_unwrap_ok[*ElfSection, allocator.AllocError](sr);
    ctx.sec_cap = INITIAL_SEC_CAP;

    val yr: Result[*ElfSymbol, allocator.AllocError] =
        allocator.allocator_zalloc[ElfSymbol](alloc, INITIAL_SYM_CAP::usize);
    if (result_is_err[*ElfSymbol, allocator.AllocError](yr)) {
        ret err[of.ObjectFormat, str]("out of memory");
    }
    ctx.symbols = result_unwrap_ok[*ElfSymbol, allocator.AllocError](yr);
    ctx.sym_cap = INITIAL_SYM_CAP;

    val rr: Result[*ElfReloc, allocator.AllocError] =
        allocator.allocator_zalloc[ElfReloc](alloc, INITIAL_REL_CAP::usize);
    if (result_is_err[*ElfReloc, allocator.AllocError](rr)) {
        ret err[of.ObjectFormat, str]("out of memory");
    }
    ctx.relocs = result_unwrap_ok[*ElfReloc, allocator.AllocError](rr);
    ctx.rel_cap = INITIAL_REL_CAP;

    var fmt: of.ObjectFormat;
    fmt.ctx = ctx::ptr;
    fmt.add_section = elf_add_section;
    fmt.write = elf_write;
    fmt.set_size = elf_set_size;
    fmt.section_offset = elf_section_offset;
    fmt.add_symbol = elf_add_symbol;
    fmt.add_reloc = elf_add_reloc;
    fmt.finalize = elf_finalize;
    fmt.destroy = elf_destroy;

    ret ok[of.ObjectFormat, str](fmt);
}

# --- interface implementations ---

fun elf_add_section(ctx: ptr, name: str, kind: u8, flags: u32, align: usize) u64 {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil) { ret 0; }

    # grow if needed
    if (e.sec_count >= e.sec_cap) {
        val new_cap: i32 = e.sec_cap * 2;
        val r: Result[*ElfSection, allocator.AllocError] =
            allocator.allocator_resize[ElfSection](e.alloc, e.sections,
                e.sec_cap::usize, new_cap::usize);
        if (result_is_err[*ElfSection, allocator.AllocError](r)) { ret 0; }
        e.sections = result_unwrap_ok[*ElfSection, allocator.AllocError](r);
        e.sec_cap = new_cap;
    }

    val idx: i32 = e.sec_count;
    e.sections[idx].name = name;
    e.sections[idx].data = nil;
    e.sections[idx].size = 0;
    e.sections[idx].cap = 0;
    e.sections[idx].kind = kind;
    e.sections[idx].flags = flags;
    e.sections[idx].align = align;
    e.sections[idx].name_off = 0;
    e.sec_count = e.sec_count + 1;

    # section index is 1-based (0 = SHN_UNDEF in ELF)
    ret (idx + 1)::u64;
}

fun elf_write(ctx: ptr, section: u64, data: *u8, size: usize) {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil || data == nil || size == 0) { ret; }

    val idx: i32 = (section - 1)::i32;
    if (idx < 0 || idx >= e.sec_count) { ret; }

    val sec: *ElfSection = ?e.sections[idx];
    val needed: usize = sec.size + size;

    if (needed > sec.cap) {
        var new_cap: usize = 256;
        if (sec.cap > 0) { new_cap = sec.cap * 2; }
        for (new_cap < needed) { new_cap = new_cap * 2; }

        val r: Result[*u8, allocator.AllocError] =
            allocator.allocator_resize[u8](e.alloc, sec.data, sec.cap, new_cap);
        if (result_is_err[*u8, allocator.AllocError](r)) { ret; }
        sec.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        sec.cap = new_cap;
    }

    var i: usize = 0;
    for (i < size) {
        sec.data[sec.size + i] = data[i];
        i = i + 1;
    }
    sec.size = sec.size + size;
}

fun elf_set_size(ctx: ptr, section: u64, size: usize) {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil) { ret; }

    val idx: i32 = (section - 1)::i32;
    if (idx < 0 || idx >= e.sec_count) { ret; }

    e.sections[idx].size = size;
}

fun elf_section_offset(ctx: ptr, section: u64) usize {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil) { ret 0; }

    val idx: i32 = (section - 1)::i32;
    if (idx < 0 || idx >= e.sec_count) { ret 0; }

    ret e.sections[idx].size;
}

fun elf_add_symbol(ctx: ptr, sym: *of.OFSymbol) u64 {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil || sym == nil) { ret 0; }

    # grow if needed
    if (e.sym_count >= e.sym_cap) {
        val new_cap: i32 = e.sym_cap * 2;
        val r: Result[*ElfSymbol, allocator.AllocError] =
            allocator.allocator_resize[ElfSymbol](e.alloc, e.symbols,
                e.sym_cap::usize, new_cap::usize);
        if (result_is_err[*ElfSymbol, allocator.AllocError](r)) { ret 0; }
        e.symbols = result_unwrap_ok[*ElfSymbol, allocator.AllocError](r);
        e.sym_cap = new_cap;
    }

    val idx: i32 = e.sym_count;
    e.symbols[idx].name = sym.name;
    e.symbols[idx].section = sym.section;
    e.symbols[idx].offset = sym.offset;
    e.symbols[idx].size = sym.size;
    e.symbols[idx].binding = sym.binding;
    e.symbols[idx].kind = sym.kind;
    e.symbols[idx].name_off = 0;
    e.sym_count = e.sym_count + 1;

    # symbol index is 1-based (0 = STN_UNDEF in ELF)
    ret (idx + 1)::u64;
}

fun elf_add_reloc(ctx: ptr, reloc: *of.OFReloc) {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil || reloc == nil) { ret; }

    # grow if needed
    if (e.rel_count >= e.rel_cap) {
        val new_cap: i32 = e.rel_cap * 2;
        val r: Result[*ElfReloc, allocator.AllocError] =
            allocator.allocator_resize[ElfReloc](e.alloc, e.relocs,
                e.rel_cap::usize, new_cap::usize);
        if (result_is_err[*ElfReloc, allocator.AllocError](r)) { ret; }
        e.relocs = result_unwrap_ok[*ElfReloc, allocator.AllocError](r);
        e.rel_cap = new_cap;
    }

    val idx: i32 = e.rel_count;
    e.relocs[idx].section = reloc.section;
    e.relocs[idx].offset = reloc.offset;
    e.relocs[idx].symbol = reloc.symbol;
    e.relocs[idx].rtype = reloc.rtype;
    e.relocs[idx].addend = reloc.addend;
    e.rel_count = e.rel_count + 1;
}

fun elf_destroy(ctx: ptr) {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil || e.alloc == nil) { ret; }

    # free section data
    var i: i32 = 0;
    for (i < e.sec_count) {
        if (e.sections[i].data != nil) {
            allocator.allocator_free[u8](e.alloc, e.sections[i].data, e.sections[i].cap);
        }
        i = i + 1;
    }

    allocator.allocator_free[ElfSection](e.alloc, e.sections, e.sec_cap::usize);
    allocator.allocator_free[ElfSymbol](e.alloc, e.symbols, e.sym_cap::usize);
    allocator.allocator_free[ElfReloc](e.alloc, e.relocs, e.rel_cap::usize);
    allocator.allocator_free[ElfContext](e.alloc, e, 1);
}

# --- abstract → ELF mapping ---

# map abstract MASM binding (0=local, 1=global, 2=weak) to ELF STB_*
fun map_binding(binding: u8) u8 {
    if (binding == 1) { ret STB_GLOBAL; }
    if (binding == 2) { ret STB_WEAK; }
    ret STB_LOCAL;
}

# map abstract MASM kind (0=none, 1=func, 2=object, 3=section, 4=file) to ELF STT_*
fun map_kind(kind: u8) u8 {
    if (kind == 1) { ret STT_FUNC; }
    if (kind == 2) { ret STT_OBJECT; }
    if (kind == 3) { ret STT_SECTION; }
    if (kind == 4) { ret STT_FILE; }
    ret STT_NOTYPE;
}

# map abstract section flags to ELF sh_flags
# abstract: 1=write, 2=exec, 4=alloc
fun map_sec_flags(flags: u32) u64 {
    var f: u64 = 0;
    if ((flags & 1) != 0) { f = f | SHF_WRITE; }
    if ((flags & 2) != 0) { f = f | SHF_EXECINSTR; }
    if ((flags & 4) != 0) { f = f | SHF_ALLOC; }
    ret f;
}

# map abstract section kind to ELF sh_type
# 0=text, 1=data, 2=rodata, 3=bss, 4=custom
fun map_sec_type(kind: u8) u32 {
    if (kind == 3) { ret SHT_NOBITS; }
    ret SHT_PROGBITS;
}

# --- string table helper ---

rec StrTab {
    data:  *u8;
    size:  usize;
    cap:   usize;
    alloc: *allocator.Allocator;
}

fun strtab_init(st: *StrTab, alloc: *allocator.Allocator) {
    st.data = nil;
    st.size = 0;
    st.cap = 0;
    st.alloc = alloc;

    # first byte is always 0 (null string)
    strtab_add(st, "");
}

fun strtab_add(st: *StrTab, s: str) u32 {
    val off: u32 = st.size::u32;
    val len: usize = str_len(s);
    val needed: usize = st.size + len + 1;

    if (needed > st.cap) {
        var new_cap: usize = INITIAL_STR_CAP;
        if (st.cap > 0) { new_cap = st.cap * 2; }
        for (new_cap < needed) { new_cap = new_cap * 2; }

        val r: Result[*u8, allocator.AllocError] =
            allocator.allocator_resize[u8](st.alloc, st.data, st.cap, new_cap);
        if (result_is_err[*u8, allocator.AllocError](r)) { ret off; }
        st.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        st.cap = new_cap;
    }

    var i: usize = 0;
    for (i < len) {
        st.data[st.size + i] = s[i];
        i = i + 1;
    }
    st.data[st.size + len] = 0;
    st.size = st.size + len + 1;
    ret off;
}

fun str_len(s: str) usize {
    if (s == nil) { ret 0; }
    var len: usize = 0;
    for (s[len] != 0) { len = len + 1; }
    ret len;
}

# --- finalize: produce ELF output ---

# ELF layout:
#   [ELF header]
#   [user section data, aligned]
#   [.symtab]
#   [.strtab]
#   [.rela.* sections]
#   [.shstrtab]
#   [section header table]

fun elf_finalize(ctx: ptr, out: *of.OutputBuffer) {
    val e: *ElfContext = ctx::*ElfContext;
    if (e == nil || out == nil) { ret; }

    # --- build string tables ---

    var shstrtab: StrTab;
    strtab_init(?shstrtab, e.alloc);

    var strtab: StrTab;
    strtab_init(?strtab, e.alloc);

    # register section names in .shstrtab
    var si: i32 = 0;
    for (si < e.sec_count) {
        e.sections[si].name_off = strtab_add(?shstrtab, e.sections[si].name);
        si = si + 1;
    }

    # register symbol names in .strtab
    var yi: i32 = 0;
    for (yi < e.sym_count) {
        e.symbols[yi].name_off = strtab_add(?strtab, e.symbols[yi].name);
        yi = yi + 1;
    }

    # --- count rela sections needed ---

    # determine which user sections have relocations
    var rela_count: i32 = 0;
    si = 0;
    for (si < e.sec_count) {
        var ri: i32 = 0;
        var has_reloc: bool = false;
        for (ri < e.rel_count) {
            if (e.relocs[ri].section == (si + 1)::u64) {
                has_reloc = true;
            }
            ri = ri + 1;
        }
        if (has_reloc) { rela_count = rela_count + 1; }
        si = si + 1;
    }

    # --- compute section header count ---
    # [0: SHN_UNDEF] [1..N: user sections] [symtab] [strtab] [rela.*...] [shstrtab]
    val shdr_count: i32 = 1 + e.sec_count + 1 + 1 + rela_count + 1;

    # register synthetic section names in shstrtab
    val symtab_name_off: u32 = strtab_add(?shstrtab, ".symtab");
    val strtab_name_off: u32 = strtab_add(?shstrtab, ".strtab");
    val shstrtab_name_off: u32 = strtab_add(?shstrtab, ".shstrtab");

    # section header indices for synthetic sections
    val symtab_shidx: i32 = 1 + e.sec_count;
    val strtab_shidx: i32 = symtab_shidx + 1;
    val rela_base_shidx: i32 = strtab_shidx + 1;
    val shstrtab_shidx: i32 = rela_base_shidx + rela_count;

    # --- write ELF header ---

    write_ehdr(out, ?e.target, ET_REL, shdr_count, shstrtab_shidx);

    # --- write user section data ---

    # track file offsets for each user section
    # we'll store them in a temporary array
    val off_r: Result[*usize, allocator.AllocError] =
        allocator.allocator_zalloc[usize](e.alloc, e.sec_count::usize);
    if (result_is_err[*usize, allocator.AllocError](off_r)) { ret; }
    val sec_offsets: *usize = result_unwrap_ok[*usize, allocator.AllocError](off_r);

    si = 0;
    for (si < e.sec_count) {
        val sec: *ElfSection = ?e.sections[si];
        val a: usize = sec.align;
        if (a > 1) { of.buf_align(out, a); }
        sec_offsets[si] = out.size;

        # BSS sections have no data in the file
        if (sec.kind != 3 && sec.data != nil && sec.size > 0) {
            of.buf_write(out, sec.data, sec.size);
        }
        si = si + 1;
    }

    # --- write .symtab ---

    of.buf_align(out, 8);
    val symtab_offset: usize = out.size;

    # first entry: null symbol
    of.buf_write_zeros(out, SYM_SIZE);

    # count local symbols first (ELF requires locals before globals)
    var local_count: i32 = 1; # null symbol counts as local
    yi = 0;
    for (yi < e.sym_count) {
        if (map_binding(e.symbols[yi].binding) == STB_LOCAL) {
            local_count = local_count + 1;
        }
        yi = yi + 1;
    }

    # build remap: original 1-based index → final 1-based index
    val remap_r: Result[*u64, allocator.AllocError] =
        allocator.allocator_zalloc[u64](e.alloc, (e.sym_count + 1)::usize);
    if (result_is_err[*u64, allocator.AllocError](remap_r)) { ret; }
    val sym_remap: *u64 =
        result_unwrap_ok[*u64, allocator.AllocError](remap_r);

    # emit local symbols, then global/weak symbols
    var pass: i32 = 0;
    var final_idx: u64 = 1;
    for (pass < 2) {
        yi = 0;
        for (yi < e.sym_count) {
            val is_local: bool = map_binding(e.symbols[yi].binding) == STB_LOCAL;
            if ((pass == 0 && is_local) || (pass == 1 && !is_local)) {
                sym_remap[(yi + 1)::usize] = final_idx;
                write_sym(out, ?e.symbols[yi]);
                final_idx = final_idx + 1;
            }
            yi = yi + 1;
        }
        pass = pass + 1;
    }

    # remap relocation symbol indices to match reordered symtab
    var rmi: i32 = 0;
    for (rmi < e.rel_count) {
        val old_sym: u64 = e.relocs[rmi].symbol;
        if (old_sym > 0 && old_sym <= e.sym_count::u64) {
            e.relocs[rmi].symbol = sym_remap[old_sym::usize];
        }
        rmi = rmi + 1;
    }

    val symtab_size: usize = (1 + e.sym_count)::usize * SYM_SIZE;

    # --- write .strtab ---

    of.buf_align(out, 1);
    val strtab_offset: usize = out.size;
    of.buf_write(out, strtab.data, strtab.size);

    # --- write .rela.* sections ---

    # allocate rela offset/size tracking
    val rela_off_r: Result[*usize, allocator.AllocError] =
        allocator.allocator_zalloc[usize](e.alloc, (rela_count * 2)::usize);
    if (result_is_err[*usize, allocator.AllocError](rela_off_r)) { ret; }
    val rela_info: *usize = result_unwrap_ok[*usize, allocator.AllocError](rela_off_r);
    # rela_info[i*2] = file offset, rela_info[i*2+1] = size

    # allocate array to track which user section each rela section applies to
    val rela_sec_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](e.alloc, rela_count::usize);
    if (result_is_err[*i32, allocator.AllocError](rela_sec_r)) { ret; }
    val rela_targets: *i32 = result_unwrap_ok[*i32, allocator.AllocError](rela_sec_r);

    var rela_idx: i32 = 0;
    si = 0;
    for (si < e.sec_count) {
        # count relocs for this section
        var rel_for_sec: i32 = 0;
        var ri: i32 = 0;
        for (ri < e.rel_count) {
            if (e.relocs[ri].section == (si + 1)::u64) {
                rel_for_sec = rel_for_sec + 1;
            }
            ri = ri + 1;
        }

        if (rel_for_sec > 0) {
            of.buf_align(out, 8);
            rela_info[rela_idx * 2] = out.size;
            rela_targets[rela_idx] = si;

            # register .rela.NAME in shstrtab
            # (we already added it or we add it now - for simplicity, just add)
            # note: we can't easily concatenate strings in mach, so the
            # shstrtab entry for rela sections is handled in shdr emission

            ri = 0;
            for (ri < e.rel_count) {
                if (e.relocs[ri].section == (si + 1)::u64) {
                    write_rela(out, ?e.relocs[ri], e.target.map_reloc);
                }
                ri = ri + 1;
            }

            rela_info[rela_idx * 2 + 1] = rel_for_sec::usize * RELA_SIZE;
            rela_idx = rela_idx + 1;
        }
        si = si + 1;
    }

    # --- write .shstrtab ---

    # add rela section names to shstrtab before writing it
    val rela_name_r: Result[*u32, allocator.AllocError] =
        allocator.allocator_zalloc[u32](e.alloc, rela_count::usize);
    if (result_is_err[*u32, allocator.AllocError](rela_name_r)) { ret; }
    val rela_names: *u32 = result_unwrap_ok[*u32, allocator.AllocError](rela_name_r);

    rela_idx = 0;
    for (rela_idx < rela_count) {
        # build ".rela.NAME" by adding ".rela." prefix + section name
        rela_names[rela_idx] = strtab_add(?shstrtab, ".rela");
        # append the section name part with a dot
        # since we can't easily build dynamic strings, we'll just use ".rela" as the name
        # the actual section association is tracked via sh_info
        rela_idx = rela_idx + 1;
    }

    of.buf_align(out, 1);
    val shstrtab_offset: usize = out.size;
    of.buf_write(out, shstrtab.data, shstrtab.size);

    # --- write section header table ---

    of.buf_align(out, 8);
    val shdr_offset: usize = out.size;

    # [0] SHN_UNDEF
    write_shdr_null(out);

    # [1..N] user sections
    si = 0;
    for (si < e.sec_count) {
        val sec: *ElfSection = ?e.sections[si];
        val sh_type: u32 = map_sec_type(sec.kind);
        val sh_flags: u64 = map_sec_flags(sec.flags);
        val sh_offset: usize = sec_offsets[si];
        var sh_size: usize = sec.size;

        # BSS: sh_type = NOBITS, offset in file but no data
        if (sec.kind == 3) {
            write_shdr(out, sec.name_off, SHT_NOBITS, sh_flags,
                       0, sh_offset, 0, sec.align, 0, 0, 0);
        } or {
            write_shdr(out, sec.name_off, sh_type, sh_flags,
                       0, sh_offset, sh_size, sec.align, 0, 0, 0);
        }
        si = si + 1;
    }

    # [symtab]
    write_shdr(out, symtab_name_off, SHT_SYMTAB, 0,
               0, symtab_offset, symtab_size, 8,
               strtab_shidx::u32, local_count::u32, SYM_SIZE);

    # [strtab]
    write_shdr(out, strtab_name_off, SHT_STRTAB, 0,
               0, strtab_offset, strtab.size, 1, 0, 0, 0);

    # [rela.*]
    rela_idx = 0;
    for (rela_idx < rela_count) {
        val target_shidx: u32 = (rela_targets[rela_idx] + 1)::u32;
        write_shdr(out, rela_names[rela_idx], SHT_RELA,
                   0x40, # SHF_INFO_LINK
                   0, rela_info[rela_idx * 2],
                   rela_info[rela_idx * 2 + 1],
                   8, symtab_shidx::u32, target_shidx, RELA_SIZE);
        rela_idx = rela_idx + 1;
    }

    # [shstrtab]
    write_shdr(out, shstrtab_name_off, SHT_STRTAB, 0,
               0, shstrtab_offset, shstrtab.size, 1, 0, 0, 0);

    # --- patch ELF header with section header offset ---

    # e_shoff is at offset 40 in the ELF header
    of.buf_patch_u64(out, 40, shdr_offset::u64);
    # e_shnum is at offset 60 (u16)
    out.data[60] = (shdr_count & 255)::u8;
    out.data[61] = ((shdr_count >> 8) & 255)::u8;
    # e_shstrndx is at offset 62 (u16)
    out.data[62] = (shstrtab_shidx & 255)::u8;
    out.data[63] = ((shstrtab_shidx >> 8) & 255)::u8;

    # --- cleanup temporaries ---

    allocator.allocator_free[usize](e.alloc, sec_offsets, e.sec_count::usize);
    allocator.allocator_free[usize](e.alloc, rela_info, (rela_count * 2)::usize);
    allocator.allocator_free[i32](e.alloc, rela_targets, rela_count::usize);
    allocator.allocator_free[u32](e.alloc, rela_names, rela_count::usize);

    if (shstrtab.data != nil) {
        allocator.allocator_free[u8](e.alloc, shstrtab.data, shstrtab.cap);
    }
    if (strtab.data != nil) {
        allocator.allocator_free[u8](e.alloc, strtab.data, strtab.cap);
    }
}

# --- ELF structure writers ---

fun write_ehdr(out: *of.OutputBuffer, target: *ElfTarget,
               e_type: u16, shnum: i32, shstrndx: i32) {
    # e_ident[16]
    of.buf_write_u8(out, EI_MAG0);
    of.buf_write_u8(out, EI_MAG1);
    of.buf_write_u8(out, EI_MAG2);
    of.buf_write_u8(out, EI_MAG3);
    of.buf_write_u8(out, target.ei_class);
    of.buf_write_u8(out, target.ei_data);
    of.buf_write_u8(out, EV_CURRENT);
    of.buf_write_u8(out, ELFOSABI_NONE);
    of.buf_write_zeros(out, 8); # padding

    of.buf_write_u16(out, e_type);           # e_type
    of.buf_write_u16(out, target.e_machine); # e_machine
    of.buf_write_u32(out, EV_CURRENT::u32);  # e_version
    of.buf_write_u64(out, 0);                # e_entry
    of.buf_write_u64(out, 0);                # e_phoff
    of.buf_write_u64(out, 0);                # e_shoff (patched later)
    of.buf_write_u32(out, 0);                # e_flags
    of.buf_write_u16(out, EHDR_SIZE::u16);   # e_ehsize
    of.buf_write_u16(out, 0);                # e_phentsize
    of.buf_write_u16(out, 0);                # e_phnum
    of.buf_write_u16(out, SHDR_SIZE::u16);   # e_shentsize
    of.buf_write_u16(out, shnum::u16);       # e_shnum (patched later too)
    of.buf_write_u16(out, shstrndx::u16);    # e_shstrndx (patched later too)
}

fun write_shdr(out: *of.OutputBuffer, name: u32, sh_type: u32, flags: u64,
               addr: u64, offset: usize, size: usize, align: usize,
               link: u32, info: u32, entsize: usize) {
    of.buf_write_u32(out, name);           # sh_name
    of.buf_write_u32(out, sh_type);        # sh_type
    of.buf_write_u64(out, flags);          # sh_flags
    of.buf_write_u64(out, addr);           # sh_addr
    of.buf_write_u64(out, offset::u64);    # sh_offset
    of.buf_write_u64(out, size::u64);      # sh_size
    of.buf_write_u32(out, link);           # sh_link
    of.buf_write_u32(out, info);           # sh_info
    of.buf_write_u64(out, align::u64);     # sh_addralign
    of.buf_write_u64(out, entsize::u64);   # sh_entsize
}

fun write_shdr_null(out: *of.OutputBuffer) {
    of.buf_write_zeros(out, SHDR_SIZE);
}

fun write_sym(out: *of.OutputBuffer, sym: *ElfSymbol) {
    val elf_bind: u8 = map_binding(sym.binding);
    val elf_type: u8 = map_kind(sym.kind);
    val st_info: u8 = (elf_bind << 4) | elf_type;

    of.buf_write_u32(out, sym.name_off);      # st_name
    of.buf_write_u8(out, st_info);             # st_info
    of.buf_write_u8(out, 0);                   # st_other (visibility)
    of.buf_write_u16(out, sym.section::u16);   # st_shndx
    of.buf_write_u64(out, sym.offset::u64);    # st_value
    of.buf_write_u64(out, sym.size::u64);      # st_size
}

fun write_rela(out: *of.OutputBuffer, rel: *ElfReloc, map_fn: fun(u32) u32) {
    val elf_type: u32 = map_fn(rel.rtype);
    val r_info: u64 = (rel.symbol << 32) | elf_type::u64;

    of.buf_write_u64(out, rel.offset::u64);    # r_offset
    of.buf_write_u64(out, r_info);              # r_info
    of.buf_write_u64(out, rel.addend::u64);     # r_addend
}

# ============================================================
# ELF64 executable format (ET_EXEC)
# ============================================================
#
# produces statically-linked ELF64 executables.
# receives pre-resolved ExecSections from the linker — all
# relocations are already applied, virtual addresses assigned.
#
# file layout:
#   [ELF header]         offset 0
#   [program headers]    offset EHDR_SIZE
#   [section data...]    each at file_offset = vaddr - base_vaddr
#
# the linker ensures vaddrs start at base + enough room for headers
# and that file_offset ≡ vaddr (mod page_size).

val INITIAL_EXEC_SYM_CAP: i32 = 256;

rec ExecSymEntry {
    name:     str;
    binding:  u8;
    kind:     u8;
    section:  i32;     # index into ExecSection array (-1 = absolute)
    value:    u64;     # virtual address
    size:     usize;
    name_off: u32;     # offset in .strtab (set during emit)
}

rec ExecContext {
    alloc:       *allocator.Allocator;
    target:      ElfTarget;
    syms:        *ExecSymEntry;
    sym_count:   i32;
    sym_cap:     i32;
    dbg_secs:    *di.DebugSection;
    dbg_count:   i32;
}

# create_exec: construct the ELF executable format.
# target provides machine type, class, endianness, and relocation mappers.
pub fun create_exec(alloc: *allocator.Allocator, target: ElfTarget) Result[of.ExecFormat, str] {
    if (alloc == nil) {
        ret err[of.ExecFormat, str]("allocator is nil");
    }

    val ctx_r: Result[*ExecContext, allocator.AllocError] =
        allocator.allocator_zalloc[ExecContext](alloc, 1);
    if (result_is_err[*ExecContext, allocator.AllocError](ctx_r)) {
        ret err[of.ExecFormat, str]("out of memory");
    }
    val ctx: *ExecContext = result_unwrap_ok[*ExecContext, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;
    ctx.target = target;

    val sr: Result[*ExecSymEntry, allocator.AllocError] =
        allocator.allocator_zalloc[ExecSymEntry](alloc, INITIAL_EXEC_SYM_CAP::usize);
    if (result_is_err[*ExecSymEntry, allocator.AllocError](sr)) {
        ret err[of.ExecFormat, str]("out of memory");
    }
    ctx.syms = result_unwrap_ok[*ExecSymEntry, allocator.AllocError](sr);
    ctx.sym_count = 0;
    ctx.sym_cap = INITIAL_EXEC_SYM_CAP;

    var fmt: of.ExecFormat;
    fmt.ctx = ctx::ptr;
    fmt.header_size = elf_exec_header_size;
    fmt.add_symbol = elf_exec_add_symbol;
    fmt.add_debug_sections = elf_exec_add_debug_sections;
    fmt.emit = elf_exec_emit;
    fmt.destroy = elf_exec_destroy;

    ret ok[of.ExecFormat, str](fmt);
}

fun elf_exec_header_size(ctx: ptr, load_count: i32) usize {
    ret EHDR_SIZE + (load_count::usize * PHDR_SIZE);
}

fun elf_exec_add_debug_sections(ctx: ptr, secs: *di.DebugSection, count: i32) {
    val e: *ExecContext = ctx::*ExecContext;
    if (e == nil || secs == nil || count <= 0) { ret; }
    e.dbg_secs = secs;
    e.dbg_count = count;
}

fun elf_exec_add_symbol(ctx: ptr, sym: *of.ExecSymbol) {
    val e: *ExecContext = ctx::*ExecContext;
    if (e == nil || sym == nil) { ret; }

    # grow if needed
    if (e.sym_count >= e.sym_cap) {
        val new_cap: i32 = e.sym_cap * 2;
        val r: Result[*ExecSymEntry, allocator.AllocError] =
            allocator.allocator_resize[ExecSymEntry](e.alloc, e.syms,
                e.sym_cap::usize, new_cap::usize);
        if (result_is_err[*ExecSymEntry, allocator.AllocError](r)) { ret; }
        e.syms = result_unwrap_ok[*ExecSymEntry, allocator.AllocError](r);
        e.sym_cap = new_cap;
    }

    val idx: i32 = e.sym_count;
    e.syms[idx].name = sym.name;
    e.syms[idx].binding = sym.binding;
    e.syms[idx].kind = sym.kind;
    e.syms[idx].section = sym.section;
    e.syms[idx].value = sym.value;
    e.syms[idx].size = sym.size;
    e.syms[idx].name_off = 0;
    e.sym_count = e.sym_count + 1;
}

fun elf_exec_destroy(ctx: ptr) {
    val e: *ExecContext = ctx::*ExecContext;
    if (e == nil || e.alloc == nil) { ret; }
    if (e.syms != nil) {
        allocator.allocator_free[ExecSymEntry](e.alloc, e.syms, e.sym_cap::usize);
    }
    allocator.allocator_free[ExecContext](e.alloc, e, 1);
}

# elf_exec_emit: produce a complete ELF64 executable.
#
# file layout:
#   [ELF header]           offset 0
#   [program headers]      offset EHDR_SIZE
#   [section data...]      each at file_offset = vaddr - base
#   --- end of loadable area ---
#   [.symtab]              non-loadable, after all section data
#   [.strtab]              non-loadable
#   [.shstrtab]            non-loadable
#   [section header table] aligned to 8
fun elf_exec_emit(ctx: ptr, sections: *of.ExecSection, count: i32,
                  entry: u64, base: u64, out: *of.OutputBuffer) {
    val e: *ExecContext = ctx::*ExecContext;
    if (e == nil || out == nil || sections == nil || count <= 0) { ret; }

    # --- write ELF header ---
    # e_shoff, e_shnum, e_shstrndx are patched after writing section headers.

    # e_ident[16]
    of.buf_write_u8(out, EI_MAG0);
    of.buf_write_u8(out, EI_MAG1);
    of.buf_write_u8(out, EI_MAG2);
    of.buf_write_u8(out, EI_MAG3);
    of.buf_write_u8(out, e.target.ei_class);
    of.buf_write_u8(out, e.target.ei_data);
    of.buf_write_u8(out, EV_CURRENT);
    of.buf_write_u8(out, ELFOSABI_NONE);
    of.buf_write_zeros(out, 8);             # padding

    of.buf_write_u16(out, ET_EXEC);          # e_type
    of.buf_write_u16(out, e.target.e_machine); # e_machine
    of.buf_write_u32(out, EV_CURRENT::u32);  # e_version
    of.buf_write_u64(out, entry);            # e_entry
    of.buf_write_u64(out, EHDR_SIZE::u64);   # e_phoff (phdrs right after ehdr)
    of.buf_write_u64(out, 0);                # e_shoff (patched later)
    of.buf_write_u32(out, 0);                # e_flags
    of.buf_write_u16(out, EHDR_SIZE::u16);   # e_ehsize
    of.buf_write_u16(out, PHDR_SIZE::u16);   # e_phentsize
    of.buf_write_u16(out, count::u16);       # e_phnum
    of.buf_write_u16(out, SHDR_SIZE::u16);   # e_shentsize
    of.buf_write_u16(out, 0);                # e_shnum (patched later)
    of.buf_write_u16(out, 0);                # e_shstrndx (patched later)

    # --- write program headers ---

    var si: i32 = 0;
    for (si < count) {
        val sec: *of.ExecSection = ?sections[si];
        val p_offset: u64 = sec.vaddr - base;
        val p_flags: u32 = exec_sec_flags_to_phdr(sec.flags);
        val p_filesz: u64 = sec.size::u64;
        val p_memsz: u64 = sec.size::u64;
        val p_align: u64 = sec.align::u64;

        of.buf_write_u32(out, PT_LOAD);     # p_type
        of.buf_write_u32(out, p_flags);     # p_flags
        of.buf_write_u64(out, p_offset);    # p_offset
        of.buf_write_u64(out, sec.vaddr);   # p_vaddr
        of.buf_write_u64(out, sec.vaddr);   # p_paddr (= vaddr for static)
        of.buf_write_u64(out, p_filesz);    # p_filesz
        of.buf_write_u64(out, p_memsz);     # p_memsz
        of.buf_write_u64(out, p_align);     # p_align

        si = si + 1;
    }

    # --- write section data ---

    si = 0;
    for (si < count) {
        val sec: *of.ExecSection = ?sections[si];
        val target_offset: usize = (sec.vaddr - base)::usize;

        if (out.size < target_offset) {
            of.buf_write_zeros(out, target_offset - out.size);
        }

        if (sec.data != nil && sec.size > 0) {
            of.buf_write(out, sec.data, sec.size);
        }

        si = si + 1;
    }

    # --- build string tables ---

    var shstrtab: StrTab;
    strtab_init(?shstrtab, e.alloc);

    var strtab: StrTab;
    strtab_init(?strtab, e.alloc);

    # register loadable section names in .shstrtab
    si = 0;
    for (si < count) {
        # sections without a name get an empty entry
        if (sections[si].name != nil) {
            strtab_add(?shstrtab, sections[si].name);
        } or {
            strtab_add(?shstrtab, "");
        }
        si = si + 1;
    }

    # register debug section names in .shstrtab
    var di: i32 = 0;
    for (di < e.dbg_count) {
        if (e.dbg_secs[di].name != nil) {
            strtab_add(?shstrtab, e.dbg_secs[di].name);
        }
        di = di + 1;
    }

    # register synthetic section names
    val symtab_name_off: u32 = strtab_add(?shstrtab, ".symtab");
    val strtab_name_off: u32 = strtab_add(?shstrtab, ".strtab");
    val shstrtab_name_off: u32 = strtab_add(?shstrtab, ".shstrtab");

    # register symbol names in .strtab
    var yi: i32 = 0;
    for (yi < e.sym_count) {
        e.syms[yi].name_off = strtab_add(?strtab, e.syms[yi].name);
        yi = yi + 1;
    }

    # --- section header indices ---
    # [0] SHN_UNDEF
    # [1..count] loadable sections
    # [count+1 .. count+dbg_count] debug sections
    # [count+dbg_count+1] .symtab
    # [count+dbg_count+2] .strtab
    # [count+dbg_count+3] .shstrtab
    val symtab_shidx: i32 = count + e.dbg_count + 1;
    val strtab_shidx: i32 = count + e.dbg_count + 2;
    val shstrtab_shidx: i32 = count + e.dbg_count + 3;
    val shdr_count: i32 = count + e.dbg_count + 4;

    # --- count local symbols (ELF requires locals before globals) ---
    var local_count: i32 = 1; # null symbol counts as local
    yi = 0;
    for (yi < e.sym_count) {
        if (map_binding(e.syms[yi].binding) == STB_LOCAL) {
            local_count = local_count + 1;
        }
        yi = yi + 1;
    }

    # --- write debug section data ---

    # allocate offset tracking for debug sections
    val dbg_off_r: Result[*usize, allocator.AllocError] =
        allocator.allocator_zalloc[usize](e.alloc, (e.dbg_count + 1)::usize);
    if (result_is_err[*usize, allocator.AllocError](dbg_off_r)) { ret; }
    val dbg_offsets: *usize =
        result_unwrap_ok[*usize, allocator.AllocError](dbg_off_r);

    di = 0;
    for (di < e.dbg_count) {
        of.buf_align(out, 1);
        dbg_offsets[di] = out.size;
        if (e.dbg_secs[di].data != nil && e.dbg_secs[di].size > 0) {
            of.buf_write(out, e.dbg_secs[di].data, e.dbg_secs[di].size);
        }
        di = di + 1;
    }

    # --- write .symtab ---

    of.buf_align(out, 8);
    val symtab_offset: usize = out.size;

    # null symbol entry
    of.buf_write_zeros(out, SYM_SIZE);

    # emit locals first, then globals
    var pass: i32 = 0;
    for (pass < 2) {
        yi = 0;
        for (yi < e.sym_count) {
            val is_local: bool = map_binding(e.syms[yi].binding) == STB_LOCAL;
            if ((pass == 0 && is_local) || (pass == 1 && !is_local)) {
                write_exec_sym(out, ?e.syms[yi]);
            }
            yi = yi + 1;
        }
        pass = pass + 1;
    }

    val symtab_size: usize = (1 + e.sym_count)::usize * SYM_SIZE;

    # --- write .strtab ---

    val strtab_offset: usize = out.size;
    of.buf_write(out, strtab.data, strtab.size);

    # --- write .shstrtab ---

    val shstrtab_offset: usize = out.size;
    of.buf_write(out, shstrtab.data, shstrtab.size);

    # --- write section header table ---

    of.buf_align(out, 8);
    val shdr_offset: usize = out.size;

    # [0] SHN_UNDEF
    write_shdr_null(out);

    # [1..count] loadable sections
    si = 0;
    for (si < count) {
        val sec: *of.ExecSection = ?sections[si];
        val sh_offset: usize = (sec.vaddr - base)::usize;
        val sh_flags: u64 = map_sec_flags(sec.flags);

        # determine sh_type: BSS has no data
        var sh_type: u32 = SHT_PROGBITS;
        var sh_size: usize = sec.size;
        if (sec.data == nil && sec.size > 0) {
            sh_type = SHT_NOBITS;
        }

        # look up the section name offset in shstrtab.
        # section names were added in order starting at index 0.
        # we need to retrieve the offset. since strtab_add returns
        # the offset when called, we track it by re-scanning shstrtab.
        var name_off: u32 = 0;
        if (sections[si].name != nil) {
            name_off = exec_shstrtab_find(?shstrtab, sections[si].name);
        }

        write_shdr(out, name_off, sh_type, sh_flags | SHF_ALLOC,
                   sec.vaddr, sh_offset, sh_size, sec.align, 0, 0, 0);

        si = si + 1;
    }

    # [debug sections] non-loadable
    di = 0;
    for (di < e.dbg_count) {
        var dbg_name_off: u32 = 0;
        if (e.dbg_secs[di].name != nil) {
            dbg_name_off = exec_shstrtab_find(?shstrtab, e.dbg_secs[di].name);
        }
        write_shdr(out, dbg_name_off, SHT_PROGBITS, 0,
                   0, dbg_offsets[di], e.dbg_secs[di].size, 1, 0, 0, 0);
        di = di + 1;
    }

    # [.symtab] sh_link = strtab index, sh_info = first non-local
    write_shdr(out, symtab_name_off, SHT_SYMTAB, 0,
               0, symtab_offset, symtab_size, 8,
               strtab_shidx::u32, local_count::u32, SYM_SIZE);

    # [.strtab]
    write_shdr(out, strtab_name_off, SHT_STRTAB, 0,
               0, strtab_offset, strtab.size, 1, 0, 0, 0);

    # [.shstrtab]
    write_shdr(out, shstrtab_name_off, SHT_STRTAB, 0,
               0, shstrtab_offset, shstrtab.size, 1, 0, 0, 0);

    # --- patch ELF header ---

    # e_shoff at offset 40
    of.buf_patch_u64(out, 40, shdr_offset::u64);
    # e_shnum at offset 60 (u16)
    out.data[60] = (shdr_count & 255)::u8;
    out.data[61] = ((shdr_count >> 8) & 255)::u8;
    # e_shstrndx at offset 62 (u16)
    out.data[62] = (shstrtab_shidx & 255)::u8;
    out.data[63] = ((shstrtab_shidx >> 8) & 255)::u8;

    # --- cleanup ---

    allocator.allocator_free[usize](e.alloc, dbg_offsets, (e.dbg_count + 1)::usize);
    if (shstrtab.data != nil) {
        allocator.allocator_free[u8](e.alloc, shstrtab.data, shstrtab.cap);
    }
    if (strtab.data != nil) {
        allocator.allocator_free[u8](e.alloc, strtab.data, strtab.cap);
    }
}

# write an Elf64_Sym for an exec symbol.
fun write_exec_sym(out: *of.OutputBuffer, sym: *ExecSymEntry) {
    val elf_bind: u8 = map_binding(sym.binding);
    val elf_type: u8 = map_kind(sym.kind);
    val st_info: u8 = (elf_bind << 4) | elf_type;

    # st_shndx: ELF section header index.
    # ExecSection[i] maps to shdr index i+1 (0 is SHN_UNDEF).
    var st_shndx: u16 = 0;
    if (sym.section >= 0) {
        st_shndx = (sym.section + 1)::u16;
    }

    of.buf_write_u32(out, sym.name_off);     # st_name
    of.buf_write_u8(out, st_info);           # st_info
    of.buf_write_u8(out, 0);                 # st_other (visibility)
    of.buf_write_u16(out, st_shndx);         # st_shndx
    of.buf_write_u64(out, sym.value);        # st_value
    of.buf_write_u64(out, sym.size::u64);    # st_size
}

# find a string's offset in the shstrtab by linear scan.
fun exec_shstrtab_find(st: *StrTab, name: str) u32 {
    if (st == nil || name == nil || st.data == nil) { ret 0; }

    val nlen: usize = str_len(name);
    var off: usize = 0;
    for (off < st.size) {
        # check if string at 'off' matches 'name'
        var match: bool = true;
        var ci: usize = 0;
        for (ci < nlen) {
            if (off + ci >= st.size || st.data[off + ci] != name[ci]) {
                match = false;
            }
            ci = ci + 1;
        }
        if (match && off + nlen < st.size && st.data[off + nlen] == 0) {
            ret off::u32;
        }
        # advance to next null terminator
        for (off < st.size && st.data[off] != 0) {
            off = off + 1;
        }
        off = off + 1; # skip null
    }
    ret 0;
}

# map abstract section flags to ELF program header flags
fun exec_sec_flags_to_phdr(flags: u32) u32 {
    var pf: u32 = PF_R; # always readable
    if ((flags & 2) != 0) { pf = pf | PF_X; } # FLAG_EXEC
    if ((flags & 1) != 0) { pf = pf | PF_W; } # FLAG_WRITE
    ret pf;
}
