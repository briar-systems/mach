use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use of:        mach.compiler.target.of;
use elf:       mach.compiler.target.of.elf;

# mach.compiler.target.of.elf.reader: ELF object file reader.
# ---
# reads relocatable ELF (ET_REL) .o files into format-agnostic ObjFile records.
# maps ELF-specific constants back to MASM abstract constants using the
# target-provided unmap_reloc function. class and endianness are validated
# against the expected target.
# this is the read-side counterpart to elf.mach (writer).

# --- ELF constants (shared with elf.mach, duplicated for reader independence) ---

val EI_MAG0:    u8 = 0x7f;
val EI_MAG1:    u8 = 0x45;
val EI_MAG2:    u8 = 0x4c;
val EI_MAG3:    u8 = 0x46;

val ET_REL: u16 = 1;

val SHT_NULL:     u32 = 0;
val SHT_PROGBITS: u32 = 1;
val SHT_SYMTAB:   u32 = 2;
val SHT_STRTAB:   u32 = 3;
val SHT_RELA:     u32 = 4;
val SHT_NOBITS:   u32 = 8;

val SHF_WRITE:     u64 = 1;
val SHF_ALLOC:     u64 = 2;
val SHF_EXECINSTR: u64 = 4;

val STB_LOCAL:  u8 = 0;
val STB_GLOBAL: u8 = 1;
val STB_WEAK:   u8 = 2;

val STT_NOTYPE:  u8 = 0;
val STT_OBJECT:  u8 = 1;
val STT_FUNC:    u8 = 2;
val STT_SECTION: u8 = 3;
val STT_FILE:    u8 = 4;

# structure sizes
val EHDR_SIZE: usize = 64;
val SHDR_SIZE: usize = 64;
val SYM_SIZE:  usize = 24;
val RELA_SIZE: usize = 24;

# --- reader context ---

rec ReaderContext {
    alloc:  *allocator.Allocator;
    target: elf.ElfTarget;
}

# --- public API ---

# create_reader: construct the ELF object reader.
# target provides class, endianness, and relocation unmap function.
pub fun create_reader(alloc: *allocator.Allocator, target: elf.ElfTarget) Result[of.ObjectReader, str] {
    if (alloc == nil) {
        ret err[of.ObjectReader, str]("allocator is nil");
    }

    val ctx_r: Result[*ReaderContext, allocator.AllocError] =
        allocator.allocator_zalloc[ReaderContext](alloc, 1);
    if (result_is_err[*ReaderContext, allocator.AllocError](ctx_r)) {
        ret err[of.ObjectReader, str]("out of memory");
    }
    val ctx: *ReaderContext =
        result_unwrap_ok[*ReaderContext, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;
    ctx.target = target;

    var reader: of.ObjectReader;
    reader.ctx = ctx::ptr;
    reader.read = elf_read;
    reader.destroy_obj = elf_destroy_obj;
    reader.destroy = elf_destroy;

    ret ok[of.ObjectReader, str](reader);
}

# --- interface implementations ---

# elf_read: read an ELF .o file into an ObjFile.
fun elf_read(ctx: ptr, path: str, alloc: *allocator.Allocator) *of.ObjFile {
    if (ctx == nil || path == nil || alloc == nil) { ret nil; }
    val rctx: *ReaderContext = ctx::*ReaderContext;

    # read entire file into memory
    val file_r: Result[str, str] = read_file_bytes(path, alloc);
    if (result_is_err[str, str](file_r)) { ret nil; }
    val data: str = result_unwrap_ok[str, str](file_r);
    val buf: *u8 = data::ptr::*u8;

    # get file size by reading until we know the structure
    # first validate the ELF header
    # we need at least EHDR_SIZE bytes
    if (!validate_ehdr(buf, rctx.target.ei_class, rctx.target.ei_data)) { ret nil; }

    # allocate ObjFile
    val obj_r: Result[*of.ObjFile, allocator.AllocError] =
        allocator.allocator_zalloc[of.ObjFile](alloc, 1);
    if (result_is_err[*of.ObjFile, allocator.AllocError](obj_r)) { ret nil; }
    val obj: *of.ObjFile =
        result_unwrap_ok[*of.ObjFile, allocator.AllocError](obj_r);
    obj.alloc = alloc;
    obj.source_path = path;

    # parse ELF header
    val e_shoff: usize = read_u64(buf, 40)::usize;
    val e_shnum: i32 = read_u16(buf, 60)::i32;
    val e_shstrndx: i32 = read_u16(buf, 62)::i32;

    if (e_shnum == 0 || e_shoff == 0) { ret obj; }

    # find .shstrtab for section names
    val shstr_off: usize = e_shoff + (e_shstrndx::usize * SHDR_SIZE);
    val shstr_data_off: usize = read_u64(buf, shstr_off + 24)::usize;

    # first pass: find .symtab, .strtab, count user sections
    var symtab_idx: i32 = -1;
    var strtab_idx: i32 = -1;
    var user_sec_count: i32 = 0;
    var rela_count: i32 = 0;

    var si: i32 = 0;
    for (si < e_shnum) {
        val sh_off: usize = e_shoff + (si::usize * SHDR_SIZE);
        val sh_type: u32 = read_u32(buf, sh_off + 4);

        if (sh_type == SHT_SYMTAB) { symtab_idx = si; }
        or (sh_type == SHT_STRTAB && si != e_shstrndx) { strtab_idx = si; }
        or (sh_type == SHT_PROGBITS || sh_type == SHT_NOBITS) {
            user_sec_count = user_sec_count + 1;
        }
        or (sh_type == SHT_RELA) { rela_count = rela_count + 1; }

        si = si + 1;
    }

    # allocate section index map: ELF section index → ObjFile section index
    val map_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_alloc[i32](alloc, e_shnum::usize);
    if (result_is_err[*i32, allocator.AllocError](map_r)) { ret obj; }
    val sec_map: *i32 = result_unwrap_ok[*i32, allocator.AllocError](map_r);
    si = 0;
    for (si < e_shnum) {
        sec_map[si] = -1;
        si = si + 1;
    }

    # allocate user sections
    if (user_sec_count > 0) {
        val sr: Result[*of.ObjSection, allocator.AllocError] =
            allocator.allocator_zalloc[of.ObjSection](alloc, user_sec_count::usize);
        if (result_is_err[*of.ObjSection, allocator.AllocError](sr)) { ret obj; }
        obj.sections = result_unwrap_ok[*of.ObjSection, allocator.AllocError](sr);
    }

    # second pass: populate sections
    var oi: i32 = 0;
    si = 0;
    for (si < e_shnum) {
        val sh_off: usize = e_shoff + (si::usize * SHDR_SIZE);
        val sh_type: u32 = read_u32(buf, sh_off + 4);

        if (sh_type == SHT_PROGBITS || sh_type == SHT_NOBITS) {
            val sh_name_off: u32 = read_u32(buf, sh_off);
            val sh_flags: u64 = read_u64(buf, sh_off + 8);
            val sh_offset: usize = read_u64(buf, sh_off + 24)::usize;
            val sh_size: usize = read_u64(buf, sh_off + 32)::usize;
            val sh_align: usize = read_u64(buf, sh_off + 48)::usize;

            obj.sections[oi].name = str_at(buf, shstr_data_off + sh_name_off::usize);
            obj.sections[oi].kind = unmap_sec_kind(sh_type, sh_flags, obj.sections[oi].name);
            obj.sections[oi].flags = unmap_sec_flags(sh_flags);
            obj.sections[oi].size = sh_size;
            obj.sections[oi].align = sh_align;

            # copy section data (except NOBITS)
            if (sh_type == SHT_PROGBITS && sh_size > 0) {
                val dr: Result[*u8, allocator.AllocError] =
                    allocator.allocator_alloc[u8](alloc, sh_size);
                if (result_is_ok[*u8, allocator.AllocError](dr)) {
                    val dst: *u8 = result_unwrap_ok[*u8, allocator.AllocError](dr);
                    copy_bytes(dst, ?buf[sh_offset], sh_size);
                    obj.sections[oi].data = dst;
                }
            } or {
                obj.sections[oi].data = nil;
            }

            sec_map[si] = oi;
            oi = oi + 1;
        }
        si = si + 1;
    }
    obj.sec_count = oi;

    # parse .symtab
    if (symtab_idx >= 0 && strtab_idx >= 0) {
        val sym_sh_off: usize = e_shoff + (symtab_idx::usize * SHDR_SIZE);
        val sym_data_off: usize = read_u64(buf, sym_sh_off + 24)::usize;
        val sym_size: usize = read_u64(buf, sym_sh_off + 32)::usize;
        val sym_count: i32 = (sym_size / SYM_SIZE)::i32;

        val str_sh_off: usize = e_shoff + (strtab_idx::usize * SHDR_SIZE);
        val str_data_off: usize = read_u64(buf, str_sh_off + 24)::usize;

        # skip null symbol at index 0
        val real_sym_count: i32 = sym_count - 1;
        if (real_sym_count > 0) {
            val yr: Result[*of.ObjSymbol, allocator.AllocError] =
                allocator.allocator_zalloc[of.ObjSymbol](alloc, real_sym_count::usize);
            if (result_is_ok[*of.ObjSymbol, allocator.AllocError](yr)) {
                obj.symbols = result_unwrap_ok[*of.ObjSymbol, allocator.AllocError](yr);

                var yi: i32 = 0;
                for (yi < real_sym_count) {
                    val elf_idx: i32 = yi + 1; # skip null symbol
                    val sym_off: usize = sym_data_off + (elf_idx::usize * SYM_SIZE);

                    val st_name: u32 = read_u32(buf, sym_off);
                    val st_info: u8 = buf[sym_off + 4];
                    val st_shndx: u16 = read_u16(buf, sym_off + 6);
                    val st_value: usize = read_u64(buf, sym_off + 8)::usize;
                    val st_size: usize = read_u64(buf, sym_off + 16)::usize;

                    obj.symbols[yi].name = str_at(buf, str_data_off + st_name::usize);
                    obj.symbols[yi].binding = unmap_binding((st_info >> 4) & 0x0F);
                    obj.symbols[yi].kind = unmap_kind(st_info & 0x0F);
                    obj.symbols[yi].offset = st_value;
                    obj.symbols[yi].size = st_size;

                    if (st_shndx == 0) {
                        # SHN_UNDEF: external/undefined
                        obj.symbols[yi].section = -1;
                        obj.symbols[yi].defined = false;
                    } or {
                        val mapped: i32 = sec_map[st_shndx::i32];
                        obj.symbols[yi].section = mapped;
                        obj.symbols[yi].defined = mapped >= 0;
                    }

                    yi = yi + 1;
                }
                obj.sym_count = real_sym_count;
            }
        }

        # parse .rela sections
        if (rela_count > 0) {
            # count total relocations
            var total_relocs: i32 = 0;
            si = 0;
            for (si < e_shnum) {
                val sh_off: usize = e_shoff + (si::usize * SHDR_SIZE);
                val sh_type: u32 = read_u32(buf, sh_off + 4);
                if (sh_type == SHT_RELA) {
                    val rela_size: usize = read_u64(buf, sh_off + 32)::usize;
                    total_relocs = total_relocs + (rela_size / RELA_SIZE)::i32;
                }
                si = si + 1;
            }

            if (total_relocs > 0) {
                val rr: Result[*of.ObjReloc, allocator.AllocError] =
                    allocator.allocator_zalloc[of.ObjReloc](alloc, total_relocs::usize);
                if (result_is_ok[*of.ObjReloc, allocator.AllocError](rr)) {
                    obj.relocs = result_unwrap_ok[*of.ObjReloc, allocator.AllocError](rr);

                    var ri: i32 = 0;
                    si = 0;
                    for (si < e_shnum) {
                        val sh_off: usize = e_shoff + (si::usize * SHDR_SIZE);
                        val sh_type: u32 = read_u32(buf, sh_off + 4);

                        if (sh_type == SHT_RELA) {
                            val rela_data_off: usize = read_u64(buf, sh_off + 24)::usize;
                            val rela_size: usize = read_u64(buf, sh_off + 32)::usize;
                            val rela_target_shidx: i32 = read_u32(buf, sh_off + 44)::i32;
                            val rela_entry_count: i32 = (rela_size / RELA_SIZE)::i32;

                            var rj: i32 = 0;
                            for (rj < rela_entry_count) {
                                val re_off: usize = rela_data_off + (rj::usize * RELA_SIZE);
                                val r_offset: usize = read_u64(buf, re_off)::usize;
                                val r_info: u64 = read_u64(buf, re_off + 8);
                                val r_addend: i64 = read_u64(buf, re_off + 16)::i64;

                                val elf_sym_idx: i32 = (r_info >> 32)::i32;
                                val elf_rtype: u32 = (r_info & 0xFFFFFFFF)::u32;

                                obj.relocs[ri].section = sec_map[rela_target_shidx];
                                obj.relocs[ri].offset = r_offset;
                                obj.relocs[ri].rtype = rctx.target.unmap_reloc(elf_rtype);
                                obj.relocs[ri].addend = r_addend;

                                # resolve symbol name
                                if (elf_sym_idx > 0 && elf_sym_idx <= obj.sym_count) {
                                    obj.relocs[ri].symbol_name =
                                        obj.symbols[elf_sym_idx - 1].name;
                                } or {
                                    obj.relocs[ri].symbol_name = nil;
                                }

                                ri = ri + 1;
                                rj = rj + 1;
                            }
                        }
                        si = si + 1;
                    }
                    obj.reloc_count = ri;
                }
            }
        }
    }

    # cleanup temp
    allocator.allocator_free[i32](alloc, sec_map, e_shnum::usize);

    ret obj;
}

# elf_destroy_obj: free all memory associated with an ObjFile.
fun elf_destroy_obj(ctx: ptr, obj: *of.ObjFile) {
    if (obj == nil || obj.alloc == nil) { ret; }
    val alloc: *allocator.Allocator = obj.alloc;

    # free section data
    var si: i32 = 0;
    for (si < obj.sec_count) {
        if (obj.sections[si].data != nil) {
            allocator.allocator_free[u8](alloc, obj.sections[si].data,
                obj.sections[si].size);
        }
        si = si + 1;
    }
    if (obj.sections != nil) {
        allocator.allocator_free[of.ObjSection](alloc, obj.sections,
            obj.sec_count::usize);
    }
    if (obj.symbols != nil) {
        allocator.allocator_free[of.ObjSymbol](alloc, obj.symbols,
            obj.sym_count::usize);
    }
    if (obj.relocs != nil) {
        allocator.allocator_free[of.ObjReloc](alloc, obj.relocs,
            obj.reloc_count::usize);
    }
    allocator.allocator_free[of.ObjFile](alloc, obj, 1);
}

# elf_destroy: free the reader context.
fun elf_destroy(ctx: ptr) {
    val e: *ReaderContext = ctx::*ReaderContext;
    if (e == nil || e.alloc == nil) { ret; }
    allocator.allocator_free[ReaderContext](e.alloc, e, 1);
}

# --- ELF → MASM reverse mappings ---

# unmap_binding: ELF STB_* → abstract BIND_*
# abstract: 0=local, 1=global, 2=weak
fun unmap_binding(elf_bind: u8) u8 {
    if (elf_bind == STB_GLOBAL) { ret 1; }
    if (elf_bind == STB_WEAK)   { ret 2; }
    ret 0;
}

# unmap_kind: ELF STT_* → abstract SYM_*
# abstract: 0=none, 1=func, 2=object, 3=section, 4=file
fun unmap_kind(elf_type: u8) u8 {
    if (elf_type == STT_FUNC)    { ret 1; }
    if (elf_type == STT_OBJECT)  { ret 2; }
    if (elf_type == STT_SECTION) { ret 3; }
    if (elf_type == STT_FILE)    { ret 4; }
    ret 0;
}

# unmap_sec_flags: ELF SHF_* → abstract FLAG_*
# abstract: 1=write, 2=exec, 4=alloc
fun unmap_sec_flags(elf_flags: u64) u32 {
    var f: u32 = 0;
    if ((elf_flags & SHF_WRITE) != 0)     { f = f | 1; }
    if ((elf_flags & SHF_EXECINSTR) != 0) { f = f | 2; }
    if ((elf_flags & SHF_ALLOC) != 0)     { f = f | 4; }
    ret f;
}

# unmap_sec_kind: ELF sh_type + flags + name → abstract SEC_*
# abstract: 0=text, 1=data, 2=rodata, 3=bss, 4=custom
#
# uses ELF flags as the primary discriminator:
#   NOBITS                        → bss
#   ALLOC + EXECINSTR             → text
#   ALLOC + WRITE                 → data
#   ALLOC (no write, no exec)     → rodata
# falls back to name heuristics when flags are ambiguous.
fun unmap_sec_kind(sh_type: u32, sh_flags: u64, name: str) u8 {
    if (sh_type == SHT_NOBITS) { ret 3; } # bss

    val is_alloc: bool = (sh_flags & SHF_ALLOC) != 0;
    val is_exec:  bool = (sh_flags & SHF_EXECINSTR) != 0;
    val is_write: bool = (sh_flags & SHF_WRITE) != 0;

    if (is_alloc) {
        if (is_exec)       { ret 0; } # text
        if (is_write)      { ret 1; } # data
        ret 2;                         # rodata (alloc, no write, no exec)
    }

    # non-alloc: fall back to name heuristics
    if (name != nil) {
        if (str_starts_with(name, ".text"))   { ret 0; }
        if (str_starts_with(name, ".rodata")) { ret 2; }
        if (str_starts_with(name, ".data"))   { ret 1; }
        if (str_starts_with(name, ".bss"))    { ret 3; }
    }
    ret 4; # custom
}

# --- byte-level helpers ---

fun read_u16(buf: *u8, off: usize) u16 {
    ret buf[off]::u16 | (buf[off + 1]::u16 << 8);
}

fun read_u32(buf: *u8, off: usize) u32 {
    ret buf[off]::u32 | (buf[off + 1]::u32 << 8) |
        (buf[off + 2]::u32 << 16) | (buf[off + 3]::u32 << 24);
}

fun read_u64(buf: *u8, off: usize) u64 {
    ret buf[off]::u64 | (buf[off + 1]::u64 << 8) |
        (buf[off + 2]::u64 << 16) | (buf[off + 3]::u64 << 24) |
        (buf[off + 4]::u64 << 32) | (buf[off + 5]::u64 << 40) |
        (buf[off + 6]::u64 << 48) | (buf[off + 7]::u64 << 56);
}

# str_at: return a pointer to the null-terminated string at the given offset.
fun str_at(buf: *u8, off: usize) str {
    ret (?buf[off])::&u8;
}

fun copy_bytes(dst: *u8, src: *u8, len: usize) {
    var i: usize = 0;
    for (i < len) {
        dst[i] = src[i];
        i = i + 1;
    }
}

fun validate_ehdr(buf: *u8, ei_class: u8, ei_data: u8) bool {
    if (buf == nil) { ret false; }
    # check magic
    if (buf[0] != EI_MAG0 || buf[1] != EI_MAG1 ||
        buf[2] != EI_MAG2 || buf[3] != EI_MAG3) { ret false; }
    # check class and endianness match expected target
    if (buf[4] != ei_class || buf[5] != ei_data) { ret false; }
    # check type = ET_REL
    val e_type: u16 = read_u16(buf, 16);
    if (e_type != ET_REL) { ret false; }
    ret true;
}

# read_file_bytes: read an entire file into an allocated buffer.
# returns a *u8 pointer disguised as str. use buf::ptr::*u8 to access raw bytes.
fun read_file_bytes(path: str, alloc: *allocator.Allocator) Result[str, str] {
    val file_r: Result[fs.File, str] = fs.open(path);
    if (result_is_err[fs.File, str](file_r)) {
        ret err[str, str]("failed to open file");
    }

    var file: fs.File = result_unwrap_ok[fs.File, str](file_r);

    # get file size via stat
    val stat_r: Result[fs.FileInfo, str] = fs.info(?file);
    if (result_is_err[fs.FileInfo, str](stat_r)) {
        fs.close(?file);
        ret err[str, str]("failed to stat file");
    }
    val fi: fs.FileInfo = result_unwrap_ok[fs.FileInfo, str](stat_r);
    val fsize: usize = fi.size;

    # allocate buffer
    val br: Result[*u8, allocator.AllocError] =
        allocator.allocator_alloc[u8](alloc, fsize + 1);
    if (result_is_err[*u8, allocator.AllocError](br)) {
        fs.close(?file);
        ret err[str, str]("out of memory");
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](br);

    # read file contents
    val read_r: Result[usize, str] = fs.read(?file, buf, fsize);
    fs.close(?file);

    if (result_is_err[usize, str](read_r)) {
        ret err[str, str]("failed to read file");
    }

    buf[fsize] = 0;
    ret ok[str, str](buf::&u8);
}
