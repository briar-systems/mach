# mach.compiler.target.of.select: object format implementation selector.
# ---
# maps format names to object format implementations.
# creates the full ObjectFormat: object writer, exec writer, reader, and debug info.
# adding a new format: import it here, add an if-branch.

use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use of:        mach.compiler.target.of;
use elf:       mach.compiler.target.of.elf;
use elf_read:  mach.compiler.target.of.elf.reader;
use dwarf:     mach.compiler.target.of.dwarf;

# select all format interfaces by format and architecture name.
# ptr_size and endian are passed through to the debug info implementation.
pub fun select(format: str, arch: str, ptr_size: usize, endian: u8,
               alloc: *allocator.Allocator) Result[of.ObjectFormat, str] {
    if (format == nil || arch == nil || alloc == nil) {
        ret err[of.ObjectFormat, str]("invalid arguments");
    }

    if (str_equals(format, "elf")) {
        ret select_elf(arch, ptr_size, endian, alloc);
    }

    ret err[of.ObjectFormat, str]("unsupported object format");
}

# select just an ObjWriter (for creating fresh per-CU writers).
pub fun select_object_format(format: str, arch: str,
                             alloc: *allocator.Allocator) Result[of.ObjWriter, str] {
    if (format == nil || arch == nil || alloc == nil) {
        ret err[of.ObjWriter, str]("invalid arguments");
    }

    if (str_equals(format, "elf")) {
        val tgt_r: Result[elf.ElfTarget, str] = make_elf_target(arch);
        if (result_is_err[elf.ElfTarget, str](tgt_r)) {
            ret err[of.ObjWriter, str](result_unwrap_err[elf.ElfTarget, str](tgt_r));
        }
        ret elf.create(alloc, result_unwrap_ok[elf.ElfTarget, str](tgt_r));
    }

    ret err[of.ObjWriter, str]("unsupported object format");
}

# select just a DebugInfo (for creating fresh per-CU debug writers).
pub fun select_debug_info(format: str, ptr_size: usize, endian: u8,
                          alloc: *allocator.Allocator) Result[of.DebugInfo, str] {
    if (format == nil || alloc == nil) {
        ret err[of.DebugInfo, str]("invalid arguments");
    }

    if (str_equals(format, "elf") || str_equals(format, "macho")) {
        ret dwarf.create(alloc, ptr_size, endian);
    } or (str_equals(format, "coff")) {
        ret err[of.DebugInfo, str]("CodeView debug info not yet implemented");
    }

    ret err[of.DebugInfo, str]("unsupported debug info format");
}

# --- ELF ---

fun select_elf(arch: str, ptr_size: usize, endian: u8,
               alloc: *allocator.Allocator) Result[of.ObjectFormat, str] {
    val tgt_r: Result[elf.ElfTarget, str] = make_elf_target(arch);
    if (result_is_err[elf.ElfTarget, str](tgt_r)) {
        ret err[of.ObjectFormat, str](result_unwrap_err[elf.ElfTarget, str](tgt_r));
    }
    val elf_tgt: elf.ElfTarget = result_unwrap_ok[elf.ElfTarget, str](tgt_r);
    var fs: of.ObjectFormat;
    fs.name = "elf";

    val of_r: Result[of.ObjWriter, str] = elf.create(alloc, elf_tgt);
    if (result_is_err[of.ObjWriter, str](of_r)) {
        ret err[of.ObjectFormat, str](result_unwrap_err[of.ObjWriter, str](of_r));
    }
    fs.obj = result_unwrap_ok[of.ObjWriter, str](of_r);

    val ef_r: Result[of.ExecFormat, str] = elf.create_exec(alloc, elf_tgt);
    if (result_is_err[of.ExecFormat, str](ef_r)) {
        ret err[of.ObjectFormat, str](result_unwrap_err[of.ExecFormat, str](ef_r));
    }
    fs.exec = result_unwrap_ok[of.ExecFormat, str](ef_r);

    val or_r: Result[of.ObjectReader, str] = elf_read.create_reader(alloc, elf_tgt);
    if (result_is_err[of.ObjectReader, str](or_r)) {
        ret err[of.ObjectFormat, str](result_unwrap_err[of.ObjectReader, str](or_r));
    }
    fs.reader = result_unwrap_ok[of.ObjectReader, str](or_r);

    val di_r: Result[of.DebugInfo, str] = dwarf.create(alloc, ptr_size, endian);
    if (result_is_err[of.DebugInfo, str](di_r)) {
        ret err[of.ObjectFormat, str](result_unwrap_err[of.DebugInfo, str](di_r));
    }
    fs.di = result_unwrap_ok[of.DebugInfo, str](di_r);

    ret ok[of.ObjectFormat, str](fs);
}

# map architecture name to ELF target metadata.
fun make_elf_target(arch: str) Result[elf.ElfTarget, str] {
    if (str_equals(arch, "x86_64")) {
        ret ok[elf.ElfTarget, str](elf.target_x86_64());
    }

    ret err[elf.ElfTarget, str]("unsupported ELF architecture");
}
