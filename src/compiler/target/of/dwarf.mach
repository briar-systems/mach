# mach.compiler.target.of.dwarf: DWARF 4 debug info generator
#
# implements the DebugInfo interface for DWARF 4 format. emits
# .debug_abbrev, .debug_info, .debug_line, and .debug_str sections
# into the object writer during finalization.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;

use of: mach.compiler.target.of;

val DW_TAG_compile_unit: u16 = 0x11;
val DW_TAG_subprogram:   u16 = 0x2E;

val DW_AT_producer:  u16 = 0x25;
val DW_AT_language:  u16 = 0x12;
val DW_AT_name:      u16 = 0x03;
val DW_AT_comp_dir:  u16 = 0x1B;
val DW_AT_low_pc:    u16 = 0x11;
val DW_AT_high_pc:   u16 = 0x12;
val DW_AT_stmt_list: u16 = 0x10;
val DW_AT_decl_file: u16 = 0x3A;
val DW_AT_decl_line: u16 = 0x3B;

val DW_FORM_strp:       u16 = 0x0E;
val DW_FORM_addr:       u16 = 0x01;
val DW_FORM_data1:      u16 = 0x0B;
val DW_FORM_data2:      u16 = 0x05;
val DW_FORM_data4:      u16 = 0x06;
val DW_FORM_sec_offset: u16 = 0x17;

val DW_LANG_Mach: u16 = 0x8001;

val DW_CHILDREN_yes: u8 = 1;
val DW_CHILDREN_no:  u8 = 0;

val DW_LNS_copy:         u8 = 1;
val DW_LNS_advance_pc:   u8 = 2;
val DW_LNS_advance_line: u8 = 3;
val DW_LNS_set_file:     u8 = 4;
val DW_LNS_set_column:   u8 = 5;

val DW_LNE_end_sequence: u8 = 1;
val DW_LNE_set_address:  u8 = 2;

val LINE_BASE:    i32 = -5;
val LINE_RANGE:   i32 = 14;
val OPCODE_BASE:  u8 = 13;

val INIT_FILE_CAP: u32 = 16;
val INIT_FUNC_CAP: u32 = 64;
val INIT_LINE_CAP: u32 = 256;
val INIT_BUF_CAP:  usize = 4096;

rec FileEntry {
    path: str;
    dir:  str;
}

rec FuncEntry {
    name:     str;
    file_idx: u16;
    line:     u32;
    low_pc:   u64;
    high_pc:  u64;
}

rec LineEntry {
    addr:     u64;
    file_idx: u16;
    line:     u32;
    col:      u32;
}

rec DebugReloc {
    buf_offset: u32;
    addend:     u64;
}

rec DwarfCtx {
    alloc:       *allocator.Allocator;
    files:       *FileEntry;
    file_count:  u32;
    file_cap:    u32;
    funcs:       *FuncEntry;
    func_count:  u32;
    func_cap:    u32;
    lines:       *LineEntry;
    line_count:  u32;
    line_cap:    u32;
    comp_dir:    str;
    producer:    str;
    info_relocs:      *DebugReloc;
    info_reloc_count: i32;
    info_reloc_cap:   i32;
    line_relocs:      *DebugReloc;
    line_reloc_count: i32;
    line_reloc_cap:   i32;
}

rec EmitBuf {
    data: *u8;
    size: usize;
    cap:  usize;
}

fun add_debug_reloc(alloc: *allocator.Allocator, relocs: **DebugReloc, count: *i32, cap: *i32, offset: u32, addend: u64) {
    if (@count >= @cap) {
        var new_cap: i32 = 32;
        if (@cap > 0) { new_cap = @cap * 2; }
        val res: Result[*DebugReloc, str] = allocator.reallocate[DebugReloc](alloc, @relocs, (@cap)::usize, new_cap::usize);
        if (is_err[*DebugReloc, str](res)) { ret; }
        @relocs = unwrap_ok[*DebugReloc, str](res);
        @cap = new_cap;
    }
    val idx: i32 = @count;
    (@relocs)[idx].buf_offset = offset;
    (@relocs)[idx].addend     = addend;
    @count = @count + 1;
}

fun buf_init_emit(alloc: *allocator.Allocator) EmitBuf {
    var b: EmitBuf;
    b.size = 0;
    b.cap  = INIT_BUF_CAP;
    val res: Result[*u8, str] = allocator.zallocate[u8](alloc, INIT_BUF_CAP);
    if (is_err[*u8, str](res)) {
        b.data = nil;
        b.cap  = 0;
        ret b;
    }
    b.data = unwrap_ok[*u8, str](res);
    ret b;
}

fun buf_grow(alloc: *allocator.Allocator, b: *EmitBuf, needed: usize) bool {
    val total: usize = b.size + needed;
    if (total <= b.cap) { ret true; }
    var new_cap: usize = b.cap;
    if (new_cap == 0) { new_cap = INIT_BUF_CAP; }
    for (new_cap < total) {
        new_cap = new_cap * 2;
    }
    val res: Result[*u8, str] = allocator.reallocate[u8](alloc, b.data, b.cap, new_cap);
    if (is_err[*u8, str](res)) { ret false; }
    b.data = unwrap_ok[*u8, str](res);
    b.cap = new_cap;
    ret true;
}

fun buf_u8(alloc: *allocator.Allocator, b: *EmitBuf, v: u8) {
    if (!buf_grow(alloc, b, 1)) { ret; }
    b.data[b.size] = v;
    b.size = b.size + 1;
}

fun buf_u16(alloc: *allocator.Allocator, b: *EmitBuf, v: u16) {
    if (!buf_grow(alloc, b, 2)) { ret; }
    b.data[b.size]     = (v & 0xFF)::u8;
    b.data[b.size + 1] = ((v >> 8) & 0xFF)::u8;
    b.size = b.size + 2;
}

fun buf_u32(alloc: *allocator.Allocator, b: *EmitBuf, v: u32) {
    if (!buf_grow(alloc, b, 4)) { ret; }
    b.data[b.size]     = (v & 0xFF)::u8;
    b.data[b.size + 1] = ((v >> 8) & 0xFF)::u8;
    b.data[b.size + 2] = ((v >> 16) & 0xFF)::u8;
    b.data[b.size + 3] = ((v >> 24) & 0xFF)::u8;
    b.size = b.size + 4;
}

fun buf_u64(alloc: *allocator.Allocator, b: *EmitBuf, v: u64) {
    buf_u32(alloc, b, (v & 0xFFFFFFFF)::u32);
    buf_u32(alloc, b, ((v >> 32) & 0xFFFFFFFF)::u32);
}

fun buf_uleb128(alloc: *allocator.Allocator, b: *EmitBuf, value: u64) {
    var v: u64 = value;
    for (true) {
        var byte: u8 = (v & 0x7F)::u8;
        v = v >> 7;
        if (v != 0) {
            byte = byte | 0x80;
        }
        buf_u8(alloc, b, byte);
        if (v == 0) { brk; }
    }
}

fun buf_sleb128(alloc: *allocator.Allocator, b: *EmitBuf, value: i64) {
    var v: i64 = value;
    var more: bool = true;
    for (more) {
        var byte: u8 = (v & 0x7F)::u8;
        v = v >> 7;
        if ((v == 0 && (byte & 0x40) == 0) || (v == -1 && (byte & 0x40) != 0)) {
            more = false;
        } or {
            byte = byte | 0x80;
        }
        buf_u8(alloc, b, byte);
    }
}

fun buf_str(alloc: *allocator.Allocator, b: *EmitBuf, s: str) {
    if (s == nil) {
        buf_u8(alloc, b, 0);
        ret;
    }
    val len: usize = str_len(s);
    if (!buf_grow(alloc, b, len + 1)) { ret; }
    var i: usize = 0;
    for (i < len) {
        b.data[b.size] = s[i];
        b.size = b.size + 1;
        i = i + 1;
    }
    b.data[b.size] = 0;
    b.size = b.size + 1;
}

fun buf_patch_u32(b: *EmitBuf, offset: usize, v: u32) {
    if (offset + 4 > b.size) { ret; }
    b.data[offset]     = (v & 0xFF)::u8;
    b.data[offset + 1] = ((v >> 8) & 0xFF)::u8;
    b.data[offset + 2] = ((v >> 16) & 0xFF)::u8;
    b.data[offset + 3] = ((v >> 24) & 0xFF)::u8;
}

fun buf_dnit(alloc: *allocator.Allocator, b: *EmitBuf) {
    if (b.data != nil && b.cap > 0) {
        allocator.deallocate[u8](alloc, b.data, b.cap);
    }
    b.data = nil;
    b.size = 0;
    b.cap  = 0;
}

# dwarf_add_file: register a source file
fun dwarf_add_file(ctx: ptr, path: str, dir: str) u16 {
    val d: *DwarfCtx = ctx::*DwarfCtx;

    var i: u32 = 0;
    for (i < d.file_count) {
        if (d.files[i].path != nil && str_equals(d.files[i].path, path)) {
            ret (i + 1)::u16;
        }
        i = i + 1;
    }

    if (d.file_count >= d.file_cap) {
        val new_cap: u32 = d.file_cap * 2;
        val res: Result[*FileEntry, str] = allocator.reallocate[FileEntry](
            d.alloc, d.files, d.file_cap::usize, new_cap::usize
        );
        if (is_err[*FileEntry, str](res)) { ret 0; }
        d.files = unwrap_ok[*FileEntry, str](res);
        d.file_cap = new_cap;
    }

    val idx: u32 = d.file_count;
    d.files[idx].path = path;
    d.files[idx].dir  = dir;
    d.file_count = d.file_count + 1;
    ret (idx + 1)::u16;
}

# dwarf_add_function: register a function
fun dwarf_add_function(ctx: ptr, name: str, file_idx: u16, line: u32, low_pc: u64, high_pc: u64) {
    val d: *DwarfCtx = ctx::*DwarfCtx;

    if (d.func_count >= d.func_cap) {
        val new_cap: u32 = d.func_cap * 2;
        val res: Result[*FuncEntry, str] = allocator.reallocate[FuncEntry](
            d.alloc, d.funcs, d.func_cap::usize, new_cap::usize
        );
        if (is_err[*FuncEntry, str](res)) { ret; }
        d.funcs = unwrap_ok[*FuncEntry, str](res);
        d.func_cap = new_cap;
    }

    val idx: u32 = d.func_count;
    d.funcs[idx].name     = name;
    d.funcs[idx].file_idx = file_idx;
    d.funcs[idx].line     = line;
    d.funcs[idx].low_pc   = low_pc;
    d.funcs[idx].high_pc  = high_pc;
    d.func_count = d.func_count + 1;
}

# dwarf_add_line: register a line mapping
fun dwarf_add_line(ctx: ptr, addr: u64, file_idx: u16, line: u32, col: u32) {
    val d: *DwarfCtx = ctx::*DwarfCtx;

    if (d.line_count >= d.line_cap) {
        val new_cap: u32 = d.line_cap * 2;
        val res: Result[*LineEntry, str] = allocator.reallocate[LineEntry](
            d.alloc, d.lines, d.line_cap::usize, new_cap::usize
        );
        if (is_err[*LineEntry, str](res)) { ret; }
        d.lines = unwrap_ok[*LineEntry, str](res);
        d.line_cap = new_cap;
    }

    val idx: u32 = d.line_count;
    d.lines[idx].addr     = addr;
    d.lines[idx].file_idx = file_idx;
    d.lines[idx].line     = line;
    d.lines[idx].col      = col;
    d.line_count = d.line_count + 1;
}

# strtab_add: add a string to the .debug_str buffer, return its offset
fun strtab_add(alloc: *allocator.Allocator, strtab: *EmitBuf, s: str) u32 {
    val off: u32 = strtab.size::u32;
    buf_str(alloc, strtab, s);
    ret off;
}

# emit_abbrev: emit the .debug_abbrev section
fun emit_abbrev(alloc: *allocator.Allocator, b: *EmitBuf) {
    # abbrev 1: DW_TAG_compile_unit, has children
    buf_uleb128(alloc, b, 1);
    buf_uleb128(alloc, b, DW_TAG_compile_unit::u64);
    buf_u8(alloc, b, DW_CHILDREN_yes);
    # DW_AT_producer, DW_FORM_strp
    buf_uleb128(alloc, b, DW_AT_producer::u64);
    buf_uleb128(alloc, b, DW_FORM_strp::u64);
    # DW_AT_language, DW_FORM_data2
    buf_uleb128(alloc, b, DW_AT_language::u64);
    buf_uleb128(alloc, b, DW_FORM_data2::u64);
    # DW_AT_name, DW_FORM_strp
    buf_uleb128(alloc, b, DW_AT_name::u64);
    buf_uleb128(alloc, b, DW_FORM_strp::u64);
    # DW_AT_comp_dir, DW_FORM_strp
    buf_uleb128(alloc, b, DW_AT_comp_dir::u64);
    buf_uleb128(alloc, b, DW_FORM_strp::u64);
    # DW_AT_low_pc, DW_FORM_addr
    buf_uleb128(alloc, b, DW_AT_low_pc::u64);
    buf_uleb128(alloc, b, DW_FORM_addr::u64);
    # DW_AT_high_pc, DW_FORM_addr
    buf_uleb128(alloc, b, DW_AT_high_pc::u64);
    buf_uleb128(alloc, b, DW_FORM_addr::u64);
    # DW_AT_stmt_list, DW_FORM_sec_offset
    buf_uleb128(alloc, b, DW_AT_stmt_list::u64);
    buf_uleb128(alloc, b, DW_FORM_sec_offset::u64);
    # end of attributes
    buf_uleb128(alloc, b, 0);
    buf_uleb128(alloc, b, 0);

    # abbrev 2: DW_TAG_subprogram, no children
    buf_uleb128(alloc, b, 2);
    buf_uleb128(alloc, b, DW_TAG_subprogram::u64);
    buf_u8(alloc, b, DW_CHILDREN_no);
    # DW_AT_name, DW_FORM_strp
    buf_uleb128(alloc, b, DW_AT_name::u64);
    buf_uleb128(alloc, b, DW_FORM_strp::u64);
    # DW_AT_decl_file, DW_FORM_data2
    buf_uleb128(alloc, b, DW_AT_decl_file::u64);
    buf_uleb128(alloc, b, DW_FORM_data2::u64);
    # DW_AT_decl_line, DW_FORM_data4
    buf_uleb128(alloc, b, DW_AT_decl_line::u64);
    buf_uleb128(alloc, b, DW_FORM_data4::u64);
    # DW_AT_low_pc, DW_FORM_addr
    buf_uleb128(alloc, b, DW_AT_low_pc::u64);
    buf_uleb128(alloc, b, DW_FORM_addr::u64);
    # DW_AT_high_pc, DW_FORM_addr
    buf_uleb128(alloc, b, DW_AT_high_pc::u64);
    buf_uleb128(alloc, b, DW_FORM_addr::u64);
    # end of attributes
    buf_uleb128(alloc, b, 0);
    buf_uleb128(alloc, b, 0);

    # end of abbreviation table
    buf_uleb128(alloc, b, 0);
}

# emit_info: emit the .debug_info section
fun emit_info(alloc: *allocator.Allocator, b: *EmitBuf, d: *DwarfCtx, strtab: *EmitBuf) {
    # compilation unit header
    val unit_length_off: usize = b.size;
    buf_u32(alloc, b, 0);
    val unit_start: usize = b.size;
    buf_u16(alloc, b, 4);
    buf_u32(alloc, b, 0);
    buf_u8(alloc, b, 8);

    # compile unit DIE (abbrev 1)
    buf_uleb128(alloc, b, 1);

    val producer_off: u32 = strtab_add(alloc, strtab, d.producer);
    buf_u32(alloc, b, producer_off);
    buf_u16(alloc, b, DW_LANG_Mach);

    var cu_name: str = "main.mach";
    if (d.file_count > 0 && d.files[0].path != nil) {
        cu_name = d.files[0].path;
    }
    val name_off: u32 = strtab_add(alloc, strtab, cu_name);
    buf_u32(alloc, b, name_off);

    val dir_off: u32 = strtab_add(alloc, strtab, d.comp_dir);
    buf_u32(alloc, b, dir_off);

    # low_pc / high_pc for the compilation unit
    var cu_low: u64 = 0;
    var cu_high: u64 = 0;
    if (d.func_count > 0) {
        cu_low = d.funcs[0].low_pc;
        cu_high = d.funcs[0].high_pc;
        var fi: u32 = 1;
        for (fi < d.func_count) {
            if (d.funcs[fi].low_pc < cu_low) { cu_low = d.funcs[fi].low_pc; }
            if (d.funcs[fi].high_pc > cu_high) { cu_high = d.funcs[fi].high_pc; }
            fi = fi + 1;
        }
    }
    add_debug_reloc(alloc, ?d.info_relocs, ?d.info_reloc_count, ?d.info_reloc_cap, b.size::u32, cu_low);
    buf_u64(alloc, b, 0);
    add_debug_reloc(alloc, ?d.info_relocs, ?d.info_reloc_count, ?d.info_reloc_cap, b.size::u32, cu_high);
    buf_u64(alloc, b, 0);

    # stmt_list: offset into .debug_line (always 0 for single CU)
    buf_u32(alloc, b, 0);

    # subprogram DIEs (abbrev 2)
    var fi: u32 = 0;
    for (fi < d.func_count) {
        buf_uleb128(alloc, b, 2);

        val fn_name_off: u32 = strtab_add(alloc, strtab, d.funcs[fi].name);
        buf_u32(alloc, b, fn_name_off);
        buf_u16(alloc, b, d.funcs[fi].file_idx);
        buf_u32(alloc, b, d.funcs[fi].line);
        add_debug_reloc(alloc, ?d.info_relocs, ?d.info_reloc_count, ?d.info_reloc_cap, b.size::u32, d.funcs[fi].low_pc);
        buf_u64(alloc, b, 0);
        add_debug_reloc(alloc, ?d.info_relocs, ?d.info_reloc_count, ?d.info_reloc_cap, b.size::u32, d.funcs[fi].high_pc);
        buf_u64(alloc, b, 0);

        fi = fi + 1;
    }

    # null terminator for children of compile_unit
    buf_u8(alloc, b, 0);

    # patch unit length
    val unit_length: u32 = (b.size - unit_start)::u32;
    buf_patch_u32(b, unit_length_off, unit_length);
}

# emit_line: emit the .debug_line section
fun emit_line(alloc: *allocator.Allocator, b: *EmitBuf, d: *DwarfCtx) {
    # line number program header
    val total_length_off: usize = b.size;
    buf_u32(alloc, b, 0);
    val header_start: usize = b.size;

    buf_u16(alloc, b, 4);
    val header_length_off: usize = b.size;
    buf_u32(alloc, b, 0);
    val prologue_start: usize = b.size;

    # minimum_instruction_length
    buf_u8(alloc, b, 1);
    # maximum_operations_per_instruction (DWARF 4)
    buf_u8(alloc, b, 1);
    # default_is_stmt
    buf_u8(alloc, b, 1);
    # line_base
    buf_u8(alloc, b, LINE_BASE::u8);
    # line_range
    buf_u8(alloc, b, LINE_RANGE::u8);
    # opcode_base
    buf_u8(alloc, b, OPCODE_BASE);

    # standard opcode lengths (opcode_base - 1 entries)
    buf_u8(alloc, b, 0); # DW_LNS_copy (1)
    buf_u8(alloc, b, 1); # DW_LNS_advance_pc (2)
    buf_u8(alloc, b, 1); # DW_LNS_advance_line (3)
    buf_u8(alloc, b, 1); # DW_LNS_set_file (4)
    buf_u8(alloc, b, 1); # DW_LNS_set_column (5)
    buf_u8(alloc, b, 0); # DW_LNS_negate_stmt (6)
    buf_u8(alloc, b, 0); # DW_LNS_set_basic_block (7)
    buf_u8(alloc, b, 0); # DW_LNS_const_add_pc (8)
    buf_u8(alloc, b, 1); # DW_LNS_fixed_advance_pc (9)
    buf_u8(alloc, b, 0); # DW_LNS_set_prologue_end (10)
    buf_u8(alloc, b, 0); # DW_LNS_set_epilogue_begin (11)
    buf_u8(alloc, b, 1); # DW_LNS_set_isa (12)

    # include directories: just the comp_dir, then null terminator
    buf_str(alloc, b, d.comp_dir);
    buf_u8(alloc, b, 0);

    # file name table
    var fi: u32 = 0;
    for (fi < d.file_count) {
        buf_str(alloc, b, d.files[fi].path);
        buf_uleb128(alloc, b, 1); # directory index (1 = comp_dir)
        buf_uleb128(alloc, b, 0); # last modification time
        buf_uleb128(alloc, b, 0); # file size
        fi = fi + 1;
    }
    buf_u8(alloc, b, 0);

    # patch header length
    val header_length: u32 = (b.size - prologue_start)::u32;
    buf_patch_u32(b, header_length_off, header_length);

    # line number program opcodes
    if (d.line_count > 0) {
        # DW_LNE_set_address for first entry
        buf_u8(alloc, b, 0);
        buf_uleb128(alloc, b, 9);
        buf_u8(alloc, b, DW_LNE_set_address);
        add_debug_reloc(alloc, ?d.line_relocs, ?d.line_reloc_count, ?d.line_reloc_cap, b.size::u32, d.lines[0].addr);
        buf_u64(alloc, b, 0);

        var cur_file: u16 = 1;
        var cur_line: i64 = 1;
        var cur_addr: u64 = d.lines[0].addr;

        var li: u32 = 0;
        for (li < d.line_count) {
            val entry_file: u16 = d.lines[li].file_idx;
            val entry_line: i64 = d.lines[li].line::i64;
            val entry_addr: u64 = d.lines[li].addr;

            if (entry_file != cur_file) {
                buf_u8(alloc, b, DW_LNS_set_file);
                buf_uleb128(alloc, b, entry_file::u64);
                cur_file = entry_file;
            }

            if (d.lines[li].col != 0) {
                buf_u8(alloc, b, DW_LNS_set_column);
                buf_uleb128(alloc, b, d.lines[li].col::u64);
            }

            val line_delta: i64 = entry_line - cur_line;
            val addr_delta: u64 = entry_addr - cur_addr;

            val adjusted_opcode: i64 = line_delta - LINE_BASE::i64;
            if (adjusted_opcode >= 0 && adjusted_opcode < LINE_RANGE::i64 && addr_delta < 245) {
                val opcode: i64 = adjusted_opcode + (addr_delta::i64 * LINE_RANGE::i64) + OPCODE_BASE::i64;
                if (opcode >= OPCODE_BASE::i64 && opcode <= 255) {
                    buf_u8(alloc, b, opcode::u8);
                    cur_line = entry_line;
                    cur_addr = entry_addr;
                    li = li + 1;
                    cnt;
                }
            }

            if (addr_delta > 0) {
                buf_u8(alloc, b, DW_LNS_advance_pc);
                buf_uleb128(alloc, b, addr_delta);
            }

            if (line_delta != 0) {
                buf_u8(alloc, b, DW_LNS_advance_line);
                buf_sleb128(alloc, b, line_delta);
            }

            buf_u8(alloc, b, DW_LNS_copy);

            cur_line = entry_line;
            cur_addr = entry_addr;
            li = li + 1;
        }

        # DW_LNE_end_sequence
        buf_u8(alloc, b, 0);
        buf_uleb128(alloc, b, 1);
        buf_u8(alloc, b, DW_LNE_end_sequence);
    }

    # patch total length
    val total_length: u32 = (b.size - header_start)::u32;
    buf_patch_u32(b, total_length_off, total_length);
}

# dwarf_finalize: emit all debug sections into the object writer
fun dwarf_finalize(ctx: ptr, obj: *of.ObjWriter) bool {
    val d: *DwarfCtx = ctx::*DwarfCtx;
    if (d == nil || obj == nil) { ret false; }
    if (d.func_count == 0 && d.line_count == 0) { ret true; }

    var strtab: EmitBuf = buf_init_emit(d.alloc);
    buf_u8(d.alloc, ?strtab, 0);

    var abbrev_buf: EmitBuf = buf_init_emit(d.alloc);
    emit_abbrev(d.alloc, ?abbrev_buf);

    var info_buf: EmitBuf = buf_init_emit(d.alloc);
    emit_info(d.alloc, ?info_buf, d, ?strtab);

    var line_buf: EmitBuf = buf_init_emit(d.alloc);
    emit_line(d.alloc, ?line_buf, d);

    val sec_abbrev: i32 = obj.add_section(obj.ctx, ".debug_abbrev", of.SK_DEBUG, 0, 1);
    val sec_info:   i32 = obj.add_section(obj.ctx, ".debug_info", of.SK_DEBUG, 0, 1);
    val sec_line:   i32 = obj.add_section(obj.ctx, ".debug_line", of.SK_DEBUG, 0, 1);
    val sec_str:    i32 = obj.add_section(obj.ctx, ".debug_str", of.SK_DEBUG, 0, 1);

    var ok: bool = true;

    if (sec_abbrev >= 0 && abbrev_buf.data != nil) {
        ok = ok && obj.emit_bytes(obj.ctx, sec_abbrev, abbrev_buf.data, abbrev_buf.size);
    }
    if (sec_info >= 0 && info_buf.data != nil) {
        ok = ok && obj.emit_bytes(obj.ctx, sec_info, info_buf.data, info_buf.size);
    }
    if (sec_line >= 0 && line_buf.data != nil) {
        ok = ok && obj.emit_bytes(obj.ctx, sec_line, line_buf.data, line_buf.size);
    }
    if (sec_str >= 0 && strtab.data != nil) {
        ok = ok && obj.emit_bytes(obj.ctx, sec_str, strtab.data, strtab.size);
    }

    if (obj.add_reloc != nil && obj.add_symbol != nil) {
        val text_sym: u32 = obj.add_symbol(obj.ctx, ".text", 0, 0, 0, false);

        var ri: i32 = 0;
        for (ri < d.info_reloc_count) {
            obj.add_reloc(obj.ctx, sec_info, d.info_relocs[ri].buf_offset::usize,
                          of.RK_ABS64, text_sym, d.info_relocs[ri].addend::i64);
            ri = ri + 1;
        }

        ri = 0;
        for (ri < d.line_reloc_count) {
            obj.add_reloc(obj.ctx, sec_line, d.line_relocs[ri].buf_offset::usize,
                          of.RK_ABS64, text_sym, d.line_relocs[ri].addend::i64);
            ri = ri + 1;
        }
    }

    buf_dnit(d.alloc, ?abbrev_buf);
    buf_dnit(d.alloc, ?info_buf);
    buf_dnit(d.alloc, ?line_buf);
    buf_dnit(d.alloc, ?strtab);

    ret ok;
}

# dwarf_dnit: free all DWARF context resources
fun dwarf_dnit(ctx: ptr) {
    val d: *DwarfCtx = ctx::*DwarfCtx;
    if (d == nil) { ret; }

    if (d.files != nil && d.file_cap > 0) {
        allocator.deallocate[FileEntry](d.alloc, d.files, d.file_cap::usize);
    }
    if (d.funcs != nil && d.func_cap > 0) {
        allocator.deallocate[FuncEntry](d.alloc, d.funcs, d.func_cap::usize);
    }
    if (d.lines != nil && d.line_cap > 0) {
        allocator.deallocate[LineEntry](d.alloc, d.lines, d.line_cap::usize);
    }

    allocator.deallocate[DwarfCtx](d.alloc, d, 1);
}

# init: create a DWARF debug info context and return a DebugInfo interface
# ---
# alloc:    allocator for internal state
# comp_dir: compilation directory
# ret:      DebugInfo with function pointers wired to DWARF backend
pub fun init(alloc: *allocator.Allocator, comp_dir: str) of.DebugInfo {
    var di: of.DebugInfo;
    mem.zero[of.DebugInfo](?di, 1);
    di.name = "dwarf";

    val res_ctx: Result[*DwarfCtx, str] = allocator.allocate[DwarfCtx](alloc, 1);
    if (is_err[*DwarfCtx, str](res_ctx)) {
        di.ctx = nil;
        ret di;
    }
    val d: *DwarfCtx = unwrap_ok[*DwarfCtx, str](res_ctx);
    mem.zero[DwarfCtx](d, 1);
    d.alloc    = alloc;
    d.comp_dir = comp_dir;
    d.producer = "mach 0.8.3";

    val res_files: Result[*FileEntry, str] = allocator.allocate[FileEntry](alloc, INIT_FILE_CAP::usize);
    if (is_err[*FileEntry, str](res_files)) {
        allocator.deallocate[DwarfCtx](alloc, d, 1);
        di.ctx = nil;
        ret di;
    }
    d.files      = unwrap_ok[*FileEntry, str](res_files);
    d.file_count = 0;
    d.file_cap   = INIT_FILE_CAP;

    val res_funcs: Result[*FuncEntry, str] = allocator.allocate[FuncEntry](alloc, INIT_FUNC_CAP::usize);
    if (is_err[*FuncEntry, str](res_funcs)) {
        allocator.deallocate[FileEntry](alloc, d.files, INIT_FILE_CAP::usize);
        allocator.deallocate[DwarfCtx](alloc, d, 1);
        di.ctx = nil;
        ret di;
    }
    d.funcs      = unwrap_ok[*FuncEntry, str](res_funcs);
    d.func_count = 0;
    d.func_cap   = INIT_FUNC_CAP;

    val res_lines: Result[*LineEntry, str] = allocator.allocate[LineEntry](alloc, INIT_LINE_CAP::usize);
    if (is_err[*LineEntry, str](res_lines)) {
        allocator.deallocate[FuncEntry](alloc, d.funcs, INIT_FUNC_CAP::usize);
        allocator.deallocate[FileEntry](alloc, d.files, INIT_FILE_CAP::usize);
        allocator.deallocate[DwarfCtx](alloc, d, 1);
        di.ctx = nil;
        ret di;
    }
    d.lines      = unwrap_ok[*LineEntry, str](res_lines);
    d.line_count = 0;
    d.line_cap   = INIT_LINE_CAP;

    d.info_relocs      = nil;
    d.info_reloc_count = 0;
    d.info_reloc_cap   = 0;
    d.line_relocs      = nil;
    d.line_reloc_count = 0;
    d.line_reloc_cap   = 0;

    di.ctx          = d::ptr;
    di.add_file     = dwarf_add_file;
    di.add_function = dwarf_add_function;
    di.add_line     = dwarf_add_line;
    di.finalize     = dwarf_finalize;
    di.dnit         = dwarf_dnit;

    ret di;
}
