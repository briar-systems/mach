# compiler.target.os.windows: Windows OS configuration

use os: compiler.target.os;

# windows: Windows OS configuration
# ---
# ret: OS record for Windows
pub fun windows() os.OS {
    var o: os.OS;
    o.name         = "windows";
    o.entry_symbol = "mainCRTStartup";
    o.base_addr    = 0x140000000;
    o.page_size    = 4096;
    ret o;
}
