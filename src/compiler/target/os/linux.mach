use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use os:        mach.compiler.target.os;
use isa:       mach.compiler.target.isa;

# mach.compiler.target.os.linux: Linux OS configuration.
# ---
# entry point: _start (provided by std.runtime, not CRT)
# base address: 0x400000 (standard for x86_64 static executables)
# page size: 4096
# syscall ABI (x86_64): number in RAX, args in RDI, RSI, RDX, R10, R8, R9

rec LinuxContext {
    alloc:   *allocator.Allocator;
    sc_regs: *isa.Register;
    sc_file: isa.RegisterFile;
    sc_ret:  isa.Register;
}

# create: construct the Linux OS implementation.
# ---
# i: the ISA provides register descriptors for the syscall ABI.
pub fun create(alloc: *allocator.Allocator, i: *isa.ISA) Result[os.OS, str] {
    if (alloc == nil) {
        ret err[os.OS, str]("allocator is nil");
    }
    if (i == nil) {
        ret err[os.OS, str]("ISA is nil");
    }

    val ctx_r: Result[*LinuxContext, allocator.AllocError] =
        allocator.allocator_zalloc[LinuxContext](alloc, 1);
    if (result_is_err[*LinuxContext, allocator.AllocError](ctx_r)) {
        ret err[os.OS, str]("out of memory");
    }
    val ctx: *LinuxContext = result_unwrap_ok[*LinuxContext, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;

    # populate syscall registers from ISA register file
    # linux x86_64 syscall ABI: number in RAX, args in RDI, RSI, RDX, R10, R8, R9
    val gp_all: isa.RegisterFile = i.gp_regs(i.ctx);

    val sc_r: Result[*isa.Register, allocator.AllocError] =
        allocator.allocator_alloc[isa.Register](alloc, 7);
    if (result_is_err[*isa.Register, allocator.AllocError](sc_r)) {
        ret err[os.OS, str]("out of memory");
    }
    ctx.sc_regs = result_unwrap_ok[*isa.Register, allocator.AllocError](sc_r);

    ctx.sc_regs[0] = gp_all.regs[0];    # RAX (syscall number)
    ctx.sc_regs[1] = gp_all.regs[7];    # RDI (arg 1)
    ctx.sc_regs[2] = gp_all.regs[6];    # RSI (arg 2)
    ctx.sc_regs[3] = gp_all.regs[2];    # RDX (arg 3)
    ctx.sc_regs[4] = gp_all.regs[10];   # R10 (arg 4)
    ctx.sc_regs[5] = gp_all.regs[8];    # R8  (arg 5)
    ctx.sc_regs[6] = gp_all.regs[9];    # R9  (arg 6)

    ctx.sc_file.regs = ctx.sc_regs;
    ctx.sc_file.count = 7;
    ctx.sc_ret = gp_all.regs[0];        # RAX (return value)

    var o: os.OS;
    o.ctx  = ctx::ptr;
    o.name = "linux";
    o.entry_point = linux_entry_point;
    o.base_addr = linux_base_addr;
    o.page_size = linux_page_size;
    o.syscall_regs = linux_syscall_regs;
    o.syscall_ret_reg = linux_syscall_ret_reg;

    ret ok[os.OS, str](o);
}

fun linux_entry_point(ctx: ptr) str {
    ret "_start";
}

fun linux_base_addr(ctx: ptr) u64 {
    ret 0x400000;
}

fun linux_page_size(ctx: ptr) usize {
    ret 4096;
}

fun linux_syscall_regs(ctx: ptr) isa.RegisterFile {
    val x: *LinuxContext = ctx::*LinuxContext;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.sc_file;
}

fun linux_syscall_ret_reg(ctx: ptr) isa.Register {
    val x: *LinuxContext = ctx::*LinuxContext;
    if (x == nil) {
        var empty: isa.Register;
        empty.id = 0;
        empty.name = "rax";
        empty.class = isa.REG_GP;
        empty.width = 8;
        ret empty;
    }
    ret x.sc_ret;
}
