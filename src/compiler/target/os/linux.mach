# compiler.target.os.linux: Linux OS configuration

use os: compiler.target.os;

# linux: Linux OS configuration
# ---
# ret: OS record for Linux
pub fun linux() os.OS {
    var o: os.OS;
    o.name         = "linux";
    o.entry_symbol = "_start";
    o.base_addr    = 0x400000;
    o.page_size    = 4096;
    ret o;
}
