# compiler.target.os.darwin: Darwin OS configuration

use os: compiler.target.os;

# darwin: Darwin/macOS OS configuration
# ---
# ret: OS record for Darwin
pub fun darwin() os.OS {
    var o: os.OS;
    o.name         = "darwin";
    o.entry_symbol = "_main";
    o.base_addr    = 0x100000000;
    o.page_size    = 4096;
    ret o;
}
