use std.types.bool;
use std.types.size;
use std.types.string;

# mach.compiler.target.os: operating system interface.
# ---
# provides OS-specific configuration for compilation and linking.
# intentionally minimal: entry point name + memory layout parameters.
# no file extensions, path separators, or other trivia — those belong
# in the standard library, not the compiler.

# OS: operating system interface.
pub rec OS {
    ctx:  ptr;
    name: str;

    # entry point symbol name for this OS.
    entry_point: fun(ptr) str;

    # default base virtual address for executables.
    base_addr: fun(ptr) u64;

    # memory page size for segment alignment.
    page_size: fun(ptr) usize;
}
