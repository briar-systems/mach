use std.types.bool;
use std.types.size;
use std.types.string;

use isa: mach.compiler.target.isa;

# mach.compiler.target.os: operating system interface.
# ---
# provides OS-specific configuration for compilation and linking.
# includes syscall ABI since system call conventions are OS-specific
# (e.g. Linux x86_64 vs FreeBSD x86_64 may differ).

# OS: operating system interface.
pub rec OS {
    ctx:  ptr;
    name: str;

    # entry point symbol name for this OS.
    entry_point: fun(ptr) str;

    # default base virtual address for executables.
    base_addr: fun(ptr) u64;

    # memory page size for segment alignment.
    page_size: fun(ptr) usize;

    # syscall register file: [0]=syscall number, [1..N]=arguments.
    # order matches the OS+ISA syscall convention.
    syscall_regs: fun(ptr) isa.RegisterFile;

    # register that holds the syscall return value.
    syscall_ret_reg: fun(ptr) isa.Register;
}
