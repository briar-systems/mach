# mach.compiler.target.isa.x86_64.printer: x86_64 assembly text printer
#
# formats ISA-level instructions as Intel-syntax assembly text.

use std.types.bool;
use std.types.size;
use std.types.string;

use iobuf: std.io.buffer;

use isa:  mach.compiler.target.isa;
use defs: mach.compiler.target.isa.x86_64.defs;

pub fun x86_print_inst(ctx: ptr, mi: *isa.Inst, buf: *iobuf.WriteBuf) {
    if (mi == nil || buf == nil) { ret; }

    val opcode: u16 = mi.opcode;

    if (opcode == isa.ISA_ASM_MARKER) {
        ws(buf, "  ; <inline asm>\n");
        ret;
    }

    if (opcode == isa.ISA_PCOPY) {
        ws(buf, "  pcopy ");
        write_operand(buf, ?mi.dst, mi.size);
        ws(buf, ", ");
        write_operand(buf, ?mi.src1, mi.size);
        ws(buf, "\n");
        ret;
    }
    if (opcode == isa.ISA_PCOPY_FENCE) {
        ws(buf, "  pcopy.fence\n");
        ret;
    }
    if (opcode == isa.ISA_LABEL) {
        if (mi.dst.label != nil) {
            ws(buf, mi.dst.label);
            ws(buf, ":\n");
        }
        ret;
    }

    if (opcode == defs.MOVSB) {
        if ((mi.flags & defs.FLAG_REP::u16) != 0) {
            ws(buf, "  rep movsb\n");
        } or {
            ws(buf, "  movsb\n");
        }
        ret;
    }

    ws(buf, "  ");
    ws(buf, opcode_name(opcode));

    val dst: *isa.Operand = ?mi.dst;
    val src1: *isa.Operand = ?mi.src1;
    val src2: *isa.Operand = ?mi.src2;
    val sz: u8 = mi.size;

    if (is_jcc(opcode) || opcode == defs.JMP) {
        ws(buf, " ");
        write_operand(buf, dst, sz);
        ws(buf, "\n");
        ret;
    }

    if (opcode == defs.CALL) {
        ws(buf, " ");
        write_operand(buf, dst, 8);
        ws(buf, "\n");
        ret;
    }

    if (opcode == defs.RET || opcode == defs.SYSCALL || opcode == defs.UD2 ||
        opcode == defs.PAUSE || opcode == defs.NOP || opcode == defs.CDQ ||
        opcode == defs.CQO) {
        ws(buf, "\n");
        ret;
    }

    if (opcode == defs.PUSH || opcode == defs.POP) {
        ws(buf, " ");
        write_operand(buf, dst, 8);
        ws(buf, "\n");
        ret;
    }

    if (is_setcc(opcode)) {
        ws(buf, " ");
        write_operand(buf, dst, 1);
        ws(buf, "\n");
        ret;
    }

    if (dst.kind != isa.OPK_NONE) {
        ws(buf, " ");
        write_operand(buf, dst, sz);
    }
    if (src1.kind != isa.OPK_NONE) {
        ws(buf, ", ");
        write_operand(buf, src1, sz);
    }
    if (src2.kind == isa.OPK_REG && src2.reg >= 0) {
        ws(buf, ", ");
        write_operand(buf, src2, sz);
    } or (src2.kind == isa.OPK_IMM) {
        ws(buf, ", ");
        write_operand(buf, src2, sz);
    } or (src2.kind == isa.OPK_MEM) {
        ws(buf, ", ");
        write_operand(buf, src2, sz);
    }
    ws(buf, "\n");
}

fun write_operand(buf: *iobuf.WriteBuf, op: *isa.Operand, sz: u8) {
    if (op.kind == isa.OPK_REG) {
        ws(buf, defs.reg_name(nil, op.reg, sz));
    } or (op.kind == isa.OPK_IMM) {
        write_i64(buf, op.imm);
    } or (op.kind == isa.OPK_MEM) {
        write_mem(buf, op, sz);
    } or (op.kind == isa.OPK_LABEL) {
        if (op.label != nil) {
            ws(buf, op.label);
        } or {
            ws(buf, "?label");
        }
    } or (op.kind == isa.OPK_SYM) {
        ws(buf, "sym:");
        write_i64(buf, op.sym_id::i64);
    }
}

fun write_mem(buf: *iobuf.WriteBuf, op: *isa.Operand, sz: u8) {
    ws(buf, size_prefix(sz));
    ws(buf, "[");
    var need_plus: bool = false;
    if (op.base >= 0) {
        ws(buf, defs.reg_name(nil, op.base, 8));
        need_plus = true;
    }
    if (op.index >= 0) {
        if (need_plus) { ws(buf, " + "); }
        ws(buf, defs.reg_name(nil, op.index, 8));
        if (op.scale > 1) {
            ws(buf, "*");
            write_i64(buf, op.scale::i64);
        }
        need_plus = true;
    }
    if (op.disp != 0 || !need_plus) {
        if (need_plus && op.disp > 0) { ws(buf, " + "); }
        or (need_plus && op.disp < 0) { ws(buf, " - "); }
        if (op.disp < 0 && need_plus) {
            write_i64(buf, (0 - op.disp::i64));
        } or {
            write_i64(buf, op.disp::i64);
        }
    }
    if (op.label != nil) {
        if (need_plus) { ws(buf, " + "); }
        ws(buf, op.label);
    }
    ws(buf, "]");
}

fun size_prefix(sz: u8) str {
    if (sz == 1) { ret "byte "; }
    if (sz == 2) { ret "word "; }
    if (sz == 4) { ret "dword "; }
    if (sz == 8) { ret "qword "; }
    ret "";
}

fun is_jcc(op: u16) bool {
    ret op >= defs.JE && op <= defs.JAE;
}

fun is_setcc(op: u16) bool {
    ret op >= defs.SETE && op <= defs.SETAE;
}

fun opcode_name(op: u16) str {
    if (op == defs.NOP)       { ret "nop"; }
    if (op == defs.MOV)       { ret "mov"; }
    if (op == defs.LEA)       { ret "lea"; }
    if (op == defs.PUSH)      { ret "push"; }
    if (op == defs.POP)       { ret "pop"; }
    if (op == defs.ADD)       { ret "add"; }
    if (op == defs.SUB)       { ret "sub"; }
    if (op == defs.IMUL)      { ret "imul"; }
    if (op == defs.IDIV)      { ret "idiv"; }
    if (op == defs.DIV)       { ret "div"; }
    if (op == defs.AND)       { ret "and"; }
    if (op == defs.OR)        { ret "or"; }
    if (op == defs.XOR)       { ret "xor"; }
    if (op == defs.SHL)       { ret "shl"; }
    if (op == defs.SHR)       { ret "shr"; }
    if (op == defs.SAR)       { ret "sar"; }
    if (op == defs.CMP)       { ret "cmp"; }
    if (op == defs.TEST)      { ret "test"; }
    if (op == defs.JMP)       { ret "jmp"; }
    if (op == defs.CALL)      { ret "call"; }
    if (op == defs.RET)       { ret "ret"; }
    if (op == defs.JE)        { ret "je"; }
    if (op == defs.JNE)       { ret "jne"; }
    if (op == defs.JL)        { ret "jl"; }
    if (op == defs.JLE)       { ret "jle"; }
    if (op == defs.JG)        { ret "jg"; }
    if (op == defs.JGE)       { ret "jge"; }
    if (op == defs.JB)        { ret "jb"; }
    if (op == defs.JBE)       { ret "jbe"; }
    if (op == defs.JA)        { ret "ja"; }
    if (op == defs.JAE)       { ret "jae"; }
    if (op == defs.SETE)      { ret "sete"; }
    if (op == defs.SETNE)     { ret "setne"; }
    if (op == defs.SETL)      { ret "setl"; }
    if (op == defs.SETLE)     { ret "setle"; }
    if (op == defs.SETG)      { ret "setg"; }
    if (op == defs.SETGE)     { ret "setge"; }
    if (op == defs.SETB)      { ret "setb"; }
    if (op == defs.SETBE)     { ret "setbe"; }
    if (op == defs.SETA)      { ret "seta"; }
    if (op == defs.SETAE)     { ret "setae"; }
    if (op == defs.MOVSS)     { ret "movss"; }
    if (op == defs.MOVSD)     { ret "movsd"; }
    if (op == defs.ADDSS)     { ret "addss"; }
    if (op == defs.ADDSD)     { ret "addsd"; }
    if (op == defs.SUBSS)     { ret "subss"; }
    if (op == defs.SUBSD)     { ret "subsd"; }
    if (op == defs.MULSS)     { ret "mulss"; }
    if (op == defs.MULSD)     { ret "mulsd"; }
    if (op == defs.DIVSS)     { ret "divss"; }
    if (op == defs.DIVSD)     { ret "divsd"; }
    if (op == defs.SYSCALL)   { ret "syscall"; }
    if (op == defs.MOVABS)    { ret "movabs"; }
    if (op == defs.UD2)       { ret "ud2"; }
    if (op == defs.PAUSE)     { ret "pause"; }
    if (op == defs.CDQ)       { ret "cdq"; }
    if (op == defs.CQO)       { ret "cqo"; }
    if (op == defs.MOVSX)     { ret "movsx"; }
    if (op == defs.MOVZX)     { ret "movzx"; }
    if (op == defs.MOVSXD)    { ret "movsxd"; }
    if (op == defs.CVTSI2SS)  { ret "cvtsi2ss"; }
    if (op == defs.CVTSI2SD)  { ret "cvtsi2sd"; }
    if (op == defs.CVTSS2SD)  { ret "cvtss2sd"; }
    if (op == defs.CVTSD2SS)  { ret "cvtsd2ss"; }
    if (op == defs.CVTTSS2SI) { ret "cvttss2si"; }
    if (op == defs.CVTTSD2SI) { ret "cvttsd2si"; }
    if (op == defs.UCOMISS)   { ret "ucomiss"; }
    if (op == defs.UCOMISD)   { ret "ucomisd"; }
    if (op == defs.MOVSB)     { ret "movsb"; }
    if (op == defs.MFENCE)    { ret "mfence"; }
    if (op == defs.CBW)       { ret "cbw"; }
    if (op == defs.CWD)       { ret "cwd"; }
    ret "???";
}

fun ws(buf: *iobuf.WriteBuf, s: str) {
    if (s == nil) { ret; }
    iobuf.wbuf_write_bytes(buf, s::*u8, str_len(s));
}

fun write_i64(buf: *iobuf.WriteBuf, n: i64) {
    if (n < 0) {
        ws(buf, "-");
        write_u64(buf, (0 - n)::u64);
    } or {
        write_u64(buf, n::u64);
    }
}

fun write_u64(buf: *iobuf.WriteBuf, n: u64) {
    var tmp: [20]u8;
    var idx: i32 = 20;
    var x: u64 = n;
    if (x == 0) {
        idx = idx - 1;
        tmp[idx] = '0';
    } or {
        for (x > 0) {
            idx = idx - 1;
            tmp[idx] = (x % 10)::u8 + '0';
            x = x / 10;
        }
    }
    iobuf.wbuf_write_bytes(buf, ?tmp[idx], (20 - idx)::usize);
}
