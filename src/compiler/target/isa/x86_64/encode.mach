# compiler.target.isa.x86_64.encode: machine code encoding for x86_64
#
# encodes x86_64 machine instructions into binary. writes encoded bytes into
# an object format section. currently a stub.

use std.types.bool;
use std.types.size;
use std.types.string;

use allocator: std.allocator;

use isa: compiler.target.isa;
use of:  compiler.target.of;

# encode_inst: encode a single machine instruction into a section
#
# writes the binary encoding of the instruction into the section's data buffer
# and returns the number of bytes emitted.
# ---
# mi:    pointer to the machine instruction to encode
# sec:   pointer to the output section
# alloc: allocator for any temporary storage
# ret:   number of bytes emitted (0 on failure)
pub fun encode_inst(mi: *isa.Inst, sec: *of.Section, alloc: &allocator.Allocator) i32 {
    ret 0;
}
