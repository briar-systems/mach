# compiler.target.isa.x86_64.isel: instruction selection for x86_64
#
# translates MASM IR instructions into x86_64 machine instructions. currently
# a stub that rejects all input.

use std.types.bool;
use std.types.size;
use std.types.string;

use isa: compiler.target.isa;

# select: select x86_64 machine instructions for a MASM IR instruction
#
# reads the IR instruction and appends zero or more machine instructions to
# the output buffer. returns true if selection succeeded.
# ---
# ir:   pointer to the IR instruction to lower
# func: pointer to the containing IR function (for pool access)
# out:  instruction buffer to append results into
# ret:  true if instruction was successfully selected
pub fun select(ir: ptr, func: ptr, out: *isa.InstBuf) bool {
    ret false;
}
