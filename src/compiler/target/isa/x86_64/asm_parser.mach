# mach.compiler.target.isa.x86_64.asm_parser: inline assembly parser
#
# parses Intel-syntax x86_64 assembly text into ISA instructions.
# handles the subset used by the mach runtime and stdlib:
#   mov, lea, call, inc, and, sub, xor, syscall, push, pop

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use isa:  mach.compiler.target.isa;
use defs: mach.compiler.target.isa.x86_64.defs;

var _alloc: *allocator.Allocator = nil;
var _locals: *isa.AsmLocal = nil;
var _local_count: i32 = 0;

fun find_asm_local(name: str) i32 {
    if (_locals == nil || name == nil) { ret 0x7FFFFFFF; }
    var i: i32 = 0;
    for (i < _local_count) {
        if (_locals[i].name != nil && str_equals(_locals[i].name, name)) {
            ret _locals[i].offset;
        }
        i = i + 1;
    }
    ret 0x7FFFFFFF;
}

pub fun parse_inline_asm(ctx: ptr, text: str, locals: *isa.AsmLocal, local_count: i32,
                         out: *isa.InstBuf, alloc: *allocator.Allocator) bool {
    _alloc = alloc;
    _locals = locals;
    _local_count = local_count;
    if (text == nil || out == nil) { ret false; }

    var pos: usize = 0;
    val len: usize = str_len(text);

    for (pos < len) {
        skip_whitespace(text, len, ?pos);
        if (pos >= len) { brk; }
        if (text[pos] == '#') {
            skip_line(text, len, ?pos);
            cnt;
        }
        if (text[pos] == '\n' || text[pos] == '\r') {
            pos = pos + 1;
            cnt;
        }

        var mnemonic: [32]u8;
        var mnem_len: usize = 0;
        for (pos < len && text[pos] != ' ' && text[pos] != '\t' &&
             text[pos] != '\n' && text[pos] != '\r' && text[pos] != '#' &&
             mnem_len < 31) {
            mnemonic[mnem_len] = text[pos];
            mnem_len = mnem_len + 1;
            pos = pos + 1;
        }
        mnemonic[mnem_len] = 0;

        if (mnem_len == 0) { cnt; }

        val mn: str = ?mnemonic[0];

        if (str_equals(mn, "syscall")) {
            isa.buf_append(out, make_simple(defs.SYSCALL));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "call")) {
            skip_whitespace(text, len, ?pos);
            var label: [128]u8;
            var ll: usize = 0;
            for (pos < len && text[pos] != '\n' && text[pos] != '\r' &&
                 text[pos] != '#' && text[pos] != ' ' && text[pos] != '\t' && ll < 127) {
                label[ll] = text[pos];
                ll = ll + 1;
                pos = pos + 1;
            }
            label[ll] = 0;
            val call_label: str = intern_label(?label[0], ll);
            isa.buf_append(out, make_call_label(call_label));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "inc")) {
            skip_whitespace(text, len, ?pos);
            val reg: i32 = parse_register(text, len, ?pos);
            isa.buf_append(out, make_alu_reg(defs.ADD, reg, isa.make_imm(1, 8)));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "push")) {
            skip_whitespace(text, len, ?pos);
            val reg: i32 = parse_register(text, len, ?pos);
            isa.buf_append(out, make_push(reg));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "pop")) {
            skip_whitespace(text, len, ?pos);
            val reg: i32 = parse_register(text, len, ?pos);
            isa.buf_append(out, make_pop(reg));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "xor")) {
            skip_whitespace(text, len, ?pos);
            val dst: i32 = parse_register(text, len, ?pos);
            skip_comma(text, len, ?pos);
            val src: i32 = parse_register(text, len, ?pos);
            isa.buf_append(out, make_alu_rr(defs.XOR, dst, src));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "and")) {
            skip_whitespace(text, len, ?pos);
            val dst: i32 = parse_register(text, len, ?pos);
            skip_comma(text, len, ?pos);
            val imm: i64 = parse_immediate(text, len, ?pos);
            isa.buf_append(out, make_alu_ri(defs.AND, dst, imm));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "sub")) {
            skip_whitespace(text, len, ?pos);
            val dst: i32 = parse_register(text, len, ?pos);
            skip_comma(text, len, ?pos);
            val imm: i64 = parse_immediate(text, len, ?pos);
            isa.buf_append(out, make_alu_ri(defs.SUB, dst, imm));
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "mov")) {
            parse_mov(text, len, ?pos, out);
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        if (str_equals(mn, "lea")) {
            parse_lea(text, len, ?pos, out);
            skip_to_eol(text, len, ?pos);
            cnt;
        }

        skip_to_eol(text, len, ?pos);
    }

    ret true;
}

fun parse_mov(text: str, len: usize, pos: *usize, out: *isa.InstBuf) {
    skip_whitespace(text, len, pos);

    if (@pos < len && text[@pos] == '[') {
        var mem: isa.Operand = parse_mem_operand(text, len, pos);
        skip_comma(text, len, pos);
        val src: i32 = parse_register(text, len, pos);
        var inst: isa.Inst;
        mem_zero_inst(?inst);
        inst.opcode = defs.MOV;
        inst.dst    = mem;
        inst.src1   = isa.make_reg(src, 8);
        inst.size   = 8;
        inst.flags  = defs.FLAG_REX_W;
        isa.buf_append(out, inst);
        ret;
    }

    val dst: i32 = parse_register(text, len, pos);
    skip_comma(text, len, pos);
    skip_whitespace(text, len, pos);

    if (@pos < len && text[@pos] == '[') {
        var mem: isa.Operand = parse_mem_operand(text, len, pos);
        var inst: isa.Inst;
        mem_zero_inst(?inst);
        inst.opcode = defs.MOV;
        inst.dst    = isa.make_reg(dst, 8);
        inst.src1   = mem;
        inst.size   = 8;
        inst.flags  = defs.FLAG_REX_W;
        isa.buf_append(out, inst);
        ret;
    }

    if (@pos < len && is_alpha(text[@pos])) {
        val save_pos: usize = @pos;
        val src: i32 = parse_register(text, len, pos);
        if (src >= 0) {
            isa.buf_append(out, make_alu_rr(defs.MOV, dst, src));
            ret;
        }
        @pos = save_pos;
    }

    val imm: i64 = parse_immediate(text, len, pos);
    isa.buf_append(out, make_mov_ri(dst, imm));
}

fun parse_lea(text: str, len: usize, pos: *usize, out: *isa.InstBuf) {
    skip_whitespace(text, len, pos);
    val dst: i32 = parse_register(text, len, pos);
    skip_comma(text, len, pos);
    skip_whitespace(text, len, pos);

    var mem: isa.Operand = parse_mem_operand(text, len, pos);

    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = defs.LEA;
    inst.dst    = isa.make_reg(dst, 8);
    inst.src1   = mem;
    inst.size   = 8;
    inst.flags  = defs.FLAG_REX_W;
    isa.buf_append(out, inst);
}

fun parse_mem_operand(text: str, len: usize, pos: *usize) isa.Operand {
    if (@pos < len && text[@pos] == '[') {
        @pos = @pos + 1;
    }
    skip_whitespace(text, len, pos);

    var base: i32 = -1;
    var index: i32 = -1;
    var scale: u8 = 1;
    var disp: i32 = 0;
    var is_symbol: bool = false;
    var sym_name: [128]u8;
    var sym_len: usize = 0;

    if (@pos < len && is_alpha(text[@pos]) || text[@pos] == '_') {
        var name: [32]u8;
        var nl: usize = 0;
        for (@pos < len && (is_alnum(text[@pos]) || text[@pos] == '_') && nl < 31) {
            name[nl] = text[@pos];
            nl = nl + 1;
            @pos = @pos + 1;
        }
        name[nl] = 0;

        val reg: i32 = lookup_register(?name[0]);
        if (reg >= 0) {
            base = reg;
            skip_whitespace(text, len, pos);

            if (@pos < len && text[@pos] == '+') {
                @pos = @pos + 1;
                skip_whitespace(text, len, pos);

                if (@pos < len && is_alpha(text[@pos])) {
                    var name2: [32]u8;
                    var nl2: usize = 0;
                    for (@pos < len && (is_alnum(text[@pos]) || text[@pos] == '_') && nl2 < 31) {
                        name2[nl2] = text[@pos];
                        nl2 = nl2 + 1;
                        @pos = @pos + 1;
                    }
                    name2[nl2] = 0;
                    index = lookup_register(?name2[0]);

                    skip_whitespace(text, len, pos);
                    if (@pos < len && text[@pos] == '*') {
                        @pos = @pos + 1;
                        skip_whitespace(text, len, pos);
                        scale = parse_u8_literal(text, len, pos);
                    }
                } or {
                    disp = parse_i32_literal(text, len, pos);
                }
            }
        } or {
            val local_off: i32 = find_asm_local(?name[0]);
            if (local_off != 0x7FFFFFFF) {
                base = defs.RBP;
                disp = local_off;
            } or {
                is_symbol = true;
                var si: usize = 0;
                for (si < nl && si < 127) {
                    sym_name[si] = name[si];
                    si = si + 1;
                }
                sym_len = nl;
                sym_name[sym_len] = 0;
            }
        }
    } or (@pos < len && (text[@pos] == '-' || is_digit(text[@pos]))) {
        disp = parse_i32_literal(text, len, pos);
    }

    skip_whitespace(text, len, pos);
    if (@pos < len && text[@pos] == ']') {
        @pos = @pos + 1;
    }

    if (is_symbol) {
        var op: isa.Operand;
        op.kind  = isa.OPK_MEM;
        op.size  = 8;
        op.base  = -1;
        op.index = -1;
        op.scale = 1;
        op.disp  = 0;
        op.label = intern_label(?sym_name[0], sym_len);
        ret op;
    }

    ret isa.make_mem(base, disp, index, scale, 8);
}

fun make_simple(opcode: u16) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = opcode;
    ret inst;
}

fun make_call_label(label: str) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = defs.CALL;
    inst.dst    = isa.make_label(label);
    inst.size   = 8;
    ret inst;
}

fun make_push(reg: i32) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = defs.PUSH;
    inst.dst    = isa.make_reg(reg, 8);
    inst.flags  = defs.FLAG_REX_W;
    ret inst;
}

fun make_pop(reg: i32) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = defs.POP;
    inst.dst    = isa.make_reg(reg, 8);
    inst.flags  = defs.FLAG_REX_W;
    ret inst;
}

fun make_mov_ri(dst: i32, imm: i64) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = defs.MOV;
    inst.dst    = isa.make_reg(dst, 8);
    inst.src1   = isa.make_imm(imm, 8);
    inst.size   = 8;
    inst.flags  = defs.FLAG_REX_W;
    ret inst;
}

fun make_alu_rr(opcode: u16, dst: i32, src: i32) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = opcode;
    inst.dst    = isa.make_reg(dst, 8);
    inst.src1   = isa.make_reg(src, 8);
    inst.size   = 8;
    inst.flags  = defs.FLAG_REX_W;
    ret inst;
}

fun make_alu_ri(opcode: u16, dst: i32, imm: i64) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = opcode;
    inst.dst    = isa.make_reg(dst, 8);
    inst.src1   = isa.make_imm(imm, 8);
    inst.size   = 8;
    inst.flags  = defs.FLAG_REX_W;
    ret inst;
}

fun make_alu_reg(opcode: u16, dst: i32, src: isa.Operand) isa.Inst {
    var inst: isa.Inst;
    mem_zero_inst(?inst);
    inst.opcode = opcode;
    inst.dst    = isa.make_reg(dst, 8);
    inst.src1   = src;
    inst.size   = 8;
    inst.flags  = defs.FLAG_REX_W;
    ret inst;
}

fun mem_zero_inst(inst: *isa.Inst) {
    inst.opcode   = 0;
    inst.size     = 0;
    inst.flags    = 0;
    inst.src_line = 0;
    inst.src_file = nil;
    inst.dst.kind   = 0;
    inst.dst.size   = 0;
    inst.dst.reg    = 0;
    inst.dst.imm    = 0;
    inst.dst.base   = 0;
    inst.dst.index  = 0;
    inst.dst.scale  = 0;
    inst.dst.disp   = 0;
    inst.dst.sym_id = 0;
    inst.dst.label  = nil;
    inst.src1.kind   = 0;
    inst.src1.size   = 0;
    inst.src1.reg    = 0;
    inst.src1.imm    = 0;
    inst.src1.base   = 0;
    inst.src1.index  = 0;
    inst.src1.scale  = 0;
    inst.src1.disp   = 0;
    inst.src1.sym_id = 0;
    inst.src1.label  = nil;
    inst.src2.kind   = 0;
    inst.src2.size   = 0;
    inst.src2.reg    = 0;
    inst.src2.imm    = 0;
    inst.src2.base   = 0;
    inst.src2.index  = 0;
    inst.src2.scale  = 0;
    inst.src2.disp   = 0;
    inst.src2.sym_id = 0;
    inst.src2.label  = nil;
}

fun intern_label(buf: *u8, len: usize) str {
    if (_alloc == nil || len == 0) { ret nil; }
    val res: Result[*u8, str] = allocator.allocate[u8](_alloc, len + 1);
    if (is_err[*u8, str](res)) { ret nil; }
    val copy: *u8 = unwrap_ok[*u8, str](res);
    var i: usize = 0;
    for (i < len) {
        copy[i] = buf[i];
        i = i + 1;
    }
    copy[len] = 0;
    ret copy::str;
}

fun lookup_register(name: str) i32 {
    if (str_equals(name, "rax")) { ret defs.RAX; }
    if (str_equals(name, "rcx")) { ret defs.RCX; }
    if (str_equals(name, "rdx")) { ret defs.RDX; }
    if (str_equals(name, "rbx")) { ret defs.RBX; }
    if (str_equals(name, "rsp")) { ret defs.RSP; }
    if (str_equals(name, "rbp")) { ret defs.RBP; }
    if (str_equals(name, "rsi")) { ret defs.RSI; }
    if (str_equals(name, "rdi")) { ret defs.RDI; }
    if (str_equals(name, "r8"))  { ret defs.R8; }
    if (str_equals(name, "r9"))  { ret defs.R9; }
    if (str_equals(name, "r10")) { ret defs.R10; }
    if (str_equals(name, "r11")) { ret defs.R11; }
    if (str_equals(name, "r12")) { ret defs.R12; }
    if (str_equals(name, "r13")) { ret defs.R13; }
    if (str_equals(name, "r14")) { ret defs.R14; }
    if (str_equals(name, "r15")) { ret defs.R15; }
    if (str_equals(name, "eax")) { ret defs.RAX; }
    if (str_equals(name, "ecx")) { ret defs.RCX; }
    if (str_equals(name, "edx")) { ret defs.RDX; }
    if (str_equals(name, "ebx")) { ret defs.RBX; }
    if (str_equals(name, "edi")) { ret defs.RDI; }
    if (str_equals(name, "esi")) { ret defs.RSI; }
    ret -1;
}

fun parse_register(text: str, len: usize, pos: *usize) i32 {
    skip_whitespace(text, len, pos);
    var name: [16]u8;
    var nl: usize = 0;
    for (@pos < len && (is_alnum(text[@pos]) || text[@pos] == '_') && nl < 15) {
        name[nl] = text[@pos];
        nl = nl + 1;
        @pos = @pos + 1;
    }
    name[nl] = 0;
    ret lookup_register(?name[0]);
}

fun parse_immediate(text: str, len: usize, pos: *usize) i64 {
    skip_whitespace(text, len, pos);
    var neg: bool = false;
    if (@pos < len && text[@pos] == '-') {
        neg = true;
        @pos = @pos + 1;
    }
    var val_out: i64 = 0;
    if (@pos + 1 < len && text[@pos] == '0' && text[@pos + 1] == 'x') {
        @pos = @pos + 2;
        for (@pos < len && is_hex(text[@pos])) {
            val_out = val_out * 16 + hex_digit(text[@pos]);
            @pos = @pos + 1;
        }
    } or {
        for (@pos < len && is_digit(text[@pos])) {
            val_out = val_out * 10 + (text[@pos] - '0')::i64;
            @pos = @pos + 1;
        }
    }
    if (neg) { val_out = 0 - val_out; }
    ret val_out;
}

fun parse_i32_literal(text: str, len: usize, pos: *usize) i32 {
    ret parse_immediate(text, len, pos)::i32;
}

fun parse_u8_literal(text: str, len: usize, pos: *usize) u8 {
    ret parse_immediate(text, len, pos)::u8;
}

fun skip_whitespace(text: str, len: usize, pos: *usize) {
    for (@pos < len && (text[@pos] == ' ' || text[@pos] == '\t')) {
        @pos = @pos + 1;
    }
}

fun skip_to_eol(text: str, len: usize, pos: *usize) {
    for (@pos < len && text[@pos] != '\n') {
        @pos = @pos + 1;
    }
}

fun skip_line(text: str, len: usize, pos: *usize) {
    for (@pos < len && text[@pos] != '\n') {
        @pos = @pos + 1;
    }
    if (@pos < len) { @pos = @pos + 1; }
}

fun skip_comma(text: str, len: usize, pos: *usize) {
    skip_whitespace(text, len, pos);
    if (@pos < len && text[@pos] == ',') {
        @pos = @pos + 1;
    }
    skip_whitespace(text, len, pos);
}

fun is_alpha(c: u8) bool { ret (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_'; }
fun is_digit(c: u8) bool { ret c >= '0' && c <= '9'; }
fun is_alnum(c: u8) bool { ret is_alpha(c) || is_digit(c); }
fun is_hex(c: u8) bool { ret is_digit(c) || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F'); }
fun hex_digit(c: u8) i64 {
    if (c >= '0' && c <= '9') { ret (c - '0')::i64; }
    if (c >= 'a' && c <= 'f') { ret (c - 'a')::i64 + 10; }
    if (c >= 'A' && c <= 'F') { ret (c - 'A')::i64 + 10; }
    ret 0;
}
