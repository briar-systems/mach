use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use dbg:       std.print;
use inst:      masm.inst;
use xi:        mach.compiler.target.isa.x86_64.inst;
use inst_buf:  mach.compiler.codegen.inst_buf;
use isa:       mach.compiler.target.isa;
use abi:       mach.compiler.target.abi;
use opcode:    mach.compiler.target.isa.x86_64.opcode;

# mach.compiler.target.isa.x86_64.regalloc: x86_64 linear scan register allocator.
# ---
# sits between ISel and encoding. rewrites virtual register operands
# to physical registers, inserting spills/reloads as needed.
# operates on x86_64-local MachInst/Operand types directly.

val MAX_POOL_REGS:   i32 = 16;
val ALIGN:           i64 = 8;
val SCRATCH_RESERVE: i32 = 2;

rec PhysWrite {
    pos: i32;
    reg: i32;
}

rec LiveRange {
    vreg:      i32;
    start:     i32;
    end_pos:   i32;
    size:      u8;
    preg:      i32;
    spill_off: i64;
    spilled:   bool;
}

pub rec RegAllocResult {
    out:         inst_buf.InstructionBuffer[xi.MachInst];
    spill_size:  usize;
    callee_mask: u32;
    ok:          bool;
}

pub fun alloc_function(alloc: *allocator.Allocator, i: *isa.ISA, a: *abi.ABI,
                       insts: *inst_buf.InstructionBuffer[xi.MachInst], local_size: usize) RegAllocResult {
    var result: RegAllocResult;
    result.out = xi.buf_create(alloc);
    result.spill_size = 0;
    result.callee_mask = 0;
    result.ok = false;

    if (alloc == nil || i == nil || a == nil || insts == nil) { ret result; }
    if (insts.count == 0) {
        result.ok = true;
        ret result;
    }

    var gp: isa.RegisterFile = i.gp_regs(i.ctx);
    var reserved: isa.RegisterFile = i.reserved_regs(i.ctx);
    var callee: isa.RegisterFile = a.callee_saved(a.ctx);

    val pool_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, MAX_POOL_REGS::usize);
    if (result_is_err[*i32, allocator.AllocError](pool_r)) {
        dbg.eprintln("[regalloc] alloc_function: pool allocation failed");
        ret result;
    }
    val pool: *i32 = result_unwrap_ok[*i32, allocator.AllocError](pool_r);
    var pool_count: i32 = 0;

    var gi: i32 = 0;
    for (gi < gp.count) {
        val rid: i32 = gp.regs[gi].id;
        if (!is_in_file(rid, ?reserved) && !is_in_file(rid, ?callee)) {
            if (pool_count < MAX_POOL_REGS) {
                pool[pool_count] = rid;
                pool_count = pool_count + 1;
            }
        }
        gi = gi + 1;
    }
    val caller_count: i32 = pool_count;

    gi = 0;
    for (gi < gp.count) {
        val rid: i32 = gp.regs[gi].id;
        if (!is_in_file(rid, ?reserved) && is_in_file(rid, ?callee)) {
            if (pool_count < MAX_POOL_REGS) {
                pool[pool_count] = rid;
                pool_count = pool_count + 1;
            }
        }
        gi = gi + 1;
    }

    val n: i32 = insts.count;

    val calls_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, n::usize);
    if (result_is_err[*i32, allocator.AllocError](calls_r)) {
        dbg.eprintln("[regalloc] alloc_function: calls array allocation failed");
        ret result;
    }
    val calls: *i32 = result_unwrap_ok[*i32, allocator.AllocError](calls_r);
    var call_count: i32 = 0;

    var ci: i32 = 0;
    for (ci < n) {
        val cinst: *xi.MachInst = xi.buf_get(insts, ci);
        if (cinst != nil && cinst.opcode == opcode.CALL) {
            calls[call_count] = ci;
            call_count = call_count + 1;
        }
        ci = ci + 1;
    }

    val pw_r: Result[*PhysWrite, allocator.AllocError] =
        allocator.allocator_zalloc[PhysWrite](alloc, n::usize);
    if (result_is_err[*PhysWrite, allocator.AllocError](pw_r)) {
        dbg.eprintln("[regalloc] alloc_function: phys_writes allocation failed");
        ret result;
    }
    val phys_writes: *PhysWrite = result_unwrap_ok[*PhysWrite, allocator.AllocError](pw_r);
    var pw_count: i32 = 0;

    val pr_r: Result[*PhysWrite, allocator.AllocError] =
        allocator.allocator_zalloc[PhysWrite](alloc, n::usize);
    if (result_is_err[*PhysWrite, allocator.AllocError](pr_r)) {
        dbg.eprintln("[regalloc] alloc_function: phys_reads allocation failed");
        ret result;
    }
    val phys_reads: *PhysWrite = result_unwrap_ok[*PhysWrite, allocator.AllocError](pr_r);
    var pr_count: i32 = 0;

    val ranges_r: Result[*LiveRange, allocator.AllocError] =
        allocator.allocator_zalloc[LiveRange](alloc, n::usize);
    if (result_is_err[*LiveRange, allocator.AllocError](ranges_r)) {
        dbg.eprintln("[regalloc] alloc_function: live ranges allocation failed");
        ret result;
    }
    val ranges: *LiveRange = result_unwrap_ok[*LiveRange, allocator.AllocError](ranges_r);
    var range_count: i32 = 0;

    var idx: i32 = 0;
    for (idx < insts.count) {
        val mi: *xi.MachInst = xi.buf_get(insts, idx);
        if (mi == nil) { idx = idx + 1; cnt; }

        if (mi.opcode == xi.LABEL) { idx = idx + 1; cnt; }

        scan_operand(?mi.dst,  idx, ranges, ?range_count);
        scan_operand(?mi.src1, idx, ranges, ?range_count);
        scan_operand(?mi.src2, idx, ranges, ?range_count);

        if (mi.dst.kind == xi.OPK_REG && !inst.is_vreg(mi.dst.reg) &&
            mi.dst.reg >= 0 && pw_count < n) {
            phys_writes[pw_count].pos = idx;
            phys_writes[pw_count].reg = mi.dst.reg;
            pw_count = pw_count + 1;
        }

        if (mi.src1.kind == xi.OPK_REG && !inst.is_vreg(mi.src1.reg) &&
            mi.src1.reg >= 0 && pr_count < n) {
            phys_reads[pr_count].pos = idx;
            phys_reads[pr_count].reg = mi.src1.reg;
            pr_count = pr_count + 1;
        }
        if (mi.src2.kind == xi.OPK_REG && !inst.is_vreg(mi.src2.reg) &&
            mi.src2.reg >= 0 && pr_count < n) {
            phys_reads[pr_count].pos = idx;
            phys_reads[pr_count].reg = mi.src2.reg;
            pr_count = pr_count + 1;
        }

        idx = idx + 1;
    }

    sort_ranges(ranges, range_count);

    val PARAM_REG_MAX: i32 = 16;
    val plr_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, PARAM_REG_MAX::usize);
    if (result_is_err[*i32, allocator.AllocError](plr_r)) {
        dbg.eprintln("[regalloc] alloc_function: param_last_read allocation failed");
        ret result;
    }
    val param_last_read: *i32 = result_unwrap_ok[*i32, allocator.AllocError](plr_r);
    build_param_live(param_last_read, PARAM_REG_MAX,
                     phys_reads, pr_count,
                     phys_writes, pw_count,
                     calls, call_count);

    val free_r: Result[*bool, allocator.AllocError] =
        allocator.allocator_alloc[bool](alloc, pool_count::usize);
    if (result_is_err[*bool, allocator.AllocError](free_r)) {
        dbg.eprintln("[regalloc] alloc_function: reg_free allocation failed");
        ret result;
    }
    val reg_free: *bool = result_unwrap_ok[*bool, allocator.AllocError](free_r);
    var fi: i32 = 0;
    for (fi < pool_count) { reg_free[fi] = true; fi = fi + 1; }

    val active_r: Result[*i32, allocator.AllocError] =
        allocator.allocator_zalloc[i32](alloc, n::usize);
    if (result_is_err[*i32, allocator.AllocError](active_r)) {
        dbg.eprintln("[regalloc] alloc_function: active list allocation failed");
        ret result;
    }
    val active: *i32 = result_unwrap_ok[*i32, allocator.AllocError](active_r);
    var active_count: i32 = 0;

    var spill_offset: i64 = -(local_size::i64);
    var callee_mask: u64 = 0;

    var ri: i32 = 0;
    for (ri < range_count) {
        val cur: *LiveRange = ?ranges[ri];

        var ai: i32 = 0;
        for (ai < active_count) {
            val act: *LiveRange = ?ranges[active[ai]];
            if (act.end_pos < cur.start) {
                free_pool_reg(reg_free, pool, pool_count, act.preg);
                active_count = active_count - 1;
                if (ai < active_count) {
                    active[ai] = active[active_count];
                }
                cnt;
            }
            ai = ai + 1;
        }

        val cross_call: bool = spans_call(cur.start, cur.end_pos,
                                          calls, call_count);

        if (cross_call) {
            val callee_idx: i32 = find_free_reg_range_excl(reg_free,
                caller_count, pool_count, pool,
                cur.start, cur.end_pos, phys_writes, pw_count,
                param_last_read, PARAM_REG_MAX,
                calls, call_count);
            if (callee_idx >= 0 && active_count < pool_count - SCRATCH_RESERVE) {
                cur.preg = pool[callee_idx];
                reg_free[callee_idx] = false;
                callee_mask = callee_mask | (1::u64 << pool[callee_idx]::u64);
                active[active_count] = ri;
                active_count = active_count + 1;
            } or {
                var victim_ai: i32 = -1;
                var victim_end: i32 = -1;
                var vi: i32 = 0;
                for (vi < active_count) {
                    val act: *LiveRange = ?ranges[active[vi]];
                    if (is_in_pool_range(act.preg, pool,
                                         caller_count, pool_count) &&
                        act.end_pos > victim_end &&
                        !is_phys_excluded(act.preg, cur.start, cur.end_pos,
                                          phys_writes, pw_count,
                                          calls, call_count) &&
                        !has_param_conflict(act.preg, cur.start,
                                            param_last_read, PARAM_REG_MAX)) {
                        victim_end = act.end_pos;
                        victim_ai = vi;
                    }
                    vi = vi + 1;
                }

                if (victim_ai >= 0 && victim_end > cur.end_pos) {
                    val victim: *LiveRange = ?ranges[active[victim_ai]];
                    cur.preg = victim.preg;
                    callee_mask = callee_mask | (1::u64 << cur.preg::u64);
                    victim.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    victim.spill_off = spill_offset;
                    active[victim_ai] = ri;
                } or {
                    cur.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    cur.spill_off = spill_offset;
                    cur.preg = -1;
                }
            }
        } or {
            val free_idx: i32 = find_free_reg_excl(reg_free, pool, pool_count,
                cur.start, cur.end_pos, phys_writes, pw_count,
                param_last_read, PARAM_REG_MAX,
                calls, call_count);
            if (free_idx >= 0 && active_count < pool_count - SCRATCH_RESERVE) {
                cur.preg = pool[free_idx];
                reg_free[free_idx] = false;
                if (free_idx >= caller_count) {
                    callee_mask = callee_mask | (1::u64 << pool[free_idx]::u64);
                }
                active[active_count] = ri;
                active_count = active_count + 1;
            } or {
                var victim_ai: i32 = -1;
                var victim_end: i32 = -1;
                var vi: i32 = 0;
                for (vi < active_count) {
                    val act: *LiveRange = ?ranges[active[vi]];
                    if (act.end_pos > victim_end &&
                        !is_phys_excluded(act.preg, cur.start, cur.end_pos,
                                          phys_writes, pw_count,
                                          calls, call_count) &&
                        !has_param_conflict(act.preg, cur.start,
                                            param_last_read, PARAM_REG_MAX)) {
                        victim_end = act.end_pos;
                        victim_ai = vi;
                    }
                    vi = vi + 1;
                }

                if (victim_ai >= 0 && victim_end > cur.end_pos) {
                    val victim: *LiveRange = ?ranges[active[victim_ai]];
                    cur.preg = victim.preg;
                    if (is_in_pool_range(cur.preg, pool,
                                         caller_count, pool_count)) {
                        callee_mask = callee_mask | (1::u64 << cur.preg::u64);
                    }
                    victim.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    victim.spill_off = spill_offset;
                    active[victim_ai] = ri;
                } or {
                    cur.spilled = true;
                    spill_offset = spill_offset - ALIGN;
                    cur.spill_off = spill_offset;
                    cur.preg = -1;
                }
            }
        }

        ri = ri + 1;
    }

    result.callee_mask = callee_mask::u32;
    result.spill_size = (-(spill_offset + local_size::i64))::usize;

    val fp_reg: i32 = opcode.RBP;

    idx = 0;
    for (idx < insts.count) {
        val mi: *xi.MachInst = xi.buf_get(insts, idx);
        if (mi == nil) { idx = idx + 1; cnt; }

        if (mi.opcode == xi.LABEL) {
            xi.buf_append(?result.out, @mi);
            idx = idx + 1;
            cnt;
        }

        var dst_range:  *LiveRange = find_range_for_operand(?mi.dst,  ranges, range_count);
        var src1_range: *LiveRange = find_range_for_operand(?mi.src1, ranges, range_count);
        var src2_range: *LiveRange = find_range_for_operand(?mi.src2, ranges, range_count);

        var dst_base_range:  *LiveRange = find_mem_base_range(?mi.dst,  ranges, range_count);
        var dst_idx_range:   *LiveRange = find_mem_idx_range(?mi.dst,   ranges, range_count);
        var src1_base_range: *LiveRange = find_mem_base_range(?mi.src1, ranges, range_count);
        var src1_idx_range:  *LiveRange = find_mem_idx_range(?mi.src1,  ranges, range_count);
        var src2_base_range: *LiveRange = find_mem_base_range(?mi.src2, ranges, range_count);
        var src2_idx_range:  *LiveRange = find_mem_idx_range(?mi.src2,  ranges, range_count);

        if (!assign_spill_temps(ranges, range_count, idx, pool, pool_count,
                                dst_range, src1_range, src2_range,
                                dst_base_range, dst_idx_range,
                                src1_base_range, src1_idx_range,
                                src2_base_range, src2_idx_range)) {
            dbg.eprintln("[regalloc] scratch register exhaustion, aborting codegen");
            ret result;
        }

        emit_reload_if_spilled(?result.out, src1_range, fp_reg);
        emit_reload_if_spilled(?result.out, src2_range, fp_reg);
        emit_reload_if_spilled(?result.out, src1_base_range, fp_reg);
        emit_reload_if_spilled(?result.out, src1_idx_range, fp_reg);
        emit_reload_if_spilled(?result.out, src2_base_range, fp_reg);
        emit_reload_if_spilled(?result.out, src2_idx_range, fp_reg);
        emit_reload_if_spilled(?result.out, dst_base_range, fp_reg);
        emit_reload_if_spilled(?result.out, dst_idx_range, fp_reg);

        var rewritten: xi.MachInst = @mi;
        rewrite_operand(?rewritten.dst,  ranges, range_count, fp_reg);
        rewrite_operand(?rewritten.src1, ranges, range_count, fp_reg);
        rewrite_operand(?rewritten.src2, ranges, range_count, fp_reg);
        xi.buf_append(?result.out, rewritten);

        emit_spill_if_spilled(?result.out, dst_range, fp_reg);

        idx = idx + 1;
    }

    result.ok = true;
    ret result;
}

fun is_in_file(reg_id: i32, file: *isa.RegisterFile) bool {
    if (file == nil || file.regs == nil) { ret false; }
    var i: i32 = 0;
    for (i < file.count) {
        if (file.regs[i].id == reg_id) { ret true; }
        i = i + 1;
    }
    ret false;
}

fun scan_operand(op: *xi.Operand, idx: i32, ranges: *LiveRange, count: *i32) {
    if (op == nil) { ret; }

    if (op.kind == xi.OPK_REG) {
        if (inst.is_vreg(op.reg)) {
            record_use(op.reg, idx, op.size, ranges, count);
        }
    } or (op.kind == xi.OPK_MEM) {
        if (inst.is_vreg(op.base)) {
            record_use(op.base, idx, 8, ranges, count);
        }
        if (op.index >= 0 && inst.is_vreg(op.index)) {
            record_use(op.index, idx, 8, ranges, count);
        }
    }
}

fun record_use(vreg: i32, idx: i32, size: u8, ranges: *LiveRange, count: *i32) {
    var i: i32 = 0;
    for (i < @count) {
        if (ranges[i].vreg == vreg) {
            if (idx < ranges[i].start) { ranges[i].start = idx; }
            if (idx > ranges[i].end_pos) { ranges[i].end_pos = idx; }
            if (size > ranges[i].size) { ranges[i].size = size; }
            ret;
        }
        i = i + 1;
    }

    val n: i32 = @count;
    ranges[n].vreg = vreg;
    ranges[n].start = idx;
    ranges[n].end_pos = idx;
    ranges[n].size = size;
    ranges[n].preg = -1;
    ranges[n].spill_off = 0;
    ranges[n].spilled = false;
    @count = n + 1;
}

fun sort_ranges(ranges: *LiveRange, count: i32) {
    var i: i32 = 1;
    for (i < count) {
        var tmp: LiveRange = ranges[i];
        var j: i32 = i - 1;
        for (j >= 0 && ranges[j].start > tmp.start) {
            ranges[j + 1] = ranges[j];
            j = j - 1;
        }
        ranges[j + 1] = tmp;
        i = i + 1;
    }
}

fun find_free_reg(reg_free: *bool, pool_count: i32) i32 {
    var i: i32 = 0;
    for (i < pool_count) {
        if (reg_free[i]) { ret i; }
        i = i + 1;
    }
    ret -1;
}

fun find_free_reg_range(reg_free: *bool, from: i32, to: i32) i32 {
    var i: i32 = from;
    for (i < to) {
        if (reg_free[i]) { ret i; }
        i = i + 1;
    }
    ret -1;
}

fun is_in_pool_range(preg: i32, pool: *i32, from: i32, to: i32) bool {
    var i: i32 = from;
    for (i < to) {
        if (pool[i] == preg) { ret true; }
        i = i + 1;
    }
    ret false;
}

fun is_phys_excluded(preg: i32, start: i32, end_pos: i32,
                     pw: *PhysWrite, pw_count: i32,
                     calls: *i32, call_count: i32) bool {
    if (pw == nil || pw_count == 0) { ret false; }
    var i: i32 = 0;
    for (i < pw_count) {
        val w: i32 = pw[i].pos;
        if (pw[i].reg == preg) {
            if (w > start && w < end_pos) {
                ret true;
            }
            if (w <= start) {
                val c: i32 = next_call_after(w, calls, call_count);
                if (c > start && !has_rewrite(preg, w, c, pw, pw_count)) {
                    ret true;
                }
            }
        }
        i = i + 1;
    }
    ret false;
}

fun build_param_live(param_last_read: *i32, max_regs: i32,
                     pr: *PhysWrite, pr_count: i32,
                     pw: *PhysWrite, pw_count: i32,
                     calls: *i32, call_count: i32) {
    var ri: i32 = 0;
    for (ri < max_regs) { param_last_read[ri] = 0; ri = ri + 1; }

    if (pr == nil || pr_count == 0) { ret; }

    var first_call: i32 = 0x7fffffff;
    if (calls != nil && call_count > 0) {
        first_call = calls[0];
    }

    var i: i32 = 0;
    for (i < pr_count) {
        val reg: i32 = pr[i].reg;
        val read_pos: i32 = pr[i].pos;
        if (reg < 0 || reg >= max_regs) { i = i + 1; cnt; }

        if (read_pos > first_call) { i = i + 1; cnt; }

        var clobbered: bool = false;
        var j: i32 = 0;
        for (j < pw_count) {
            if (pw[j].reg == reg && pw[j].pos < read_pos) {
                clobbered = true;
                brk;
            }
            j = j + 1;
        }
        if (clobbered) { i = i + 1; cnt; }

        if (read_pos > param_last_read[reg]) {
            param_last_read[reg] = read_pos;
        }

        i = i + 1;
    }
}

fun has_param_conflict(preg: i32, vreg_start: i32,
                       param_last_read: *i32, max_regs: i32) bool {
    if (param_last_read == nil || preg < 0 || preg >= max_regs) { ret false; }
    ret param_last_read[preg] > vreg_start;
}

fun find_free_reg_excl(reg_free: *bool, pool: *i32, pool_count: i32,
                       start: i32, end_pos: i32,
                       pw: *PhysWrite, pw_count: i32,
                       plr: *i32, plr_max: i32,
                       calls: *i32, call_count: i32) i32 {
    var i: i32 = 0;
    for (i < pool_count) {
        if (reg_free[i] &&
            !is_phys_excluded(pool[i], start, end_pos, pw, pw_count,
                              calls, call_count) &&
            !has_param_conflict(pool[i], start, plr, plr_max)) {
            ret i;
        }
        i = i + 1;
    }
    ret -1;
}

fun find_free_reg_range_excl(reg_free: *bool, from: i32, to: i32,
                             pool: *i32, start: i32, end_pos: i32,
                             pw: *PhysWrite, pw_count: i32,
                             plr: *i32, plr_max: i32,
                             calls: *i32, call_count: i32) i32 {
    var i: i32 = from;
    for (i < to) {
        if (reg_free[i] &&
            !is_phys_excluded(pool[i], start, end_pos, pw, pw_count,
                              calls, call_count) &&
            !has_param_conflict(pool[i], start, plr, plr_max)) {
            ret i;
        }
        i = i + 1;
    }
    ret -1;
}

fun spans_call(start: i32, end_pos: i32, calls: *i32, call_count: i32) bool {
    if (calls == nil || call_count == 0) { ret false; }
    var i: i32 = 0;
    for (i < call_count) {
        if (calls[i] > start && calls[i] < end_pos) { ret true; }
        if (calls[i] >= end_pos) { ret false; }
        i = i + 1;
    }
    ret false;
}

fun next_call_after(pos: i32, calls: *i32, call_count: i32) i32 {
    var i: i32 = 0;
    for (i < call_count) {
        if (calls[i] > pos) { ret calls[i]; }
        i = i + 1;
    }
    ret -1;
}

fun has_rewrite(preg: i32, from: i32, to: i32,
                pw: *PhysWrite, pw_count: i32) bool {
    var i: i32 = 0;
    for (i < pw_count) {
        if (pw[i].reg == preg && pw[i].pos > from && pw[i].pos < to) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

fun free_pool_reg(reg_free: *bool, pool: *i32, pool_count: i32, preg: i32) {
    var i: i32 = 0;
    for (i < pool_count) {
        if (pool[i] == preg) { reg_free[i] = true; ret; }
        i = i + 1;
    }
}

fun find_range(vreg: i32, ranges: *LiveRange, count: i32) *LiveRange {
    var i: i32 = 0;
    for (i < count) {
        if (ranges[i].vreg == vreg) { ret ?ranges[i]; }
        i = i + 1;
    }
    ret nil;
}

fun find_range_for_operand(op: *xi.Operand, ranges: *LiveRange, count: i32) *LiveRange {
    if (op == nil) { ret nil; }
    if (op.kind == xi.OPK_REG && inst.is_vreg(op.reg)) {
        ret find_range(op.reg, ranges, count);
    }
    ret nil;
}

fun find_mem_base_range(op: *xi.Operand, ranges: *LiveRange, count: i32) *LiveRange {
    if (op == nil) { ret nil; }
    if (op.kind == xi.OPK_MEM && inst.is_vreg(op.base)) {
        ret find_range(op.base, ranges, count);
    }
    ret nil;
}

fun find_mem_idx_range(op: *xi.Operand, ranges: *LiveRange, count: i32) *LiveRange {
    if (op == nil) { ret nil; }
    if (op.kind == xi.OPK_MEM && op.index >= 0 && inst.is_vreg(op.index)) {
        ret find_range(op.index, ranges, count);
    }
    ret nil;
}

fun assign_spill_temps(ranges: *LiveRange, range_count: i32, idx: i32,
                       pool: *i32, pool_count: i32,
                       dst_r: *LiveRange, src1_r: *LiveRange, src2_r: *LiveRange,
                       dst_base_r: *LiveRange, dst_idx_r: *LiveRange,
                       src1_base_r: *LiveRange, src1_idx_r: *LiveRange,
                       src2_base_r: *LiveRange, src2_idx_r: *LiveRange) bool {
    var occupied: u64 = 0;
    var ri: i32 = 0;
    for (ri < range_count) {
        if (!ranges[ri].spilled && ranges[ri].preg >= 0 &&
            ranges[ri].start <= idx && ranges[ri].end_pos >= idx) {
            var pi: i32 = 0;
            for (pi < pool_count) {
                if (pool[pi] == ranges[ri].preg) {
                    occupied = occupied | (1::u64 << pi::u64);
                }
                pi = pi + 1;
            }
        }
        ri = ri + 1;
    }

    if (!assign_one_temp(src1_r,      idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src2_r,      idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src1_base_r, idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src1_idx_r,  idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src2_base_r, idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(src2_idx_r,  idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(dst_base_r,  idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(dst_idx_r,   idx, pool, pool_count, ?occupied)) { ret false; }
    if (!assign_one_temp(dst_r,       idx, pool, pool_count, ?occupied)) { ret false; }
    ret true;
}

fun assign_one_temp(lr: *LiveRange, idx: i32, pool: *i32, pool_count: i32,
                    occupied: *u64) bool {
    if (lr == nil || !lr.spilled) { ret true; }

    var pi: i32 = 0;
    for (pi < pool_count) {
        if ((@occupied & (1::u64 << pi::u64)) == 0) {
            lr.preg = pool[pi];
            @occupied = @occupied | (1::u64 << pi::u64);
            ret true;
        }
        pi = pi + 1;
    }
    dbg.eprint("regalloc: error: all pool registers occupied at instruction ");
    dbg.eu64(idx::u64);
    dbg.eprint(", cannot assign scratch for spilled operand\n");
    lr.preg = -1;
    ret false;
}

# emit_reload_if_spilled: emit a reload (MOV preg, [fp_reg + offset]) for a spilled live range.
fun emit_reload_if_spilled(out: *inst_buf.InstructionBuffer[xi.MachInst],
                           lr: *LiveRange, fp_reg: i32) {
    if (lr == nil || !lr.spilled || lr.preg < 0) { ret; }
    var mi: xi.MachInst;
    mi.opcode = opcode.OP_MOV;
    mi.dst = xi.make_reg(lr.preg, lr.size);
    mi.src1 = xi.make_mem(fp_reg, -1, 1, lr.spill_off, lr.size);
    mi.size = lr.size;
    mi.flags = 0;
    if (lr.size == 8) { mi.flags = opcode.FLAG_REX_W; }
    xi.buf_append(out, mi);
}

# emit_spill_if_spilled: emit a spill (MOV [fp_reg + offset], preg) for a spilled live range.
fun emit_spill_if_spilled(out: *inst_buf.InstructionBuffer[xi.MachInst],
                          lr: *LiveRange, fp_reg: i32) {
    if (lr == nil || !lr.spilled || lr.preg < 0) { ret; }
    var mi: xi.MachInst;
    mi.opcode = opcode.OP_MOV;
    mi.dst = xi.make_mem(fp_reg, -1, 1, lr.spill_off, lr.size);
    mi.src1 = xi.make_reg(lr.preg, lr.size);
    mi.size = lr.size;
    mi.flags = 0;
    if (lr.size == 8) { mi.flags = opcode.FLAG_REX_W; }
    xi.buf_append(out, mi);
}

fun rewrite_operand(op: *xi.Operand, ranges: *LiveRange, count: i32, fp_reg: i32) {
    if (op == nil) { ret; }

    if (op.kind == xi.OPK_REG) {
        if (inst.is_vreg(op.reg)) {
            val lr: *LiveRange = find_range(op.reg, ranges, count);
            if (lr != nil && lr.preg >= 0) {
                op.reg = lr.preg;
            }
        }
    } or (op.kind == xi.OPK_MEM) {
        if (op.base == inst.VREG_FP) {
            op.base = fp_reg;
        } or (op.base == inst.VREG_SP) {
            # leave VREG_SP unchanged — pipeline resolves after total_frame is known
        } or (inst.is_vreg(op.base)) {
            val lr: *LiveRange = find_range(op.base, ranges, count);
            if (lr != nil && lr.preg >= 0) {
                op.base = lr.preg;
            }
        }
        if (op.index >= 0 && inst.is_vreg(op.index)) {
            val lr: *LiveRange = find_range(op.index, ranges, count);
            if (lr != nil && lr.preg >= 0) {
                op.index = lr.preg;
            }
        }
    }
}
