use std.types.bool;

use xi:       mach.compiler.target.isa.x86_64.inst;
use inst_buf: mach.compiler.codegen.inst_buf;
use op:       mach.compiler.target.isa.x86_64.opcode;

# mach.compiler.target.isa.x86_64.peephole: x86_64 peephole optimizer.
# ---
# runs pattern-matching rules over a MachInstBuf to eliminate
# redundancy before encoding. operates in a fixed-point loop.

# optimize: run all peephole rules until no more changes occur.
pub fun optimize(buf: *inst_buf.InstructionBuffer[xi.MachInst]) {
    if (buf == nil || buf.count == 0) { ret; }

    var changed: bool = true;
    for (changed) {
        changed = false;
        if (rule_self_move(buf))        { changed = true; }
        if (rule_zero_via_xor(buf))     { changed = true; }
        if (rule_push_pop(buf))         { changed = true; }
        if (rule_reverse_mov(buf))      { changed = true; }
        if (rule_spill_reload(buf))     { changed = true; }
    }

    xi.buf_compact(buf);
}

# --- rules ---

# rule_self_move: eliminate mov rX, rX.
fun rule_self_move(buf: *inst_buf.InstructionBuffer[xi.MachInst]) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count) {
        val inst: *xi.MachInst = xi.buf_get(buf, i);
        if (inst != nil && inst.opcode == op.OP_MOV &&
            inst.dst.kind == xi.OPK_REG && inst.src1.kind == xi.OPK_REG &&
            inst.dst.reg == inst.src1.reg && inst.dst.size == inst.src1.size) {
            xi.buf_mark_nop(buf, i);
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_zero_via_xor: replace mov rX, 0 with xor rX, rX.
fun rule_zero_via_xor(buf: *inst_buf.InstructionBuffer[xi.MachInst]) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count) {
        val inst: *xi.MachInst = xi.buf_get(buf, i);
        if (inst != nil && inst.opcode == op.OP_MOV &&
            inst.dst.kind == xi.OPK_REG && inst.src1.kind == xi.OPK_IMM &&
            inst.src1.imm == 0) {
            inst.opcode = op.XOR;
            inst.src1.kind = xi.OPK_REG;
            inst.src1.reg = inst.dst.reg;
            inst.src1.imm = 0;
            # xor r32,r32 zero-extends on x86_64 and is smaller
            if (inst.size == 8) {
                inst.dst.size = 4;
                inst.src1.size = 4;
                inst.size = 4;
                inst.flags = 0;
            }
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_push_pop: optimize adjacent push/pop pairs.
# push rX; pop rX → NOP both
# push rX; pop rY → mov rY, rX
fun rule_push_pop(buf: *inst_buf.InstructionBuffer[xi.MachInst]) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count - 1) {
        val a: *xi.MachInst = xi.buf_get(buf, i);
        val b: *xi.MachInst = xi.buf_get(buf, i + 1);
        if (a != nil && b != nil &&
            a.opcode == op.PUSH && b.opcode == op.POP &&
            a.dst.kind == xi.OPK_REG && b.dst.kind == xi.OPK_REG) {
            if (a.dst.reg == b.dst.reg) {
                xi.buf_mark_nop(buf, i);
                xi.buf_mark_nop(buf, i + 1);
                changed = true;
            } or {
                b.opcode = op.OP_MOV;
                b.src1.kind = xi.OPK_REG;
                b.src1.reg = a.dst.reg;
                b.src1.size = 8;
                b.size = 8;
                b.flags = op.FLAG_REX_W;
                xi.buf_mark_nop(buf, i);
                changed = true;
            }
        }
        i = i + 1;
    }
    ret changed;
}

# rule_reverse_mov: eliminate mov rY, rX after mov rX, rY.
fun rule_reverse_mov(buf: *inst_buf.InstructionBuffer[xi.MachInst]) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count - 1) {
        val a: *xi.MachInst = xi.buf_get(buf, i);
        val b: *xi.MachInst = xi.buf_get(buf, i + 1);
        if (a != nil && b != nil &&
            a.opcode == op.OP_MOV && b.opcode == op.OP_MOV &&
            a.dst.kind == xi.OPK_REG && a.src1.kind == xi.OPK_REG &&
            b.dst.kind == xi.OPK_REG && b.src1.kind == xi.OPK_REG &&
            a.dst.reg == b.src1.reg && a.src1.reg == b.dst.reg) {
            xi.buf_mark_nop(buf, i + 1);
            changed = true;
        }
        i = i + 1;
    }
    ret changed;
}

# rule_spill_reload: eliminate redundant spill/reload pairs.
# mov [mem], rX; mov rX, [mem] → NOP second
# mov [mem], rX; mov rY, [mem] → mov rY, rX
fun rule_spill_reload(buf: *inst_buf.InstructionBuffer[xi.MachInst]) bool {
    var changed: bool = false;
    var i: i32 = 0;
    for (i < buf.count - 1) {
        val a: *xi.MachInst = xi.buf_get(buf, i);
        val b: *xi.MachInst = xi.buf_get(buf, i + 1);
        if (a == nil || b == nil ||
            a.opcode != op.OP_MOV || b.opcode != op.OP_MOV) {
            i = i + 1;
            cnt;
        }

        # store then reload same reg from same address
        if (a.dst.kind == xi.OPK_MEM && a.src1.kind == xi.OPK_REG &&
            b.dst.kind == xi.OPK_REG && b.src1.kind == xi.OPK_MEM &&
            a.dst.base == b.src1.base && a.dst.disp == b.src1.disp) {
            if (a.src1.reg == b.dst.reg) {
                # same reg: NOP the reload
                xi.buf_mark_nop(buf, i + 1);
                changed = true;
                i = i + 2;
                cnt;
            }
            # different reg: replace reload with reg-reg mov
            b.src1.kind = xi.OPK_REG;
            b.src1.reg = a.src1.reg;
            b.src1.size = b.dst.size;
            changed = true;
        }

        i = i + 1;
    }
    ret changed;
}
