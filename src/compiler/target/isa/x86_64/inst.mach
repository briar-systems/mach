use std.types.bool;
use std.types.size;
use std.types.string;

use inst:     masm.inst;
use op:       masm.op;
use fn:       masm.function;
use pool:     masm.pool;
use inst_buf: mach.compiler.codegen.inst_buf;

use allocator: std.allocator;

# mach.compiler.target.isa.x86_64.inst: x86_64 machine instruction types.
# ---
# defines the x86_64-specific MachInst, Operand, and buffer operations.
# these types are local to the x86_64 backend — they do not leak to
# the ISA interface or any other pipeline stage.
# also provides compact-IR-to-Operand reconstruction for ISel.

pub def ValueKind: u8;

pub val OPK_NONE:  ValueKind = 0;
pub val OPK_REG:   ValueKind = 1;
pub val OPK_IMM:   ValueKind = 2;
pub val OPK_MEM:   ValueKind = 3;
pub val OPK_LABEL: ValueKind = 4;
pub val OPK_SYM:   ValueKind = 5;

pub val LABEL: i32 = -1;
pub val NOP:   i32 = -2;

pub rec Operand {
    kind:   ValueKind;
    size:   u8;
    reg:    i32;
    imm:    i64;
    base:   i32;
    index:  i32;
    scale:  i32;
    disp:   i64;
    sym_id: u64;
    label:  str;
}

pub rec MachInst {
    opcode:   i32;
    dst:      Operand;
    src1:     Operand;
    src2:     Operand;
    size:     u8;
    flags:    u32;
    src_line: i32;
    src_file: u16;
}

pub fun make_none() Operand {
    var o: Operand;
    o.kind = OPK_NONE;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = -1;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_reg(reg: i32, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_REG;
    o.size = size;
    o.reg = reg;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_imm(imm: i64, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_IMM;
    o.size = size;
    o.reg = 0;
    o.imm = imm;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_mem(base: i32, index: i32, scale: i32, disp: i64, size: u8) Operand {
    var o: Operand;
    o.kind = OPK_MEM;
    o.size = size;
    o.reg = 0;
    o.imm = 0;
    o.base = base;
    o.index = index;
    o.scale = scale;
    o.disp = disp;
    o.sym_id = 0;
    o.label = nil;
    ret o;
}

pub fun make_label(label: str) Operand {
    var o: Operand;
    o.kind = OPK_LABEL;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = 0;
    o.label = label;
    ret o;
}

pub fun make_sym(sym_id: u64) Operand {
    var o: Operand;
    o.kind = OPK_SYM;
    o.size = 0;
    o.reg = 0;
    o.imm = 0;
    o.base = 0;
    o.index = -1;
    o.scale = 1;
    o.disp = 0;
    o.sym_id = sym_id;
    o.label = nil;
    ret o;
}

pub fun is_none(o: *Operand) bool {
    if (o == nil) { ret true; }
    ret o.kind == OPK_NONE;
}

pub fun is_reg(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_REG;
}

pub fun is_imm(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_IMM;
}

pub fun is_mem(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_MEM;
}

pub fun is_label(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_LABEL;
}

pub fun is_sym(o: *Operand) bool {
    if (o == nil) { ret false; }
    ret o.kind == OPK_SYM;
}

pub fun kind_name(kind: ValueKind) str {
    if (kind == OPK_NONE)  { ret "none"; }
    if (kind == OPK_REG)   { ret "reg"; }
    if (kind == OPK_IMM)   { ret "imm"; }
    if (kind == OPK_MEM)   { ret "mem"; }
    if (kind == OPK_LABEL) { ret "label"; }
    if (kind == OPK_SYM)   { ret "sym"; }
    ret "unknown";
}

# buffer wrappers using InstructionBuffer[MachInst]

pub fun buf_create(alloc: *allocator.Allocator) inst_buf.InstructionBuffer[MachInst] {
    ret inst_buf.buf_create[MachInst](alloc);
}

pub fun buf_append(buf: *inst_buf.InstructionBuffer[MachInst], mi: MachInst) bool {
    ret inst_buf.buf_append[MachInst](buf, mi);
}

pub fun buf_get(buf: *inst_buf.InstructionBuffer[MachInst], index: i32) *MachInst {
    ret inst_buf.buf_get[MachInst](buf, index);
}

pub fun buf_clear(buf: *inst_buf.InstructionBuffer[MachInst]) {
    inst_buf.buf_clear[MachInst](buf);
}

pub fun buf_destroy(buf: *inst_buf.InstructionBuffer[MachInst]) {
    inst_buf.buf_destroy[MachInst](buf);
}

pub fun buf_mark_nop(buf: *inst_buf.InstructionBuffer[MachInst], index: i32) {
    val mi: *MachInst = buf_get(buf, index);
    if (mi != nil) { mi.opcode = NOP; }
}

pub fun buf_compact(buf: *inst_buf.InstructionBuffer[MachInst]) {
    if (buf == nil || buf.insts == nil) { ret; }
    var write: i32 = 0;
    var read: i32 = 0;
    for (read < buf.count) {
        if (buf.insts[read].opcode != NOP) {
            if (write != read) {
                buf.insts[write] = buf.insts[read];
            }
            write = write + 1;
        }
        read = read + 1;
    }
    buf.count = write;
}

# pool-resolved accessors (f2 is DataPool byte offset)

pub fun imm32(i: *inst.Instruction, func: *fn.Function) i32 {
    ret pool.data_get_i32(?func.data_pool, i.f2::i32);
}

pub fun disp(i: *inst.Instruction, func: *fn.Function) i32 {
    ret pool.data_get_i32(?func.data_pool, i.f2::i32);
}

pub fun mem_index(i: *inst.Instruction, func: *fn.Function) u16 {
    val packed: i32 = pool.data_get_i32(?func.data_pool, i.f2::i32);
    ret (packed >> 16)::u16;
}

pub fun mem_scale(i: *inst.Instruction) u8 {
    ret 1 << (inst.cc(i) & 3);
}

pub fun mem_disp16(i: *inst.Instruction, func: *fn.Function) i16 {
    val packed: i32 = pool.data_get_i32(?func.data_pool, i.f2::i32);
    ret packed::i16;
}

# inst_to_dst_operand: reconstruct destination Operand from compact Instruction.
pub fun inst_to_dst_operand(i: *inst.Instruction, func: *fn.Function) Operand {
    val o: u8 = i.op;
    val sz: u8 = inst.size(i);

    if (o == op.OP_STORE) {
        if (inst.flag(i) != 0) {
            ret make_mem(i.f1::i32, mem_index(i, func)::i32,
                         mem_scale(i)::i32, mem_disp16(i, func)::i64, sz);
        }
        ret make_mem(i.f1::i32, -1, 1, disp(i, func)::i64, sz);
    }

    if (o == op.OP_JMP || o == op.OP_BRCOND || o == op.OP_LABEL) {
        val name: str = pool.label_get(?func.labels, i.f2::i32);
        ret make_label(name);
    }

    if (o == op.OP_CALL) {
        if (inst.flag(i) == 0) {
            val name: str = pool.label_get(?func.labels, i.f2::i32);
            ret make_label(name);
        }
        ret make_reg(i.f1::i32, 8);
    }

    if (o == op.OP_ICMP || o == op.OP_FCMP) {
        ret make_reg(i.f0::i32, 1);
    }

    ret make_reg(i.f0::i32, sz);
}

# inst_to_src1_operand: reconstruct src1 Operand from compact Instruction.
pub fun inst_to_src1_operand(i: *inst.Instruction, func: *fn.Function) Operand {
    val o: u8 = i.op;
    val sz: u8 = inst.size(i);

    if (o == op.OP_ADDR && inst.cc(i) == 1) {
        val name: str = pool.label_get(?func.labels, i.f2::i32);
        ret make_label(name);
    }

    if (o == op.OP_LOAD || o == op.OP_ADDR) {
        if (inst.flag(i) != 0) {
            ret make_mem(i.f1::i32, mem_index(i, func)::i32,
                         mem_scale(i)::i32, mem_disp16(i, func)::i64, sz);
        }
        ret make_mem(i.f1::i32, -1, 1, disp(i, func)::i64, sz);
    }

    if (o == op.OP_MOV && inst.flag(i) != 0) {
        val value: u64 = pool.const_get(?func.const_pool, i.f2::i32);
        ret make_imm(value::i64, sz);
    }

    if (o == op.OP_MOV && inst.cc(i) == 1) {
        ret make_imm(imm32(i, func)::i64, sz);
    }

    if (o == op.OP_BRCOND) {
        ret make_reg(i.f0::i32, 1);
    }

    if (o == op.OP_STORE) {
        ret make_reg(i.f0::i32, sz);
    }

    if (o == op.OP_FTOI) {
        var src_sz: u8 = i.f2::u8;
        if (src_sz == 0) { src_sz = sz; }
        ret make_reg(i.f1::i32, src_sz);
    }

    ret make_reg(i.f1::i32, sz);
}

# inst_to_src2_operand: reconstruct src2 Operand from compact Instruction.
pub fun inst_to_src2_operand(i: *inst.Instruction) Operand {
    val o: u8 = i.op;
    val sz: u8 = inst.size(i);

    if (o >= op.OP_ADD && o <= op.OP_SAR) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }
    if (o >= op.OP_FADD && o <= op.OP_FDIV) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }
    if (o == op.OP_ICMP || o == op.OP_FCMP) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }
    if (o == op.OP_MEMSET) {
        ret make_reg(inst.src2_reg(i)::i32, sz);
    }

    ret make_none();
}
