# mach.compiler.target.isa.x86_64.defs: register definitions and opcode constants
#
# defines all x86_64 general-purpose and SSE register IDs, machine opcodes,
# and encoding flags. provides register file construction and register name
# lookup.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use isa: mach.compiler.target.isa;

pub val RAX: i32 = 0;
pub val RCX: i32 = 1;
pub val RDX: i32 = 2;
pub val RBX: i32 = 3;
pub val RSP: i32 = 4;
pub val RBP: i32 = 5;
pub val RSI: i32 = 6;
pub val RDI: i32 = 7;
pub val R8:  i32 = 8;
pub val R9:  i32 = 9;
pub val R10: i32 = 10;
pub val R11: i32 = 11;
pub val R12: i32 = 12;
pub val R13: i32 = 13;
pub val R14: i32 = 14;
pub val R15: i32 = 15;

pub val XMM0:  i32 = 0;
pub val XMM1:  i32 = 1;
pub val XMM2:  i32 = 2;
pub val XMM3:  i32 = 3;
pub val XMM4:  i32 = 4;
pub val XMM5:  i32 = 5;
pub val XMM6:  i32 = 6;
pub val XMM7:  i32 = 7;
pub val XMM8:  i32 = 8;
pub val XMM9:  i32 = 9;
pub val XMM10: i32 = 10;
pub val XMM11: i32 = 11;
pub val XMM12: i32 = 12;
pub val XMM13: i32 = 13;
pub val XMM14: i32 = 14;
pub val XMM15: i32 = 15;

pub val GP_COUNT: i32 = 16;
pub val FP_COUNT: i32 = 16;

pub def Opcode: u16;
pub val NOP:       Opcode = 0;
pub val MOV:       Opcode = 1;
pub val LEA:       Opcode = 2;
pub val PUSH:      Opcode = 3;
pub val POP:       Opcode = 4;
pub val ADD:       Opcode = 5;
pub val SUB:       Opcode = 6;
pub val IMUL:      Opcode = 7;
pub val IDIV:      Opcode = 8;
pub val DIV:       Opcode = 9;
pub val AND:       Opcode = 10;
pub val OR:        Opcode = 11;
pub val XOR:       Opcode = 12;
pub val SHL:       Opcode = 13;
pub val SHR:       Opcode = 14;
pub val SAR:       Opcode = 15;
pub val CMP:       Opcode = 16;
pub val TEST:      Opcode = 17;
pub val JMP:       Opcode = 18;
pub val CALL:      Opcode = 19;
pub val RET:       Opcode = 20;
pub val JE:        Opcode = 21;
pub val JNE:       Opcode = 22;
pub val JL:        Opcode = 23;
pub val JLE:       Opcode = 24;
pub val JG:        Opcode = 25;
pub val JGE:       Opcode = 26;
pub val JB:        Opcode = 27;
pub val JBE:       Opcode = 28;
pub val JA:        Opcode = 29;
pub val JAE:       Opcode = 30;
pub val SETE:      Opcode = 31;
pub val SETNE:     Opcode = 32;
pub val SETL:      Opcode = 33;
pub val SETLE:     Opcode = 34;
pub val SETG:      Opcode = 35;
pub val SETGE:     Opcode = 36;
pub val SETB:      Opcode = 37;
pub val SETBE:     Opcode = 38;
pub val SETA:      Opcode = 39;
pub val SETAE:     Opcode = 40;
pub val MOVSS:     Opcode = 41;
pub val MOVSD:     Opcode = 42;
pub val ADDSS:     Opcode = 43;
pub val ADDSD:     Opcode = 44;
pub val SUBSS:     Opcode = 45;
pub val SUBSD:     Opcode = 46;
pub val MULSS:     Opcode = 47;
pub val MULSD:     Opcode = 48;
pub val DIVSS:     Opcode = 49;
pub val DIVSD:     Opcode = 50;
pub val SYSCALL:   Opcode = 51;
pub val MOVABS:    Opcode = 52;
pub val UD2:       Opcode = 53;
pub val PAUSE:     Opcode = 54;
pub val CDQ:       Opcode = 55;
pub val CQO:       Opcode = 56;
pub val MOVSX:     Opcode = 57;
pub val MOVZX:     Opcode = 58;
pub val MOVSXD:    Opcode = 59;
pub val CVTSI2SS:  Opcode = 60;
pub val CVTSI2SD:  Opcode = 61;
pub val CVTSS2SD:  Opcode = 62;
pub val CVTSD2SS:  Opcode = 63;
pub val CVTTSS2SI: Opcode = 64;
pub val CVTTSD2SI: Opcode = 65;
pub val UCOMISS:   Opcode = 66;
pub val UCOMISD:       Opcode = 67;
pub val MOVSB:         Opcode = 68;
pub val MFENCE:        Opcode = 69;
pub val ISA_ASM_BLOCK: Opcode = 70;
pub val CBW:           Opcode = 71;
pub val CWD:           Opcode = 72;
pub val MOVQ:          Opcode = 73;
pub val XORPS:         Opcode = 74;

pub def EncFlag: u16;
pub val FLAG_REX_W:    EncFlag = 1;
pub val FLAG_16BIT:    EncFlag = 2;
pub val FLAG_LOCK:     EncFlag = 4;
pub val FLAG_REP:      EncFlag = 8;
pub val FLAG_INDIRECT: EncFlag = 16;
pub val FLAG_REX_BYTE: EncFlag = 32;

pub rec X86Context {
    alloc:   *allocator.Allocator;
    gp:      *isa.Register;
    fp:      *isa.Register;
    gp_file: isa.RegisterFile;
    fp_file: isa.RegisterFile;
}

pub fun init_context(alloc: *allocator.Allocator) *X86Context {
    val res_ctx: Result[*X86Context, str] = allocator.allocate[X86Context](alloc, 1);
    if (is_err[*X86Context, str](res_ctx)) { ret nil; }
    val xctx: *X86Context = unwrap_ok[*X86Context, str](res_ctx);
    xctx.alloc = alloc;

    val res_gp: Result[*isa.Register, str] = allocator.allocate[isa.Register](alloc, GP_COUNT::usize);
    if (is_err[*isa.Register, str](res_gp)) { ret nil; }
    xctx.gp = unwrap_ok[*isa.Register, str](res_gp);
    var i: i32 = 0;
    for (i < GP_COUNT) {
        xctx.gp[i].id   = i;
        xctx.gp[i].size  = 8;
        i = i + 1;
    }

    val res_fp: Result[*isa.Register, str] = allocator.allocate[isa.Register](alloc, FP_COUNT::usize);
    if (is_err[*isa.Register, str](res_fp)) { ret nil; }
    xctx.fp = unwrap_ok[*isa.Register, str](res_fp);
    i = 0;
    for (i < FP_COUNT) {
        xctx.fp[i].id   = i;
        xctx.fp[i].size  = 16;
        i = i + 1;
    }

    xctx.gp_file.regs  = xctx.gp;
    xctx.gp_file.count = GP_COUNT;
    xctx.fp_file.regs  = xctx.fp;
    xctx.fp_file.count = FP_COUNT;

    ret xctx;
}

pub fun gp_registers(ctx: ptr) isa.RegisterFile {
    if (ctx != nil) {
        val xctx: *X86Context = ctx::*X86Context;
        ret xctx.gp_file;
    }
    var rf: isa.RegisterFile;
    rf.regs  = nil;
    rf.count = GP_COUNT;
    ret rf;
}

pub fun fp_registers(ctx: ptr) isa.RegisterFile {
    if (ctx != nil) {
        val xctx: *X86Context = ctx::*X86Context;
        ret xctx.fp_file;
    }
    var rf: isa.RegisterFile;
    rf.regs  = nil;
    rf.count = FP_COUNT;
    ret rf;
}

pub fun x86_is_fp_opcode(op: u16) bool {
    if (op >= MOVSS && op <= DIVSD) { ret true; }
    if (op >= CVTSI2SS && op <= UCOMISD) { ret true; }
    if (op == MOVQ || op == XORPS) { ret true; }
    ret false;
}

# reg_name: look up the name of a GP register for a given operand size
# ---
# ctx:  ISA backend context (unused)
# id:   register number (0-15)
# size: operand width in bytes (1, 2, 4, 8)
# ret:  register name string
pub fun reg_name(ctx: ptr, id: i32, size: u8) str {
    if (size == 1) {
        if (id == RAX) { ret "al"; }
        if (id == RCX) { ret "cl"; }
        if (id == RDX) { ret "dl"; }
        if (id == RBX) { ret "bl"; }
        if (id == RSP) { ret "spl"; }
        if (id == RBP) { ret "bpl"; }
        if (id == RSI) { ret "sil"; }
        if (id == RDI) { ret "dil"; }
        if (id == R8)  { ret "r8b"; }
        if (id == R9)  { ret "r9b"; }
        if (id == R10) { ret "r10b"; }
        if (id == R11) { ret "r11b"; }
        if (id == R12) { ret "r12b"; }
        if (id == R13) { ret "r13b"; }
        if (id == R14) { ret "r14b"; }
        if (id == R15) { ret "r15b"; }
    }

    if (size == 2) {
        if (id == RAX) { ret "ax"; }
        if (id == RCX) { ret "cx"; }
        if (id == RDX) { ret "dx"; }
        if (id == RBX) { ret "bx"; }
        if (id == RSP) { ret "sp"; }
        if (id == RBP) { ret "bp"; }
        if (id == RSI) { ret "si"; }
        if (id == RDI) { ret "di"; }
        if (id == R8)  { ret "r8w"; }
        if (id == R9)  { ret "r9w"; }
        if (id == R10) { ret "r10w"; }
        if (id == R11) { ret "r11w"; }
        if (id == R12) { ret "r12w"; }
        if (id == R13) { ret "r13w"; }
        if (id == R14) { ret "r14w"; }
        if (id == R15) { ret "r15w"; }
    }

    if (size == 4) {
        if (id == RAX) { ret "eax"; }
        if (id == RCX) { ret "ecx"; }
        if (id == RDX) { ret "edx"; }
        if (id == RBX) { ret "ebx"; }
        if (id == RSP) { ret "esp"; }
        if (id == RBP) { ret "ebp"; }
        if (id == RSI) { ret "esi"; }
        if (id == RDI) { ret "edi"; }
        if (id == R8)  { ret "r8d"; }
        if (id == R9)  { ret "r9d"; }
        if (id == R10) { ret "r10d"; }
        if (id == R11) { ret "r11d"; }
        if (id == R12) { ret "r12d"; }
        if (id == R13) { ret "r13d"; }
        if (id == R14) { ret "r14d"; }
        if (id == R15) { ret "r15d"; }
    }

    if (id == RAX) { ret "rax"; }
    if (id == RCX) { ret "rcx"; }
    if (id == RDX) { ret "rdx"; }
    if (id == RBX) { ret "rbx"; }
    if (id == RSP) { ret "rsp"; }
    if (id == RBP) { ret "rbp"; }
    if (id == RSI) { ret "rsi"; }
    if (id == RDI) { ret "rdi"; }
    if (id == R8)  { ret "r8"; }
    if (id == R9)  { ret "r9"; }
    if (id == R10) { ret "r10"; }
    if (id == R11) { ret "r11"; }
    if (id == R12) { ret "r12"; }
    if (id == R13) { ret "r13"; }
    if (id == R14) { ret "r14"; }
    if (id == R15) { ret "r15"; }

    ret "???";
}
