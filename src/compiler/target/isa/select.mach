# mach.compiler.target.isa.select: ISA implementation selector.
# ---
# maps architecture names to ISA implementations.
# adding a new ISA: import it here, add an if-branch.

use std.types.string;
use std.types.result;

use allocator: std.allocator;
use isa:       mach.compiler.target.isa;
use x86_64:   mach.compiler.target.isa.x86_64;

# select an ISA implementation by architecture name.
pub fun select(arch: str, alloc: *allocator.Allocator) Result[isa.ISA, str] {
    if (arch == nil || alloc == nil) {
        ret err[isa.ISA, str]("invalid arguments");
    }

    if (str_equals(arch, "x86_64")) {
        ret x86_64.create(alloc);
    }

    ret err[isa.ISA, str]("unsupported architecture");
}
