# mach.compiler.target.target: target composition and selection
#
# composes ISA, ABI, OS, and object format into a single Target record.
# the select function validates the requested combination and returns a
# fully-configured target or an error.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;

use isa: mach.compiler.target.isa;
use abi: mach.compiler.target.abi;
use os:  mach.compiler.target.os;
use of:  mach.compiler.target.of;

use sysv64: mach.compiler.target.abi.sysv64;
use elf:    mach.compiler.target.of.elf;

# fully resolved compilation target
# ---
# isa:      instruction set architecture interface
# abi:      calling convention interface
# os:       operating system configuration
# of:       object format (writer + linker)
# ptr_size: pointer size in bytes for this target
pub rec Target {
    isa:      isa.ISA;
    abi:      abi.ABI;
    os:       os.OS;
    of:       of.ObjectFormat;
    ptr_size: usize;
}

# select: select a target by component names
#
# currently only supports x86_64/linux/sysv64/elf. returns an error for any
# unsupported combination.
# ---
# arch:     architecture name ("x86_64")
# os_name:  os name ("linux")
# abi_name: ABI name ("sysv64")
# fmt:      object format name ("elf")
# alloc:    allocator for backend state
# ret:      configured Target or error string
pub fun select(arch: str, os_name: str, abi_name: str, fmt: str, alloc: &allocator.Allocator) Result[Target, str] {
    if (!str_equals(arch, "x86_64")) {
        ret err[Target, str]("unsupported architecture");
    }
    if (!str_equals(os_name, "linux") && !str_equals(os_name, "darwin") && !str_equals(os_name, "windows")) {
        ret err[Target, str]("unsupported os");
    }
    if (!str_equals(abi_name, "sysv64")) {
        ret err[Target, str]("unsupported abi");
    }
    if (!str_equals(fmt, "elf")) {
        ret err[Target, str]("unsupported object format");
    }

    val res_os: Result[os.OS, str] = os.from_name(os_name);
    if (is_err[os.OS, str](res_os)) {
        ret err[Target, str]("failed to configure os");
    }

    var t: Target;
    t.os       = unwrap_ok[os.OS, str](res_os);
    t.abi      = sysv64.init(alloc);
    t.ptr_size = 8;

    mem.zero[isa.ISA](?t.isa, 1);
    t.isa.name      = "x86_64";
    t.isa.ptr_size  = 8;
    t.isa.stack_dir = -1;

    var fmt_obj: of.ObjectFormat;
    fmt_obj.name = "elf";
    fmt_obj.obj  = elf.init_writer(alloc);
    fmt_obj.exec = elf.init_exec(alloc);
    t.of = fmt_obj;

    ret ok[Target, str](t);
}

# select_native: select the native host target
#
# assumes x86_64 linux with sysv64 ABI and ELF format.
# ---
# alloc: allocator for backend state
# ret:   configured Target or error string
pub fun select_native(alloc: &allocator.Allocator) Result[Target, str] {
    ret select("x86_64", "linux", "sysv64", "elf", alloc);
}

# dnit: tear down target state
# ---
# target: target to destroy
pub fun dnit(target: *Target) {
}
