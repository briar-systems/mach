# mach.compiler.target.target: target composition and selection
#
# composes ISA, ABI, OS, and object format into a single Target record.
# the select function validates the requested combination and returns a
# fully-configured target or an error.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;

use isa: mach.compiler.target.isa;
use abi: mach.compiler.target.abi;
use os:  mach.compiler.target.os;
use of:  mach.compiler.target.of;

use sysv64:   mach.compiler.target.abi.sysv64;
use elf:      mach.compiler.target.of.elf;
use dwarf:    mach.compiler.target.of.dwarf;
use x86_isel: mach.compiler.target.isa.x86_64.isel;
use x86_enc:  mach.compiler.target.isa.x86_64.encode;
use x86_asm:  mach.compiler.target.isa.x86_64.asm_parser;
use x86_defs: mach.compiler.target.isa.x86_64.defs;
use x86_prn:  mach.compiler.target.isa.x86_64.printer;

$if ($mach.build.target.os.id == $mach.os.linux.id) {
    pub val HOST_OS:  str = "linux";
    pub val HOST_FMT: str = "elf";
}
$or ($mach.build.target.os.id == $mach.os.macos.id) {
    pub val HOST_OS:  str = "darwin";
    pub val HOST_FMT: str = "macho";
}
$or ($mach.build.target.os.id == $mach.os.windows.id) {
    pub val HOST_OS:  str = "windows";
    pub val HOST_FMT: str = "pe";
}
$or {
    pub val HOST_OS:  str = "linux";
    pub val HOST_FMT: str = "elf";
}

$if ($mach.build.target.arch.id == $mach.arch.x86_64.id) {
    pub val HOST_ISA: str = "x86_64";
    pub val HOST_ABI: str = "sysv64";
    pub val HOST_PTR: usize = 8;
}
$or ($mach.build.target.arch.id == $mach.arch.arm64.id) {
    pub val HOST_ISA: str = "aarch64";
    pub val HOST_ABI: str = "aapcs";
    pub val HOST_PTR: usize = 8;
}
$or {
    pub val HOST_ISA: str = "x86_64";
    pub val HOST_ABI: str = "sysv64";
    pub val HOST_PTR: usize = 8;
}

# fully resolved compilation target
# ---
# isa:      instruction set architecture interface
# abi:      calling convention interface
# os:       operating system configuration
# of:       object format (writer + linker)
# ptr_size: pointer size in bytes for this target
pub rec Target {
    isa:      isa.ISA;
    abi:      abi.ABI;
    os:       os.OS;
    of:       of.ObjectFormat;
    ptr_size: usize;
}

# select: select a target by component names
#
# validates the requested ISA/OS/ABI/format combination and constructs
# a fully configured Target. extend the dispatch tables below to add
# new targets — no other file needs to change.
# ---
# arch:     architecture name ("x86_64", "aarch64")
# os_name:  os name ("linux", "darwin", "windows")
# abi_name: ABI name ("sysv64", "win64", "aapcs")
# fmt:      object format name ("elf", "macho", "pe")
# alloc:    allocator for backend state
# ret:      configured Target or error string
pub fun select(arch: str, os_name: str, abi_name: str, fmt: str, alloc: *allocator.Allocator) Result[Target, str] {
    val res_os: Result[os.OS, str] = os.from_name(os_name);
    if (is_err[os.OS, str](res_os)) {
        ret err[Target, str]("unsupported os");
    }

    var t: Target;
    t.os = unwrap_ok[os.OS, str](res_os);

    # ISA dispatch
    if (str_equals(arch, "x86_64")) {
        mem.zero[isa.ISA](?t.isa, 1);
        val xctx: *x86_defs.X86Context = x86_defs.init_context(alloc);
        t.isa.ctx       = xctx::ptr;
        t.isa.name      = "x86_64";
        t.isa.ptr_size  = 8;
        t.isa.stack_dir = -1;
        t.isa.isel           = x86_isel.select;
        t.isa.encode         = x86_enc.encode_inst;
        t.isa.parse_asm      = x86_asm.parse_inline_asm;
        t.isa.emit_prologue  = x86_enc.x86_emit_prologue;
        t.isa.emit_epilogue  = x86_enc.x86_emit_epilogue;
        t.isa.is_ret         = x86_enc.x86_is_ret;
        t.isa.is_call        = x86_enc.x86_is_call;
        t.isa.reloc_offset   = x86_enc.x86_reloc_offset;
        t.isa.reg_name       = x86_defs.reg_name;
        t.isa.print_inst     = x86_prn.x86_print_inst;
        t.isa.gp_regs   = x86_defs.gp_registers;
        t.isa.fp_regs   = x86_defs.fp_registers;
        t.ptr_size      = 8;
    } or {
        ret err[Target, str]("unsupported architecture");
    }

    # ABI dispatch
    if (str_equals(abi_name, "sysv64")) {
        t.abi = sysv64.init(alloc);
    } or {
        ret err[Target, str]("unsupported abi");
    }

    # object format dispatch
    var fmt_obj: of.ObjectFormat;
    if (str_equals(fmt, "elf")) {
        fmt_obj.name  = "elf";
        fmt_obj.obj   = elf.init_writer(alloc);
        fmt_obj.exec  = elf.init_exec(alloc);
        fmt_obj.debug = dwarf.init(alloc, ".");
    } or {
        ret err[Target, str]("unsupported object format");
    }
    t.of = fmt_obj;

    ret ok[Target, str](t);
}

# select_native: select the native host target
#
# uses comptime-resolved HOST_* constants to detect the host platform.
# ---
# alloc: allocator for backend state
# ret:   configured Target or error string
pub fun select_native(alloc: *allocator.Allocator) Result[Target, str] {
    ret select(HOST_ISA, HOST_OS, HOST_ABI, HOST_FMT, alloc);
}

# dnit: tear down target state
# ---
# target: target to destroy
pub fun dnit(target: *Target) {
    if (target == nil) { ret; }
    val debug_dnit: fun(ptr) = target.of.debug.dnit;
    if (debug_dnit != nil && target.of.debug.ctx != nil) {
        debug_dnit(target.of.debug.ctx);
    }
}
