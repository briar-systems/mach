# mach.compiler.target.abi.select: ABI implementation selector.
# ---
# maps architecture + OS combinations to ABI implementations.
# adding a new ABI: import it here, add an if-branch.

use std.types.string;
use std.types.result;

use allocator: std.allocator;
use abi:       mach.compiler.target.abi;
use isa:       mach.compiler.target.isa;
use sysv64:   mach.compiler.target.abi.sysv64;

# select an ABI implementation by architecture, OS, and ISA.
# ---
# i: the ISA provides register descriptors so the ABI never imports
#    ISA-specific opcode modules directly.
pub fun select(arch: str, os_name: str, alloc: *allocator.Allocator,
               i: *isa.ISA) Result[abi.ABI, str] {
    if (arch == nil || os_name == nil || alloc == nil) {
        ret err[abi.ABI, str]("invalid arguments");
    }

    # SysV64 for x86_64 on non-windows platforms
    if (str_equals(arch, "x86_64") && !str_equals(os_name, "windows")) {
        ret sysv64.create(alloc, i);
    }

    ret err[abi.ABI, str]("unsupported ABI for target");
}
