# compiler.target.abi.sysv64: System V AMD64 ABI implementation
#
# stub implementation of the System V x86-64 calling convention. provides
# parameter classification, register files, and stack layout constants.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use isa: compiler.target.isa;
use abi: compiler.target.abi;

val GP_PARAM_COUNT: i32 = 6;
val FP_PARAM_COUNT: i32 = 8;
val CALLEE_SAVED_COUNT: i32 = 5;

# initialize the System V AMD64 ABI.
# ---
# alloc: allocator for internal state
# ret:   populated ABI record
pub fun init(alloc: &allocator.Allocator) abi.ABI {
    var a: abi.ABI;
    a.ctx             = nil;
    a.name            = "sysv64";
    a.classify_param  = stub_classify_param;
    a.classify_return = stub_classify_return;
    a.gp_param_regs   = stub_gp_param_regs;
    a.fp_param_regs   = stub_fp_param_regs;
    a.callee_saved    = stub_callee_saved;
    a.stack_align     = stub_stack_align;
    a.red_zone        = stub_red_zone;
    ret a;
}

fun stub_classify_param(ctx: ptr, index: i32, size: usize, align: usize, is_float: bool, is_aggregate: bool, gp_used: i32, fp_used: i32) abi.ParamSlot {
    var slot: abi.ParamSlot;
    if (is_float && fp_used < FP_PARAM_COUNT) {
        slot.class = abi.CLASS_FP;
        slot.reg   = fp_used;
        slot.offset = 0;
        slot.size  = size;
        ret slot;
    }
    if (!is_aggregate && gp_used < GP_PARAM_COUNT) {
        slot.class = abi.CLASS_GP;
        slot.reg   = gp_used;
        slot.offset = 0;
        slot.size  = size;
        ret slot;
    }
    slot.class  = abi.CLASS_STACK;
    slot.reg    = -1;
    slot.offset = 0;
    slot.size   = size;
    ret slot;
}

fun stub_classify_return(ctx: ptr, size: usize, align: usize, is_float: bool, is_aggregate: bool) abi.ParamSlot {
    var slot: abi.ParamSlot;
    if (is_float) {
        slot.class = abi.CLASS_FP;
        slot.reg   = 0;
    } or {
        slot.class = abi.CLASS_GP;
        slot.reg   = 0;
    }
    slot.offset = 0;
    slot.size   = size;
    ret slot;
}

fun stub_gp_param_regs(ctx: ptr) isa.RegisterFile {
    var rf: isa.RegisterFile;
    rf.regs  = nil;
    rf.count = GP_PARAM_COUNT;
    ret rf;
}

fun stub_fp_param_regs(ctx: ptr) isa.RegisterFile {
    var rf: isa.RegisterFile;
    rf.regs  = nil;
    rf.count = FP_PARAM_COUNT;
    ret rf;
}

fun stub_callee_saved(ctx: ptr) isa.RegisterFile {
    var rf: isa.RegisterFile;
    rf.regs  = nil;
    rf.count = CALLEE_SAVED_COUNT;
    ret rf;
}

fun stub_stack_align(ctx: ptr) usize {
    ret 16;
}

fun stub_red_zone(ctx: ptr) usize {
    ret 128;
}
