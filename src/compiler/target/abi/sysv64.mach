use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use abi:       mach.compiler.target.abi;
use isa:       mach.compiler.target.isa;

# mach.compiler.target.abi.sysv64: System V AMD64 ABI implementation.
# ---
# GP param regs:    RDI, RSI, RDX, RCX, R8, R9
# FP param regs:    XMM0 through XMM7
# callee-saved:     RBX, R12, R13, R14, R15 (RBP is frame pointer)
# return:           RAX (integer), XMM0 (float)
# stack alignment:  16 bytes
# red zone:         128 bytes
# variadic:         AL = count of FP args in XMM registers

val GP_PARAM_COUNT:    i32 = 6;
val FP_PARAM_COUNT:    i32 = 8;
val CALLEE_SAVE_COUNT: i32 = 5;
val STACK_ALIGNMENT:   usize = 16;
val RED_ZONE_SIZE:     usize = 128;
val MAX_REG_AGGREGATE: usize = 16;

# SysVContext: internal state for the SysV64 ABI.
rec SysVContext {
    alloc:       *allocator.Allocator;

    gp_params:   *isa.Register;
    gp_file:     isa.RegisterFile;

    fp_params:   *isa.Register;
    fp_file:     isa.RegisterFile;

    callee:      *isa.Register;
    callee_file: isa.RegisterFile;

    ret_rax:     isa.Register;
    ret_rdx:     isa.Register;
    var_al:      isa.Register;

    stack_off:   i64;
}

fun set_reg(r: *isa.Register, id: i32, name: str, class: isa.RegClass, width: u8) {
    if (r == nil) { ret; }
    r.id = id;
    r.name = name;
    r.class = class;
    r.width = width;
}

# create: construct the SysV AMD64 ABI.
# ---
# i: the ISA whose register files provide physical register descriptors.
#    the ABI indexes into gp_regs/fp_regs by register ID to resolve
#    physical registers without importing ISA-specific opcode constants.
pub fun create(alloc: *allocator.Allocator, i: *isa.ISA) Result[abi.ABI, str] {
    if (alloc == nil) {
        ret err[abi.ABI, str]("allocator is nil");
    }
    if (i == nil) {
        ret err[abi.ABI, str]("ISA is nil");
    }

    val ctx_r: Result[*SysVContext, str] =
        allocator.zallocate[SysVContext](alloc, 1);
    if (!ctx_r.tag) {
        ret err[abi.ABI, str]("out of memory");
    }
    val ctx: *SysVContext = ctx_r.value.ok;
    ctx.alloc = alloc;
    ctx.stack_off = 0;

    val gp_all: isa.RegisterFile = i.gp_regs(i.ctx);
    val fp_all: isa.RegisterFile = i.fp_regs(i.ctx);

    # GP parameter registers: RDI, RSI, RDX, RCX, R8, R9
    # looked up from the ISA's GP register file by register ID
    val gp_r: Result[*isa.Register, str] =
        allocator.allocate[isa.Register](alloc, GP_PARAM_COUNT::usize);
    if (!gp_r.tag) {
        ret err[abi.ABI, str]("out of memory");
    }
    ctx.gp_params = gp_r.value.ok;

    ctx.gp_params[0] = gp_all.regs[7];   # RDI
    ctx.gp_params[1] = gp_all.regs[6];   # RSI
    ctx.gp_params[2] = gp_all.regs[2];   # RDX
    ctx.gp_params[3] = gp_all.regs[1];   # RCX
    ctx.gp_params[4] = gp_all.regs[8];   # R8
    ctx.gp_params[5] = gp_all.regs[9];   # R9

    ctx.gp_file.regs = ctx.gp_params;
    ctx.gp_file.count = GP_PARAM_COUNT;

    # FP parameter registers: XMM0 through XMM7
    val fp_r: Result[*isa.Register, str] =
        allocator.allocate[isa.Register](alloc, FP_PARAM_COUNT::usize);
    if (!fp_r.tag) {
        ret err[abi.ABI, str]("out of memory");
    }
    ctx.fp_params = fp_r.value.ok;

    var fi: i32 = 0;
    for (fi < FP_PARAM_COUNT) {
        ctx.fp_params[fi] = fp_all.regs[fi];
        fi = fi + 1;
    }

    ctx.fp_file.regs = ctx.fp_params;
    ctx.fp_file.count = FP_PARAM_COUNT;

    # callee-saved registers: RBX, R12, R13, R14, R15
    # (RBP is the frame pointer -- saved/restored by prologue/epilogue)
    val cs_r: Result[*isa.Register, str] =
        allocator.allocate[isa.Register](alloc, CALLEE_SAVE_COUNT::usize);
    if (!cs_r.tag) {
        ret err[abi.ABI, str]("out of memory");
    }
    ctx.callee = cs_r.value.ok;

    ctx.callee[0] = gp_all.regs[3];    # RBX
    ctx.callee[1] = gp_all.regs[12];   # R12
    ctx.callee[2] = gp_all.regs[13];   # R13
    ctx.callee[3] = gp_all.regs[14];   # R14
    ctx.callee[4] = gp_all.regs[15];   # R15

    ctx.callee_file.regs = ctx.callee;
    ctx.callee_file.count = CALLEE_SAVE_COUNT;

    # cache return and variadic registers from ISA
    ctx.ret_rax = gp_all.regs[0];     # RAX
    ctx.ret_rdx = gp_all.regs[2];     # RDX
    set_reg(?ctx.var_al, gp_all.regs[0].id, "al", isa.REG_GP, 1);

    # construct ABI interface
    var a: abi.ABI;
    a.ctx  = ctx::ptr;
    a.name = "sysv64";
    a.classify_param = sysv_classify_param;
    a.classify_return = sysv_classify_return;
    a.gp_param_regs = sysv_gp_param_regs;
    a.fp_param_regs = sysv_fp_param_regs;
    a.callee_saved = sysv_callee_saved;
    a.stack_align = sysv_stack_align;
    a.red_zone = sysv_red_zone;
    a.variadic_info = sysv_variadic_info;
    a.vararg_layout = sysv_vararg_layout;
    a.frame_header_size = sysv_frame_header_size;
    a.reset_stack = sysv_reset_stack;

    ret ok[abi.ABI, str](a);
}

fun sysv_reset_stack(ctx: ptr) {
    val x: *SysVContext = ctx::*SysVContext;
    x.stack_off = 0;
}

fun sysv_classify_param(ctx: ptr, index: i32, size: usize, align: usize,
                        is_float: bool, is_aggregate: bool,
                        gp_used: i32, fp_used: i32) abi.ParamSlot {
    val x: *SysVContext = ctx::*SysVContext;
    var slot: abi.ParamSlot;
    slot.size = size;

    # large aggregates: pass by reference (caller copies)
    if (is_aggregate && size > MAX_REG_AGGREGATE) {
        if (gp_used < GP_PARAM_COUNT) {
            slot.class = abi.CLASS_BYREF;
            slot.reg = x.gp_params[gp_used];
            ret slot;
        }
        slot.class = abi.CLASS_STACK;
        slot.offset = stack_offset(x, 8, 8);
        ret slot;
    }

    # 2-register aggregates (9-16 bytes): need 2 consecutive GP registers
    if (is_aggregate && size > 8 && gp_used + 1 < GP_PARAM_COUNT) {
        slot.class = abi.CLASS_GP2;
        slot.reg = x.gp_params[gp_used];
        slot.reg2 = x.gp_params[gp_used + 1];
        ret slot;
    }

    # floats and small float aggregates: use XMM registers
    if (is_float && !is_aggregate) {
        if (fp_used < FP_PARAM_COUNT) {
            slot.class = abi.CLASS_FP;
            slot.reg = x.fp_params[fp_used];
            ret slot;
        }
        slot.class = abi.CLASS_STACK;
        slot.offset = stack_offset(x, size, align);
        ret slot;
    }

    # integers, pointers, small aggregates: use GP registers
    if (gp_used < GP_PARAM_COUNT) {
        slot.class = abi.CLASS_GP;
        slot.reg = x.gp_params[gp_used];
        ret slot;
    }

    # out of registers: pass on the stack
    slot.class = abi.CLASS_STACK;
    slot.offset = stack_offset(x, size, align);
    ret slot;
}

fun sysv_classify_return(ctx: ptr, size: usize, align: usize,
                         is_float: bool, is_aggregate: bool) abi.ParamSlot {
    val x: *SysVContext = ctx::*SysVContext;
    var slot: abi.ParamSlot;
    slot.size = size;

    # large aggregates: return via hidden sret pointer
    if (is_aggregate && size > MAX_REG_AGGREGATE) {
        slot.class = abi.CLASS_SRET;
        slot.reg = x.gp_params[0]; # RDI holds the sret pointer
        ret slot;
    }

    # 2-register aggregates (9-16 bytes): return in RAX + RDX
    if (is_aggregate && size > 8) {
        slot.class = abi.CLASS_GP2;
        slot.reg = x.ret_rax;
        slot.reg2 = x.ret_rdx;
        ret slot;
    }

    # floats: return in XMM0
    if (is_float && !is_aggregate) {
        slot.class = abi.CLASS_FP;
        slot.reg = x.fp_params[0];
        ret slot;
    }

    # integers, pointers, small aggregates: return in RAX
    slot.class = abi.CLASS_GP;
    slot.reg = x.ret_rax;
    ret slot;
}

fun sysv_gp_param_regs(ctx: ptr) isa.RegisterFile {
    val x: *SysVContext = ctx::*SysVContext;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.gp_file;
}

fun sysv_fp_param_regs(ctx: ptr) isa.RegisterFile {
    val x: *SysVContext = ctx::*SysVContext;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.fp_file;
}

fun sysv_callee_saved(ctx: ptr) isa.RegisterFile {
    val x: *SysVContext = ctx::*SysVContext;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.callee_file;
}

fun sysv_stack_align(ctx: ptr) usize {
    ret STACK_ALIGNMENT;
}

fun sysv_red_zone(ctx: ptr) usize {
    ret RED_ZONE_SIZE;
}

fun sysv_variadic_info(ctx: ptr) abi.VariadicInfo {
    val x: *SysVContext = ctx::*SysVContext;
    var info: abi.VariadicInfo;
    info.needs_fp_count = true;
    info.fp_count_reg = x.var_al;
    ret info;
}

fun sysv_vararg_layout(ctx: ptr) abi.VarargLayout {
    var l: abi.VarargLayout;

    # register save area: 6 GP regs * 8 bytes = 48
    # (XMM saves not yet implemented -- FP va_arg falls back to stack)
    l.save_area_size = GP_PARAM_COUNT::usize * 8;
    l.save_area_align = STACK_ALIGNMENT;

    # va_list struct layout (SysV x86_64):
    #   offset 0:  u32 gp_offset
    #   offset 4:  u32 fp_offset
    #   offset 8:  ptr overflow_arg_area
    #   offset 16: ptr reg_save_area
    l.gp_offset_off = 0;
    l.gp_offset_size = 4;
    l.fp_offset_off = 4;
    l.fp_offset_size = 4;
    l.overflow_area_off = 8;
    l.reg_save_area_off = 16;

    # register slot sizes within save area
    l.gp_slot_size = 8;
    l.fp_slot_size = 16;
    l.fp_area_base = GP_PARAM_COUNT::i64 * 8;

    # stack args start at RBP+16 (saved RBP + return address)
    l.stack_args_base = 16;
    l.stack_slot_size = 8;

    # GP threshold: all GP register slots exhausted
    l.gp_threshold = GP_PARAM_COUNT::i64 * 8;
    l.gp_increment = 8;

    # va_list type: SysV x86_64 va_list is 24 bytes (4+4+8+8), aligned to 8
    l.va_list_size = 24;
    l.va_list_align = 8;

    ret l;
}

fun sysv_frame_header_size(ctx: ptr) i64 {
    # SysV x86_64: saved RBP (8) + return address (8) = 16
    ret 16;
}

# stack_offset: compute aligned stack offset and advance.
fun stack_offset(ctx: *SysVContext, size: usize, align: usize) i64 {
    var a: usize = align;
    if (a < 8) { a = 8; } # minimum 8-byte alignment on stack

    # align up
    val mask: i64 = a::i64 - 1;
    ctx.stack_off = (ctx.stack_off + mask) & ~mask;

    val off: i64 = ctx.stack_off;
    ctx.stack_off = ctx.stack_off + size::i64;
    ret off;
}
