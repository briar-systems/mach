use std.types.bool;
use std.types.size;
use std.types.string;

use allocator: std.allocator;
use section:   mach.compiler.target.of.section;
use msym:      masm.symbol;

# mach.compiler.target.isa: instruction set architecture interface.
# ---
# abstracts all ISA-specific operations behind function pointers.
# the ISA interface is opaque — the orchestrator never touches machine
# instruction internals. each backend defines its own instruction types
# and runs a complete pipeline from IR to section bytes.

pub def RegClass: u8;

pub val REG_GP:  RegClass = 0;
pub val REG_FP:  RegClass = 1;
pub val REG_VEC: RegClass = 2;

pub val ENDIAN_LITTLE: u8 = 0;
pub val ENDIAN_BIG:    u8 = 1;

pub rec Register {
    id:    i32;
    name:  str;
    class: RegClass;
    width: u8;
}

pub rec RegisterFile {
    regs:  *Register;
    count: i32;
}

# BackendResult: metrics returned by codegen_function.
# ---
# the orchestrator uses these for verbose logging without
# needing to inspect ISA-specific instruction types.
pub rec BackendResult {
    ok:          bool;
    ir_count:    i32;
    inst_count:  i32;
    spill_count: i32;
    frame_size:  usize;
    callee_mask: u32;
}

# ISA: instruction set architecture interface.
# ---
# function pointer record. each ISA implementation provides a
# constructor that populates all fields. the codegen_function
# entry point runs the complete backend pipeline for one function
# (ISel -> regalloc -> peephole -> frame -> fixup -> encode).
pub rec ISA {
    ctx:       ptr;
    name:      str;
    ptr_size:  usize;
    ptr_align: usize;
    endian:    u8;

    gp_regs: fun(ptr) RegisterFile;
    fp_regs: fun(ptr) RegisterFile;

    # physical frame pointer register ID.
    frame_reg: fun(ptr) i32;

    # registers that cannot be allocated (stack pointer, frame pointer).
    reserved_regs: fun(ptr) RegisterFile;

    # complete backend pipeline for one function.
    # args: (ctx, request_ptr) -> BackendResult.
    # request_ptr is *CodegenRequest (defined in codegen.mach).
    codegen_function: fun(ptr, ptr) BackendResult;

    # encode a NOP sequence of exactly `size` bytes.
    encode_nop: fun(ptr, i32, *section.Section,
                    *allocator.Allocator) i32;

    # size in bytes of a relocation for a given abstract relocation type.
    reloc_size: fun(ptr, msym.RelocKind) u8;

    # apply a resolved relocation.
    # ---
    # rtype:      abstract relocation kind
    # sym_addr:   resolved virtual address of the target symbol
    # reloc_addr: virtual address of the relocation site
    # addend:     relocation addend
    # dest:       pointer into section data at the relocation offset
    # ret:        bytes written (0 on error)
    resolve_reloc: fun(ptr, msym.RelocKind, u64, u64, i64, *u8) i32;

    # parse an ISA-specific inline asm block and produce IR instructions.
    # ---
    # buf_ptr is *InstructionBuffer[inst.Instruction] (from codegen/inst_buf.mach).
    # content[start..end] is the text inside the ISA's { } block.
    # alloc is for temporary allocations (e.g., label strings).
    lower_asm: fun(ptr, ptr, *allocator.Allocator, str, usize, usize);
}
