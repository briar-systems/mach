# mach.compiler.target.isa: instruction set architecture interface
#
# defines the machine-independent types for registers, operands, instructions,
# and instruction buffers. ISA backends populate the ISA function-pointer record
# to provide target-specific behavior.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use iobuf:     std.io.buffer;

pub val ISA_ASM_MARKER:  u16 = 0xFFFE;
pub val ISA_PCOPY:       u16 = 0xFFFD;
pub val ISA_PCOPY_FENCE: u16 = 0xFFFC;

pub rec AsmLocal {
    name:   str;
    offset: i32;
    size:   u8;
}

pub def OperandKind: u8;
pub val OPK_NONE:  OperandKind = 0;
pub val OPK_REG:   OperandKind = 1;
pub val OPK_IMM:   OperandKind = 2;
pub val OPK_MEM:   OperandKind = 3;
pub val OPK_LABEL: OperandKind = 4;
pub val OPK_SYM:   OperandKind = 5;

# a physical register
# ---
# id:   register number within its class
# size: width in bytes (1, 2, 4, 8)
pub rec Register {
    id:   i32;
    size: u8;
}

# a set of registers (e.g. all GP regs or all FP regs)
# ---
# regs:  array of registers
# count: number of registers in the set
pub rec RegisterFile {
    regs:  *Register;
    count: i32;
}

# a machine instruction operand
# ---
# kind:   OPK_* discriminator
# size:   operand width in bytes
# reg:    register id (OPK_REG)
# imm:    immediate value (OPK_IMM)
# base:   base register id (OPK_MEM)
# index:  index register id (OPK_MEM, -1 if none)
# scale:  index scale 1/2/4/8 (OPK_MEM)
# disp:   displacement (OPK_MEM)
# sym_id: symbol reference (OPK_SYM)
# label:  label name (OPK_LABEL)
pub rec Operand {
    kind:   OperandKind;
    size:   u8;
    reg:    i32;
    imm:    i64;
    base:   i32;
    index:  i32;
    scale:  u8;
    disp:   i32;
    sym_id: u32;
    label:  str;
}

# a machine instruction
# ---
# opcode:   target-specific opcode
# dst:      destination operand
# src1:     first source operand
# src2:     second source operand
# size:     operation width in bytes
# flags:    encoding flags (REX_W, 16BIT, LOCK, etc.)
# src_line: source line for debug info
# src_file: source file for debug info
pub rec Inst {
    opcode:   u16;
    dst:      Operand;
    src1:     Operand;
    src2:     Operand;
    size:     u8;
    flags:    u16;
    src_line: u32;
    src_file: str;
}

# growable buffer of machine instructions
# ---
# insts: array of instructions
# count: number of instructions in the buffer
# cap:   allocated capacity
# alloc: backing allocator
pub rec InstBuf {
    insts: *Inst;
    count: i32;
    cap:   i32;
    alloc: *allocator.Allocator;
}

# target ISA interface via function pointers
# ---
# ctx:       opaque backend state
# name:      ISA name ("x86_64", etc.)
# isel:      instruction selection callback
# encode:    instruction encoding callback
# reg_name:  register name lookup
# gp_regs:   return all general-purpose registers
# fp_regs:   return all floating-point registers
# ptr_size:  pointer size in bytes
# stack_dir: stack growth direction (-1 = downward)
pub rec ISA {
    ctx:            ptr;
    name:           str;
    isel:           fun(ptr, ptr, ptr, *InstBuf) bool;
    encode:         fun(ptr, *Inst, ptr, *allocator.Allocator) i32;
    parse_asm:      fun(ptr, str, *InstBuf, *allocator.Allocator) bool;
    emit_prologue:  fun(ptr, *InstBuf, usize);
    emit_epilogue:  fun(ptr, *InstBuf);
    is_ret:         fun(ptr, *Inst) bool;
    reloc_offset:   fun(ptr, *Inst, i32) i32;
    reg_name:       fun(ptr, i32, u8) str;
    gp_regs:        fun(ptr) RegisterFile;
    fp_regs:        fun(ptr) RegisterFile;
    print_inst:     fun(ptr, *Inst, *iobuf.WriteBuf);
    set_asm_locals: fun(*AsmLocal, i32);
    ptr_size:       u8;
    stack_dir:      i8;
}

val INSTBUF_INIT_CAP: i32 = 64;

# buf_init: initialize an instruction buffer
# ---
# alloc: backing allocator
# ret:   empty InstBuf
pub fun buf_init(alloc: *allocator.Allocator) InstBuf {
    var buf: InstBuf;
    buf.insts = nil;
    buf.count = 0;
    buf.cap   = 0;
    buf.alloc = alloc;
    ret buf;
}

# buf_append: append an instruction to the buffer, growing if needed
# ---
# buf:  instruction buffer
# inst: instruction to append
pub fun buf_append(buf: *InstBuf, inst: Inst) {
    if (buf.count >= buf.cap) {
        var new_cap: i32 = INSTBUF_INIT_CAP;
        if (buf.cap > 0) {
            new_cap = buf.cap * 2;
        }

        val res_realloc: Result[*Inst, str] = allocator.reallocate[Inst](
            buf.alloc, buf.insts, buf.cap::usize, new_cap::usize
        );
        if (is_err[*Inst, str](res_realloc)) { ret; }
        buf.insts = unwrap_ok[*Inst, str](res_realloc);
        buf.cap = new_cap;
    }

    buf.insts[buf.count] = inst;
    buf.count = buf.count + 1;
}

# buf_dnit: free the instruction buffer
# ---
# buf: buffer to destroy
pub fun buf_dnit(buf: *InstBuf) {
    if (buf == nil) { ret; }
    if (buf.insts != nil && buf.cap > 0) {
        allocator.deallocate[Inst](buf.alloc, buf.insts, buf.cap::usize);
        buf.insts = nil;
    }
    buf.count = 0;
    buf.cap   = 0;
}

# make_reg: create a register operand
# ---
# id:   register number
# size: width in bytes
# ret:  Operand with kind=OPK_REG
pub fun make_reg(id: i32, size: u8) Operand {
    var op: Operand;
    op.kind  = OPK_REG;
    op.size  = size;
    op.reg   = id;
    op.imm   = 0;
    op.base  = -1;
    op.index = -1;
    op.scale = 0;
    op.disp  = 0;
    op.sym_id = 0;
    op.label = nil;
    ret op;
}

# make_imm: create an immediate operand
# ---
# value: immediate value
# size:  width in bytes
# ret:   Operand with kind=OPK_IMM
pub fun make_imm(value: i64, size: u8) Operand {
    var op: Operand;
    op.kind  = OPK_IMM;
    op.size  = size;
    op.reg   = -1;
    op.imm   = value;
    op.base  = -1;
    op.index = -1;
    op.scale = 0;
    op.disp  = 0;
    op.sym_id = 0;
    op.label = nil;
    ret op;
}

# make_mem: create a memory operand
# ---
# base:  base register id
# disp:  displacement
# index: index register id (-1 if none)
# scale: index scale (1, 2, 4, or 8)
# size:  access width in bytes
# ret:   Operand with kind=OPK_MEM
pub fun make_mem(base: i32, disp: i32, index: i32, scale: u8, size: u8) Operand {
    var op: Operand;
    op.kind  = OPK_MEM;
    op.size  = size;
    op.reg   = -1;
    op.imm   = 0;
    op.base  = base;
    op.index = index;
    op.scale = scale;
    op.disp  = disp;
    op.sym_id = 0;
    op.label = nil;
    ret op;
}

# make_label: create a label operand
# ---
# name: label name
# ret:  Operand with kind=OPK_LABEL
pub fun make_label(name: str) Operand {
    var op: Operand;
    op.kind  = OPK_LABEL;
    op.size  = 0;
    op.reg   = -1;
    op.imm   = 0;
    op.base  = -1;
    op.index = -1;
    op.scale = 0;
    op.disp  = 0;
    op.sym_id = 0;
    op.label = name;
    ret op;
}
