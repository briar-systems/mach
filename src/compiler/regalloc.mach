# mach.compiler.regalloc: target-independent linear scan register allocation
#
# implements a linear scan allocator with live range splitting at call
# boundaries and eviction-based spilling. ranges that cross calls are split
# into sub-ranges so each can independently receive a register. spill slots
# are scoped and shared between non-overlapping ranges.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;

use mcfg: mach.compiler.mir.cfg;
use isa:      mach.compiler.target.isa;
use abi:      mach.compiler.target.abi;

val VREG_START:      i32 = 32;
val MAX_RANGES:      i32 = 8192;
val MAX_ACTIVE:      i32 = 128;
val MAX_CALLS:       i32 = 1024;
val MAX_SPILL_SLOTS: i32 = 512;
val MAX_FIXED:       i32 = 4096;
val REG_CLASS_GP:    u8  = 0;
val REG_CLASS_FP:    u8  = 1;

val MAX_FIXED_PER_REG: i32 = 2048;

rec FixedEntry {
    start: i32;
    end_p: i32;
}

rec FixedRegList {
    entries: *FixedEntry;
    count:   i32;
}

rec LiveRange {
    vreg:         i32;
    start:        i32;
    end_pos:      i32;
    use_count:    i32;
    size:         u8;
    reg_class:    u8;
    preg:         i32;
    spill_slot:   i32;
    spilled:      bool;
    hint:         i32;
    split_parent: i32;
    split_child:  i32;
    split_next:   i32;
}

rec SpillSlot {
    offset:    i64;
    size:      u8;
    range_ids: [16]i32;
    range_cnt: i32;
}

pub rec RegAllocResult {
    out:         isa.InstBuf;
    spill_size:  usize;
    callee_mask: u32;
    ok:          bool;
}

rec RegAllocState {
    alloc:       *allocator.Allocator;
    isa_ref:     *isa.ISA;
    abi_ref:     *abi.ABI;
    insts:       *isa.InstBuf;
    local_size:  usize;
    ranges:      *LiveRange;
    range_count: i32;
    calls:       *i32;
    call_count:  i32;
    fixed:       *FixedRegList;
    worklist:    *i32;
    wl_count:    i32;
    gp_active:   *i32;
    fp_active:   *i32;
    slots:       *SpillSlot;
    slot_count:  i32;
    spill_off:   usize;
    callee_mask: u32;
}

fun init_range() LiveRange {
    var r: LiveRange;
    r.vreg         = -1;
    r.start        = 0x7FFFFFFF;
    r.end_pos      = -1;
    r.use_count    = 0;
    r.size         = 8;
    r.reg_class    = REG_CLASS_GP;
    r.preg         = -1;
    r.spill_slot   = -1;
    r.spilled      = false;
    r.hint         = -1;
    r.split_parent = -1;
    r.split_child  = -1;
    r.split_next   = -1;
    ret r;
}

fun is_vreg(id: i32) bool { ret id >= VREG_START; }

fun is_reserved(i: *isa.ISA, preg: i32) bool {
    ret preg == i.stack_reg || preg == i.frame_reg;
}

fun is_callee_saved(a: *abi.ABI, preg: i32) bool {
    if (a == nil || a.callee_saved == nil) { ret false; }
    val cs: isa.RegisterFile = a.callee_saved(a.ctx);
    if (cs.regs == nil) { ret false; }
    var i: i32 = 0;
    for (i < cs.count) {
        if (cs.regs[i].id == preg) { ret true; }
        i = i + 1;
    }
    ret false;
}

fun classify_operand(isa_ref: *isa.ISA, inst: *isa.Inst) u8 {
    if (isa_ref.is_fp_opcode != nil && isa_ref.is_fp_opcode(inst.opcode)) {
        ret REG_CLASS_FP;
    }
    ret REG_CLASS_GP;
}

fun scan_operand_reg(op: *isa.Operand) i32 {
    if (op.kind == isa.OPK_REG) { ret op.reg; }
    ret -1;
}

fun map_fixed_vreg(i: *isa.ISA, id: i32) i32 {
    if (id == 30) { ret i.stack_reg; }
    if (id == 31) { ret i.frame_reg; }
    ret id;
}

fun align_up(value: usize, alignment: usize) usize {
    if (alignment == 0) { ret value; }
    ret (value + alignment - 1) & ~(alignment - 1);
}

fun add_fixed(state: *RegAllocState, preg: i32, pos: i32) {
    add_fixed_range(state, preg, pos, pos);
}

fun add_fixed_range(state: *RegAllocState, preg: i32, start: i32, end_p: i32) {
    val total_regs: i32 = state.isa_ref.gp_count + state.isa_ref.fp_count;
    if (preg < 0 || preg >= total_regs) { ret; }
    val list: *FixedRegList = ?state.fixed[preg];
    if (list.entries == nil || list.count >= MAX_FIXED_PER_REG) { ret; }
    list.entries[list.count].start = start;
    list.entries[list.count].end_p = end_p;
    list.count = list.count + 1;
}

fun preg_has_fixed_conflict(state: *RegAllocState, preg: i32, start: i32, end_p: i32) bool {
    val total_regs: i32 = state.isa_ref.gp_count + state.isa_ref.fp_count;
    if (preg < 0 || preg >= total_regs) { ret false; }
    val list: *FixedRegList = ?state.fixed[preg];
    if (list.entries == nil) { ret false; }
    var i: i32 = 0;
    for (i < list.count) {
        if (list.entries[i].start <= end_p && start <= list.entries[i].end_p) { ret true; }
        i = i + 1;
    }
    ret false;
}

fun ranges_overlap(ranges: *LiveRange, a: i32, b: i32) bool {
    if (a < 0 || b < 0) { ret false; }
    ret ranges[a].start <= ranges[b].end_pos && ranges[b].start <= ranges[a].end_pos;
}

fun find_range(ranges: *LiveRange, count: *i32, vreg: i32) *LiveRange {
    var i: i32 = 0;
    for (i < @count) {
        if (ranges[i].vreg == vreg) { ret ?ranges[i]; }
        i = i + 1;
    }
    if (@count >= MAX_RANGES) { ret nil; }
    val idx: i32 = @count;
    @count = @count + 1;
    ranges[idx] = init_range();
    ranges[idx].vreg = vreg;
    ret ?ranges[idx];
}

fun record_vreg(ranges: *LiveRange, count: *i32, vreg: i32, pos: i32, is_def: bool,
                size: u8, rc: u8, hint: i32) {
    val r: *LiveRange = find_range(ranges, count, vreg);
    if (r == nil) { ret; }
    if (pos < r.start) { r.start = pos; }
    if (pos > r.end_pos) { r.end_pos = pos; }
    r.use_count = r.use_count + 1;
    if (is_def) { r.size = size; r.reg_class = rc; }
    or { if (r.size == 0) { r.size = size; } }
    if (r.hint < 0 && hint >= 0) { r.hint = hint; }
}

fun record_phys_operand(state: *RegAllocState, op: *isa.Operand, pos: i32) {
    if (op.kind == isa.OPK_REG && op.reg >= 0 && !is_vreg(op.reg) && !is_reserved(state.isa_ref, op.reg)) {
        add_fixed(state, op.reg, pos);
    }
    if (op.kind == isa.OPK_MEM && op.base >= 0 && !is_vreg(op.base) && !is_reserved(state.isa_ref, op.base)) {
        add_fixed(state, op.base, pos);
    }
    if (op.kind == isa.OPK_MEM && op.index >= 0 && !is_vreg(op.index) && !is_reserved(state.isa_ref, op.index)) {
        add_fixed(state, op.index, pos);
    }
}

fun record_vreg_operand(state: *RegAllocState, op: *isa.Operand, pos: i32, is_def: bool,
                         rc: u8, hint: i32) {
    if (op.kind == isa.OPK_REG && is_vreg(op.reg)) {
        record_vreg(state.ranges, ?state.range_count, op.reg, pos, is_def, op.size, rc, hint);
    }
    if (op.kind == isa.OPK_MEM && is_vreg(op.base)) {
        record_vreg(state.ranges, ?state.range_count, op.base, pos, false, 8, 0, -1);
    }
    if (op.kind == isa.OPK_MEM && is_vreg(op.index)) {
        record_vreg(state.ranges, ?state.range_count, op.index, pos, false, 8, 0, -1);
    }
}

fun track_param_liveness(state: *RegAllocState, pos: i32, inst: *isa.Inst,
                         first_call_pos: i32) {
    if (first_call_pos >= 0 && pos >= first_call_pos) { ret; }
    val s1: i32 = scan_operand_reg(?inst.src1);
    if (s1 >= 0 && !is_vreg(s1) && !is_reserved(state.isa_ref, s1)) {
        val d: i32 = scan_operand_reg(?inst.dst);
        if (d >= 0 && is_vreg(d)) {
            add_fixed_range(state, s1, 0, pos);
        }
    }
}

fun track_phys_dst_liveness(state: *RegAllocState, pos: i32, inst: *isa.Inst) {
    val d: i32 = scan_operand_reg(?inst.dst);
    if (d < 0 || is_vreg(d) || is_reserved(state.isa_ref, d)) { ret; }
    val s1: i32 = scan_operand_reg(?inst.src1);
    if (s1 < 0 || !is_vreg(s1)) { ret; }
    var end_p: i32 = pos;
    var scan: i32 = pos + 1;
    for (scan < state.insts.count) {
        val mi: *isa.Inst = ?state.insts.insts[scan];
        val mi_s1: i32 = scan_operand_reg(?mi.src1);
        val mi_s2: i32 = scan_operand_reg(?mi.src2);
        val mi_dst: i32 = scan_operand_reg(?mi.dst);
        if (mi_s1 == d || mi_s2 == d
            || (mi.src1.kind == isa.OPK_MEM && mi.src1.base == d)
            || (mi.dst.kind == isa.OPK_MEM && mi.dst.base == d)) {
            end_p = scan;
        }
        if (mi_dst == d && mi.dst.kind == isa.OPK_REG) { scan = state.insts.count; }
        or { scan = scan + 1; }
    }
    if (end_p > pos) {
        add_fixed_range(state, d, pos, end_p);
    }
}

fun build_ranges(state: *RegAllocState) {
    var first_call_pos: i32 = -1;
    var scan: i32 = 0;
    for (scan < state.insts.count) {
        val si: *isa.Inst = ?state.insts.insts[scan];
        if (state.isa_ref.is_call != nil && state.isa_ref.is_call(state.isa_ref.ctx, si)) {
            first_call_pos = scan;
            scan = state.insts.count;
        }
        scan = scan + 1;
    }

    var pos: i32 = 0;
    for (pos < state.insts.count) {
        val inst: *isa.Inst = ?state.insts.insts[pos];

        if (inst.opcode == isa.ISA_PCOPY_FENCE) { pos = pos + 1; cnt; }

        if (inst.opcode == isa.ISA_PCOPY) {
            val s1: i32 = scan_operand_reg(?inst.src1);
            if (is_vreg(s1)) {
                var hint: i32 = -1;
                if (inst.dst.kind == isa.OPK_REG && !is_vreg(inst.dst.reg)) {
                    hint = inst.dst.reg;
                }
                record_vreg(state.ranges, ?state.range_count, s1, pos, false,
                            inst.src1.size, REG_CLASS_GP, hint);
            }
            record_phys_operand(state, ?inst.dst, pos);
            record_phys_operand(state, ?inst.src1, pos);
            pos = pos + 1;
            cnt;
        }

        if (state.isa_ref.is_call != nil && state.isa_ref.is_call(state.isa_ref.ctx, inst)) {
            if (state.call_count < MAX_CALLS) {
                state.calls[state.call_count] = pos;
                state.call_count = state.call_count + 1;
            }
            var ci: i32 = 0;
            for (ci < state.isa_ref.gp_count) {
                if (!is_reserved(state.isa_ref, ci) && !is_callee_saved(state.abi_ref, ci)) {
                    add_fixed(state, ci, pos);
                }
                ci = ci + 1;
            }
        }

        val rc: u8 = classify_operand(state.isa_ref, inst);

        track_param_liveness(state, pos, inst, first_call_pos);
        track_phys_dst_liveness(state, pos, inst);

        record_phys_operand(state, ?inst.dst, pos);
        record_phys_operand(state, ?inst.src1, pos);
        record_phys_operand(state, ?inst.src2, pos);

        var h: i32 = -1;
        val sh: i32 = scan_operand_reg(?inst.src1);
        if (sh >= 0 && !is_vreg(sh)) { h = sh; }

        record_vreg_operand(state, ?inst.dst, pos, true, rc, h);
        record_vreg_operand(state, ?inst.src1, pos, false, 0, -1);
        record_vreg_operand(state, ?inst.src2, pos, false, 0, -1);

        pos = pos + 1;
    }
}

fun split_range_at(state: *RegAllocState, ri: i32, split_pos: i32) i32 {
    if (state.range_count >= MAX_RANGES) { ret -1; }
    val new_ri: i32 = state.range_count;
    state.range_count = state.range_count + 1;
    state.ranges[new_ri] = init_range();

    val parent: *LiveRange = ?state.ranges[ri];
    val child: *LiveRange = ?state.ranges[new_ri];

    child.vreg      = parent.vreg;
    child.start     = split_pos;
    child.end_pos   = parent.end_pos;
    child.size      = parent.size;
    child.reg_class = parent.reg_class;
    child.hint      = parent.hint;

    child.split_parent = ri;
    child.split_next   = parent.split_child;
    parent.split_child = new_ri;

    parent.end_pos = split_pos - 1;

    var new_uses: i32 = 0;
    var old_uses: i32 = 0;
    var pi: i32 = 0;
    for (pi < state.insts.count) {
        val inst: *isa.Inst = ?state.insts.insts[pi];
        if (inst.opcode == isa.ISA_PCOPY_FENCE) { pi = pi + 1; cnt; }

        var touches: bool = false;
        if (scan_operand_reg(?inst.dst) == parent.vreg) { touches = true; }
        if (scan_operand_reg(?inst.src1) == parent.vreg) { touches = true; }
        if (scan_operand_reg(?inst.src2) == parent.vreg) { touches = true; }
        if (inst.dst.kind == isa.OPK_MEM && inst.dst.base == parent.vreg) { touches = true; }
        if (inst.src1.kind == isa.OPK_MEM && inst.src1.base == parent.vreg) { touches = true; }
        if (inst.src2.kind == isa.OPK_MEM && inst.src2.base == parent.vreg) { touches = true; }
        if (inst.dst.kind == isa.OPK_MEM && inst.dst.index == parent.vreg) { touches = true; }
        if (inst.src1.kind == isa.OPK_MEM && inst.src1.index == parent.vreg) { touches = true; }

        if (touches) {
            if (pi >= split_pos) { new_uses = new_uses + 1; }
            or { old_uses = old_uses + 1; }
        }
        pi = pi + 1;
    }
    child.use_count  = new_uses;
    parent.use_count = old_uses;

    ret new_ri;
}

fun split_at_calls(state: *RegAllocState) {
    val orig_count: i32 = state.range_count;
    var ri: i32 = 0;
    for (ri < orig_count) {
        val r: *LiveRange = ?state.ranges[ri];
        if (r.start >= r.end_pos) { ri = ri + 1; cnt; }

        var cur_ri: i32 = ri;
        var ci: i32 = 0;
        for (ci < state.call_count) {
            val cp: i32 = state.calls[ci];
            val cur: *LiveRange = ?state.ranges[cur_ri];
            if (cp > cur.start && cp < cur.end_pos) {
                val new_ri: i32 = split_range_at(state, cur_ri, cp + 1);
                if (new_ri < 0) { ci = state.call_count; }
                or { cur_ri = new_ri; }
            }
            ci = ci + 1;
        }
        ri = ri + 1;
    }
}

fun sort_worklist(state: *RegAllocState) {
    state.wl_count = state.range_count;
    var i: i32 = 0;
    for (i < state.range_count) {
        state.worklist[i] = i;
        i = i + 1;
    }
    var a: i32 = 1;
    for (a < state.wl_count) {
        val key: i32 = state.worklist[a];
        val key_start: i32 = state.ranges[key].start;
        var b: i32 = a - 1;
        for (b >= 0 && state.ranges[state.worklist[b]].start > key_start) {
            state.worklist[b + 1] = state.worklist[b];
            b = b - 1;
        }
        state.worklist[b + 1] = key;
        a = a + 1;
    }
}

fun spill_weight(r: *LiveRange) i64 {
    val span: i32 = r.end_pos - r.start + 1;
    if (span <= 0) { ret r.use_count::i64 * 1000; }
    ret (r.use_count::i64 * 1000) / span::i64;
}

fun is_preg_free(state: *RegAllocState, preg: i32, ri: i32) bool {
    val r: *LiveRange = ?state.ranges[ri];
    if (preg_has_fixed_conflict(state, preg, r.start, r.end_pos)) { ret false; }
    var si: i32 = 0;
    for (si < state.range_count) {
        if (si != ri && state.ranges[si].preg == preg && !state.ranges[si].spilled
            && ranges_overlap(state.ranges, si, ri)) {
            ret false;
        }
        si = si + 1;
    }
    ret true;
}

fun try_alloc_free(state: *RegAllocState, ri: i32) i32 {
    val r: *LiveRange = ?state.ranges[ri];
    var count: i32 = state.isa_ref.gp_count;
    if (r.reg_class == REG_CLASS_FP) {
        count = state.isa_ref.fp_count;
    }

    # hints disabled — they cause identity PCOPY copies where the hinted
    # register gets reused by a non-overlapping vreg, destroying the value
    # before the PCOPY resolver sees it as a no-op.

    var pi: i32 = 0;
    for (pi < count) {
        if (r.reg_class == REG_CLASS_GP && is_reserved(state.isa_ref, pi)) { pi = pi + 1; cnt; }
        if (r.reg_class == REG_CLASS_GP && is_callee_saved(state.abi_ref, pi)) { pi = pi + 1; cnt; }
        if (is_preg_free(state, pi, ri)) { ret pi; }
        pi = pi + 1;
    }

    pi = 0;
    for (pi < count) {
        if (r.reg_class == REG_CLASS_GP && is_reserved(state.isa_ref, pi)) { pi = pi + 1; cnt; }
        if (is_preg_free(state, pi, ri)) { ret pi; }
        pi = pi + 1;
    }

    ret -1;
}

fun assign_reg(state: *RegAllocState, ri: i32, preg: i32) {
    state.ranges[ri].preg = preg;
    if (state.ranges[ri].reg_class == REG_CLASS_GP) {
        state.gp_active[preg] = ri;
    } or {
        state.fp_active[preg] = ri;
    }
    if (is_callee_saved(state.abi_ref, preg)) {
        state.callee_mask = state.callee_mask | (1 << preg::u32);
    }
}

fun try_evict(state: *RegAllocState, ri: i32) bool {
    val r: *LiveRange = ?state.ranges[ri];
    var count: i32 = state.isa_ref.gp_count;
    var active: *i32 = state.gp_active;
    if (r.reg_class == REG_CLASS_FP) {
        count = state.isa_ref.fp_count;
        active = state.fp_active;
    }

    val our_weight: i64 = spill_weight(r);
    var best_preg: i32 = -1;
    var best_weight: i64 = our_weight;
    var best_ri: i32 = -1;

    var pi: i32 = 0;
    for (pi < count) {
        if (r.reg_class == REG_CLASS_GP && is_reserved(state.isa_ref, pi)) { pi = pi + 1; cnt; }
        if (preg_has_fixed_conflict(state, pi, r.start, r.end_pos)) { pi = pi + 1; cnt; }
        val occ: i32 = active[pi];
        if (occ < 0) { pi = pi + 1; cnt; }
        if (!ranges_overlap(state.ranges, occ, ri)) { pi = pi + 1; cnt; }
        val occ_weight: i64 = spill_weight(?state.ranges[occ]);
        if (occ_weight < best_weight) {
            best_weight = occ_weight;
            best_preg = pi;
            best_ri = occ;
        }
        pi = pi + 1;
    }

    if (best_preg < 0) { ret false; }

    state.ranges[best_ri].preg = -1;
    active[best_preg] = -1;

    assign_spill(state, best_ri);

    assign_reg(state, ri, best_preg);
    ret true;
}

fun get_spill_offset(state: *RegAllocState, ri: i32) i64 {
    val slot_idx: i32 = state.ranges[ri].spill_slot;
    if (slot_idx < 0 || slot_idx >= state.slot_count) { ret 0; }
    ret state.slots[slot_idx].offset;
}

fun assign_spill(state: *RegAllocState, ri: i32) {
    state.ranges[ri].spilled = true;

    if (state.ranges[ri].split_parent >= 0) {
        val parent_slot: i32 = state.ranges[state.ranges[ri].split_parent].spill_slot;
        if (parent_slot >= 0) {
            state.ranges[ri].spill_slot = parent_slot;
            if (state.slots[parent_slot].range_cnt < 16) {
                state.slots[parent_slot].range_ids[state.slots[parent_slot].range_cnt] = ri;
                state.slots[parent_slot].range_cnt = state.slots[parent_slot].range_cnt + 1;
            }
            ret;
        }
    }

    var si: i32 = 0;
    for (si < state.slot_count) {
        if (state.slots[si].size >= state.ranges[ri].size) {
            var ok: bool = true;
            var k: i32 = 0;
            for (k < state.slots[si].range_cnt) {
                if (ranges_overlap(state.ranges, state.slots[si].range_ids[k], ri)) {
                    ok = false;
                    k = state.slots[si].range_cnt;
                }
                k = k + 1;
            }
            if (ok && state.slots[si].range_cnt < 16) {
                state.ranges[ri].spill_slot = si;
                state.slots[si].range_ids[state.slots[si].range_cnt] = ri;
                state.slots[si].range_cnt = state.slots[si].range_cnt + 1;
                ret;
            }
        }
        si = si + 1;
    }

    if (state.slot_count >= MAX_SPILL_SLOTS) {
        state.ranges[ri].spill_slot = 0;
        ret;
    }

    var slot_sz: usize = state.ranges[ri].size::usize;
    if (slot_sz < 8) { slot_sz = 8; }
    state.spill_off = align_up(state.spill_off + slot_sz, 8);

    val new_si: i32 = state.slot_count;
    state.slot_count = state.slot_count + 1;
    state.slots[new_si].offset = state.spill_off::i64;
    state.slots[new_si].size = state.ranges[ri].size;
    state.slots[new_si].range_ids[0] = ri;
    state.slots[new_si].range_cnt = 1;
    state.ranges[ri].spill_slot = new_si;
}

fun ensure_split_slot(state: *RegAllocState, ri: i32) i32 {
    if (state.ranges[ri].spill_slot >= 0) { ret state.ranges[ri].spill_slot; }

    var root: i32 = ri;
    if (state.ranges[ri].split_parent >= 0) { root = state.ranges[ri].split_parent; }
    if (state.ranges[root].spill_slot >= 0) {
        state.ranges[ri].spill_slot = state.ranges[root].spill_slot;
        ret state.ranges[ri].spill_slot;
    }

    if (state.slot_count >= MAX_SPILL_SLOTS) { ret -1; }

    var slot_sz: usize = state.ranges[ri].size::usize;
    if (slot_sz < 8) { slot_sz = 8; }
    state.spill_off = align_up(state.spill_off + slot_sz, 8);

    val new_si: i32 = state.slot_count;
    state.slot_count = state.slot_count + 1;
    state.slots[new_si].offset = state.spill_off::i64;
    state.slots[new_si].size = state.ranges[ri].size;
    state.slots[new_si].range_ids[0] = ri;
    state.slots[new_si].range_cnt = 1;
    state.ranges[ri].spill_slot = new_si;
    state.ranges[root].spill_slot = new_si;
    ret new_si;
}

fun allocate_ranges(state: *RegAllocState) {
    var wi: i32 = 0;
    for (wi < state.wl_count) {
        val ri: i32 = state.worklist[wi];
        if (state.ranges[ri].preg >= 0 || state.ranges[ri].spilled) {
            wi = wi + 1;
            cnt;
        }
        if (state.ranges[ri].start > state.ranges[ri].end_pos) {
            wi = wi + 1;
            cnt;
        }

        val preg: i32 = try_alloc_free(state, ri);
        if (preg >= 0) {
            assign_reg(state, ri, preg);
            wi = wi + 1;
            cnt;
        }

        if (try_evict(state, ri)) {
            wi = wi + 1;
            cnt;
        }

        assign_spill(state, ri);
        wi = wi + 1;
    }
}

fun is_call_at(state: *RegAllocState, pos: i32) bool {
    var i: i32 = 0;
    for (i < state.call_count) {
        if (state.calls[i] == pos) { ret true; }
        i = i + 1;
    }
    ret false;
}

fun find_split_sibling(state: *RegAllocState, ri: i32, after_pos: i32) i32 {
    val vreg: i32 = state.ranges[ri].vreg;
    var si: i32 = 0;
    for (si < state.range_count) {
        if (si != ri && state.ranges[si].vreg == vreg && state.ranges[si].start == after_pos) {
            ret si;
        }
        si = si + 1;
    }
    ret -1;
}

fun emit_mi_store(state: *RegAllocState, out: *isa.InstBuf, preg: i32, slot_off: i64,
                  size: u8, line: u32, file: str) {
    var mi: isa.Inst;
    mi.opcode   = state.isa_ref.store_opcode;
    mi.dst      = isa.make_mem(state.isa_ref.frame_reg, -(slot_off::i32), -1, 0, size);
    mi.src1     = isa.make_reg(preg, size);
    mi.src2     = isa.make_reg(-1, 0);
    mi.size     = size;
    mi.flags    = state.isa_ref.rex_w_flag;
    mi.src_line = line;
    mi.src_file = file;
    isa.buf_append(out, mi);
}

fun emit_mi_load(state: *RegAllocState, out: *isa.InstBuf, preg: i32, slot_off: i64,
                 size: u8, line: u32, file: str) {
    var mi: isa.Inst;
    mi.opcode   = state.isa_ref.load_opcode;
    mi.dst      = isa.make_reg(preg, size);
    mi.src1     = isa.make_mem(state.isa_ref.frame_reg, -(slot_off::i32), -1, 0, size);
    mi.src2     = isa.make_reg(-1, 0);
    mi.size     = size;
    mi.flags    = state.isa_ref.rex_w_flag;
    mi.src_line = line;
    mi.src_file = file;
    isa.buf_append(out, mi);
}

fun emit_split_stores(state: *RegAllocState, out: *isa.InstBuf, call_pos: i32,
                      line: u32, file: str) {
    var ri: i32 = 0;
    for (ri < state.range_count) {
        val r: *LiveRange = ?state.ranges[ri];
        if (r.end_pos == call_pos && r.preg >= 0 && !r.spilled
            && (r.split_child >= 0 || r.split_next >= 0)) {
            val slot_idx: i32 = ensure_split_slot(state, ri);
            if (slot_idx >= 0) {
                val off: i64 = state.slots[slot_idx].offset;
                emit_mi_store(state, out, r.preg, off, 8, line, file);
            }
        }
        ri = ri + 1;
    }
}

fun emit_split_loads(state: *RegAllocState, out: *isa.InstBuf, call_pos: i32,
                     line: u32, file: str) {
    var ri: i32 = 0;
    for (ri < state.range_count) {
        val r: *LiveRange = ?state.ranges[ri];
        if (r.start == call_pos + 1 && r.preg >= 0 && !r.spilled && r.split_parent >= 0) {
            val slot_idx: i32 = ensure_split_slot(state, ri);
            if (slot_idx >= 0) {
                val off: i64 = state.slots[slot_idx].offset;
                emit_mi_load(state, out, r.preg, off, 8, line, file);
            }
        }
        ri = ri + 1;
    }
}

fun resolve_vreg_at(state: *RegAllocState, vreg: i32, pos: i32) i32 {
    var best_ri: i32 = -1;
    var best_span: i32 = 0x7FFFFFFF;
    var ri: i32 = 0;
    for (ri < state.range_count) {
        if (state.ranges[ri].vreg == vreg && state.ranges[ri].preg >= 0
            && !state.ranges[ri].spilled
            && pos >= state.ranges[ri].start && pos <= state.ranges[ri].end_pos) {
            val span: i32 = state.ranges[ri].end_pos - state.ranges[ri].start;
            if (span < best_span) {
                best_span = span;
                best_ri = ri;
            }
        }
        ri = ri + 1;
    }
    if (best_ri >= 0) { ret state.ranges[best_ri].preg; }
    ret vreg;
}

fun resolve_vreg_at_any(state: *RegAllocState, vreg: i32, pos: i32) i32 {
    var best_ri: i32 = -1;
    var best_span: i32 = 0x7FFFFFFF;
    var ri: i32 = 0;
    for (ri < state.range_count) {
        if (state.ranges[ri].vreg == vreg
            && pos >= state.ranges[ri].start && pos <= state.ranges[ri].end_pos) {
            val span: i32 = state.ranges[ri].end_pos - state.ranges[ri].start;
            if (span < best_span) {
                best_span = span;
                best_ri = ri;
            }
        }
        ri = ri + 1;
    }
    if (best_ri >= 0) {
        if (state.ranges[best_ri].preg >= 0 && !state.ranges[best_ri].spilled) {
            ret state.ranges[best_ri].preg;
        }
    }
    ret vreg;
}

fun rewrite_operand_reg(state: *RegAllocState, op: *isa.Operand, pos: i32) {
    if (op.kind == isa.OPK_REG) {
        op.reg = map_fixed_vreg(state.isa_ref, op.reg);
    }
    if (op.kind == isa.OPK_MEM) {
        op.base = map_fixed_vreg(state.isa_ref, op.base);
        op.index = map_fixed_vreg(state.isa_ref, op.index);
    }
    if (op.kind == isa.OPK_REG && is_vreg(op.reg)) {
        op.reg = resolve_vreg_at(state, op.reg, pos);
    }
    if (op.kind == isa.OPK_MEM && is_vreg(op.base)) {
        op.base = resolve_vreg_at(state, op.base, pos);
    }
    if (op.kind == isa.OPK_MEM && is_vreg(op.index)) {
        op.index = resolve_vreg_at(state, op.index, pos);
    }
}

fun find_spill_for_vreg(state: *RegAllocState, vreg: i32, pos: i32) i32 {
    var ri: i32 = 0;
    for (ri < state.range_count) {
        if (state.ranges[ri].vreg == vreg && state.ranges[ri].spilled
            && pos >= state.ranges[ri].start && pos <= state.ranges[ri].end_pos) {
            ret ri;
        }
        ri = ri + 1;
    }
    ret -1;
}

fun find_any_range_for_vreg(state: *RegAllocState, vreg: i32, pos: i32) i32 {
    var best: i32 = -1;
    var best_span: i32 = 0x7FFFFFFF;
    var ri: i32 = 0;
    for (ri < state.range_count) {
        if (state.ranges[ri].vreg == vreg
            && pos >= state.ranges[ri].start && pos <= state.ranges[ri].end_pos) {
            val span: i32 = state.ranges[ri].end_pos - state.ranges[ri].start;
            if (span < best_span) {
                best_span = span;
                best = ri;
            }
        }
        ri = ri + 1;
    }
    ret best;
}

fun rewrite_instructions(state: *RegAllocState) isa.InstBuf {
    var out: isa.InstBuf = isa.buf_init(state.alloc);

    var pos: i32 = 0;
    for (pos < state.insts.count) {
        var inst: isa.Inst = state.insts.insts[pos];

        if (inst.opcode == isa.ISA_PCOPY_FENCE) {
            isa.buf_append(?out, inst);
            pos = pos + 1;
            cnt;
        }

        val at_call: bool = is_call_at(state, pos);

        var has_spill_dst: bool = false;
        var spill_dst_off: i64 = 0;
        var spill_dst_size: u8 = 8;
        var has_spill_s1: bool = false;
        var spill_s1_off: i64 = 0;
        var spill_s1_size: u8 = 8;
        var has_spill_s2: bool = false;
        var spill_s2_off: i64 = 0;
        var spill_s2_size: u8 = 8;

        if (inst.dst.kind == isa.OPK_REG && is_vreg(inst.dst.reg)) {
            val sri: i32 = find_spill_for_vreg(state, inst.dst.reg, pos);
            if (sri >= 0) {
                has_spill_dst = true;
                spill_dst_off = get_spill_offset(state, sri);
                spill_dst_size = state.ranges[sri].size;
            }
        }
        if (inst.src1.kind == isa.OPK_REG && is_vreg(inst.src1.reg)) {
            val sri: i32 = find_spill_for_vreg(state, inst.src1.reg, pos);
            if (sri >= 0) {
                has_spill_s1 = true;
                spill_s1_off = get_spill_offset(state, sri);
                spill_s1_size = state.ranges[sri].size;
            }
        }
        if (inst.src2.kind == isa.OPK_REG && is_vreg(inst.src2.reg)) {
            val sri: i32 = find_spill_for_vreg(state, inst.src2.reg, pos);
            if (sri >= 0) {
                has_spill_s2 = true;
                spill_s2_off = get_spill_offset(state, sri);
                spill_s2_size = state.ranges[sri].size;
            }
        }

        if (inst.src1.kind == isa.OPK_MEM && is_vreg(inst.src1.base)) {
            val sri: i32 = find_spill_for_vreg(state, inst.src1.base, pos);
            if (sri >= 0) {
                val off: i64 = get_spill_offset(state, sri);
                emit_mi_load(state, ?out, state.isa_ref.scratch_reg2, off, 8,
                             inst.src_line, inst.src_file);
                inst.src1.base = state.isa_ref.scratch_reg2;
            }
        }

        if (has_spill_s1) {
            emit_mi_load(state, ?out, state.isa_ref.scratch_reg2, spill_s1_off, spill_s1_size,
                         inst.src_line, inst.src_file);
            inst.src1 = isa.make_reg(state.isa_ref.scratch_reg2, spill_s1_size);
        }
        if (has_spill_s2) {
            emit_mi_load(state, ?out, state.isa_ref.scratch_reg, spill_s2_off, spill_s2_size,
                         inst.src_line, inst.src_file);
            inst.src2 = isa.make_reg(state.isa_ref.scratch_reg, spill_s2_size);
        }

        if (has_spill_dst) {
            inst.dst = isa.make_reg(state.isa_ref.scratch_reg2, spill_dst_size);
        }

        rewrite_operand_reg(state, ?inst.dst, pos);
        rewrite_operand_reg(state, ?inst.src1, pos);
        rewrite_operand_reg(state, ?inst.src2, pos);
        isa.buf_append(?out, inst);

        if (has_spill_dst) {
            emit_mi_store(state, ?out, state.isa_ref.scratch_reg2, spill_dst_off, spill_dst_size,
                          inst.src_line, inst.src_file);
        }


        pos = pos + 1;
    }

    ret out;
}

pub fun alloc_function(alloc: *allocator.Allocator, i: *isa.ISA, a: *abi.ABI,
                       insts: *isa.InstBuf, local_size: usize,
                       cfg: *mcfg.CFG, live: *mcfg.LiveSets) RegAllocResult {
    var result: RegAllocResult;
    result.spill_size  = 0;
    result.callee_mask = 0;
    result.ok          = false;

    if (insts == nil || insts.count == 0) {
        result.out = isa.buf_init(alloc);
        result.ok  = true;
        ret result;
    }

    val res_ranges: Result[*LiveRange, str] = allocator.allocate[LiveRange](alloc, MAX_RANGES::usize);
    if (is_err[*LiveRange, str](res_ranges)) {
        result.out = isa.buf_init(alloc);
        ret result;
    }
    val res_calls: Result[*i32, str] = allocator.allocate[i32](alloc, MAX_CALLS::usize);
    if (is_err[*i32, str](res_calls)) {
        allocator.deallocate[LiveRange](alloc, unwrap_ok[*LiveRange, str](res_ranges), MAX_RANGES::usize);
        result.out = isa.buf_init(alloc);
        ret result;
    }
    val res_wl: Result[*i32, str] = allocator.allocate[i32](alloc, MAX_RANGES::usize);
    if (is_err[*i32, str](res_wl)) {
        allocator.deallocate[LiveRange](alloc, unwrap_ok[*LiveRange, str](res_ranges), MAX_RANGES::usize);
        allocator.deallocate[i32](alloc, unwrap_ok[*i32, str](res_calls), MAX_CALLS::usize);
        result.out = isa.buf_init(alloc);
        ret result;
    }
    val res_gp: Result[*i32, str] = allocator.allocate[i32](alloc, i.gp_count::usize);
    val res_fp: Result[*i32, str] = allocator.allocate[i32](alloc, i.fp_count::usize);
    if (is_err[*i32, str](res_gp) || is_err[*i32, str](res_fp)) {
        result.out = isa.buf_init(alloc);
        ret result;
    }
    val res_slots: Result[*SpillSlot, str] = allocator.allocate[SpillSlot](alloc, MAX_SPILL_SLOTS::usize);
    if (is_err[*SpillSlot, str](res_slots)) {
        result.out = isa.buf_init(alloc);
        ret result;
    }
    val total_regs: i32 = i.gp_count + i.fp_count;
    val res_fixed: Result[*FixedRegList, str] = allocator.allocate[FixedRegList](alloc, total_regs::usize);
    if (is_err[*FixedRegList, str](res_fixed)) {
        result.out = isa.buf_init(alloc);
        ret result;
    }

    var state: RegAllocState;
    state.alloc       = alloc;
    state.isa_ref     = i;
    state.abi_ref     = a;
    state.insts       = insts;
    state.local_size  = local_size;
    state.ranges      = unwrap_ok[*LiveRange, str](res_ranges);
    state.range_count = 0;
    state.calls       = unwrap_ok[*i32, str](res_calls);
    state.call_count  = 0;
    state.fixed = unwrap_ok[*FixedRegList, str](res_fixed);
    var fri: i32 = 0;
    for (fri < total_regs) {
        state.fixed[fri].count = 0;
        val rp: Result[*FixedEntry, str] = allocator.allocate[FixedEntry](alloc, MAX_FIXED_PER_REG::usize);
        if (is_ok[*FixedEntry, str](rp)) {
            state.fixed[fri].entries = unwrap_ok[*FixedEntry, str](rp);
        } or {
            state.fixed[fri].entries = nil;
        }
        fri = fri + 1;
    }
    state.worklist    = unwrap_ok[*i32, str](res_wl);
    state.wl_count    = 0;
    state.gp_active   = unwrap_ok[*i32, str](res_gp);
    state.fp_active   = unwrap_ok[*i32, str](res_fp);
    state.slots       = unwrap_ok[*SpillSlot, str](res_slots);
    state.slot_count  = 0;
    state.spill_off   = local_size;
    state.callee_mask = 0;

    var gi: i32 = 0;
    for (gi < i.gp_count) { state.gp_active[gi] = -1; gi = gi + 1; }
    var fi: i32 = 0;
    for (fi < i.fp_count) { state.fp_active[fi] = -1; fi = fi + 1; }

    build_ranges(?state);

    if (state.range_count == 0) {
        var out: isa.InstBuf = isa.buf_init(alloc);
        var ci: i32 = 0;
        for (ci < insts.count) {
            isa.buf_append(?out, insts.insts[ci]);
            ci = ci + 1;
        }
        result.out = out;
        result.ok  = true;
        ret result;
    }

    # split_at_calls disabled — requires basic block awareness to avoid
    # splitting at calls in unreachable branches. Instead, call-crossing
    # ranges are forced to callee-saved registers or spilled.
    sort_worklist(?state);
    allocate_ranges(?state);

    val out: isa.InstBuf = rewrite_instructions(?state);

    result.out         = out;
    result.spill_size  = align_up(state.spill_off - local_size, 16);
    result.callee_mask = state.callee_mask;
    result.ok          = true;

    val total_regs2: i32 = i.gp_count + i.fp_count;
    var dri: i32 = 0;
    for (dri < total_regs2) {
        if (state.fixed[dri].entries != nil) {
            allocator.deallocate[FixedEntry](alloc, state.fixed[dri].entries, MAX_FIXED_PER_REG::usize);
        }
        dri = dri + 1;
    }
    allocator.deallocate[FixedRegList](alloc, state.fixed, total_regs2::usize);
    allocator.deallocate[SpillSlot](alloc, state.slots, MAX_SPILL_SLOTS::usize);
    allocator.deallocate[i32](alloc, state.fp_active, i.fp_count::usize);
    allocator.deallocate[i32](alloc, state.gp_active, i.gp_count::usize);
    allocator.deallocate[i32](alloc, state.worklist, MAX_RANGES::usize);
    allocator.deallocate[i32](alloc, state.calls, MAX_CALLS::usize);
    allocator.deallocate[LiveRange](alloc, state.ranges, MAX_RANGES::usize);

    ret result;
}
