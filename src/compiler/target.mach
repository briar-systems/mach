## Initialize the $feature namespace with all feature descriptors.
fun init_feature_namespace() feature {
    var ns: feature;
    ns.soft_float       = feature_info(FEATURE_SOFT_FLOAT);
    ns.hard_float       = feature_info(FEATURE_HARD_FLOAT);
    ns.simd             = feature_info(FEATURE_SIMD);
    ns.unaligned_memory = feature_info(FEATURE_UNALIGNED_MEMORY);
    ns.atomics_64       = feature_info(FEATURE_ATOMICS_64);
    ns.atomics_128      = feature_info(FEATURE_ATOMICS_128);
    ns.threads          = feature_info(FEATURE_THREADS);
    ns.mmu              = feature_info(FEATURE_MMU);
    ns.cache            = feature_info(FEATURE_CACHE);
    ns.vector_ext       = feature_info(FEATURE_VECTOR_EXT);
    ret ns;
}

## Contains all target-specific information.
pub rec Target {
    triple:              str;
    cpu:                 str;
    arch:                ArchitectureInfo;
    os:                  OSInfo;
    abi:                 ABIInfo;
    vendor:              VendorInfo;
    environment:         EnvironmentInfo;
    object_format:       ObjectFormatInfo;
    endianness:          EndiannessInfo;
    pointer_width:       u8;
    address_width:       u8;
    page_size:           u32;
    default_alignment:   u8;
    max_alignment:       u8;
    default_backend:     BackendKindInfo;
    supported_backends:  Option[List[BackendKind]];
    features:            FeatureSet;
}

pub fun target_unknown() Target {
    var target: Target;
    target.triple              = "unknown-unknown-unknown";
    target.cpu                 = "generic";
    target.arch                = arch_info(ARCHITECTURE_UNKNOWN);
    target.os                  = os_info(OS_UNKNOWN);
    target.abi                 = abi_info(ABI_UNKNOWN);
    target.vendor              = vendor_info(VENDOR_UNKNOWN);
    target.environment         = environment_info(ENVIRONMENT_UNKNOWN);
    target.object_format       = object_format_info(OBJECT_FORMAT_UNKNOWN);
    target.endianness          = endianness_info(ENDIANNESS_UNKNOWN);
    target.pointer_width       = 0;
    target.address_width       = 0;
    target.page_size           = 0;
    target.default_alignment   = 1;
    target.max_alignment       = 1;
    target.default_backend     = backend_kind_info(BACKEND_KIND_UNKNOWN);
    target.supported_backends  = none[List[BackendKind]]();
    target.features            = 0;

    ret target;
}

## Check if a feature is enabled for this target.
pub fun (this: Target) has_feature(flag: Feature) bool {
    ret this.features.has(flag);
}
