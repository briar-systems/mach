## Create an ArchitectureInfo descriptor for the given architecture.
pub fun arch_info(arch: Architecture) ArchitectureInfo {
    var info: ArchitectureInfo;
    info.id          = arch;
    info.name        = arch.to_str();
    info.word_size   = 0;
    info.is_64bit    = false;
    info.is_embedded = false;
    info.has_fpu     = false;

    if (arch == ARCHITECTURE_X86_64 || arch == ARCHITECTURE_AARCH64 || arch == ARCHITECTURE_RISCV64 || arch == ARCHITECTURE_WASM64) {
        info.word_size = 8;
        info.is_64bit  = true;
        info.has_fpu   = true;
    }
    or (arch == ARCHITECTURE_X86 || arch == ARCHITECTURE_ARM || arch == ARCHITECTURE_RISCV32 || arch == ARCHITECTURE_WASM32) {
        info.word_size = 4;
        info.has_fpu   = true;
    }
    or (arch == ARCHITECTURE_THUMB || arch == ARCHITECTURE_THUMBV6M || arch == ARCHITECTURE_THUMBV7M || arch == ARCHITECTURE_THUMBV7EM) {
        info.word_size   = 4;
        info.is_embedded = true;
        if (arch == ARCHITECTURE_THUMBV7EM) {
            info.has_fpu = true;
        }
    }
    or (arch == ARCHITECTURE_AVR) {
        info.word_size   = 2;
        info.is_embedded = true;
    }
    or (arch == ARCHITECTURE_MSP430) {
        info.word_size   = 2;
        info.is_embedded = true;
    }

    ret info;
}

## Create an OSInfo descriptor for the given OS.
pub fun os_info(os: OS) OSInfo {
    var info: OSInfo;
    info.id                  = os;
    info.name                = os.to_str();
    info.supports_filesystem = false;
    info.supports_networking = false;
    info.supports_threads    = false;
    info.has_mmu             = false;
    info.is_freestanding     = false;

    if (os == OS_LINUX || os == OS_DARWIN || os == OS_WINDOWS) {
        info.supports_filesystem = true;
        info.supports_networking = true;
        info.supports_threads    = true;
        info.has_mmu             = true;
    }
    or (os == OS_WASI) {
        info.supports_filesystem = true;
    }
    or (os == OS_FREESTANDING || os == OS_NONE) {
        info.is_freestanding = true;
    }
    or (os == OS_ZEPHYR) {
        info.supports_filesystem = true;
        info.supports_threads    = true;
    }

    ret info;
}

## Create an ABIInfo descriptor for the given ABI.
pub fun abi_info(abi: ABI) ABIInfo {
    var info: ABIInfo;
    info.id            = abi;
    info.name          = abi.to_str();
    info.requires_libc = false;

    if (abi == ABI_GNU || abi == ABI_MUSL || abi == ABI_NEWLIB || abi == ABI_MSVC) {
        info.requires_libc = true;
    }

    ret info;
}

