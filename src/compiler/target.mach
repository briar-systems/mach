    var ns: abi;
    ns.gnu     = abi_info(ABI_GNU);
    ns.msvc    = abi_info(ABI_MSVC);
    ns.musl    = abi_info(ABI_MUSL);
    ns.newlib  = abi_info(ABI_NEWLIB);
    ns.bare    = abi_info(ABI_BARE);
    ns.wasi    = abi_info(ABI_WASI);
    ret ns;
}

