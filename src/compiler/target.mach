use std.types.bool;
use std.types.option;
use std.collections.list;

pub def Architecture: u8;

pub val ARCHITECTURE_UNKNOWN:   Architecture = $iota();
pub val ARCHITECTURE_X86:       Architecture = $iota();
pub val ARCHITECTURE_X86_64:    Architecture = $iota();
pub val ARCHITECTURE_ARM:       Architecture = $iota();
pub val ARCHITECTURE_AARCH64:   Architecture = $iota();
pub val ARCHITECTURE_THUMB:     Architecture = $iota();
pub val ARCHITECTURE_THUMBV6M:  Architecture = $iota();
pub val ARCHITECTURE_THUMBV7M:  Architecture = $iota();
pub val ARCHITECTURE_THUMBV7EM: Architecture = $iota();
pub val ARCHITECTURE_RISCV32:   Architecture = $iota();
pub val ARCHITECTURE_RISCV64:   Architecture = $iota();
pub val ARCHITECTURE_AVR:       Architecture = $iota();
pub val ARCHITECTURE_MSP430:    Architecture = $iota();
pub val ARCHITECTURE_WASM32:    Architecture = $iota();
pub val ARCHITECTURE_WASM64:    Architecture = $iota();

pub fun (this: Architecture) to_str() str {
    if (this == ARCHITECTURE_X86)       { ret "x86"; }
    if (this == ARCHITECTURE_X86_64)    { ret "x86_64"; }
    if (this == ARCHITECTURE_ARM)       { ret "arm"; }
    if (this == ARCHITECTURE_AARCH64)   { ret "aarch64"; }
    if (this == ARCHITECTURE_THUMB)     { ret "thumb"; }
    if (this == ARCHITECTURE_THUMBV6M)  { ret "thumbv6m"; }
    if (this == ARCHITECTURE_THUMBV7M)  { ret "thumbv7m"; }
    if (this == ARCHITECTURE_THUMBV7EM) { ret "thumbv7em"; }
    if (this == ARCHITECTURE_RISCV32)   { ret "riscv32"; }
    if (this == ARCHITECTURE_RISCV64)   { ret "riscv64"; }
    if (this == ARCHITECTURE_AVR)       { ret "avr"; }
    if (this == ARCHITECTURE_MSP430)    { ret "msp430"; }
    if (this == ARCHITECTURE_WASM32)    { ret "wasm32"; }
    if (this == ARCHITECTURE_WASM64)    { ret "wasm64"; }
    ret "unknown";
}

## Architecture descriptor with metadata
pub rec ArchitectureInfo {
    id:          Architecture;
    name:        str;
    word_size:   u8;
    is_64bit:    bool;
    is_embedded: bool;
    has_fpu:     bool;
}

pub def OS: u8;

pub val OS_UNKNOWN:      OS = $iota();
pub val OS_LINUX:        OS = $iota();
pub val OS_WINDOWS:      OS = $iota();
pub val OS_DARWIN:       OS = $iota();
pub val OS_WASI:         OS = $iota();
pub val OS_FREESTANDING: OS = $iota();
pub val OS_ZEPHYR:       OS = $iota();
pub val OS_NONE:         OS = $iota();

pub fun (this: OS) to_str() str {
    if (this == OS_LINUX)        { ret "linux"; }
    if (this == OS_WINDOWS)      { ret "windows"; }
    if (this == OS_DARWIN)       { ret "darwin"; }
    if (this == OS_WASI)         { ret "wasi"; }
    if (this == OS_FREESTANDING) { ret "freestanding"; }
    if (this == OS_ZEPHYR)       { ret "zephyr"; }
    if (this == OS_NONE)         { ret "none"; }
    ret "unknown";
}

## OS descriptor with metadata
pub rec OSInfo {
    id:                  OS;
    name:                str;
    supports_filesystem: bool;
    supports_networking: bool;
    supports_threads:    bool;
    has_mmu:             bool;
    is_freestanding:     bool;
}

pub def ABI: u8;

pub val ABI_UNKNOWN: ABI = $iota();
pub val ABI_GNU:     ABI = $iota();
pub val ABI_MSVC:    ABI = $iota();
pub val ABI_MUSL:    ABI = $iota();
pub val ABI_NEWLIB:  ABI = $iota();
pub val ABI_BARE:    ABI = $iota();
pub val ABI_WASI:    ABI = $iota();

pub fun (this: ABI) to_str() str {
    if (this == ABI_GNU)   { ret "gnu"; }
    if (this == ABI_MSVC)  { ret "msvc"; }
    if (this == ABI_MUSL)  { ret "musl"; }
    if (this == ABI_NEWLIB){ ret "newlib"; }
    if (this == ABI_BARE)  { ret "bare"; }
    if (this == ABI_WASI)  { ret "wasi"; }
    ret "unknown";
}

