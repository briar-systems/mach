pub def Feature: u8;

pub val FEATURE_SOFT_FLOAT:       Feature = $iota();
pub val FEATURE_HARD_FLOAT:       Feature = $iota();
pub val FEATURE_SIMD:             Feature = $iota();
pub val FEATURE_UNALIGNED_MEMORY: Feature = $iota();
pub val FEATURE_ATOMICS_64:       Feature = $iota();
pub val FEATURE_ATOMICS_128:      Feature = $iota();
pub val FEATURE_THREADS:          Feature = $iota();
pub val FEATURE_MMU:              Feature = $iota();
pub val FEATURE_CACHE:            Feature = $iota();
pub val FEATURE_VECTOR_EXT:       Feature = $iota();

pub def FeatureSet: u64;

## Create a FeatureSet with only the specified flag set.
##
## flag: Feature to set
pub fun feature_bit(flag: Feature) FeatureSet {
    ret 1::u64 << flag::u64;
}

## Check if the specified feature flag is set in the FeatureSet.
##
## flag: Feature to check
pub fun (this: FeatureSet) has(flag: Feature) bool {
    ret (this & feature_bit(flag)) != 0;
}

## Set the specified feature flag in the FeatureSet.
##
## flag: Feature to set
pub fun (this: FeatureSet) set(flag: Feature) FeatureSet {
    ret this | feature_bit(flag);
}

## Unset the specified feature flag in the FeatureSet.
##
## flag: Feature to unset
pub fun (this: FeatureSet) unset(flag: Feature) FeatureSet {
    ret this & ~feature_bit(flag);
}

## Feature descriptor with metadata
pub rec FeatureInfo {
    id:   Feature;
    name: str;
}

