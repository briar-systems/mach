# mach.compiler.target: compilation target composition root.
# ---
# given a target triple, selects and composes all interface
# implementations (ISA, ABI, OF, OS) into a single Target record.
# all downstream code receives *Target — nothing downstream ever
# calls interface selectors directly.
#
# target.mach owns triple parsing and orchestration.
# implementation selection is delegated to per-interface selector modules:
#   isa/select.mach, abi/select.mach, of/select.mach, os/select.mach

use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use isa:      mach.compiler.target.isa;
use abi:      mach.compiler.target.abi;
use of:       mach.compiler.target.of;
use os:       mach.compiler.target.os;
use isa_sel:  mach.compiler.target.isa.select;
use abi_sel:  mach.compiler.target.abi.select;
use of_sel:   mach.compiler.target.of.select;
use os_sel:   mach.compiler.target.os.select;

# host platform constants
val HOST_ARCH:   str = $mach.build.target.arch;
val HOST_OS:     str = $mach.build.target.os;
val HOST_FORMAT: str = "elf"; # TODO: $mach.build.target.of — cmach treats 'of' as reserved

# fully composed compilation target.
# ---
# isa: instruction set (name, ptr_size, ptr_align, endian, registers, isel, encode, ...)
# abi: calling convention (name, param/return classification, callee-saved, ...)
# of:  object format (name, obj writer, exec writer, reader, debug info)
# os:  operating system (name, entry point, base addr, page size)
pub rec Target {
    isa: isa.ISA;
    abi: abi.ABI;
    of:  of.ObjectFormat;
    os:  os.OS;
}

# parse a target triple and compose all interfaces.
pub fun select(triple: str, alloc: *allocator.Allocator) Result[Target, str] {
    if (triple == nil || alloc == nil) {
        ret err[Target, str]("invalid arguments");
    }

    var arch: str = nil;
    var os_name: str = nil;
    var format: str = nil;
    parse_triple(triple, ?arch, ?os_name, ?format);

    if (arch == nil || os_name == nil || format == nil) {
        ret err[Target, str]("invalid triple format: expected arch-os-format");
    }

    var t: Target;

    # ISA
    val isa_r: Result[isa.ISA, str] = isa_sel.select(arch, alloc);
    if (result_is_err[isa.ISA, str](isa_r)) {
        ret err[Target, str](result_unwrap_err[isa.ISA, str](isa_r));
    }
    t.isa = result_unwrap_ok[isa.ISA, str](isa_r);

    # ABI
    val abi_r: Result[abi.ABI, str] = abi_sel.select(arch, os_name, alloc, ?t.isa);
    if (result_is_err[abi.ABI, str](abi_r)) {
        ret err[Target, str](result_unwrap_err[abi.ABI, str](abi_r));
    }
    t.abi = result_unwrap_ok[abi.ABI, str](abi_r);

    # OF
    val fmt_r: Result[of.ObjectFormat, str] = of_sel.select(
        format, arch, t.isa.ptr_size, t.isa.endian, alloc);
    if (result_is_err[of.ObjectFormat, str](fmt_r)) {
        ret err[Target, str](result_unwrap_err[of.ObjectFormat, str](fmt_r));
    }
    t.of = result_unwrap_ok[of.ObjectFormat, str](fmt_r);

    # OS
    val os_r: Result[os.OS, str] = os_sel.select(os_name, alloc);
    if (result_is_err[os.OS, str](os_r)) {
        ret err[Target, str](result_unwrap_err[os.OS, str](os_r));
    }
    t.os = result_unwrap_ok[os.OS, str](os_r);

    ret ok[Target, str](t);
}

# return the Target for the current host platform.
pub fun host(alloc: *allocator.Allocator) Result[Target, str] {
    if (alloc == nil) {
        ret err[Target, str]("allocator is nil");
    }

    # build triple: "arch-os-format"
    val arch_len: usize = str_len(HOST_ARCH);
    val os_len:   usize = str_len(HOST_OS);
    val fmt_len:  usize = str_len(HOST_FORMAT);
    val total:    usize = arch_len + 1 + os_len + 1 + fmt_len + 1;

    val buf_r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_r)) {
        ret err[Target, str]("out of memory");
    }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_r);

    var pos: usize = 0;
    var i: usize = 0;
    for (i < arch_len) { buf[pos] = HOST_ARCH[i]; pos = pos + 1; i = i + 1; }
    buf[pos] = '-'; pos = pos + 1;
    i = 0;
    for (i < os_len) { buf[pos] = HOST_OS[i]; pos = pos + 1; i = i + 1; }
    buf[pos] = '-'; pos = pos + 1;
    i = 0;
    for (i < fmt_len) { buf[pos] = HOST_FORMAT[i]; pos = pos + 1; i = i + 1; }
    buf[pos] = '\0';

    ret select(buf::str, alloc);
}

# create a fresh ObjWriter for the target's format.
pub fun create_object_format(tgt: *Target, alloc: *allocator.Allocator) Result[of.ObjWriter, str] {
    if (tgt == nil || alloc == nil) {
        ret err[of.ObjWriter, str]("invalid arguments");
    }
    ret of_sel.select_object_format(tgt.of.name, tgt.isa.name, alloc);
}

# create a fresh DebugInfo for the target's format.
pub fun create_debug_info(tgt: *Target, alloc: *allocator.Allocator) Result[of.DebugInfo, str] {
    if (tgt == nil || alloc == nil) {
        ret err[of.DebugInfo, str]("invalid arguments");
    }
    ret of_sel.select_debug_info(tgt.of.name, tgt.isa.ptr_size, tgt.isa.endian, alloc);
}

# --- triple parsing ---

fun parse_triple(triple: str, out_arch: *str, out_os: *str, out_fmt: *str) {
    if (triple == nil) { ret; }

    var seg: i32 = 0;
    var start: usize = 0;
    var i: usize = 0;

    for (triple[i] != 0) {
        if (triple[i] == '-') {
            val len: usize = i - start;
            if (seg == 0) {
                @out_arch = match_arch(triple, start, len);
            } or (seg == 1) {
                @out_os = match_os(triple, start, len);
            }
            seg = seg + 1;
            start = i + 1;
        }
        i = i + 1;
    }

    if (seg == 2) {
        val len: usize = i - start;
        @out_fmt = match_format(triple, start, len);
    }
}

fun match_arch(s: str, start: usize, len: usize) str {
    if (str_region_equals(s, start, len, "x86_64"))  { ret "x86_64"; }
    if (str_region_equals(s, start, len, "aarch64")) { ret "aarch64"; }
    if (str_region_equals(s, start, len, "arm64"))   { ret "aarch64"; }
    if (str_region_equals(s, start, len, "riscv64")) { ret "riscv64"; }
    if (str_region_equals(s, start, len, "x86"))     { ret "i386"; }
    ret nil;
}

fun match_os(s: str, start: usize, len: usize) str {
    if (str_region_equals(s, start, len, "linux"))     { ret "linux"; }
    if (str_region_equals(s, start, len, "darwin"))    { ret "darwin"; }
    if (str_region_equals(s, start, len, "windows"))   { ret "windows"; }
    if (str_region_equals(s, start, len, "freebsd"))   { ret "freebsd"; }
    if (str_region_equals(s, start, len, "netbsd"))    { ret "netbsd"; }
    if (str_region_equals(s, start, len, "openbsd"))   { ret "openbsd"; }
    if (str_region_equals(s, start, len, "dragonfly")) { ret "dragonfly"; }
    if (str_region_equals(s, start, len, "noos"))      { ret "noos"; }
    ret nil;
}

fun match_format(s: str, start: usize, len: usize) str {
    if (str_region_equals(s, start, len, "elf"))   { ret "elf"; }
    if (str_region_equals(s, start, len, "macho")) { ret "macho"; }
    if (str_region_equals(s, start, len, "coff"))  { ret "coff"; }
    if (str_region_equals(s, start, len, "pe"))    { ret "coff"; }
    ret nil;
}
