    ret info;
}

## Create a FeatureInfo descriptor for the given feature.
pub fun feature_info(feat: Feature) FeatureInfo {
    var info: FeatureInfo;
    info.id = feat;
    
    if (feat == FEATURE_SOFT_FLOAT)       { info.name = "soft_float"; }
    or (feat == FEATURE_HARD_FLOAT)       { info.name = "hard_float"; }
    or (feat == FEATURE_SIMD)             { info.name = "simd"; }
    or (feat == FEATURE_UNALIGNED_MEMORY) { info.name = "unaligned_memory"; }
    or (feat == FEATURE_ATOMICS_64)       { info.name = "atomics_64"; }
    or (feat == FEATURE_ATOMICS_128)      { info.name = "atomics_128"; }
    or (feat == FEATURE_THREADS)          { info.name = "threads"; }
    or (feat == FEATURE_MMU)              { info.name = "mmu"; }
    or (feat == FEATURE_CACHE)            { info.name = "cache"; }
    or (feat == FEATURE_VECTOR_EXT)       { info.name = "vector_ext"; }
    or                                    { info.name = "unknown"; }
    
    ret info;
}

## Initialize the $arch namespace with all architecture descriptors.
fun init_arch_namespace() arch {
    var ns: arch;
    ns.x86       = arch_info(ARCHITECTURE_X86);
    ns.x86_64    = arch_info(ARCHITECTURE_X86_64);
    ns.arm       = arch_info(ARCHITECTURE_ARM);
    ns.aarch64   = arch_info(ARCHITECTURE_AARCH64);
    ns.thumb     = arch_info(ARCHITECTURE_THUMB);
    ns.thumbv6m  = arch_info(ARCHITECTURE_THUMBV6M);
    ns.thumbv7m  = arch_info(ARCHITECTURE_THUMBV7M);
    ns.thumbv7em = arch_info(ARCHITECTURE_THUMBV7EM);
    ns.riscv32   = arch_info(ARCHITECTURE_RISCV32);
    ns.riscv64   = arch_info(ARCHITECTURE_RISCV64);
    ns.avr       = arch_info(ARCHITECTURE_AVR);
    ns.msp430    = arch_info(ARCHITECTURE_MSP430);
    ns.wasm32    = arch_info(ARCHITECTURE_WASM32);
    ns.wasm64    = arch_info(ARCHITECTURE_WASM64);
    ret ns;
}

## Initialize the $os namespace with all OS descriptors.
fun init_os_namespace() os {
    var ns: os;
    ns.linux        = os_info(OS_LINUX);
    ns.windows      = os_info(OS_WINDOWS);
    ns.darwin       = os_info(OS_DARWIN);
    ns.wasi         = os_info(OS_WASI);
    ns.freestanding = os_info(OS_FREESTANDING);
    ns.zephyr       = os_info(OS_ZEPHYR);
    ns.none         = os_info(OS_NONE);
    ret ns;
}

