# buf.mach: growable buffer of x86_64 instructions for deferred encoding.
# ---
# collects spec.Instruction records during ISel so that peephole
# optimization can run before final encoding to machine bytes.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use spec:      mach.compiler.masm.isa.spec;
use operand:   mach.compiler.masm.operand;

# sentinel opcode for label markers in the instruction buffer.
# ISel pushes these instead of immediately defining symbols;
# flush_buffer resolves them at encode time.
pub val LABEL_MARKER: i32 = -1;

# sentinel opcode for debug line markers in the instruction buffer.
# carries file index in dst.imm and line number in src1.imm.
pub val DEBUG_LINE_MARKER: i32 = -2;

# InstrBuffer: growable array of spec.Instruction records.
# ---
# instrs: pointer to instruction array
# count:  number of instructions in buffer
# cap:    allocated capacity
# alloc:  allocator for growth
pub rec InstrBuffer {
    instrs: *spec.Instruction;
    count:  i32;
    cap:    i32;
    alloc:  *allocator.Allocator;
}

# buf_init: create a new empty instruction buffer.
pub fun buf_init(alloc: *allocator.Allocator) InstrBuffer {
    var buf: InstrBuffer;
    buf.instrs = nil;
    buf.count = 0;
    buf.cap = 0;
    buf.alloc = alloc;
    ret buf;
}

# buf_append: append an instruction to the buffer, growing if needed.
pub fun buf_append(buf: *InstrBuffer, instr: spec.Instruction) bool {
    if (buf == nil || buf.alloc == nil) {
        ret false;
    }

    if (buf.count >= buf.cap) {
        var new_cap: i32 = 64;
        if (buf.cap > 0) {
            new_cap = buf.cap * 2;
        }

        val r: Result[*spec.Instruction, allocator.AllocError] =
            allocator.allocator_resize[spec.Instruction](
                buf.alloc, buf.instrs, buf.cap::usize, new_cap::usize
            );
        if (result_is_err[*spec.Instruction, allocator.AllocError](r)) {
            ret false;
        }

        buf.instrs = result_unwrap_ok[*spec.Instruction, allocator.AllocError](r);
        buf.cap = new_cap;
    }

    buf.instrs[buf.count] = instr;
    buf.count = buf.count + 1;
    ret true;
}

# buf_clear: reset the buffer count to zero (keeps allocation).
pub fun buf_clear(buf: *InstrBuffer) {
    if (buf == nil) {
        ret;
    }
    buf.count = 0;
}

# buf_get: get a pointer to the instruction at index i.
pub fun buf_get(buf: *InstrBuffer, i: i32) *spec.Instruction {
    if (buf == nil || i < 0 || i >= buf.count) {
        ret nil;
    }
    ret ?buf.instrs[i];
}

# buf_mark_nop: mark instruction at index i as a NOP (for peephole elimination).
pub fun buf_mark_nop(buf: *InstrBuffer, i: i32) {
    if (buf == nil || i < 0 || i >= buf.count) {
        ret;
    }
    buf.instrs[i].opcode = 0;
    buf.instrs[i].dst = operand.none();
    buf.instrs[i].src1 = operand.none();
    buf.instrs[i].src2 = operand.none();
    buf.instrs[i].size = 0;
    buf.instrs[i].flags = 0;
}

# buf_compact: remove NOP instructions (opcode 0, size 0) from the buffer.
# shifts remaining instructions down and updates count.
pub fun buf_compact(buf: *InstrBuffer) {
    if (buf == nil || buf.count == 0) {
        ret;
    }

    var write: i32 = 0;
    var read: i32 = 0;
    for (read < buf.count) {
        # skip NOPs that were marked for removal (opcode 0, size 0, no operands)
        if (buf.instrs[read].opcode == 0 && buf.instrs[read].size == 0 &&
            buf.instrs[read].dst.kind.tag == operand.OP_NONE) {
            read = read + 1;
            cnt;
        }

        if (write != read) {
            buf.instrs[write] = buf.instrs[read];
        }
        write = write + 1;
        read = read + 1;
    }
    buf.count = write;
}

# buf_append_label: append a label marker to the buffer.
# the label name is carried in dst.label; opcode is LABEL_MARKER (-1).
pub fun buf_append_label(buf: *InstrBuffer, label_name: str) bool {
    var instr: spec.Instruction;
    instr.opcode = LABEL_MARKER;
    instr.dst = operand.label(label_name);
    instr.src1 = operand.none();
    instr.src2 = operand.none();
    instr.size = 0;
    instr.flags = 0;
    ret buf_append(buf, instr);
}

# buf_append_debug_line: append a debug line marker to the buffer.
# file index stored in dst.imm, line number stored in src1.imm.
pub fun buf_append_debug_line(buf: *InstrBuffer, file_idx: u16, line: i32) bool {
    var instr: spec.Instruction;
    instr.opcode = DEBUG_LINE_MARKER;
    instr.dst = operand.imm(file_idx::i64, 0);
    instr.src1 = operand.imm(line::i64, 0);
    instr.src2 = operand.none();
    instr.size = 0;
    instr.flags = 0;
    ret buf_append(buf, instr);
}
