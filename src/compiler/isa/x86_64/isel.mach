use std.types.bool;
use std.types.size;
use std.types.string;

use ir:  mach.compiler.masm.ir;
use isa: mach.compiler.isa;
use op:  mach.compiler.isa.x86_64.opcode;

# mach.compiler.isa.x86_64.isel: instruction selection.
# ---
# translates target-independent IR instructions (ir.Inst) into
# x86_64 machine instructions (isa.MachInst).
#
# the IR uses abstract opcodes (OP_ADD, OP_LOAD, etc.) with operands
# that already carry register/imm/mem information. ISel maps each
# IR opcode to one or more x86_64 opcodes, handling special cases
# like division (which needs CDQ/CQO + IDIV), comparisons (CMP + SETcc),
# and conditional branches (CMP + Jcc).

# --- operand forwarding ---
# IR operands and MachInst operands are both ir.Operand, so most
# operands pass through unchanged. ISel only needs to pick the
# right x86_64 opcode and handle multi-instruction patterns.

fun emit(out: *isa.MachInstBuf, opcode: i32, dst: ir.Operand,
         src1: ir.Operand, src2: ir.Operand, size: u8, flags: u32) bool {
    var mi: isa.MachInst;
    mi.opcode = opcode;
    mi.dst = dst;
    mi.src1 = src1;
    mi.src2 = src2;
    mi.size = size;
    mi.flags = flags;
    ret isa.buf_append(out, mi);
}

fun emit2(out: *isa.MachInstBuf, opcode: i32, dst: ir.Operand,
          src1: ir.Operand, size: u8) bool {
    var mi: isa.MachInst;
    mi.opcode = opcode;
    mi.dst = dst;
    mi.src1 = src1;
    mi.src2 = ir.make_none();
    mi.size = size;
    mi.flags = 0;
    if (size == 8) { mi.flags = op.FLAG_REX_W; }
    ret isa.buf_append(out, mi);
}

fun emit1(out: *isa.MachInstBuf, opcode: i32, dst: ir.Operand, size: u8) bool {
    var mi: isa.MachInst;
    mi.opcode = opcode;
    mi.dst = dst;
    mi.src1 = ir.make_none();
    mi.src2 = ir.make_none();
    mi.size = size;
    mi.flags = 0;
    if (size == 8) { mi.flags = op.FLAG_REX_W; }
    ret isa.buf_append(out, mi);
}

fun emit0(out: *isa.MachInstBuf, opcode: i32) bool {
    var mi: isa.MachInst;
    mi.opcode = opcode;
    mi.dst = ir.make_none();
    mi.src1 = ir.make_none();
    mi.src2 = ir.make_none();
    mi.size = 0;
    mi.flags = 0;
    ret isa.buf_append(out, mi);
}

# --- condition code mapping ---

# cc_to_jcc: map IR condition code to x86_64 Jcc opcode.
fun cc_to_jcc(cc: ir.Cond) i32 {
    if (cc == ir.CC_EQ) { ret op.JE; }
    if (cc == ir.CC_NE) { ret op.JNE; }
    if (cc == ir.CC_LT) { ret op.JL; }
    if (cc == ir.CC_LE) { ret op.JLE; }
    if (cc == ir.CC_GT) { ret op.JG; }
    if (cc == ir.CC_GE) { ret op.JGE; }
    if (cc == ir.CC_ULT) { ret op.JB; }
    if (cc == ir.CC_ULE) { ret op.JBE; }
    if (cc == ir.CC_UGT) { ret op.JA; }
    if (cc == ir.CC_UGE) { ret op.JAE; }
    ret op.JE;
}

# cc_to_setcc: map IR condition code to x86_64 SETcc opcode.
fun cc_to_setcc(cc: ir.Cond) i32 {
    if (cc == ir.CC_EQ) { ret op.SETE; }
    if (cc == ir.CC_NE) { ret op.SETNE; }
    if (cc == ir.CC_LT) { ret op.SETL; }
    if (cc == ir.CC_LE) { ret op.SETLE; }
    if (cc == ir.CC_GT) { ret op.SETG; }
    if (cc == ir.CC_GE) { ret op.SETGE; }
    if (cc == ir.CC_ULT) { ret op.SETB; }
    if (cc == ir.CC_ULE) { ret op.SETBE; }
    if (cc == ir.CC_UGT) { ret op.SETA; }
    if (cc == ir.CC_UGE) { ret op.SETAE; }
    ret op.SETE;
}

# --- main entry point ---

# select: translate one IR instruction into x86_64 machine instructions.
# appends results to `out`. returns true on success.
pub fun select(inst: *ir.Inst, out: *isa.MachInstBuf) bool {
    if (inst == nil || out == nil) { ret false; }

    val o: ir.Operator = inst.op;

    # derive effective size: prefer explicit inst.size, otherwise
    # infer from operand sizes (dst > src1 > src2).
    var sz: u8 = inst.size;
    if (sz == 0) { sz = inst.dst.size; }
    if (sz == 0) { sz = inst.src1.size; }
    if (sz == 0) { sz = inst.src2.size; }

    # --- data movement ---

    if (o == ir.OP_MOV) {
        ret emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
    }

    if (o == ir.OP_LOAD) {
        ret emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
    }

    if (o == ir.OP_STORE) {
        # for STORE: size comes from the value being stored (src1),
        # not the memory destination (dst), which may be a larger slot.
        var ssz: u8 = inst.size;
        if (ssz == 0) { ssz = inst.src1.size; }
        if (ssz == 0) { ssz = inst.dst.size; }

        # x86_64 cannot encode MEM-to-MEM MOV; materialize through R11.
        if (inst.src1.kind == ir.OPK_MEM) {
            val tmp: ir.Operand = ir.make_reg(op.R11, ssz);
            emit2(out, op.OP_MOV, tmp, inst.src1, ssz);
            ret emit2(out, op.OP_MOV, inst.dst, tmp, ssz);
        }

        ret emit2(out, op.OP_MOV, inst.dst, inst.src1, ssz);
    }

    if (o == ir.OP_ADDR) {
        # symbol/label addresses: use MOV with relocation (MOVABS)
        if (inst.src1.kind == ir.OPK_LABEL || inst.src1.kind == ir.OPK_SYM) {
            ret emit2(out, op.OP_MOV, inst.dst, inst.src1, 8);
        }
        # memory operands (address-of local): use LEA
        ret emit2(out, op.LEA, inst.dst, inst.src1, sz);
    }

    # --- integer arithmetic ---
    # x86 binary ops are 2-address (dst OP= src), but the IR is 3-address
    # (dst = src1 OP src2). when src2 is present, insert MOV dst, src1 to
    # initialise dst, then apply the operation with src2. when src2 is
    # absent (inline asm, already 2-address), fall through unchanged.

    if (o == ir.OP_ADD) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.ADD, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.ADD, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_SUB) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.SUB, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.SUB, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_MUL) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.IMUL, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.IMUL, inst.dst, inst.src1, sz);
    }

    # signed division: CDQ/CQO + IDIV
    if (o == ir.OP_DIV) {
        if (sz == 8) { emit0(out, op.CQO); }
        or            { emit0(out, op.CDQ); }
        ret emit1(out, op.IDIV, inst.src1, sz);
    }

    # signed modulo: same sequence, result in RDX
    if (o == ir.OP_MOD) {
        if (sz == 8) { emit0(out, op.CQO); }
        or            { emit0(out, op.CDQ); }
        ret emit1(out, op.IDIV, inst.src1, sz);
    }

    # unsigned division: zero RDX + DIV
    if (o == ir.OP_DIVU) {
        var rdx: ir.Operand;
        rdx.kind = ir.OPK_REG;
        rdx.reg = op.RDX;
        rdx.size = sz;
        var zero: ir.Operand;
        zero.kind = ir.OPK_REG;
        zero.reg = op.RDX;
        zero.size = sz;
        emit2(out, op.XOR, rdx, zero, sz);
        ret emit1(out, op.DIV, inst.src1, sz);
    }

    # unsigned modulo: same as DIVU
    if (o == ir.OP_MODU) {
        var rdx: ir.Operand;
        rdx.kind = ir.OPK_REG;
        rdx.reg = op.RDX;
        rdx.size = sz;
        var zero: ir.Operand;
        zero.kind = ir.OPK_REG;
        zero.reg = op.RDX;
        zero.size = sz;
        emit2(out, op.XOR, rdx, zero, sz);
        ret emit1(out, op.DIV, inst.src1, sz);
    }

    # --- bitwise ---

    if (o == ir.OP_AND) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.AND, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.AND, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_OR) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.OR, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.OR, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_XOR) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.XOR, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.XOR, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_SHL) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.SHL, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.SHL, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_SHR) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.SHR, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.SHR, inst.dst, inst.src1, sz);
    }
    if (o == ir.OP_SAR) {
        if (inst.src2.kind != ir.OPK_NONE) {
            emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
            ret emit2(out, op.SAR, inst.dst, inst.src2, sz);
        }
        ret emit2(out, op.SAR, inst.dst, inst.src1, sz);
    }

    # --- comparison ---
    # OP_ICMP produces a value: CMP + SETcc + MOVZX

    if (o == ir.OP_ICMP) {
        # CMP must use source operand width, not dst (which is always 1-byte bool)
        var cmp_sz: u8 = inst.src1.size;
        if (cmp_sz == 0) { cmp_sz = inst.src2.size; }
        if (cmp_sz == 0) { cmp_sz = sz; }
        emit2(out, op.CMP, inst.src1, inst.src2, cmp_sz);
        emit1(out, cc_to_setcc(inst.cc), inst.dst, 1);
        ret emit2(out, op.MOVZX, inst.dst, inst.dst, sz);
    }

    if (o == ir.OP_FCMP) {
        emit2(out, op.UCOMISD, inst.src1, inst.src2, sz);
        emit1(out, cc_to_setcc(inst.cc), inst.dst, 1);
        ret emit2(out, op.MOVZX, inst.dst, inst.dst, sz);
    }

    # --- control flow ---

    if (o == ir.OP_JMP) {
        ret emit1(out, op.JMP, inst.dst, 0);
    }

    # OP_BRCOND: branch if src1 is nonzero
    # test src1, src1 + jne target
    if (o == ir.OP_BRCOND) {
        emit2(out, op.TEST, inst.src1, inst.src1, sz);
        ret emit1(out, cc_to_jcc(inst.cc), inst.dst, 0);
    }

    if (o == ir.OP_CALL) {
        ret emit1(out, op.CALL, inst.dst, 0);
    }

    if (o == ir.OP_RET) {
        ret emit0(out, op.RET);
    }

    # --- conversions ---

    if (o == ir.OP_ZEXT) { ret emit2(out, op.MOVZX, inst.dst, inst.src1, sz); }
    if (o == ir.OP_SEXT) { ret emit2(out, op.MOVSX, inst.dst, inst.src1, sz); }

    if (o == ir.OP_TRUNC) {
        # truncation is just a mov; upper bits ignored at smaller size
        ret emit2(out, op.OP_MOV, inst.dst, inst.src1, sz);
    }

    if (o == ir.OP_ITOF) {
        if (sz == 4) { ret emit2(out, op.CVTSI2SS, inst.dst, inst.src1, sz); }
        ret emit2(out, op.CVTSI2SD, inst.dst, inst.src1, sz);
    }

    if (o == ir.OP_FTOI) {
        if (inst.src1.size == 4) { ret emit2(out, op.CVTTSS2SI, inst.dst, inst.src1, sz); }
        ret emit2(out, op.CVTTSD2SI, inst.dst, inst.src1, sz);
    }

    if (o == ir.OP_FEXT)   { ret emit2(out, op.CVTSS2SD, inst.dst, inst.src1, sz); }
    if (o == ir.OP_FTRUNC) { ret emit2(out, op.CVTSD2SS, inst.dst, inst.src1, sz); }

    # --- float arithmetic ---

    if (o == ir.OP_FADD) {
        if (sz == 4) {
            emit2(out, op.MOVSS, inst.dst, inst.src1, sz);
            ret emit2(out, op.ADDSS, inst.dst, inst.src2, sz);
        }
        emit2(out, op.MOVSD, inst.dst, inst.src1, sz);
        ret emit2(out, op.ADDSD, inst.dst, inst.src2, sz);
    }
    if (o == ir.OP_FSUB) {
        if (sz == 4) {
            emit2(out, op.MOVSS, inst.dst, inst.src1, sz);
            ret emit2(out, op.SUBSS, inst.dst, inst.src2, sz);
        }
        emit2(out, op.MOVSD, inst.dst, inst.src1, sz);
        ret emit2(out, op.SUBSD, inst.dst, inst.src2, sz);
    }
    if (o == ir.OP_FMUL) {
        if (sz == 4) {
            emit2(out, op.MOVSS, inst.dst, inst.src1, sz);
            ret emit2(out, op.MULSS, inst.dst, inst.src2, sz);
        }
        emit2(out, op.MOVSD, inst.dst, inst.src1, sz);
        ret emit2(out, op.MULSD, inst.dst, inst.src2, sz);
    }
    if (o == ir.OP_FDIV) {
        if (sz == 4) {
            emit2(out, op.MOVSS, inst.dst, inst.src1, sz);
            ret emit2(out, op.DIVSS, inst.dst, inst.src2, sz);
        }
        emit2(out, op.MOVSD, inst.dst, inst.src1, sz);
        ret emit2(out, op.DIVSD, inst.dst, inst.src2, sz);
    }

    # --- misc ---

    if (o == ir.OP_LABEL) {
        # labels are pseudo-instructions, not encoded
        ret true;
    }

    if (o == ir.OP_SYSCALL) {
        ret emit0(out, op.SYSCALL);
    }

    if (o == ir.OP_NOP) {
        ret emit0(out, op.OP_NOP);
    }

    ret false;
}
