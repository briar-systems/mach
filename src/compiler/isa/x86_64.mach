use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use dbg:       std.print;
use stream:    std.stream;
use fmt:       std.fmt;
use isa:       mach.compiler.isa;
use ir:        mach.compiler.masm.ir;
use section:   mach.compiler.masm.section;
use opcode:    mach.compiler.isa.x86_64.opcode;
use encode:    mach.compiler.isa.x86_64.encode;
use isel:      mach.compiler.isa.x86_64.isel;
use peephole:  mach.compiler.isa.x86_64.peephole;
use xiasm:     mach.compiler.isa.x86_64.iasm;

# mach.compiler.isa.x86_64: x86_64 ISA implementation.
# ---
# provides a constructor that returns a fully populated ISA interface
# with x86_64-specific function implementations.

# X86Context: internal state for the x86_64 ISA.
rec X86Context {
    alloc:         *allocator.Allocator;
    gp_regs:       *isa.Register;
    gp_count:      i32;
    fp_regs:       *isa.Register;
    fp_count:      i32;
    gp_file:       isa.RegisterFile;
    fp_file:       isa.RegisterFile;
    reserved_regs: *isa.Register;
    reserved_file: isa.RegisterFile;
}

# create: construct the x86_64 ISA.
pub fun create(alloc: *allocator.Allocator) Result[isa.ISA, str] {
    if (alloc == nil) {
        ret err[isa.ISA, str]("allocator is nil");
    }

    # allocate context
    val ctx_r: Result[*X86Context, allocator.AllocError] = allocator.allocator_zalloc[X86Context](alloc, 1);
    if (result_is_err[*X86Context, allocator.AllocError](ctx_r)) {
        ret err[isa.ISA, str]("out of memory");
    }
    val ctx: *X86Context = result_unwrap_ok[*X86Context, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;

    # allocate and populate GP registers (16: RAX through R15)
    val gp_r: Result[*isa.Register, allocator.AllocError] = allocator.allocator_alloc[isa.Register](alloc, 16);
    if (result_is_err[*isa.Register, allocator.AllocError](gp_r)) {
        ret err[isa.ISA, str]("out of memory");
    }
    ctx.gp_regs = result_unwrap_ok[*isa.Register, allocator.AllocError](gp_r);
    ctx.gp_count = 16;

    set_reg(?ctx.gp_regs[0],  opcode.RAX, "rax", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[1],  opcode.RCX, "rcx", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[2],  opcode.RDX, "rdx", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[3],  opcode.RBX, "rbx", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[4],  opcode.RSP, "rsp", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[5],  opcode.RBP, "rbp", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[6],  opcode.RSI, "rsi", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[7],  opcode.RDI, "rdi", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[8],  opcode.R8,  "r8",  isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[9],  opcode.R9,  "r9",  isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[10], opcode.R10, "r10", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[11], opcode.R11, "r11", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[12], opcode.R12, "r12", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[13], opcode.R13, "r13", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[14], opcode.R14, "r14", isa.REG_GP, 8);
    set_reg(?ctx.gp_regs[15], opcode.R15, "r15", isa.REG_GP, 8);

    ctx.gp_file.regs = ctx.gp_regs;
    ctx.gp_file.count = ctx.gp_count;

    # allocate and populate FP registers (16: XMM0 through XMM15)
    val fp_r: Result[*isa.Register, allocator.AllocError] = allocator.allocator_alloc[isa.Register](alloc, 16);
    if (result_is_err[*isa.Register, allocator.AllocError](fp_r)) {
        ret err[isa.ISA, str]("out of memory");
    }
    ctx.fp_regs = result_unwrap_ok[*isa.Register, allocator.AllocError](fp_r);
    ctx.fp_count = 16;

    set_reg(?ctx.fp_regs[0],  opcode.XMM0,  "xmm0",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[1],  opcode.XMM1,  "xmm1",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[2],  opcode.XMM2,  "xmm2",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[3],  opcode.XMM3,  "xmm3",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[4],  opcode.XMM4,  "xmm4",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[5],  opcode.XMM5,  "xmm5",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[6],  opcode.XMM6,  "xmm6",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[7],  opcode.XMM7,  "xmm7",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[8],  opcode.XMM8,  "xmm8",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[9],  opcode.XMM9,  "xmm9",  isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[10], opcode.XMM10, "xmm10", isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[11], opcode.XMM11, "xmm11", isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[12], opcode.XMM12, "xmm12", isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[13], opcode.XMM13, "xmm13", isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[14], opcode.XMM14, "xmm14", isa.REG_FP, 16);
    set_reg(?ctx.fp_regs[15], opcode.XMM15, "xmm15", isa.REG_FP, 16);

    ctx.fp_file.regs = ctx.fp_regs;
    ctx.fp_file.count = ctx.fp_count;

    # allocate and populate reserved registers (RSP, RBP)
    val res_r: Result[*isa.Register, allocator.AllocError] = allocator.allocator_alloc[isa.Register](alloc, 2);
    if (result_is_err[*isa.Register, allocator.AllocError](res_r)) {
        ret err[isa.ISA, str]("out of memory");
    }
    ctx.reserved_regs = result_unwrap_ok[*isa.Register, allocator.AllocError](res_r);
    set_reg(?ctx.reserved_regs[0], opcode.RSP, "rsp", isa.REG_GP, 8);
    set_reg(?ctx.reserved_regs[1], opcode.RBP, "rbp", isa.REG_GP, 8);
    ctx.reserved_file.regs = ctx.reserved_regs;
    ctx.reserved_file.count = 2;

    # construct ISA interface
    var i: isa.ISA;
    i.ctx = ctx::ptr;
    i.gp_regs = x86_gp_regs;
    i.fp_regs = x86_fp_regs;
    i.isel = x86_isel;
    i.encode = x86_encode;
    i.encode_nop = x86_encode_nop;
    i.peephole = x86_peephole;
    i.frame_reg = x86_frame_reg;
    i.reserved_regs = x86_reserved_regs;
    i.is_ret = x86_is_ret;
    i.is_call = x86_is_call;
    i.emit_spill = x86_emit_spill;
    i.emit_reload = x86_emit_reload;
    i.prologue = x86_prologue;
    i.epilogue = x86_epilogue;
    i.reloc_size = x86_reloc_size;
    i.resolve_reloc = x86_resolve_reloc;
    i.lower_asm = x86_lower_asm;
    i.format_inst = x86_format_inst;

    ret ok[isa.ISA, str](i);
}

# --- helpers ---

fun set_reg(r: *isa.Register, id: i32, name: str, class: isa.RegClass, width: u8) {
    if (r == nil) { ret; }
    r.id = id;
    r.name = name;
    r.class = class;
    r.width = width;
}

# --- ISA interface implementations ---

fun x86_gp_regs(ctx: ptr) isa.RegisterFile {
    val x: *X86Context = ctx::*X86Context;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.gp_file;
}

fun x86_fp_regs(ctx: ptr) isa.RegisterFile {
    val x: *X86Context = ctx::*X86Context;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.fp_file;
}

fun x86_isel(ctx: ptr, inst: *ir.Inst, out: *isa.MachInstBuf) bool {
    ret isel.select(inst, out);
}

fun x86_encode(ctx: ptr, inst: *isa.MachInst, sec: *section.Section,
               alloc: *allocator.Allocator) i32 {
    ret encode.encode_instruction(inst, sec, alloc);
}

fun x86_encode_nop(ctx: ptr, size: i32, sec: *section.Section,
                   alloc: *allocator.Allocator) i32 {
    ret encode.encode_nop_sequence(size, sec, alloc);
}

fun x86_peephole(ctx: ptr, buf: *isa.MachInstBuf) {
    peephole.optimize(buf);
}

# --- register allocation support ---

fun x86_frame_reg(ctx: ptr) i32 {
    ret opcode.RBP;
}

fun x86_reserved_regs(ctx: ptr) isa.RegisterFile {
    val x: *X86Context = ctx::*X86Context;
    if (x == nil) {
        var empty: isa.RegisterFile;
        empty.regs = nil;
        empty.count = 0;
        ret empty;
    }
    ret x.reserved_file;
}

fun x86_is_ret(ctx: ptr, inst: *isa.MachInst) bool {
    if (inst == nil) { ret false; }
    ret inst.opcode == opcode.RET;
}

fun x86_is_call(ctx: ptr, inst: *isa.MachInst) bool {
    if (inst == nil) { ret false; }
    ret inst.opcode == opcode.CALL;
}

fun x86_emit_spill(ctx: ptr, buf: *isa.MachInstBuf, preg: i32,
                   offset: i64, size: u8, fp_reg: i32) i32 {
    # MOV [fp_reg + offset], preg
    var mi: isa.MachInst;
    mi.opcode = opcode.OP_MOV;
    mi.dst = ir.make_mem(fp_reg, -1, 1, offset, size);
    mi.src1 = ir.make_reg(preg, size);
    mi.size = size;
    mi.flags = 0;
    if (size == 8) { mi.flags = opcode.FLAG_REX_W; }
    if (isa.buf_append(buf, mi)) { ret 1; }
    ret 0;
}

fun x86_emit_reload(ctx: ptr, buf: *isa.MachInstBuf, preg: i32,
                    offset: i64, size: u8, fp_reg: i32) i32 {
    # MOV preg, [fp_reg + offset]
    var mi: isa.MachInst;
    mi.opcode = opcode.OP_MOV;
    mi.dst = ir.make_reg(preg, size);
    mi.src1 = ir.make_mem(fp_reg, -1, 1, offset, size);
    mi.size = size;
    mi.flags = 0;
    if (size == 8) { mi.flags = opcode.FLAG_REX_W; }
    if (isa.buf_append(buf, mi)) { ret 1; }
    ret 0;
}

# --- frame management ---

fun emit_push_reg(sec: *section.Section, alloc: *allocator.Allocator, reg: i32) i32 {
    var inst: isa.MachInst;
    inst.opcode = opcode.PUSH;
    inst.dst = ir.make_reg(reg, 8);
    inst.size = 8;
    inst.flags = 0;
    ret encode.encode_instruction(?inst, sec, alloc);
}

fun emit_pop_reg(sec: *section.Section, alloc: *allocator.Allocator, reg: i32) i32 {
    var inst: isa.MachInst;
    inst.opcode = opcode.POP;
    inst.dst = ir.make_reg(reg, 8);
    inst.size = 8;
    inst.flags = 0;
    ret encode.encode_instruction(?inst, sec, alloc);
}

fun x86_prologue(ctx: ptr, frame_size: usize, callee_mask: u32,
                 sec: *section.Section, alloc: *allocator.Allocator) i32 {
    var n: i32 = 0;

    # push rbp (frame pointer — always saved)
    n = n + emit_push_reg(sec, alloc, opcode.RBP);

    # mov rbp, rsp (set frame pointer BEFORE callee-saved pushes — standard SysV64)
    var mov_inst: isa.MachInst;
    mov_inst.opcode = opcode.OP_MOV;
    mov_inst.dst = ir.make_reg(opcode.RBP, 8);
    mov_inst.src1 = ir.make_reg(opcode.RSP, 8);
    mov_inst.size = 8;
    mov_inst.flags = opcode.FLAG_REX_W;
    n = n + encode.encode_instruction(?mov_inst, sec, alloc);

    # push callee-saved registers indicated by mask (ascending ID order)
    if ((callee_mask & (1::u32 << 3::u32)) != 0) { n = n + emit_push_reg(sec, alloc, opcode.RBX); }
    if ((callee_mask & (1::u32 << 12::u32)) != 0) { n = n + emit_push_reg(sec, alloc, opcode.R12); }
    if ((callee_mask & (1::u32 << 13::u32)) != 0) { n = n + emit_push_reg(sec, alloc, opcode.R13); }
    if ((callee_mask & (1::u32 << 14::u32)) != 0) { n = n + emit_push_reg(sec, alloc, opcode.R14); }
    if ((callee_mask & (1::u32 << 15::u32)) != 0) { n = n + emit_push_reg(sec, alloc, opcode.R15); }

    # sub rsp, frame_size
    if (frame_size > 0) {
        var sub_inst: isa.MachInst;
        sub_inst.opcode = opcode.SUB;
        sub_inst.dst = ir.make_reg(opcode.RSP, 8);
        sub_inst.src1 = ir.make_imm(frame_size::i64, 8);
        sub_inst.size = 8;
        sub_inst.flags = opcode.FLAG_REX_W;
        n = n + encode.encode_instruction(?sub_inst, sec, alloc);
    }

    ret n;
}

fun x86_epilogue(ctx: ptr, callee_mask: u32, sec: *section.Section,
                 alloc: *allocator.Allocator) i32 {
    var n: i32 = 0;

    # compute callee_save_size = popcount(callee_mask) * 8
    var callee_save_size: i64 = 0;
    var tmp: u32 = callee_mask;
    for (tmp != 0) {
        callee_save_size = callee_save_size + (tmp & 1)::i64;
        tmp = tmp >> 1;
    }
    callee_save_size = callee_save_size * 8;

    # lea rsp, [rbp - callee_save_size]
    var lea_inst: isa.MachInst;
    lea_inst.opcode = opcode.LEA;
    lea_inst.dst = ir.make_reg(opcode.RSP, 8);
    lea_inst.src1 = ir.make_mem(opcode.RBP, -1, 1, -callee_save_size, 8);
    lea_inst.size = 8;
    lea_inst.flags = opcode.FLAG_REX_W;
    n = n + encode.encode_instruction(?lea_inst, sec, alloc);

    # pop callee-saved registers (descending ID order — reverse of prologue)
    if ((callee_mask & (1::u32 << 15::u32)) != 0) { n = n + emit_pop_reg(sec, alloc, opcode.R15); }
    if ((callee_mask & (1::u32 << 14::u32)) != 0) { n = n + emit_pop_reg(sec, alloc, opcode.R14); }
    if ((callee_mask & (1::u32 << 13::u32)) != 0) { n = n + emit_pop_reg(sec, alloc, opcode.R13); }
    if ((callee_mask & (1::u32 << 12::u32)) != 0) { n = n + emit_pop_reg(sec, alloc, opcode.R12); }
    if ((callee_mask & (1::u32 << 3::u32)) != 0) { n = n + emit_pop_reg(sec, alloc, opcode.RBX); }

    # pop rbp (frame pointer — always restored)
    n = n + emit_pop_reg(sec, alloc, opcode.RBP);

    # ret
    var ret_inst: isa.MachInst;
    ret_inst.opcode = opcode.RET;
    ret_inst.size = 0;
    ret_inst.flags = 0;
    n = n + encode.encode_instruction(?ret_inst, sec, alloc);

    ret n;
}

# --- relocation ---

fun x86_reloc_size(ctx: ptr, rtype: section.RelocKind) u8 {
    if (rtype == section.RELOC_ABS64)  { ret 8; }
    if (rtype == section.RELOC_REL32)  { ret 4; }
    if (rtype == section.RELOC_CALL32) { ret 4; }
    if (rtype == section.RELOC_ABS32)  { ret 4; }
    if (rtype == section.RELOC_ABS32S) { ret 4; }
    ret 0;
}

fun x86_resolve_reloc(ctx: ptr, rtype: section.RelocKind, sym_addr: u64,
                      reloc_addr: u64, addend: i64, dest: *u8) i32 {
    if (dest == nil) { ret 0; }

    if (rtype == section.RELOC_ABS64) {
        val v: u64 = sym_addr + addend::u64;
        dest[0] = (v & 255)::u8;
        dest[1] = ((v >> 8) & 255)::u8;
        dest[2] = ((v >> 16) & 255)::u8;
        dest[3] = ((v >> 24) & 255)::u8;
        dest[4] = ((v >> 32) & 255)::u8;
        dest[5] = ((v >> 40) & 255)::u8;
        dest[6] = ((v >> 48) & 255)::u8;
        dest[7] = ((v >> 56) & 255)::u8;
        ret 8;
    }

    if (rtype == section.RELOC_REL32 || rtype == section.RELOC_CALL32) {
        val v: i64 = sym_addr::i64 + addend - reloc_addr::i64;
        val u: u32 = v::u32;
        dest[0] = (u & 255)::u8;
        dest[1] = ((u >> 8) & 255)::u8;
        dest[2] = ((u >> 16) & 255)::u8;
        dest[3] = ((u >> 24) & 255)::u8;
        ret 4;
    }

    if (rtype == section.RELOC_ABS32 || rtype == section.RELOC_ABS32S) {
        val v: u64 = sym_addr + addend::u64;
        val u: u32 = v::u32;
        dest[0] = (u & 255)::u8;
        dest[1] = ((u >> 8) & 255)::u8;
        dest[2] = ((u >> 16) & 255)::u8;
        dest[3] = ((u >> 24) & 255)::u8;
        ret 4;
    }

    ret 0;
}

fun x86_lower_asm(ctx: ptr, buf: *isa.AsmInstBuf, alloc: *allocator.Allocator,
                  content: str, start: usize, end: usize) {
    xiasm.lower(ctx, buf, alloc, content, start, end);
}

# --- assembly text formatting ---

# gp_reg_name_sized: get a GP register name for a given operand size.
fun gp_reg_name_sized(id: i32, size: u8) str {
    if (size == 8) {
        if (id == 0)  { ret "rax"; }
        if (id == 1)  { ret "rcx"; }
        if (id == 2)  { ret "rdx"; }
        if (id == 3)  { ret "rbx"; }
        if (id == 4)  { ret "rsp"; }
        if (id == 5)  { ret "rbp"; }
        if (id == 6)  { ret "rsi"; }
        if (id == 7)  { ret "rdi"; }
        if (id == 8)  { ret "r8"; }
        if (id == 9)  { ret "r9"; }
        if (id == 10) { ret "r10"; }
        if (id == 11) { ret "r11"; }
        if (id == 12) { ret "r12"; }
        if (id == 13) { ret "r13"; }
        if (id == 14) { ret "r14"; }
        if (id == 15) { ret "r15"; }
    }
    if (size == 4) {
        if (id == 0)  { ret "eax"; }
        if (id == 1)  { ret "ecx"; }
        if (id == 2)  { ret "edx"; }
        if (id == 3)  { ret "ebx"; }
        if (id == 4)  { ret "esp"; }
        if (id == 5)  { ret "ebp"; }
        if (id == 6)  { ret "esi"; }
        if (id == 7)  { ret "edi"; }
        if (id == 8)  { ret "r8d"; }
        if (id == 9)  { ret "r9d"; }
        if (id == 10) { ret "r10d"; }
        if (id == 11) { ret "r11d"; }
        if (id == 12) { ret "r12d"; }
        if (id == 13) { ret "r13d"; }
        if (id == 14) { ret "r14d"; }
        if (id == 15) { ret "r15d"; }
    }
    if (size == 2) {
        if (id == 0)  { ret "ax"; }
        if (id == 1)  { ret "cx"; }
        if (id == 2)  { ret "dx"; }
        if (id == 3)  { ret "bx"; }
        if (id == 4)  { ret "sp"; }
        if (id == 5)  { ret "bp"; }
        if (id == 6)  { ret "si"; }
        if (id == 7)  { ret "di"; }
        if (id == 8)  { ret "r8w"; }
        if (id == 9)  { ret "r9w"; }
        if (id == 10) { ret "r10w"; }
        if (id == 11) { ret "r11w"; }
        if (id == 12) { ret "r12w"; }
        if (id == 13) { ret "r13w"; }
        if (id == 14) { ret "r14w"; }
        if (id == 15) { ret "r15w"; }
    }
    if (size == 1) {
        if (id == 0)  { ret "al"; }
        if (id == 1)  { ret "cl"; }
        if (id == 2)  { ret "dl"; }
        if (id == 3)  { ret "bl"; }
        if (id == 4)  { ret "spl"; }
        if (id == 5)  { ret "bpl"; }
        if (id == 6)  { ret "sil"; }
        if (id == 7)  { ret "dil"; }
        if (id == 8)  { ret "r8b"; }
        if (id == 9)  { ret "r9b"; }
        if (id == 10) { ret "r10b"; }
        if (id == 11) { ret "r11b"; }
        if (id == 12) { ret "r12b"; }
        if (id == 13) { ret "r13b"; }
        if (id == 14) { ret "r14b"; }
        if (id == 15) { ret "r15b"; }
    }
    # fallback to 64-bit name
    if (id == 0)  { ret "rax"; }
    if (id == 1)  { ret "rcx"; }
    if (id == 2)  { ret "rdx"; }
    if (id == 3)  { ret "rbx"; }
    if (id == 4)  { ret "rsp"; }
    if (id == 5)  { ret "rbp"; }
    if (id == 6)  { ret "rsi"; }
    if (id == 7)  { ret "rdi"; }
    if (id == 8)  { ret "r8"; }
    if (id == 9)  { ret "r9"; }
    if (id == 10) { ret "r10"; }
    if (id == 11) { ret "r11"; }
    if (id == 12) { ret "r12"; }
    if (id == 13) { ret "r13"; }
    if (id == 14) { ret "r14"; }
    if (id == 15) { ret "r15"; }
    ret "?reg";
}

# fp_reg_name: get an FP/SSE register name.
fun fp_reg_name(id: i32) str {
    if (id == 0)  { ret "xmm0"; }
    if (id == 1)  { ret "xmm1"; }
    if (id == 2)  { ret "xmm2"; }
    if (id == 3)  { ret "xmm3"; }
    if (id == 4)  { ret "xmm4"; }
    if (id == 5)  { ret "xmm5"; }
    if (id == 6)  { ret "xmm6"; }
    if (id == 7)  { ret "xmm7"; }
    if (id == 8)  { ret "xmm8"; }
    if (id == 9)  { ret "xmm9"; }
    if (id == 10) { ret "xmm10"; }
    if (id == 11) { ret "xmm11"; }
    if (id == 12) { ret "xmm12"; }
    if (id == 13) { ret "xmm13"; }
    if (id == 14) { ret "xmm14"; }
    if (id == 15) { ret "xmm15"; }
    ret "?xmm";
}

# mem_size_prefix: get Intel syntax size prefix for memory operands.
fun mem_size_prefix(size: u8) str {
    if (size == 1) { ret "byte"; }
    if (size == 2) { ret "word"; }
    if (size == 4) { ret "dword"; }
    if (size == 8) { ret "qword"; }
    if (size == 16) { ret "xmmword"; }
    ret "qword";
}

# is_fp_conversion_dst_gp: check if a conversion opcode has a GP destination.
fun is_fp_conversion_dst_gp(opc: i32) bool {
    ret opc == opcode.CVTSS2SI || opc == opcode.CVTSD2SI
        || opc == opcode.CVTTSS2SI || opc == opcode.CVTTSD2SI;
}

# is_fp_conversion_src_gp: check if a conversion opcode has a GP source.
fun is_fp_conversion_src_gp(opc: i32) bool {
    ret opc == opcode.CVTSI2SS || opc == opcode.CVTSI2SD;
}

# format_reg_operand: write a register operand with correct naming.
fun format_reg_operand(w: *stream.Writer, op: *ir.Operand, use_fp: bool) {
    if (use_fp) {
        fmt.write_str(w, fp_reg_name(op.reg));
    } or {
        fmt.write_str(w, gp_reg_name_sized(op.reg, op.size));
    }
}

# format_mem_operand: write a memory operand in Intel syntax.
fun format_mem_operand(w: *stream.Writer, op: *ir.Operand, inst_size: u8) {
    var sz: u8 = op.size;
    if (sz == 0) { sz = inst_size; }
    fmt.write_str(w, mem_size_prefix(sz));
    fmt.write_str(w, " [");
    fmt.write_str(w, gp_reg_name_sized(op.base, 8));
    if (op.index >= 0) {
        fmt.write_str(w, " + ");
        fmt.write_str(w, gp_reg_name_sized(op.index, 8));
        if (op.scale > 1) {
            fmt.format(w, "*%d", op.scale::i64);
        }
    }
    if (op.disp > 0) {
        fmt.format(w, " + %d", op.disp);
    } or (op.disp < 0) {
        fmt.format(w, " - %d", -op.disp);
    }
    fmt.write_str(w, "]");
}

# format_operand: write a single operand.
fun format_operand(w: *stream.Writer, op: *ir.Operand, use_fp: bool, inst_size: u8) {
    if (op.kind == ir.OPK_REG) {
        format_reg_operand(w, op, use_fp);
    }
    or (op.kind == ir.OPK_IMM) {
        fmt.write_i64(w, op.imm);
    }
    or (op.kind == ir.OPK_MEM) {
        format_mem_operand(w, op, inst_size);
    }
    or (op.kind == ir.OPK_LABEL) {
        if (op.label != nil) {
            fmt.write_str(w, op.label);
        }
    }
    or (op.kind == ir.OPK_SYM) {
        fmt.format(w, "sym(%u)", op.sym_id);
    }
}

# x86_format_inst: format a machine instruction as x86_64 assembly text.
fun x86_format_inst(ctx: ptr, inst: *isa.MachInst, w: *stream.Writer) i32 {
    if (inst == nil || w == nil) { ret -1; }

    # skip NOPs
    if (inst.opcode == isa.MACHINST_NOP) { ret 0; }

    # labels
    if (inst.opcode == isa.MACHINST_LABEL) {
        if (inst.dst.label != nil) {
            fmt.write_str(w, inst.dst.label);
            fmt.write_str(w, ":\n");
        }
        ret 0;
    }

    # instruction indent + mnemonic
    fmt.write_str(w, "    ");
    fmt.write_str(w, opcode.get_name(inst.opcode));

    # determine register class usage
    val cat: u8 = opcode.get_category(inst.opcode);
    val is_float: bool = cat == opcode.CAT_FLOAT;
    val dst_is_gp: bool = is_fp_conversion_dst_gp(inst.opcode);
    val src_is_gp: bool = is_fp_conversion_src_gp(inst.opcode);

    # FP-FP conversions: both operands are FP
    val is_fp_fp: bool = inst.opcode == opcode.CVTSS2SD
        || inst.opcode == opcode.CVTSD2SS;

    # operands
    var has_dst: bool = false;

    if (inst.dst.kind != ir.OPK_NONE) {
        fmt.write_str(w, " ");
        if (is_float) {
            if (dst_is_gp) {
                format_operand(w, ?inst.dst, false, inst.size);
            } or {
                format_operand(w, ?inst.dst, true, inst.size);
            }
        } or {
            format_operand(w, ?inst.dst, false, inst.size);
        }
        has_dst = true;
    }

    if (inst.src1.kind != ir.OPK_NONE) {
        if (has_dst) { fmt.write_str(w, ", "); }
        or { fmt.write_str(w, " "); }
        if (is_float) {
            if (src_is_gp) {
                format_operand(w, ?inst.src1, false, inst.size);
            } or (is_fp_fp) {
                format_operand(w, ?inst.src1, true, inst.size);
            } or (dst_is_gp) {
                # CVTSS2SI etc: src is FP
                format_operand(w, ?inst.src1, true, inst.size);
            } or {
                format_operand(w, ?inst.src1, false, inst.size);
            }
        } or {
            format_operand(w, ?inst.src1, false, inst.size);
        }
    }

    if (inst.src2.kind != ir.OPK_NONE) {
        fmt.write_str(w, ", ");
        format_operand(w, ?inst.src2, false, inst.size);
    }

    fmt.write_newline(w);
    ret 0;
}
