# compiler.lower.data: global data declarations
#
# handles lowering of module-level val/var declarations into data
# sections and string constant emission. produces DataDecl records
# for the module builder: rodata for string constants, bss for
# zero-initialized globals, data for initialized globals.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use ast:    compiler.parse.ast;
use data:   masm.data;
use module: masm.module;
use sym:    masm.symbol;

use lower: compiler.lower.lower;

# lower_global_var: lower a global variable declaration
#
# placeholder for global variable lowering. full implementation requires
# comptime evaluation of initializers and access to the module's NodeStore
# (which the current call site does not pass). global val/var declarations
# are skipped until the API is extended.
# ---
# ctx:     lowering context
# node_id: AST node id for the NK_DECL_VAL or NK_DECL_VAR
pub fun lower_global_var(ctx: *lower.LowerContext, node_id: ast.NodeId) {
}

# lower_string_constant: intern a string constant and return its label name
#
# allocates a buffer for the string bytes (with null terminator), creates
# a DataDecl in .rodata, and registers it with the module builder. returns
# the generated label name for use in addr_label instructions.
# ---
# ctx:     lowering context
# value:   string content (without surrounding quotes)
# val_len: byte length of value
# ret:     label name for the string constant
pub fun lower_string_constant(ctx: *lower.LowerContext, value: str,
                              val_len: usize) str {
    if (ctx == nil || ctx.builder == nil) { ret nil; }

    # generate a unique label: .str.N
    val counter: i32 = ctx.str_counter;
    ctx.str_counter = ctx.str_counter + 1;

    val res_lbl: Result[*u8, str] = allocator.allocate[u8](ctx.alloc, 32);
    if (!res_lbl.tag) { ret nil; }
    val lbl_buf: *u8 = res_lbl.value.ok;

    # write ".str."
    lbl_buf[0] = '.';
    lbl_buf[1] = 's';
    lbl_buf[2] = 't';
    lbl_buf[3] = 'r';
    lbl_buf[4] = '.';
    var pos: usize = 5;

    if (counter == 0) {
        lbl_buf[pos] = '0';
        pos = pos + 1;
    } or {
        var dlen: usize = 0;
        var tmp: i32 = counter;
        for (tmp > 0) { dlen = dlen + 1; tmp = tmp / 10; }
        var di: usize = pos + dlen;
        tmp = counter;
        for (tmp > 0) {
            di = di - 1;
            lbl_buf[di] = (tmp % 10)::u8 + '0';
            tmp = tmp / 10;
        }
        pos = pos + dlen;
    }
    lbl_buf[pos] = 0;
    val label: str = lbl_buf::str;

    # allocate and copy string data with null terminator
    val data_len: u32 = (val_len + 1)::u32;
    val res_data: Result[*u8, str] = allocator.allocate[u8](ctx.alloc, data_len::usize);
    if (!res_data.tag) { ret nil; }
    val str_data: *u8 = res_data.value.ok;

    var ci: usize = 0;
    val src: *u8 = value::*u8;
    for (ci < val_len) {
        str_data[ci] = src[ci];
        ci = ci + 1;
    }
    str_data[val_len] = 0;

    val decl: data.DataDecl = data.make_bytes(label, sym.SEC_RODATA,
                                              sym.BIND_LOCAL, str_data,
                                              data_len, 1);
    module.builder_add_data(ctx.builder, decl);
    ret label;
}
