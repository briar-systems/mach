# compiler.lower.data: global data declarations
#
# handles lowering of module-level val/var declarations into data
# sections and string constant emission. currently stubbed — global
# variables will produce DataDecl records for the module builder.

use std.types.string;

use ast:   compiler.parse.ast;

use lower: compiler.lower.lower;

# lower_global_var: lower a global variable declaration
#
# global val/var declarations produce data section entries rather than
# instructions. the full implementation will create a DataDecl with
# initialized or zero-filled content and register it with the module builder.
# currently stubbed.
# ---
# ctx:     lowering context
# node_id: AST node id for the NK_DECL_VAL or NK_DECL_VAR
pub fun lower_global_var(ctx: *lower.LowerContext, node_id: ast.NodeId) {
}

# lower_string_constant: intern a string constant and return its label name
#
# the full implementation will emit the string bytes into a rodata
# DataDecl and return the label name that references them. for now
# returns a placeholder.
# ---
# ctx:   lowering context
# value: string value to intern
# ret:   label name for the string constant
pub fun lower_string_constant(ctx: *lower.LowerContext, value: str) str {
    ret ".str_placeholder";
}
