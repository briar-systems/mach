# compiler.lower.expr: expression lowering
#
# translates expression AST nodes into MASM IR instructions.
# each lower_* function returns a vreg holding the expression result.
# lvalue lowering returns an LvalueResult describing the memory location.

use std.types.bool;
use std.types.size;
use std.types.string;

use op:    masm.op;
use inst:  masm.inst;
use pool:  masm.pool;

use ast:   compiler.parse.ast;
use token: compiler.lex.token;

use lower: compiler.lower.lower;

# result of lowering an lvalue expression
# ---
# base_vreg: virtual register holding the base address
# disp_off:  data pool offset for the displacement
# size:      operand size in bytes
pub rec LvalueResult {
    base_vreg: u16;
    disp_off:  u16;
    size:      u8;
}

# lower_expr: lower an expression, returning the vreg holding the result
# ---
# ctx:     lowering context
# node_id: AST node to lower
# store:   AST node store
# ret:     vreg id holding the expression value
pub fun lower_expr(ctx: *lower.LowerContext, node_id: ast.NodeId,
                   store: &ast.NodeStore) u16 {
    if (ctx == nil) { ret 0; }
    if (node_id::u32 == ast.NODE_NIL::u32) { ret 0; }

    val node: &ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_EXPR_LIT_INT) {
        ret lower_int_lit(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_LIT_BOOL) {
        ret lower_bool_lit(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_LIT_NIL) {
        ret lower_nil_lit(ctx);
    }
    if (node.kind == ast.NK_EXPR_IDENT) {
        ret lower_ident(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_BINARY) {
        ret lower_binary(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_UNARY) {
        ret lower_unary(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_CALL) {
        ret lower_call(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_FIELD) {
        ret lower_field(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_INDEX) {
        ret lower_index(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_CAST) {
        ret lower_cast(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_ADDR) {
        ret lower_addr(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_DEREF) {
        ret lower_deref(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_PAREN) {
        val inner: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        ret lower_expr(ctx, inner, store);
    }
    if (node.kind == ast.NK_EXPR_LIT_STR) {
        ret lower_string_lit(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_LIT_FLOAT) {
        ret lower_float_lit(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_LIT_CHAR) {
        ret lower_char_lit(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_STRUCT_LIT) {
        ret lower_struct_lit(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_ARRAY_LIT) {
        ret lower_array_lit(ctx, node_id, store);
    }

    ret 0;
}

# lower_lvalue: lower an lvalue expression, returning base address and displacement
# ---
# ctx:     lowering context
# node_id: lvalue AST node
# store:   AST node store
# ret:     lvalue result with base vreg and displacement
pub fun lower_lvalue(ctx: *lower.LowerContext, node_id: ast.NodeId,
                     store: &ast.NodeStore) LvalueResult {
    var result: LvalueResult;
    result.base_vreg = 0;
    result.disp_off  = 0;
    result.size      = ctx.ptr_size;

    if (node_id::u32 == ast.NODE_NIL::u32) { ret result; }

    val node: &ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_EXPR_IDENT) {
        ret lower_ident_lvalue(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_DEREF) {
        ret lower_deref_lvalue(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_FIELD) {
        ret lower_field_lvalue(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_INDEX) {
        ret lower_index_lvalue(ctx, node_id, store);
    }
    if (node.kind == ast.NK_EXPR_PAREN) {
        val inner: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        ret lower_lvalue(ctx, inner, store);
    }

    ret result;
}

# lower an integer literal
fun lower_int_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                  store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val text_sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
    val text: str = ast.get_str(store, text_sid);

    var value: i64 = 0;
    if (text != nil) {
        value = parse_int_literal(text);
    }

    val dst: u16 = lower.alloc_vreg(ctx);
    val sz: u8 = ctx.ptr_size;

    if (value >= -2147483648 && value <= 2147483647) {
        val disp: u16 = lower.intern_disp(ctx, value::i32);
        lower.emit(ctx, inst.make_mov_imm32(dst, disp, sz));
    } or {
        val ci: u16 = lower.intern_const(ctx, value::u64);
        lower.emit(ctx, inst.make_mov_imm64(dst, ci, sz));
    }

    ret dst;
}

# lower a boolean literal
fun lower_bool_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                   store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val value: u32 = ast.get_extra(store, node.payload);

    val dst: u16 = lower.alloc_vreg(ctx);
    val disp: u16 = lower.intern_disp(ctx, value::i32);
    lower.emit(ctx, inst.make_mov_imm32(dst, disp, 1));

    ret dst;
}

# lower a nil literal
fun lower_nil_lit(ctx: *lower.LowerContext) u16 {
    val dst: u16 = lower.alloc_vreg(ctx);
    val ci: u16 = lower.intern_const(ctx, 0);
    lower.emit(ctx, inst.make_mov_imm64(dst, ci, ctx.ptr_size));
    ret dst;
}

# lower an identifier reference (loads from local variable)
fun lower_ident(ctx: *lower.LowerContext, node_id: ast.NodeId,
                store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val name_sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
    val name: str = ast.get_str(store, name_sid);

    val lv: *lower.LocalVar = lower.find_local(ctx, name);
    if (lv == nil) {
        ret 0;
    }

    val dst: u16 = lower.alloc_vreg(ctx);
    val disp: u16 = lower.intern_disp(ctx, lv.offset::i32);
    val sz: u8 = lv.size::u8;
    if (sz == 0) { ret dst; }
    lower.emit(ctx, inst.make_load(dst, inst.VREG_FP::u16, disp, sz));
    ret dst;
}

# lower a binary expression
fun lower_binary(ctx: *lower.LowerContext, node_id: ast.NodeId,
                 store: &ast.NodeStore) u16 {
    val lhs_id: ast.NodeId = ast.binary_lhs(store, node_id);
    val rhs_id: ast.NodeId = ast.binary_rhs(store, node_id);
    val op_tag: u8 = ast.binary_op(store, node_id);

    if (op_tag == token.TAG_EQ::u8) {
        ret lower_assign(ctx, lhs_id, rhs_id, store);
    }

    if (op_tag == token.TAG_AMP_AMP::u8) {
        ret lower_logical_and(ctx, lhs_id, rhs_id, store);
    }
    if (op_tag == token.TAG_PIPE_PIPE::u8) {
        ret lower_logical_or(ctx, lhs_id, rhs_id, store);
    }

    val lhs: u16 = lower_expr(ctx, lhs_id, store);
    val rhs: u16 = lower_expr(ctx, rhs_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    val sz: u8 = ctx.ptr_size;

    if (op_tag == token.TAG_PLUS::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_ADD, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_MINUS::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_SUB, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_STAR::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_MUL, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_SLASH::u8) {
        lower.emit(ctx, inst.make_div(dst, lhs, rhs, op.DIV_QUOT, sz));
    } or (op_tag == token.TAG_PERCENT::u8) {
        lower.emit(ctx, inst.make_div(dst, lhs, rhs, op.DIV_REM, sz));
    } or (op_tag == token.TAG_AMP::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_AND, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_PIPE::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_OR, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_CARET::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_XOR, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_LT_LT::u8) {
        lower.emit(ctx, inst.make_alu(op.OP_SHL, dst, lhs, rhs, sz));
    } or (op_tag == token.TAG_GT_GT::u8) {
        lower.emit(ctx, inst.make_shr(dst, lhs, rhs, op.SHR_LOGICAL, sz));
    } or (op_tag == token.TAG_EQ_EQ::u8) {
        lower.emit(ctx, inst.make_cmp(dst, lhs, rhs, op.CC_EQ, sz));
    } or (op_tag == token.TAG_BANG_EQ::u8) {
        lower.emit(ctx, inst.make_cmp(dst, lhs, rhs, op.CC_NE, sz));
    } or (op_tag == token.TAG_LT::u8) {
        lower.emit(ctx, inst.make_cmp(dst, lhs, rhs, op.CC_LT, sz));
    } or (op_tag == token.TAG_LT_EQ::u8) {
        lower.emit(ctx, inst.make_cmp(dst, lhs, rhs, op.CC_LE, sz));
    } or (op_tag == token.TAG_GT::u8) {
        lower.emit(ctx, inst.make_cmp(dst, lhs, rhs, op.CC_GT, sz));
    } or (op_tag == token.TAG_GT_EQ::u8) {
        lower.emit(ctx, inst.make_cmp(dst, lhs, rhs, op.CC_GE, sz));
    }

    ret dst;
}

# lower short-circuit logical AND
fun lower_logical_and(ctx: *lower.LowerContext, lhs_id: ast.NodeId,
                      rhs_id: ast.NodeId, store: &ast.NodeStore) u16 {
    val result: u16 = lower.alloc_vreg(ctx);
    val rhs_label: u16 = lower.alloc_label(ctx, "and_rhs");
    val end_label: u16 = lower.alloc_label(ctx, "and_end");

    val lhs: u16 = lower_expr(ctx, lhs_id, store);
    lower.emit(ctx, inst.make_unary(op.OP_MOV, result, lhs, ctx.ptr_size));
    lower.emit(ctx, inst.make_branch(lhs, rhs_label, op.CC_NE));
    lower.emit(ctx, inst.make_jmp(end_label));

    lower.new_block(ctx, rhs_label);
    val rhs: u16 = lower_expr(ctx, rhs_id, store);
    lower.emit(ctx, inst.make_unary(op.OP_MOV, result, rhs, ctx.ptr_size));
    lower.emit(ctx, inst.make_jmp(end_label));

    lower.new_block(ctx, end_label);
    ret result;
}

# lower short-circuit logical OR
fun lower_logical_or(ctx: *lower.LowerContext, lhs_id: ast.NodeId,
                     rhs_id: ast.NodeId, store: &ast.NodeStore) u16 {
    val result: u16 = lower.alloc_vreg(ctx);
    val rhs_label: u16 = lower.alloc_label(ctx, "or_rhs");
    val end_label: u16 = lower.alloc_label(ctx, "or_end");

    val lhs: u16 = lower_expr(ctx, lhs_id, store);
    lower.emit(ctx, inst.make_unary(op.OP_MOV, result, lhs, ctx.ptr_size));
    lower.emit(ctx, inst.make_branch(lhs, end_label, op.CC_NE));
    lower.emit(ctx, inst.make_jmp(rhs_label));

    lower.new_block(ctx, rhs_label);
    val rhs: u16 = lower_expr(ctx, rhs_id, store);
    lower.emit(ctx, inst.make_unary(op.OP_MOV, result, rhs, ctx.ptr_size));
    lower.emit(ctx, inst.make_jmp(end_label));

    lower.new_block(ctx, end_label);
    ret result;
}

# lower a unary expression
fun lower_unary(ctx: *lower.LowerContext, node_id: ast.NodeId,
                store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    val op_tag: u8 = ast.get_extra(store, node.payload + 1)::u8;

    val src: u16 = lower_expr(ctx, operand_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    val sz: u8 = ctx.ptr_size;

    if (op_tag == token.TAG_MINUS::u8) {
        val zero: u16 = lower.alloc_vreg(ctx);
        val zi: u16 = lower.intern_disp(ctx, 0);
        lower.emit(ctx, inst.make_mov_imm32(zero, zi, sz));
        lower.emit(ctx, inst.make_alu(op.OP_SUB, dst, zero, src, sz));
    } or (op_tag == token.TAG_BANG::u8) {
        val zero: u16 = lower.alloc_vreg(ctx);
        val zi: u16 = lower.intern_disp(ctx, 0);
        lower.emit(ctx, inst.make_mov_imm32(zero, zi, sz));
        lower.emit(ctx, inst.make_cmp(dst, src, zero, op.CC_EQ, sz));
    } or (op_tag == token.TAG_TILDE::u8) {
        val ones: u16 = lower.alloc_vreg(ctx);
        val ci: u16 = lower.intern_const(ctx, 0xFFFFFFFFFFFFFFFF);
        lower.emit(ctx, inst.make_mov_imm64(ones, ci, sz));
        lower.emit(ctx, inst.make_alu(op.OP_XOR, dst, src, ones, sz));
    } or {
        lower.emit(ctx, inst.make_unary(op.OP_MOV, dst, src, sz));
    }

    ret dst;
}

# lower a function call expression
fun lower_call(ctx: *lower.LowerContext, node_id: ast.NodeId,
               store: &ast.NodeStore) u16 {
    val callee_id: ast.NodeId = ast.call_callee(store, node_id);
    val args: ast.NodeSpan = ast.call_args(store, node_id);

    var i: u32 = 0;
    for (i < args.len) {
        val arg_nid: ast.NodeId = ast.get_extra(store, args.start + i)::ast.NodeId;
        val arg_vreg: u16 = lower_expr(ctx, arg_nid, store);
        val td: u16 = 0xFFFF;
        lower.emit(ctx, inst.make_arg(i::u8, arg_vreg, td, ctx.ptr_size));
        i = i + 1;
    }

    val callee_node: &ast.Node = ast.get(store, callee_id);
    val result: u16 = lower.alloc_vreg(ctx);

    if (callee_node.kind == ast.NK_EXPR_IDENT) {
        val name_sid: ast.StrId = ast.get_extra(store, callee_node.payload)::ast.StrId;
        val name: str = ast.get_str(store, name_sid);

        val li: i32 = pool.label_intern(ctx.alloc, ?ctx.func.labels, name);
        if (li >= 0) {
            lower.emit(ctx, inst.make_call_direct(result, li::u16, false, ctx.ptr_size));
        }
    } or {
        val callee_reg: u16 = lower_expr(ctx, callee_id, store);
        lower.emit(ctx, inst.make_call_indirect(result, callee_reg, false, ctx.ptr_size));
    }

    ret result;
}

# lower a field access expression
fun lower_field(ctx: *lower.LowerContext, node_id: ast.NodeId,
                store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val base_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    val field_sid: ast.StrId = ast.get_extra(store, node.payload + 1)::ast.StrId;

    val lv: LvalueResult = lower_field_lvalue(ctx, node_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    lower.emit(ctx, inst.make_load(dst, lv.base_vreg, lv.disp_off, lv.size));
    ret dst;
}

# lower an index expression
fun lower_index(ctx: *lower.LowerContext, node_id: ast.NodeId,
                store: &ast.NodeStore) u16 {
    val lv: LvalueResult = lower_index_lvalue(ctx, node_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    lower.emit(ctx, inst.make_load(dst, lv.base_vreg, lv.disp_off, lv.size));
    ret dst;
}

# lower a cast expression
fun lower_cast(ctx: *lower.LowerContext, node_id: ast.NodeId,
               store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;

    val src: u16 = lower_expr(ctx, operand_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    lower.emit(ctx, inst.make_conv(dst, src, op.CONV_ZEXT, ctx.ptr_size));
    ret dst;
}

# lower an address-of expression
fun lower_addr(ctx: *lower.LowerContext, node_id: ast.NodeId,
               store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;

    val lv: LvalueResult = lower_lvalue(ctx, operand_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    lower.emit(ctx, inst.make_addr(dst, lv.base_vreg, lv.disp_off, ctx.ptr_size));
    ret dst;
}

# lower a dereference expression
fun lower_deref(ctx: *lower.LowerContext, node_id: ast.NodeId,
                store: &ast.NodeStore) u16 {
    val node: &ast.Node = ast.get(store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;

    val ptr_vreg: u16 = lower_expr(ctx, operand_id, store);
    val dst: u16 = lower.alloc_vreg(ctx);
    val zero_disp: u16 = lower.intern_disp(ctx, 0);
    lower.emit(ctx, inst.make_load(dst, ptr_vreg, zero_disp, ctx.ptr_size));
    ret dst;
}

# lower an assignment (binary = operator)
fun lower_assign(ctx: *lower.LowerContext, lhs_id: ast.NodeId,
                 rhs_id: ast.NodeId, store: &ast.NodeStore) u16 {
    val rhs: u16 = lower_expr(ctx, rhs_id, store);
    val lv: LvalueResult = lower_lvalue(ctx, lhs_id, store);
    lower.emit(ctx, inst.make_store(rhs, lv.base_vreg, lv.disp_off, lv.size));
    ret rhs;
}

# lower an identifier as an lvalue
fun lower_ident_lvalue(ctx: *lower.LowerContext, node_id: ast.NodeId,
                       store: &ast.NodeStore) LvalueResult {
    var result: LvalueResult;
    result.base_vreg = inst.VREG_FP::u16;
    result.disp_off  = 0;
    result.size      = ctx.ptr_size;

    val node: &ast.Node = ast.get(store, node_id);
    val name_sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
    val name: str = ast.get_str(store, name_sid);

    val lv: *lower.LocalVar = lower.find_local(ctx, name);
    if (lv != nil) {
        result.disp_off = lower.intern_disp(ctx, lv.offset::i32);
        result.size     = lv.size::u8;
    }

    ret result;
}

# lower a dereference as an lvalue
fun lower_deref_lvalue(ctx: *lower.LowerContext, node_id: ast.NodeId,
                       store: &ast.NodeStore) LvalueResult {
    var result: LvalueResult;
    val node: &ast.Node = ast.get(store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;

    result.base_vreg = lower_expr(ctx, operand_id, store);
    result.disp_off  = lower.intern_disp(ctx, 0);
    result.size      = ctx.ptr_size;
    ret result;
}

# lower a field access as an lvalue
fun lower_field_lvalue(ctx: *lower.LowerContext, node_id: ast.NodeId,
                       store: &ast.NodeStore) LvalueResult {
    val node: &ast.Node = ast.get(store, node_id);
    val base_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;

    val base_lv: LvalueResult = lower_lvalue(ctx, base_id, store);

    var result: LvalueResult;
    result.base_vreg = base_lv.base_vreg;
    result.disp_off  = base_lv.disp_off;
    result.size      = ctx.ptr_size;
    ret result;
}

# lower an index expression as an lvalue
fun lower_index_lvalue(ctx: *lower.LowerContext, node_id: ast.NodeId,
                       store: &ast.NodeStore) LvalueResult {
    val node: &ast.Node = ast.get(store, node_id);
    val base_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    val index_id: ast.NodeId = ast.get_extra(store, node.payload + 1)::ast.NodeId;

    val base_addr: u16 = lower_expr(ctx, base_id, store);
    val index_vreg: u16 = lower_expr(ctx, index_id, store);

    val elem_size: u8 = ctx.ptr_size;
    val offset: u16 = lower.alloc_vreg(ctx);
    val size_vreg: u16 = lower.alloc_vreg(ctx);
    val sz_disp: u16 = lower.intern_disp(ctx, elem_size::i32);
    lower.emit(ctx, inst.make_mov_imm32(size_vreg, sz_disp, ctx.ptr_size));
    lower.emit(ctx, inst.make_alu(op.OP_MUL, offset, index_vreg, size_vreg, ctx.ptr_size));

    val addr: u16 = lower.alloc_vreg(ctx);
    lower.emit(ctx, inst.make_alu(op.OP_ADD, addr, base_addr, offset, ctx.ptr_size));

    var result: LvalueResult;
    result.base_vreg = addr;
    result.disp_off  = lower.intern_disp(ctx, 0);
    result.size      = elem_size;
    ret result;
}

# stub: lower a string literal
fun lower_string_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                     store: &ast.NodeStore) u16 {
    ret 0;
}

# stub: lower a float literal
fun lower_float_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                    store: &ast.NodeStore) u16 {
    ret 0;
}

# stub: lower a char literal
fun lower_char_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                   store: &ast.NodeStore) u16 {
    ret 0;
}

# stub: lower a struct literal
fun lower_struct_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                     store: &ast.NodeStore) u16 {
    ret 0;
}

# stub: lower an array literal
fun lower_array_lit(ctx: *lower.LowerContext, node_id: ast.NodeId,
                    store: &ast.NodeStore) u16 {
    ret 0;
}

# parse a decimal integer literal string into an i64 value
fun parse_int_literal(text: str) i64 {
    if (text == nil) { ret 0; }

    var value: i64 = 0;
    var neg: bool = false;
    var i: usize = 0;

    if (text[0] == '-') {
        neg = true;
        i = 1;
    }

    if (text[i] == '0' && (text[i + 1] == 'x' || text[i + 1] == 'X')) {
        i = i + 2;
        for (text[i] != 0) {
            val c: u8 = text[i];
            if (c >= '0' && c <= '9') {
                value = value * 16 + (c - '0')::i64;
            } or (c >= 'a' && c <= 'f') {
                value = value * 16 + (c - 'a' + 10)::i64;
            } or (c >= 'A' && c <= 'F') {
                value = value * 16 + (c - 'A' + 10)::i64;
            } or (c == '_') {
                i = i + 1;
                cnt;
            } or {
                brk;
            }
            i = i + 1;
        }
    } or (text[i] == '0' && (text[i + 1] == 'b' || text[i + 1] == 'B')) {
        i = i + 2;
        for (text[i] != 0) {
            val c: u8 = text[i];
            if (c == '0' || c == '1') {
                value = value * 2 + (c - '0')::i64;
            } or (c == '_') {
                i = i + 1;
                cnt;
            } or {
                brk;
            }
            i = i + 1;
        }
    } or (text[i] == '0' && (text[i + 1] == 'o' || text[i + 1] == 'O')) {
        i = i + 2;
        for (text[i] != 0) {
            val c: u8 = text[i];
            if (c >= '0' && c <= '7') {
                value = value * 8 + (c - '0')::i64;
            } or (c == '_') {
                i = i + 1;
                cnt;
            } or {
                brk;
            }
            i = i + 1;
        }
    } or {
        for (text[i] != 0) {
            val c: u8 = text[i];
            if (c >= '0' && c <= '9') {
                value = value * 10 + (c - '0')::i64;
            } or (c == '_') {
                i = i + 1;
                cnt;
            } or {
                brk;
            }
            i = i + 1;
        }
    }

    if (neg) { value = -value; }
    ret value;
}
