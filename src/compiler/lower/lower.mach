# mach.compiler.lower.lower: AST to MASM IR lowering driver
#
# transforms typed AST (sema output) into target-independent MASM IR.
# dispatches to expr, stmt, and data sub-modules. types and utility
# functions live in ctx.mach to avoid circular imports.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use op:       masm.op;
use inst:     masm.inst;
use pool:     masm.pool;
use fn:       masm.function;
use module:   masm.module;
use typedesc: masm.typedesc;

use sema:     mach.compiler.sema.sema;
use type:     mach.compiler.sema.type;
use smod:     mach.compiler.sema.module;
use ast:      mach.compiler.parse.ast;

use lctx:     mach.compiler.lower.ctx;
use data_mod: mach.compiler.lower.data;
use stmt_mod: mach.compiler.lower.stmt;

# init: initialize a lowering context
# ---
# alloc:   allocator for all internal storage
# target:  target descriptor pointer
# builder: masm module builder to populate
# sa:      semantic analysis context
# ret:     initialized context or error string
pub fun init(alloc: *allocator.Allocator, target: ptr,
             builder: *module.ModuleBuilder, sa: *sema.Sema) Result[lctx.LowerContext, str] {
    ret lctx.init(alloc, target, builder, sa);
}

# dnit: tear down a lowering context, freeing all internal storage
# ---
# ctx: context to destroy
pub fun dnit(ctx: *lctx.LowerContext) {
    lctx.dnit(ctx);
}

# lower_module: lower all top-level declarations in a module
# ---
# ctx:    lowering context
# mod_id: module to lower
pub fun lower_module(ctx: *lctx.LowerContext, mod_id: smod.ModuleId) {
    if (ctx == nil || ctx.sema == nil) { ret; }

    val m: &smod.Module = smod.get(ctx.sema.modules, mod_id);
    val store: &ast.NodeStore = ?m.store;
    val root: ast.NodeId = m.root;
    if (root::u32 == ast.NODE_NIL::u32) { ret; }

    val root_node: &ast.Node = ast.get(store, root);
    if (root_node.kind != ast.NK_PROGRAM && root_node.kind != ast.NK_STMT_BLOCK) { ret; }

    val stmts: ast.NodeSpan = ast.block_stmts(store, root);
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
        if (child_id::u32 == ast.NODE_NIL::u32) {
            i = i + 1;
            cnt;
        }

        val child: &ast.Node = ast.get(store, child_id);
        if (child.kind == ast.NK_DECL_FUN) {
            lower_function(ctx, child_id, store);
        } or (child.kind == ast.NK_DECL_VAL || child.kind == ast.NK_DECL_VAR) {
            data_mod.lower_global_var(ctx, child_id);
        } or (child.kind == ast.NK_DECL_PUB) {
            val inner_id: ast.NodeId = ast.get_extra(store, child.payload)::ast.NodeId;
            if (inner_id::u32 != ast.NODE_NIL::u32) {
                val inner: &ast.Node = ast.get(store, inner_id);
                if (inner.kind == ast.NK_DECL_FUN) {
                    lower_function(ctx, inner_id, store);
                } or (inner.kind == ast.NK_DECL_VAL || inner.kind == ast.NK_DECL_VAR) {
                    data_mod.lower_global_var(ctx, inner_id);
                }
            }
        }
        i = i + 1;
    }
}

# lower_function: lower a single function declaration into MASM IR
# ---
# ctx:     lowering context
# node_id: AST node id for the NK_DECL_FUN node
# store:   AST node store
pub fun lower_function(ctx: *lctx.LowerContext, node_id: ast.NodeId, store: &ast.NodeStore) {
    if (ctx == nil) { ret; }

    val name_sid: ast.StrId = ast.fun_name(store, node_id);
    val name: str = ast.get_str(store, name_sid);
    if (name == nil) { ret; }

    val generics: ast.NodeId = ast.fun_generics(store, node_id);
    if (generics::u32 != ast.NODE_NIL::u32) { ret; }

    val res_func: Result[*fn.Function, str] =
        allocator.allocate[fn.Function](ctx.alloc, 1);
    if (!res_func.tag) { ret; }
    val func: *fn.Function = res_func.value.ok;
    @func = fn.func_init(ctx.alloc, name);
    ctx.func = func;

    ctx.vreg_next     = inst.VREG_START;
    ctx.local_count   = 0;
    ctx.stack_offset  = 0;
    ctx.label_counter = 0;
    ctx.ds.count      = 0;
    ctx.ds.mark       = 0;

    val res_entry: Result[*fn.Block, str] =
        allocator.allocate[fn.Block](ctx.alloc, 1);
    if (!res_entry.tag) { ret; }
    val entry_block: *fn.Block = res_entry.value.ok;
    @entry_block = fn.block_init("entry");
    fn.func_add_block(func, entry_block);
    ctx.block = entry_block;

    val params: ast.NodeSpan = ast.fun_params(store, node_id);
    var pi: u32 = 0;
    for (pi < params.len) {
        val param_nid: ast.NodeId = ast.get_extra(store, params.start + pi)::ast.NodeId;
        if (param_nid::u32 != ast.NODE_NIL::u32) {
            val pnode: &ast.Node = ast.get(store, param_nid);
            val p_payload: u32 = pnode.payload;
            val pname_sid: ast.StrId = ast.get_extra(store, p_payload)::ast.StrId;
            val pname: str = ast.get_str(store, pname_sid);

            val td_idx: u16 = 0;
            lctx.emit(ctx, inst.make_param(pi::u8, 8, td_idx));

            if (pname != nil) {
                lctx.push_local(ctx, pname, type.TYPE_NIL, 8, 8);
            }
        }
        pi = pi + 1;
    }

    val ret_type_node: ast.NodeId = ast.fun_ret_type(store, node_id);
    if (ret_type_node::u32 != ast.NODE_NIL::u32) {
        ctx.rs.ret_type = type.TYPE_NIL;
    } or {
        ctx.rs.ret_type = 0::type.TypeId;
    }

    val body: ast.NodeId = ast.fun_body(store, node_id);
    if (body::u32 != ast.NODE_NIL::u32) {
        stmt_mod.lower_stmt(ctx, body, store);
    }

    if (ctx.block != nil) {
        val bc: i32 = ctx.block.inst_count;
        var needs_ret: bool = true;
        if (bc > 0) {
            val last_op: u8 = ctx.block.insts[bc - 1].op;
            if (last_op == op.OP_RET || last_op == op.OP_JMP) {
                needs_ret = false;
            }
        }
        if (needs_ret) {
            lctx.emit(ctx, inst.make_ret());
        }
    }

    func.param_count = params.len::i32;
    module.builder_add_function(ctx.builder, func);
}
