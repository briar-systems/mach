use std.types.bool;
use std.types.option;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;

use ast:     mach.compiler.ast;
use symbol:  mach.compiler.symbol;
use type:      mach.compiler.type;
use target:  mach.compiler.target;
use ir:      mach.compiler.masm.ir;
use module:  mach.compiler.masm.module;
use data:    mach.compiler.masm.data;
use section: mach.compiler.masm.section;
use sym:     mach.compiler.masm.symbol;
use mangle:  mach.compiler.masm.mangle;
use abi:     mach.compiler.abi;
use lstmt:   mach.compiler.lower.stmt;
use lexpr:   mach.compiler.lower.expr;

use mach.compiler.lower;

# mach.compiler.lower.decl: function and global declaration lowering.
# ---
# handles function declarations (prologue, parameter placement via ABI,
# body lowering, epilogue) and global variable declarations.

# lower_module: lower all declarations in a module.
pub fun lower_module(ctx: *LowerContext, module: *ast.Node) {
    if (ctx == nil || module == nil) { ret; }

    # module root may be NODE_PROGRAM (from parser) or NODE_STMT_BLOCK;
    # both use block_stmt.stmts for their children.
    if (module.kind != ast.NODE_STMT_BLOCK && module.kind != ast.NODE_PROGRAM) { ret; }
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) { ret; }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            lower_decl(ctx, node);
        }
        i = i + 1;
    }
}

# lower_decl: dispatch on declaration kind.
fun lower_decl(ctx: *LowerContext, node: *ast.Node) {
    if (node == nil) { ret; }

    if (node.kind == ast.NODE_DECL_FUN) {
        lower_function(ctx, node);
    } or (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        lower_global_var(ctx, node);
    } or (node.kind == ast.NODE_DECL_PUB) {
        # pub wrapper — unwrap and lower the inner declaration
        if (node.info.wrapper.inner != nil) {
            lower_decl(ctx, node.info.wrapper.inner);
        }
    } or (node.kind == ast.NODE_COMPTIME_IF) {
        # comptime if — lower the taken branch (dead branches trimmed by sema)
        lower_comptime_if(ctx, node);
    }
}

# lower_func_inst: lower a generic function instantiation.
# the cloned AST has concrete types but still has the generics field set,
# so we bypass the generics check and use the pre-computed mangled name.
pub fun lower_func_inst(ctx: *LowerContext, node: *ast.Node,
                        mangled: str, sema_sym: *symbol.Symbol) {
    if (ctx == nil || node == nil || mangled == nil) { ret; }
    if (node.kind != ast.NODE_DECL_FUN) { ret; }

    val fn_type: *type.Type = node.type;
    if (fn_type == nil) { ret; }

    update_source_loc(ctx, node);
    reset_function_state(ctx);

    val fn_r: Result[*ir.Function, str] = ir.create_function(ctx.alloc, mangled);
    if (result_is_err[*ir.Function, str](fn_r)) { ret; }
    ctx.current_fn = result_unwrap_ok[*ir.Function, str](fn_r);

    ctx.fn_ret_type = fn_type.ret_type;
    ctx.fn_is_variadic = node.info.fun_decl.is_variadic;

    if (ctx.fn_ret_type != nil && !type.type_is_void(ctx.fn_ret_type)) {
        val ret_size: usize = type_size(ctx, ctx.fn_ret_type);
        val ret_align: usize = type.type_align(ctx.fn_ret_type);
        val is_float: bool = is_float_type(ctx.fn_ret_type);
        val is_agg: bool = type.type_is_record(ctx.fn_ret_type) ||
                           type.type_is_union(ctx.fn_ret_type);

        val a: *abi.ABI = ?ctx.target.abi;
        val ret_slot: abi.ParamSlot = a.classify_return(a.ctx, ret_size, ret_align,
                                                         is_float, is_agg);
        if (ret_slot.class == abi.CLASS_SRET) {
            ctx.fn_has_sret = true;
        }
    }

    start_block(ctx, mangled);
    lower_params(ctx, node);

    val body: *ast.Node = node.info.fun_decl.body;
    if (body != nil) {
        lstmt.lower_stmt(ctx, body);
    }

    if (ctx.fn_ret_type == nil || type.type_is_void(ctx.fn_ret_type)) {
        emit_ret(ctx);
    }

    if (ctx.current_fn != nil) {
        ctx.current_fn.local_size = ctx.stack_offset::usize;
        ctx.current_fn.call_area_size = ctx.max_call_arg_bytes::usize;
    }

    register_function_symbol(ctx, mangled, sema_sym);

    if (ctx.current_fn != nil) {
        module.builder_add_function(ctx.builder, ctx.current_fn);
    }
}

# lower_function: lower a function declaration.
fun lower_function(ctx: *LowerContext, node: *ast.Node) {
    if (node == nil || node.kind != ast.NODE_DECL_FUN) { ret; }

    val name: str = node.info.fun_decl.name;
    if (name == nil) { ret; }

    # skip generic functions (instantiated copies are lowered instead)
    if (node.info.fun_decl.generics != nil) { ret; }

    # get the mangled function name via symbol
    var mangled: str = name;
    var fn_sym: *symbol.Symbol = nil;
    if (node.symbol != nil) {
        fn_sym = node.symbol::*symbol.Symbol;
    }
    if (fn_sym == nil && ctx.symbols != nil) {
        val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(ctx.symbols, name);
        if (option_is_some[*symbol.Symbol](sym_opt)) {
            fn_sym = option_unwrap[*symbol.Symbol](sym_opt);
        }
    }
    if (fn_sym != nil) {
        if (fn_sym.export_name != nil) {
            mangled = fn_sym.export_name;
        } or {
            mangled = mangle.mangle(ctx.alloc, fn_sym.module_path, fn_sym.name);
        }
    }

    # get function type
    val fn_type: *type.Type = node.type;
    if (fn_type == nil) { ret; }

    # set source location for debug info
    update_source_loc(ctx, node);

    # reset per-function state
    reset_function_state(ctx);

    # create IR function
    val fn_r: Result[*ir.Function, str] = ir.create_function(ctx.alloc, mangled);
    if (result_is_err[*ir.Function, str](fn_r)) { ret; }
    ctx.current_fn = result_unwrap_ok[*ir.Function, str](fn_r);

    # determine return convention
    ctx.fn_ret_type = fn_type.ret_type;
    ctx.fn_is_variadic = node.info.fun_decl.is_variadic;

    if (ctx.fn_ret_type != nil && !type.type_is_void(ctx.fn_ret_type)) {
        val ret_size: usize = type_size(ctx, ctx.fn_ret_type);
        val ret_align: usize = type.type_align(ctx.fn_ret_type);
        val is_float: bool = is_float_type(ctx.fn_ret_type);
        val is_agg: bool = type.type_is_record(ctx.fn_ret_type) ||
                           type.type_is_union(ctx.fn_ret_type);

        val a: *abi.ABI = ?ctx.target.abi;
        val ret_slot: abi.ParamSlot = a.classify_return(a.ctx, ret_size, ret_align,
                                                         is_float, is_agg);
        if (ret_slot.class == abi.CLASS_SRET) {
            ctx.fn_has_sret = true;
        }
    }

    # create entry block
    start_block(ctx, mangled);

    # --- prologue: receive parameters via ABI ---
    lower_params(ctx, node);

    # --- lower function body ---
    val body: *ast.Node = node.info.fun_decl.body;
    if (body != nil) {
        lstmt.lower_stmt(ctx, body);
    }

    # --- epilogue: implicit return for void functions ---
    if (ctx.fn_ret_type == nil || type.type_is_void(ctx.fn_ret_type)) {
        emit_ret(ctx);
    }

    # record function local size and call area
    if (ctx.current_fn != nil) {
        ctx.current_fn.local_size = ctx.stack_offset::usize;
        ctx.current_fn.call_area_size = ctx.max_call_arg_bytes::usize;
    }

    # register the function as a symbol in MASM
    register_function_symbol(ctx, mangled, fn_sym);

    # register the IR function for ISel/encode
    if (ctx.current_fn != nil) {
        module.builder_add_function(ctx.builder, ctx.current_fn);
    }
}

# lower_params: lower function parameters using ABI classification.
# emits OP_PARAM for each parameter; the ABI lowering pass expands
# these to MOVs from physical registers or stack locations.
fun lower_params(ctx: *LowerContext, node: *ast.Node) {
    val params: *ast.List = node.info.fun_decl.params;
    if (params == nil) { ret; }

    val fn_type: *type.Type = node.type;
    if (fn_type == nil) { ret; }

    val a: *abi.ABI = ?ctx.target.abi;
    val psz: u8 = ctx.ptr_size;

    # if sret, emit OP_PARAM(index=-1) for the hidden pointer
    if (ctx.fn_has_sret) {
        val sret_vreg: ir.Operand = new_vreg(ctx, psz);
        emit(ctx, ir.OP_PARAM,
             ir.make_imm(psz::i64, psz),
             ir.make_imm(-1, 0),
             sret_vreg, ir.CC_NONE);
        ctx.sret_slot = ir.make_mem(sret_vreg.reg, -1, 1, 0, psz);
    }

    # variadic prologue: allocate register save area
    if (ctx.fn_is_variadic) {
        val layout: abi.VarargLayout = a.vararg_layout(a.ctx);

        # allocate save area on stack
        val align_mask: i64 = layout.save_area_align::i64 - 1;
        ctx.stack_offset = (ctx.stack_offset + layout.save_area_size::i64
                            + align_mask) & ~align_mask;
        ctx.va_reg_save_off = -ctx.stack_offset;

        # emit OP_PARAM(index=-2) for variadic register save
        # the ABI pass expands this to stores of all GP arg registers
        val save_base: ir.Operand = ir.make_mem(ir.VREG_FP, -1, 1,
                                                  ctx.va_reg_save_off, psz);
        emit(ctx, ir.OP_PARAM,
             ir.make_imm(layout.save_area_size::i64, layout.save_area_align::u8),
             ir.make_imm(-2, 0),
             save_base, ir.CC_NONE);
    }

    # classify params to track GP/FP/stack counts (needed for va_start)
    a.reset_stack(a.ctx);
    var gp_used: i32 = 0;
    var fp_used: i32 = 0;
    var stack_count: i32 = 0;
    if (ctx.fn_has_sret) { gp_used = 1; }

    var i: i32 = 0;
    for (i < params.count) {
        val param: *ast.Node = params.nodes[i];
        if (param == nil) { i = i + 1; cnt; }

        val pname: str = param.info.var_decl.name;
        val ptype: *type.Type = param.type;
        if (ptype == nil) { i = i + 1; cnt; }

        val psize: usize = type_size(ctx, ptype);
        val palign: usize = type.type_align(ptype);
        val is_float: bool = is_float_type(ptype);
        val is_agg: bool = type.type_is_record(ptype) || type.type_is_union(ptype);

        # classify to track register usage counts
        val slot: abi.ParamSlot = a.classify_param(a.ctx, i, psize, palign,
                                                    is_float, is_agg,
                                                    gp_used, fp_used);
        if (slot.class == abi.CLASS_GP || slot.class == abi.CLASS_BYREF) {
            gp_used = gp_used + 1;
        } or (slot.class == abi.CLASS_GP2) {
            gp_used = gp_used + 2;
        } or (slot.class == abi.CLASS_FP) {
            fp_used = fp_used + 1;
        } or (slot.class == abi.CLASS_STACK) {
            stack_count = stack_count + 1;
        }

        # allocate local variable for the parameter
        val lv: *LocalVar = local_add(ctx, pname, ptype, psize);
        if (lv == nil) { i = i + 1; cnt; }
        lv.is_param = true;

        val dst: ir.Operand = local_operand(lv, psz);

        var flags: u8 = 0;
        if (is_float) { flags = flags | ir.ABI_FLAG_FLOAT; }
        if (is_agg)   { flags = flags | ir.ABI_FLAG_AGG; }

        # emit abstract parameter receive
        emit(ctx, ir.OP_PARAM,
             ir.make_imm(psize::i64, palign::u8),
             ir.make_imm(i::i64, flags),
             dst, ir.CC_NONE);

        if (ctx.current_fn != nil) {
            ctx.current_fn.param_count = ctx.current_fn.param_count + 1;
        }

        i = i + 1;
    }

    # record variadic param counts for va_start
    if (ctx.fn_is_variadic) {
        ctx.va_named_gp = gp_used;
        ctx.va_named_fp = fp_used;
        ctx.va_named_stack = stack_count;
    }
}

# lower_global_var: lower a global variable or constant declaration.
fun lower_global_var(ctx: *LowerContext, node: *ast.Node) {
    if (node == nil) { ret; }

    val name: str = node.info.var_decl.name;
    val init: *ast.Node = node.info.var_decl.init;
    val vtype: *type.Type = node.type;
    if (name == nil || vtype == nil) { ret; }

    var mangled: str = name;
    var var_sym: *symbol.Symbol = nil;
    if (node.symbol != nil) {
        var_sym = node.symbol::*symbol.Symbol;
    }
    if (var_sym == nil && ctx.symbols != nil) {
        val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(ctx.symbols, name);
        if (option_is_some[*symbol.Symbol](sym_opt)) {
            var_sym = option_unwrap[*symbol.Symbol](sym_opt);
        }
    }
    if (var_sym != nil) {
        if (var_sym.export_name != nil) {
            mangled = var_sym.export_name;
        } or {
            mangled = mangle.mangle(ctx.alloc, var_sym.module_path, var_sym.name);
        }
    }
    val vsize: usize = type_size(ctx, vtype);

    # determine binding
    var binding: sym.SymBinding = sym.BIND_LOCAL;
    if (var_sym != nil && var_sym.is_public) {
        binding = sym.BIND_GLOBAL;
    }

    # determine section: data for initialized, bss for uninitialized
    if (init != nil && init.kind == ast.NODE_EXPR_LIT_INT) {
        val value: i64 = parse_int_str(init.info.lit_expr.text);
        val buf: *u8 = int_to_bytes(ctx.alloc, value, vsize);
        if (buf != nil) {
            module.builder_add_data_decl(ctx.builder, data.make_bytes(mangled, section.SEC_DATA,
                binding, buf, vsize::u32, 1));
        }
    } or (init != nil && init.kind == ast.NODE_EXPR_LIT_STR) {
        # string literal global: string bytes in .rodata, pointer+relocation in .data
        val text: str = init.info.lit_expr.text;

        # 1. build string bytes for .rodata DataDecl
        val str_label: str = make_str_label(ctx.alloc, ctx.str_counter);
        ctx.str_counter = ctx.str_counter + 1;
        if (str_label == nil) { ret; }

        # count string bytes
        var str_len: u32 = 0;
        if (text != nil && text[0] == '"') {
            var ci: usize = 1;
            for (text[ci] != 0 && text[ci] != '"') {
                if (text[ci] == '\\' && text[ci + 1] != 0) { ci = ci + 2; }
                or { ci = ci + 1; }
                str_len = str_len + 1;
            }
        }
        str_len = str_len + 1;  # null terminator

        val str_buf_r: Result[*u8, allocator.AllocError] =
            allocator.allocator_alloc[u8](ctx.alloc, str_len::usize);
        if (result_is_err[*u8, allocator.AllocError](str_buf_r)) { ret; }
        val str_buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](str_buf_r);

        var spos: u32 = 0;
        if (text != nil && text[0] == '"') {
            var ti: usize = 1;
            for (text[ti] != 0 && text[ti] != '"') {
                if (text[ti] == '\\' && text[ti + 1] != 0) {
                    if (text[ti + 1] == 'n')  { str_buf[spos] = '\n'; }
                    or (text[ti + 1] == 't')  { str_buf[spos] = '\t'; }
                    or (text[ti + 1] == 'r')  { str_buf[spos] = '\r'; }
                    or (text[ti + 1] == '0')  { str_buf[spos] = 0; }
                    or (text[ti + 1] == '\\') { str_buf[spos] = '\\'; }
                    or (text[ti + 1] == '"')  { str_buf[spos] = '"'; }
                    or { str_buf[spos] = text[ti + 1]; }
                    ti = ti + 2;
                } or {
                    str_buf[spos] = text[ti];
                    ti = ti + 1;
                }
                spos = spos + 1;
            }
        }
        str_buf[spos] = 0;

        # register string data in .rodata
        module.builder_add_data_decl(ctx.builder, data.make_bytes(str_label, section.SEC_RODATA,
            sym.BIND_LOCAL, str_buf, str_len, 1));

        # 2. build pointer placeholder in .data with relocation
        val psz: usize = ctx.target.ptr_size;
        val ptr_buf_r: Result[*u8, allocator.AllocError] =
            allocator.allocator_alloc[u8](ctx.alloc, psz);
        if (result_is_err[*u8, allocator.AllocError](ptr_buf_r)) { ret; }
        val ptr_buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](ptr_buf_r);
        # zero-fill the pointer placeholder
        var zi: usize = 0;
        for (zi < psz) { ptr_buf[zi] = 0; zi = zi + 1; }

        var decl: data.DataDecl = data.make_bytes(mangled, section.SEC_DATA,
            binding, ptr_buf, psz::u32, 1);

        # add relocation pointing to the string data
        var reloc_kind: section.RelocKind = section.RELOC_ABS64;
        if (psz == 4) { reloc_kind = section.RELOC_ABS32; }
        data.decl_add_reloc(ctx.alloc, ?decl, 0, str_label, reloc_kind, 0);

        module.builder_add_data_decl(ctx.builder, decl);
    } or (init != nil && init.kind == ast.NODE_EXPR_LIT_FLOAT) {
        val fl_text: str = init.info.lit_expr.text;
        val fl_value: f64 = parse_float(fl_text);
        val buf: *u8 = float_to_bytes(ctx.alloc, fl_value, vsize);
        if (buf != nil) {
            module.builder_add_data_decl(ctx.builder, data.make_bytes(mangled, section.SEC_DATA,
                binding, buf, vsize::u32, 1));
        }
    } or (init != nil && init.kind == ast.NODE_EXPR_LIT_CHAR) {
        val ch_text: str = init.info.lit_expr.text;
        var ch_val: i64 = 0;
        if (ch_text != nil) { ch_val = ch_text[0]::i64; }
        val buf: *u8 = int_to_bytes(ctx.alloc, ch_val, vsize);
        if (buf != nil) {
            module.builder_add_data_decl(ctx.builder, data.make_bytes(mangled, section.SEC_DATA,
                binding, buf, vsize::u32, 1));
        }
    } or (init != nil && init.kind == ast.NODE_EXPR_LIT_BOOL) {
        val bl_text: str = init.info.lit_expr.text;
        var bl_val: i64 = 0;
        if (bl_text != nil && str_equals(bl_text, "true")) { bl_val = 1; }
        val buf: *u8 = int_to_bytes(ctx.alloc, bl_val, vsize);
        if (buf != nil) {
            module.builder_add_data_decl(ctx.builder, data.make_bytes(mangled, section.SEC_DATA,
                binding, buf, vsize::u32, 1));
        }
    } or (init != nil && init.kind == ast.NODE_EXPR_LIT_NIL) {
        val buf: *u8 = int_to_bytes(ctx.alloc, 0, vsize);
        if (buf != nil) {
            module.builder_add_data_decl(ctx.builder, data.make_bytes(mangled, section.SEC_DATA,
                binding, buf, vsize::u32, 1));
        }
    } or (init != nil) {
        # fallback: try constant folding for expressions like `1024 / 4`
        var fb_folded: i64 = 0;
        if (lexpr.try_fold_const_int(init, ?fb_folded)) {
            val buf: *u8 = int_to_bytes(ctx.alloc, fb_folded, vsize);
            if (buf != nil) {
                module.builder_add_data_decl(ctx.builder, data.make_bytes(mangled, section.SEC_DATA,
                    binding, buf, vsize::u32, 1));
            }
        } or {
            # non-foldable initializer — emit to .bss and warn
            print.eprint("[lower] warning: non-constant global initializer for '");
            print.eprint(name);
            print.eprint("', zero-initialized\n");
            module.builder_add_data_decl(ctx.builder, data.make_zero(mangled, vsize::u32, binding, 1));
        }
    } or {
        # uninitialized — goes to .bss
        module.builder_add_data_decl(ctx.builder, data.make_zero(mangled, vsize::u32, binding, 1));
    }
}

# lower_comptime_if: lower a comptime if statement at module scope.
fun lower_comptime_if(ctx: *LowerContext, node: *ast.Node) {
    if (node == nil) { ret; }

    # comptime if has already been resolved by sema
    # lower the taken branch
    val taken: *ast.Node = node.info.cond_stmt.body;
    if (taken != nil && taken.kind == ast.NODE_STMT_BLOCK) {
        val stmts: *ast.List = taken.info.block_stmt.stmts;
        if (stmts != nil) {
            var i: i32 = 0;
            for (i < stmts.count) {
                if (stmts.nodes[i] != nil) {
                    lower_decl(ctx, stmts.nodes[i]);
                }
                i = i + 1;
            }
        }
    }
}

# --- helpers ---

# int_to_bytes: allocate a buffer and write an integer value in little-endian.
fun int_to_bytes(alloc: *allocator.Allocator, value: i64, size: usize) *u8 {
    if (alloc == nil || size == 0) { ret nil; }
    val r: Result[*u8, allocator.AllocError] =
        allocator.allocator_alloc[u8](alloc, size);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    val v: u64 = value::u64;
    if (size >= 1) { buf[0] = (v & 255)::u8; }
    if (size >= 2) { buf[1] = ((v >> 8) & 255)::u8; }
    if (size >= 4) {
        buf[2] = ((v >> 16) & 255)::u8;
        buf[3] = ((v >> 24) & 255)::u8;
    }
    if (size >= 8) {
        buf[4] = ((v >> 32) & 255)::u8;
        buf[5] = ((v >> 40) & 255)::u8;
        buf[6] = ((v >> 48) & 255)::u8;
        buf[7] = ((v >> 56) & 255)::u8;
    }
    ret buf;
}

# float_to_bytes: allocate a buffer and write float bits in little-endian.
fun float_to_bytes(alloc: *allocator.Allocator, value: f64, size: usize) *u8 {
    if (alloc == nil || size == 0) { ret nil; }
    val r: Result[*u8, allocator.AllocError] =
        allocator.allocator_alloc[u8](alloc, size);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](r);

    if (size == 4) {
        val f32_val: f32 = value::f32;
        val bits: u32 = f32_val::u32;
        buf[0] = (bits & 255)::u8;
        buf[1] = ((bits >> 8) & 255)::u8;
        buf[2] = ((bits >> 16) & 255)::u8;
        buf[3] = ((bits >> 24) & 255)::u8;
    } or {
        val bits: u64 = value::u64;
        buf[0] = (bits & 255)::u8;
        buf[1] = ((bits >> 8) & 255)::u8;
        buf[2] = ((bits >> 16) & 255)::u8;
        buf[3] = ((bits >> 24) & 255)::u8;
        buf[4] = ((bits >> 32) & 255)::u8;
        buf[5] = ((bits >> 40) & 255)::u8;
        buf[6] = ((bits >> 48) & 255)::u8;
        buf[7] = ((bits >> 56) & 255)::u8;
    }
    ret buf;
}

fun register_function_symbol(ctx: *LowerContext, name: str, sema_sym: *symbol.Symbol) {
    var binding: sym.SymBinding = sym.BIND_LOCAL;
    if (sema_sym != nil && (sema_sym.is_public || sema_sym.export_name != nil)) {
        binding = sym.BIND_GLOBAL;
    }

    var decl: data.DataDecl = data.make_func(name, binding);
    decl.src_file = ctx.debug_file_path;
    decl.src_line = ctx.current_line;
    module.builder_add_data_decl(ctx.builder, decl);
}

