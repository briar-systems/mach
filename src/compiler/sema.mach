use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use print: std.print;
use fs: std.filesystem;
use mem: std.memory;
use path: std.types.path;

use ast:    mach.compiler.ast;
use utilfs: mach.util.filesystem;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use token:  mach.compiler.token;
use lexer:  mach.compiler.lexer;
use parser: mach.compiler.parser;
use comptime: mach.compiler.comptime;
use config: mach.config.config;

# mach.compiler.sema: semantic analysis.
# ---
# performs type checking, symbol resolution, and semantic validation on the AST.

# SemaError: a semantic analysis error.
# ---
# pos:       position in source where error occurred
# line:      1-based line number
# col:       1-based column number
# file_path: path to the source file
# message:   error description
pub rec SemaError {
    pos:       i32;
    line:      i32;
    col:       i32;
    file_path: str;
    message:   str;
}

# ModuleAlias: tracks an aliased import (use alias: module.path;)
# ---
# alias:  the alias name (e.g., "cli" from "use cli: mach.cli.main;")
# module: pointer to the loaded module
# next:   linked list of aliases
pub rec ModuleAlias {
    alias:  str;
    module: *SemaModule;
    next:   *ModuleAlias;
}

# ModuleImport: tracks a direct import (use module.path;)
# ---
# path:   the module path (e.g., "mach.cli.main")
# module: pointer to the loaded module
# next:   linked list of imports
pub rec ModuleImport {
    path:   str;
    module: *SemaModule;
    next:   *ModuleImport;
}

# CachedInstantiation: tracks a previously instantiated generic type.
# ---
# generic_args: array of type arguments
# arg_count:    number of type arguments
# result_type:  the instantiated concrete type
# next:         linked list of cached instantiations
pub rec CachedInstantiation {
    generic_args: **ty.Type;
    arg_count:    i32;
    result_type:  *ty.Type;
    next:         *CachedInstantiation;
}

# GenericInstance: tracks a generic type with its parameter bindings.
# ---
# generic_type:  the generic type being instantiated
# param_names:   array of parameter names
# param_count:   number of parameters
# bindings:      array of bound types
# binding_count: number of bindings
# instantiated_type: the resulting concrete type
pub rec GenericInstance {
    generic_type:      *ty.Type;
    param_names:       *str;
    param_count:       i32;
    bindings:          **ty.Type;
    binding_count:     i32;
    instantiated_type: *ty.Type;
}

# MethodInstantiation: tracks a concrete instantiation of a generic method.
# ---
# func_ast:       original function AST node (shared across instantiations)
# mangled_name:   unique mangled name for this instantiation
# func_type:      instantiated function type (concrete param/return types)
# receiver_type:  concrete instantiated receiver type
# param_names:    generic param names (e.g., ["T", "E"])
# param_types:    concrete types bound to params (e.g., [*Section, str])
# param_count:    number of type parameters
# origin_module:  module where the method is defined
# next:           linked list of instantiations
# FunctionInstantiation: tracks a concrete instantiation of a generic free function.
# ---
# func_ast:       original function AST node (shared across instantiations)
# mangled_name:   unique mangled name for this instantiation
# func_type:      instantiated function type (concrete param/return types)
# param_names:    generic param names (e.g., ["T", "E"])
# param_types:    concrete types bound to params (e.g., [*Section, str])
# param_count:    number of type parameters
# origin_module:  module where the function is defined
# next:           linked list of instantiations
pub rec FunctionInstantiation {
    func_ast:      *ast.Node;
    mangled_name:  str;
    func_type:     *ty.Type;
    param_names:   *str;
    param_types:   **ty.Type;
    param_count:   i32;
    origin_module: *SemaModule;
    next:          *FunctionInstantiation;
}

pub rec MethodInstantiation {
    func_ast:      *ast.Node;
    mangled_name:  str;
    func_type:     *ty.Type;
    receiver_type: *ty.Type;
    param_names:   *str;
    param_types:   **ty.Type;
    param_count:   i32;
    origin_module: *SemaModule;
    next:          *MethodInstantiation;
}

# InstMapEntry: a single entry in the instantiation dedup hash table.
# ---
# key:  mangled name string (nil if slot is empty)
# val:  persistent mangled name pointer (returned on dedup hit)
pub rec InstMapEntry {
    key: str;
    value: str;
}

# INST_MAP_SIZE: number of buckets in the instantiation hash table.
# must be a power of two for fast masking.
val INST_MAP_SIZE: i32 = 256;

# InstMap: open-addressing hash table for O(1) instantiation dedup.
# ---
# entries: flat array of INST_MAP_SIZE buckets
# count:   number of occupied slots
pub rec InstMap {
    entries: *InstMapEntry;
    count:   i32;
}

# SemaModule: represents a loaded module during semantic analysis.
# ---
# path:        the module path (e.g., "mach.cli.main")
# file_path:   the file system path to the source file
# source:      source text for the module
# ast:         the module's AST
# is_analyzed: whether this module has been fully analyzed
# next:        linked list of modules
# aliases:     list of aliases for this module
# imports:     list of imports from this module
# table:       symbol table for this module
pub rec SemaModule {
    path:        str;
    file_path:   str;
    source:      str;
    ast:         *ast.Node;
    is_analyzed: bool;
    next:        *SemaModule;
    aliases:     *ModuleAlias;
    imports:     *ModuleImport;
    table:       *symbol.Table;
}

# Scope: represents a lexical scope during semantic analysis.
# ---
# symbols: symbol table for this scope
# parent:  parent scope (nil for global scope)
# depth:   nesting depth (0 for global)
pub rec Scope {
    table:  *symbol.Table;
    parent: *Scope;
    depth:  i32;
}

# Sema: the semantic analyzer.
# ---
# alloc:           allocator for all sema allocations
# types:           type context for creating types
# symbols:         global symbol table
# current_scope:   current lexical scope
# root_scope:      root (global) scope
# current_fn:      current function being analyzed
# current_fn_ret:  current function's return type
# modules:         list of loaded modules
# module_count:    number of modules loaded
# module_roots:    array of module root paths for lookup
# root_count:      number of module roots
# project_id:      project identifier for module path prefix
# src_root:        source root directory path
# dep_root:        dependency root directory path
# deps:            array of dependency configurations
# dep_count:       number of dependencies
# generic_cache:   cache of generic instantiations
# generic_stack:   stack of currently resolving generics (for cycle detection)
# errors:          array of semantic errors
# error_count:     number of errors
# error_cap:       capacity of errors array
# had_error:       whether any error occurred
# current_module:  currently analyzing module
# file_path:       path to current file
# source:          source text for error messages
# comptime_ctx:    compile-time context for comptime evaluation
pub rec Sema {
    alloc:           *allocator.Allocator;
    types:           *ty.TypeContext;
    symbols:         *symbol.Table;
    current_scope:   *Scope;
    root_scope:      *Scope;
    current_fn:      *ast.Node;
    current_fn_ret:  *ty.Type;
    modules:         *SemaModule;
    module_count:    i32;
    module_roots:    *str;
    root_count:      i32;
    project_id:      str;
    src_root:        str;
    dep_root:        str;
    deps:            *config.Dep;
    dep_count:       i32;
    generic_cache:   *CachedInstantiation;
    generic_stack:   *GenericInstance;
    generic_stack_count: i32;
    errors:          *SemaError;
    error_count:     i32;
    error_cap:       i32;
    had_error:       bool;
    current_module:  *SemaModule;
    module_path:     str;   # current module's dot-separated path (for symbol mangling)
    file_path:       str;
    source:          str;
    comptime_ctx:    *comptime.ComptimeContext;
    method_insts:    *MethodInstantiation;    # linked list of method instantiations
    method_inst_count: i32;
    func_insts:      *FunctionInstantiation;  # linked list of generic function instantiations
    func_inst_count: i32;
    func_inst_map:   InstMap;                 # hash table for O(1) function instantiation dedup
    method_inst_map: InstMap;                 # hash table for O(1) method instantiation dedup
}

# --- initialization and cleanup ---

# init: initialize a new semantic analyzer.
# ---
# alloc: allocator for sema allocations
# ret:   initialized sema context
pub fun init(alloc: *allocator.Allocator) Sema {
    var sema: Sema;
    sema.alloc = alloc;
    
    # create type context using init_context - returns TypeContext by value
    val types_res: Result[ty.TypeContext, str] = ty.init_context(alloc);
    if (types_res.is_ok()) {
        # allocate space for TypeContext and copy the result
        val ctx_res: Result[*ty.TypeContext, allocator.AllocError] = alloc.alloc[ty.TypeContext](1);
        if (ctx_res.is_ok()) {
            sema.types = ctx_res.unwrap_ok();
            @sema.types = types_res.unwrap_ok();
        } or {
            sema.types = nil;
        }
    } or {
        sema.types = nil;
    }
    
    sema.symbols = nil;
    sema.current_scope = nil;
    sema.root_scope = nil;
    sema.current_fn = nil;
    sema.current_fn_ret = nil;
    sema.modules = nil;
    sema.module_count = 0;
    sema.module_roots = nil;
    sema.root_count = 0;
    sema.project_id = nil;
    sema.src_root = nil;
    sema.dep_root = nil;
    sema.deps = nil;
    sema.dep_count = 0;
    sema.generic_cache = nil;
    sema.generic_stack = nil;
    sema.generic_stack_count = 0;
    sema.errors = nil;
    sema.error_count = 0;
    sema.error_cap = 0;
    sema.had_error = false;
    sema.current_module = nil;
    sema.module_path = nil;
    sema.file_path = nil;
    sema.source = nil;
    sema.comptime_ctx = nil;
    sema.method_insts = nil;
    sema.method_inst_count = 0;
    sema.func_insts = nil;
    sema.func_inst_count = 0;
    sema.func_inst_map.entries = nil;
    sema.func_inst_map.count = 0;
    sema.method_inst_map.entries = nil;
    sema.method_inst_map.count = 0;
    ret sema;
}

# --- instantiation hash table helpers ---

# inst_map_hash: FNV-1a hash of a string, returning a bucket index.
fun inst_map_hash(s: str) i32 {
    if (s == nil) {
        ret 0;
    }
    var h: u64 = 14695981039346656037;  # FNV offset basis
    val len: usize = s.len();
    var i: usize = 0;
    for (i < len) {
        h = h ^ s[i]::u64;
        h = h * 1099511628211;  # FNV prime
        i = i + 1;
    }
    ret (h & (INST_MAP_SIZE - 1)::u64)::i32;
}

# inst_map_get: look up a mangled name in the hash table.
# returns the persistent name if found, nil otherwise.
fun inst_map_get(m: *InstMap, key: str) str {
    if (m == nil || m.entries == nil || key == nil) {
        ret nil;
    }
    var idx: i32 = inst_map_hash(key);
    var probes: i32 = 0;
    for (probes < INST_MAP_SIZE) {
        val e: *InstMapEntry = ?m.entries[idx];
        if (e.key == nil) {
            ret nil;
        }
        if (e.key.equals(key)) {
            ret e.value;
        }
        idx = (idx + 1) & (INST_MAP_SIZE - 1);
        probes = probes + 1;
    }
    ret nil;
}

# inst_map_put: insert a mangled name into the hash table.
# allocates the backing array on first use.
fun inst_map_put(m: *InstMap, alloc: *allocator.Allocator, key: str, val_name: str) {
    if (m == nil || alloc == nil || key == nil) {
        ret;
    }
    # lazy-allocate the entries array
    if (m.entries == nil) {
        val res: Result[*InstMapEntry, allocator.AllocError] = alloc.zalloc[InstMapEntry](INST_MAP_SIZE::usize);
        if (res.is_err()) {
            ret;
        }
        m.entries = res.unwrap_ok();
    }
    var idx: i32 = inst_map_hash(key);
    var probes: i32 = 0;
    for (probes < INST_MAP_SIZE) {
        val e: *InstMapEntry = ?m.entries[idx];
        if (e.key == nil) {
            e.key = key;
            e.value = val_name;
            m.count = m.count + 1;
            ret;
        }
        if (e.key.equals(key)) {
            ret;  # already present
        }
        idx = (idx + 1) & (INST_MAP_SIZE - 1);
        probes = probes + 1;
    }
}

# --- helper functions ---

# pos_to_line: convert a byte position to a 1-based line number.
# ---
# source: full source text
# pos:    byte position (0-based)
# ret:    1-based line number
fun pos_to_line(source: str, pos: i32) i32 {
    if (source == nil || pos < 0) {
        ret 1;
    }

    var line: i32 = 1;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    for (i < pos && i < len) {
        if (source[i] == '\n') {
            line = line + 1;
        }
        i = i + 1;
    }

    ret line;
}

# pos_to_col: convert a byte position to a 1-based column number.
# ---
# source: full source text
# pos:    byte position (0-based)
# ret:    1-based column number
fun pos_to_col(source: str, pos: i32) i32 {
    if (source == nil || pos < 0) {
        ret 1;
    }

    var col: i32 = 1;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    for (i < pos && i < len) {
        if (source[i] == '\n') {
            col = 1;
        } or {
            col = col + 1;
        }
        i = i + 1;
    }

    ret col;
}

# report_error: record a semantic error at a token position.
# ---
# sema:    analyzer context
# tok:     token where error occurred
# message: error message
# ret:     none
fun report_error(sema: *Sema, tok: token.Token, message: str) {
    if (sema == nil) {
        ret;
    }

    # grow errors array if needed
    if (sema.error_count >= sema.error_cap) {
        var new_cap: i32 = 8;
        if (sema.error_cap > 0) {
            new_cap = sema.error_cap * 2;
        }

        val r: Result[*SemaError, allocator.AllocError] = sema.alloc.resize[SemaError](
            sema.errors,
            sema.error_cap::u64,
            new_cap::u64
        );

        if (r.is_err()) {
            ret;
        }

        sema.errors = r.unwrap_ok();
        sema.error_cap = new_cap;
    }

    val idx: i32 = sema.error_count;
    sema.errors[idx].pos = tok.pos;
    sema.errors[idx].line = pos_to_line(sema.source, tok.pos);
    sema.errors[idx].col = pos_to_col(sema.source, tok.pos);
    sema.errors[idx].file_path = sema.file_path;
    sema.errors[idx].message = message;
    sema.error_count = sema.error_count + 1;
}

# report_error_node: record a semantic error at a node's token.
# ---
# sema:    analyzer context
# node:    node where error occurred
# message: error message
# ret:     none
fun report_error_node(sema: *Sema, node: *ast.Node, message: str) {
    if (node == nil) {
        ret;
    }
    report_error(sema, node.tok, message);
}

# debug_type_kind: get a string name for a type kind.
# ---
# kind: type kind
# ret:  string name
fun debug_type_kind(kind: ty.TypeKind) str {
    if (kind == ty.TY_VOID) { ret "void"; }
    if (kind == ty.TY_BOOL) { ret "bool"; }
    if (kind == ty.TY_U8) { ret "u8"; }
    if (kind == ty.TY_U16) { ret "u16"; }
    if (kind == ty.TY_U32) { ret "u32"; }
    if (kind == ty.TY_U64) { ret "u64"; }
    if (kind == ty.TY_I8) { ret "i8"; }
    if (kind == ty.TY_I16) { ret "i16"; }
    if (kind == ty.TY_I32) { ret "i32"; }
    if (kind == ty.TY_I64) { ret "i64"; }
    if (kind == ty.TY_F32) { ret "f32"; }
    if (kind == ty.TY_F64) { ret "f64"; }
    if (kind == ty.TY_PTR) { ret "ptr"; }
    if (kind == ty.TY_USIZE) { ret "usize"; }
    if (kind == ty.TY_ISIZE) { ret "isize"; }
    if (kind == ty.TY_POINTER) { ret "pointer"; }
    if (kind == ty.TY_ARRAY) { ret "array"; }
    if (kind == ty.TY_RECORD) { ret "record"; }
    if (kind == ty.TY_UNION) { ret "union"; }
    if (kind == ty.TY_FUN) { ret "fun"; }
    if (kind == ty.TY_STR) { ret "str"; }
    if (kind == ty.TY_NIL) { ret "nil"; }
    if (kind == ty.TY_ERROR) { ret "error"; }
    if (kind == ty.TY_GENERIC) { ret "generic"; }
    ret "unknown";
}

# debug_print_type: print a type for debugging.
# ---
# t: type to print
# ret: none
fun debug_print_type(t: *ty.Type) {
    if (t == nil) {
        print.eprint("nil");
        ret;
    }
    print.eprint(debug_type_kind(t.kind));
    if (t.name != nil) {
        print.eprint("(");
        print.eprint(t.name);
        print.eprint(")");
    }
    if (t.kind == ty.TY_POINTER && t.inner != nil) {
        if (t.is_mutable) {
            print.eprint("*");
        } or {
            print.eprint("ref");
        }
        debug_print_type(t.inner);
    }
}

# --- error handling ---

# get_error_count: get the number of semantic errors.
# ---
# sema: analyzer context
# ret:  error count
pub fun get_error_count(sema: *Sema) i32 {
    if (sema == nil) {
        ret 0;
    }
    ret sema.error_count;
}

# has_errors: check if there are any semantic errors.
# ---
# sema: analyzer context
# ret:  true if errors exist
pub fun has_errors(sema: *Sema) bool {
    if (sema == nil) {
        ret false;
    }
    ret sema.error_count > 0;
}

# get_error: get error at index.
# ---
# sema: analyzer context
# idx:  error index
# ret:  error or nil if invalid index
pub fun get_error(sema: *Sema, idx: i32) *SemaError {
    if (sema == nil || sema.errors == nil || idx < 0 || idx >= sema.error_count) {
        ret nil;
    }
    ret ?sema.errors[idx];
}

# format_error: format an error message with location info.
# ---
# sema: analyzer context
# e:    error to format
# ret:  error message string
pub fun format_error(sema: *Sema, e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    ret e.message;
}

# print_i32: print an i32 value to stderr.
# ---
# n: number to print
# ret: none
fun print_i32(n: i32) {
    if (n < 0) {
        print.eprint("-");
        print_i32(-n);
        ret;
    }

    if (n == 0) {
        print.eprint("0");
        ret;
    }

    # build digits in reverse order into buffer
    var buf: [16]u8;
    var len: i32 = 0;
    var num: i32 = n;

    for (num > 0) {
        buf[len] = (num % 10)::u8 + 48;
        num = num / 10;
        len = len + 1;
    }

    # reverse the digits in place
    var i: i32 = 0;
    var j: i32 = len - 1;
    for (i < j) {
        val tmp: u8 = buf[i];
        buf[i] = buf[j];
        buf[j] = tmp;
        i = i + 1;
        j = j - 1;
    }

    # print the digits
    i = 0;
    for (i < len) {
        var s: [2]u8;
        s[0] = buf[i];
        s[1] = 0;
        print.eprint((?s[0])::str);
        i = i + 1;
    }
}

# print_ptr: print a pointer value in hex.
fun print_ptr(p: *u8) {
    print.eprint("0x");
    val addr: u64 = p::u64;
    var nibbles: [16]u8;
    var i: i32 = 0;
    var n: u64 = addr;
    for (i < 16) {
        val d: u8 = (n % 16)::u8;
        if (d < 10) {
            nibbles[15 - i] = d + 48;
        } or {
            nibbles[15 - i] = d - 10 + 97;
        }
        n = n / 16;
        i = i + 1;
    }
    i = 0;
    for (i < 16) {
        var s: [2]u8;
        s[0] = nibbles[i];
        s[1] = 0;
        print.eprint((?s[0])::str);
        i = i + 1;
    }
}

# print_error_line: print a source line with a caret at the column.
fun print_error_line(source: str, line: i32, col: i32) {
    if (source == nil || line < 1) {
        ret;
    }

    var current_line: i32 = 1;
    var line_start: i32 = 0;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    for (i < len && current_line < line) {
        if (source[i] == '\n') {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) {
        ret;
    }

    var line_end: i32 = line_start;
    for (line_end < len && source[line_end] != '\n') {
        line_end = line_end + 1;
    }

    # print line number and content
    print.eprint("  ");
    print_i32(line);
    print.eprint(" | ");
    i = line_start;
    for (i < line_end) {
        var ch: [2]u8;
        ch[0] = source[i];
        ch[1] = 0;
        print.eprint((?ch[0])::str);
        i = i + 1;
    }
    print.eprintln("");

    # caret line
    print.eprint("    | ");
    var c: i32 = 1;
    for (c < col) {
        print.eprint(" ");
        c = c + 1;
    }
    print.eprintln("^");
}

# print_errors: print all errors to stderr.
# ---
# sema: analyzer context
# ret:  none
pub fun print_errors(sema: *Sema) {
    if (sema == nil || sema.errors == nil || sema.error_count == 0) {
        ret;
    }

    var i: i32 = 0;
    for (i < sema.error_count) {
        val e: *SemaError = ?sema.errors[i];

        print.eprint("error: ");
        if (e.message != nil) {
            print.eprintln(e.message);
        } or {
            print.eprintln("(null message)");
        }

        if (e.file_path != nil) {
            print.eprint(e.file_path);
            print.eprint(":");
        } or {
            print.eprint("<unknown>:");
        }

        print_i32(e.line);
        print.eprint(":");
        print_i32(e.col);
        print.eprintln("");

        print_error_line(sema.source, e.line, e.col);
        i = i + 1;
    }

    print_i32(sema.error_count);
    print.eprintln(" semantic error(s) found");
}

# get_source_line: extract a specific line from source text.
# ---
# source: full source text
# line:   1-based line number
# ret:    the line content or nil if not found
pub fun get_source_line(source: str, line: i32) str {
    if (source == nil || line < 1) {
        ret nil;
    }

    # find the start of the requested line
    var current_line: i32 = 1;
    var line_start: i32 = 0;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    # find start of target line
    for (i < len && current_line < line) {
        if (source[i] == '\n') {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) {
        ret nil;
    }

    # find end of line
    var line_end: i32 = line_start;
    for (line_end < len && source[line_end] != '\n') {
        line_end = line_end + 1;
    }

    # calculate length
    val line_len: i32 = line_end - line_start;
    if (line_len < 0) {
        ret nil;
    }

    # return pointer to line start (Mach strings track length separately)
    # for now, just return the start pointer - the caller needs to know the length
    # this is a limitation until we have better string slicing
    ret (source + line_start::usize)::str;
}

# get_error_location: get error location as "line:col" string.
# ---
# e: error
# ret: location string or nil
pub fun get_error_location(e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    # would format as "line:col" but need string formatting
    ret nil;
}

# get_error_col: get the column number of an error.
# ---
# e: error
# ret: 1-based column number
pub fun get_error_col(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.col;
}

# get_error_line: get the line number of an error.
# ---
# e: error
# ret: 1-based line number
pub fun get_error_line(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.line;
}

# get_error_message: get the error message.
# ---
# e: error
# ret: message string
pub fun get_error_message(e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    ret e.message;
}

# get_error_pos: get the byte position of an error.
# ---
# e: error
# ret: 0-based byte position
pub fun get_error_pos(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.pos;
}

# is_error: check if an error represents an actual error (not nil).
# ---
# e: error
# ret: true if valid error
pub fun is_error(e: *SemaError) bool {
    ret e != nil;
}

# --- scope management ---

# push_scope: create and enter a new lexical scope.
# ---
# sema: analyzer context
# ret:  Ok(true) on success, Err(str) on failure
pub fun push_scope(sema: *Sema) Result[bool, str] {
    if (sema == nil || sema.alloc == nil) {
        ret err[bool, str]("invalid sema context");
    }

    val scope_res: Result[*Scope, allocator.AllocError] = sema.alloc.alloc[Scope](1);
    if (scope_res.is_err()) {
        ret err[bool, str]("out of memory");
    }

    val scope: *Scope = scope_res.unwrap_ok();
    scope.parent = sema.current_scope;
    if (sema.current_scope != nil) {
        scope.depth = sema.current_scope.depth + 1;
    } or {
        scope.depth = 0;
    }
    
    # create symbol table for this scope
    val table_res: Result[*symbol.Table, allocator.AllocError] = sema.alloc.alloc[symbol.Table](1);
    if (table_res.is_err()) {
        sema.alloc.free[Scope](scope, 1);
        ret err[bool, str]("out of memory");
    }

    scope.table = table_res.unwrap_ok();
    # table is a symbol.Table which has alloc, current, and root fields
    # the table was already initialized by alloc, so we just need to set up scope linkage
    if (sema.current_scope != nil) {
        scope.table.current = sema.current_scope.table.current;
    }

    sema.current_scope = scope;
    
    # if this is the first scope, it's the root
    if (sema.root_scope == nil) {
        sema.root_scope = scope;
    }

    ret ok[bool, str](true);
}

# pop_scope: exit the current lexical scope.
# ---
# sema: analyzer context
# ret:  none
pub fun pop_scope(sema: *Sema) {
    if (sema == nil || sema.current_scope == nil) {
        ret;
    }

    val scope: *Scope = sema.current_scope;
    sema.current_scope = scope.parent;

    # note: we don't free the scope - it may still be referenced
    # a full implementation would use an arena or reference counting
}

# current_scope_depth: get the current scope nesting depth.
# ---
# sema: analyzer context
# ret:  scope depth (0 = global)
pub fun current_scope_depth(sema: *Sema) i32 {
    if (sema == nil || sema.current_scope == nil) {
        ret 0;
    }
    ret sema.current_scope.depth;
}

# get_current_scope: get the current scope.
# ---
# sema: analyzer context
# ret:  current scope or nil
pub fun get_current_scope(sema: *Sema) *Scope {
    if (sema == nil) {
        ret nil;
    }
    ret sema.current_scope;
}

# get_root_scope: get the root (global) scope.
# ---
# sema: analyzer context
# ret:  root scope or nil
pub fun get_root_scope(sema: *Sema) *Scope {
    if (sema == nil) {
        ret nil;
    }
    ret sema.root_scope;
}

# get_symbol_table: get the global symbol table.
# ---
# sema: analyzer context
# ret:  symbol table or nil
pub fun get_symbol_table(sema: *Sema) *symbol.Table {
    if (sema == nil) {
        ret nil;
    }
    ret sema.symbols;
}

# get_type_context: get the type context.
# ---
# sema: analyzer context
# ret:  type context or nil
pub fun get_type_context(sema: *Sema) *ty.TypeContext {
    if (sema == nil) {
        ret nil;
    }
    ret sema.types;
}

# get_loaded_modules: get all loaded modules.
# ---
# sema:      analyzer context
# out_mods:  array to fill with module pointers (array of *SemaModule)
# max_count: maximum number of modules to return
# ret:       number of modules written to out_mods
pub fun get_loaded_modules(sema: *Sema, out_mods: **SemaModule, max_count: i32) i32 {
    if (sema == nil || out_mods == nil || max_count <= 0) {
        ret 0;
    }

    var count: i32 = 0;
    var mod: *SemaModule = sema.modules;
    for (mod != nil && count < max_count) {
        # write pointer to array slot
        out_mods[count] = mod;
        count = count + 1;
        mod = mod.next;
    }

    ret count;
}

# --- semantic analysis (continues with remaining analysis functions) ---

# analyze: perform semantic analysis on the AST.
# ---
# sema:    analyzer context
# module:  module root node
# file:    source file path
# src:     source text
# cctx:    compile-time context
# ret:     Ok(true) if analysis succeeds, Err(str) if errors occurred
pub fun analyze(sema: *Sema, module: *ast.Node, file: str, src: str, cctx: *comptime.ComptimeContext) Result[bool, str] {
    if (sema == nil || module == nil) {
        ret err[bool, str]("invalid arguments");
    }

    sema.file_path = file;
    sema.source = src;
    sema.comptime_ctx = cctx;

    # set main module path for symbol mangling
    if (sema.module_path == nil) {
        if (sema.project_id != nil) {
            sema.module_path = sema.project_id;
        } or {
            sema.module_path = "main";
        }
    }

    # reset error state
    sema.error_count = 0;
    sema.had_error = false;

    # create symbol table for main module if not already present
    if (sema.symbols == nil) {
        val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
        if (table_res.is_err()) {
            ret err[bool, str]("failed to create symbol table");
        }

        val table_ptr_res: Result[*symbol.Table, allocator.AllocError] = sema.alloc.alloc[symbol.Table](1);
        if (table_ptr_res.is_err()) {
            ret err[bool, str]("failed to allocate symbol table");
        }
        val table_ptr: *symbol.Table = table_ptr_res.unwrap_ok();
        @table_ptr = table_res.unwrap_ok();
        sema.symbols = table_ptr;
    }

    # create a SemaModule for the main module so aliases/imports are tracked
    if (sema.current_module == nil) {
        val main_mod_res: Result[*SemaModule, allocator.AllocError] = sema.alloc.alloc[SemaModule](1);
        if (main_mod_res.is_ok()) {
            val main_mod: *SemaModule = main_mod_res.unwrap_ok();
            main_mod.path = sema.module_path;
            main_mod.file_path = file;
            main_mod.source = src;
            main_mod.ast = module;
            main_mod.is_analyzed = false;
            main_mod.next = nil;
            main_mod.aliases = nil;
            main_mod.imports = nil;
            main_mod.table = sema.symbols;
            sema.current_module = main_mod;
        }
    }

    # create root scope
    val push_res: Result[bool, str] = push_scope(sema);
    if (push_res.is_err()) {
        ret err[bool, str]("failed to create root scope");
    }

    # pass 1: collect all declarations and add to symbol table
    collect_declarations(sema, module);

    # pass 2: resolve types and build type information
    resolve_types(sema, module);

    # pass 3: analyze function bodies
    analyze_functions(sema, module);

    # cleanup
    for (sema.current_scope != nil) {
        pop_scope(sema);
    }

    # check for errors
    if (sema.error_count > 0) {
        # print errors before returning
        print_errors(sema);
        ret err[bool, str]("semantic errors found");
    }

    ret ok[bool, str](true);
}

# collect_declarations: pass 1 - collect all top-level declarations.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
fun collect_declarations(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # function declaration
        if (node.kind == ast.NODE_DECL_FUN) {
            collect_function_decl(sema, node);
        }

        # variable/constant declaration
        if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
            collect_var_decl(sema, node);
        }

        # type declaration
        if (node.kind == ast.NODE_DECL_DEF) {
            collect_type_decl(sema, node);
        }

        # external declaration
        if (node.kind == ast.NODE_DECL_EXT) {
            collect_ext_decl(sema, node);
        }

        # record declaration
        if (node.kind == ast.NODE_DECL_REC) {
            collect_rec_decl(sema, node);
        }

        # union declaration
        if (node.kind == ast.NODE_DECL_UNI) {
            collect_uni_decl(sema, node);
        }

        # use declaration (import)
        if (node.kind == ast.NODE_DECL_USE) {
            process_use_decl(sema, node);
        }

        # comptime if ($if)
        if (node.kind == ast.NODE_COMPTIME_IF) {
            process_comptime_if(sema, node, true);
        }

        # pub wrapper - process inner declaration
        if (node.kind == ast.NODE_DECL_PUB) {
            process_pub_decl(sema, node);
        }

        i = i + 1;
    }
}

# process_pub_decl: process a pub-wrapped declaration.
# ---
# sema: analyzer context
# node: NODE_DECL_PUB wrapper node
# ret:  none
fun process_pub_decl(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) { ret; }
    val inner: *ast.Node = node.info.wrapper.inner;
    if (inner == nil) { ret; }

    if (inner.kind == ast.NODE_DECL_FUN) {
        collect_function_decl(sema, inner);
        # set is_public - use qualified name for methods
        var sym_key: str = inner.info.fun_decl.name;
        if (sym_key != nil && inner.info.fun_decl.receiver != nil) {
            val recv_name: str = get_receiver_type_name(inner.info.fun_decl.receiver);
            if (recv_name != nil) {
                val rlen: usize = recv_name.len();
                val nlen: usize = sym_key.len();
                val qres: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](rlen + 1 + nlen + 1);
                if (qres.is_ok()) {
                    val qbuf: *u8 = qres.unwrap_ok();
                    var qi: usize = 0;
                    for (qi < rlen) { qbuf[qi] = recv_name[qi]; qi = qi + 1; }
                    qbuf[qi] = '.'; qi = qi + 1;
                    var qj: usize = 0;
                    for (qj < nlen) { qbuf[qi] = sym_key[qj]; qi = qi + 1; qj = qj + 1; }
                    qbuf[qi] = 0;
                    sym_key = qbuf::str;
                }
            }
        }
        if (sym_key != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(sym_key);
            if (sym_opt.is_some()) { sym_opt.unwrap().is_public = true; }
        }
    }
    if (inner.kind == ast.NODE_DECL_VAR || inner.kind == ast.NODE_DECL_VAL) {
        collect_var_decl(sema, inner);
        val name: str = inner.info.var_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) { sym_opt.unwrap().is_public = true; }
        }
    }
    if (inner.kind == ast.NODE_DECL_DEF) {
        collect_type_decl(sema, inner);
        val name: str = inner.info.def_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) { sym_opt.unwrap().is_public = true; }
        }
    }
    if (inner.kind == ast.NODE_DECL_EXT) {
        collect_ext_decl(sema, inner);
        val name: str = inner.info.ext_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) { sym_opt.unwrap().is_public = true; }
        }
    }
    if (inner.kind == ast.NODE_DECL_REC) {
        collect_rec_decl(sema, inner);
        val name: str = inner.info.type_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) { sym_opt.unwrap().is_public = true; }
        }
    }
    if (inner.kind == ast.NODE_DECL_UNI) {
        collect_uni_decl(sema, inner);
        val name: str = inner.info.type_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) { sym_opt.unwrap().is_public = true; }
        }
    }
}

# process_use_decl: process a use declaration (import).
# ---
# sema: analyzer context
# node: use declaration node
# ret:  none
fun process_use_decl(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind != ast.NODE_DECL_USE) {
        ret;
    }

    # get module path from node
    val module_path: str = node.info.use_decl.path;
    if (module_path == nil) {
        report_error_node(sema, node, "use statement has null module path");
        ret;
    }

    # check for alias
    var alias: str = nil;
    if (node.info.use_decl.alias != nil) {
        alias = node.info.use_decl.alias;
    }

    # if no module resolution configured, skip (single-file mode)
    if (!has_module_resolution(sema)) {
        ret;
    }

    # load and analyze the module
    val loaded_mod: *SemaModule = load_module(sema, module_path);
    if (loaded_mod == nil) {
        # module not found - this is an error
        report_error_node(sema, node, "failed to load module");
        ret;
    }

    # register the import in the current module
    if (sema.current_module == nil) {
        ret;
    }

    if (alias != nil) {
        # aliased import: use alias: module.path;
        val alias_res: Result[*ModuleAlias, allocator.AllocError] = sema.alloc.alloc[ModuleAlias](1);
        if (alias_res.is_err()) {
            ret;
        }

        val ma: *ModuleAlias = alias_res.unwrap_ok();
        ma.alias = alias;
        ma.module = loaded_mod;
        ma.next = sema.current_module.aliases;
        sema.current_module.aliases = ma;
    } or {
        # direct import: use module.path;
        val import_res: Result[*ModuleImport, allocator.AllocError] = sema.alloc.alloc[ModuleImport](1);
        if (import_res.is_err()) {
            ret;
        }

        val imp: *ModuleImport = import_res.unwrap_ok();
        imp.path = module_path;
        imp.module = loaded_mod;
        imp.next = sema.current_module.imports;
        sema.current_module.imports = imp;
    }
}

# process_comptime_if: process a $if compile-time conditional.
# ---
# sema:     analyzer context
# node:     comptime_if node
# is_decl:  true if processing top-level declarations, false for statements
# ret:      none
fun process_comptime_if(sema: *Sema, node: *ast.Node, is_decl: bool) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind != ast.NODE_COMPTIME_IF && node.kind != ast.NODE_COMPTIME_OR) {
        ret;
    }

    # get condition
    val cond: *ast.Node = node.info.cond_stmt.cond;

    # evaluate condition
    var cond_result: bool = false;
    if (cond != nil && sema.comptime_ctx != nil) {
        val eval_res: Result[bool, str] = comptime.eval_condition(sema.comptime_ctx, cond);
        if (eval_res.is_ok()) {
            cond_result = eval_res.unwrap_ok();
        } or {
            # evaluation failed - report error and skip
            report_error_node(sema, cond, "failed to evaluate compile-time condition");
            ret;
        }
    } or (cond == nil && node.kind == ast.NODE_COMPTIME_OR) {
        # $or without condition - always true (else branch)
        cond_result = true;
    }

    if (cond_result) {
        # condition is true - process the body
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            if (is_decl) {
                # process top-level declarations in the body block
                process_comptime_if_body_decls(sema, body);
            } or {
                # process statements in the body block
                analyze_stmt(sema, body);
            }
        }
    } or {
        # condition is false - try $or chain
        val or_node: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_node != nil) {
            process_comptime_if(sema, or_node, is_decl);
        }
    }
}

# process_comptime_if_body_decls: process declarations inside a $if body.
# ---
# sema: analyzer context
# body: block node containing declarations
# ret:  none
fun process_comptime_if_body_decls(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    # body should be a block with a list of nodes
    if (body.kind != ast.NODE_STMT_BLOCK) {
        # might be a single declaration
        if (body.kind == ast.NODE_DECL_USE) {
            process_use_decl(sema, body);
        }
        if (body.kind == ast.NODE_DECL_FUN) {
            collect_function_decl(sema, body);
        }
        if (body.kind == ast.NODE_DECL_VAR || body.kind == ast.NODE_DECL_VAL) {
            collect_var_decl(sema, body);
        }
        if (body.kind == ast.NODE_DECL_DEF) {
            collect_type_decl(sema, body);
        }
        if (body.kind == ast.NODE_DECL_EXT) {
            collect_ext_decl(sema, body);
        }
        if (body.kind == ast.NODE_COMPTIME_IF) {
            process_comptime_if(sema, body, true);
        }
        if (body.kind == ast.NODE_DECL_PUB) {
            process_pub_decl(sema, body);
        }
        ret;
    }

    # get declarations from block
    val decls: *ast.List = body.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        if (node.kind == ast.NODE_DECL_USE) {
            process_use_decl(sema, node);
        }
        if (node.kind == ast.NODE_DECL_FUN) {
            collect_function_decl(sema, node);
        }
        if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
            collect_var_decl(sema, node);
        }
        if (node.kind == ast.NODE_DECL_DEF) {
            collect_type_decl(sema, node);
        }
        if (node.kind == ast.NODE_DECL_EXT) {
            collect_ext_decl(sema, node);
        }
        if (node.kind == ast.NODE_COMPTIME_IF) {
            process_comptime_if(sema, node, true);
        }
        if (node.kind == ast.NODE_DECL_PUB) {
            process_pub_decl(sema, node);
        }

        i = i + 1;
    }
}

# resolve_comptime_if_types: resolve types in a $if taken branch.
# ---
# sema: analyzer context
# body: taken branch body node
# ret:  none
fun resolve_comptime_if_types(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    # body should be a block node
    if (body.kind != ast.NODE_STMT_BLOCK) {
        # single declaration
        resolve_node_type(sema, body);
        ret;
    }

    # get declarations from block
    val decls: *ast.List = body.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            resolve_node_type(sema, node);
        }
        i = i + 1;
    }
}

# get_receiver_type_name: extract base type name from receiver (unwrapping pointers).
# ---
# receiver: receiver parameter node
# ret:      base type name or nil
fun get_receiver_type_name(receiver: *ast.Node) str {
    if (receiver == nil) {
        ret nil;
    }

    # receiver is NODE_PARAM, its type is in field_decl.type_node
    var recv_type: *ast.Node = receiver.info.field_decl.type_node;
    if (recv_type == nil) {
        ret nil;
    }

    # unwrap pointer/ref types
    for (recv_type != nil && (recv_type.kind == ast.NODE_TYPE_PTR || recv_type.kind == ast.NODE_TYPE_REF)) {
        recv_type = recv_type.info.type_ptr.inner;
    }

    if (recv_type != nil && recv_type.kind == ast.NODE_TYPE_NAME) {
        ret recv_type.info.type_name.path;
    }

    ret nil;
}

# collect_function_decl: collect a function declaration.
# ---
# sema: analyzer context
# node: function declaration node
# ret:  none
fun collect_function_decl(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.fun_decl.name;
    if (name == nil) {
        report_error_node(sema, node, "function has no name");
        ret;
    }

    # for methods, build qualified name "ReceiverType.methodName"
    var symbol_key: str = name;
    if (node.info.fun_decl.receiver != nil) {
        val recv_type_name: str = get_receiver_type_name(node.info.fun_decl.receiver);
        if (recv_type_name != nil) {
            # build "ReceiverType.methodName"
            val recv_len: usize = recv_type_name.len();
            val name_len: usize = name.len();
            val total_len: usize = recv_len + 1 + name_len + 1;  # +1 for dot, +1 for null
            
            val alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total_len);
            if (alloc_res.is_ok()) {
                val buf: *u8 = alloc_res.unwrap_ok();
                var i: usize = 0;
                # copy receiver type name
                for (i < recv_len) {
                    buf[i] = recv_type_name[i];
                    i = i + 1;
                }
                buf[i] = '.';
                i = i + 1;
                # copy method name
                var j: usize = 0;
                for (j < name_len) {
                    buf[i] = name[j];
                    i = i + 1;
                    j = j + 1;
                }
                buf[i] = 0;  # null terminator
                symbol_key = buf::str;
            }
        }
    }

    # check for duplicate in current scope only
    val existing_opt: Option[*symbol.Symbol] = sema.symbols.lookup(symbol_key);
    if (existing_opt.is_some()) {
        report_error_node(sema, node, "duplicate function declaration");
        ret;
    }

    # create symbol (type will be resolved later)
    val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(symbol_key, symbol.SYM_FUN);
    if (sym_res.is_err()) {
        print.eprint("[collect_function_decl] failed to create symbol for: ");
        print.eprintln(symbol_key);
        print.eprint("[collect_function_decl] error: ");
        print.eprintln(sym_res.unwrap_err());
        report_error_node(sema, node, "failed to create symbol");
        ret;
    }

    val sym: *symbol.Symbol = sym_res.unwrap_ok();
    sym.decl_node = node;
    sym.module_path = sema.module_path;

    # check for generics
    if (node.info.fun_decl.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.info.fun_decl.generics;
    }
}

# collect_var_decl: collect a variable declaration.
# ---
# sema: analyzer context
# node: variable declaration node
# ret:  none
fun collect_var_decl(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.var_decl.name;
    if (name == nil) {
        report_error_node(sema, node, "variable has no name");
        ret;
    }

    # check for duplicate
    val existing_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (existing_opt.is_some()) {
        report_error_node(sema, node, "duplicate variable declaration");
        ret;
    }

    # create symbol
    var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
    if (node.kind == ast.NODE_DECL_VAR) {
        sym_kind = symbol.SYM_VAR;
    }
    val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(name, sym_kind);
    if (sym_res.is_err()) {
        report_error_node(sema, node, "failed to create symbol");
        ret;
    }

    val sym: *symbol.Symbol = sym_res.unwrap_ok();
    sym.decl_node = node;
    sym.module_path = sema.module_path;
}

