use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use print: std.print;
use fs: std.filesystem;
use mem: std.memory;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use token:  mach.compiler.token;
use lexer:  mach.compiler.lexer;
use parser: mach.compiler.parser;
use comptime: mach.compiler.comptime;
use config: mach.config.config;

# mach.compiler.sema: semantic analysis.
# ---
# performs type checking, symbol resolution, and semantic validation on the AST.

# SemaError: a semantic analysis error.
# ---
# pos:       position in source where error occurred
# line:      1-based line number
# col:       1-based column number
# file_path: path to the source file
# message:   error description
pub rec SemaError {
    pos:       i32;
    line:      i32;
    col:       i32;
    file_path: str;
    message:   str;
}

# ModuleAlias: tracks an aliased import (use alias: module.path;)
# ---
# alias:  the alias name (e.g., "cli" from "use cli: mach.cli.main;")
# module: pointer to the loaded module
# next:   linked list of aliases
pub rec ModuleAlias {
    alias:  str;
    module: *SemaModule;
    next:   *ModuleAlias;
}

# ModuleImport: tracks an unaliased import (use module.path;)
# ---
# module: pointer to the loaded module
# next:   linked list of imports
pub rec ModuleImport {
    module: *SemaModule;
    next:   *ModuleImport;
}

# SemaModule: represents a loaded module.
# ---
# module_path: fully qualified module path (e.g., "mach.cli.main")
# file_path:   file system path to the source file
# source:      source text (kept for error reporting)
# ast:         parsed AST
# table:       module's symbol table
# imports:     this module's unaliased imports (use foo.bar;)
# aliases:     this module's aliased imports (use a: foo.bar;)
# analyzed:    true if module has been fully analyzed
# next:        linked list of all loaded modules
pub rec SemaModule {
    module_path: str;
    file_path:   str;
    source:      str;
    ast:         *ast.Node;
    table:       *symbol.Table;
    imports:     *ModuleImport;
    aliases:     *ModuleAlias;
    analyzed:    bool;
    next:        *SemaModule;
}

# counter for generating unique anonymous type names
var anon_type_counter: i32 = 0;

# Sema: semantic analyzer context.
# ---
# alloc:          allocator for analysis
# symbols:        symbol table
# types:          type context
# module_path:    current module path
# file_path:      path to current file
# source:         source text for error reporting
# errors:         list of errors
# error_count:    number of errors
# error_cap:      allocated capacity
# current_fn:     current function being analyzed (for return type checking)
# loop_depth:     nesting depth of loops (for break/continue checking)
# current_module: current module being analyzed
# modules:        linked list of all loaded modules
# project_root:   root directory of the project (for resolving module paths)
# project_id:     project id (module prefix for main project)
# src_root:       path to src directory
# dep_root:       path to dep directory
# deps:           dependency list from config
# dep_count:      number of deps
pub rec Sema {
    alloc:          *allocator.Allocator;
    symbols:        symbol.Table;
    types:          ty.TypeContext;
    module_path:    str;
    file_path:      str;
    source:         str;
    errors:         *SemaError;
    error_count:    i32;
    error_cap:      i32;
    current_fn:     *symbol.Symbol;
    current_fn_ret: *ty.Type;
    loop_depth:     i32;
    current_module: *SemaModule;
    modules:        *SemaModule;
    project_root:   str;
    project_id:     str;
    src_root:       str;
    dep_root:       str;
    deps:           *config.Dep;
    dep_count:      i32;
    current_table:  *symbol.Table;  # module-scoped symbol table (switched per-module)
}

# init: create a new semantic analyzer.
# ---
# alloc:       allocator to use
# module_path: module path for the entry file
# ret:         Ok(Sema) on success, Err(str) on failure
pub fun init(alloc: *allocator.Allocator, module_path: str) Result[Sema, str] {
    if (alloc == nil) {
        ret err[Sema, str]("allocator is nil");
    }

    val sym_res: Result[symbol.Table, str] = symbol.init(alloc);
    if (sym_res.is_err()) {
        ret err[Sema, str](sym_res.unwrap_err());
    }

    val type_res: Result[ty.TypeContext, str] = ty.init_context(alloc);
    if (type_res.is_err()) {
        ret err[Sema, str](type_res.unwrap_err());
    }

    var sema: Sema;
    sema.alloc = alloc;
    sema.symbols = sym_res.unwrap_ok();
    sema.types = type_res.unwrap_ok();
    sema.module_path = module_path;
    sema.file_path = nil;
    sema.source = nil;
    sema.errors = nil;
    sema.error_count = 0;
    sema.error_cap = 0;
    sema.current_fn = nil;
    sema.current_fn_ret = nil;
    sema.loop_depth = 0;
    sema.current_module = nil;
    sema.modules = nil;
    sema.project_root = nil;
    sema.project_id = nil;
    sema.src_root = nil;
    sema.dep_root = nil;
    sema.deps = nil;
    sema.dep_count = 0;
    sema.current_table = nil;  # will be set to ?sema.symbols for main module

    ret ok[Sema, str](sema);
}

# deinit: free all resources associated with the analyzer.
# ---
# sema: analyzer to clean up
pub fun deinit(sema: *Sema) {
    if (sema == nil) {
        ret;
    }

    sema.symbols.deinit();
    ty.deinit_context(?sema.types);

    if (sema.errors != nil && sema.alloc != nil) {
        sema.alloc.free[SemaError](sema.errors, sema.error_cap::usize);
    }
}

# set_file_context: set the current file context for error reporting.
# ---
# sema:      analyzer
# file_path: path to the file being analyzed
# source:    source text of the file
pub fun set_file_context(sema: *Sema, file_path: str, source: str) {
    if (sema == nil) {
        ret;
    }

    sema.file_path = file_path;
    sema.source = source;
}

# --- error reporting ---

# pos_to_line: compute 1-based line number from byte position in source.
# ---
# source: source text
# pos:    byte offset into source
# ret:    1-based line number
fun pos_to_line(source: str, pos: i32) i32 {
    if (source == nil || pos < 0) {
        ret 1;
    }

    var line: i32 = 1;
    var i: i32 = 0;
    for (i < pos) {
        if (source[i] == 10) {  # newline character
            line = line + 1;
        }
        i = i + 1;
    }
    ret line;
}

# report_error: record a semantic error at a token position.
fun report_error(sema: *Sema, tok: token.Token, message: str) {
    if (sema == nil) {
        ret;
    }

    # grow errors array if needed
    if (sema.error_count >= sema.error_cap) {
        var new_cap: i32 = 8;
        if (sema.error_cap > 0) {
            new_cap = sema.error_cap * 2;
        }

        val r: Result[*SemaError, allocator.AllocError] = sema.alloc.resize[SemaError](
            sema.errors,
            sema.error_cap::u64,
            new_cap::u64
        );

        if (r.is_err()) {
            ret;
        }

        sema.errors = r.unwrap_ok();
        sema.error_cap = new_cap;
    }

    val idx: i32 = sema.error_count;
    sema.errors[idx].pos = tok.pos;
    sema.errors[idx].line = pos_to_line(sema.source, tok.pos);
    sema.errors[idx].col = 0;
    sema.errors[idx].file_path = sema.file_path;
    sema.errors[idx].message = message;
    sema.error_count = sema.error_count + 1;
}

# report_error_node: record a semantic error at a node's token.
fun report_error_node(sema: *Sema, node: *ast.Node, message: str) {
    if (node == nil) {
        ret;
    }
    report_error(sema, node.tok, message);
}

# debug_type_kind: get a string name for a type kind.
fun debug_type_kind(kind: ty.TypeKind) str {
    if (kind == ty.TY_VOID) { ret "void"; }
    if (kind == ty.TY_BOOL) { ret "bool"; }
    if (kind == ty.TY_U8) { ret "u8"; }
    if (kind == ty.TY_U16) { ret "u16"; }
    if (kind == ty.TY_U32) { ret "u32"; }
    if (kind == ty.TY_U64) { ret "u64"; }
    if (kind == ty.TY_I8) { ret "i8"; }
    if (kind == ty.TY_I16) { ret "i16"; }
    if (kind == ty.TY_I32) { ret "i32"; }
    if (kind == ty.TY_I64) { ret "i64"; }
    if (kind == ty.TY_F32) { ret "f32"; }
    if (kind == ty.TY_F64) { ret "f64"; }
    if (kind == ty.TY_PTR) { ret "ptr"; }
    if (kind == ty.TY_USIZE) { ret "usize"; }
    if (kind == ty.TY_ISIZE) { ret "isize"; }
    if (kind == ty.TY_POINTER) { ret "pointer"; }
    if (kind == ty.TY_ARRAY) { ret "array"; }
    if (kind == ty.TY_RECORD) { ret "record"; }
    if (kind == ty.TY_UNION) { ret "union"; }
    if (kind == ty.TY_FUN) { ret "fun"; }
    if (kind == ty.TY_STR) { ret "str"; }
    if (kind == ty.TY_NIL) { ret "nil"; }
    if (kind == ty.TY_ERROR) { ret "error"; }
    if (kind == ty.TY_GENERIC) { ret "generic"; }
    ret "unknown";
}

# debug_print_type: print a type for debugging.
fun debug_print_type(t: *ty.Type) {
    if (t == nil) {
        print.eprint("nil");
        ret;
    }
    print.eprint(debug_type_kind(t.kind));
    if (t.name != nil) {
        print.eprint("(");
        print.eprint(t.name);
        print.eprint(")");
    }
    if (t.kind == ty.TY_POINTER && t.inner != nil) {
        if (t.is_mutable) {
            print.eprint("*");
        } or {
            print.eprint("ref");
        }
        debug_print_type(t.inner);
    }
}

# get_error_count: get the number of semantic errors.
pub fun get_error_count(sema: *Sema) i32 {
    if (sema == nil) {
        ret 0;
    }
    ret sema.error_count;
}

# has_errors: check if any errors occurred.
pub fun has_errors(sema: *Sema) bool {
    ret get_error_count(sema) > 0;
}

# get_symbol_table: get the symbol table.
pub fun get_symbol_table(sema: *Sema) *symbol.Table {
    if (sema == nil) {
        ret nil;
    }
    ret ?sema.symbols;
}

# get_type_context: get the type context.
pub fun get_type_context(sema: *Sema) *ty.TypeContext {
    if (sema == nil) {
        ret nil;
    }
    ret ?sema.types;
}

# get_receiver_type_name: extract the base type name from a receiver type node.
# ---
# handles pointers/refs like *Pair[T, U] -> "Pair"
# handles generic instantiations like Pair[T, U] -> "Pair"
fun get_receiver_type_name(type_node: *ast.Node) str {
    if (type_node == nil) {
        ret nil;
    }

    var node: *ast.Node = type_node;

    # unwrap pointers and refs
    for (node != nil && (node.kind == ast.NODE_TYPE_PTR || node.kind == ast.NODE_TYPE_REF)) {
        node = node.children;
    }

    if (node == nil) {
        ret nil;
    }

    # for type names, extract the name
    if (node.kind == ast.NODE_TYPE_NAME) {
        val name: str = node.data::str;
        if (name != nil) {
            # strip any module path - get just the type name
            # for now just return the full path, module resolution will handle it
            ret name;
        }
    }

    ret nil;
}

# build_method_symbol_name: create a qualified name for a method.
# ---
# receiver_type_name: name of the receiver type (e.g., "Option")
# method_name:        name of the method (e.g., "unwrap")
# alloc:              allocator for the result string
# ret:                qualified name "ReceiverType.methodName" or nil on failure
fun build_method_symbol_name(sema: *Sema, receiver_type_name: str, method_name: str) str {
    if (sema == nil || receiver_type_name == nil || method_name == nil) {
        ret nil;
    }

    val recv_len: usize = receiver_type_name.len();
    val method_len: usize = method_name.len();
    val total_len: usize = recv_len + 1 + method_len + 1;  # "ReceiverType.methodName\0"

    val buf_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total_len);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy receiver type name
    var i: usize = 0;
    for (i < recv_len) {
        buf[pos] = receiver_type_name[i];
        pos = pos + 1;
        i = i + 1;
    }

    # add dot separator
    buf[pos] = 46;  # '.'
    pos = pos + 1;

    # copy method name
    i = 0;
    for (i < method_len) {
        buf[pos] = method_name[i];
        pos = pos + 1;
        i = i + 1;
    }

    # null terminate
    buf[pos] = 0;

    ret buf::str;
}


# --- type resolution ---

# resolve_type: resolve an AST type node to a Type.
# ---
# sema:      analyzer
# type_node: AST node representing a type
# ret:       resolved Type or nil on failure
pub fun resolve_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    if (sema == nil || type_node == nil) {
        ret nil;
    }

    val ctx: *ty.TypeContext = ?sema.types;
    val kind: ast.NodeKind = type_node.kind;

    # type_name: primitive or user-defined type
    if (kind == ast.NODE_TYPE_NAME) {
        ret resolve_type_name(sema, type_node);
    }

    # type_ptr: *T (mutable pointer)
    if (kind == ast.NODE_TYPE_PTR) {
        val inner: *ty.Type = resolve_type(sema, type_node.children);
        if (inner == nil) {
            ret nil;
        }
        val res: Result[*ty.Type, str] = ty.pointer_type(ctx, inner, true);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to create pointer type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # type_ref: &T (immutable pointer)
    if (kind == ast.NODE_TYPE_REF) {
        val inner: *ty.Type = resolve_type(sema, type_node.children);
        if (inner == nil) {
            ret nil;
        }
        val res: Result[*ty.Type, str] = ty.pointer_type(ctx, inner, false);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to create ref type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # type_array: [N]T
    if (kind == ast.NODE_TYPE_ARRAY) {
        val elem_type: *ty.Type = resolve_type(sema, type_node.children);
        if (elem_type == nil) {
            ret nil;
        }
        # array length stored in data as expression node
        val size_node: *ast.Node = type_node.data::*ast.Node;
        if (size_node == nil || size_node.kind != ast.NODE_EXPR_LIT_INT) {
            report_error_node(sema, type_node, "array size must be a constant integer");
            ret nil;
        }
        val len: usize = size_node.get_int_value()::usize;
        val res: Result[*ty.Type, str] = ty.array_type(ctx, elem_type, len);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to create array type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # type_fun: fun(...) T
    if (kind == ast.NODE_TYPE_FUN) {
        ret resolve_function_type(sema, type_node);
    }

    # type_rec: anonymous record type
    if (kind == ast.NODE_TYPE_REC) {
        ret resolve_anon_record_type(sema, type_node);
    }

    # type_uni: anonymous union type
    if (kind == ast.NODE_TYPE_UNI) {
        ret resolve_anon_union_type(sema, type_node);
    }

    report_error_node(sema, type_node, "unsupported type syntax");
    ret nil;
}

# resolve_anon_record_type: resolve an anonymous record type expression.
fun resolve_anon_record_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # fields are stored in children as *List (cast from *Node)
    val fields_list: *ast.List = type_node.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        # empty anonymous record
        val res: Result[*ty.Type, str] = ty.record_type(ctx, nil, nil, 0);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    val field_count: i32 = fields_list.count;

    # allocate Field array
    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, type_node, "failed to allocate fields");
        ret nil;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    # resolve each field
    var offset: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        val field_name: str = field_node.get_name();
        val ft_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (ft_node != nil) {
            field_type = resolve_type(sema, ft_node);
        }

        if (field_type == nil) {
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        var field_align: usize = 1;
        var field_size: usize = 0;
        if (field_type != nil) {
            field_align = field_type.align;
            field_size = field_type.size;
            if (field_align > max_align) {
                max_align = field_align;
            }
        }

        if (field_align > 0) {
            offset = (offset + field_align - 1) & ~(field_align - 1);
        }

        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = offset;

        offset = offset + field_size;
        i = i + 1;
    }

    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    val res: Result[*ty.Type, str] = ty.record_type(ctx, nil, fields, field_count);
    if (res.is_err()) {
        report_error_node(sema, type_node, "failed to create anonymous record type");
        ret nil;
    }

    val rec_type: *ty.Type = res.unwrap_ok();
    rec_type.size = offset;
    rec_type.align = max_align;

    ret rec_type;
}

# resolve_anon_union_type: resolve an anonymous union type expression.
fun resolve_anon_union_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # variants are stored in children as *List
    val fields_list: *ast.List = type_node.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        val res: Result[*ty.Type, str] = ty.union_type(ctx, nil, nil, 0);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    val field_count: i32 = fields_list.count;

    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, type_node, "failed to allocate variants");
        ret nil;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    var max_size: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        val field_name: str = field_node.get_name();
        val ft_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (ft_node != nil) {
            field_type = resolve_type(sema, ft_node);
        }

        if (field_type == nil) {
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        if (field_type != nil) {
            if (field_type.size > max_size) {
                max_size = field_type.size;
            }
            if (field_type.align > max_align) {
                max_align = field_type.align;
            }
        }

        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = 0;

        i = i + 1;
    }

    # align size to max alignment
    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    # mach unions are untagged (like C unions) - no tag bytes
    val res: Result[*ty.Type, str] = ty.union_type(ctx, nil, fields, field_count);
    if (res.is_err()) {
        report_error_node(sema, type_node, "failed to create anonymous union type");
        ret nil;
    }

    val uni_type: *ty.Type = res.unwrap_ok();
    uni_type.size = max_size;
    uni_type.align = max_align;

    ret uni_type;
}

# resolve_type_name: resolve a named type (primitive or user-defined).
fun resolve_type_name(sema: *Sema, type_node: *ast.Node) *ty.Type {
    val name: str = type_node.get_name();
    if (name == nil) {
        report_error_node(sema, type_node, "type name is nil");
        ret nil;
    }

    val ctx: *ty.TypeContext = ?sema.types;

    # check if this is a generic instantiation (has children that are type args)
    # generic args are stored as a NODE_GENERIC node in children
    var has_generic_args: bool = false;
    if (type_node.count > 0 && type_node.children != nil) {
        val first_child: *ast.Node = type_node.children;
        if (first_child != nil && first_child.kind == ast.NODE_GENERIC) {
            has_generic_args = true;
        }
    }

    # check for primitive type (primitives can't have generic args)
    val prim_opt: Option[ty.TypeKind] = ty.primitive_kind_from_name(name);
    if (prim_opt.is_some()) {
        if (has_generic_args) {
            report_error_node(sema, type_node, "primitive types cannot have generic arguments");
            ret nil;
        }
        val prim_kind: ty.TypeKind = prim_opt.unwrap();
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, prim_kind);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to get primitive type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # check for module-qualified type (alias.Type)
    val sym: *symbol.Symbol = lookup_type_symbol(sema, name);
    if (sym == nil) {
        report_error_node(sema, type_node, "undefined type");
        ret nil;
    }

    if (!sym.is_type_symbol()) {
        report_error_node(sema, type_node, "not a type");
        ret nil;
    }

    # cycle detection: check if type is currently being resolved
    if (sym.is_being_resolved) {
        # if we have a shell type already, return it for self-references
        # this allows rec Type { inner: *Type } patterns
        if (sym.resolved_type != nil) {
            ret sym.resolved_type;
        }
        report_error_node(sema, type_node, "circular type dependency detected");
        ret nil;
    }

    # use lazy analysis to resolve type if needed
    val resolved: *ty.Type = ensure_symbol_analyzed(sema, sym);
    if (resolved == nil) {
        report_error_node(sema, type_node, "type not yet resolved");
        ret nil;
    }

    # if this is a generic instantiation, create an instantiated type
    if (has_generic_args) {
        ret resolve_generic_instantiation(sema, type_node, sym);
    }

    ret resolved;
}

# lookup_type_symbol: look up a type symbol by name.
# ---
# handles module-qualified types (alias.Type) and unaliased imports.
# sema: analyzer context
# name: type name (may contain dots for module qualification)
# ret:  symbol if found, nil otherwise
fun lookup_type_symbol(sema: *Sema, name: str) *symbol.Symbol {
    if (sema == nil || name == nil) {
        ret nil;
    }

    # check for module-qualified type (contains a dot)
    val dot_pos: i32 = find_last_dot(name);
    if (dot_pos > 0) {
        # split into alias and type name
        val alias_len: usize = dot_pos::usize;
        val alias_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](alias_len + 1);
        if (alias_res.is_err()) {
            ret nil;
        }
        val alias_buf: *u8 = alias_res.unwrap_ok();
        mem.raw_copy(alias_buf::ptr, name::ptr, alias_len);
        alias_buf[alias_len] = 0;
        val module_alias: str = alias_buf::str;

        val type_name: str = (name::u64 + dot_pos::u64 + 1)::str;

        # look up alias in current module
        val alias: *ModuleAlias = find_alias(sema, module_alias);

        if (alias != nil && alias.module != nil && alias.module.table != nil) {
            val sym_opt: Option[*symbol.Symbol] = alias.module.table.lookup(type_name);
            if (sym_opt.is_some()) {
                val sym: *symbol.Symbol = sym_opt.unwrap();
                if (sym.is_public && sym.is_type_symbol()) {
                    ret sym;
                }
            }
        }

        # not found via alias
        ret nil;
    }

    # unqualified type: first check local scopes
    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_some()) {
        val sym: *symbol.Symbol = sym_opt.unwrap();
        if (sym.is_type_symbol()) {
            ret sym;
        }
    }

    # check unaliased imports (use foo.bar; brings public symbols into scope)
    if (sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                val cand_opt: Option[*symbol.Symbol] = imp.module.table.lookup(name);
                if (cand_opt.is_some()) {
                    val cand: *symbol.Symbol = cand_opt.unwrap();
                    if (cand.is_public && cand.is_type_symbol()) {
                        ret cand;
                    }
                }
            }
            imp = imp.next;
        }
    }

    ret nil;
}

# find_last_dot: find the position of the last dot in a string.
# ---
# ret: position of last dot, or -1 if not found
fun find_last_dot(s: str) i32 {
    if (s == nil) {
        ret -1;
    }
    var last: i32 = -1;
    var i: i32 = 0;
    for (s[i] != 0) {
        if (s[i] == 46) {  # '.' = 46
            last = i;
        }
        i = i + 1;
    }
    ret last;
}

# resolve_generic_instantiation: resolve a generic type with type arguments.
# ---
# sema:      analyzer
# type_node: AST node with generic args in children
# generic_sym: the symbol for the generic type being instantiated
# ret:       instantiated type or nil on error
fun resolve_generic_instantiation(sema: *Sema, type_node: *ast.Node, generic_sym: *symbol.Symbol) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val base_type: *ty.Type = generic_sym.resolved_type;

    if (base_type == nil) {
        report_error_node(sema, type_node, "generic type not yet resolved");
        ret nil;
    }

    # check that the symbol is actually generic
    if (!generic_sym.is_generic || generic_sym.generic_node == nil) {
        # not a generic type, just return the base type
        ret base_type;
    }

    # get the generic args node from the type_node
    val generic_args_node: *ast.Node = type_node.children;
    if (generic_args_node == nil || generic_args_node.kind != ast.NODE_GENERIC) {
        report_error_node(sema, type_node, "invalid generic arguments");
        ret nil;
    }

    # generic args are stored in the generic node's children as *List
    val args_list: *ast.List = generic_args_node.children::*ast.List;
    if (args_list == nil || args_list.count == 0) {
        report_error_node(sema, type_node, "empty generic arguments");
        ret nil;
    }

    # get generic params from the symbol's generic_node
    val params_node: *ast.Node = generic_sym.generic_node;
    val params_list: *ast.List = params_node.children::*ast.List;
    if (params_list == nil) {
        report_error_node(sema, type_node, "invalid generic declaration");
        ret nil;
    }

    # check that arg count matches param count
    if (args_list.count != params_list.count) {
        report_error_node(sema, type_node, "wrong number of generic arguments");
        ret nil;
    }

    val arg_count: i32 = args_list.count;

    # resolve each type argument
    val resolved_args_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](arg_count::usize);
    if (resolved_args_res.is_err()) {
        report_error_node(sema, type_node, "allocation failed");
        ret nil;
    }
    val resolved_args: **ty.Type = resolved_args_res.unwrap_ok();

    var i: i32 = 0;
    for (i < arg_count) {
        val arg_node: *ast.Node = args_list.nodes[i];
        if (arg_node == nil) {
            report_error_node(sema, type_node, "nil type argument");
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }

        val arg_type: *ty.Type = resolve_type(sema, arg_node);
        if (arg_type == nil) {
            # error already reported
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }
        resolved_args[i] = arg_type;
        i = i + 1;
    }

    # generate mangled name for caching: <name>I<type_args>E
    # for now, use a simple concatenation since we don't have full string building
    # we'll look up by checking against existing instantiations

    # check cache for existing instantiation with same args
    val cached: *ty.Type = find_cached_instantiation(sema, base_type, resolved_args, arg_count);
    if (cached != nil) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret cached;
    }

    # create scope with generic param bindings for field type resolution
    val push_res: Result[bool, str] = sema.current_table.push_scope();
    if (push_res.is_err()) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # bind each generic parameter to its concrete type
    i = 0;
    for (i < arg_count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node != nil) {
            val param_name: str = param_node.data::str;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = sema.current_table.define(param_name, symbol.SYM_GENERIC);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # now resolve fields with the bound generic params
    var inst_type: *ty.Type = nil;

    if (base_type.kind == ty.TY_RECORD) {
        inst_type = instantiate_record_type(sema, generic_sym, resolved_args, arg_count);
    } or {
        if (base_type.kind == ty.TY_UNION) {
            inst_type = instantiate_union_type(sema, generic_sym, resolved_args, arg_count);
        } or {
            # for other types, just return base with args attached
            val create_res: Result[*ty.Type, str] = ty.create_type(ctx, base_type.kind);
            if (create_res.is_ok()) {
                inst_type = create_res.unwrap_ok();
                inst_type.name = base_type.name;
                ty.set_generic_args(ctx, inst_type, resolved_args, arg_count);
                ty.set_base_generic(inst_type, base_type);
            }
        }
    }

    # pop the generic param scope
    val pop_res: Result[bool, str] = sema.current_table.pop_scope();

    if (inst_type == nil) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # attach generic args to instantiated type
    ty.set_generic_args(ctx, inst_type, resolved_args, arg_count);
    ty.set_base_generic(inst_type, base_type);

    ret inst_type;
}

# find_cached_instantiation: look for an existing instantiation with the same args.
fun find_cached_instantiation(sema: *Sema, base_type: *ty.Type, args: **ty.Type, arg_count: i32) *ty.Type {
    # iterate through all types in the context and find a matching instantiation
    val ctx: *ty.TypeContext = ?sema.types;

    var i: i32 = 0;
    for (i < ctx.type_count) {
        val t: *ty.Type = ctx.types[i];
        if (t != nil && t.base_generic == base_type && t.generic_arg_count == arg_count) {
            # check if all args match
            var match: bool = true;
            var j: i32 = 0;
            for (j < arg_count && match) {
                if (!ty.types_equal(t.generic_args[j], args[j])) {
                    match = false;
                }
                j = j + 1;
            }
            if (match) {
                ret t;
            }
        }
        i = i + 1;
    }

    ret nil;
}

# instantiate_record_type: create an instantiated record type with resolved fields.
fun instantiate_record_type(sema: *Sema, generic_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val decl: *ast.Node = generic_sym.decl_node;

    if (decl == nil || decl.kind != ast.NODE_DECL_REC) {
        ret nil;
    }

    # get fields from declaration
    val fields_list: *ast.List = decl.children::*ast.List;
    var field_count: i32 = 0;
    if (fields_list != nil) {
        field_count = fields_list.count;
    }

    # allocate fields array
    var fields: *ty.Field = nil;
    if (field_count > 0) {
        val alloc_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
        if (alloc_res.is_err()) {
            ret nil;
        }
        fields = alloc_res.unwrap_ok();

        # resolve each field type with generic params bound
        var offset: usize = 0;
        var max_align: usize = 1;
        var i: i32 = 0;
        for (i < field_count) {
            val field_node: *ast.Node = fields_list.nodes[i];
            if (field_node != nil && field_node.kind == ast.NODE_FIELD) {
                fields[i].name = field_node.data::str;

                # resolve field type - generic params are bound in current scope
                if (field_node.children != nil) {
                    fields[i].ty = resolve_type(sema, field_node.children);
                }

                # compute offset with alignment
                if (fields[i].ty != nil) {
                    val align: usize = fields[i].ty.align;
                    if (align > 0) {
                        offset = (offset + align - 1) & ~(align - 1);
                    }
                    fields[i].offset = offset;
                    offset = offset + fields[i].ty.size;
                    if (align > max_align) {
                        max_align = align;
                    }
                }
            }
            i = i + 1;
        }

        # create the instantiated record type
        val rec_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_RECORD);
        if (rec_res.is_err()) {
            sema.alloc.free[ty.Field](fields, field_count::usize);
            ret nil;
        }

        val inst: *ty.Type = rec_res.unwrap_ok();
        inst.name = generic_sym.name;
        inst.fields = fields;
        inst.field_count = field_count;

        # align total size
        if (max_align > 0) {
            offset = (offset + max_align - 1) & ~(max_align - 1);
        }
        inst.size = offset;
        inst.align = max_align;

        ret inst;
    }

    # no fields - create empty record
    val rec_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_RECORD);
    if (rec_res.is_ok()) {
        val inst: *ty.Type = rec_res.unwrap_ok();
        inst.name = generic_sym.name;
        ret inst;
    }

    ret nil;
}

# instantiate_union_type: create an instantiated union type with resolved variants.
fun instantiate_union_type(sema: *Sema, generic_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val decl: *ast.Node = generic_sym.decl_node;

    if (decl == nil || decl.kind != ast.NODE_DECL_UNI) {
        ret nil;
    }

    # get variants from declaration
    val fields_list: *ast.List = decl.children::*ast.List;
    var field_count: i32 = 0;
    if (fields_list != nil) {
        field_count = fields_list.count;
    }

    # allocate fields array
    var fields: *ty.Field = nil;
    if (field_count > 0) {
        val alloc_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
        if (alloc_res.is_err()) {
            ret nil;
        }
        fields = alloc_res.unwrap_ok();

        # resolve each variant type with generic params bound
        var max_size: usize = 0;
        var max_align: usize = 1;
        var i: i32 = 0;
        for (i < field_count) {
            val field_node: *ast.Node = fields_list.nodes[i];
            if (field_node != nil && field_node.kind == ast.NODE_FIELD) {
                fields[i].name = field_node.data::str;
                fields[i].offset = 0;  # all union fields at offset 0 (untagged)

                # resolve variant type
                if (field_node.children != nil) {
                    fields[i].ty = resolve_type(sema, field_node.children);
                }

                if (fields[i].ty != nil) {
                    if (fields[i].ty.size > max_size) {
                        max_size = fields[i].ty.size;
                    }
                    if (fields[i].ty.align > max_align) {
                        max_align = fields[i].ty.align;
                    }
                }
            }
            i = i + 1;
        }

        # create the instantiated union type
        val uni_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_UNION);
        if (uni_res.is_err()) {
            sema.alloc.free[ty.Field](fields, field_count::usize);
            ret nil;
        }

        val inst: *ty.Type = uni_res.unwrap_ok();
        inst.name = generic_sym.name;
        inst.fields = fields;
        inst.field_count = field_count;

        # mach unions are untagged (like C unions) - no tag bytes
        if (max_align > 0) {
            max_size = (max_size + max_align - 1) & ~(max_align - 1);
        }
        inst.size = max_size;
        inst.align = max_align;

        ret inst;
    }

    # no variants - create empty union (size 0)
    val uni_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_UNION);
    if (uni_res.is_ok()) {
        val inst: *ty.Type = uni_res.unwrap_ok();
        inst.name = generic_sym.name;
        inst.size = 0;
        inst.align = 1;
        ret inst;
    }

    ret nil;
}

# instantiate_generic_function: instantiate a generic function with type arguments.
# ---
# sema:         analyzer
# type_args_node: NODE_GENERIC node containing type arguments
# generic_sym:  symbol for the generic function
# ret:          instantiated function type or nil on error
fun instantiate_generic_function(sema: *Sema, type_args_node: *ast.Node, generic_sym: *symbol.Symbol) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    if (type_args_node == nil || type_args_node.kind != ast.NODE_GENERIC) {
        report_error_node(sema, type_args_node, "invalid generic arguments");
        ret nil;
    }

    if (!generic_sym.is_generic || generic_sym.generic_node == nil) {
        # not a generic function, just return the resolved type
        ret generic_sym.resolved_type;
    }

    # get type arguments from the call
    val args_list: *ast.List = type_args_node.children::*ast.List;
    if (args_list == nil || args_list.count == 0) {
        report_error_node(sema, type_args_node, "empty generic arguments");
        ret nil;
    }

    # get generic params from the symbol's generic_node
    val params_node: *ast.Node = generic_sym.generic_node;
    val params_list: *ast.List = params_node.children::*ast.List;
    if (params_list == nil) {
        report_error_node(sema, type_args_node, "invalid generic declaration");
        ret nil;
    }

    # check arg count matches param count
    if (args_list.count != params_list.count) {
        report_error_node(sema, type_args_node, "wrong number of generic arguments");
        ret nil;
    }

    val arg_count: i32 = args_list.count;

    # resolve each type argument IN THE CALLER'S CONTEXT (before switching)
    val resolved_args_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](arg_count::usize);
    if (resolved_args_res.is_err()) {
        report_error_node(sema, type_args_node, "allocation failed");
        ret nil;
    }
    val resolved_args: **ty.Type = resolved_args_res.unwrap_ok();

    var i: i32 = 0;
    for (i < arg_count) {
        val arg_node: *ast.Node = args_list.nodes[i];
        if (arg_node == nil) {
            report_error_node(sema, type_args_node, "nil type argument");
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }

        val arg_type: *ty.Type = resolve_type(sema, arg_node);
        if (arg_type == nil) {
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }
        resolved_args[i] = arg_type;
        i = i + 1;
    }

    # check cache for existing instantiation
    val cached: *ty.Type = find_cached_function_instantiation(sema, generic_sym, resolved_args, arg_count);
    if (cached != nil) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret cached;
    }

    # save current context before switching to the function's origin module
    val saved_module: *SemaModule = sema.current_module;
    val saved_table: *symbol.Table = sema.current_table;
    val saved_module_path: str = sema.module_path;

    # switch to the function's origin module for type resolution
    # this is needed so unqualified types in the function's return/param types
    # are resolved in the correct module context
    var origin: *SemaModule = nil;
    if (generic_sym.module_path != nil) {
        origin = find_module(sema, generic_sym.module_path);
    }

    if (origin != nil && origin != saved_module) {
        sema.current_module = origin;
        sema.current_table = origin.table;
        sema.module_path = origin.module_path;
    }

    # create scope with generic param bindings for type resolution
    val push_res: Result[bool, str] = sema.current_table.push_scope();
    if (push_res.is_err()) {
        # restore context before returning
        sema.current_module = saved_module;
        sema.current_table = saved_table;
        sema.module_path = saved_module_path;
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # bind each generic parameter to its concrete type
    i = 0;
    for (i < arg_count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node != nil) {
            val param_name: str = param_node.data::str;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = sema.current_table.define(param_name, symbol.SYM_GENERIC);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # resolve parameter and return types with generic params bound
    val decl: *ast.Node = generic_sym.decl_node;
    if (decl == nil || decl.kind != ast.NODE_DECL_FUN) {
        val pop_res: Result[bool, str] = sema.current_table.pop_scope();
        # restore context before returning
        sema.current_module = saved_module;
        sema.current_table = saved_table;
        sema.module_path = saved_module_path;
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # get parameter list from decl.extra
    val params_decl: *ast.List = decl.extra::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_decl != nil && params_decl.count > 0) {
        param_count = params_decl.count;

        val alloc_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (alloc_res.is_ok()) {
            param_types = alloc_res.unwrap_ok();

            var j: i32 = 0;
            for (j < param_count) {
                val param_node: *ast.Node = params_decl.nodes[j];
                if (param_node != nil && param_node.children != nil) {
                    param_types[j] = resolve_type(sema, param_node.children);
                } or {
                    param_types[j] = nil;
                }
                j = j + 1;
            }
        }
    }

    # resolve return type from decl.ret_type
    var ret_type: *ty.Type = nil;
    if (decl.ret_type != nil) {
        ret_type = resolve_type(sema, decl.ret_type);
    }

    if (ret_type == nil) {
        # default to void
        val void_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (void_res.is_ok()) {
            ret_type = void_res.unwrap_ok();
        }
    }

    # pop the generic param scope
    val pop_res: Result[bool, str] = sema.current_table.pop_scope();

    # restore context before creating the function type
    sema.current_module = saved_module;
    sema.current_table = saved_table;
    sema.module_path = saved_module_path;

    # create the instantiated function type
    val fn_res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (fn_res.is_err()) {
        if (param_types != nil) {
            sema.alloc.free[*ty.Type](param_types, param_count::usize);
        }
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    val inst_type: *ty.Type = fn_res.unwrap_ok();

    # attach generic args to the instantiated type
    ty.set_generic_args(ctx, inst_type, resolved_args, arg_count);

    # link to base function's type if available
    if (generic_sym.resolved_type != nil) {
        ty.set_base_generic(inst_type, generic_sym.resolved_type);
    }

    ret inst_type;
}

# find_cached_function_instantiation: look for an existing function instantiation.
fun find_cached_function_instantiation(sema: *Sema, generic_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val base_type: *ty.Type = generic_sym.resolved_type;

    if (base_type == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < ctx.type_count) {
        val t: *ty.Type = ctx.types[i];
        if (t != nil && t.kind == ty.TY_FUN && t.base_generic == base_type && t.generic_arg_count == arg_count) {
            # check if all args match
            var match: bool = true;
            var j: i32 = 0;
            for (j < arg_count && match) {
                if (!ty.types_equal(t.generic_args[j], args[j])) {
                    match = false;
                }
                j = j + 1;
            }
            if (match) {
                ret t;
            }
        }
        i = i + 1;
    }

    ret nil;
}

# resolve_qualified_type_name: resolve a qualified type name like module.Type.
# ---
# handles dotted names where the name contains '.' (e.g., "std.types.Result")
fun resolve_qualified_type_name(sema: *Sema, name: str) *ty.Type {
    # qualified names are stored as "module.Type" in the name field
    # we need to look up through module scopes

    if (name == nil) {
        ret nil;
    }

    # for now, try direct lookup first
    # full implementation would split on '.' and traverse
    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_some()) {
        val sym: *symbol.Symbol = sym_opt.unwrap();
        if (sym.is_type_symbol() && sym.resolved_type != nil) {
            ret sym.resolved_type;
        }
    }

    # type not found with full path
    ret nil;
}

# resolve_function_type: resolve a function type signature.
fun resolve_function_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    # function type nodes store params in data as *List and return type in extra
    val ctx: *ty.TypeContext = ?sema.types;

    # resolve return type
    var ret_type: *ty.Type = nil;
    if (type_node.extra != nil) {
        ret_type = resolve_type(sema, type_node.extra::*ast.Node);
    }
    if (ret_type == nil) {
        # default to void
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (res.is_ok()) {
            ret_type = res.unwrap_ok();
        }
    }

    # resolve parameter types
    val params_list: *ast.List = type_node.data::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_list != nil && params_list.count > 0) {
        param_count = params_list.count;

        # allocate param type array
        val ptypes_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.zalloc[*ty.Type](param_count::usize);
        if (ptypes_res.is_ok()) {
            param_types = ptypes_res.unwrap_ok();

            # resolve each parameter type
            var i: i32 = 0;
            for (i < param_count) {
                val param_node: *ast.Node = params_list.nodes[i];
                if (param_node != nil) {
                    # param types can be stored directly or in children
                    if (param_node.is_type()) {
                        param_types[i] = resolve_type(sema, param_node);
                    } or {
                        if (param_node.children != nil) {
                            param_types[i] = resolve_type(sema, param_node.children);
                        }
                    }
                }
                i = i + 1;
            }
        }
    }

    val res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (res.is_err()) {
        report_error_node(sema, type_node, "failed to create function type");
        ret nil;
    }

    ret res.unwrap_ok();
}

# --- expression type checking ---

# check_expr: type-check an expression and return its type.
# ---
# sema: analyzer
# expr: expression AST node
# ret:  type of expression or nil on error
pub fun check_expr(sema: *Sema, expr: *ast.Node) *ty.Type {
    ret check_expr_with_hint(sema, expr, nil);
}

# check_expr_with_hint: type-check an expression with optional expected type hint.
# ---
# sema:     analyzer
# expr:     expression AST node
# expected: expected type hint for literal inference (may be nil)
# ret:      type of expression or nil on error
pub fun check_expr_with_hint(sema: *Sema, expr: *ast.Node, expected: *ty.Type) *ty.Type {
    if (sema == nil || expr == nil) {
        ret nil;
    }

    val kind: ast.NodeKind = expr.kind;
    val ctx: *ty.TypeContext = ?sema.types;

    # integer literal
    if (kind == ast.NODE_EXPR_LIT_INT) {
        # if expected type is an integer type, use it; else default to i64
        if (expected != nil && expected.is_integer()) {
            ret expected;
        }
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_I64);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # float literal
    if (kind == ast.NODE_EXPR_LIT_FLOAT) {
        # if expected type is a float type, use it; else default to f64
        if (expected != nil && expected.is_float()) {
            ret expected;
        }
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_F64);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # char literal
    if (kind == ast.NODE_EXPR_LIT_CHAR) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_U8);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # string literal
    if (kind == ast.NODE_EXPR_LIT_STR) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_STR);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # bool literal
    if (kind == ast.NODE_EXPR_LIT_BOOL) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_BOOL);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # nil literal
    if (kind == ast.NODE_EXPR_LIT_NIL) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_NIL);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # identifier
    if (kind == ast.NODE_EXPR_IDENT) {
        ret check_ident(sema, expr);
    }

    # binary expression - pass through expected type for literal inference
    if (kind == ast.NODE_EXPR_BINARY) {
        ret check_binary_with_hint(sema, expr, expected);
    }

    # unary expression - pass through expected type for literal inference
    if (kind == ast.NODE_EXPR_UNARY) {
        ret check_unary_with_hint(sema, expr, expected);
    }

    # function call
    if (kind == ast.NODE_EXPR_CALL) {
        ret check_call(sema, expr);
    }

    # field access
    if (kind == ast.NODE_EXPR_FIELD) {
        ret check_field(sema, expr);
    }

    # index
    if (kind == ast.NODE_EXPR_INDEX) {
        ret check_index(sema, expr);
    }

    # cast
    if (kind == ast.NODE_EXPR_CAST) {
        ret check_cast(sema, expr);
    }

    # address-of
    if (kind == ast.NODE_EXPR_ADDR) {
        ret check_addr(sema, expr);
    }

    # dereference
    if (kind == ast.NODE_EXPR_DEREF) {
        ret check_deref(sema, expr);
    }

    # parenthesized expression - pass through expected type
    if (kind == ast.NODE_EXPR_PAREN) {
        ret check_expr_with_hint(sema, expr.children, expected);
    }

    # array literal
    if (kind == ast.NODE_EXPR_ARRAY_LIT) {
        ret check_array_lit(sema, expr);
    }

    # struct literal
    if (kind == ast.NODE_EXPR_STRUCT_LIT) {
        ret check_struct_lit(sema, expr);
    }

    report_error_node(sema, expr, "unsupported expression");
    ret nil;
}

# check_array_lit: type-check an array literal expression.
fun check_array_lit(sema: *Sema, expr: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # array literal elements are in data as *List
    val elems_list: *ast.List = expr.data::*ast.List;
    if (elems_list == nil || elems_list.count == 0) {
        # empty array - need type annotation
        report_error_node(sema, expr, "cannot infer type of empty array literal");
        ret nil;
    }

    # check first element to determine array type
    val first: *ast.Node = elems_list.nodes[0];
    if (first == nil) {
        report_error_node(sema, expr, "array element is nil");
        ret nil;
    }

    val elem_type: *ty.Type = check_expr(sema, first);
    if (elem_type == nil) {
        ret nil;
    }

    # check remaining elements have compatible types, passing first element type as hint
    var i: i32 = 1;
    for (i < elems_list.count) {
        val elem: *ast.Node = elems_list.nodes[i];
        if (elem != nil) {
            val et: *ty.Type = check_expr_with_hint(sema, elem, elem_type);
            if (et != nil && !ty.can_assign(et, elem_type)) {
                report_error_node(sema, elem, "array element type mismatch");
            }
        }
        i = i + 1;
    }

    # create array type
    val arr_res: Result[*ty.Type, str] = ty.array_type(ctx, elem_type, elems_list.count::usize);
    if (arr_res.is_err()) {
        report_error_node(sema, expr, "failed to create array type");
        ret nil;
    }

    ret arr_res.unwrap_ok();
}

# check_struct_lit: type-check a struct/union literal expression.
fun check_struct_lit(sema: *Sema, expr: *ast.Node) *ty.Type {
    # struct/union literal: TypeName { field: value, ... }
    # type name is in data, field inits are in children as *List

    val type_name: str = expr.data::str;
    if (type_name == nil) {
        report_error_node(sema, expr, "struct literal missing type name");
        ret nil;
    }

    # look up struct/union type
    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(type_name);
    if (sym_opt.is_none()) {
        report_error_node(sema, expr, "undefined struct type");
        ret nil;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    if (sym.resolved_type == nil) {
        report_error_node(sema, expr, "struct type not resolved");
        ret nil;
    }

    val struct_type: *ty.Type = sym.resolved_type;
    if (!struct_type.is_record() && !struct_type.is_union()) {
        report_error_node(sema, expr, "not a struct or union type");
        ret nil;
    }

    # check field initializers
    val inits_list: *ast.List = expr.children::*ast.List;
    if (inits_list != nil) {
        var i: i32 = 0;
        for (i < inits_list.count) {
            val init_node: *ast.Node = inits_list.nodes[i];
            if (init_node != nil) {
                # field init: name = value
                val field_name: str = init_node.get_name();
                if (field_name != nil) {
                    # look up field in struct type
                    val field_opt: Option[*ty.Field] = ty.get_field(struct_type, field_name);
                    if (field_opt.is_none()) {
                        report_error_node(sema, init_node, "undefined field");
                    } or {
                        # check value type, passing field type as hint for literal inference
                        val value_node: *ast.Node = init_node.children;
                        if (value_node != nil) {
                            val field: *ty.Field = field_opt.unwrap();
                            val value_type: *ty.Type = check_expr_with_hint(sema, value_node, field.ty);
                            if (value_type != nil && field.ty != nil && !ty.can_assign(value_type, field.ty)) {
                                report_error_node(sema, value_node, "field initializer type mismatch");
                            }
                        }
                    }
                }
            }
            i = i + 1;
        }
    }

    ret struct_type;
}

# ensure_symbol_analyzed: lazy on-demand type resolution.
# ---
# If the symbol's type is not yet resolved and it has a declaration,
# this will analyze the declaration (possibly in another module) to resolve the type.
# This matches the bootstrap compiler's lazy analysis behavior.
fun ensure_symbol_analyzed(sema: *Sema, sym: *symbol.Symbol) *ty.Type {
    if (sym == nil) {
        ret nil;
    }

    # if already resolved, return it
    if (sym.resolved_type != nil) {
        ret sym.resolved_type;
    }

    # if no declaration node, can't analyze
    if (sym.decl_node == nil) {
        ret nil;
    }

    # cycle detection - if already being analyzed, return nil to break cycle
    if (sym.is_being_resolved) {
        ret nil;
    }

    # save current context
    val saved_module: *SemaModule = sema.current_module;
    val saved_table: *symbol.Table = sema.current_table;
    val saved_module_path: str = sema.module_path;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;
    val saved_fn: *symbol.Symbol = sema.current_fn;
    val saved_fn_ret: *ty.Type = sema.current_fn_ret;

    # find the module where this symbol is defined
    var origin: *SemaModule = nil;
    if (sym.module_path != nil) {
        origin = find_module(sema, sym.module_path);
    }

    # switch to origin module context if different
    if (origin != nil && origin != saved_module) {
        sema.current_module = origin;
        sema.current_table = origin.table;
        sema.module_path = origin.module_path;
        sema.file_path = origin.file_path;
        sema.source = origin.source;
    }

    # analyze the declaration based on its kind
    val decl: *ast.Node = sym.decl_node;
    val kind: ast.NodeKind = decl.kind;

    # for val/var/fun, we handle cycle detection here
    # for types (rec/uni/def), the resolve_*_type functions handle it themselves
    var needs_flag_clear: bool = false;

    if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
        sym.is_being_resolved = true;
        needs_flag_clear = true;
        # resolve type from annotation or infer from initializer
        if (decl.extra != nil) {
            sym.resolved_type = resolve_type(sema, decl.extra::*ast.Node);
        } or {
            if (decl.children != nil) {
                sym.resolved_type = check_expr(sema, decl.children);
            }
        }
    }

    if (kind == ast.NODE_DECL_FUN) {
        sym.is_being_resolved = true;
        needs_flag_clear = true;
        # resolve function type
        resolve_function_decl(sema, decl);
    }

    if (kind == ast.NODE_DECL_REC) {
        # ensure record type is resolved (handles its own cycle detection)
        resolve_record_type(sema, decl);
    }

    if (kind == ast.NODE_DECL_UNI) {
        # ensure union type is resolved (handles its own cycle detection)
        resolve_union_type(sema, decl);
    }

    if (kind == ast.NODE_DECL_DEF) {
        # resolve type alias
        resolve_def_type(sema, decl);
    }

    # restore context
    sema.current_module = saved_module;
    sema.current_table = saved_table;
    sema.module_path = saved_module_path;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
    sema.current_fn = saved_fn;
    sema.current_fn_ret = saved_fn_ret;

    # clear resolving flag only if we set it
    if (needs_flag_clear) {
        sym.is_being_resolved = false;
    }

    ret sym.resolved_type;
}

# check_ident: type-check an identifier expression.
fun check_ident(sema: *Sema, expr: *ast.Node) *ty.Type {
    val name: str = expr.get_name();
    if (name == nil) {
        report_error_node(sema, expr, "identifier has no name");
        ret nil;
    }

    # first look up in local scopes
    var sym: *symbol.Symbol = nil;
    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_some()) {
        sym = sym_opt.unwrap();
    } or {
        # if not found locally, check unaliased imports
        if (sema.current_module != nil) {
            var imp: *ModuleImport = sema.current_module.imports;
            for (imp != nil) {
                if (imp.module != nil && imp.module.table != nil) {
                    val cand_opt: Option[*symbol.Symbol] = imp.module.table.lookup(name);
                    if (cand_opt.is_some()) {
                        val cand: *symbol.Symbol = cand_opt.unwrap();
                        if (cand.is_public) {
                            sym = cand;
                            brk;
                        }
                    }
                }
                imp = imp.next;
            }
        }
    }

    if (sym == nil) {
        print.eprint("  [DEBUG] undefined identifier: ");
        print.eprintln(name);
        report_error_node(sema, expr, "undefined identifier");
        ret nil;
    }

    # use lazy analysis to resolve type if needed
    val resolved: *ty.Type = ensure_symbol_analyzed(sema, sym);
    if (resolved == nil) {
        # for generic functions/types, we don't have a resolved type yet
        # this is fine - the call site will handle instantiation
        if (sym.is_generic) {
            # store symbol reference for call handling
            expr.extra = sym::ptr;
            # for generic callables, return a placeholder function type
            # so the call expression can proceed with instantiation
            ret nil;
        }
        report_error_node(sema, expr, "identifier type not resolved");
        ret nil;
    }

    ret resolved;
}

# check_binary: type-check a binary expression.
fun check_binary(sema: *Sema, expr: *ast.Node) *ty.Type {
    ret check_binary_with_hint(sema, expr, nil);
}

# check_binary_with_hint: type-check a binary expression with optional expected type hint.
fun check_binary_with_hint(sema: *Sema, expr: *ast.Node, expected: *ty.Type) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # binary expression has two children: left and right
    val left: *ast.Node = expr.get_child(0);
    val right: *ast.Node = expr.get_child(1);

    if (left == nil || right == nil) {
        report_error_node(sema, expr, "binary expression missing operand");
        ret nil;
    }

    # operator is stored in data as token tag
    val op: u8 = expr.data::u8;

    # for assignment, check left first and use its type as hint for right
    if (op == token.TAG_EQ) {
        val left_type: *ty.Type = check_expr(sema, left);
        if (left_type == nil) {
            ret nil;
        }
        # pass left type as hint for right side (enables literal inference)
        val right_type: *ty.Type = check_expr_with_hint(sema, right, left_type);
        if (right_type == nil) {
            ret nil;
        }
        if (!ty.can_assign(right_type, left_type)) {
            print.eprint("  [DEBUG] assign mismatch: ");
            debug_print_type(right_type);
            print.eprint(" -> ");
            debug_print_type(left_type);
            print.eprintln("");
            report_error_node(sema, expr, "type mismatch in assignment");
            ret nil;
        }
        ret left_type;
    }

    # for arithmetic operators, use expected type as hint for both operands
    # this allows: val x: i32 = 1 + 2; to infer i32 for both literals
    var type_hint: *ty.Type = expected;

    # check left first, using expected type as hint
    val left_type: *ty.Type = check_expr_with_hint(sema, left, type_hint);
    if (left_type == nil) {
        ret nil;
    }

    # if no expected hint but left gave us a numeric type, use that for right
    if (type_hint == nil && left_type.is_numeric()) {
        type_hint = left_type;
    }

    # pass type hint for right operand
    val right_type: *ty.Type = check_expr_with_hint(sema, right, type_hint);
    if (right_type == nil) {
        ret nil;
    }

    # arithmetic operators: +, -, *, /, %
    if (op == token.TAG_PLUS || op == token.TAG_MINUS ||
        op == token.TAG_STAR || op == token.TAG_SLASH || op == token.TAG_PERCENT) {
        if (!left_type.is_numeric() || !right_type.is_numeric()) {
            report_error_node(sema, expr, "arithmetic requires numeric operands");
            ret nil;
        }
        # result is the wider type (simplified: just use left)
        ret left_type;
    }

    # comparison operators: ==, !=, <, >, <=, >=
    if (op == token.TAG_EQ_EQ || op == token.TAG_BANG_EQ ||
        op == token.TAG_LT || op == token.TAG_GT ||
        op == token.TAG_LT_EQ || op == token.TAG_GT_EQ) {
        # comparison always returns bool
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_BOOL);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # logical operators: &&, ||
    if (op == token.TAG_AMP_AMP || op == token.TAG_PIPE_PIPE) {
        if (!left_type.is_bool() || !right_type.is_bool()) {
            report_error_node(sema, expr, "logical operators require bool operands");
            ret nil;
        }
        ret left_type;
    }

    # bitwise operators: &, |, ^, <<, >>
    if (op == token.TAG_AMP || op == token.TAG_PIPE || op == token.TAG_CARET ||
        op == token.TAG_LT_LT || op == token.TAG_GT_GT) {
        if (!left_type.is_integer() || !right_type.is_integer()) {
            report_error_node(sema, expr, "bitwise operators require integer operands");
            ret nil;
        }
        ret left_type;
    }

    report_error_node(sema, expr, "unknown binary operator");
    ret nil;
}

# check_unary: type-check a unary expression.
fun check_unary(sema: *Sema, expr: *ast.Node) *ty.Type {
    ret check_unary_with_hint(sema, expr, nil);
}

# check_unary_with_hint: type-check a unary expression with optional expected type hint.
fun check_unary_with_hint(sema: *Sema, expr: *ast.Node, expected: *ty.Type) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    val operand: *ast.Node = expr.children;
    if (operand == nil) {
        report_error_node(sema, expr, "unary expression missing operand");
        ret nil;
    }

    # pass expected type hint to operand for literal inference
    val operand_type: *ty.Type = check_expr_with_hint(sema, operand, expected);
    if (operand_type == nil) {
        ret nil;
    }

    # operator stored in data
    val op: u8 = expr.data::u8;

    # negation: -
    if (op == token.TAG_MINUS) {
        if (!operand_type.is_numeric()) {
            report_error_node(sema, expr, "negation requires numeric operand");
            ret nil;
        }
        ret operand_type;
    }

    # logical not: !
    if (op == token.TAG_BANG) {
        if (!operand_type.is_bool()) {
            report_error_node(sema, expr, "logical not requires bool operand");
            ret nil;
        }
        ret operand_type;
    }

    # bitwise not: ~
    if (op == token.TAG_TILDE) {
        if (!operand_type.is_integer()) {
            report_error_node(sema, expr, "bitwise not requires integer operand");
            ret nil;
        }
        ret operand_type;
    }

    # dereference: * (as prefix)
    if (op == token.TAG_STAR) {
        if (!operand_type.is_pointer()) {
            report_error_node(sema, expr, "dereference requires pointer operand");
            ret nil;
        }
        ret ty.get_element_type(operand_type);
    }

    # address-of: @ or &
    if (op == token.TAG_AT || op == token.TAG_AMP) {
        val res: Result[*ty.Type, str] = ty.pointer_type(ctx, operand_type, op == token.TAG_AT);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # try operator: ? (unwrap Result or Option)
    if (op == token.TAG_QUESTION) {
        # try operator extracts the inner type from Result[T, E] or Option[T]
        # check if operand is a generic instantiation
        if (!ty.is_generic_instantiation(operand_type)) {
            report_error_node(sema, expr, "try operator requires Result or Option type");
            ret nil;
        }

        # get the base type name to check if it's Result or Option
        val base: *ty.Type = ty.get_base_generic(operand_type);
        if (base == nil || base.name == nil) {
            report_error_node(sema, expr, "try operator requires Result or Option type");
            ret nil;
        }

        val base_name: str = base.name;
        var is_result: bool = false;
        var is_option: bool = false;

        # check if base name ends with "Result" or "Option"
        # (could be std.types.Result or just Result depending on import)
        if (base_name != nil) {
            val len: i32 = base_name.len()::i32;
            if (len >= 6) {
                # check for "Result" at end
                if (base_name[len - 6] == 'R' && base_name[len - 5] == 'e' &&
                    base_name[len - 4] == 's' && base_name[len - 3] == 'u' &&
                    base_name[len - 2] == 'l' && base_name[len - 1] == 't') {
                    is_result = true;
                }
                # check for "Option" at end
                if (base_name[len - 6] == 'O' && base_name[len - 5] == 'p' &&
                    base_name[len - 4] == 't' && base_name[len - 3] == 'i' &&
                    base_name[len - 2] == 'o' && base_name[len - 1] == 'n') {
                    is_option = true;
                }
            }
        }

        if (!is_result && !is_option) {
            report_error_node(sema, expr, "try operator requires Result or Option type");
            ret nil;
        }

        # extract the first generic argument (T in Result[T, E] or Option[T])
        val arg_count: i32 = ty.get_generic_arg_count(operand_type);
        if (arg_count < 1) {
            report_error_node(sema, expr, "Result/Option type missing type argument");
            ret nil;
        }

        val inner_type: *ty.Type = ty.get_generic_arg(operand_type, 0);
        if (inner_type == nil) {
            report_error_node(sema, expr, "failed to extract inner type from Result/Option");
            ret nil;
        }

        ret inner_type;
    }

    report_error_node(sema, expr, "unknown unary operator");
    ret nil;
}

# check_call: type-check a function call.
fun check_call(sema: *Sema, expr: *ast.Node) *ty.Type {
    # callee is first child, arguments are in data as *List
    val callee: *ast.Node = expr.get_child(0);
    if (callee == nil) {
        report_error_node(sema, expr, "call missing callee");
        ret nil;
    }

    # check if this is a generic function call (has type args in expr.generics)
    var callee_type: *ty.Type = nil;

    if (expr.generics != nil && callee.kind == ast.NODE_EXPR_IDENT) {
        # generic function call: func[T](args)
        # look up the function symbol and instantiate it
        val func_name: str = callee.data::str;
        if (func_name != nil) {
            var sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(func_name);

            # if not found locally, check imported modules
            if (sym_opt.is_none() && sema.current_module != nil) {
                var imp: *ModuleImport = sema.current_module.imports;
                for (imp != nil) {
                    if (imp.module != nil && imp.module.table != nil) {
                        val cand_opt: Option[*symbol.Symbol] = imp.module.table.lookup(func_name);
                        if (cand_opt.is_some()) {
                            val cand: *symbol.Symbol = cand_opt.unwrap();
                            if (cand.is_public) {
                                sym_opt = cand_opt;
                                brk;
                            }
                        }
                    }
                    imp = imp.next;
                }
            }

            # also check aliased modules
            if (sym_opt.is_none() && sema.current_module != nil) {
                var alias: *ModuleAlias = sema.current_module.aliases;
                for (alias != nil) {
                    if (alias.module != nil && alias.module.table != nil) {
                        val cand_opt: Option[*symbol.Symbol] = alias.module.table.lookup(func_name);
                        if (cand_opt.is_some()) {
                            val cand: *symbol.Symbol = cand_opt.unwrap();
                            if (cand.is_public) {
                                sym_opt = cand_opt;
                                brk;
                            }
                        }
                    }
                    alias = alias.next;
                }
            }

            if (sym_opt.is_some()) {
                val func_sym: *symbol.Symbol = sym_opt.unwrap();
                if (func_sym.is_generic && func_sym.is_callable()) {
                    # instantiate the generic function with type args
                    callee_type = instantiate_generic_function(sema, expr.generics, func_sym);
                } or {
                    # not a generic function but called with type args
                    report_error_node(sema, expr, "function is not generic");
                    ret nil;
                }
            } or {
                report_error_node(sema, expr, "undefined function");
                ret nil;
            }
        }
    } or {
        if (expr.generics != nil && callee.kind == ast.NODE_EXPR_FIELD) {
            # generic method call: obj.method[T](args)
            # we need to look up the method symbol and instantiate it
            callee_type = check_generic_method_call(sema, expr, callee);
        } or {
            # regular (non-generic) function call
            callee_type = check_expr(sema, callee);
        }
    }

    if (callee_type == nil) {
        ret nil;
    }

    if (!callee_type.is_function()) {
        report_error_node(sema, expr, "cannot call non-function");
        ret nil;
    }

    # check argument types match parameters
    val args_list: *ast.List = expr.data::*ast.List;
    var arg_count: i32 = 0;
    if (args_list != nil) {
        arg_count = args_list.count;
    }

    # check argument count
    if (arg_count != callee_type.param_count) {
        report_error_node(sema, expr, "wrong number of arguments");
        # continue to check what we can
    }

    # check each argument type, passing parameter type as hint for literal inference
    if (args_list != nil) {
        var i: i32 = 0;
        for (i < args_list.count) {
            val arg_node: *ast.Node = args_list.nodes[i];
            if (arg_node != nil) {
                # get parameter type hint if available
                var param_type_hint: *ty.Type = nil;
                if (i < callee_type.param_count && callee_type.params != nil) {
                    param_type_hint = callee_type.params[i];
                }

                val arg_type: *ty.Type = check_expr_with_hint(sema, arg_node, param_type_hint);

                # check against parameter type if available
                if (arg_type != nil && param_type_hint != nil) {
                    if (!ty.can_assign(arg_type, param_type_hint)) {
                        print.eprint("  [DEBUG] arg mismatch: ");
                        debug_print_type(arg_type);
                        print.eprint(" (kind=");
                        print.eu64(arg_type.kind::u64);
                        if (arg_type.is_pointer() && arg_type.inner != nil) {
                            print.eprint(" inner_kind=");
                            print.eu64(arg_type.inner.kind::u64);
                            if (arg_type.inner.kind == ty.TY_ARRAY) {
                                print.eprint(" arr_len=");
                                print.eu64(arg_type.inner.array_len::u64);
                            }
                        }
                        print.eprint(") -> ");
                        debug_print_type(param_type_hint);
                        print.eprint(" (kind=");
                        print.eu64(param_type_hint.kind::u64);
                        if (param_type_hint.is_pointer() && param_type_hint.inner != nil) {
                            print.eprint(" inner_kind=");
                            print.eu64(param_type_hint.inner.kind::u64);
                            if (param_type_hint.inner.kind == ty.TY_ARRAY) {
                                print.eprint(" arr_len=");
                                print.eu64(param_type_hint.inner.array_len::u64);
                            }
                        }
                        print.eprint(")");
                        print.eprintln("");
                        report_error_node(sema, arg_node, "argument type mismatch");
                    }
                }
            }
            i = i + 1;
        }
    }

    ret callee_type.ret_type;
}

# check_generic_method_call: type-check a generic method call like obj.method[T](args).
fun check_generic_method_call(sema: *Sema, call_expr: *ast.Node, field_expr: *ast.Node) *ty.Type {
    # field_expr is the a.method part
    val base: *ast.Node = field_expr.get_child(0);
    if (base == nil) {
        report_error_node(sema, call_expr, "generic method call missing base");
        ret nil;
    }

    val method_name: str = field_expr.get_name();
    if (method_name == nil) {
        report_error_node(sema, call_expr, "generic method call missing method name");
        ret nil;
    }

    # check the base expression to get its type
    val base_type: *ty.Type = check_expr(sema, base);
    if (base_type == nil) {
        ret nil;
    }

    # auto-dereference pointers
    var target_type: *ty.Type = base_type;
    if (base_type.is_pointer()) {
        target_type = ty.get_element_type(base_type);
    }

    val type_name: str = target_type.name;
    if (type_name == nil) {
        report_error_node(sema, call_expr, "cannot call method on unnamed type");
        ret nil;
    }

    # look up the method symbol
    var method_sym: *symbol.Symbol = find_method_symbol(sema.current_table, type_name, method_name);

    # if not found locally, check imported and aliased modules
    if (method_sym == nil && sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                method_sym = find_method_symbol(imp.module.table, type_name, method_name);
                if (method_sym != nil && method_sym.is_public) {
                    brk;
                }
                method_sym = nil;
            }
            imp = imp.next;
        }
    }

    if (method_sym == nil && sema.current_module != nil) {
        var alias: *ModuleAlias = sema.current_module.aliases;
        for (alias != nil) {
            if (alias.module != nil && alias.module.table != nil) {
                method_sym = find_method_symbol(alias.module.table, type_name, method_name);
                if (method_sym != nil && method_sym.is_public) {
                    brk;
                }
                method_sym = nil;
            }
            alias = alias.next;
        }
    }

    if (method_sym == nil) {
        report_error_node(sema, call_expr, "undefined method");
        ret nil;
    }

    if (!method_sym.is_generic) {
        report_error_node(sema, call_expr, "method is not generic");
        ret nil;
    }

    # instantiate the generic method with the provided type arguments
    val instantiated: *ty.Type = instantiate_generic_function(sema, call_expr.generics, method_sym);
    ret instantiated;
}

# check_field: type-check field access (expr.field).
fun check_field(sema: *Sema, expr: *ast.Node) *ty.Type {
    val base: *ast.Node = expr.get_child(0);
    if (base == nil) {
        report_error_node(sema, expr, "field access missing base");
        ret nil;
    }

    val field_name: str = expr.get_name();
    if (field_name == nil) {
        report_error_node(sema, expr, "field name missing");
        ret nil;
    }

    # check for module alias access (alias.symbol) BEFORE analyzing the object
    # this prevents errors when the alias name is not in the symbol table
    if (base.kind == ast.NODE_EXPR_IDENT) {
        val ident_name: str = base.get_name();
        if (ident_name != nil) {
            val alias: *ModuleAlias = find_alias(sema, ident_name);
            if (alias != nil && alias.module != nil && alias.module.table != nil) {
                # found module alias - look up symbol in the module's table
                val sym_opt: Option[*symbol.Symbol] = alias.module.table.lookup(field_name);
                if (sym_opt.is_some()) {
                    val sym: *symbol.Symbol = sym_opt.unwrap();
                    if (sym.is_public) {
                        # use lazy analysis to resolve type if needed
                        val resolved: *ty.Type = ensure_symbol_analyzed(sema, sym);
                        # attach symbol to expression for codegen
                        expr.extra = sym::ptr;
                        ret resolved;
                    }
                }
                report_error_node(sema, expr, "undefined symbol in module");
                ret nil;
            }
        }
    }

    # not a module alias, analyze object normally
    val base_type: *ty.Type = check_expr(sema, base);
    if (base_type == nil) {
        ret nil;
    }

    # auto-dereference pointers for field access
    var target_type: *ty.Type = base_type;
    if (base_type.is_pointer()) {
        target_type = ty.get_element_type(base_type);
    }

    # first, try to find a field with this name
    if (target_type.is_record() || target_type.is_union()) {
        val field_opt: Option[*ty.Field] = ty.get_field(target_type, field_name);
        if (field_opt.is_some()) {
            ret field_opt.unwrap().ty;
        }
    }

    # not a field, try to find a method with this name
    val method_type: *ty.Type = lookup_method(sema, target_type, field_name);
    if (method_type != nil) {
        ret method_type;
    }

    # neither field nor method found
    if (target_type.is_record() || target_type.is_union()) {
        print.eprint("  [DEBUG] undefined field/method: ");
        print.eprint(field_name);
        print.eprint(" on type ");
        debug_print_type(target_type);
        print.eprintln("");
        report_error_node(sema, expr, "undefined field or method");
    } or {
        print.eprint("  [DEBUG] field access on non-record: ");
        print.eprint(field_name);
        print.eprint(" on type ");
        debug_print_type(target_type);
        print.eprintln("");
        report_error_node(sema, expr, "field access requires record or union type");
    }
    ret nil;
}

# lookup_method: look up a method on a type by name.
# ---
# handles generic method instantiation for instantiated generic types.
fun lookup_method(sema: *Sema, target_type: *ty.Type, method_name: str) *ty.Type {
    if (target_type == nil || method_name == nil) {
        ret nil;
    }

    # get the type name to look up methods
    var type_name: str = target_type.name;

    # handle primitive types that have methods but no name field
    if (type_name == nil) {
        if (target_type.kind == ty.TY_STR) {
            type_name = "str";
        } or {
            ret nil;
        }
    }

    # for instantiated generic types, use the base generic's name for method lookup
    var lookup_name: str = type_name;
    var is_instantiated_generic: bool = false;
    var generic_args: **ty.Type = nil;
    var generic_arg_count: i32 = 0;

    if (target_type.base_generic != nil) {
        is_instantiated_generic = true;
        generic_args = target_type.generic_args;
        generic_arg_count = target_type.generic_arg_count;
        if (target_type.base_generic.name != nil) {
            lookup_name = target_type.base_generic.name;
        }
    }

    # look up method by iterating through symbols
    # methods are registered with receiver_name set to the type name
    # first check current table
    var method_sym: *symbol.Symbol = find_method_symbol(sema.current_table, lookup_name, method_name);

    # if not found locally, check imported modules (unaliased)
    if (method_sym == nil && sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                method_sym = find_method_symbol(imp.module.table, lookup_name, method_name);
                if (method_sym != nil && method_sym.is_public) {
                    brk;
                }
                method_sym = nil;  # reset if not public
            }
            imp = imp.next;
        }
    }

    # if still not found, check aliased modules
    if (method_sym == nil && sema.current_module != nil) {
        var alias: *ModuleAlias = sema.current_module.aliases;
        for (alias != nil) {
            if (alias.module != nil && alias.module.table != nil) {
                method_sym = find_method_symbol(alias.module.table, lookup_name, method_name);
                if (method_sym != nil && method_sym.is_public) {
                    brk;
                }
                method_sym = nil;  # reset if not public
            }
            alias = alias.next;
        }
    }

    if (method_sym == nil) {
        ret nil;
    }

    # if the method is generic and we have an instantiated receiver, instantiate the method
    if (method_sym.is_generic && is_instantiated_generic && generic_arg_count > 0) {
        ret instantiate_method_for_generic_receiver(sema, method_sym, generic_args, generic_arg_count);
    }

    # use lazy analysis to ensure the method's type is resolved
    ret ensure_symbol_analyzed(sema, method_sym);
}

# find_method_symbol: find a method symbol by receiver type name and method name.
fun find_method_symbol(table: *symbol.Table, receiver_name: str, method_name: str) *symbol.Symbol {
    if (table == nil || receiver_name == nil || method_name == nil) {
        ret nil;
    }

    # build the qualified name "ReceiverType.methodName" that methods are registered with
    # we need to compare against sym.name which contains the qualified name
    val receiver_len: usize = receiver_name.len();
    val method_len: usize = method_name.len();
    val qualified_len: usize = receiver_len + 1 + method_len;  # +1 for dot

    # search through all scopes for a matching method
    var scope: *symbol.Scope = table.current;
    for (scope != nil) {
        var i: i32 = 0;
        for (i < scope.symbol_count) {
            val sym: *symbol.Symbol = ?scope.symbols[i];
            if (sym.is_method && sym.receiver_name != nil && sym.name != nil) {
                # methods are registered with qualified name "ReceiverType.methodName"
                # check receiver_name matches
                if (sym.receiver_name.equals(receiver_name)) {
                    # sym.name is the qualified name, check if it ends with ".methodName"
                    val sym_name_len: usize = sym.name.len();
                    if (sym_name_len == qualified_len) {
                        # check if name is "receiver_name.method_name"
                        val expected_start: bool = sym.name.starts_with(receiver_name);
                        if (expected_start) {
                            # check for dot after receiver name
                            if (sym.name[receiver_len] == 46) {  # '.' = 46
                                # check method name matches after the dot
                                val after_dot: str = (sym.name::u64 + receiver_len + 1)::str;
                                if (after_dot.starts_with(method_name)) {
                                    ret sym;
                                }
                            }
                        }
                    }
                }
            }
            i = i + 1;
        }
        scope = scope.parent;
    }

    ret nil;
}

# instantiate_method_for_generic_receiver: instantiate a method with the receiver's type args.
fun instantiate_method_for_generic_receiver(sema: *Sema, method_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    if (method_sym == nil || method_sym.generic_node == nil || args == nil || arg_count <= 0) {
        ret method_sym.resolved_type;
    }

    # get generic params from the method's generic_node
    val params_node: *ast.Node = method_sym.generic_node;
    val params_list: *ast.List = params_node.children::*ast.List;
    if (params_list == nil || params_list.count != arg_count) {
        ret method_sym.resolved_type;
    }

    # check cache for existing instantiation
    val cached: *ty.Type = find_cached_function_instantiation(sema, method_sym, args, arg_count);
    if (cached != nil) {
        ret cached;
    }

    # create scope with generic param bindings
    val push_res: Result[bool, str] = sema.current_table.push_scope();
    if (push_res.is_err()) {
        ret method_sym.resolved_type;
    }

    # bind each generic parameter to its concrete type
    var i: i32 = 0;
    for (i < arg_count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node != nil) {
            val param_name: str = param_node.data::str;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = sema.current_table.define(param_name, symbol.SYM_GENERIC);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = args[i];
                }
            }
        }
        i = i + 1;
    }

    # resolve parameter and return types with generic params bound
    val decl: *ast.Node = method_sym.decl_node;
    if (decl == nil || decl.kind != ast.NODE_DECL_FUN) {
        val pop_res: Result[bool, str] = sema.current_table.pop_scope();
        ret method_sym.resolved_type;
    }

    # get parameter list from decl.extra
    val params_decl: *ast.List = decl.extra::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_decl != nil && params_decl.count > 0) {
        param_count = params_decl.count;

        val alloc_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (alloc_res.is_ok()) {
            param_types = alloc_res.unwrap_ok();

            var j: i32 = 0;
            for (j < param_count) {
                val param_node: *ast.Node = params_decl.nodes[j];
                if (param_node != nil && param_node.children != nil) {
                    param_types[j] = resolve_type(sema, param_node.children);
                } or {
                    param_types[j] = nil;
                }
                j = j + 1;
            }
        }
    }

    # resolve return type from decl.ret_type
    var ret_type: *ty.Type = nil;
    if (decl.ret_type != nil) {
        ret_type = resolve_type(sema, decl.ret_type);
    }

    if (ret_type == nil) {
        # default to void
        val void_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (void_res.is_ok()) {
            ret_type = void_res.unwrap_ok();
        }
    }

    # pop the generic param scope
    val pop_res: Result[bool, str] = sema.current_table.pop_scope();

    # create the instantiated function type
    val fn_res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (fn_res.is_err()) {
        if (param_types != nil) {
            sema.alloc.free[*ty.Type](param_types, param_count::usize);
        }
        ret method_sym.resolved_type;
    }

    val inst_type: *ty.Type = fn_res.unwrap_ok();

    # attach generic args to the instantiated type
    ty.set_generic_args(ctx, inst_type, args, arg_count);

    # link to base method's type
    if (method_sym.resolved_type != nil) {
        ty.set_base_generic(inst_type, method_sym.resolved_type);
    }

    ret inst_type;
}

# check_index: type-check array/pointer indexing.
fun check_index(sema: *Sema, expr: *ast.Node) *ty.Type {
    val base: *ast.Node = expr.get_child(0);
    val index: *ast.Node = expr.get_child(1);

    if (base == nil || index == nil) {
        report_error_node(sema, expr, "index expression missing operand");
        ret nil;
    }

    val base_type: *ty.Type = check_expr(sema, base);

    # pass isize as hint for index expression (common index type)
    val ctx: *ty.TypeContext = ?sema.types;
    var index_hint: *ty.Type = nil;
    val isize_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ISIZE);
    if (isize_res.is_ok()) {
        index_hint = isize_res.unwrap_ok();
    }
    val index_type: *ty.Type = check_expr_with_hint(sema, index, index_hint);

    if (base_type == nil || index_type == nil) {
        ret nil;
    }

    # str is indexable like a pointer (it's &u8)
    val is_str: bool = base_type.kind == ty.TY_STR;
    if (!base_type.is_array() && !base_type.is_pointer() && !is_str) {
        report_error_node(sema, expr, "cannot index non-array/pointer type");
        ret nil;
    }

    if (!index_type.is_integer()) {
        report_error_node(sema, expr, "index must be integer");
        ret nil;
    }

    # for str, return u8 since str is &u8
    if (is_str) {
        val u8_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_U8);
        if (u8_res.is_ok()) {
            ret u8_res.unwrap_ok();
        }
        ret nil;
    }

    ret ty.get_element_type(base_type);
}

# check_cast: type-check a type cast (expr::Type).
fun check_cast(sema: *Sema, expr: *ast.Node) *ty.Type {
    # parser stores: children[0] = operand, children[1] = target type
    val operand: *ast.Node = expr.get_child(0);
    val target_type_node: *ast.Node = expr.get_child(1);

    if (operand == nil) {
        report_error_node(sema, expr, "cast missing operand");
        ret nil;
    }

    if (target_type_node == nil) {
        report_error_node(sema, expr, "cast missing target type");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    val target_type: *ty.Type = resolve_type(sema, target_type_node);
    if (target_type == nil) {
        ret nil;
    }

    if (!ty.can_cast(operand_type, target_type)) {
        print.eprint("  [DEBUG] cast mismatch: ");
        debug_print_type(operand_type);
        print.eprint(" -> ");
        debug_print_type(target_type);
        print.eprintln("");
        report_error_node(sema, expr, "invalid cast");
        ret nil;
    }

    ret target_type;
}

# check_addr: type-check address-of expression.
fun check_addr(sema: *Sema, expr: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    val operand: *ast.Node = expr.children;
    if (operand == nil) {
        report_error_node(sema, expr, "address-of missing operand");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    # TODO: check operand is lvalue

    val res: Result[*ty.Type, str] = ty.pointer_type(ctx, operand_type, true);
    if (res.is_ok()) {
        ret res.unwrap_ok();
    }

    report_error_node(sema, expr, "failed to create pointer type");
    ret nil;
}

# check_deref: type-check dereference expression.
fun check_deref(sema: *Sema, expr: *ast.Node) *ty.Type {
    val operand: *ast.Node = expr.children;
    if (operand == nil) {
        report_error_node(sema, expr, "dereference missing operand");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    if (!operand_type.is_pointer()) {
        report_error_node(sema, expr, "cannot dereference non-pointer");
        ret nil;
    }

    ret ty.get_element_type(operand_type);
}

# --- statement checking ---

# check_stmt: type-check a statement.
# ---
# sema: analyzer
# stmt: statement AST node
# ret:  true on success, false on error
pub fun check_stmt(sema: *Sema, stmt: *ast.Node) bool {
    if (sema == nil || stmt == nil) {
        ret false;
    }

    val kind: ast.NodeKind = stmt.kind;

    # variable declarations
    if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
        ret check_var_decl(sema, stmt);
    }

    # expression statement
    if (kind == ast.NODE_STMT_EXPR) {
        val expr_type: *ty.Type = check_expr(sema, stmt.children);
        ret expr_type != nil;
    }

    # block statement
    if (kind == ast.NODE_STMT_BLOCK) {
        ret check_block(sema, stmt);
    }

    # if statement
    if (kind == ast.NODE_STMT_IF) {
        ret check_if(sema, stmt);
    }

    # for loop
    if (kind == ast.NODE_STMT_FOR) {
        ret check_for(sema, stmt);
    }

    # return statement
    if (kind == ast.NODE_STMT_RET) {
        ret check_return(sema, stmt);
    }

    # break statement
    if (kind == ast.NODE_STMT_BRK) {
        if (sema.loop_depth <= 0) {
            report_error_node(sema, stmt, "break outside of loop");
            ret false;
        }
        ret true;
    }

    # continue statement
    if (kind == ast.NODE_STMT_CNT) {
        if (sema.loop_depth <= 0) {
            report_error_node(sema, stmt, "continue outside of loop");
            ret false;
        }
        ret true;
    }

    # defer statement
    if (kind == ast.NODE_STMT_FIN) {
        ret check_stmt(sema, stmt.children);
    }

    # inline assembly - skip type checking
    if (kind == ast.NODE_STMT_MASM) {
        ret true;
    }

    # declarations at statement level
    if (kind == ast.NODE_DECL_FUN) {
        ret check_function(sema, stmt);
    }

    if (kind == ast.NODE_DECL_REC || kind == ast.NODE_DECL_UNI) {
        # type declarations are handled in collection pass
        ret true;
    }

    report_error_node(sema, stmt, "unsupported statement");
    ret false;
}

# check_var_decl: check a val/var declaration.
fun check_var_decl(sema: *Sema, stmt: *ast.Node) bool {
    val name: str = stmt.get_name();
    if (name == nil) {
        report_error_node(sema, stmt, "declaration missing name");
        ret false;
    }

    val is_mutable: bool = stmt.kind == ast.NODE_DECL_VAR;
    val sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
    if (is_mutable) {
        # SymbolKind constant
    }

    # lookup symbol (should already be defined by collect_declarations)
    var sym: *symbol.Symbol = nil;
    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_some()) {
        sym = sym_opt.unwrap();
    } or {
        # not found - define it (for local variables in blocks)
        val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
            name,
            sym_kind
        );

        if (def_res.is_err()) {
            report_error_node(sema, stmt, "redefinition of symbol");
            ret false;
        }
        sym = def_res.unwrap_ok();
    }

    sym.decl_node = stmt;
    sym.is_mutable = is_mutable;

    # resolve declared type if present
    var declared_type: *ty.Type = nil;
    if (stmt.extra != nil) {
        declared_type = resolve_type(sema, stmt.extra::*ast.Node);
    }

    # check initializer if present, passing declared type as hint for literal inference
    var init_type: *ty.Type = nil;
    if (stmt.children != nil) {
        init_type = check_expr_with_hint(sema, stmt.children, declared_type);
    }

    # determine symbol type
    if (declared_type != nil) {
        sym.resolved_type = declared_type;
        if (init_type != nil && !ty.can_assign(init_type, declared_type)) {
            report_error_node(sema, stmt, "initializer type mismatch");
            ret false;
        }
    } or {
        if (init_type != nil) {
            sym.resolved_type = init_type;
        } or {
            report_error_node(sema, stmt, "cannot infer type without initializer");
            ret false;
        }
    }

    ret true;
}

# check_block: check a block statement.
fun check_block(sema: *Sema, stmt: *ast.Node) bool {
    # push new scope
    val push_res: Result[bool, str] = sema.current_table.push_scope();
    if (push_res.is_err()) {
        report_error_node(sema, stmt, "failed to push scope");
        ret false;
    }

    var success: bool = true;
    var terminated: bool = false;

    # check each statement in block
    val list: *ast.List = stmt.get_list();
    if (list != nil) {
        var i: i32 = 0;
        for (i < list.count) {
            val s: *ast.Node = list.nodes[i];
            if (s == nil) {
                i = i + 1;
                cnt;
            }

            # check for unreachable code
            if (terminated) {
                report_error_node(sema, s, "unreachable code");
                # still check the statement for other errors
            }

            if (!check_stmt(sema, s)) {
                success = false;
            }

            # check if this statement terminates the block
            if (is_terminal_stmt(s)) {
                terminated = true;
            }

            i = i + 1;
        }
    }

    # pop scope
    val pop_res: Result[bool, str] = sema.current_table.pop_scope();
    if (pop_res.is_err()) {
        # this shouldn't happen
    }

    ret success;
}

# is_terminal_stmt: check if a statement terminates control flow.
fun is_terminal_stmt(stmt: *ast.Node) bool {
    if (stmt == nil) {
        ret false;
    }

    val kind: ast.NodeKind = stmt.kind;

    # ret, brk, cnt are terminal
    if (kind == ast.NODE_STMT_RET || kind == ast.NODE_STMT_BRK || kind == ast.NODE_STMT_CNT) {
        ret true;
    }

    # a block is terminal if its last statement is terminal
    if (kind == ast.NODE_STMT_BLOCK) {
        val list: *ast.List = stmt.get_list();
        if (list != nil && list.count > 0) {
            ret is_terminal_stmt(list.nodes[list.count - 1]);
        }
        ret false;
    }

    # if/or is terminal if both branches are terminal
    if (kind == ast.NODE_STMT_IF) {
        val then_branch: *ast.Node = stmt.get_child(1);
        val else_branch: *ast.Node = stmt.get_child(2);

        # must have else branch to be terminal
        if (else_branch == nil) {
            ret false;
        }

        ret is_terminal_stmt(then_branch) && is_terminal_stmt(else_branch);
    }

    # for with no condition (infinite loop) that contains no break could be terminal
    # but conservatively, we don't consider for loops terminal
    ret false;
}

# block_returns: check if a block always returns.
# ---
# used to detect missing returns in non-void functions.
# returns true if all execution paths through the block end with a return.
fun block_returns(stmt: *ast.Node) bool {
    if (stmt == nil) {
        ret false;
    }

    val kind: ast.NodeKind = stmt.kind;

    # a return statement always returns
    if (kind == ast.NODE_STMT_RET) {
        ret true;
    }

    # a block returns if its last statement returns, or if any unconditional return exists
    if (kind == ast.NODE_STMT_BLOCK) {
        val list: *ast.List = stmt.get_list();
        if (list == nil || list.count == 0) {
            ret false;
        }

        # check if any statement in the block is an unconditional return
        var i: i32 = 0;
        for (i < list.count) {
            val s: *ast.Node = list.nodes[i];
            if (s != nil && s.kind == ast.NODE_STMT_RET) {
                ret true;
            }
            i = i + 1;
        }

        # check if last statement returns
        val last: *ast.Node = list.nodes[list.count - 1];
        ret block_returns(last);
    }

    # an if/or returns if both branches return
    if (kind == ast.NODE_STMT_IF) {
        val then_branch: *ast.Node = stmt.get_child(1);
        val else_branch: *ast.Node = stmt.get_child(2);

        # must have else branch for guaranteed return
        if (else_branch == nil) {
            ret false;
        }

        # then branch must return
        if (!block_returns(then_branch)) {
            ret false;
        }

        # else branch: could be a block, another if, or an or-chain
        ret or_chain_returns(else_branch);
    }

    # NODE_STMT_OR: part of an or-chain
    if (kind == ast.NODE_STMT_OR) {
        ret or_chain_returns(stmt);
    }

    # for loops don't guarantee return (condition could be false)
    if (kind == ast.NODE_STMT_FOR) {
        ret false;
    }

    # break/continue don't return
    if (kind == ast.NODE_STMT_BRK || kind == ast.NODE_STMT_CNT) {
        ret false;
    }

    # expression statements don't return
    if (kind == ast.NODE_STMT_EXPR) {
        ret false;
    }

    # defer doesn't return
    if (kind == ast.NODE_STMT_FIN) {
        ret false;
    }

    ret false;
}

# or_chain_returns: check if an or-chain guarantees a return.
# walks the linked list of NODE_STMT_OR nodes.
fun or_chain_returns(node: *ast.Node) bool {
    if (node == nil) {
        ret false;
    }

    val kind: ast.NodeKind = node.kind;

    # if it's a regular statement (block, if, etc.), check it directly
    if (kind != ast.NODE_STMT_OR) {
        ret block_returns(node);
    }

    # NODE_STMT_OR: body in data, next in extra
    val body: *ast.Node = node.data::*ast.Node;
    if (!block_returns(body)) {
        ret false;
    }

    # check for next in chain
    val next_or: *ast.Node = node.extra::*ast.Node;
    if (next_or != nil) {
        # must continue checking the chain
        ret or_chain_returns(next_or);
    }

    # no more in chain - check if this was an unconditional else (no condition)
    # an unconditional or (no condition) guarantees the else path is covered
    val cond: *ast.Node = node.children;
    if (cond == nil) {
        # unconditional or - this is the final else, and it returns
        ret true;
    }

    # conditional or with no next - not all paths covered
    ret false;
}

# check_if: check an if statement.
fun check_if(sema: *Sema, stmt: *ast.Node) bool {
    # condition is first child
    val cond: *ast.Node = stmt.get_child(0);
    if (cond != nil) {
        val cond_type: *ty.Type = check_expr(sema, cond);
        if (cond_type != nil && !cond_type.is_bool()) {
            report_error_node(sema, cond, "if condition must be bool");
        }
    }

    # then branch is second child
    val then_branch: *ast.Node = stmt.get_child(1);
    if (then_branch != nil) {
        check_stmt(sema, then_branch);
    }

    # else/or chain is third child (if present)
    val or_chain: *ast.Node = stmt.get_child(2);
    if (or_chain != nil) {
        check_or_chain(sema, or_chain);
    }

    ret true;
}

# check_or_chain: check an or chain (linked list of NODE_STMT_OR).
fun check_or_chain(sema: *Sema, or_node: *ast.Node) {
    if (sema == nil || or_node == nil) {
        ret;
    }

    # if this is a regular statement (e.g., else block or else if), just check it
    if (or_node.kind != ast.NODE_STMT_OR) {
        check_stmt(sema, or_node);
        ret;
    }

    # NODE_STMT_OR: condition in children, body in data, next in extra
    # check condition if present
    val cond: *ast.Node = or_node.children;
    if (cond != nil) {
        val cond_type: *ty.Type = check_expr(sema, cond);
        if (cond_type != nil && !cond_type.is_bool()) {
            report_error_node(sema, cond, "or condition must be bool");
        }
    }

    # check body (stored in data)
    val body: *ast.Node = or_node.data::*ast.Node;
    if (body != nil) {
        check_stmt(sema, body);
    }

    # check next or node in chain (stored in extra)
    val next_or: *ast.Node = or_node.extra::*ast.Node;
    if (next_or != nil) {
        check_or_chain(sema, next_or);
    }
}

# check_for: check a for loop.
fun check_for(sema: *Sema, stmt: *ast.Node) bool {
    sema.loop_depth = sema.loop_depth + 1;

    # condition is first child (may be nil for infinite loop)
    val cond: *ast.Node = stmt.get_child(0);
    if (cond != nil) {
        val cond_type: *ty.Type = check_expr(sema, cond);
        if (cond_type != nil && !cond_type.is_bool()) {
            report_error_node(sema, cond, "for condition must be bool");
        }
    }

    # push scope for loop body - variables declared in the loop are local to it
    val push_res: Result[bool, str] = sema.current_table.push_scope();

    # body is second child
    val body: *ast.Node = stmt.get_child(1);
    if (body != nil) {
        check_stmt(sema, body);
    }

    # pop loop scope
    if (push_res.is_ok()) {
        sema.current_table.pop_scope();
    }

    sema.loop_depth = sema.loop_depth - 1;
    ret true;
}

# check_return: check a return statement.
fun check_return(sema: *Sema, stmt: *ast.Node) bool {
    var ret_type: *ty.Type = nil;

    # pass expected return type as hint for literal inference
    if (stmt.children != nil) {
        ret_type = check_expr_with_hint(sema, stmt.children, sema.current_fn_ret);
    }

    # check against current function's return type
    if (sema.current_fn_ret != nil) {
        if (ret_type == nil) {
            if (!sema.current_fn_ret.is_void()) {
                report_error_node(sema, stmt, "missing return value");
                ret false;
            }
        } or {
            if (!ty.can_assign(ret_type, sema.current_fn_ret)) {
                print.eprint("  [DEBUG] return mismatch: ");
                debug_print_type(ret_type);
                print.eprint(" -> ");
                debug_print_type(sema.current_fn_ret);
                print.eprintln("");
                report_error_node(sema, stmt, "return type mismatch");
                ret false;
            }
        }
    }

    ret true;
}

# define_receiver: define the method receiver (e.g., "this") in the current scope.
fun define_receiver(sema: *Sema, decl: *ast.Node) bool {
    if (decl.receiver == nil) {
        ret true;  # not a method, nothing to do
    }

    val receiver: *ast.Node = decl.receiver;

    # receiver name is in data field
    val receiver_name: str = receiver.data::str;
    if (receiver_name == nil) {
        ret true;  # no receiver name
    }

    # define receiver as a parameter symbol
    val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
        receiver_name,
        symbol.SYM_PARAM
    );

    if (def_res.is_ok()) {
        val recv_sym: *symbol.Symbol = def_res.unwrap_ok();
        recv_sym.decl_node = receiver;
        recv_sym.is_mutable = false;

        # resolve receiver type from children
        if (receiver.children != nil) {
            recv_sym.resolved_type = resolve_type(sema, receiver.children);
        }
    }

    ret true;
}

# define_parameters: define function parameters in current scope.
fun define_parameters(sema: *Sema, decl: *ast.Node) bool {
    # params are stored in node.extra as *List
    val params_list: *ast.List = decl.extra::*ast.List;
    if (params_list == nil || params_list.count == 0) {
        ret true;
    }

    var i: i32 = 0;
    for (i < params_list.count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node == nil) {
            i = i + 1;
            cnt;
        }

        val param_name: str = param_node.get_name();
        if (param_name == nil) {
            i = i + 1;
            cnt;
        }

        # define parameter symbol
        val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
            param_name,
            symbol.SYM_PARAM
        );

        if (def_res.is_ok()) {
            val param_sym: *symbol.Symbol = def_res.unwrap_ok();
            param_sym.decl_node = param_node;
            param_sym.is_mutable = false;  # parameters are immutable by default

            # resolve parameter type
            if (param_node.children != nil) {
                param_sym.resolved_type = resolve_type(sema, param_node.children);
            }
        }

        i = i + 1;
    }

    ret true;
}

# check_function: check a function declaration.
fun check_function(sema: *Sema, stmt: *ast.Node) bool {
    val name: str = stmt.get_name();
    if (name == nil) {
        report_error_node(sema, stmt, "function missing name");
        ret false;
    }

    # for methods, use qualified name "ReceiverType.methodName"
    var symbol_name: str = name;
    if (stmt.receiver != nil) {
        val receiver: *ast.Node = stmt.receiver;
        if (receiver.children != nil) {
            val receiver_type_name: str = get_receiver_type_name(receiver.children);
            if (receiver_type_name != nil) {
                val qualified: str = build_method_symbol_name(sema, receiver_type_name, name);
                if (qualified != nil) {
                    symbol_name = qualified;
                }
            }
        }
    }

    # lookup or define symbol
    var sym: *symbol.Symbol = nil;
    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(symbol_name);
    if (sym_opt.is_some()) {
        sym = sym_opt.unwrap();
        # skip full analysis of generic functions - they're analyzed at instantiation time
        if (sym.is_generic) {
            ret true;
        }
    } or {
        val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
            symbol_name,
            symbol.SYM_FUN
        );
        if (def_res.is_err()) {
            report_error_node(sema, stmt, "failed to define function");
            ret false;
        }
        sym = def_res.unwrap_ok();
    }

    sym.decl_node = stmt;

    # skip generic functions - check generics node on AST or symbol
    # this handles cases where is_generic wasn't set yet, or methods on generic receivers
    if (stmt.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = stmt.generics;
        ret true;
    }

    # check if this is a method on a generic type - skip if so
    if (stmt.receiver != nil) {
        val receiver: *ast.Node = stmt.receiver;
        if (receiver.children != nil) {
            val receiver_type_name: str = get_receiver_type_name(receiver.children);
            if (receiver_type_name != nil) {
                val recv_sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(receiver_type_name);
                if (recv_sym_opt.is_some()) {
                    val recv_sym: *symbol.Symbol = recv_sym_opt.unwrap();
                    if (recv_sym.is_generic) {
                        # method on generic type - skip until instantiation
                        sym.is_generic = true;
                        sym.generic_node = recv_sym.generic_node;
                        ret true;
                    }
                }
            }
        }
    }

    # save previous function context
    val prev_fn: *symbol.Symbol = sema.current_fn;
    val prev_ret: *ty.Type = sema.current_fn_ret;

    sema.current_fn = sym;

    # get return type from resolved function type if available
    if (sym.resolved_type != nil && sym.resolved_type.is_function()) {
        sema.current_fn_ret = sym.resolved_type.ret_type;
    } or {
        # fallback: try to resolve from AST ret_type field
        if (stmt.ret_type != nil) {
            sema.current_fn_ret = resolve_type(sema, stmt.ret_type);
        } or {
            # default void return
            val res: Result[*ty.Type, str] = ty.primitive_type(?sema.types, ty.TY_VOID);
            if (res.is_ok()) {
                sema.current_fn_ret = res.unwrap_ok();
            }
        }
    }

    # update symbol type if not already set
    if (sym.resolved_type == nil) {
        sym.resolved_type = sema.current_fn_ret;
    }

    # push function scope for parameters and body
    val push_res: Result[bool, str] = sema.current_table.push_scope();
    if (push_res.is_err()) {
        ret false;
    }

    # define receiver (this) for methods
    define_receiver(sema, stmt);

    # define parameters in scope
    define_parameters(sema, stmt);

    # check function body (stored directly in children)
    var body: *ast.Node = stmt.children;

    var check_result: bool = true;
    if (body != nil && body.kind == ast.NODE_STMT_BLOCK) {
        check_result = check_block(sema, body);

        # check for missing return in non-void functions
        if (sema.current_fn_ret != nil && !sema.current_fn_ret.is_void()) {
            if (!block_returns(body)) {
                report_error_node(sema, stmt, "function may not return a value");
            }
        }
    }

    # pop function scope
    val pop_res: Result[bool, str] = sema.current_table.pop_scope();

    # restore previous function context
    sema.current_fn = prev_fn;
    sema.current_fn_ret = prev_ret;

    ret check_result;
}

# --- multi-pass analysis ---

# collect_declarations: first pass - collect all top-level declarations.
fun collect_declarations(sema: *Sema, program: *ast.Node) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }

    val list: *ast.List = program.get_list();
    if (list == nil) {
        ret true;
    }

    var success: bool = true;

    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # handle comptime if - evaluate condition and only process taken branch
        if (kind == ast.NODE_COMPTIME_IF) {
            collect_comptime_if(sema, decl);
            i = i + 1;
            cnt;
        }

        var name: str = decl.get_name();
        var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
        var is_public: bool = false;

        # handle pub modifier - it wraps the actual declaration
        var actual_decl: *ast.Node = decl;
        var actual_kind: ast.NodeKind = kind;
        if (kind == ast.NODE_DECL_PUB) {
            is_public = true;
            # the wrapped declaration is in children
            actual_decl = decl.children;
            if (actual_decl != nil) {
                actual_kind = actual_decl.kind;
                name = actual_decl.get_name();
            } or {
                i = i + 1;
                cnt;
            }
        }

        if (actual_kind == ast.NODE_DECL_VAL) {
            sym_kind = symbol.SYM_VAL;
        } or {
            if (actual_kind == ast.NODE_DECL_VAR) {
                sym_kind = symbol.SYM_VAR;
            } or {
                if (actual_kind == ast.NODE_DECL_FUN) {
                    sym_kind = symbol.SYM_FUN;
                } or {
                    if (actual_kind == ast.NODE_DECL_REC) {
                        sym_kind = symbol.SYM_REC;
                    } or {
                        if (actual_kind == ast.NODE_DECL_UNI) {
                            sym_kind = symbol.SYM_UNI;
                        } or {
                            if (actual_kind == ast.NODE_DECL_DEF) {
                                sym_kind = symbol.SYM_TYPE;
                            } or {
                                if (actual_kind == ast.NODE_DECL_EXT) {
                                    sym_kind = symbol.SYM_EXT;
                                } or {
                                    if (actual_kind == ast.NODE_DECL_USE) {
                                        # handle use declarations separately
                                        collect_use_decl(sema, actual_decl);
                                        i = i + 1;
                                        cnt;
                                    } or {
                                        # skip test, etc.
                                        i = i + 1;
                                        cnt;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        # for methods, use qualified name "ReceiverType.methodName"
        var symbol_name: str = name;
        var receiver_type_name: str = nil;
        var is_method: bool = false;

        if (actual_kind == ast.NODE_DECL_FUN && actual_decl.receiver != nil) {
            is_method = true;
            # extract receiver type name from receiver node
            val receiver: *ast.Node = actual_decl.receiver;
            if (receiver.children != nil) {
                receiver_type_name = get_receiver_type_name(receiver.children);
            }
            # build qualified name for methods to avoid collisions
            if (receiver_type_name != nil && name != nil) {
                val qualified: str = build_method_symbol_name(sema, receiver_type_name, name);
                if (qualified != nil) {
                    symbol_name = qualified;
                }
            }
        }

        if (symbol_name != nil) {
            val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
                symbol_name,
                sym_kind
            );

            if (def_res.is_ok()) {
                val sym: *symbol.Symbol = def_res.unwrap_ok();
                sym.decl_node = actual_decl;
                sym.is_public = is_public;
                sym.module_path = sema.module_path;

                # detect generic declarations via node.generics field
                if (actual_decl.generics != nil) {
                    sym.is_generic = true;
                    sym.generic_node = actual_decl.generics;
                }

                # detect methods
                if (is_method) {
                    sym.is_method = true;
                    sym.receiver_name = receiver_type_name;

                    # for methods on generic types, inherit generic params from receiver
                    if (receiver_type_name != nil && actual_decl.generics == nil) {
                        # look up the receiver type to get its generic params
                        val recv_sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(receiver_type_name);
                        if (recv_sym_opt.is_some()) {
                            val recv_sym: *symbol.Symbol = recv_sym_opt.unwrap();
                            if (recv_sym.is_generic && recv_sym.generic_node != nil) {
                                sym.is_generic = true;
                                sym.generic_node = recv_sym.generic_node;
                            }
                        }
                    }
                }
            } or {
                report_error_node(sema, decl, "duplicate definition");
                success = false;
            }
        }

        i = i + 1;
    }

    ret success;
}

# collect_comptime_if: handle a comptime if declaration.
# ---
# evaluates the condition and collects declarations from the taken branch only.
fun collect_comptime_if(sema: *Sema, decl: *ast.Node) {
    if (sema == nil || decl == nil) {
        ret;
    }

    # get condition from children
    val cond: *ast.Node = decl.children;

    # evaluate condition using a temporary comptime context
    var cond_val: bool = false;
    if (cond != nil) {
        var ctx: comptime.ComptimeContext = comptime.init(sema.alloc, sema.current_table, ?sema.types);
        val eval_res: Result[bool, str] = comptime.eval_condition(?ctx, cond);
        if (eval_res.is_ok()) {
            cond_val = eval_res.unwrap_ok();
        }
    }

    if (cond_val) {
        # condition is true - process body
        val body: *ast.Node = decl.data::*ast.Node;
        if (body != nil) {
            collect_block_declarations(sema, body);
        }
    } or {
        # condition is false - try $or chain
        val or_node: *ast.Node = decl.extra::*ast.Node;
        if (or_node != nil) {
            collect_comptime_or(sema, or_node);
        }
    }
}

# collect_comptime_or: handle a comptime or branch.
fun collect_comptime_or(sema: *Sema, decl: *ast.Node) {
    if (sema == nil || decl == nil) {
        ret;
    }

    # get optional condition from children (nil means unconditional else)
    val cond: *ast.Node = decl.children;

    var cond_val: bool = true;  # default to true for unconditional $or
    if (cond != nil) {
        var ctx: comptime.ComptimeContext = comptime.init(sema.alloc, sema.current_table, ?sema.types);
        val eval_res: Result[bool, str] = comptime.eval_condition(?ctx, cond);
        if (eval_res.is_ok()) {
            cond_val = eval_res.unwrap_ok();
        } or {
            cond_val = false;
        }
    }

    if (cond_val) {
        # condition is true (or unconditional) - process body and STOP
        val body: *ast.Node = decl.data::*ast.Node;
        if (body != nil) {
            collect_block_declarations(sema, body);
        }
    } or {
        # condition is false - try next $or in chain
        val or_node: *ast.Node = decl.extra::*ast.Node;
        if (or_node != nil) {
            collect_comptime_or(sema, or_node);
        }
    }
}

# collect_block_declarations: collect declarations from a block (for comptime if bodies).
fun collect_block_declarations(sema: *Sema, block: *ast.Node) {
    if (sema == nil || block == nil) {
        ret;
    }

    val list: *ast.List = block.get_list();
    if (list == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl != nil) {
            collect_single_declaration(sema, decl);
        }
        i = i + 1;
    }
}

# collect_single_declaration: collect a single declaration (extracted for reuse).
fun collect_single_declaration(sema: *Sema, decl: *ast.Node) {
    if (sema == nil || decl == nil) {
        ret;
    }

    val kind: ast.NodeKind = decl.kind;

    # handle nested comptime if
    if (kind == ast.NODE_COMPTIME_IF) {
        collect_comptime_if(sema, decl);
        ret;
    }

    var name: str = decl.get_name();
    var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
    var is_public: bool = false;

    var actual_decl: *ast.Node = decl;
    var actual_kind: ast.NodeKind = kind;

    if (kind == ast.NODE_DECL_PUB) {
        is_public = true;
        actual_decl = decl.children;
        if (actual_decl != nil) {
            actual_kind = actual_decl.kind;
            name = actual_decl.get_name();
        } or {
            ret;
        }
    }

    if (actual_kind == ast.NODE_DECL_VAL) {
        sym_kind = symbol.SYM_VAL;
    } or {
        if (actual_kind == ast.NODE_DECL_VAR) {
            sym_kind = symbol.SYM_VAR;
        } or {
            if (actual_kind == ast.NODE_DECL_FUN) {
                sym_kind = symbol.SYM_FUN;
            } or {
                if (actual_kind == ast.NODE_DECL_REC) {
                    sym_kind = symbol.SYM_REC;
                } or {
                    if (actual_kind == ast.NODE_DECL_UNI) {
                        sym_kind = symbol.SYM_UNI;
                    } or {
                        if (actual_kind == ast.NODE_DECL_DEF) {
                            sym_kind = symbol.SYM_TYPE;
                        } or {
                            if (actual_kind == ast.NODE_DECL_EXT) {
                                sym_kind = symbol.SYM_EXT;
                            } or {
                                if (actual_kind == ast.NODE_DECL_USE) {
                                    collect_use_decl(sema, actual_decl);
                                    ret;
                                } or {
                                    ret;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if (name != nil) {
        val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
            name,
            sym_kind
        );

        if (def_res.is_ok()) {
            val sym: *symbol.Symbol = def_res.unwrap_ok();
            sym.decl_node = actual_decl;
            sym.is_public = is_public;
            sym.module_path = sema.module_path;

            if (actual_decl.generics != nil) {
                sym.is_generic = true;
                sym.generic_node = actual_decl.generics;
            }
        }
    }
}

# collect_use_decl: handle a use declaration.
# ---
# loads the imported module and registers aliases for access.
fun collect_use_decl(sema: *Sema, decl: *ast.Node) {
    if (sema == nil || decl == nil) {
        ret;
    }

    # path is stored in data
    val module_path: str = decl.get_name();
    if (module_path == nil) {
        ret;
    }

    # load the module
    val load_res: Result[*SemaModule, str] = load_module(sema, module_path);

    if (load_res.is_err()) {
        # module loading failed - report error but continue
        report_error_node(sema, decl, "failed to load module");
        ret;
    }

    val loaded_mod: *SemaModule = load_res.unwrap_ok();

    # check if there's an alias (count > 0 means alias was provided)
    # for aliased imports like "use foo: bar.baz;", we create an alias
    if (decl.count > 0 && decl.extra != nil) {
        val alias_name: str = decl.extra::str;
        if (alias_name != nil && sema.current_module != nil) {
            # create ModuleAlias and add to current module's alias list
            val alias_alloc_res: Result[*ModuleAlias, allocator.AllocError] = sema.alloc.zalloc[ModuleAlias](1);
            if (alias_alloc_res.is_ok()) {
                val alias: *ModuleAlias = alias_alloc_res.unwrap_ok();
                alias.alias = alias_name;
                alias.module = loaded_mod;
                alias.next = sema.current_module.aliases;
                sema.current_module.aliases = alias;
            }
        }
        ret;
    }

    # unaliased import - add to imports list for symbol lookup
    if (sema.current_module != nil) {
        val import_alloc_res: Result[*ModuleImport, allocator.AllocError] = sema.alloc.zalloc[ModuleImport](1);
        if (import_alloc_res.is_ok()) {
            val imp: *ModuleImport = import_alloc_res.unwrap_ok();
            imp.module = loaded_mod;
            imp.next = sema.current_module.imports;
            sema.current_module.imports = imp;

        }
    }

    # also register the module path as a symbol for module.symbol access
    val def_res: Result[*symbol.Symbol, str] = sema.current_table.define(
        module_path,
        symbol.SYM_MODULE
    );

    if (def_res.is_ok()) {
        val sym: *symbol.Symbol = def_res.unwrap_ok();
        sym.decl_node = decl;
    }
    # ignore duplicate module imports
}

# resolve_types: second pass - resolve all type references.
fun resolve_types(sema: *Sema, program: *ast.Node) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }

    val list: *ast.List = program.get_list();
    if (list == nil) {
        ret true;
    }

    var success: bool = true;

    # first pass: create type shells for records/unions (allows forward references)
    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # create record type shell
        if (kind == ast.NODE_DECL_REC) {
            val name: str = decl.get_name();
            if (name != nil) {
                val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
                if (sym_opt.is_some()) {
                    val sym: *symbol.Symbol = sym_opt.unwrap();
                    if (sym.resolved_type == nil) {
                        val ctx: *ty.TypeContext = ?sema.types;
                        val res: Result[*ty.Type, str] = ty.record_type(ctx, name, nil, 0);
                        if (res.is_ok()) {
                            sym.resolved_type = res.unwrap_ok();
                        }
                    }
                }
            }
        }

        # create union type shell
        if (kind == ast.NODE_DECL_UNI) {
            val name: str = decl.get_name();
            if (name != nil) {
                val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
                if (sym_opt.is_some()) {
                    val sym: *symbol.Symbol = sym_opt.unwrap();
                    if (sym.resolved_type == nil) {
                        val ctx: *ty.TypeContext = ?sema.types;
                        val res: Result[*ty.Type, str] = ty.union_type(ctx, name, nil, 0);
                        if (res.is_ok()) {
                            sym.resolved_type = res.unwrap_ok();
                        }
                    }
                }
            }
        }

        i = i + 1;
    }

    # second pass: resolve type aliases (def)
    i = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl != nil && decl.kind == ast.NODE_DECL_DEF) {
            if (!resolve_def_type(sema, decl)) {
                success = false;
            }
        }
        i = i + 1;
    }

    # third pass: resolve record/union fields (now all types are known)
    i = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # resolve record field types
        if (kind == ast.NODE_DECL_REC) {
            if (!resolve_record_type(sema, decl)) {
                success = false;
            }
        }

        # resolve union variant types
        if (kind == ast.NODE_DECL_UNI) {
            if (!resolve_union_type(sema, decl)) {
                success = false;
            }
        }

        i = i + 1;
    }

    # fourth pass: resolve function types
    i = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        if (kind == ast.NODE_DECL_FUN) {
            if (!resolve_function_decl(sema, decl)) {
                success = false;
            }
        }

        if (kind == ast.NODE_DECL_EXT) {
            if (!resolve_ext_decl(sema, decl)) {
                success = false;
            }
        }

        if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
            if (!resolve_var_decl_type(sema, decl)) {
                success = false;
            }
        }

        i = i + 1;
    }

    ret success;
}

# resolve_record_type: resolve a record type declaration.
fun resolve_record_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = decl.get_name();
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    val ctx: *ty.TypeContext = ?sema.types;

    # skip generic records - defer field resolution until instantiation
    if (sym.is_generic || decl.generics != nil) {
        sym.is_generic = true;
        # create empty record type shell for the generic
        if (sym.resolved_type == nil) {
            val res: Result[*ty.Type, str] = ty.record_type(ctx, name, nil, 0);
            if (res.is_ok()) {
                sym.resolved_type = res.unwrap_ok();
            }
        }
        ret true;
    }

    # cycle detection
    if (sym.is_being_resolved) {
        print.eprint("  [DEBUG] circular dependency: ");
        print.eprintln(name);
        report_error_node(sema, decl, "circular type dependency detected");
        ret false;
    }

    # if already resolved, skip
    if (sym.resolved_type != nil && sym.resolved_type.field_count > 0) {
        ret true;
    }

    sym.is_being_resolved = true;

    # create type first to allow self-references (with nil fields)
    var rec_type: *ty.Type = sym.resolved_type;
    if (rec_type == nil) {
        val res: Result[*ty.Type, str] = ty.record_type(ctx, name, nil, 0);
        if (res.is_err()) {
            sym.is_being_resolved = false;
            report_error_node(sema, decl, "failed to create record type");
            ret false;
        }
        rec_type = res.unwrap_ok();
        sym.resolved_type = rec_type;
    }

    # now resolve field types
    # fields are stored in node.children as a *List (cast from *Node)
    val fields_list: *ast.List = decl.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        # empty record
        ret true;
    }

    val field_count: i32 = fields_list.count;

    # allocate Field array
    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, decl, "failed to allocate fields");
        ret false;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    # resolve each field
    var offset: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        # field name is in data
        val field_name: str = field_node.get_name();

        # field type is in children
        val type_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (type_node != nil) {
            field_type = resolve_type(sema, type_node);
        }

        if (field_type == nil) {
            # use error type as placeholder
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        # compute alignment and offset
        var field_align: usize = 1;
        var field_size: usize = 0;
        if (field_type != nil) {
            field_align = field_type.align;
            field_size = field_type.size;
            if (field_align > max_align) {
                max_align = field_align;
            }
        }

        # align offset
        if (field_align > 0) {
            offset = (offset + field_align - 1) & ~(field_align - 1);
        }

        # store field
        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = offset;

        offset = offset + field_size;
        i = i + 1;
    }

    # final padding for struct alignment
    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    # update record type with resolved fields
    rec_type.fields = fields;
    rec_type.field_count = field_count;
    rec_type.size = offset;
    rec_type.align = max_align;

    sym.is_being_resolved = false;
    ret true;
}

# resolve_union_type: resolve a union type declaration.
fun resolve_union_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = decl.get_name();
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    val ctx: *ty.TypeContext = ?sema.types;

    # skip generic unions - defer variant resolution until instantiation
    if (sym.is_generic || decl.generics != nil) {
        sym.is_generic = true;
        # create empty union type shell for the generic
        if (sym.resolved_type == nil) {
            val res: Result[*ty.Type, str] = ty.union_type(ctx, name, nil, 0);
            if (res.is_ok()) {
                sym.resolved_type = res.unwrap_ok();
            }
        }
        ret true;
    }

    # cycle detection
    if (sym.is_being_resolved) {
        print.eprint("  [DEBUG] circular dependency (union): ");
        print.eprintln(name);
        report_error_node(sema, decl, "circular type dependency detected");
        ret false;
    }

    # if already resolved, skip
    if (sym.resolved_type != nil && sym.resolved_type.field_count > 0) {
        ret true;
    }

    sym.is_being_resolved = true;

    # create type first to allow self-references (with nil fields)
    var uni_type: *ty.Type = sym.resolved_type;
    if (uni_type == nil) {
        val res: Result[*ty.Type, str] = ty.union_type(ctx, name, nil, 0);
        if (res.is_err()) {
            sym.is_being_resolved = false;
            report_error_node(sema, decl, "failed to create union type");
            ret false;
        }
        uni_type = res.unwrap_ok();
        sym.resolved_type = uni_type;
    }

    # now resolve variant types
    # variants are stored in node.children as a *List (cast from *Node)
    val fields_list: *ast.List = decl.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        # empty union
        ret true;
    }

    val field_count: i32 = fields_list.count;

    # allocate Field array
    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, decl, "failed to allocate variants");
        ret false;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    # resolve each variant
    var max_size: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        # variant name is in data
        val field_name: str = field_node.get_name();

        # variant type is in children
        val type_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (type_node != nil) {
            field_type = resolve_type(sema, type_node);
        }

        if (field_type == nil) {
            # use error type as placeholder
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        # track max size and alignment
        if (field_type != nil) {
            if (field_type.size > max_size) {
                max_size = field_type.size;
            }
            if (field_type.align > max_align) {
                max_align = field_type.align;
            }
        }

        # store variant (all variants at offset 0)
        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = 0;

        i = i + 1;
    }

    # align max_size
    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    # mach unions are untagged (like C unions) - no tag bytes
    # update union type with resolved variants
    uni_type.fields = fields;
    uni_type.field_count = field_count;
    uni_type.size = max_size;
    uni_type.align = max_align;

    sym.is_being_resolved = false;
    ret true;
}

# resolve_def_type: resolve a type alias definition.
fun resolve_def_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = decl.get_name();
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # the aliased type is in children
    val type_node: *ast.Node = decl.children;
    if (type_node == nil) {
        report_error_node(sema, decl, "type alias missing target type");
        ret false;
    }

    val aliased_type: *ty.Type = resolve_type(sema, type_node);
    if (aliased_type == nil) {
        report_error_node(sema, decl, "failed to resolve aliased type");
        ret false;
    }

    sym.resolved_type = aliased_type;
    ret true;
}

# resolve_function_type: resolve a function declaration's type.
fun resolve_function_decl(sema: *Sema, decl: *ast.Node) bool {
    val name: str = decl.get_name();
    if (name == nil) {
        ret false;
    }

    # for methods, use qualified name "ReceiverType.methodName"
    var symbol_name: str = name;
    if (decl.receiver != nil) {
        val receiver: *ast.Node = decl.receiver;
        if (receiver.children != nil) {
            val receiver_type_name: str = get_receiver_type_name(receiver.children);
            if (receiver_type_name != nil) {
                val qualified: str = build_method_symbol_name(sema, receiver_type_name, name);
                if (qualified != nil) {
                    symbol_name = qualified;
                }
            }
        }
    }

    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(symbol_name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    val ctx: *ty.TypeContext = ?sema.types;

    # skip generic functions - defer type resolution until instantiation
    if (sym.is_generic || decl.generics != nil) {
        sym.is_generic = true;
        ret true;
    }

    # skip methods on generic receiver types
    if (decl.receiver != nil) {
        val receiver: *ast.Node = decl.receiver;
        if (receiver.children != nil) {
            val receiver_type_name: str = get_receiver_type_name(receiver.children);
            if (receiver_type_name != nil) {
                val recv_sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(receiver_type_name);
                if (recv_sym_opt.is_some()) {
                    val recv_sym: *symbol.Symbol = recv_sym_opt.unwrap();
                    if (recv_sym.is_generic) {
                        # method on generic type - skip until instantiation
                        sym.is_generic = true;
                        sym.generic_node = recv_sym.generic_node;
                        ret true;
                    }
                }
            }
        }
    }

    # get parameter list from node.extra (stored as *List)
    val params_list: *ast.List = decl.extra::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_list != nil && params_list.count > 0) {
        param_count = params_list.count;

        # allocate param type array
        val ptypes_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.zalloc[*ty.Type](param_count::usize);
        if (ptypes_res.is_err()) {
            report_error_node(sema, decl, "failed to allocate param types");
            ret false;
        }

        param_types = ptypes_res.unwrap_ok();

        # resolve each parameter type
        var i: i32 = 0;
        for (i < param_count) {
            val param_node: *ast.Node = params_list.nodes[i];
            if (param_node != nil && param_node.children != nil) {
                param_types[i] = resolve_type(sema, param_node.children);
            }
            if (param_types[i] == nil) {
                # use error type as placeholder
                val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
                if (err_res.is_ok()) {
                    param_types[i] = err_res.unwrap_ok();
                }
            }
            i = i + 1;
        }
    }

    # resolve return type from the ret_type field
    var ret_type: *ty.Type = nil;

    if (decl.ret_type != nil) {
        ret_type = resolve_type(sema, decl.ret_type);
    }

    if (ret_type == nil) {
        # default to void
        val void_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (void_res.is_ok()) {
            ret_type = void_res.unwrap_ok();
        }
    }

    # create function type
    val fn_res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (fn_res.is_err()) {
        report_error_node(sema, decl, "failed to create function type");
        ret false;
    }

    sym.resolved_type = fn_res.unwrap_ok();
    ret true;
}

# resolve_ext_decl: resolve an external declaration's type.
fun resolve_ext_decl(sema: *Sema, decl: *ast.Node) bool {
    # ext declarations wrap a function signature in children
    val inner: *ast.Node = decl.children;
    if (inner == nil) {
        ret true;  # just a module import
    }

    if (inner.kind == ast.NODE_DECL_FUN) {
        ret resolve_function_decl(sema, inner);
    }

    ret true;
}

# resolve_var_type: resolve a variable/constant declaration's type.
fun resolve_var_decl_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = decl.get_name();
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = sema.current_table.lookup(name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # declared type is in extra (as type node)
    if (decl.extra != nil) {
        val type_node: *ast.Node = decl.extra::*ast.Node;
        sym.resolved_type = resolve_type(sema, type_node);
    }

    # if no declared type, will be inferred during check pass
    ret true;
}

# check_declarations: third pass - type-check all declarations.
fun check_declarations(sema: *Sema, program: *ast.Node) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }

    val list: *ast.List = program.get_list();
    if (list == nil) {
        ret true;
    }

    var success: bool = true;

    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # check functions
        if (kind == ast.NODE_DECL_FUN) {
            if (!check_function(sema, decl)) {
                success = false;
            }
        }

        # check values
        if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
            if (!check_var_decl(sema, decl)) {
                success = false;
            }
        }

        # skip test blocks during regular compilation
        # tests are only analyzed when running the test command
        if (kind == ast.NODE_DECL_TEST) {
            i = i + 1;
            cnt;
        }

        i = i + 1;
    }

    ret success;
}

# check_test: check a test block.
fun check_test(sema: *Sema, decl: *ast.Node) bool {
    # test blocks are like void functions
    val prev_fn: *symbol.Symbol = sema.current_fn;
    val prev_ret: *ty.Type = sema.current_fn_ret;

    sema.current_fn = nil;

    val res: Result[*ty.Type, str] = ty.primitive_type(?sema.types, ty.TY_VOID);
    if (res.is_ok()) {
        sema.current_fn_ret = res.unwrap_ok();
    }

    val push_res: Result[bool, str] = sema.current_table.push_scope();
    if (push_res.is_err()) {
        ret false;
    }

    # check test body
    val body: *ast.Node = decl.children;
    if (body != nil) {
        check_stmt(sema, body);
    }

    val pop_res: Result[bool, str] = sema.current_table.pop_scope();

    sema.current_fn = prev_fn;
    sema.current_fn_ret = prev_ret;

    ret true;
}

# --- module system ---

# set_module_roots: configure module resolution for the project.
# ---
# project_id: project id (module prefix)
# src_root:   absolute (or project-relative) src directory
# dep_root:   absolute (or project-relative) dep directory
# deps:       config deps array
# dep_count:  number of deps
pub fun set_module_roots(sema: *Sema, project_id: str, src_root: str, dep_root: str, deps: *config.Dep, dep_count: i32) {
    if (sema == nil) {
        ret;
    }
    sema.project_id = project_id;
    sema.src_root = src_root;
    sema.dep_root = dep_root;
    sema.deps = deps;
    sema.dep_count = dep_count;
}

# find_module: look up a module by path in the loaded modules list.
# ---
# sema:        analyzer context
# module_path: fully qualified module path
# ret:         pointer to module if found, nil otherwise
fun find_module(sema: *Sema, module_path: str) *SemaModule {
    if (sema == nil || module_path == nil) {
        ret nil;
    }

    var mod: *SemaModule = sema.modules;
    for (mod != nil) {
        if (mod.module_path != nil && mod.module_path.equals(module_path)) {
            ret mod;
        }
        mod = mod.next;
    }
    ret nil;
}

# build_module_path: build file path from base + module_path rest.
# ---
# base: base directory
# module_path: full module path
# rest_start: index in module_path after prefix (e.g., after "mach.")
fun build_module_path(sema: *Sema, base: str, module_path: str, rest_start: usize) Result[str, str] {
    if (sema == nil || base == nil || module_path == nil) {
        ret err[str, str]("invalid arguments");
    }

    val path_len: usize = module_path.len();
    if (path_len <= rest_start) {
        ret err[str, str]("invalid module path");
    }

    val rest_len: usize = path_len - rest_start;
    val suffix: str = ".mach";
    val out_len: usize = base.len() + rest_len + suffix.len();
    val alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](out_len + 1);
    if (alloc_res.is_err()) {
        ret err[str, str]("allocation failed");
    }

    val buf: *u8 = alloc_res.unwrap_ok();
    var pos: usize = 0;

    # copy base (ensure it ends with '/')
    var i: usize = 0;
    for (i < base.len()) {
        buf[pos] = base[i];
        pos = pos + 1;
        i = i + 1;
    }
    if (pos > 0 && buf[pos - 1] != 47) {
        buf[pos] = 47; pos = pos + 1;
    }

    # copy rest, replacing dots with '/'
    i = rest_start;
    for (i < path_len) {
        if (module_path[i] == 46) { buf[pos] = 47; } else { buf[pos] = module_path[i]; }
        pos = pos + 1;
        i = i + 1;
    }

    # suffix
    i = 0;
    for (i < suffix.len()) { buf[pos] = suffix[i]; pos = pos + 1; i = i + 1; }
    buf[pos] = 0;
    ret ok[str, str](buf::str);
}

# resolve_module_path: convert a module path to a file system path.
# ---
# sema:        analyzer context
# module_path: fully qualified module path (e.g., "mach.cli.main")
# ret:         Ok(file_path) on success, Err(str) on failure
fun resolve_module_path(sema: *Sema, module_path: str) Result[str, str] {
    if (sema == nil || module_path == nil) {
        ret err[str, str]("invalid arguments");
    }

    val path_len: usize = module_path.len();
    if (path_len == 0) {
        ret err[str, str]("empty module path");
    }

    # 1) std.* => dep_root/mach-std/src
    if (path_len >= 4 && module_path[0] == 115 && module_path[1] == 116 && module_path[2] == 100 && module_path[3] == 46) {
        var base: str = "dep/mach-std/src";
        if (sema.dep_root != nil) {
            val total: usize = sema.dep_root.len() + 1 + 9 + 1 + 3; # /mach-std/src
            val r: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total + 1);
            if (r.is_err()) { ret err[str, str]("allocation failed"); }
            val buf: *u8 = r.unwrap_ok();
            var p: usize = 0;
            var i: usize = 0;
            for (i < sema.dep_root.len()) { buf[p] = sema.dep_root[i]; p = p + 1; i = i + 1; }
            buf[p] = 47; p = p + 1; # '/'
            # mach-std
            buf[p] = 109; p = p + 1; buf[p] = 97; p = p + 1; buf[p] = 99; p = p + 1; buf[p] = 104; p = p + 1;
            buf[p] = 45; p = p + 1; buf[p] = 115; p = p + 1; buf[p] = 116; p = p + 1; buf[p] = 100; p = p + 1;
            buf[p] = 47; p = p + 1; # '/'
            buf[p] = 115; p = p + 1; buf[p] = 114; p = p + 1; buf[p] = 99; p = p + 1;
            buf[p] = 0;
            base = buf::str;
        }
        ret build_module_path(sema, base, module_path, 4);
    }

    # 2) project_id.* => src_root
    if (sema.project_id != nil) {
        # build prefix = project_id + "."
        val prefix_len: usize = sema.project_id.len() + 1;
        if (path_len >= prefix_len) {
            var matches: bool = true;
            var i: usize = 0;
            for (i < sema.project_id.len()) {
                if (module_path[i] != sema.project_id[i]) { matches = false; brk; }
                i = i + 1;
            }
            if (matches && module_path[sema.project_id.len()] == 46) {
                val base2: str = (sema.src_root != nil) ? sema.src_root : "src";
                ret build_module_path(sema, base2, module_path, prefix_len);
            }
        }
    }

    # 3) deps: <alias>.* => dep_root/<alias>/src
    if (sema.deps != nil && sema.dep_count > 0) {
        var d: i32 = 0;
        for (d < sema.dep_count) {
            val dep: *config.Dep = ?sema.deps[d];
            if (dep != nil && dep.name != nil) {
                val prefix_len: usize = dep.name.len() + 1;
                if (path_len >= prefix_len) {
                    var matches: bool = true;
                    var i2: usize = 0;
                    for (i2 < dep.name.len()) {
                        if (module_path[i2] != dep.name[i2]) { matches = false; brk; }
                        i2 = i2 + 1;
                    }
                    if (matches && module_path[dep.name.len()] == 46) {
                        var dep_base: str = "dep";
                        if (sema.dep_root != nil) {
                            dep_base = sema.dep_root;
                        }
                        # build base: dep_root/<alias>/src
                        val total: usize = dep_base.len() + 1 + dep.name.len() + 4;
                        val r: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total + 1);
                        if (r.is_err()) { ret err[str, str]("allocation failed"); }
                        val buf: *u8 = r.unwrap_ok();
                        var p: usize = 0;
                        var j: usize = 0;
                        for (j < dep_base.len()) { buf[p] = dep_base[j]; p = p + 1; j = j + 1; }
                        buf[p] = 47; p = p + 1;
                        j = 0;
                        for (j < dep.name.len()) { buf[p] = dep.name[j]; p = p + 1; j = j + 1; }
                        # append /src
                        buf[p] = 47; p = p + 1; buf[p] = 115; p = p + 1; buf[p] = 114; p = p + 1; buf[p] = 99; p = p + 1;
                        buf[p] = 0;
                        val base3: str = buf::str;
                        ret build_module_path(sema, base3, module_path, prefix_len);
                    }
                }
            }
            d = d + 1;
        }
    }

    # 4) fallback for mach.* => src
    if (path_len >= 5 && module_path[0] == 109 && module_path[1] == 97 && module_path[2] == 99 && module_path[3] == 104 && module_path[4] == 46) {
        var base4: str = "src";
        if (sema.src_root != nil) {
            base4 = sema.src_root;
        }
        ret build_module_path(sema, base4, module_path, 5);
    }

    ret err[str, str]("unknown module prefix");
}

# read_file_contents: read entire file into an allocated buffer.
# ---
# sema: analyzer context (for allocator)
# path: file path
# ret:  Ok(str) with file contents, Err(str) on failure
fun read_file_contents(sema: *Sema, path: str) Result[str, str] {
    if (sema == nil || path == nil) {
        ret err[str, str]("invalid arguments");
    }

    # open file
    val open_res: Result[fs.File, str] = fs.open(path);
    if (open_res.is_err()) {
        ret err[str, str](open_res.unwrap_err());
    }

    var file: fs.File = open_res.unwrap_ok();

    # get file size via stat
    val stat_res: Result[fs.Stat, str] = file.stat();
    if (stat_res.is_err()) {
        file.close();
        ret err[str, str](stat_res.unwrap_err());
    }

    val st: fs.Stat = stat_res.unwrap_ok();
    val size: usize = st.st_size::usize;

    # allocate buffer
    val alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](size + 1);
    if (alloc_res.is_err()) {
        file.close();
        ret err[str, str]("allocation failed");
    }

    val buf: *u8 = alloc_res.unwrap_ok();

    # read file contents
    var total_read: usize = 0;
    for (total_read < size) {
        val remaining: usize = size - total_read;
        val buf_pos: *u8 = (buf::usize + total_read)::*u8;
        val read_res: Result[usize, str] = file.read(buf_pos, remaining);
        if (read_res.is_err()) {
            file.close();
            ret err[str, str](read_res.unwrap_err());
        }
        val bytes_read: usize = read_res.unwrap_ok();
        if (bytes_read == 0) {
            brk;  # EOF
        }
        total_read = total_read + bytes_read;
    }

    buf[total_read] = 0;  # null terminate
    file.close();

    ret ok[str, str](buf::str);
}

# load_module: load and analyze a module by path.
# ---
# sema:        analyzer context
# module_path: fully qualified module path
# ret:         Ok(*SemaModule) on success, Err(str) on failure
fun load_module(sema: *Sema, module_path: str) Result[*SemaModule, str] {
    if (sema == nil || module_path == nil) {
        ret err[*SemaModule, str]("invalid arguments");
    }

    # check if already loaded
    val cached: *SemaModule = find_module(sema, module_path);
    if (cached != nil) {
        ret ok[*SemaModule, str](cached);
    }

    # resolve module path to file path
    val path_res: Result[str, str] = resolve_module_path(sema, module_path);
    if (path_res.is_err()) {
        ret err[*SemaModule, str](path_res.unwrap_err());
    }

    val file_path: str = path_res.unwrap_ok();

    # read file contents
    val read_res: Result[str, str] = read_file_contents(sema, file_path);
    if (read_res.is_err()) {
        ret err[*SemaModule, str](read_res.unwrap_err());
    }

    val source: str = read_res.unwrap_ok();

    # parse the source
    var p: parser.Parser = parser.init(source, sema.alloc);
    val parse_res: Result[*ast.Node, str] = p.parse_program();
    if (parse_res.is_err()) {
        ret err[*SemaModule, str](parse_res.unwrap_err());
    }

    val module_ast: *ast.Node = parse_res.unwrap_ok();

    # create module structure
    val mod_alloc_res: Result[*SemaModule, allocator.AllocError] = sema.alloc.zalloc[SemaModule](1);
    if (mod_alloc_res.is_err()) {
        ret err[*SemaModule, str]("failed to allocate module");
    }

    val mod: *SemaModule = mod_alloc_res.unwrap_ok();

    # allocate a copy of the module path
    val path_len: usize = module_path.len();
    val path_alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](path_len + 1);
    if (path_alloc_res.is_err()) {
        ret err[*SemaModule, str]("failed to allocate path");
    }
    val path_buf: *u8 = path_alloc_res.unwrap_ok();
    mem.raw_copy(path_buf::ptr, module_path::ptr, path_len);
    path_buf[path_len] = 0;

    mod.module_path = path_buf::str;
    mod.file_path = file_path;
    mod.source = source;
    mod.ast = module_ast;
    mod.imports = nil;
    mod.aliases = nil;
    mod.analyzed = false;

    # create symbol table for module
    val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
    if (table_res.is_err()) {
        ret err[*SemaModule, str](table_res.unwrap_err());
    }

    val table_alloc_res: Result[*symbol.Table, allocator.AllocError] = sema.alloc.zalloc[symbol.Table](1);
    if (table_alloc_res.is_err()) {
        ret err[*SemaModule, str]("failed to allocate table");
    }

    val table_ptr: *symbol.Table = table_alloc_res.unwrap_ok();

    # manually copy fields to work around struct assignment codegen bug
    val table_val: symbol.Table = table_res.unwrap_ok();
    table_ptr.alloc = table_val.alloc;
    table_ptr.current = table_val.current;
    table_ptr.root = table_val.root;
    mod.table = table_ptr;

    # add to modules list
    mod.next = sema.modules;
    sema.modules = mod;

    # save current context
    val saved_module: *SemaModule = sema.current_module;
    val saved_source: str = sema.source;
    val saved_file: str = sema.file_path;
    val saved_path: str = sema.module_path;
    val saved_table: *symbol.Table = sema.current_table;

    # switch to module context
    sema.current_module = mod;
    sema.source = source;
    sema.file_path = file_path;
    sema.module_path = mod.module_path;
    sema.current_table = mod.table;  # use module's symbol table

    # collect declarations in the module (first pass)
    val collect_ok: bool = collect_declarations(sema, module_ast);

    # resolve types (second pass)
    val types_ok: bool = resolve_types(sema, module_ast);

    # full analysis (third pass)
    val check_ok: bool = check_declarations(sema, module_ast);

    mod.analyzed = true;

    # restore context
    sema.current_module = saved_module;
    sema.source = saved_source;
    sema.file_path = saved_file;
    sema.module_path = saved_path;
    sema.current_table = saved_table;

    ret ok[*SemaModule, str](mod);
}

# find_alias: look up a module alias by name in current module.
# ---
# sema: analyzer context
# name: alias name to find
# ret:  pointer to alias if found, nil otherwise
fun find_alias(sema: *Sema, name: str) *ModuleAlias {
    if (sema == nil || name == nil || sema.current_module == nil) {
        ret nil;
    }

    var alias: *ModuleAlias = sema.current_module.aliases;
    for (alias != nil) {
        if (alias.alias != nil && alias.alias.equals(name)) {
            ret alias;
        }
        alias = alias.next;
    }
    ret nil;
}

# --- main entry point ---

# analyze: perform semantic analysis on an AST.
# ---
# sema: analyzer context
# root: AST root (program node)
# ret:  Ok(true) on success (may have errors), Err(str) on fatal error
pub fun analyze(sema: *Sema, root: *ast.Node) Result[bool, str] {
    if (sema == nil) {
        ret err[bool, str]("sema is nil");
    }

    if (root == nil) {
        ret err[bool, str]("AST is nil");
    }

    # create SemaModule for the main entry point
    val mod_alloc_res: Result[*SemaModule, allocator.AllocError] = sema.alloc.zalloc[SemaModule](1);
    if (mod_alloc_res.is_err()) {
        ret err[bool, str]("failed to allocate main module");
    }

    val main_mod: *SemaModule = mod_alloc_res.unwrap_ok();
    main_mod.module_path = sema.module_path;
    main_mod.file_path = sema.file_path;
    main_mod.source = sema.source;
    main_mod.ast = root;
    main_mod.imports = nil;
    main_mod.aliases = nil;
    main_mod.analyzed = false;

    # set module table to point to sema's symbol table
    main_mod.table = ?sema.symbols;

    # add to modules list and set as current
    main_mod.next = sema.modules;
    sema.modules = main_mod;
    sema.current_module = main_mod;
    sema.current_table = main_mod.table;  # use main module's table for symbol operations

    # pass 1: collect top-level declarations
    collect_declarations(sema, root);

    # pass 2: resolve type references
    resolve_types(sema, root);

    # pass 3: type-check expressions and statements
    check_declarations(sema, root);

    # pass 4: control flow validation (TODO)

    ret ok[bool, str](!has_errors(sema));
}

# --- utilities ---

# print_errors: print all errors to stderr.
pub fun print_errors(sema: *Sema) {
    if (sema == nil || sema.errors == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < sema.error_count) {
        val e: *SemaError = ?sema.errors[i];

        # print error location and message
        # format: file:line:col: error: message
        if (sema.file_path != nil) {
            # would need std.io for proper printing
            # for now, just record errors are available via get_error_count
        }

        i = i + 1;
    }
}

# get_error: get error at index.
pub fun get_error(sema: *Sema, idx: i32) *SemaError {
    if (sema == nil || sema.errors == nil || idx < 0 || idx >= sema.error_count) {
        ret nil;
    }
    ret ?sema.errors[idx];
}

# format_error: format an error message with location info.
pub fun format_error(sema: *Sema, e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    # return just the message for now
    # full formatting would need string concatenation
    ret e.message;
}

# get_source_line: extract a specific line from source text.
# ---
# source: full source text
# line:   1-based line number
# ret:    the line content or nil if not found
pub fun get_source_line(source: str, line: i32) str {
    if (source == nil || line < 1) {
        ret nil;
    }

    # find the start of the requested line
    var current_line: i32 = 1;
    var line_start: i32 = 0;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    # find start of target line
    for (i < len && current_line < line) {
        if (source[i] == '\n') {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) {
        ret nil;
    }

    # find end of line
    var line_end: i32 = line_start;
    for (line_end < len && source[line_end] != '\n') {
        line_end = line_end + 1;
    }

    # extract the line (would need substring support)
    # for now, return nil - actual implementation needs string slicing
    ret nil;
}

# format_error_context: format an error with source context.
# ---
# sema: analyzer context
# e:    error to format
# ret:  formatted error string or nil
# note: returns components separately since we can't easily concatenate strings
pub fun get_error_location(e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    # would format as "line:col" but need string formatting
    ret nil;
}

# make_caret_line: create a line with spaces and a caret at the column.
# ---
# col: 1-based column number
# ret: string with spaces followed by '^'
# note: would need string building support
pub fun get_error_col(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.col;
}

# get_error_line: get the line number of an error.
pub fun get_error_line(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.line;
}

# get_error_message: get the error message.
pub fun get_error_message(e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    ret e.message;
}

# get_error_pos: get the byte position of an error.
pub fun get_error_pos(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.pos;
}

# LoadedModule: info about a loaded module for lowering.
# ---
# ast:   the module's parsed AST
# table: the module's symbol table
pub rec LoadedModule {
    ast:   *ast.Node;
    table: *symbol.Table;
}

# get_loaded_modules: get all loaded modules for lowering.
# ---
# sema:     semantic analyzer
# out:      array to fill with LoadedModule entries
# max_count: maximum number of entries to return
# ret:      number of modules written to out (excludes main module)
pub fun get_loaded_modules(sema: *Sema, out: *LoadedModule, max_count: i32) i32 {
    if (sema == nil || out == nil || max_count <= 0) {
        ret 0;
    }

    var count: i32 = 0;
    var mod: *SemaModule = sema.modules;

    # skip the main module (first one in the list after we prepend new ones)
    # actually iterate all and skip current_module
    for (mod != nil && count < max_count) {
        # skip the main module - it's lowered separately
        if (mod != sema.current_module && mod.ast != nil && mod.table != nil) {
            out[count].ast = mod.ast;
            out[count].table = mod.table;
            count = count + 1;
        }
        mod = mod.next;
    }

    ret count;
}

# get_main_module_table: get the symbol table for the main module.
# ---
# sema: semantic analyzer
# ret:  main module's symbol table
pub fun get_main_module_table(sema: *Sema) *symbol.Table {
    if (sema == nil || sema.current_module == nil) {
        ret nil;
    }
    ret sema.current_module.table;
}
