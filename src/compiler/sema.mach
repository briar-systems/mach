use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;

use ast:      mach.compiler.ast;
use symbol:   mach.compiler.symbol;
use ty:       mach.compiler.type;
use tyctx:    mach.compiler.type_context;
use comptime: mach.compiler.comptime;
use target:   mach.compiler.target;
use config:   mach.config.config;
use token:    mach.compiler.token;

use scollect: mach.compiler.sema.collect;
use sresolve: mach.compiler.sema.resolve;
use scheck:   mach.compiler.sema.check;

# mach.compiler.sema: semantic analysis orchestration.
# ---
# bridges raw AST from the parser to typed AST for lowering.
# runs three passes: collect → resolve → check.

# --- module tracking ---

pub rec Module {
    path:      str          # "mach.compiler.foo"
    file_path: str          # "/path/to/foo.mach"
    source:    str          # source text (for error messages)
    ast:       *ast.Node    # parsed AST root
    table:     symbol.Table # this module's symbol table (by value)
    analyzed:  bool
    next:      *Module      # linked list
}

# --- error tracking ---

pub rec Error {
    file_path: str;
    message:   str;
    line:      i32;
    col:       i32;
}

# --- generic instantiation cache ---

pub rec GenericInst {
    args:      **ty.Type;
    arg_count: i32;
    result:    *ty.Type;
    next:      *GenericInst;
}

# --- function specialization ---

pub rec FnSpec {
    func_ast:    *ast.Node;
    mangled:     str;
    func_type:   *ty.Type;
    param_names: *str;
    param_types: **ty.Type;
    param_count: i32;
    origin:      *Module;
    next:        *FnSpec;
}

# --- spec map (FNV-1a open-addressing hash table) ---

pub rec SpecMapEntry {
    key:   str;
    value: str;
}

pub rec SpecMap {
    entries:  *SpecMapEntry;
    count:    i32;
    capacity: i32;
}

val SPEC_MAP_INIT_CAP: i32 = 64;

# --- context ---

pub rec Sema {
    alloc:          *allocator.Allocator;
    types:          *tyctx.TypeContext;
    target:         target.Target;

    # module registry
    modules:        *Module;
    module_count:   i32;
    current:        *Module;

    # module resolution config
    project_id:     str;
    src_root:       str;
    dep_root:       str;
    deps:           *config.Dep;
    dep_count:      i32;
    includes:       *config.IncludePath;
    include_count:  i32;

    # function context (during resolve)
    current_fn:     *ast.Node;
    fn_ret_type:    *ty.Type;

    # generic instantiation
    generic_cache:  *GenericInst;
    fn_specs:       *FnSpec;
    fn_spec_count:  i32;
    spec_map:       SpecMap;

    # errors
    errors:         *Error;
    error_count:    i32;
    error_cap:      i32;
    had_error:      bool;

    # comptime
    comptime:       *comptime.ComptimeContext;
}

# --- public API ---

pub fun init(alloc: *allocator.Allocator, tgt: target.Target) Sema {
    var sema: Sema;
    sema.alloc = alloc;
    sema.target = tgt;

    # create type context
    val types_res: Result[tyctx.TypeContext, str] = tyctx.init_context(alloc, tgt);
    if (result_is_ok[tyctx.TypeContext, str](types_res)) {
        val ctx_res: Result[*tyctx.TypeContext, allocator.AllocError] = allocator.allocator_alloc[tyctx.TypeContext](alloc, 1);
        if (result_is_ok[*tyctx.TypeContext, allocator.AllocError](ctx_res)) {
            sema.types = result_unwrap_ok[*tyctx.TypeContext, allocator.AllocError](ctx_res);
            @sema.types = result_unwrap_ok[tyctx.TypeContext, str](types_res);
        } or {
            sema.types = nil;
        }
    } or {
        sema.types = nil;
    }

    sema.modules = nil;
    sema.module_count = 0;
    sema.current = nil;
    sema.project_id = nil;
    sema.src_root = nil;
    sema.dep_root = nil;
    sema.deps = nil;
    sema.dep_count = 0;
    sema.includes = nil;
    sema.include_count = 0;
    sema.current_fn = nil;
    sema.fn_ret_type = nil;
    sema.generic_cache = nil;
    sema.fn_specs = nil;
    sema.fn_spec_count = 0;
    sema.spec_map.entries = nil;
    sema.spec_map.count = 0;
    sema.spec_map.capacity = 0;
    sema.errors = nil;
    sema.error_count = 0;
    sema.error_cap = 0;
    sema.had_error = false;
    sema.comptime = nil;

    ret sema;
}

pub fun dnit(sema: *Sema) {
    if (sema == nil) { ret; }
    # arena allocation — no individual frees needed
}

pub fun configure(sema: *Sema, project_id: str, src_root: str, dep_root: str,
                  deps: *config.Dep, dep_count: i32,
                  includes: *config.IncludePath, include_count: i32) {
    if (sema == nil) { ret; }
    sema.project_id = project_id;
    sema.src_root = src_root;
    sema.dep_root = dep_root;
    sema.deps = deps;
    sema.dep_count = dep_count;
    sema.includes = includes;
    sema.include_count = include_count;
}

pub fun analyze(sema: *Sema, root: *ast.Node, file_path: str, source: str,
                cctx: *comptime.ComptimeContext) Result[bool, str] {
    if (sema == nil || root == nil) {
        ret err[bool, str]("invalid arguments");
    }

    sema.comptime = cctx;

    # reset error state
    sema.error_count = 0;
    sema.had_error = false;

    # determine module path
    var mod_path: str = "main";
    if (sema.project_id != nil) {
        mod_path = sema.project_id;
    }

    # register main module
    val mod: *Module = register_module(sema, mod_path, file_path, source, root);
    if (mod == nil) {
        ret err[bool, str]("failed to register main module");
    }
    sema.current = mod;

    # update comptime context with module's symbol table
    if (sema.comptime != nil) {
        sema.comptime.symbols = ?mod.table;
    }

    # pass 1: collect declarations
    scollect.run(sema, root);

    # pass 2: resolve types and expressions
    if (!sema.had_error) {
        sresolve.run(sema, root);
    }

    # pass 3: validation
    if (!sema.had_error) {
        scheck.run(sema, root);
    }

    mod.analyzed = true;

    if (sema.had_error) {
        ret err[bool, str]("semantic analysis failed");
    }

    ret ok[bool, str](true);
}

pub fun get_symbols(sema: *Sema) *symbol.Table {
    if (sema == nil || sema.current == nil) { ret nil; }
    ret ?sema.current.table;
}

pub fun get_types(sema: *Sema) *tyctx.TypeContext {
    if (sema == nil) { ret nil; }
    ret sema.types;
}

pub fun has_errors(sema: *Sema) bool {
    if (sema == nil) { ret false; }
    ret sema.had_error;
}

pub fun print_errors(sema: *Sema) {
    if (sema == nil) { ret; }
    var i: i32 = 0;
    for (i < sema.error_count) {
        val e: *Error = ?sema.errors[i];
        if (e.file_path != nil) {
            print.print_str(e.file_path);
            print.print_str(":");
        }
        print.print_i64(e.line::i64);
        print.print_str(":");
        print.print_i64(e.col::i64);
        print.print_str(": error: ");
        print.print_str(e.message);
        print.print_str("\n");
        i = i + 1;
    }
}

# --- symbol table delegation ---

pub fun define(sema: *Sema, name: str, kind: symbol.SymbolKind) Result[*symbol.Symbol, str] {
    if (sema == nil || sema.current == nil) {
        ret err[*symbol.Symbol, str]("no current module");
    }
    ret symbol.table_define(?sema.current.table, name, kind);
}

pub fun lookup(sema: *Sema, name: str) Option[*symbol.Symbol] {
    if (sema == nil || sema.current == nil) {
        ret none[*symbol.Symbol]();
    }
    ret symbol.table_lookup(?sema.current.table, name);
}

pub fun push_scope(sema: *Sema) Result[bool, str] {
    if (sema == nil || sema.current == nil) {
        ret err[bool, str]("no current module");
    }
    ret symbol.table_push_scope(?sema.current.table);
}

pub fun pop_scope(sema: *Sema) Result[bool, str] {
    if (sema == nil || sema.current == nil) {
        ret err[bool, str]("no current module");
    }
    ret symbol.table_pop_scope(?sema.current.table);
}

# --- module registry ---

pub fun find_module(sema: *Sema, path: str) *Module {
    if (sema == nil || path == nil) { ret nil; }
    var mod: *Module = sema.modules;
    for (mod != nil) {
        if (mod.path != nil && str_equals(mod.path, path)) {
            ret mod;
        }
        mod = mod.next;
    }
    ret nil;
}

pub fun register_module(sema: *Sema, path: str, file_path: str, source: str, root: *ast.Node) *Module {
    if (sema == nil) { ret nil; }

    val res: Result[*Module, allocator.AllocError] = allocator.allocator_zalloc[Module](sema.alloc, 1);
    if (result_is_err[*Module, allocator.AllocError](res)) { ret nil; }

    val mod: *Module = result_unwrap_ok[*Module, allocator.AllocError](res);
    mod.path = path;
    mod.file_path = file_path;
    mod.source = source;
    mod.ast = root;
    mod.analyzed = false;
    mod.next = sema.modules;

    # create symbol table for this module
    val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
    if (result_is_err[symbol.Table, str](table_res)) { ret nil; }
    mod.table = result_unwrap_ok[symbol.Table, str](table_res);

    sema.modules = mod;
    sema.module_count = sema.module_count + 1;

    ret mod;
}

# --- error reporting ---

pub fun report_error(sema: *Sema, node: *ast.Node, msg: str) {
    if (sema == nil) { ret; }
    sema.had_error = true;

    # grow error array if needed
    if (sema.error_count >= sema.error_cap) {
        var new_cap: i32 = 16;
        if (sema.error_cap > 0) { new_cap = sema.error_cap * 2; }
        val res: Result[*Error, allocator.AllocError] = allocator.allocator_resize[Error](
            sema.alloc, sema.errors, sema.error_cap::usize, new_cap::usize);
        if (result_is_err[*Error, allocator.AllocError](res)) { ret; }
        sema.errors = result_unwrap_ok[*Error, allocator.AllocError](res);
        sema.error_cap = new_cap;
    }

    val e: *Error = ?sema.errors[sema.error_count];
    if (sema.current != nil) {
        e.file_path = sema.current.file_path;
    } or {
        e.file_path = nil;
    }
    e.message = msg;

    if (node != nil && sema.current != nil && sema.current.source != nil) {
        e.line = pos_to_line(sema.current.source, node.tok.pos);
        e.col = pos_to_col(sema.current.source, node.tok.pos);
    } or {
        e.line = 0;
        e.col = 0;
    }

    sema.error_count = sema.error_count + 1;
}

# --- comptime ---

pub fun eval_comptime(sema: *Sema, node: *ast.Node) Result[bool, str] {
    if (sema == nil || node == nil) {
        ret err[bool, str]("invalid arguments");
    }
    if (sema.comptime == nil) {
        ret ok[bool, str](false);
    }
    if (node.kind != ast.NODE_COMPTIME_IF && node.kind != ast.NODE_COMPTIME_OR) {
        ret err[bool, str]("not a comptime conditional");
    }
    val cond: *ast.Node = node.info.cond_stmt.cond;
    if (cond != nil) {
        ret comptime.eval_condition(sema.comptime, cond);
    }
    # $or without condition = else branch, always true
    if (cond == nil && node.kind == ast.NODE_COMPTIME_OR) {
        ret ok[bool, str](true);
    }
    ret ok[bool, str](false);
}

# --- module resolution helpers ---

pub fun has_module_resolution(sema: *Sema) bool {
    if (sema == nil) { ret false; }
    if (sema.project_id != nil && sema.src_root != nil) { ret true; }
    if (sema.deps != nil && sema.dep_count > 0 && sema.dep_root != nil) { ret true; }
    if (sema.includes != nil && sema.include_count > 0) { ret true; }
    ret false;
}

# --- spec map ---

fun spec_map_hash(s: str, cap: i32) i32 {
    if (s == nil) { ret 0; }
    var h: u64 = 14695981039346656037;
    val len: usize = str_len(s);
    var i: usize = 0;
    for (i < len) {
        h = h ^ s[i]::u64;
        h = h * 1099511628211;
        i = i + 1;
    }
    ret (h & (cap - 1)::u64)::i32;
}

fun spec_map_put_inner(m: *SpecMap, key: str, val_name: str) {
    var idx: i32 = spec_map_hash(key, m.capacity);
    var probes: i32 = 0;
    for (probes < m.capacity) {
        val e: *SpecMapEntry = ?m.entries[idx];
        if (e.key == nil) {
            e.key = key;
            e.value = val_name;
            m.count = m.count + 1;
            ret;
        }
        if (str_equals(e.key, key)) { ret; }
        idx = (idx + 1) & (m.capacity - 1);
        probes = probes + 1;
    }
}

fun spec_map_grow(m: *SpecMap, alloc: *allocator.Allocator) {
    val old_entries: *SpecMapEntry = m.entries;
    val old_cap: i32 = m.capacity;
    val new_cap: i32 = old_cap * 2;
    val res: Result[*SpecMapEntry, allocator.AllocError] = allocator.allocator_zalloc[SpecMapEntry](alloc, new_cap::usize);
    if (result_is_err[*SpecMapEntry, allocator.AllocError](res)) { ret; }
    m.entries = result_unwrap_ok[*SpecMapEntry, allocator.AllocError](res);
    m.capacity = new_cap;
    m.count = 0;
    var i: i32 = 0;
    for (i < old_cap) {
        val e: *SpecMapEntry = ?old_entries[i];
        if (e.key != nil) { spec_map_put_inner(m, e.key, e.value); }
        i = i + 1;
    }
    allocator.allocator_free[SpecMapEntry](alloc, old_entries, old_cap::usize);
}

pub fun spec_map_get(m: *SpecMap, key: str) str {
    if (m == nil || m.entries == nil || key == nil) { ret nil; }
    var idx: i32 = spec_map_hash(key, m.capacity);
    var probes: i32 = 0;
    for (probes < m.capacity) {
        val e: *SpecMapEntry = ?m.entries[idx];
        if (e.key == nil) { ret nil; }
        if (str_equals(e.key, key)) { ret e.value; }
        idx = (idx + 1) & (m.capacity - 1);
        probes = probes + 1;
    }
    ret nil;
}

pub fun spec_map_put(m: *SpecMap, alloc: *allocator.Allocator, key: str, val_name: str) {
    if (m == nil || alloc == nil || key == nil) { ret; }
    if (m.entries == nil) {
        val cap: i32 = SPEC_MAP_INIT_CAP;
        val res: Result[*SpecMapEntry, allocator.AllocError] = allocator.allocator_zalloc[SpecMapEntry](alloc, cap::usize);
        if (result_is_err[*SpecMapEntry, allocator.AllocError](res)) { ret; }
        m.entries = result_unwrap_ok[*SpecMapEntry, allocator.AllocError](res);
        m.capacity = cap;
    }
    if (m.count * 4 >= m.capacity * 3) {
        spec_map_grow(m, alloc);
    }
    spec_map_put_inner(m, key, val_name);
}

# --- position helpers ---

fun pos_to_line(source: str, pos: i32) i32 {
    if (source == nil || pos <= 0) { ret 1; }
    var line: i32 = 1;
    var i: i32 = 0;
    for (i < pos) {
        if (source[i] == 10) { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

fun pos_to_col(source: str, pos: i32) i32 {
    if (source == nil || pos <= 0) { ret 1; }
    var col: i32 = 1;
    var i: i32 = pos - 1;
    for (i >= 0) {
        if (source[i] == 10) { ret col; }
        col = col + 1;
        i = i - 1;
    }
    ret col;
}
