# resolve_types: pass 2 - resolve all types.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
fun resolve_types(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    # first pass: create type shells for all declarations
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # resolve type for this declaration
        resolve_node_type(sema, node);

        i = i + 1;
    }

    # second pass: resolve record/union fields (now that all type shells exist)
    var j: i32 = 0;
    for (j < decls.count) {
        val node2: *ast.Node = decls.nodes[j];
        if (node2 != nil) {
            resolve_node_fields(sema, node2);
        }
        j = j + 1;
    }
}

# resolve_node_type: resolve the type for a declaration node.
# ---
# sema: analyzer context
# node: declaration node
# ret:  none
fun resolve_node_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # type declaration - resolve the underlying type
    if (node.kind == ast.NODE_DECL_DEF) {
        val type_node: *ast.Node = node.info.def_decl.type_node;
        if (type_node != nil) {
            val t: *ty.Type = resolve_type_expr(sema, type_node);
            if (t != nil) {
                node.ty = t;
                # update symbol's resolved type
                val name: str = node.info.def_decl.name;
                if (name != nil) {
                    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
                    if (sym_opt.is_some()) {
                        sym_opt.unwrap().resolved_type = t;
                    }
                }
            }
        }
        ret;
    }

    # function declaration - resolve signature
    if (node.kind == ast.NODE_DECL_FUN) {
        val fun_type: *ty.Type = resolve_function_type(sema, node);
        if (fun_type != nil) {
            node.ty = fun_type;

            # update symbol's type
            val name2: str = node.info.fun_decl.name;
            if (name2 != nil) {
                val sym_opt2: Option[*symbol.Symbol] = sema.symbols.lookup(name2);
                if (sym_opt2.is_some()) {
                    val sym2: *symbol.Symbol = sym_opt2.unwrap();
                    sym2.resolved_type = fun_type;
                }
            }
        }
        ret;
    }

    # variable/constant declaration - resolve initializer type
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val init_node: *ast.Node = node.info.var_decl.init;
        if (init_node != nil) {
            val init_type: *ty.Type = resolve_expr_type(sema, init_node);
            if (init_type != nil) {
                node.ty = init_type;

                # update symbol's type
                val name: str = node.info.var_decl.name;
                if (name != nil) {
                    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
                    if (sym_opt.is_some()) {
                        val sym: *symbol.Symbol = sym_opt.unwrap();
                        sym.resolved_type = init_type;
                    }
                }
            }
        }
        ret;
    }

    # comptime if - process taken branch for type resolution
    if (node.kind == ast.NODE_COMPTIME_IF) {
        # the taken branch body
        val taken: *ast.Node = node.info.cond_stmt.body;
        if (taken != nil) {
            resolve_comptime_if_types(sema, taken);
        }
        ret;
    }

    # record declaration - create type and update symbol
    if (node.kind == ast.NODE_DECL_REC) {
        resolve_rec_type(sema, node);
        ret;
    }

    # union declaration - create type and update symbol
    if (node.kind == ast.NODE_DECL_UNI) {
        resolve_uni_type(sema, node);
        ret;
    }

    # pub wrapper - process inner declaration
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            resolve_node_type(sema, inner);
        }
        ret;
    }
}

# resolve_node_fields: resolve fields for record/union declarations (second pass).
# ---
# sema: analyzer context
# node: declaration node
# ret:  none
fun resolve_node_fields(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind == ast.NODE_DECL_REC) {
        resolve_rec_fields(sema, node);
        ret;
    }

    if (node.kind == ast.NODE_DECL_UNI) {
        resolve_uni_fields(sema, node);
        ret;
    }

    # pub wrapper - process inner declaration
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            resolve_node_fields(sema, inner);
        }
        ret;
    }
}

# resolve_rec_type: resolve types for a record declaration.
# ---
# sema: analyzer context
# node: record declaration node
# ret:  none
fun resolve_rec_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    # get symbol
    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (!sym_opt.is_some()) {
        ret;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # if already resolved, skip
    if (sym.resolved_type != nil) {
        ret;
    }

    # if generic, don't resolve fields yet - wait for instantiation
    if (sym.is_generic) {
        # create placeholder generic type
        val gen_res: Result[*ty.Type, str] = ty.generic_type(sema.types, name);
        if (gen_res.is_ok()) {
            sym.resolved_type = gen_res.unwrap_ok();
            node.ty = sym.resolved_type;
        }
        ret;
    }

    # create record type shell first (fields resolved in second pass)
    val rec_res: Result[*ty.Type, str] = ty.record_type(sema.types, name, nil, 0);
    if (rec_res.is_ok()) {
        sym.resolved_type = rec_res.unwrap_ok();
        node.ty = sym.resolved_type;
    }
}

# resolve_rec_fields: resolve fields for a record declaration (second pass).
# ---
# This is called after all type shells exist, so self-referential types work.
# sema: analyzer context
# node: record declaration node
# ret:  none
fun resolve_rec_fields(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (!sym_opt.is_some()) {
        ret;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    if (sym.resolved_type == nil || sym.is_generic) {
        ret;
    }

    # skip if fields already resolved
    if (sym.resolved_type.field_count != 0) {
        ret;
    }

    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) {
        ret;
    }

    val fields_res: Result[*ty.Field, allocator.AllocError] =
        sema.alloc.alloc[ty.Field](ast_fields.count::usize);
    if (fields_res.is_err()) {
        ret;
    }
    val fields: *ty.Field = fields_res.unwrap_ok();
    var field_count: i32 = 0;

    var fi: i32 = 0;
    for (fi < ast_fields.count) {
        val field_node: *ast.Node = ast_fields.nodes[fi];
        if (field_node != nil) {
            val field_name: str = field_node.info.field_decl.name;
            val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
            var field_type: *ty.Type = nil;
            if (field_type_node != nil) {
                field_type = resolve_type_expr(sema, field_type_node);
            }
            if (field_name != nil && field_type != nil) {
                fields[field_count].name = field_name;
                fields[field_count].ty = field_type;
                fields[field_count].offset = 0;
                field_count = field_count + 1;
            }
        }
        fi = fi + 1;
    }

    if (field_count > 0) {
        # update type with resolved fields
        val t: *ty.Type = sym.resolved_type;
        t.fields = fields;
        t.field_count = field_count;

        # recompute size and alignment
        var offset: usize = 0;
        var max_align: usize = 1;

        var i: i32 = 0;
        for (i < field_count) {
            val ft: *ty.Type = fields[i].ty;
            if (ft != nil) {
                val field_align: usize = ft.align;
                if (field_align > max_align) {
                    max_align = field_align;
                }
                if (field_align > 0) {
                    offset = (offset + field_align - 1) & ~(field_align - 1);
                }
                fields[i].offset = offset;
                offset = offset + ft.size;
            }
            i = i + 1;
        }

        if (max_align > 0) {
            offset = (offset + max_align - 1) & ~(max_align - 1);
        }

        t.size = offset;
        t.align = max_align;
    }
}

# resolve_uni_type: resolve types for a union declaration.
# ---
# sema: analyzer context
# node: union declaration node
# ret:  none
fun resolve_uni_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    # get symbol
    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (!sym_opt.is_some()) {
        ret;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # if already resolved, skip
    if (sym.resolved_type != nil) {
        ret;
    }

    # if generic, don't resolve fields yet - wait for instantiation
    if (sym.is_generic) {
        # create placeholder generic type
        val gen_res: Result[*ty.Type, str] = ty.generic_type(sema.types, name);
        if (gen_res.is_ok()) {
            sym.resolved_type = gen_res.unwrap_ok();
            node.ty = sym.resolved_type;
        }
        ret;
    }

    # non-generic union: create empty shell (fields resolved in second pass)
    val uni_res: Result[*ty.Type, str] = ty.union_type(sema.types, name, nil, 0);
    if (uni_res.is_ok()) {
        sym.resolved_type = uni_res.unwrap_ok();
        node.ty = sym.resolved_type;
    }
}

# resolve_uni_fields: resolve fields for a union declaration (second pass).
# ---
# This is called after all type shells exist, so self-referential types work.
# sema: analyzer context
# node: union declaration node
# ret:  none
fun resolve_uni_fields(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (!sym_opt.is_some()) {
        ret;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    if (sym.resolved_type == nil || sym.is_generic) {
        ret;
    }

    # skip if fields already resolved
    if (sym.resolved_type.field_count != 0) {
        ret;
    }

    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) {
        ret;
    }

    val fields_res: Result[*ty.Field, allocator.AllocError] =
        sema.alloc.alloc[ty.Field](ast_fields.count::usize);
    if (fields_res.is_err()) {
        ret;
    }
    val fields: *ty.Field = fields_res.unwrap_ok();
    var field_count: i32 = 0;

    var fi: i32 = 0;
    for (fi < ast_fields.count) {
        val field_node: *ast.Node = ast_fields.nodes[fi];
        if (field_node != nil) {
            val field_name: str = field_node.info.field_decl.name;
            val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
            var field_type: *ty.Type = nil;
            if (field_type_node != nil) {
                field_type = resolve_type_expr(sema, field_type_node);
            }
            if (field_name != nil && field_type != nil) {
                fields[field_count].name = field_name;
                fields[field_count].ty = field_type;
                fields[field_count].offset = 0;
                field_count = field_count + 1;
            }
        }
        fi = fi + 1;
    }

    if (field_count > 0) {
        val t: *ty.Type = sym.resolved_type;
        t.fields = fields;
        t.field_count = field_count;

        # union size = max of field sizes, alignment = max of alignments
        var max_size: usize = 0;
        var max_align: usize = 1;

        var i: i32 = 0;
        for (i < field_count) {
            val ft: *ty.Type = fields[i].ty;
            if (ft != nil) {
                if (ft.size > max_size) {
                    max_size = ft.size;
                }
                if (ft.align > max_align) {
                    max_align = ft.align;
                }
            }
            fields[i].offset = 0;  # all union fields start at offset 0
            i = i + 1;
        }

        if (max_align > 0) {
            max_size = (max_size + max_align - 1) & ~(max_align - 1);
        }

        t.size = max_size;
        t.align = max_align;
    }
}

# maybe_resolve_symbol_type_in_module: resolve a type symbol in its module context if needed.
# ---
# sema: analyzer context
# mod:  module containing the symbol (may be nil for current)
# sym:  symbol to resolve
fun maybe_resolve_symbol_type_in_module(sema: *Sema, mod: *SemaModule, sym: *symbol.Symbol) {
    if (sema == nil || sym == nil) {
        ret;
    }
    if (sym.resolved_type != nil || sym.decl_node == nil) {
        ret;
    }
    if (sym.is_being_resolved) {
        ret;
    }

    sym.is_being_resolved = true;

    # save context
    val saved_module: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;

    if (mod != nil) {
        sema.current_module = mod;
        sema.symbols = mod.table;
        sema.file_path = mod.file_path;
        sema.source = mod.source;
    }

    resolve_node_type(sema, sym.decl_node);

    sym.is_being_resolved = false;

    # restore context
    sema.current_module = saved_module;
    sema.symbols = saved_symbols;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
}

# lookup_type_symbol: look up a type symbol by name, checking local scope and imports.
# ---
# sema: analyzer context
# name: type name (may be dotted like "alias.Type")
# ret:  symbol if found, nil otherwise
fun lookup_type_symbol(sema: *Sema, name: str) *symbol.Symbol {
    if (sema == nil || name == nil) {
        ret nil;
    }

    # check for dotted path (alias.Type)
    var pos: usize = 0;
    var found_dot: bool = false;
    val name_len: usize = name.len();
    var i: usize = 0;
    for (i < name_len) {
        if (name[i] == '.') {
            pos = i;
            found_dot = true;
            brk;
        }
        i = i + 1;
    }
    if (found_dot) {
        if (pos > 0 && sema.current_module != nil) {
            # extract alias and type name
            # alias is name[0..pos], type_name is name[pos+1..]
            # name_len already computed
            
            # find the alias in current module's aliases
            var alias_entry: *ModuleAlias = sema.current_module.aliases;
            for (alias_entry != nil) {
                if (alias_entry.alias != nil) {
                    val alias_len: usize = alias_entry.alias.len();
                    if (alias_len == pos) {
                        # compare alias prefix
                        var match: bool = true;
                        var i: usize = 0;
                        for (i < pos) {
                            if (name[i] != alias_entry.alias[i]) {
                                match = false;
                                brk;
                            }
                            i = i + 1;
                        }
                        
                        if (match) {
                            # found matching alias - look up type in that module
                            val target_mod: *SemaModule = alias_entry.module;
                            if (target_mod != nil && target_mod.table != nil) {
                                # extract type name after the dot
                                val type_start: usize = pos + 1;
                                val type_len: usize = name_len - type_start;
                                
                                # look up in that module's root scope
                                val root: *symbol.Scope = target_mod.table.root;
                                if (root != nil) {
                                    var si: i32 = 0;
                                    var fallback: *symbol.Symbol = nil;
                                    for (si < root.symbol_count) {
                                        val sym: *symbol.Symbol = ?root.symbols[si::usize];
                                        if (sym.name != nil) {
                                            val sym_len: usize = sym.name.len();
                                            if (sym_len == type_len) {
                                                # compare type name
                                                var tmatch: bool = true;
                                                var ti: usize = 0;
                                                for (ti < type_len) {
                                                    if (name[type_start + ti] != sym.name[ti]) {
                                                        tmatch = false;
                                                        brk;
                                                    }
                                                    ti = ti + 1;
                                                }
                                                if (tmatch && (sym.kind == symbol.SYM_TYPE || 
                                                               sym.kind == symbol.SYM_REC || 
                                                               sym.kind == symbol.SYM_UNI)) {
                                                    if (sym.is_public) {
                                                        maybe_resolve_symbol_type_in_module(sema, target_mod, sym);
                                                        ret sym;
                                                    }
                                                    if (fallback == nil) {
                                                        fallback = sym;
                                                    }
                                                }
                                            }
                                        }
                                        si = si + 1;
                                    }
                                    if (fallback != nil) {
                                        maybe_resolve_symbol_type_in_module(sema, target_mod, fallback);
                                        ret fallback;
                                    }
                                }
                            }
                            ret nil;  # alias found but type not found
                        }
                    }
                }
                alias_entry = alias_entry.next;
            }
        }
        # dotted name but alias not found - fall through to local lookup
    }

    # unqualified type: check local symbol table
    val local_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (local_opt.is_some()) {
        val sym: *symbol.Symbol = local_opt.unwrap();
        if (sym.kind == symbol.SYM_TYPE || sym.kind == symbol.SYM_REC || sym.kind == symbol.SYM_UNI) {
            maybe_resolve_symbol_type_in_module(sema, sema.current_module, sym);
            ret sym;
        }
    }

    # check unaliased imports (use foo.bar; brings public symbols into scope)
    if (sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                val root: *symbol.Scope = imp.module.table.root;
                if (root != nil) {
                    var i: i32 = 0;
                    for (i < root.symbol_count) {
                        val sym: *symbol.Symbol = ?root.symbols[i::usize];
                        if (sym.name != nil && sym.is_public && sym.name.equals(name)) {
                            if (sym.kind == symbol.SYM_TYPE || 
                                sym.kind == symbol.SYM_REC || 
                                sym.kind == symbol.SYM_UNI) {
                                maybe_resolve_symbol_type_in_module(sema, imp.module, sym);
                                ret sym;
                            }
                        }
                        i = i + 1;
                    }
                }
            }
            imp = imp.next;
        }
    }

    ret nil;
}

# lookup_function_symbol: look up a function symbol by name, checking local scope and imports.
# ---
# sema: analyzer context
# name: function name
# ret:  symbol if found, nil otherwise
fun lookup_function_symbol(sema: *Sema, name: str) *symbol.Symbol {
    if (sema == nil || name == nil) {
        ret nil;
    }

    # check local symbol table first
    val local_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (local_opt.is_some()) {
        val sym: *symbol.Symbol = local_opt.unwrap();
        if (sym.kind == symbol.SYM_FUN || sym.kind == symbol.SYM_EXT) {
            ret sym;
        }
    }

    # check unaliased imports
    if (sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                val root: *symbol.Scope = imp.module.table.root;
                if (root != nil) {
                    var i: i32 = 0;
                    for (i < root.symbol_count) {
                        val sym: *symbol.Symbol = ?root.symbols[i::usize];
                        if (sym.name != nil && sym.is_public && sym.name.equals(name)) {
                            if (sym.kind == symbol.SYM_FUN || sym.kind == symbol.SYM_EXT) {
                                ret sym;
                            }
                        }
                        i = i + 1;
                    }
                }
            }
            imp = imp.next;
        }

        # also check aliased imports (use alias: module.path;)
        var alias: *ModuleAlias = sema.current_module.aliases;
        for (alias != nil) {
            if (alias.module != nil && alias.module.table != nil) {
                val root: *symbol.Scope = alias.module.table.root;
                if (root != nil) {
                    var i: i32 = 0;
                    for (i < root.symbol_count) {
                        val sym: *symbol.Symbol = ?root.symbols[i::usize];
                        if (sym.name != nil && sym.is_public && sym.name.equals(name)) {
                            if (sym.kind == symbol.SYM_FUN || sym.kind == symbol.SYM_EXT) {
                                ret sym;
                            }
                        }
                        i = i + 1;
                    }
                }
            }
            alias = alias.next;
        }
    }

    ret nil;
}

# resolve_type_expr: resolve a type expression to a Type.
# instantiate_generic_type: instantiate a generic type with concrete type arguments.
# ---
# sema:      analyzer context
# type_sym:  the generic type's symbol
# type_args: NODE_GENERIC node containing the type arguments list
# ret:       instantiated concrete type or nil
fun instantiate_generic_type(sema: *Sema, type_sym: *symbol.Symbol, type_args: *ast.Node) *ty.Type {
    if (sema == nil || type_sym == nil || type_args == nil) {
        ret nil;
    }

    if (!type_sym.is_generic || type_sym.decl_node == nil) {
        ret nil;
    }

    val type_decl: *ast.Node = type_sym.decl_node;

    # get formal generic params from type declaration
    val generic_params: *ast.Node = type_decl.info.type_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    # type_args is NODE_GENERIC, its children is the list
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    # resolve type args in current scope BEFORE pushing bindings
    var resolved_args: [8]*ty.Type;
    var all_concrete: bool = true;
    var j: i32 = 0;
    for (j < args_list.count && j < 8) {
        val arg: *ast.Node = args_list.nodes[j];
        if (arg != nil) {
            resolved_args[j] = resolve_type_expr(sema, arg);
            # check if this is an unresolvable type
            if (resolved_args[j] == nil ||
                resolved_args[j].kind == ty.TY_GENERIC) {
                all_concrete = false;
            }
        } or {
            all_concrete = false;
        }
        j = j + 1;
    }

    # if not all args are concrete, don't instantiate
    if (!all_concrete) {
        ret nil;
    }

    # push a new scope for the generic bindings
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        ret nil;
    }

    # bind each generic param to its resolved type arg
    var i: i32 = 0;
    for (i < params_list.count && i < 8) {
        val param: *ast.Node = params_list.nodes[i];
        if (param != nil && resolved_args[i] != nil) {
            val param_name: str = param.info.type_name.path;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, symbol.SYM_TYPE);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # switch to origin module context for field resolution
    val saved_module: *SemaModule = sema.current_module;
    val saved_module_path: str = sema.module_path;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;

    if (type_sym.module_path != nil) {
        var origin: *SemaModule = sema.modules;
        for (origin != nil) {
            if (origin.path != nil && origin.path.equals(type_sym.module_path)) {
                sema.current_module = origin;
                sema.module_path = origin.path;
                sema.file_path = origin.file_path;
                sema.source = origin.source;
            }
            origin = origin.next;
        }
    }

    # now resolve the type's fields with bindings in scope
    var result_type: *ty.Type = nil;

    if (type_decl.kind == ast.NODE_DECL_REC) {
        # resolve record fields
        val ast_fields: *ast.List = type_decl.info.type_decl.fields;
        if (ast_fields != nil && ast_fields.count > 0) {
            # allocate fields array
            val fields_res: Result[*ty.Field, allocator.AllocError] =
                sema.alloc.alloc[ty.Field](ast_fields.count::usize);
            if (fields_res.is_err()) {
                sema.symbols.pop_scope();
                sema.current_module = saved_module;
                sema.module_path = saved_module_path;
                sema.file_path = saved_file_path;
                sema.source = saved_source;
                ret nil;
            }
            val fields: *ty.Field = fields_res.unwrap_ok();
            var field_count: i32 = 0;

            # resolve and populate fields
            var fi: i32 = 0;
            for (fi < ast_fields.count) {
                val field_node: *ast.Node = ast_fields.nodes[fi];
                if (field_node != nil) {
                    val field_name: str = field_node.info.field_decl.name;
                    val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
                    var field_type: *ty.Type = nil;
                    if (field_type_node != nil) {
                        field_type = resolve_type_expr(sema, field_type_node);
                    }
                    if (field_name != nil && field_type != nil) {
                        fields[field_count].name = field_name;
                        fields[field_count].ty = field_type;
                        fields[field_count].offset = 0;
                        field_count = field_count + 1;
                    }
                }
                fi = fi + 1;
            }

            # create the record type (this computes size/alignment)
            val rec_res: Result[*ty.Type, str] = ty.record_type(sema.types, type_sym.name, fields, field_count);
            if (rec_res.is_ok()) {
                result_type = rec_res.unwrap_ok();
                # store generic args on the instantiated type
                ty.set_generic_args(sema.types, result_type, ?resolved_args[0], args_list.count);
                ty.set_base_generic(result_type, type_sym.resolved_type);
            }
        }
    } or {
        if (type_decl.kind == ast.NODE_DECL_UNI) {
            # resolve union variants
            val ast_variants: *ast.List = type_decl.info.type_decl.fields;
            if (ast_variants != nil && ast_variants.count > 0) {
                # allocate fields array
                val fields_res: Result[*ty.Field, allocator.AllocError] =
                    sema.alloc.alloc[ty.Field](ast_variants.count::usize);
                if (fields_res.is_err()) {
                    sema.symbols.pop_scope();
                    sema.current_module = saved_module;
                    sema.module_path = saved_module_path;
                    sema.file_path = saved_file_path;
                    sema.source = saved_source;
                    ret nil;
                }
                val fields: *ty.Field = fields_res.unwrap_ok();
                var field_count: i32 = 0;

                var vi: i32 = 0;
                for (vi < ast_variants.count) {
                    val variant_node: *ast.Node = ast_variants.nodes[vi];
                    if (variant_node != nil) {
                        val var_name: str = variant_node.info.field_decl.name;
                        val var_type_node: *ast.Node = variant_node.info.field_decl.type_node;
                        var var_type: *ty.Type = nil;
                        if (var_type_node != nil) {
                            var_type = resolve_type_expr(sema, var_type_node);
                        }
                        if (var_name != nil && var_type != nil) {
                            fields[field_count].name = var_name;
                            fields[field_count].ty = var_type;
                            fields[field_count].offset = 0;
                            field_count = field_count + 1;
                        }
                    }
                    vi = vi + 1;
                }

                # create the union type (this computes size/alignment)
                val uni_res: Result[*ty.Type, str] = ty.union_type(sema.types, type_sym.name, fields, field_count);
                if (uni_res.is_ok()) {
                    result_type = uni_res.unwrap_ok();
                    # store generic args on the instantiated type
                    ty.set_generic_args(sema.types, result_type, ?resolved_args[0], args_list.count);
                    ty.set_base_generic(result_type, type_sym.resolved_type);
                }
            }
        }
    }

    # pop the binding scope
    sema.symbols.pop_scope();

    # restore module context
    sema.current_module = saved_module;
    sema.module_path = saved_module_path;
    sema.file_path = saved_file_path;
    sema.source = saved_source;

    ret result_type;
}

# ---
# sema: analyzer context
# node: type expression node
# ret:  resolved type or nil
fun resolve_type_expr(sema: *Sema, node: *ast.Node) *ty.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # named type (primitive or typedef)
    if (node.kind == ast.NODE_TYPE_NAME) {
        val name: str = node.info.type_name.path;
        if (name != nil) {
            # lookup primitive type
            if (name.equals("void")) { ret ty.get_void(sema.types); }
            if (name.equals("bool")) { ret ty.get_bool(sema.types); }
            if (name.equals("u8")) { ret ty.get_u8(sema.types); }
            if (name.equals("u16")) { ret ty.get_u16(sema.types); }
            if (name.equals("u32")) { ret ty.get_u32(sema.types); }
            if (name.equals("u64")) { ret ty.get_u64(sema.types); }
            if (name.equals("i8")) { ret ty.get_i8(sema.types); }
            if (name.equals("i16")) { ret ty.get_i16(sema.types); }
            if (name.equals("i32")) { ret ty.get_i32(sema.types); }
            if (name.equals("i64")) { ret ty.get_i64(sema.types); }
            if (name.equals("f32")) { ret ty.get_f32(sema.types); }
            if (name.equals("f64")) { ret ty.get_f64(sema.types); }
            if (name.equals("ptr")) { ret ty.get_ptr(sema.types); }
            if (name.equals("usize")) { ret ty.get_usize(sema.types); }
            if (name.equals("isize")) { ret ty.get_isize(sema.types); }
            if (name.equals("str")) { ret ty.get_str(sema.types); }
            if (name.equals("va_list")) { ret ty.get_ptr(sema.types); }

            # lookup type symbol (local and imports)
            val sym: *symbol.Symbol = lookup_type_symbol(sema, name);
            if (sym != nil) {
                # check for generic instantiation: Type[arg1, arg2, ...]
                val type_args: *ast.Node = node.info.type_name.args;
                if (type_args != nil && type_args.kind == ast.NODE_GENERIC && sym.is_generic) {
                    # instantiate the generic type with concrete args
                    val inst_type: *ty.Type = instantiate_generic_type(sema, sym, type_args);
                    if (inst_type != nil) {
                        ret inst_type;
                    }
                }

                # if type is already resolved, return it
                if (sym.resolved_type != nil) {
                    # on-demand field resolution: if a rec/uni has unresolved fields,
                    # resolve them now (handles cross-module ordering issues)
                    if (sym.resolved_type.field_count == 0 && sym.resolved_type.size == 0 &&
                        !sym.is_generic && !sym.is_being_resolved && sym.decl_node != nil) {
                        val dk: ast.NodeKind = sym.decl_node.kind;
                        if (dk == ast.NODE_DECL_REC || dk == ast.NODE_DECL_UNI) {
                            # switch to origin module context for field type resolution
                            val sv_mod: *SemaModule = sema.current_module;
                            val sv_sym: *symbol.Table = sema.symbols;
                            val sv_fp: str = sema.file_path;
                            val sv_src: str = sema.source;

                            if (sym.module_path != nil) {
                                var origin: *SemaModule = sema.modules;
                                for (origin != nil) {
                                    if (origin.path != nil && origin.path.equals(sym.module_path)) {
                                        sema.current_module = origin;
                                        sema.symbols = origin.table;
                                        sema.file_path = origin.file_path;
                                        sema.source = origin.source;
                                    }
                                    origin = origin.next;
                                }
                            }

                            sym.is_being_resolved = true;
                            if (dk == ast.NODE_DECL_REC) {
                                resolve_rec_fields(sema, sym.decl_node);
                            } or {
                                resolve_uni_fields(sema, sym.decl_node);
                            }
                            sym.is_being_resolved = false;

                            sema.current_module = sv_mod;
                            sema.symbols = sv_sym;
                            sema.file_path = sv_fp;
                            sema.source = sv_src;
                        }
                    }
                    ret sym.resolved_type;
                }
                # try to resolve on-demand from decl_node (for forward references)
                if (sym.decl_node != nil && sym.decl_node.kind == ast.NODE_DECL_DEF) {
                    val inner: *ast.Node = sym.decl_node.info.def_decl.type_node;
                    if (inner != nil) {
                        val t: *ty.Type = resolve_type_expr(sema, inner);
                        if (t != nil) {
                            sym.resolved_type = t;
                            sym.decl_node.ty = t;
                            ret t;
                        }
                    }
                }
                # for rec/uni, check if decl_node.ty is set
                if (sym.decl_node != nil && sym.decl_node.ty != nil) {
                    sym.resolved_type = sym.decl_node.ty;
                    ret sym.decl_node.ty;
                }
            }

            report_error_node(sema, node, "undefined type");
        }
        ret nil;
    }

    # pointer type
    if (node.kind == ast.NODE_TYPE_PTR || node.kind == ast.NODE_TYPE_REF) {
        val elem_type: *ty.Type = resolve_type_expr(sema, node.info.type_ptr.inner);
        if (elem_type != nil) {
            val is_mutable: bool = node.kind == ast.NODE_TYPE_PTR;
            val ptr_res: Result[*ty.Type, str] = ty.pointer_type(sema.types, elem_type, is_mutable);
            if (ptr_res.is_ok()) {
                ret ptr_res.unwrap_ok();
            }
        }
        ret nil;
    }

    # array type
    if (node.kind == ast.NODE_TYPE_ARRAY) {
        # element type and size from type_array
        val elem_type: *ty.Type = resolve_type_expr(sema, node.info.type_array.elem_type);
        val size_node: *ast.Node = node.info.type_array.size;

        var size: usize = 0;
        if (size_node != nil && size_node.kind == ast.NODE_EXPR_LIT_INT) {
            size = size_node.get_int_value()::usize;
        }

        if (elem_type != nil && size > 0) {
            val arr_res: Result[*ty.Type, str] = ty.array_type(sema.types, elem_type, size);
            if (arr_res.is_ok()) {
                ret arr_res.unwrap_ok();
            }
        }
        ret nil;
    }

    # function type expression (NODE_TYPE_FUN uses type_fun variant, not fun_decl)
    if (node.kind == ast.NODE_TYPE_FUN) {
        var ret_type: *ty.Type = ty.get_void(sema.types);
        if (node.info.type_fun.ret_type != nil) {
            val rt: *ty.Type = resolve_type_expr(sema, node.info.type_fun.ret_type);
            if (rt != nil) {
                ret_type = rt;
            }
        }

        var param_types: **ty.Type = nil;
        var param_count: i32 = 0;
        val params: *ast.List = node.info.type_fun.params;
        if (params != nil && params.count > 0) {
            val pt_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](params.count::usize);
            if (pt_res.is_ok()) {
                param_types = pt_res.unwrap_ok();
                param_count = params.count;
                var i: i32 = 0;
                for (i < params.count) {
                    val param: *ast.Node = params.nodes[i];
                    if (param != nil) {
                        val param_type_node: *ast.Node = param.info.field_decl.type_node;
                        val pt: *ty.Type = resolve_type_expr(sema, param_type_node);
                        if (pt != nil) {
                            param_types[i] = pt;
                        } or {
                            param_types[i] = ty.get_void(sema.types);
                        }
                    }
                    i = i + 1;
                }
            }
        }

        val fun_res: Result[*ty.Type, str] = ty.function_type(sema.types, param_types, param_count, ret_type);
        if (param_types != nil) {
            sema.alloc.free[*ty.Type](param_types, param_count::usize);
        }
        if (fun_res.is_ok()) {
            ret fun_res.unwrap_ok();
        }
        ret nil;
    }

    # inline anonymous union type: uni { ok: T; err: E; }
    if (node.kind == ast.NODE_TYPE_UNI) {
        val variants: *ast.List = node.info.type_decl.fields;
        if (variants != nil && variants.count > 0) {
            val fields_res: Result[*ty.Field, allocator.AllocError] =
                sema.alloc.alloc[ty.Field](variants.count::usize);
            if (fields_res.is_err()) {
                ret nil;
            }
            val fields: *ty.Field = fields_res.unwrap_ok();
            var field_count: i32 = 0;

            var vi: i32 = 0;
            for (vi < variants.count) {
                val vnode: *ast.Node = variants.nodes[vi];
                if (vnode != nil) {
                    val vname: str = vnode.info.field_decl.name;
                    val vtype_node: *ast.Node = vnode.info.field_decl.type_node;
                    var vtype: *ty.Type = nil;
                    if (vtype_node != nil) {
                        vtype = resolve_type_expr(sema, vtype_node);
                    }
                    if (vname != nil && vtype != nil) {
                        fields[field_count].name = vname;
                        fields[field_count].ty = vtype;
                        fields[field_count].offset = 0;
                        field_count = field_count + 1;
                    }
                }
                vi = vi + 1;
            }

            if (field_count > 0) {
                val uni_res: Result[*ty.Type, str] = ty.union_type(sema.types, nil, fields, field_count);
                if (uni_res.is_ok()) {
                    ret uni_res.unwrap_ok();
                }
            }
        }
        ret nil;
    }

    ret nil;
}

# resolve_function_type: resolve a function type.
# ---
# sema: analyzer context
# node: function type or declaration node
# ret:  function type or nil
fun resolve_function_type(sema: *Sema, node: *ast.Node) *ty.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # check if this is a method on a generic type - if so, bind type parameters
    var pushed_scope: bool = false;
    if (node.info.fun_decl.receiver != nil) {
        pushed_scope = bind_method_type_params(sema, node.info.fun_decl.receiver);
    }

    # also bind function's own generic type parameters (e.g., fun ok[T, E](...))
    var pushed_func_scope: bool = false;
    if (node.info.fun_decl.generics != nil) {
        val func_generics: *ast.Node = node.info.fun_decl.generics;
        if (func_generics.kind == ast.NODE_GENERIC) {
            val params_list: *ast.List = func_generics.info.generic_node.args;
            if (params_list != nil && params_list.count > 0) {
                val push_res: Result[bool, str] = sema.symbols.push_scope();
                if (push_res.is_ok()) {
                    pushed_func_scope = true;
                    # bind each type parameter as a type symbol with TY_GENERIC_PARAM
                    var i: i32 = 0;
                    for (i < params_list.count) {
                        val param: *ast.Node = params_list.nodes[i];
                        if (param != nil) {
                            val param_name: str = param.info.type_name.path;
                            if (param_name != nil) {
                                val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, symbol.SYM_TYPE);
                                if (sym_res.is_ok()) {
                                    val tsym: *symbol.Symbol = sym_res.unwrap_ok();
                                    # create a TY_GENERIC_PARAM type for this parameter
                                    val gp_res: Result[*ty.Type, str] = ty.generic_param_type(sema.types, param_name);
                                    if (gp_res.is_ok()) {
                                        tsym.resolved_type = gp_res.unwrap_ok();
                                    }
                                }
                            }
                        }
                        i = i + 1;
                    }
                }
            }
        }
    }

    # get return type
    var ret_type: *ty.Type = ty.get_void(sema.types);
    if (node.info.fun_decl.ret_type != nil) {
        val rt: *ty.Type = resolve_type_expr(sema, node.info.fun_decl.ret_type);
        if (rt != nil) {
            ret_type = rt;
        }
    }

    # get parameter types
    var param_types: **ty.Type = nil;
    var param_count: i32 = 0;

    val params: *ast.List = node.info.fun_decl.params;
    if (params != nil && params.count > 0) {
        val pt_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](params.count::usize);
        if (pt_res.is_ok()) {
            param_types = pt_res.unwrap_ok();
            param_count = params.count;
            
            var i: i32 = 0;
            for (i < params.count) {
                val param: *ast.Node = params.nodes[i];
                if (param != nil) {
                    # param is NODE_PARAM: type annotation is in field_decl.type_node
                    val param_type_node: *ast.Node = param.info.field_decl.type_node;
                    val pt: *ty.Type = resolve_type_expr(sema, param_type_node);
                    if (pt != nil) {
                        param_types[i] = pt;
                        param.ty = pt;  # set type on param node for lowering
                    } or {
                        param_types[i] = ty.get_void(sema.types);
                    }
                }
                i = i + 1;
            }
        }
    }

    # pop the function type parameter scope if we pushed one
    if (pushed_func_scope) {
        sema.symbols.pop_scope();
    }

    # pop the method type parameter scope if we pushed one
    if (pushed_scope) {
        sema.symbols.pop_scope();
    }

    # create function type
    val fun_res: Result[*ty.Type, str] = ty.function_type(sema.types, param_types, param_count, ret_type);
    if (param_types != nil) {
        sema.alloc.free[*ty.Type](param_types, param_count::usize);
    }
    
    if (fun_res.is_ok()) {
        ret fun_res.unwrap_ok();
    }
    ret nil;
}

# bind_method_type_params: for a method on a generic type, bind type parameters in scope.
# ---
# sema:     analyzer context
# receiver: receiver node (NODE_PARAM with type as children)
# ret:      true if a scope was pushed, false otherwise
fun bind_method_type_params(sema: *Sema, receiver: *ast.Node) bool {
    if (sema == nil || receiver == nil) {
        ret false;
    }

    # get the receiver type node
    var recv_type: *ast.Node = receiver.info.field_decl.type_node;
    if (recv_type == nil) {
        ret false;
    }

    # unwrap pointer/ref types to get base type
    for (recv_type != nil && (recv_type.kind == ast.NODE_TYPE_PTR || recv_type.kind == ast.NODE_TYPE_REF)) {
        recv_type = recv_type.info.type_ptr.inner;
    }

    if (recv_type == nil || recv_type.kind != ast.NODE_TYPE_NAME) {
        ret false;
    }

    # check if the receiver type has generic args (e.g., Option[T])
    val generic_args_node: *ast.Node = recv_type.info.type_name.args;
    if (generic_args_node == nil || generic_args_node.kind != ast.NODE_GENERIC) {
        ret false;
    }

    # get the generic args list from the NODE_GENERIC node
    val args_list: *ast.List = generic_args_node.info.generic_node.args;
    if (args_list == nil || args_list.count == 0) {
        ret false;
    }

    # look up the receiver type's declaration to get formal params
    val recv_name: str = recv_type.info.type_name.path;
    if (recv_name == nil) {
        ret false;
    }

    val sym: *symbol.Symbol = lookup_type_symbol(sema, recv_name);
    if (sym == nil || !sym.is_generic || sym.decl_node == nil) {
        ret false;
    }

    # get formal generic parameters from the declaration
    val formal_generics: *ast.Node = sym.decl_node.info.type_decl.generics;
    if (formal_generics == nil) {
        ret false;
    }

    val formal_list: *ast.List = formal_generics.info.generic_node.args;
    if (formal_list == nil || formal_list.count != args_list.count) {
        ret false;
    }

    # push a new scope for type parameter bindings
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        ret false;
    }

    # bind each actual arg name to a type parameter symbol
    # e.g., for Option[T], bind "T" as a type symbol with a generic param type
    var i: i32 = 0;
    for (i < args_list.count) {
        val actual: *ast.Node = args_list.nodes[i];
        if (actual != nil && actual.kind == ast.NODE_TYPE_NAME) {
            val param_name: str = actual.info.type_name.path;
            if (param_name != nil) {
                # create a type symbol for this parameter
                val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, symbol.SYM_TYPE);
                if (sym_res.is_ok()) {
                    val param_sym: *symbol.Symbol = sym_res.unwrap_ok();
                    # create a generic parameter type for this binding
                    val gen_res: Result[*ty.Type, str] = ty.generic_param_type(sema.types, param_name);
                    if (gen_res.is_ok()) {
                        param_sym.resolved_type = gen_res.unwrap_ok();
                    }
                }
            }
        }
        i = i + 1;
    }

    ret true;
}

# resolve_generic_call_return_type: resolve the return type of a generic function call.
# ---
# sema:      analyzer context
# func_sym:  the generic function's symbol
# type_args: the call's type arguments node
# ret:       resolved concrete return type or nil
fun resolve_generic_call_return_type(sema: *Sema, func_sym: *symbol.Symbol, type_args: *ast.Node) *ty.Type {
    if (sema == nil || func_sym == nil || type_args == nil) {
        ret nil;
    }

    val func_decl: *ast.Node = func_sym.decl_node;
    if (func_decl == nil) {
        ret nil;
    }

    # get formal generic params from function declaration
    val generic_params: *ast.Node = func_decl.info.fun_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    # generic params should have a list of param nodes in children
    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    # type args should be a NODE_GENERIC or similar with args list
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    # first resolve the type args in the current scope BEFORE pushing
    var resolved_args: [8]*ty.Type;  # max 8 type args
    var valid_count: i32 = 0;
    var j: i32 = 0;
    for (j < params_list.count && j < 8) {
        val arg: *ast.Node = args_list.nodes[j];
        if (arg != nil) {
            resolved_args[j] = resolve_type_expr(sema, arg);
            if (resolved_args[j] != nil) {
                valid_count = valid_count + 1;
            }
        }
        j = j + 1;
    }

    # push a new scope for the generic bindings
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        ret nil;
    }

    # bind each generic param to its resolved type arg
    var i: i32 = 0;
    for (i < params_list.count && i < 8) {
        val param: *ast.Node = params_list.nodes[i];

        if (param != nil && resolved_args[i] != nil) {
            val param_name: str = param.info.type_name.path;
            if (param_name != nil) {
                # create a symbol for this binding in the new scope
                val bind_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, symbol.SYM_TYPE);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # resolve the return type node with the bindings in scope
    val ret_type: *ty.Type = resolve_type_expr(sema, func_decl.info.fun_decl.ret_type);

    # pop the binding scope
    sema.symbols.pop_scope();

    ret ret_type;
}

# instantiate_generic_function: create a specialized version of a generic free function
# for a concrete set of type arguments from the call site.
# ---
# sema:      analyzer context
# func_sym:  the generic function's symbol (e.g., ok, err)
# type_args: the call's type arguments node
# ret:       mangled name of the instantiation, or nil on failure
# Module context swap: this function temporarily switches sema.current_module
# and sema.symbols to the origin module (where the generic was defined) so that
# type annotations resolve in the correct scope. Both fields are saved before
# the swap and restored on ALL exit paths (normal return, early error return).
pub fun instantiate_generic_function(sema: *Sema, func_sym: *symbol.Symbol, type_args: *ast.Node) str {
    if (sema == nil || func_sym == nil || type_args == nil) {
        ret nil;
    }

    val func_decl: *ast.Node = func_sym.decl_node;
    if (func_decl == nil) {
        ret nil;
    }

    # get formal generic params from function declaration
    val generic_params: *ast.Node = func_decl.info.fun_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    # resolve type args
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    var resolved_args: [8]*ty.Type;
    var ri: i32 = 0;
    for (ri < args_list.count && ri < 8) {
        val arg: *ast.Node = args_list.nodes[ri];
        if (arg != nil) {
            resolved_args[ri] = resolve_type_expr(sema, arg);
        }
        ri = ri + 1;
    }

    # generate mangled name: "funcName" + "I" + mangle(type_args) + "E"
    var mangled_buf: [512]u8;
    var pos: i32 = 0;

    val base_name: str = func_sym.name;
    if (base_name == nil) {
        ret nil;
    }
    val base_len: usize = base_name.len();
    var ci: usize = 0;
    for (ci < base_len && pos < 500) {
        mangled_buf[pos::usize] = base_name[ci];
        pos = pos + 1;
        ci = ci + 1;
    }

    # write "I"
    mangled_buf[pos::usize] = 'I';
    pos = pos + 1;

    # write each type arg's mangled form
    var ai: i32 = 0;
    for (ai < args_list.count && pos < 500) {
        val arg_ty: *ty.Type = resolved_args[ai];
        if (arg_ty != nil) {
            val mangle_written: i32 = ty.type_mangle(arg_ty, ?mangled_buf[pos::usize], (512 - pos)::usize);
            pos = pos + mangle_written;
        }
        ai = ai + 1;
    }

    # write "E"
    mangled_buf[pos::usize] = 'E';
    pos = pos + 1;
    mangled_buf[pos::usize] = 0;

    val mangled_name: str = (?mangled_buf[0])::str;

    # check if this instantiation already exists (O(1) hash lookup)
    val existing_name: str = inst_map_get(?sema.func_inst_map, mangled_name);
    if (existing_name != nil) {
        ret existing_name;
    }

    # get generic param names
    var param_names: *str = nil;
    val param_count: i32 = params_list.count;
    val names_res: Result[*str, allocator.AllocError] = sema.alloc.alloc[str](param_count::usize);
    if (names_res.is_ok()) {
        param_names = names_res.unwrap_ok();
        var ni: i32 = 0;
        for (ni < param_count) {
            val pnode: *ast.Node = params_list.nodes[ni];
            if (pnode != nil) {
                param_names[ni] = pnode.info.type_name.path;
            }
            ni = ni + 1;
        }
    }

    # switch to origin module so that names in the function's type annotations
    # resolve in the correct module context
    val saved_mod: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    if (func_sym.module_path != nil) {
        var origin_mod: *SemaModule = sema.modules;
        for (origin_mod != nil) {
            if (origin_mod.path != nil && origin_mod.path.equals(func_sym.module_path)) {
                sema.current_module = origin_mod;
                if (origin_mod.table != nil) {
                    sema.symbols = origin_mod.table;
                }
            }
            origin_mod = origin_mod.next;
        }
    }

    # resolve the concrete function type with type bindings
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        sema.symbols = saved_symbols;
        sema.current_module = saved_mod;
        ret nil;
    }

    var bi: i32 = 0;
    for (bi < param_count && bi < 8) {
        if (param_names != nil && param_names[bi] != nil && resolved_args[bi] != nil) {
            val bind_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_names[bi], symbol.SYM_TYPE);
            if (bind_res.is_ok()) {
                val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                bind_sym.resolved_type = resolved_args[bi];
            }
        }
        bi = bi + 1;
    }

    # resolve return type
    var concrete_ret_type: *ty.Type = nil;
    if (func_decl.info.fun_decl.ret_type != nil) {
        concrete_ret_type = resolve_type_expr(sema, func_decl.info.fun_decl.ret_type);
    }

    # resolve parameter types
    val func_params: *ast.List = func_decl.info.fun_decl.params;
    var concrete_param_count: i32 = 0;
    var concrete_param_types: [16]*ty.Type;
    if (func_params != nil) {
        var pi: i32 = 0;
        for (pi < func_params.count && pi < 16) {
            val param: *ast.Node = func_params.nodes[pi];
            if (param != nil) {
                val param_type_node: *ast.Node = param.info.field_decl.type_node;
                if (param_type_node != nil) {
                    concrete_param_types[concrete_param_count] = resolve_type_expr(sema, param_type_node);
                } or {
                    concrete_param_types[concrete_param_count] = nil;
                }
                concrete_param_count = concrete_param_count + 1;
            }
            pi = pi + 1;
        }
    }

    sema.symbols.pop_scope();

    # restore caller module context
    sema.symbols = saved_symbols;
    sema.current_module = saved_mod;

    # create the instantiated function type
    val ftype_res: Result[*ty.Type, str] = ty.function_type(sema.types,
        ?concrete_param_types[0], concrete_param_count, concrete_ret_type);

    var inst_func_type: *ty.Type = nil;
    if (ftype_res.is_ok()) {
        inst_func_type = ftype_res.unwrap_ok();
    }

    # allocate persistent copy of mangled name
    val name_len: usize = mangled_name.len();
    val name_alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](name_len + 1);
    if (name_alloc_res.is_err()) {
        ret nil;
    }
    val persistent_name: *u8 = name_alloc_res.unwrap_ok();
    var pni: usize = 0;
    for (pni < name_len) {
        persistent_name[pni] = mangled_name[pni];
        pni = pni + 1;
    }
    persistent_name[name_len] = 0;
    val pname: str = persistent_name::str;

    # allocate persistent copy of param_types array
    var persistent_param_types: **ty.Type = nil;
    if (param_count > 0) {
        val pt_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (pt_res.is_ok()) {
            persistent_param_types = pt_res.unwrap_ok();
            var pti: i32 = 0;
            for (pti < param_count && pti < 8) {
                persistent_param_types[pti] = resolved_args[pti];
                pti = pti + 1;
            }
        }
    }

    # create FunctionInstantiation record
    val inst_res: Result[*FunctionInstantiation, allocator.AllocError] = sema.alloc.zalloc[FunctionInstantiation](1);
    if (inst_res.is_err()) {
        ret nil;
    }

    val finst: *FunctionInstantiation = inst_res.unwrap_ok();
    finst.func_ast = func_decl;
    finst.mangled_name = pname;
    finst.func_type = inst_func_type;
    finst.param_names = param_names;
    finst.param_types = persistent_param_types;
    finst.param_count = param_count;
    finst.origin_module = sema.current_module;
    finst.next = sema.func_insts;
    sema.func_insts = finst;
    sema.func_inst_count = sema.func_inst_count + 1;
    inst_map_put(?sema.func_inst_map, sema.alloc, pname, pname);

    # create a symbol for the instantiated function
    val inst_sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(pname, symbol.SYM_FUN);
    if (inst_sym_res.is_ok()) {
        val inst_sym: *symbol.Symbol = inst_sym_res.unwrap_ok();
        inst_sym.resolved_type = inst_func_type;
        inst_sym.decl_node = func_decl;
        inst_sym.module_path = func_sym.module_path;
        inst_sym.is_public = func_sym.is_public;
    }

    ret pname;
}

# instantiate_generic_method: create a specialized version of a generic method
# for a concrete set of type arguments derived from the receiver's type.
#
# Module context swap: this function temporarily switches sema.current_module
# and sema.symbols to the origin module (where the generic was defined) so that
# type annotations resolve in the correct scope. Both fields are saved before
# the swap and restored on ALL exit paths (normal return, early error return).
# ---
# sema:          analyzer context
# method_sym:    the generic method's symbol (e.g., Result.unwrap_ok)
# recv_type:     the concrete instantiated receiver type (e.g., Result[*Section, str])
# ret:           mangled name of the instantiation, or nil on failure
pub fun instantiate_generic_method(sema: *Sema, method_sym: *symbol.Symbol, recv_type: *ty.Type) str {
    if (sema == nil || method_sym == nil || recv_type == nil) {
        ret nil;
    }

    # get concrete type args from the receiver type
    if (recv_type.generic_args == nil || recv_type.generic_arg_count <= 0) {
        ret nil;
    }

    # save fields early — symbol table reallocation can invalidate method_sym
    val saved_module_path2: str = method_sym.module_path;
    val saved_is_public2: bool = method_sym.is_public;

    # get the method's declaration AST
    val func_decl: *ast.Node = method_sym.decl_node;
    if (func_decl == nil) {
        ret nil;
    }

    # generate mangled name: "QualifiedName" + "I" + mangle(type_args) + "E"
    var mangled_buf: [512]u8;
    var pos: i32 = 0;

    # write the method's qualified name (e.g., "Result.unwrap_ok")
    val base_name: str = method_sym.name;
    if (base_name == nil) {
        ret nil;
    }
    val base_len: usize = base_name.len();
    var ci: usize = 0;
    for (ci < base_len && pos < 500) {
        mangled_buf[pos::usize] = base_name[ci];
        pos = pos + 1;
        ci = ci + 1;
    }

    # write "I"
    mangled_buf[pos::usize] = 'I';
    pos = pos + 1;

    # write each type arg's mangled form
    var ai: i32 = 0;
    for (ai < recv_type.generic_arg_count && pos < 500) {
        val arg_ty: *ty.Type = recv_type.generic_args[ai];
        if (arg_ty != nil) {
            val mangle_written: i32 = ty.type_mangle(arg_ty, ?mangled_buf[pos::usize], (512 - pos)::usize);
            pos = pos + mangle_written;
        }
        ai = ai + 1;
    }

    # write "E"
    mangled_buf[pos::usize] = 'E';
    pos = pos + 1;
    mangled_buf[pos::usize] = 0;

    val mangled_name: str = (?mangled_buf[0])::str;

    # check if this instantiation already exists (O(1) hash lookup)
    val existing_name: str = inst_map_get(?sema.method_inst_map, mangled_name);
    if (existing_name != nil) {
        ret existing_name;
    }

    # get generic param names from the receiver type's declaration
    # unwrap pointer/ref to get to the base type name
    var recv_ast_type: *ast.Node = nil;
    if (func_decl.info.fun_decl.receiver != nil) {
        recv_ast_type = func_decl.info.fun_decl.receiver.info.field_decl.type_node;
        for (recv_ast_type != nil && (recv_ast_type.kind == ast.NODE_TYPE_PTR || recv_ast_type.kind == ast.NODE_TYPE_REF)) {
            recv_ast_type = recv_ast_type.info.type_ptr.inner;
        }
    }

    var param_names: *str = nil;
    var param_count: i32 = 0;

    if (recv_ast_type != nil && recv_ast_type.kind == ast.NODE_TYPE_NAME) {
        val generic_args_node: *ast.Node = recv_ast_type.info.type_name.args;
        if (generic_args_node != nil && generic_args_node.kind == ast.NODE_GENERIC) {
            val gargs_list: *ast.List = generic_args_node.info.generic_node.args;
            if (gargs_list != nil && gargs_list.count == recv_type.generic_arg_count) {
                param_count = gargs_list.count;
                val names_res: Result[*str, allocator.AllocError] = sema.alloc.alloc[str](param_count::usize);
                if (names_res.is_ok()) {
                    param_names = names_res.unwrap_ok();
                    var ni: i32 = 0;
                    for (ni < param_count) {
                        val garg: *ast.Node = gargs_list.nodes[ni];
                        if (garg != nil) {
                            param_names[ni] = garg.info.type_name.path;
                        }
                        ni = ni + 1;
                    }
                }
            }
        }
    }

    # switch to origin module so that names in the method's type annotations
    # resolve in the correct module context
    val saved_mod: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    if (method_sym.module_path != nil) {
        var origin_mod: *SemaModule = sema.modules;
        for (origin_mod != nil) {
            if (origin_mod.path != nil && origin_mod.path.equals(method_sym.module_path)) {
                sema.current_module = origin_mod;
                if (origin_mod.table != nil) {
                    sema.symbols = origin_mod.table;
                }
            }
            origin_mod = origin_mod.next;
        }
    }

    # resolve the concrete function type with type bindings
    # push a scope with T=concrete, E=concrete, etc.
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        sema.symbols = saved_symbols;
        sema.current_module = saved_mod;
        ret nil;
    }

    # bind generic params to concrete types
    var bi: i32 = 0;
    for (bi < param_count && bi < recv_type.generic_arg_count) {
        if (param_names[bi] != nil && recv_type.generic_args[bi] != nil) {
            val bind_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_names[bi], symbol.SYM_TYPE);
            if (bind_res.is_ok()) {
                val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                bind_sym.resolved_type = recv_type.generic_args[bi];
            }
        }
        bi = bi + 1;
    }

    # resolve return type with bindings
    var concrete_ret_type: *ty.Type = nil;
    if (func_decl.info.fun_decl.ret_type != nil) {
        concrete_ret_type = resolve_type_expr(sema, func_decl.info.fun_decl.ret_type);
    }

    # resolve receiver type with bindings
    var concrete_recv_type: *ty.Type = recv_type;
    # if receiver is a pointer/ref, wrap the instantiated type
    if (func_decl.info.fun_decl.receiver != nil) {
        val recv_ann: *ast.Node = func_decl.info.fun_decl.receiver.info.field_decl.type_node;
        if (recv_ann != nil && (recv_ann.kind == ast.NODE_TYPE_PTR || recv_ann.kind == ast.NODE_TYPE_REF)) {
            val is_mut: bool = recv_ann.kind == ast.NODE_TYPE_PTR;
            val ptr_res: Result[*ty.Type, str] = ty.pointer_type(sema.types, recv_type, is_mut);
            if (ptr_res.is_ok()) {
                concrete_recv_type = ptr_res.unwrap_ok();
            }
        }
    }

    # resolve parameter types
    val func_params: *ast.List = func_decl.info.fun_decl.params;
    var concrete_param_count: i32 = 0;
    var concrete_param_types: [16]*ty.Type;
    if (func_params != nil) {
        var pi: i32 = 0;
        for (pi < func_params.count && pi < 16) {
            val param: *ast.Node = func_params.nodes[pi];
            if (param != nil) {
                val param_type_node: *ast.Node = param.info.field_decl.type_node;
                if (param_type_node != nil) {
                    concrete_param_types[concrete_param_count] = resolve_type_expr(sema, param_type_node);
                } or {
                    concrete_param_types[concrete_param_count] = nil;
                }
                concrete_param_count = concrete_param_count + 1;
            }
            pi = pi + 1;
        }
    }

    sema.symbols.pop_scope();

    # restore caller module context
    sema.symbols = saved_symbols;
    sema.current_module = saved_mod;

    # create the instantiated function type
    val ftype_res: Result[*ty.Type, str] = ty.function_type(sema.types,
        ?concrete_param_types[0], concrete_param_count, concrete_ret_type);

    var inst_func_type: *ty.Type = nil;
    if (ftype_res.is_ok()) {
        inst_func_type = ftype_res.unwrap_ok();
    }

    # allocate persistent copy of mangled name
    val name_len: usize = mangled_name.len();
    val name_alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](name_len + 1);
    if (name_alloc_res.is_err()) {
        ret nil;
    }
    val persistent_name: *u8 = name_alloc_res.unwrap_ok();
    var ni: usize = 0;
    for (ni < name_len) {
        persistent_name[ni] = mangled_name[ni];
        ni = ni + 1;
    }
    persistent_name[name_len] = 0;
    val pname: str = persistent_name::str;

    # allocate persistent copy of param_types array
    var persistent_param_types: **ty.Type = nil;
    if (param_count > 0) {
        val pt_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (pt_res.is_ok()) {
            persistent_param_types = pt_res.unwrap_ok();
            var pti: i32 = 0;
            for (pti < param_count) {
                persistent_param_types[pti] = recv_type.generic_args[pti];
                pti = pti + 1;
            }
        }
    }

    # create MethodInstantiation record
    val inst_res: Result[*MethodInstantiation, allocator.AllocError] = sema.alloc.zalloc[MethodInstantiation](1);
    if (inst_res.is_err()) {
        ret nil;
    }

    val inst: *MethodInstantiation = inst_res.unwrap_ok();
    inst.func_ast = func_decl;
    inst.mangled_name = pname;
    inst.func_type = inst_func_type;
    inst.receiver_type = concrete_recv_type;
    inst.param_names = param_names;
    inst.param_types = persistent_param_types;
    inst.param_count = param_count;
    inst.origin_module = sema.current_module;
    inst.next = sema.method_insts;
    sema.method_insts = inst;
    sema.method_inst_count = sema.method_inst_count + 1;
    inst_map_put(?sema.method_inst_map, sema.alloc, pname, pname);

    # define symbol in root scope (not current function-local scope)
    # this ensures the symbol persists after function analysis completes
    val saved_scope: *symbol.Scope = sema.symbols.current;
    sema.symbols.current = sema.symbols.root;
    val inst_sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(pname, symbol.SYM_FUN);
    sema.symbols.current = saved_scope;

    if (inst_sym_res.is_ok()) {
        val inst_sym: *symbol.Symbol = inst_sym_res.unwrap_ok();
        inst_sym.resolved_type = inst_func_type;
        inst_sym.decl_node = func_decl;
        inst_sym.module_path = saved_module_path2;
        inst_sym.is_public = saved_is_public2;
        inst_sym.is_method = true;
        inst_sym.receiver_type = concrete_recv_type;
    }

    ret pname;
}

# instantiate_nested_generic_calls: walk a function body AST to find generic
# free function calls (e.g., ok[*T, E](...)) and create FunctionInstantiation
# records for them. Called during generic method instantiation while type
# bindings are active so that type params resolve to concrete types.
fun instantiate_nested_generic_calls(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind == ast.NODE_EXPR_CALL) {
        val call_ta: *ast.Node = node.info.call_expr.type_args;
        if (call_ta != nil) {
            val callee: *ast.Node = node.info.call_expr.callee;
            if (callee != nil && callee.kind == ast.NODE_EXPR_IDENT) {
                val fname: str = callee.info.ident_expr.name;
                if (fname != nil) {
                    var fsym: *symbol.Symbol = nil;
                    val fopt: Option[*symbol.Symbol] = sema.symbols.lookup(fname);
                    if (fopt.is_some()) {
                        fsym = fopt.unwrap();
                    } or {
                        fsym = lookup_function_symbol(sema, fname);
                    }
                    if (fsym != nil && fsym.decl_node != nil &&
                        fsym.decl_node.info.fun_decl.generics != nil) {
                        instantiate_generic_function(sema, fsym, call_ta);
                    }
                }
            }

            # handle method calls with type args: e.g., this.alloc[T](count)
            if (callee != nil && callee.kind == ast.NODE_EXPR_FIELD) {
                val mname: str = callee.info.field_expr.field;
                val recv_obj: *ast.Node = callee.info.field_expr.object;
                if (mname != nil && recv_obj != nil) {
                    var recv_ty: *ty.Type = recv_obj.ty;
                    if (recv_ty == nil && recv_obj.kind == ast.NODE_EXPR_IDENT) {
                        val rn: str = recv_obj.info.ident_expr.name;
                        if (rn != nil) {
                            val ropt: Option[*symbol.Symbol] = sema.symbols.lookup(rn);
                            if (ropt.is_some()) {
                                recv_ty = ropt.unwrap().resolved_type;
                            }
                        }
                    }
                    if (recv_ty != nil) {
                        var base_ty: *ty.Type = recv_ty;
                        if (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
                            base_ty = base_ty.inner;
                        }
                        if (base_ty.name != nil) {
                            # build "TypeName.method" qualified name
                            var qbuf: [256]u8;
                            var qpos: i32 = 0;
                            val bn: str = base_ty.name;
                            val bn_len: usize = bn.len();
                            var qi: usize = 0;
                            for (qi < bn_len && qpos < 240) {
                                qbuf[qpos::usize] = bn[qi];
                                qpos = qpos + 1;
                                qi = qi + 1;
                            }
                            qbuf[qpos::usize] = '.';
                            qpos = qpos + 1;
                            val mn_len: usize = mname.len();
                            var qj: usize = 0;
                            for (qj < mn_len && qpos < 254) {
                                qbuf[qpos::usize] = mname[qj];
                                qpos = qpos + 1;
                                qj = qj + 1;
                            }
                            qbuf[qpos::usize] = 0;
                            val qual_name: str = (?qbuf[0])::str;
                            var msym: *symbol.Symbol = nil;
                            val mopt: Option[*symbol.Symbol] = sema.symbols.lookup(qual_name);
                            if (mopt.is_some()) {
                                msym = mopt.unwrap();
                            } or {
                                msym = lookup_function_symbol(sema, qual_name);
                            }
                            if (msym != nil && msym.decl_node != nil &&
                                msym.decl_node.kind == ast.NODE_DECL_FUN &&
                                msym.decl_node.info.fun_decl.generics != nil &&
                                msym.decl_node.info.fun_decl.receiver != nil) {
                                instantiate_generic_own_method(sema, msym, call_ta, recv_ty);
                            }
                        }
                    }
                }
            }
        }
        val ca: *ast.List = node.info.call_expr.args;
        if (ca != nil) {
            var i: i32 = 0;
            for (i < ca.count) {
                instantiate_nested_generic_calls(sema, ca.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_BLOCK) {
        val sl: *ast.List = node.info.block_stmt.stmts;
        if (sl != nil) {
            var i: i32 = 0;
            for (i < sl.count) {
                instantiate_nested_generic_calls(sema, sl.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_EXPR || node.kind == ast.NODE_STMT_RET ||
        node.kind == ast.NODE_DECL_PUB || node.kind == ast.NODE_EXPR_PAREN) {
        instantiate_nested_generic_calls(sema, node.info.wrapper.inner);
        ret;
    }

    if (node.kind == ast.NODE_STMT_IF || node.kind == ast.NODE_STMT_OR) {
        instantiate_nested_generic_calls(sema, node.info.cond_stmt.cond);
        instantiate_nested_generic_calls(sema, node.info.cond_stmt.body);
        instantiate_nested_generic_calls(sema, node.info.cond_stmt.or_branch);
        ret;
    }

    if (node.kind == ast.NODE_DECL_VAL || node.kind == ast.NODE_DECL_VAR) {
        instantiate_nested_generic_calls(sema, node.info.var_decl.init);
        ret;
    }

    if (node.kind == ast.NODE_STMT_FOR) {
        instantiate_nested_generic_calls(sema, node.info.for_stmt.cond);
        instantiate_nested_generic_calls(sema, node.info.for_stmt.body);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_BINARY) {
        instantiate_nested_generic_calls(sema, node.info.binary_expr.left);
        instantiate_nested_generic_calls(sema, node.info.binary_expr.right);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_UNARY || node.kind == ast.NODE_EXPR_ADDR ||
        node.kind == ast.NODE_EXPR_DEREF) {
        instantiate_nested_generic_calls(sema, node.info.unary_expr.expr);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_FIELD) {
        instantiate_nested_generic_calls(sema, node.info.field_expr.object);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_INDEX) {
        instantiate_nested_generic_calls(sema, node.info.index_expr.base);
        instantiate_nested_generic_calls(sema, node.info.index_expr.index);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_CAST) {
        instantiate_nested_generic_calls(sema, node.info.cast_expr.expr);
        ret;
    }
}

# instantiate_generic_own_method: create a specialized version of a method
# that has its own type parameters (e.g., Allocator.alloc[T]).
#
# Module context swap: this function temporarily switches sema.current_module
# and sema.symbols to the origin module (where the generic was defined) so that
# type annotations resolve in the correct scope. Both fields are saved before
# the swap and restored on ALL exit paths (normal return, early error return).
# ---
# sema:        analyzer context
# method_sym:  the generic method's symbol (e.g., Allocator.alloc)
# type_args:   the call's type arguments node (e.g., [u8])
# recv_type:   the receiver type (e.g., *Allocator)
# ret:         mangled name of the instantiation, or nil on failure
pub fun instantiate_generic_own_method(sema: *Sema, method_sym: *symbol.Symbol,
    type_args: *ast.Node, recv_type: *ty.Type) str {
    if (sema == nil || method_sym == nil || type_args == nil) {
        ret nil;
    }

    val func_decl: *ast.Node = method_sym.decl_node;
    if (func_decl == nil) {
        ret nil;
    }

    # save fields from method_sym early because symbol table reallocation
    # (from define() or nested instantiation) can invalidate the pointer
    val saved_module_path: str = method_sym.module_path;
    val saved_is_public: bool = method_sym.is_public;

    # get formal generic params from function declaration
    val generic_params: *ast.Node = func_decl.info.fun_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    # resolve type args
    var resolved_args: [8]*ty.Type;
    var ri: i32 = 0;
    for (ri < args_list.count && ri < 8) {
        val arg: *ast.Node = args_list.nodes[ri];
        if (arg != nil) {
            resolved_args[ri] = resolve_type_expr(sema, arg);
        }
        ri = ri + 1;
    }

    # generate mangled name: "QualifiedMethodName" + "I" + mangle(type_args) + "E"
    var mangled_buf: [512]u8;
    var pos: i32 = 0;

    val base_name: str = method_sym.name;
    if (base_name == nil) {
        ret nil;
    }
    val base_len: usize = base_name.len();
    var ci: usize = 0;
    for (ci < base_len && pos < 500) {
        mangled_buf[pos::usize] = base_name[ci];
        pos = pos + 1;
        ci = ci + 1;
    }

    mangled_buf[pos::usize] = 'I';
    pos = pos + 1;

    var ai: i32 = 0;
    for (ai < args_list.count && pos < 500) {
        val arg_ty: *ty.Type = resolved_args[ai];
        if (arg_ty != nil) {
            val mangle_written: i32 = ty.type_mangle(arg_ty, ?mangled_buf[pos::usize], (512 - pos)::usize);
            pos = pos + mangle_written;
        }
        ai = ai + 1;
    }

    mangled_buf[pos::usize] = 'E';
    pos = pos + 1;
    mangled_buf[pos::usize] = 0;

    val mangled_name: str = (?mangled_buf[0])::str;

    # check for existing instantiation (O(1) hash lookup)
    val existing_name: str = inst_map_get(?sema.method_inst_map, mangled_name);
    if (existing_name != nil) {
        ret existing_name;
    }

    # get param names
    var param_names: *str = nil;
    val param_count: i32 = params_list.count;
    val names_res: Result[*str, allocator.AllocError] = sema.alloc.alloc[str](param_count::usize);
    if (names_res.is_ok()) {
        param_names = names_res.unwrap_ok();
        var ni: i32 = 0;
        for (ni < param_count) {
            val pnode: *ast.Node = params_list.nodes[ni];
            if (pnode != nil) {
                param_names[ni] = pnode.info.type_name.path;
            }
            ni = ni + 1;
        }
    }

    # switch to origin module so that names in the method's type annotations
    # (like AllocError) resolve in the correct module context
    val saved_mod: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    if (method_sym.module_path != nil) {
        var origin_mod: *SemaModule = sema.modules;
        for (origin_mod != nil) {
            if (origin_mod.path != nil && origin_mod.path.equals(method_sym.module_path)) {
                sema.current_module = origin_mod;
                if (origin_mod.table != nil) {
                    sema.symbols = origin_mod.table;
                }
            }
            origin_mod = origin_mod.next;
        }
    }

    # resolve concrete function type in origin module context
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        sema.symbols = saved_symbols;
        sema.current_module = saved_mod;
        ret nil;
    }

    var bi: i32 = 0;
    for (bi < param_count && bi < 8) {
        if (param_names != nil && param_names[bi] != nil && resolved_args[bi] != nil) {
            val bind_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_names[bi], symbol.SYM_TYPE);
            if (bind_res.is_ok()) {
                val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                bind_sym.resolved_type = resolved_args[bi];
            }
        }
        bi = bi + 1;
    }

    var concrete_ret_type: *ty.Type = nil;
    if (func_decl.info.fun_decl.ret_type != nil) {
        concrete_ret_type = resolve_type_expr(sema, func_decl.info.fun_decl.ret_type);
    }

    val func_params: *ast.List = func_decl.info.fun_decl.params;
    var concrete_param_count: i32 = 0;
    var concrete_param_types: [16]*ty.Type;
    if (func_params != nil) {
        var pi: i32 = 0;
        for (pi < func_params.count && pi < 16) {
            val param: *ast.Node = func_params.nodes[pi];
            if (param != nil) {
                val param_type_node: *ast.Node = param.info.field_decl.type_node;
                if (param_type_node != nil) {
                    concrete_param_types[concrete_param_count] = resolve_type_expr(sema, param_type_node);
                } or {
                    concrete_param_types[concrete_param_count] = nil;
                }
                concrete_param_count = concrete_param_count + 1;
            }
            pi = pi + 1;
        }
    }

    # walk the body to instantiate nested generic function calls
    # (e.g., ok[*T, AllocError](...) inside Allocator.alloc[T] with T=u8)
    # already in origin module context, so type refs like AllocError resolve correctly
    if (func_decl.info.fun_decl.body != nil) {
        instantiate_nested_generic_calls(sema, func_decl.info.fun_decl.body);
    }

    sema.symbols.pop_scope();

    # restore caller module context
    sema.symbols = saved_symbols;
    sema.current_module = saved_mod;

    val ftype_res: Result[*ty.Type, str] = ty.function_type(sema.types,
        ?concrete_param_types[0], concrete_param_count, concrete_ret_type);

    var inst_func_type: *ty.Type = nil;
    if (ftype_res.is_ok()) {
        inst_func_type = ftype_res.unwrap_ok();
    }

    # allocate persistent copies
    val name_len: usize = mangled_name.len();
    val name_alloc_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](name_len + 1);
    if (name_alloc_res.is_err()) {
        ret nil;
    }
    val persistent_name: *u8 = name_alloc_res.unwrap_ok();
    var pni: usize = 0;
    for (pni < name_len) {
        persistent_name[pni] = mangled_name[pni];
        pni = pni + 1;
    }
    persistent_name[name_len] = 0;
    val pname: str = persistent_name::str;

    var persistent_param_types: **ty.Type = nil;
    if (param_count > 0) {
        val pt_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (pt_res.is_ok()) {
            persistent_param_types = pt_res.unwrap_ok();
            var pti: i32 = 0;
            for (pti < param_count && pti < 8) {
                persistent_param_types[pti] = resolved_args[pti];
                pti = pti + 1;
            }
        }
    }

    # create MethodInstantiation record
    val inst_res: Result[*MethodInstantiation, allocator.AllocError] = sema.alloc.zalloc[MethodInstantiation](1);
    if (inst_res.is_err()) {
        ret nil;
    }

    val inst: *MethodInstantiation = inst_res.unwrap_ok();
    inst.func_ast = func_decl;
    inst.mangled_name = pname;
    inst.func_type = inst_func_type;
    inst.receiver_type = recv_type;
    inst.param_names = param_names;
    inst.param_types = persistent_param_types;
    inst.param_count = param_count;

    inst.origin_module = sema.current_module;
    inst.next = sema.method_insts;
    sema.method_insts = inst;
    sema.method_inst_count = sema.method_inst_count + 1;
    inst_map_put(?sema.method_inst_map, sema.alloc, pname, pname);

    # define symbol in root scope (not current function-local scope)
    val own_saved_scope: *symbol.Scope = sema.symbols.current;
    sema.symbols.current = sema.symbols.root;
    val inst_sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(pname, symbol.SYM_FUN);
    sema.symbols.current = own_saved_scope;

    if (inst_sym_res.is_ok()) {
        val inst_sym: *symbol.Symbol = inst_sym_res.unwrap_ok();
        inst_sym.resolved_type = inst_func_type;
        inst_sym.decl_node = func_decl;
        inst_sym.module_path = saved_module_path;
        inst_sym.is_public = saved_is_public;
        inst_sym.is_method = true;
        inst_sym.receiver_type = recv_type;
    }

    ret pname;
}

# prepend_method_receivers: recursively walk an expression tree and prepend
# method receivers on any nested CALL nodes that are method calls.
# this is a lightweight pass that only does method detection and receiver
# prepending, without full type resolution (avoiding "undefined identifier"
# errors for function params during resolve_types pass).
fun prepend_method_receivers(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # recurse into CALL arguments
    if (node.kind == ast.NODE_EXPR_CALL) {
        val call_args: *ast.List = node.info.call_expr.args;
        if (call_args != nil) {
            var i: i32 = 0;
            for (i < call_args.count) {
                if (call_args.nodes[i] != nil) {
                    prepend_method_receivers(sema, call_args.nodes[i]);
                }
                i = i + 1;
            }
        }

        # check if this call's callee is a method call
        val callee: *ast.Node = node.info.call_expr.callee;
        if (callee != nil && callee.kind == ast.NODE_EXPR_FIELD) {
            val receiver: *ast.Node = callee.info.field_expr.object;
            if (receiver != nil && receiver.kind == ast.NODE_EXPR_IDENT) {
                val recv_name: str = receiver.info.ident_expr.name;

                # check if receiver is a module alias
                var is_module_alias: bool = false;
                if (recv_name != nil && sema.current_module != nil) {
                    var ma: *ModuleAlias = sema.current_module.aliases;
                    for (ma != nil) {
                        if (ma.alias != nil && ma.alias.equals(recv_name)) {
                            is_module_alias = true;
                        }
                        ma = ma.next;
                    }
                }

                if (!is_module_alias) {
                    # look up receiver in symbol table
                    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(recv_name);
                    if (sym_opt.is_some()) {
                        val sym: *symbol.Symbol = sym_opt.unwrap();
                        var recv_ty: *ty.Type = sym.resolved_type;
                        if (recv_ty == nil && sym.decl_node != nil) {
                            recv_ty = sym.decl_node.ty;
                        }

                        if (recv_ty != nil) {
                            receiver.ty = recv_ty;
                        }

                        var is_method_call: bool = recv_ty != nil && (
                            recv_ty.kind == ty.TY_RECORD ||
                            recv_ty.kind == ty.TY_UNION ||
                            recv_ty.kind == ty.TY_STR ||
                            recv_ty.kind == ty.TY_GENERIC ||
                            (recv_ty.kind == ty.TY_POINTER && recv_ty.inner != nil &&
                             (recv_ty.inner.kind == ty.TY_RECORD || recv_ty.inner.kind == ty.TY_UNION || recv_ty.inner.kind == ty.TY_GENERIC))
                        );

                        # exclude function-pointer struct fields from method call detection
                        if (is_method_call) {
                            val fp_field_name: str = callee.info.field_expr.field;
                            if (fp_field_name != nil) {
                                var base_rec_ty: *ty.Type = recv_ty;
                                if (base_rec_ty.kind == ty.TY_POINTER && base_rec_ty.inner != nil) {
                                    base_rec_ty = base_rec_ty.inner;
                                }
                                if ((base_rec_ty.kind == ty.TY_RECORD || base_rec_ty.kind == ty.TY_UNION) &&
                                    base_rec_ty.fields != nil && base_rec_ty.field_count > 0) {
                                    var fi: i32 = 0;
                                    for (fi < base_rec_ty.field_count) {
                                        val f: *ty.Field = ?base_rec_ty.fields[fi];
                                        if (f.name != nil && f.name.equals(fp_field_name) &&
                                            f.ty != nil && f.ty.kind == ty.TY_FUN) {
                                            is_method_call = false;
                                        }
                                        fi = fi + 1;
                                    }
                                }
                            }
                        }

                        if (is_method_call) {
                            # prepend receiver as first argument
                            var args: *ast.List = node.info.call_expr.args;
                            if (args == nil) {
                                val list_res: Result[*ast.List, str] = ast.create_list(sema.alloc);
                                if (list_res.is_ok()) {
                                    args = list_res.unwrap_ok();
                                    node.info.call_expr.args = args;
                                }
                            }

                            if (args != nil) {
                                val new_count: i32 = args.count + 1;
                                if (new_count > args.capacity) {
                                    val new_cap: i32 = new_count * 2;
                                    val alloc_res: Result[**ast.Node, allocator.AllocError] =
                                        sema.alloc.alloc[*ast.Node](new_cap::usize);
                                    if (alloc_res.is_ok()) {
                                        val new_nodes: **ast.Node = alloc_res.unwrap_ok();
                                        var j: i32 = 0;
                                        for (j < args.count) {
                                            new_nodes[j + 1] = args.nodes[j];
                                            j = j + 1;
                                        }
                                        new_nodes[0] = receiver;
                                        args.nodes = new_nodes;
                                        args.count = new_count;
                                        args.capacity = new_cap;
                                    }
                                } or {
                                    var j: i32 = args.count;
                                    for (j > 0) {
                                        args.nodes[j] = args.nodes[j - 1];
                                        j = j - 1;
                                    }
                                    args.nodes[0] = receiver;
                                    args.count = new_count;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

# auto_ref_receiver: wrap the first argument (receiver) in address-of or deref
# if needed to match the method's expected receiver parameter type.
# ---
# sema:       analyzer context
# node:       call expression node
# recv_ty:    actual receiver type
# method_sym: resolved method symbol
fun auto_ref_receiver(sema: *Sema, node: *ast.Node, recv_ty: *ty.Type, method_sym: *symbol.Symbol) {
    if (sema == nil || node == nil || recv_ty == nil || method_sym == nil) { ret; }

    # skip for generic methods — receiver types not yet concrete
    if (method_sym.is_generic) { ret; }

    # get the expected receiver type from the method declaration's receiver node
    # (the function type's params array does NOT include the receiver)
    if (method_sym.decl_node == nil || method_sym.decl_node.info.fun_decl.receiver == nil) { ret; }
    val recv_decl: *ast.Node = method_sym.decl_node.info.fun_decl.receiver;

    # receiver is NODE_PARAM, its type AST node is in field_decl.type_node
    val recv_type_node: *ast.Node = recv_decl.info.field_decl.type_node;
    if (recv_type_node == nil) { ret; }

    # determine if method expects a pointer/ref receiver
    val method_expects_ptr: bool = (recv_type_node.kind == ast.NODE_TYPE_PTR || recv_type_node.kind == ast.NODE_TYPE_REF);

    val args: *ast.List = node.info.call_expr.args;
    if (args == nil || args.count < 1 || args.nodes == nil) { ret; }

    # auto-ref: method expects pointer, receiver is value -> wrap in addr-of
    if (method_expects_ptr && recv_ty.kind != ty.TY_POINTER) {
        val addr_res: Result[*ast.Node, str] = ast.create_node(sema.alloc, ast.NODE_EXPR_ADDR, args.nodes[0].tok);
        if (addr_res.is_ok()) {
            val addr_node: *ast.Node = addr_res.unwrap_ok();
            addr_node.info.unary_expr.expr = args.nodes[0];
            val ptr_res: Result[*ty.Type, str] = ty.pointer_type(sema.types, recv_ty, true);
            if (ptr_res.is_ok()) {
                addr_node.ty = ptr_res.unwrap_ok();
            }
            args.nodes[0] = addr_node;
        }
    }
    # auto-deref: method expects value, receiver is pointer -> wrap in deref
    or (!method_expects_ptr && recv_ty.kind == ty.TY_POINTER) {
        val deref_res: Result[*ast.Node, str] = ast.create_node(sema.alloc, ast.NODE_EXPR_DEREF, args.nodes[0].tok);
        if (deref_res.is_ok()) {
            val deref_node: *ast.Node = deref_res.unwrap_ok();
            deref_node.info.unary_expr.expr = args.nodes[0];
            if (recv_ty.inner != nil) {
                deref_node.ty = recv_ty.inner;
            }
            args.nodes[0] = deref_node;
        }
    }
}

# resolve_expr_type: infer the type of an expression.
# ---
# sema: analyzer context
# node: expression node
# ret:  inferred type or nil
fun resolve_expr_type(sema: *Sema, node: *ast.Node) *ty.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # if node already has a type, return it
    if (node.ty != nil) {
        ret node.ty;
    }

    # integer literal - default to i64
    if (node.kind == ast.NODE_EXPR_LIT_INT) {
        node.ty = ty.get_i64(sema.types);
        ret node.ty;
    }

    # string literal
    if (node.kind == ast.NODE_EXPR_LIT_STR) {
        node.ty = ty.get_str(sema.types);
        ret node.ty;
    }

    # boolean literal
    if (node.kind == ast.NODE_EXPR_LIT_BOOL) {
        node.ty = ty.get_bool(sema.types);
        ret node.ty;
    }

    # identifier - lookup symbol type
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.info.ident_expr.name;
        if (name != nil) {
            var sym: *symbol.Symbol = nil;

            # first check local scopes
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) {
                sym = sym_opt.unwrap();
            } or {
                # if not found locally, check unaliased imports
                if (sema.current_module != nil) {
                    var imp: *ModuleImport = sema.current_module.imports;
                    for (imp != nil && sym == nil) {
                        if (imp.module != nil && imp.module.table != nil) {
                            val root: *symbol.Scope = imp.module.table.root_scope();
                            if (root != nil) {
                                val cand_opt: Option[*symbol.Symbol] = root.lookup_local(name);
                                if (cand_opt.is_some()) {
                                    val cand: *symbol.Symbol = cand_opt.unwrap();
                                    if (cand.is_public) {
                                        sym = cand;
                                    }
                                }
                            }
                        }
                        imp = imp.next;
                    }
                }
            }

            if (sym != nil && sym.resolved_type != nil) {
                node.ty = sym.resolved_type;
                ret node.ty;
            }
            report_error_node(sema, node, "undefined identifier");
        }
        ret nil;
    }

    # field access expression (e.g., node.ty, ty.kind)
    if (node.kind == ast.NODE_EXPR_FIELD) {
        val fa_base: *ast.Node = node.info.field_expr.object;
        val fa_field_name: str = node.info.field_expr.field;
        if (fa_base == nil || fa_field_name == nil) {
            ret nil;
        }

        # check if base is a module alias
        if (fa_base.kind == ast.NODE_EXPR_IDENT && sema.current_module != nil) {
            val fa_base_name: str = fa_base.info.ident_expr.name;
            if (fa_base_name != nil) {
                var fa_ma: *ModuleAlias = sema.current_module.aliases;
                for (fa_ma != nil) {
                    if (fa_ma.alias != nil && fa_ma.alias.equals(fa_base_name)) {
                        # module alias - look up field_name in that module's symbol table
                        if (fa_ma.module != nil && fa_ma.module.table != nil) {
                            val fa_root: *symbol.Scope = fa_ma.module.table.root_scope();
                            if (fa_root != nil) {
                                val fa_sym_opt: Option[*symbol.Symbol] = fa_root.lookup_local(fa_field_name);
                                if (fa_sym_opt.is_some()) {
                                    val fa_sym: *symbol.Symbol = fa_sym_opt.unwrap();
                                    if (fa_sym.resolved_type != nil) {
                                        node.ty = fa_sym.resolved_type;
                                        ret node.ty;
                                    }
                                }
                            }
                        }
                        ret nil;
                    }
                    fa_ma = fa_ma.next;
                }
            }
        }

        # not a module alias - resolve base expression type
        val fa_base_ty: *ty.Type = resolve_expr_type(sema, fa_base);
        if (fa_base_ty == nil) {
            ret nil;
        }

        # auto-dereference pointer to record/union
        var fa_struct_ty: *ty.Type = fa_base_ty;
        if (fa_base_ty.kind == ty.TY_POINTER && fa_base_ty.inner != nil) {
            fa_struct_ty = fa_base_ty.inner;
        }

        # look up field in record/union
        if (fa_struct_ty.kind == ty.TY_RECORD || fa_struct_ty.kind == ty.TY_UNION) {
            val fa_field_opt: Option[*ty.Field] = ty.get_field(fa_struct_ty, fa_field_name);
            if (fa_field_opt.is_some()) {
                val fa_field: *ty.Field = fa_field_opt.unwrap();
                node.ty = fa_field.ty;
                ret node.ty;
            }
        }

        # field not found on record/union — try method lookup
        # get the base type name for building qualified method name
        var fa_type_name: str = fa_struct_ty.name;
        if (fa_type_name == nil && fa_struct_ty.kind == ty.TY_STR) {
            fa_type_name = "str";
        }

        # for instantiated generic types, also extract the base generic name
        # e.g., for "ResultI6stat_tK2u8E" extract "Result"
        var fa_generic_base_name: str = nil;
        if (fa_struct_ty.generic_arg_count > 0 && fa_type_name != nil) {
            fa_generic_base_name = fa_type_name;
            # if the type name contains mangling, extract base before 'I'
            # but for self-hosted, the name is typically the un-mangled "Result"
        }

        if (fa_type_name != nil) {
            # build "TypeName.methodName"
            val fa_tn_len: usize = fa_type_name.len();
            val fa_mn_len: usize = fa_field_name.len();
            val fa_qn_len: usize = fa_tn_len + 1 + fa_mn_len + 1;
            val fa_qn_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](fa_qn_len);
            if (fa_qn_res.is_ok()) {
                val fa_qn_buf: *u8 = fa_qn_res.unwrap_ok();
                var fa_qi: usize = 0;
                for (fa_qi < fa_tn_len) { fa_qn_buf[fa_qi] = fa_type_name[fa_qi]; fa_qi = fa_qi + 1; }
                fa_qn_buf[fa_qi] = '.'; fa_qi = fa_qi + 1;
                var fa_qj: usize = 0;
                for (fa_qj < fa_mn_len) { fa_qn_buf[fa_qi] = fa_field_name[fa_qj]; fa_qi = fa_qi + 1; fa_qj = fa_qj + 1; }
                fa_qn_buf[fa_qi] = 0;
                val fa_qual_name: str = fa_qn_buf::str;

                val fa_method: *symbol.Symbol = lookup_function_symbol(sema, fa_qual_name);
                if (fa_method != nil) {
                    # check if receiver type is an instantiated generic (has concrete type args)
                    if (fa_struct_ty.generic_args != nil && fa_struct_ty.generic_arg_count > 0) {
                        # instantiate the method with the receiver's concrete type args
                        val fa_inst_name: str = instantiate_generic_method(sema, fa_method, fa_struct_ty);
                        if (fa_inst_name != nil) {
                            var fa_inst: *symbol.Symbol = nil;
                            val fa_inst_opt: Option[*symbol.Symbol] = sema.symbols.lookup(fa_inst_name);
                            if (fa_inst_opt.is_some()) {
                                fa_inst = fa_inst_opt.unwrap();
                            } or {
                                # symbol may have been defined in a different module's scope
                                fa_inst = lookup_function_symbol(sema, fa_inst_name);
                            }
                            if (fa_inst != nil) {
                                if (fa_inst.resolved_type != nil && fa_inst.resolved_type.kind == ty.TY_FUN) {
                                    node.ty = fa_inst.resolved_type;
                                    ret node.ty;
                                }
                            }
                        }
                    }

                    # non-generic method (or generic instantiation failed) — use method's own type
                    if (fa_method.resolved_type != nil && fa_method.resolved_type.kind == ty.TY_FUN) {
                        node.ty = fa_method.resolved_type;
                        ret node.ty;
                    }
                }
            }
        }

        ret nil;
    }

    # cast expression
    if (node.kind == ast.NODE_EXPR_CAST) {
        # resolve inner expression first (for side effects like method instantiation)
        val cast_inner: *ast.Node = node.info.cast_expr.expr;
        if (cast_inner != nil) {
            resolve_expr_type(sema, cast_inner);
        }
        val cast_type_node: *ast.Node = node.info.cast_expr.type_node;
        if (cast_type_node != nil) {
            val cast_target: *ty.Type = resolve_type_expr(sema, cast_type_node);
            if (cast_target != nil) {
                node.ty = cast_target;
                ret node.ty;
            }
        }
        ret nil;
    }

    # parenthesized expression
    if (node.kind == ast.NODE_EXPR_PAREN) {
        val paren_inner: *ast.Node = node.info.wrapper.inner;
        if (paren_inner != nil) {
            val paren_ty: *ty.Type = resolve_expr_type(sema, paren_inner);
            if (paren_ty != nil) {
                node.ty = paren_ty;
                ret node.ty;
            }
        }
        ret nil;
    }

    # struct literal (e.g., MyStruct { field: value })
    if (node.kind == ast.NODE_EXPR_STRUCT_LIT) {
        val slit_type_node: *ast.Node = node.info.struct_lit.type_node;
        if (slit_type_node != nil) {
            val slit_type: *ty.Type = resolve_type_expr(sema, slit_type_node);
            if (slit_type != nil) {
                node.ty = slit_type;

                # resolve field value expressions so calls inside struct literals
                # are properly analyzed (triggers method instantiation, sets node.ty)
                val slit_fields: *ast.List = node.info.struct_lit.fields;
                if (slit_fields != nil) {
                    var sfi: i32 = 0;
                    for (sfi < slit_fields.count) {
                        val sfield: *ast.Node = slit_fields.nodes[sfi];
                        if (sfield != nil) {
                            val sfval: *ast.Node = sfield.info.field_decl.type_node;
                            if (sfval != nil) {
                                resolve_expr_type(sema, sfval);
                            }
                        }
                        sfi = sfi + 1;
                    }
                }

                ret node.ty;
            }
        }
        ret nil;
    }

    # binary expression
    if (node.kind == ast.NODE_EXPR_BINARY) {
        val lhs_type: *ty.Type = resolve_expr_type(sema, node.info.binary_expr.left);
        val rhs_type: *ty.Type = resolve_expr_type(sema, node.info.binary_expr.right);
        
        if (lhs_type != nil) {
            node.ty = lhs_type;
            ret node.ty;
        }
        if (rhs_type != nil) {
            node.ty = rhs_type;
            ret node.ty;
        }
        ret nil;
    }

    # unary expression
    if (node.kind == ast.NODE_EXPR_UNARY) {
        val operand_type: *ty.Type = resolve_expr_type(sema, node.info.unary_expr.expr);
        if (operand_type != nil) {
            node.ty = operand_type;
            ret node.ty;
        }
        ret nil;
    }

    # function call
    if (node.kind == ast.NODE_EXPR_CALL) {
        # recursively prepend method receivers in nested call arguments
        # (e.g., s.len() inside write_all(w, s, s.len()))
        if (sema.current_fn != nil) {
            val call_args: *ast.List = node.info.call_expr.args;
            if (call_args != nil) {
                var ai: i32 = 0;
                for (ai < call_args.count) {
                    if (call_args.nodes[ai] != nil) {
                        prepend_method_receivers(sema, call_args.nodes[ai]);
                        resolve_expr_type(sema, call_args.nodes[ai]);
                    }
                    ai = ai + 1;
                }
            }
        }

        val callee: *ast.Node = node.info.call_expr.callee;
        if (callee != nil) {
            # check if this is a method call (callee is a field access on an object)
            if (callee.kind == ast.NODE_EXPR_FIELD) {
                val receiver: *ast.Node = callee.info.field_expr.object;
                if (receiver != nil && receiver.kind == ast.NODE_EXPR_IDENT) {
                    val recv_name: str = receiver.info.ident_expr.name;

                    # check if receiver is a module alias (not a method call)
                    var is_module_alias: bool = false;
                    if (recv_name != nil && sema.current_module != nil) {
                        var ma: *ModuleAlias = sema.current_module.aliases;
                        for (ma != nil) {
                            if (ma.alias != nil && ma.alias.equals(recv_name)) {
                                is_module_alias = true;
                            }
                            ma = ma.next;
                        }
                    }

                    if (!is_module_alias) {

                        # try to find receiver as a symbol (without reporting error)
                        val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(recv_name);
                        if (sym_opt.is_some()) {
                            val sym: *symbol.Symbol = sym_opt.unwrap();
                            var recv_ty: *ty.Type = sym.resolved_type;
                            if (recv_ty == nil && sym.decl_node != nil) {
                                recv_ty = sym.decl_node.ty;
                            }

                            # set type on receiver node for lowering to detect method calls
                            if (recv_ty != nil) {
                                receiver.ty = recv_ty;
                            }

                            # only prepend receiver for actual method calls on objects
                            var is_method_call: bool = recv_ty != nil && (
                                recv_ty.kind == ty.TY_RECORD ||
                                recv_ty.kind == ty.TY_UNION ||
                                recv_ty.kind == ty.TY_STR ||
                                recv_ty.kind == ty.TY_GENERIC ||
                                (recv_ty.kind == ty.TY_POINTER && recv_ty.inner != nil &&
                                 (recv_ty.inner.kind == ty.TY_RECORD || recv_ty.inner.kind == ty.TY_UNION || recv_ty.inner.kind == ty.TY_GENERIC))
                            );

                            # exclude function-pointer struct fields from method call detection
                            if (is_method_call) {
                                val fp_field_name2: str = callee.info.field_expr.field;
                                if (fp_field_name2 != nil) {
                                    var base_rec_ty2: *ty.Type = recv_ty;
                                    if (base_rec_ty2.kind == ty.TY_POINTER && base_rec_ty2.inner != nil) {
                                        base_rec_ty2 = base_rec_ty2.inner;
                                    }
                                    if ((base_rec_ty2.kind == ty.TY_RECORD || base_rec_ty2.kind == ty.TY_UNION) &&
                                        base_rec_ty2.fields != nil && base_rec_ty2.field_count > 0) {
                                        var fi2: i32 = 0;
                                        for (fi2 < base_rec_ty2.field_count) {
                                            val f2: *ty.Field = ?base_rec_ty2.fields[fi2];
                                            if (f2.name != nil && f2.name.equals(fp_field_name2) &&
                                                f2.ty != nil && f2.ty.kind == ty.TY_FUN) {
                                                is_method_call = false;
                                            }
                                            fi2 = fi2 + 1;
                                        }
                                    }
                                }
                            }

                            if (is_method_call) {
                                # method call: prepend receiver as first argument

                                # guard: skip if receiver was already prepended by prepend_method_receivers
                                var args: *ast.List = node.info.call_expr.args;
                                var already_prepended: bool = false;
                                if (args != nil && args.count > 0 && args.nodes[0] == receiver) {
                                    already_prepended = true;
                                }

                                if (!already_prepended) {
                                    # get or create args list
                                    if (args == nil) {
                                        val list_res: Result[*ast.List, str] = ast.create_list(sema.alloc);
                                        if (list_res.is_ok()) {
                                            args = list_res.unwrap_ok();
                                            node.info.call_expr.args = args;
                                        }
                                    }

                                    # prepend receiver to args by shifting existing args
                                    if (args != nil) {
                                        # ensure capacity
                                        val new_count: i32 = args.count + 1;
                                        if (new_count > args.capacity) {
                                            val new_cap: i32 = new_count * 2;
                                            val alloc_res: Result[**ast.Node, allocator.AllocError] =
                                                sema.alloc.alloc[*ast.Node](new_cap::usize);
                                            if (alloc_res.is_ok()) {
                                                val new_nodes: **ast.Node = alloc_res.unwrap_ok();
                                                # copy existing args starting at index 1
                                                var i: i32 = 0;
                                                for (i < args.count) {
                                                    new_nodes[i + 1] = args.nodes[i];
                                                    i = i + 1;
                                                }
                                                # put receiver at index 0
                                                new_nodes[0] = receiver;
                                                args.nodes = new_nodes;
                                                args.count = new_count;
                                                args.capacity = new_cap;
                                            }
                                        } or {
                                            # shift existing elements up by 1
                                            var i: i32 = args.count;
                                            for (i > 0) {
                                                args.nodes[i] = args.nodes[i - 1];
                                                i = i - 1;
                                            }
                                            # put receiver at index 0
                                            args.nodes[0] = receiver;
                                            args.count = new_count;
                                        }
                                    }
                                }
                            }
                        }
                    }
                } or {
                  if (receiver != nil) {
                    # handle non-identifier receivers (field access, index, etc.)
                    # e.g., e.key.equals(key) where e.key is NODE_EXPR_FIELD
                    val recv_ty: *ty.Type = resolve_expr_type(sema, receiver);
                    if (recv_ty != nil) {
                        var is_method_call: bool = (
                            recv_ty.kind == ty.TY_RECORD ||
                            recv_ty.kind == ty.TY_UNION ||
                            recv_ty.kind == ty.TY_STR ||
                            recv_ty.kind == ty.TY_GENERIC ||
                            (recv_ty.kind == ty.TY_POINTER && recv_ty.inner != nil &&
                             (recv_ty.inner.kind == ty.TY_RECORD || recv_ty.inner.kind == ty.TY_UNION || recv_ty.inner.kind == ty.TY_GENERIC))
                        );

                        # exclude function-pointer struct fields
                        if (is_method_call) {
                            val fp_fn: str = callee.info.field_expr.field;
                            if (fp_fn != nil) {
                                var base_ty: *ty.Type = recv_ty;
                                if (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
                                    base_ty = base_ty.inner;
                                }
                                if ((base_ty.kind == ty.TY_RECORD || base_ty.kind == ty.TY_UNION) &&
                                    base_ty.fields != nil && base_ty.field_count > 0) {
                                    var fi3: i32 = 0;
                                    for (fi3 < base_ty.field_count) {
                                        val f3: *ty.Field = ?base_ty.fields[fi3];
                                        if (f3.name != nil && f3.name.equals(fp_fn) &&
                                            f3.ty != nil && f3.ty.kind == ty.TY_FUN) {
                                            is_method_call = false;
                                        }
                                        fi3 = fi3 + 1;
                                    }
                                }
                            }
                        }

                        if (is_method_call) {
                            var args: *ast.List = node.info.call_expr.args;
                            var already_prepended: bool = false;
                            if (args != nil && args.count > 0 && args.nodes[0] == receiver) {
                                already_prepended = true;
                            }

                            if (!already_prepended) {
                                if (args == nil) {
                                    val list_res: Result[*ast.List, str] = ast.create_list(sema.alloc);
                                    if (list_res.is_ok()) {
                                        args = list_res.unwrap_ok();
                                        node.info.call_expr.args = args;
                                    }
                                }

                                if (args != nil) {
                                    val new_count: i32 = args.count + 1;
                                    if (new_count > args.capacity) {
                                        val new_cap: i32 = new_count * 2;
                                        val alloc_res: Result[**ast.Node, allocator.AllocError] =
                                            sema.alloc.alloc[*ast.Node](new_cap::usize);
                                        if (alloc_res.is_ok()) {
                                            val new_nodes: **ast.Node = alloc_res.unwrap_ok();
                                            var ci: i32 = 0;
                                            for (ci < args.count) {
                                                new_nodes[ci + 1] = args.nodes[ci];
                                                ci = ci + 1;
                                            }
                                            new_nodes[0] = receiver;
                                            args.nodes = new_nodes;
                                            args.count = new_count;
                                            args.capacity = new_cap;
                                        }
                                    } or {
                                        var ci: i32 = args.count;
                                        for (ci > 0) {
                                            args.nodes[ci] = args.nodes[ci - 1];
                                            ci = ci - 1;
                                        }
                                        args.nodes[0] = receiver;
                                        args.count = new_count;
                                    }
                                }
                            }
                        }
                    }
                  }
                }
            }

            val callee_type: *ty.Type = resolve_expr_type(sema, callee);
            if (callee_type != nil && callee_type.kind == ty.TY_FUN) {
                # check for generic function call with type args
                val type_args: *ast.Node = node.info.call_expr.type_args;
                if (type_args != nil && callee.kind == ast.NODE_EXPR_IDENT) {
                    # look up the function symbol (including imports)
                    val func_name: str = callee.info.ident_expr.name;
                    if (func_name != nil) {
                        val sym: *symbol.Symbol = lookup_function_symbol(sema, func_name);
                        if (sym != nil && sym.is_generic && sym.decl_node != nil && sym.decl_node.info.fun_decl.ret_type != nil) {
                            # resolve return type with generic bindings
                            val ret_ty: *ty.Type = resolve_generic_call_return_type(sema, sym, type_args);
                            # also create an instantiation record for lowering
                            instantiate_generic_function(sema, sym, type_args);
                            if (ret_ty != nil) {
                                node.ty = ret_ty;
                                ret ret_ty;
                            }
                        }
                    }
                }
                node.ty = callee_type.ret_type;
                ret node.ty;
            }

            # callee_type is nil - might be a method call on a generic type
            # (field access doesn't resolve for methods since they're not record fields)
            if (callee.kind == ast.NODE_EXPR_FIELD) {
                val mc_base: *ast.Node = callee.info.field_expr.object;
                val mc_method_name: str = callee.info.field_expr.field;
                if (mc_base != nil && mc_method_name != nil) {
                    var mc_recv_ty: *ty.Type = mc_base.ty;

                    # for identifiers, try local variable lookup
                    if (mc_recv_ty == nil && mc_base.kind == ast.NODE_EXPR_IDENT) {
                        val mc_base_name: str = mc_base.info.ident_expr.name;
                        if (mc_base_name != nil) {
                            val mc_sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(mc_base_name);
                            if (mc_sym_opt.is_some()) {
                                val mc_sym: *symbol.Symbol = mc_sym_opt.unwrap();
                                mc_recv_ty = mc_sym.resolved_type;
                            }
                        }
                    }

                    if (mc_recv_ty != nil) {
                        # unwrap pointer to get base type
                        var mc_base_ty: *ty.Type = mc_recv_ty;
                        if (mc_base_ty.kind == ty.TY_POINTER && mc_base_ty.inner != nil) {
                            mc_base_ty = mc_base_ty.inner;
                        }

                        # check if receiver type is an instantiated generic (has concrete type args)
                        if (mc_base_ty.generic_args != nil && mc_base_ty.generic_arg_count > 0) {
                            # look up the generic method symbol by qualified name
                            val mc_type_name: str = mc_base_ty.name;
                            if (mc_type_name != nil) {
                                # build "TypeName.methodName"
                                val tn_len: usize = mc_type_name.len();
                                val mn_len: usize = mc_method_name.len();
                                val qn_len: usize = tn_len + 1 + mn_len + 1;
                                val qn_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](qn_len);
                                if (qn_res.is_ok()) {
                                    val qn_buf: *u8 = qn_res.unwrap_ok();
                                    var qi: usize = 0;
                                    for (qi < tn_len) { qn_buf[qi] = mc_type_name[qi]; qi = qi + 1; }
                                    qn_buf[qi] = '.'; qi = qi + 1;
                                    var qj: usize = 0;
                                    for (qj < mn_len) { qn_buf[qi] = mc_method_name[qj]; qi = qi + 1; qj = qj + 1; }
                                    qn_buf[qi] = 0;
                                    val qual_name: str = qn_buf::str;

                                    # look up the generic method symbol (also search imports)
                                    val method_sym: *symbol.Symbol = lookup_function_symbol(sema, qual_name);
                                    if (method_sym != nil) {
                                        # instantiate the method with the receiver's concrete type args
                                        val inst_name: str = instantiate_generic_method(sema, method_sym, mc_base_ty);
                                        if (inst_name != nil) {
                                            # look up the instantiated symbol to get its return type
                                            var inst_sym: *symbol.Symbol = nil;
                                            val inst_sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(inst_name);
                                            if (inst_sym_opt.is_some()) {
                                                inst_sym = inst_sym_opt.unwrap();
                                            } or {
                                                # symbol may have been defined in a different module's scope
                                                inst_sym = lookup_function_symbol(sema, inst_name);
                                            }
                                            if (inst_sym != nil) {
                                                if (inst_sym.resolved_type != nil && inst_sym.resolved_type.kind == ty.TY_FUN) {
                                                    auto_ref_receiver(sema, node, mc_recv_ty, inst_sym);
                                                    node.ty = inst_sym.resolved_type.ret_type;
                                                    ret node.ty;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        # non-generic method call: try to resolve return type from method symbol
                        var mc_type_name2: str = mc_base_ty.name;
                        if (mc_type_name2 == nil && mc_base_ty.kind == ty.TY_STR) {
                            mc_type_name2 = "str";
                        }
                        if (mc_type_name2 != nil) {
                            val tn_len2: usize = mc_type_name2.len();
                            val mn_len2: usize = mc_method_name.len();
                            val qn_len2: usize = tn_len2 + 1 + mn_len2 + 1;
                            val qn_res2: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](qn_len2);
                            if (qn_res2.is_ok()) {
                                val qn_buf2: *u8 = qn_res2.unwrap_ok();
                                var qi2: usize = 0;
                                for (qi2 < tn_len2) { qn_buf2[qi2] = mc_type_name2[qi2]; qi2 = qi2 + 1; }
                                qn_buf2[qi2] = '.'; qi2 = qi2 + 1;
                                var qj2: usize = 0;
                                for (qj2 < mn_len2) { qn_buf2[qi2] = mc_method_name[qj2]; qi2 = qi2 + 1; qj2 = qj2 + 1; }
                                qn_buf2[qi2] = 0;
                                val qual_name2: str = qn_buf2::str;

                                val ms: *symbol.Symbol = lookup_function_symbol(sema, qual_name2);
                                if (ms != nil) {
                                    # skip early return for generic methods with explicit type args
                                    # (e.g., alloc.alloc[u8]) — these must fall through to the
                                    # instantiation code below
                                    val ms_is_generic: bool = ms.is_generic ||
                                        (ms.decl_node != nil && ms.decl_node.info.fun_decl.generics != nil);
                                    val ms_has_type_args: bool = node.info.call_expr.type_args != nil;
                                    if (!ms_is_generic || !ms_has_type_args) {
                                        auto_ref_receiver(sema, node, mc_recv_ty, ms);
                                        if (ms.resolved_type != nil && ms.resolved_type.kind == ty.TY_FUN) {
                                            node.ty = ms.resolved_type.ret_type;
                                            ret node.ty;
                                        }
                                        # method found but no resolved_type - try from decl_node.ty
                                        if (ms.decl_node != nil && ms.decl_node.ty != nil && ms.decl_node.ty.kind == ty.TY_FUN) {
                                            node.ty = ms.decl_node.ty.ret_type;
                                            ret node.ty;
                                        }
                                    }
                                }
                            }
                        }

                        # check if the call has its own type args (e.g., alloc.alloc[T](count))
                        val mc_call_type_args: *ast.Node = node.info.call_expr.type_args;
                        if (mc_call_type_args != nil) {
                            var mc_type_name3: str = mc_base_ty.name;
                            if (mc_type_name3 == nil && mc_base_ty.kind == ty.TY_STR) {
                                mc_type_name3 = "str";
                            }
                            if (mc_type_name3 != nil) {
                                val tn_len3: usize = mc_type_name3.len();
                                val mn_len3: usize = mc_method_name.len();
                                val qn_len3: usize = tn_len3 + 1 + mn_len3 + 1;
                                val qn_res3: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](qn_len3);
                                if (qn_res3.is_ok()) {
                                    val qn_buf3: *u8 = qn_res3.unwrap_ok();
                                    var qi3: usize = 0;
                                    for (qi3 < tn_len3) { qn_buf3[qi3] = mc_type_name3[qi3]; qi3 = qi3 + 1; }
                                    qn_buf3[qi3] = '.'; qi3 = qi3 + 1;
                                    var qj3: usize = 0;
                                    for (qj3 < mn_len3) { qn_buf3[qi3] = mc_method_name[qj3]; qi3 = qi3 + 1; qj3 = qj3 + 1; }
                                    qn_buf3[qi3] = 0;
                                    val qual_name3: str = qn_buf3::str;

                                    val gms: *symbol.Symbol = lookup_function_symbol(sema, qual_name3);
                                    if (gms != nil) {
                                        if (gms.is_generic || (gms.decl_node != nil && gms.decl_node.info.fun_decl.generics != nil)) {
                                            val gm_inst_name: str = instantiate_generic_own_method(
                                                sema, gms, mc_call_type_args, mc_recv_ty);
                                            if (gm_inst_name != nil) {
                                                var gm_sym: *symbol.Symbol = nil;
                                                val gm_sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(gm_inst_name);
                                                if (gm_sym_opt.is_some()) {
                                                    gm_sym = gm_sym_opt.unwrap();
                                                } or {
                                                    # symbol may have been defined in a different module's scope
                                                    gm_sym = lookup_function_symbol(sema, gm_inst_name);
                                                }
                                                if (gm_sym != nil) {
                                                    if (gm_sym.resolved_type != nil && gm_sym.resolved_type.kind == ty.TY_FUN) {
                                                        auto_ref_receiver(sema, node, mc_recv_ty, gm_sym);
                                                        node.ty = gm_sym.resolved_type.ret_type;
                                                        ret node.ty;
                                                    }
                                                }
                                            }
                                            # fall back to non-generic return type resolution
                                            val gm_ret_ty: *ty.Type = resolve_generic_call_return_type(sema, gms, mc_call_type_args);
                                            if (gm_ret_ty != nil) {
                                                node.ty = gm_ret_ty;
                                                ret node.ty;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        ret nil;
    }

    # address-of
    if (node.kind == ast.NODE_EXPR_ADDR) {
        val operand_type: *ty.Type = resolve_expr_type(sema, node.info.unary_expr.expr);
        if (operand_type != nil) {
            val ptr_res: Result[*ty.Type, str] = ty.pointer_type(sema.types, operand_type, true);
            if (ptr_res.is_ok()) {
                node.ty = ptr_res.unwrap_ok();
                ret node.ty;
            }
        }
        ret nil;
    }

    # index expression (e.g., arr[i]) - element type of pointer/array
    if (node.kind == ast.NODE_EXPR_INDEX) {
        val idx_base: *ast.Node = node.info.index_expr.base;
        if (idx_base != nil) {
            val idx_base_ty: *ty.Type = resolve_expr_type(sema, idx_base);
            if (idx_base_ty != nil) {
                if (idx_base_ty.kind == ty.TY_POINTER && idx_base_ty.inner != nil) {
                    node.ty = idx_base_ty.inner;
                    ret node.ty;
                }
                if (idx_base_ty.kind == ty.TY_ARRAY && idx_base_ty.inner != nil) {
                    node.ty = idx_base_ty.inner;
                    ret node.ty;
                }
            }
        }
        ret nil;
    }

    # dereference
    if (node.kind == ast.NODE_EXPR_DEREF) {
        val operand_type: *ty.Type = resolve_expr_type(sema, node.info.unary_expr.expr);
        if (operand_type != nil && operand_type.kind == ty.TY_POINTER) {
            node.ty = operand_type.inner;
            ret node.ty;
        }
        ret nil;
    }

    # nil
    if (node.kind == ast.NODE_EXPR_LIT_NIL) {
        node.ty = ty.get_nil(sema.types);
        ret node.ty;
    }

    ret nil;
}

# analyze_functions: pass 3 - analyze function bodies.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
fun analyze_functions(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # analyze function body
        if (node.kind == ast.NODE_DECL_FUN) {
            analyze_function(sema, node);
        }

        # pub wrapper - process inner declaration
        if (node.kind == ast.NODE_DECL_PUB) {
            val inner: *ast.Node = node.info.wrapper.inner;
            if (inner != nil && inner.kind == ast.NODE_DECL_FUN) {
                analyze_function(sema, inner);
            }
        }

        # comptime statement
        if (node.kind == ast.NODE_COMPTIME) {
            analyze_comptime_stmt(sema, node);
        }

        # comptime if - analyze functions in taken branch
        if (node.kind == ast.NODE_COMPTIME_IF) {
            val taken: *ast.Node = node.info.cond_stmt.body;
            if (taken != nil) {
                analyze_comptime_if_functions(sema, taken);
            }
        }

        i = i + 1;
    }
}

# analyze_comptime_if_functions: analyze functions in a $if taken branch.
# ---
# sema: analyzer context
# body: taken branch body node
# ret:  none
fun analyze_comptime_if_functions(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    # body should be a block node
    if (body.kind != ast.NODE_STMT_BLOCK) {
        # single declaration
        if (body.kind == ast.NODE_DECL_FUN) {
            analyze_function(sema, body);
        }
        if (body.kind == ast.NODE_COMPTIME_IF) {
            val taken: *ast.Node = body.info.cond_stmt.body;
            if (taken != nil) {
                analyze_comptime_if_functions(sema, taken);
            }
        }
        ret;
    }

    # get declarations from block
    val decls: *ast.List = body.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            if (node.kind == ast.NODE_DECL_FUN) {
                analyze_function(sema, node);
            }
            if (node.kind == ast.NODE_COMPTIME_IF) {
                val taken: *ast.Node = node.info.cond_stmt.body;
                if (taken != nil) {
                    analyze_comptime_if_functions(sema, taken);
                }
            }
        }
        i = i + 1;
    }
}

# analyze_function: analyze a function body.
# ---
# sema: analyzer context
# node: function declaration node
# ret:  none
fun analyze_function(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # set current function
    sema.current_fn = node;
    
    # get function return type
    if (node.ty != nil && node.ty.kind == ty.TY_FUN) {
        sema.current_fn_ret = node.ty.ret_type;
    } or {
        sema.current_fn_ret = ty.get_void(sema.types);
    }

    # create new scope for function
    val push_res: Result[bool, str] = push_scope(sema);
    if (push_res.is_err()) {
        report_error_node(sema, node, "failed to create function scope");
        ret;
    }

    # push symbol table scope so local variables don't leak into root scope
    sema.symbols.push_scope();

    # bind generic type parameters (from receiver and/or function generics)
    if (node.info.fun_decl.receiver != nil) {
        bind_method_type_params(sema, node.info.fun_decl.receiver);
    }
    if (node.info.fun_decl.generics != nil) {
        val func_generics: *ast.Node = node.info.fun_decl.generics;
        if (func_generics.kind == ast.NODE_GENERIC) {
            val gp_list: *ast.List = func_generics.info.generic_node.args;
            if (gp_list != nil) {
                var gi: i32 = 0;
                for (gi < gp_list.count) {
                    val gp: *ast.Node = gp_list.nodes[gi];
                    if (gp != nil) {
                        val gp_name: str = gp.info.type_name.path;
                        if (gp_name != nil) {
                            val gp_sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(gp_name, symbol.SYM_TYPE);
                            if (gp_sym_res.is_ok()) {
                                val gp_sym: *symbol.Symbol = gp_sym_res.unwrap_ok();
                                val gp_type_res: Result[*ty.Type, str] = ty.generic_param_type(sema.types, gp_name);
                                if (gp_type_res.is_ok()) {
                                    gp_sym.resolved_type = gp_type_res.unwrap_ok();
                                }
                            }
                        }
                    }
                    gi = gi + 1;
                }
            }
        }
    }

    # add method receiver to scope (e.g., this: *Writer)
    if (node.info.fun_decl.receiver != nil) {
        val recv_name: str = node.info.fun_decl.receiver.info.field_decl.name;
        if (recv_name != nil) {
            val recv_sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(recv_name, symbol.SYM_VAL);
            if (recv_sym_res.is_ok()) {
                val recv_sym: *symbol.Symbol = recv_sym_res.unwrap_ok();
                # resolve the receiver type from its type annotation
                val recv_type_node: *ast.Node = node.info.fun_decl.receiver.info.field_decl.type_node;
                if (recv_type_node != nil) {
                    val recv_ty: *ty.Type = resolve_type_expr(sema, recv_type_node);
                    if (recv_ty != nil) {
                        recv_sym.resolved_type = recv_ty;
                        node.info.fun_decl.receiver.ty = recv_ty;
                    }
                }
                recv_sym.decl_node = node.info.fun_decl.receiver;
            }
        }
    }

    # add parameters to scope
    val params: *ast.List = node.info.fun_decl.params;
    if (params != nil) {
        var i: i32 = 0;
        for (i < params.count) {
            val param: *ast.Node = params.nodes[i];
            if (param != nil) {
                val param_name: str = param.info.field_decl.name;
                if (param_name != nil) {
                    var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
                    if (node.kind == ast.NODE_DECL_VAR) {
                        sym_kind = symbol.SYM_VAR;
                    }
                    val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, sym_kind);
                    if (sym_res.is_ok()) {
                        val sym: *symbol.Symbol = sym_res.unwrap_ok();
                        sym.resolved_type = param.ty;
                        sym.decl_node = param;
                    }
                }
            }
            i = i + 1;
        }
    }

    # analyze function body
    val body: *ast.Node = node.info.fun_decl.body;
    if (body != nil) {
        analyze_stmt(sema, body);
    }

    # pop symbol table scope (matches push in analyze_function above)
    sema.symbols.pop_scope();

    # pop function scope
    pop_scope(sema);

    # clear current function
    sema.current_fn = nil;
    sema.current_fn_ret = nil;
}

# analyze_stmt: analyze a statement.
# ---
# sema: analyzer context
# node: statement node
# ret:  none
fun analyze_stmt(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # comptime statement
    if (node.kind == ast.NODE_COMPTIME) {
        analyze_comptime_stmt(sema, node);
        ret;
    }

    # block statement
    if (node.kind == ast.NODE_STMT_BLOCK) {
        # create new scope for block
        val push_res: Result[bool, str] = push_scope(sema);
        if (push_res.is_ok()) {
            sema.symbols.push_scope();
            val stmts: *ast.List = node.info.block_stmt.stmts;
            if (stmts != nil) {
                var i: i32 = 0;
                for (i < stmts.count) {
                    analyze_stmt(sema, stmts.nodes[i]);
                    i = i + 1;
                }
            }
            sema.symbols.pop_scope();
            pop_scope(sema);
        }
        ret;
    }

    # expression statement
    if (node.kind == ast.NODE_STMT_EXPR) {
        val expr: *ast.Node = node.info.wrapper.inner;
        if (expr != nil) {
            resolve_expr_type(sema, expr);
        }
        ret;
    }

    # variable declaration
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val name: str = node.info.var_decl.name;
        val init: *ast.Node = node.info.var_decl.init;
        val type_annot: *ast.Node = node.info.var_decl.type_node;

        # first try to resolve from type annotation
        if (type_annot != nil) {
            val annot_type: *ty.Type = resolve_type_expr(sema, type_annot);
            if (annot_type != nil) {
                node.ty = annot_type;
            }
        }

        # always analyze initializer for method receiver prepending and type inference
        if (init != nil) {
            val init_type: *ty.Type = resolve_expr_type(sema, init);
            if (node.ty == nil && init_type != nil) {
                node.ty = init_type;
            }
        }

        if (name != nil) {
            var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
            if (node.kind == ast.NODE_DECL_VAR) {
                sym_kind = symbol.SYM_VAR;
            }
            val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(name, sym_kind);
            if (sym_res.is_ok()) {
                val sym: *symbol.Symbol = sym_res.unwrap_ok();
                sym.resolved_type = node.ty;
                sym.decl_node = node;
            }
        }
        ret;
    }

    # return statement
    if (node.kind == ast.NODE_STMT_RET) {
        val ret_expr: *ast.Node = node.info.wrapper.inner;
        if (ret_expr != nil) {
            val ret_type: *ty.Type = resolve_expr_type(sema, ret_expr);
            # check against function return type
            if (sema.current_fn_ret != nil && ret_type != nil) {
                if (!ty.types_equal(sema.current_fn_ret, ret_type)) {
                    report_error_node(sema, node, "return type mismatch");
                }
            }
        } or {
            # void return - check function returns void
            if (sema.current_fn_ret != nil && sema.current_fn_ret.kind != ty.TY_VOID) {
                report_error_node(sema, node, "missing return value");
            }
        }
        ret;
    }

    # if statement
    if (node.kind == ast.NODE_STMT_IF) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) {
            val cond_type: *ty.Type = resolve_expr_type(sema, cond);
            # condition should be boolean or integer
            if (cond_type != nil && cond_type.kind != ty.TY_BOOL && !cond_type.is_integer()) {
                report_error_node(sema, cond, "condition must be boolean or integer");
            }
        }

        val then_stmt: *ast.Node = node.info.cond_stmt.body;
        if (then_stmt != nil) {
            analyze_stmt(sema, then_stmt);
        }

        val else_stmt: *ast.Node = node.info.cond_stmt.or_branch;
        if (else_stmt != nil) {
            analyze_stmt(sema, else_stmt);
        }
        ret;
    }

    # or block (else clause of if/or chain)
    if (node.kind == ast.NODE_STMT_OR) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) {
            val cond_type: *ty.Type = resolve_expr_type(sema, cond);
            if (cond_type != nil && cond_type.kind != ty.TY_BOOL && !cond_type.is_integer()) {
                report_error_node(sema, cond, "condition must be boolean or integer");
            }
        }

        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            analyze_stmt(sema, body);
        }

        val next: *ast.Node = node.info.cond_stmt.or_branch;
        if (next != nil) {
            analyze_stmt(sema, next);
        }
        ret;
    }

    # while/for loop
    if (node.kind == ast.NODE_STMT_FOR) {
        val cond: *ast.Node = node.info.for_stmt.cond;
        if (cond != nil) {
            val cond_type: *ty.Type = resolve_expr_type(sema, cond);
            if (cond_type != nil && cond_type.kind != ty.TY_BOOL && !cond_type.is_integer()) {
                report_error_node(sema, cond, "loop condition must be boolean or integer");
            }
        }

        val body: *ast.Node = node.info.for_stmt.body;
        if (body != nil) {
            analyze_stmt(sema, body);
        }
        ret;
    }

    # assignment
    if (node.kind == ast.NODE_STMT_EXPR) {
        val lhs: *ast.Node = node.info.wrapper.inner;
        var rhs: *ast.Node = nil;
        
        if (lhs != nil && rhs != nil) {
            val lhs_type: *ty.Type = resolve_expr_type(sema, lhs);
            val rhs_type: *ty.Type = resolve_expr_type(sema, rhs);
            
            if (lhs_type != nil && rhs_type != nil) {
                if (!ty.types_equal(lhs_type, rhs_type)) {
                    # check if types are compatible
                    if (!ty.can_assign(rhs_type, lhs_type)) {
                        report_error_node(sema, node, "type mismatch in assignment");
                    }
                }
            }
        }
        ret;
    }

    # comptime if ($if) - statement context
    if (node.kind == ast.NODE_COMPTIME_IF) {
        process_comptime_if(sema, node, false);
        ret;
    }
}

# analyze_comptime_stmt: handle $attribute assignments and $error.
fun analyze_comptime_stmt(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val inner: *ast.Node = node.info.wrapper.inner;
    if (inner == nil) {
        ret;
    }

    # handle assignment: $symbol.attr = "value"
    if (inner.kind == ast.NODE_EXPR_BINARY) {
        val op: u8 = inner.info.binary_expr.op;
        if (op == token.TAG_EQ) {
            val lhs: *ast.Node = inner.info.binary_expr.left;
            val rhs: *ast.Node = inner.info.binary_expr.right;

            if (rhs == nil || rhs.kind != ast.NODE_EXPR_LIT_STR) {
                report_error_node(sema, inner, "expected string literal for attribute value");
                ret;
            }

            if (lhs == nil || lhs.kind != ast.NODE_EXPR_FIELD) {
                report_error_node(sema, inner, "expected attribute access (e.g. $foo.name)");
                ret;
            }

            val obj: *ast.Node = lhs.info.field_expr.object;
            if (obj == nil || obj.kind != ast.NODE_EXPR_IDENT) {
                report_error_node(sema, inner, "expected symbol identifier");
                ret;
            }

            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(obj.info.ident_expr.name);
            if (sym_opt.is_none()) {
                report_error_node(sema, inner, "undefined symbol");
                ret;
            }

            val field_name: str = lhs.info.field_expr.field;
            if (field_name == nil) {
                report_error_node(sema, inner, "attribute has no name");
                ret;
            }

            # strip quotes from string literal
            val raw: str = rhs.info.lit_expr.text;
            var value: str = raw;
            if (raw != nil && raw.len() >= 2 && raw[0] == '"' && raw[raw.len() - 1] == '"') {
                val inner_len: usize = raw.len() - 2;
                val res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](inner_len + 1);
                if (res.is_err()) {
                    report_error_node(sema, inner, "out of memory");
                    ret;
                }
                val buf: *u8 = res.unwrap_ok();
                var i: usize = 0;
                for (i < inner_len) {
                    buf[i] = raw[i + 1];
                    i = i + 1;
                }
                buf[inner_len] = 0;
                value = buf::&u8;
            }

            val sym: *symbol.Symbol = sym_opt.unwrap();
            if (field_name.equals("name") || field_name.equals("symbol")) {
                sym.export_name = value;
            } or {
                report_error_node(sema, inner, "unknown compiletime attribute");
            }

            ret;
        }
    }

    # handle $error("message")
    if (inner.kind == ast.NODE_EXPR_CALL) {
        val func: *ast.Node = inner.info.call_expr.callee;
        if (func != nil && func.kind == ast.NODE_EXPR_IDENT) {
            val name: str = func.info.ident_expr.name;
            if (name != nil && name.equals("error")) {
                val args: *ast.List = inner.info.call_expr.args;
                if (args == nil || args.count != 1) {
                    report_error_node(sema, inner, "expected 1 argument for $error");
                    ret;
                }
                val arg: *ast.Node = args.nodes[0];
                if (arg == nil || arg.kind != ast.NODE_EXPR_LIT_STR) {
                    report_error_node(sema, inner, "expected string literal for error message");
                    ret;
                }
                val raw_msg: str = arg.info.lit_expr.text;
                var msg: str = raw_msg;
                if (raw_msg != nil && raw_msg.len() >= 2 && raw_msg[0] == '"' && raw_msg[raw_msg.len() - 1] == '"') {
                    val inner_len2: usize = raw_msg.len() - 2;
                    val res2: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](inner_len2 + 1);
                    if (res2.is_err()) {
                        report_error_node(sema, inner, "out of memory");
                        ret;
                    }
                    val buf2: *u8 = res2.unwrap_ok();
                    var j: usize = 0;
                    for (j < inner_len2) {
                        buf2[j] = raw_msg[j + 1];
                        j = j + 1;
                    }
                    buf2[inner_len2] = 0;
                    msg = buf2::&u8;
                }

                report_error_node(sema, inner, msg);
                ret;
            }
        }
    }

    # validate other comptime expressions
    resolve_expr_type(sema, inner);
}

# --- module resolution helpers ---

# build_file_from_root: build file path from base directory and module path rest.
# ---
# sema:     analyzer context (for allocator)
# base_dir: base directory path
# rest:     module path after prefix (e.g., "cli.main" -> "cli/main.mach")
# ret:      file path or nil on error
fun build_file_from_root(sema: *Sema, base_dir: str, rest: str) str {
    if (sema == nil || base_dir == nil) {
        ret nil;
    }

    # handle empty rest (just the module prefix itself)
    if (rest == nil || rest.len() == 0) {
        # just base_dir + ".mach" - but this is usually not valid
        ret nil;
    }

    val base_len: usize = base_dir.len();
    val rest_len: usize = rest.len();
    # base + '/' + rest (with dots as slashes) + ".mach" + '\0'
    val total_len: usize = base_len + 1 + rest_len + 5 + 1;

    val buf_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total_len);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy base_dir
    var i: usize = 0;
    for (i < base_len) {
        buf[pos] = base_dir[i];
        pos = pos + 1;
        i = i + 1;
    }

    # add separator
    buf[pos] = 47; # '/'
    pos = pos + 1;

    # copy rest, replacing dots with slashes
    i = 0;
    for (i < rest_len) {
        val c: u8 = rest[i];
        if (c == 46) { # '.'
            buf[pos] = 47; # '/'
        } or {
            buf[pos] = c;
        }
        pos = pos + 1;
        i = i + 1;
    }

    # append ".mach"
    buf[pos] = 46; pos = pos + 1;     # '.'
    buf[pos] = 109; pos = pos + 1;    # 'm'
    buf[pos] = 97; pos = pos + 1;     # 'a'
    buf[pos] = 99; pos = pos + 1;     # 'c'
    buf[pos] = 104; pos = pos + 1;    # 'h'
    buf[pos] = 0;                      # null terminator

    ret buf::&u8;
}

# load_dep_project_id: load a dependency's project id from its mach.toml.
# ---
# sema:     analyzer context
# dep_name: dependency directory name
# ret:      project id or nil if not found
fun load_dep_project_id(sema: *Sema, dep_name: str) str {
    if (sema == nil || sema.dep_root == nil || dep_name == nil) {
        ret nil;
    }

    # build path: dep_root/dep_name/mach.toml
    val dep_root_len: usize = sema.dep_root.len();
    val dep_name_len: usize = dep_name.len();
    val toml_len: usize = 10; # "/mach.toml"
    val total: usize = dep_root_len + 1 + dep_name_len + toml_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy dep_root
    var i: usize = 0;
    for (i < dep_root_len) {
        buf[pos] = sema.dep_root[i];
        pos = pos + 1;
        i = i + 1;
    }

    buf[pos] = 47; pos = pos + 1; # '/'

    # copy dep_name
    i = 0;
    for (i < dep_name_len) {
        buf[pos] = dep_name[i];
        pos = pos + 1;
        i = i + 1;
    }

    # copy "/mach.toml"
    buf[pos] = 47; pos = pos + 1;   # '/'
    buf[pos] = 109; pos = pos + 1;  # 'm'
    buf[pos] = 97; pos = pos + 1;   # 'a'
    buf[pos] = 99; pos = pos + 1;   # 'c'
    buf[pos] = 104; pos = pos + 1;  # 'h'
    buf[pos] = 46; pos = pos + 1;   # '.'
    buf[pos] = 116; pos = pos + 1;  # 't'
    buf[pos] = 111; pos = pos + 1;  # 'o'
    buf[pos] = 109; pos = pos + 1;  # 'm'
    buf[pos] = 108; pos = pos + 1;  # 'l'
    buf[pos] = 0;

    val config_path: str = buf::&u8;

    # load the config
    val cfg_res: Result[config.Config, str] = config.load(config_path, sema.alloc);
    if (cfg_res.is_err()) {
        ret nil;
    }

    val cfg: config.Config = cfg_res.unwrap_ok();
    ret cfg.id;
}

# resolve_module_path: resolve a module path to a file path.
# ---
# sema:        analyzer context
# module_path: module path (e.g., "std.filesystem")
# ret:         file path or nil if not found
fun resolve_module_path(sema: *Sema, module_path: str) str {
    if (sema == nil || module_path == nil) {
        ret nil;
    }

    val mod_len: usize = module_path.len();
    if (mod_len == 0) {
        ret nil;
    }

    # 1) check project_id -> src_root mapping
    if (sema.project_id != nil && sema.src_root != nil) {
        val id_len: usize = sema.project_id.len();
        if (module_path.starts_with(sema.project_id)) {
            # check if it's followed by '.' or end of string
            if (mod_len == id_len || (mod_len > id_len && module_path[id_len] == 46)) {
                # get the rest after the prefix
                var rest: str = nil;
                if (mod_len > id_len) {
                    rest = (module_path::usize + id_len + 1)::str;  # skip prefix and dot
                }
                ret build_file_from_root(sema, sema.src_root, rest);
            }
        }
    }

    # 2) check dependencies
    if (sema.deps != nil && sema.dep_count > 0 && sema.dep_root != nil) {
        var i: i32 = 0;
        for (i < sema.dep_count) {
            # deps is *Dep (array), so sema.deps[i] gives us Dep
            val dep_name: str = sema.deps[i].name;
            if (dep_name == nil) {
                i = i + 1;
                cnt;
            }

            # load the dependency's project id from its mach.toml
            val dep_project_id: str = load_dep_project_id(sema, dep_name);
            if (dep_project_id == nil) {
                i = i + 1;
                cnt;
            }

            val dep_id_len: usize = dep_project_id.len();
            if (module_path.starts_with(dep_project_id)) {
                if (mod_len == dep_id_len || (mod_len > dep_id_len && module_path[dep_id_len] == 46)) {
                    # get the rest after the prefix
                    var rest: str = nil;
                    if (mod_len > dep_id_len) {
                        rest = (module_path::usize + dep_id_len + 1)::str;
                    }

                    # build base dir: dep_root/dep_name/src (default to "src")
                    val dep_root_len: usize = sema.dep_root.len();
                    val dep_name_len: usize = dep_name.len();
                    val src_dir: str = "src";
                    val src_len: usize = 3;
                    val base_total: usize = dep_root_len + 1 + dep_name_len + 1 + src_len + 1;

                    val base_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](base_total);
                    if (base_res.is_err()) {
                        i = i + 1;
                        cnt;
                    }

                    val base_buf: *u8 = base_res.unwrap_ok();
                    var pos: usize = 0;

                    # copy dep_root
                    var j: usize = 0;
                    for (j < dep_root_len) {
                        base_buf[pos] = sema.dep_root[j];
                        pos = pos + 1;
                        j = j + 1;
                    }

                    base_buf[pos] = 47; pos = pos + 1; # '/'

                    # copy dep_name
                    j = 0;
                    for (j < dep_name_len) {
                        base_buf[pos] = dep_name[j];
                        pos = pos + 1;
                        j = j + 1;
                    }

                    base_buf[pos] = 47; pos = pos + 1; # '/'

                    # copy "src"
                    base_buf[pos] = 115; pos = pos + 1; # 's'
                    base_buf[pos] = 114; pos = pos + 1; # 'r'
                    base_buf[pos] = 99; pos = pos + 1;  # 'c'
                    base_buf[pos] = 0;

                    val base_dir: str = base_buf::&u8;
                    ret build_file_from_root(sema, base_dir, rest);
                }
            }

            i = i + 1;
        }
    }

    ret nil;
}

# has_module_resolution: check if module resolution is configured.
# ---
# sema: analyzer context
# ret:  true if module roots are configured
fun has_module_resolution(sema: *Sema) bool {
    if (sema == nil) {
        ret false;
    }
    # have project mapping
    if (sema.project_id != nil && sema.src_root != nil) {
        ret true;
    }
    # have dependencies
    if (sema.deps != nil && sema.dep_count > 0 && sema.dep_root != nil) {
        ret true;
    }
    ret false;
}

# set_module_roots: set project context for module import resolution.
# ---
# sema:       analyzer context
# project_id: project identifier for module path prefix
# src_root:   source root directory path
# dep_root:   dependency root directory path
# deps:       array of dependency configurations
# dep_count:  number of dependencies
# ret:        none
pub fun set_module_roots(sema: *Sema, project_id: str, src_root: str, dep_root: str, deps: *config.Dep, dep_count: i32) {
    if (sema == nil) {
        ret;
    }
    sema.project_id = project_id;
    sema.src_root = src_root;
    sema.dep_root = dep_root;
    sema.deps = deps;
    sema.dep_count = dep_count;
}

# load_module: load a module by path.
# ---
# sema: analyzer context
# path: module path (e.g., "mach.cli.main")
# ret:  loaded module or nil
pub fun load_module(sema: *Sema, mod_path: str) *SemaModule {
    if (sema == nil || mod_path == nil) {
        ret nil;
    }

    # check if already loaded
    var existing: *SemaModule = sema.modules;
    for (existing != nil) {
        if (existing.path != nil && existing.path.equals(mod_path)) {
            ret existing;
        }
        existing = existing.next;
    }

    # resolve module path to file path
    val file_path: str = resolve_module_path(sema, mod_path);
    if (file_path == nil) {
        ret nil;
    }

    # read the source file
    val source_res: Result[str, str] = utilfs.read_file(file_path, sema.alloc);
    if (source_res.is_err()) {
        ret nil;
    }

    val source: str = source_res.unwrap_ok();

    # parse the source
    var p: parser.Parser = parser.init(source, sema.alloc);

    val parse_res: Result[*ast.Node, str] = p.parse_program();
    if (parse_res.is_err()) {
        p.deinit();
        ret nil;
    }

    val mod_ast: *ast.Node = parse_res.unwrap_ok();

    if (p.had_error || mod_ast == nil) {
        p.deinit();
        ret nil;
    }

    # create the module record
    val mod_res: Result[*SemaModule, allocator.AllocError] = sema.alloc.alloc[SemaModule](1);
    if (mod_res.is_err()) {
        p.deinit();
        ret nil;
    }

    val mod: *SemaModule = mod_res.unwrap_ok();
    mod.path = mod_path;
    mod.file_path = file_path;
    mod.source = source;
    mod.ast = mod_ast;
    mod.is_analyzed = false;
    mod.aliases = nil;
    mod.imports = nil;
    mod.table = nil;

    # add to module list (prepend)
    mod.next = sema.modules;
    sema.modules = mod;
    sema.module_count = sema.module_count + 1;

    # save current context
    val saved_module: *SemaModule = sema.current_module;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;
    val saved_symbols: *symbol.Table = sema.symbols;
    val saved_module_path: str = sema.module_path;

    # create a new symbol table for this module
    val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
    if (table_res.is_err()) {
        p.deinit();
        ret nil;
    }

    # allocate space for the table and copy
    val table_ptr_res: Result[*symbol.Table, allocator.AllocError] = sema.alloc.alloc[symbol.Table](1);
    if (table_ptr_res.is_err()) {
        p.deinit();
        ret nil;
    }
    val table_ptr: *symbol.Table = table_ptr_res.unwrap_ok();
    @table_ptr = table_res.unwrap_ok();

    # store table on module for cross-module lookups
    mod.table = table_ptr;

    # set module context
    sema.current_module = mod;
    sema.file_path = file_path;
    sema.source = source;
    sema.symbols = table_ptr;
    sema.module_path = mod_path;

    # analyze the module: pass 1 - collect declarations
    collect_declarations(sema, mod_ast);

    # analyze the module: pass 2 - resolve types
    resolve_types(sema, mod_ast);

    # process top-level comptime statements (e.g., $X.symbol = "Y")
    # these aren't processed in passes 1-2 but are needed for export_name
    val ct_decls: *ast.List = mod_ast.info.block_stmt.stmts;
    if (ct_decls != nil) {
        var ct_i: i32 = 0;
        for (ct_i < ct_decls.count) {
            val ct_node: *ast.Node = ct_decls.nodes[ct_i];
            if (ct_node != nil && ct_node.kind == ast.NODE_COMPTIME) {
                analyze_comptime_stmt(sema, ct_node);
            }
            ct_i = ct_i + 1;
        }
    }

    # pass 3: analyze function bodies in imported module
    # save and restore error state since imported modules may have benign issues
    val saved_error_count: i32 = sema.error_count;
    val saved_had_error: bool = sema.had_error;
    analyze_functions(sema, mod_ast);
    sema.error_count = saved_error_count;
    sema.had_error = saved_had_error;

    # mark as analyzed
    mod.is_analyzed = true;

    # restore context
    sema.current_module = saved_module;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
    sema.symbols = saved_symbols;
    sema.module_path = saved_module_path;

    p.deinit();
    ret mod;
}

# lookup_module_alias: lookup an aliased import.
# ---
# sema:  analyzer context
# alias: alias name
# ret:   module or nil
pub fun lookup_module_alias(sema: *Sema, alias: str) *SemaModule {
    if (sema == nil || alias == nil) {
        ret nil;
    }

    var mod: *SemaModule = sema.modules;
    for (mod != nil) {
        var ma: *ModuleAlias = mod.aliases;
        for (ma != nil) {
            if (ma.alias != nil && ma.alias.equals(alias)) {
                ret ma.module;
            }
            ma = ma.next;
        }
        mod = mod.next;
    }

    ret nil;
}

# deinit: cleanup sema resources.
# ---
# sema: analyzer context
# ret:  none
pub fun deinit(sema: *Sema) {
    if (sema == nil) {
        ret;
    }

    # cleanup scopes
    for (sema.current_scope != nil) {
        pop_scope(sema);
    }

    # note: full cleanup would free all allocated resources
    # but we use arena allocation, so it's not strictly necessary
}
