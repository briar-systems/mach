use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;

# mach.compiler.sema: semantic analysis.
# ---
# performs type checking, symbol resolution, and semantic validation on the AST.

# SemaError: a semantic analysis error.
# ---
# node:    AST node where error occurred
# message: error description
pub rec SemaError {
    node:    *ast.Node;
    message: str;
}

# Sema: semantic analyzer context.
# ---
# alloc:        allocator for analysis
# symbols:      symbol table
# types:        type context
# module_path:  current module path
# errors:       list of errors
# error_count:  number of errors
# error_cap:    allocated capacity
pub rec Sema {
    alloc:       *allocator.Allocator;
    symbols:     symbol.Table;
    types:       ty.TypeContext;
    module_path: str;
    file_path:   str;
    source:      str;
    errors:      *SemaError;
    error_count: i32;
    error_cap:   i32;
}

# init: create a new semantic analyzer.
# ---
# alloc:       allocator to use
# module_path: module path for the entry file
# ret:         Ok(Sema) on success, Err(str) on failure
pub fun init(alloc: *allocator.Allocator, module_path: str) Result[Sema, str] {
    if (alloc == nil) {
        ret err[Sema, str]("allocator is nil");
    }

    val sym_res: Result[symbol.Table, str] = symbol.init(alloc);
    if (sym_res.is_err()) {
        ret err[Sema, str](sym_res.unwrap_err());
    }

    val type_res: Result[ty.TypeContext, str] = ty.init_context(alloc);
    if (type_res.is_err()) {
        ret err[Sema, str](type_res.unwrap_err());
    }

    var sema: Sema;
    sema.alloc = alloc;
    sema.symbols = sym_res.unwrap_ok();
    sema.types = type_res.unwrap_ok();
    sema.module_path = module_path;
    sema.file_path = nil;
    sema.source = nil;
    sema.errors = nil;
    sema.error_count = 0;
    sema.error_cap = 0;

    ret ok[Sema, str](sema);
}

# deinit: free all resources associated with the analyzer.
# ---
# sema: analyzer to clean up
# ret:  none
pub fun deinit(sema: *Sema) {
    if (sema == nil) {
        ret;
    }

    symbol.deinit(?sema.symbols);
    ty.deinit_context(?sema.types);

    if (sema.errors != nil && sema.alloc != nil) {
        sema.alloc.free[SemaError](sema.errors, sema.error_cap::usize);
    }
}

# set_file_context: set the current file context for error reporting.
# ---
# sema:      analyzer
# file_path: path to the file being analyzed
# source:    source text of the file
# ret:       none
pub fun set_file_context(sema: *Sema, file_path: str, source: str) {
    if (sema == nil) {
        ret;
    }

    sema.file_path = file_path;
    sema.source = source;
}

# analyze: perform semantic analysis on an AST.
# ---
# sema: analyzer context
# ast:  AST to analyze (program node)
# ret:  Ok(true) on success (may have errors), Err(str) on fatal error
pub fun analyze(sema: *Sema, root: *ast.Node) Result[bool, str] {
    if (sema == nil) {
        ret err[bool, str]("sema is nil");
    }

    if (root == nil) {
        ret err[bool, str]("AST is nil");
    }

    # TODO: implement semantic analysis passes
    # pass 1: collect top-level declarations (types, functions)
    # pass 2: resolve type references
    # pass 3: type-check expressions and statements
    # pass 4: check for unresolved symbols
    # pass 5: validate control flow (returns, breaks)

    ret ok[bool, str](true);
}

# report_error: record a semantic error.
# ---
# sema:    analyzer
# node:    node where error occurred
# message: error description
# ret:     none
pub fun report_error(sema: *Sema, node: *ast.Node, message: str) {
    if (sema == nil) {
        ret;
    }

    sema.error_count = sema.error_count + 1;

    # TODO: grow and append to errors array
}

# get_error_count: get the number of semantic errors.
# ---
# sema: analyzer
# ret:  error count
pub fun get_error_count(sema: *Sema) i32 {
    if (sema == nil) {
        ret 0;
    }
    ret sema.error_count;
}

# has_errors: check if any errors occurred.
# ---
# sema: analyzer
# ret:  true if errors occurred
pub fun has_errors(sema: *Sema) bool {
    ret get_error_count(sema) > 0;
}

# get_symbol_table: get the symbol table.
# ---
# sema: analyzer
# ret:  pointer to symbol table
pub fun get_symbol_table(sema: *Sema) *symbol.Table {
    if (sema == nil) {
        ret nil;
    }
    ret ?sema.symbols;
}

# get_type_context: get the type context.
# ---
# sema: analyzer
# ret:  pointer to type context
pub fun get_type_context(sema: *Sema) *ty.TypeContext {
    if (sema == nil) {
        ret nil;
    }
    ret ?sema.types;
}

# resolve_type: resolve an AST type node to a Type.
# ---
# sema:      analyzer
# type_node: AST node representing a type
# ret:       Ok(*Type) on success, Err(str) on failure
pub fun resolve_type(sema: *Sema, type_node: *ast.Node) Result[*ty.Type, str] {
    if (sema == nil) {
        ret err[*ty.Type, str]("sema is nil");
    }

    if (type_node == nil) {
        ret err[*ty.Type, str]("type node is nil");
    }

    # TODO: implement type resolution based on node kind
    # - type_name: look up in symbol table
    # - type_ptr/type_ref: resolve inner and wrap
    # - type_array: resolve inner and create array type
    # - type_fun: resolve params and return type
    # - type_rec/type_uni: create anonymous record/union type

    ret err[*ty.Type, str]("resolve_type not yet implemented");
}

# check_expr: type-check an expression.
# ---
# sema: analyzer
# expr: expression AST node
# ret:  Ok(*Type) with expression type, Err(str) on failure
pub fun check_expr(sema: *Sema, expr: *ast.Node) Result[*ty.Type, str] {
    if (sema == nil) {
        ret err[*ty.Type, str]("sema is nil");
    }

    if (expr == nil) {
        ret err[*ty.Type, str]("expression is nil");
    }

    # TODO: implement expression type checking based on node kind
    # - literals: return appropriate primitive type
    # - identifiers: look up in symbol table
    # - binary ops: check operand types, determine result type
    # - unary ops: check operand type, determine result type
    # - calls: resolve function, check argument types
    # - field access: check base type has field
    # - index: check base is array/pointer, return element type
    # - cast: validate cast is allowed
    # - address-of: return pointer to operand type
    # - deref: check operand is pointer, return inner type

    ret err[*ty.Type, str]("check_expr not yet implemented");
}

# check_stmt: type-check a statement.
# ---
# sema: analyzer
# stmt: statement AST node
# ret:  Ok(true) on success, Err(str) on failure
pub fun check_stmt(sema: *Sema, stmt: *ast.Node) Result[bool, str] {
    if (sema == nil) {
        ret err[bool, str]("sema is nil");
    }

    if (stmt == nil) {
        ret err[bool, str]("statement is nil");
    }

    # TODO: implement statement checking based on node kind
    # - val/var: check initializer type matches declared type
    # - if: check condition is bool, check branches
    # - for: check condition is bool, check body
    # - ret: check return value matches function return type
    # - block: check each statement in block
    # - expr: check expression

    ret err[bool, str]("check_stmt not yet implemented");
}

# print_errors: print all errors to stderr.
# ---
# sema: analyzer
# ret:  none
pub fun print_errors(sema: *Sema) {
    if (sema == nil) {
