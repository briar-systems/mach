use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use token:  mach.compiler.token;

# mach.compiler.sema: semantic analysis.
# ---
# performs type checking, symbol resolution, and semantic validation on the AST.

# SemaError: a semantic analysis error.
# ---
# pos:     position in source where error occurred
# message: error description
pub rec SemaError {
    pos:     i32;
    line:    i32;
    col:     i32;
    message: str;
}

# counter for generating unique anonymous type names
var anon_type_counter: i32 = 0;

# Sema: semantic analyzer context.
# ---
# alloc:          allocator for analysis
# symbols:        symbol table
# types:          type context
# module_path:    current module path
# file_path:      path to current file
# source:         source text for error reporting
# errors:         list of errors
# error_count:    number of errors
# error_cap:      allocated capacity
# current_fn:     current function being analyzed (for return type checking)
# loop_depth:     nesting depth of loops (for break/continue checking)
pub rec Sema {
    alloc:          *allocator.Allocator;
    symbols:        symbol.Table;
    types:          ty.TypeContext;
    module_path:    str;
    file_path:      str;
    source:         str;
    errors:         *SemaError;
    error_count:    i32;
    error_cap:      i32;
    current_fn:     *symbol.Symbol;
    current_fn_ret: *ty.Type;
    loop_depth:     i32;
}

# init: create a new semantic analyzer.
# ---
# alloc:       allocator to use
# module_path: module path for the entry file
# ret:         Ok(Sema) on success, Err(str) on failure
pub fun init(alloc: *allocator.Allocator, module_path: str) Result[Sema, str] {
    if (alloc == nil) {
        ret err[Sema, str]("allocator is nil");
    }

    val sym_res: Result[symbol.Table, str] = symbol.init(alloc);
    if (sym_res.is_err()) {
        ret err[Sema, str](sym_res.unwrap_err());
    }

    val type_res: Result[ty.TypeContext, str] = ty.init_context(alloc);
    if (type_res.is_err()) {
        ret err[Sema, str](type_res.unwrap_err());
    }

    var sema: Sema;
    sema.alloc = alloc;
    sema.symbols = sym_res.unwrap_ok();
    sema.types = type_res.unwrap_ok();
    sema.module_path = module_path;
    sema.file_path = nil;
    sema.source = nil;
    sema.errors = nil;
    sema.error_count = 0;
    sema.error_cap = 0;
    sema.current_fn = nil;
    sema.current_fn_ret = nil;
    sema.loop_depth = 0;

    ret ok[Sema, str](sema);
}

# deinit: free all resources associated with the analyzer.
# ---
# sema: analyzer to clean up
pub fun deinit(sema: *Sema) {
    if (sema == nil) {
        ret;
    }

    symbol.deinit(?sema.symbols);
    ty.deinit_context(?sema.types);

    if (sema.errors != nil && sema.alloc != nil) {
        sema.alloc.free[SemaError](sema.errors, sema.error_cap::usize);
    }
}

# set_file_context: set the current file context for error reporting.
# ---
# sema:      analyzer
# file_path: path to the file being analyzed
# source:    source text of the file
pub fun set_file_context(sema: *Sema, file_path: str, source: str) {
    if (sema == nil) {
        ret;
    }

    sema.file_path = file_path;
    sema.source = source;
}

# --- error reporting ---

# report_error: record a semantic error at a token position.
fun report_error(sema: *Sema, tok: token.Token, message: str) {
    if (sema == nil) {
        ret;
    }

    # grow errors array if needed
    if (sema.error_count >= sema.error_cap) {
        var new_cap: i32 = 8;
        if (sema.error_cap > 0) {
            new_cap = sema.error_cap * 2;
        }

        val r: Result[*SemaError, allocator.AllocError] = sema.alloc.resize[SemaError](
            sema.errors,
            sema.error_cap::usize,
            new_cap::usize
        );

        if (r.is_err()) {
            ret;
        }

        sema.errors = r.unwrap_ok();
        sema.error_cap = new_cap;
    }

    val idx: i32 = sema.error_count;
    sema.errors[idx].pos = tok.pos;
    sema.errors[idx].line = tok.line;
    sema.errors[idx].col = tok.col;
    sema.errors[idx].message = message;
    sema.error_count = sema.error_count + 1;
}

# report_error_node: record a semantic error at a node's token.
fun report_error_node(sema: *Sema, node: *ast.Node, message: str) {
    if (node == nil) {
        ret;
    }
    report_error(sema, node.tok, message);
}

# get_error_count: get the number of semantic errors.
pub fun get_error_count(sema: *Sema) i32 {
    if (sema == nil) {
        ret 0;
    }
    ret sema.error_count;
}

# has_errors: check if any errors occurred.
pub fun has_errors(sema: *Sema) bool {
    ret get_error_count(sema) > 0;
}

# get_symbol_table: get the symbol table.
pub fun get_symbol_table(sema: *Sema) *symbol.Table {
    if (sema == nil) {
        ret nil;
    }
    ret ?sema.symbols;
}

# get_type_context: get the type context.
pub fun get_type_context(sema: *Sema) *ty.TypeContext {
    if (sema == nil) {
        ret nil;
    }
    ret ?sema.types;
}

# get_receiver_type_name: extract the base type name from a receiver type node.
# ---
# handles pointers/refs like *Pair[T, U] -> "Pair"
# handles generic instantiations like Pair[T, U] -> "Pair"
fun get_receiver_type_name(type_node: *ast.Node) str {
    if (type_node == nil) {
        ret nil;
    }

    var node: *ast.Node = type_node;

    # unwrap pointers and refs
    for (node != nil && (node.kind == ast.NODE_TYPE_PTR || node.kind == ast.NODE_TYPE_REF)) {
        node = node.children;
    }

    if (node == nil) {
        ret nil;
    }

    # for type names, extract the name
    if (node.kind == ast.NODE_TYPE_NAME) {
        val name: str = node.data::str;
        if (name != nil) {
            # strip any module path - get just the type name
            # for now just return the full path, module resolution will handle it
            ret name;
        }
    }

    ret nil;
}


# --- type resolution ---

# resolve_type: resolve an AST type node to a Type.
# ---
# sema:      analyzer
# type_node: AST node representing a type
# ret:       resolved Type or nil on failure
pub fun resolve_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    if (sema == nil || type_node == nil) {
        ret nil;
    }

    val ctx: *ty.TypeContext = ?sema.types;
    val kind: ast.NodeKind = type_node.kind;

    # type_name: primitive or user-defined type
    if (kind == ast.NODE_TYPE_NAME) {
        ret resolve_type_name(sema, type_node);
    }

    # type_ptr: *T (mutable pointer)
    if (kind == ast.NODE_TYPE_PTR) {
        val inner: *ty.Type = resolve_type(sema, type_node.children);
        if (inner == nil) {
            ret nil;
        }
        val res: Result[*ty.Type, str] = ty.pointer_type(ctx, inner, true);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to create pointer type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # type_ref: &T (immutable pointer)
    if (kind == ast.NODE_TYPE_REF) {
        val inner: *ty.Type = resolve_type(sema, type_node.children);
        if (inner == nil) {
            ret nil;
        }
        val res: Result[*ty.Type, str] = ty.pointer_type(ctx, inner, false);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to create ref type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # type_array: [N]T
    if (kind == ast.NODE_TYPE_ARRAY) {
        val elem_type: *ty.Type = resolve_type(sema, type_node.children);
        if (elem_type == nil) {
            ret nil;
        }
        # array length stored in data as integer
        val len: usize = type_node.data::usize;
        val res: Result[*ty.Type, str] = ty.array_type(ctx, elem_type, len);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to create array type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # type_fun: fun(...) T
    if (kind == ast.NODE_TYPE_FUN) {
        ret resolve_function_type(sema, type_node);
    }

    # type_rec: anonymous record type
    if (kind == ast.NODE_TYPE_REC) {
        ret resolve_anon_record_type(sema, type_node);
    }

    # type_uni: anonymous union type
    if (kind == ast.NODE_TYPE_UNI) {
        ret resolve_anon_union_type(sema, type_node);
    }

    report_error_node(sema, type_node, "unsupported type syntax");
    ret nil;
}

# resolve_anon_record_type: resolve an anonymous record type expression.
fun resolve_anon_record_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # fields are stored in children as *List (cast from *Node)
    val fields_list: *ast.List = type_node.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        # empty anonymous record
        val res: Result[*ty.Type, str] = ty.record_type(ctx, nil, nil, 0);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    val field_count: i32 = fields_list.count;

    # allocate Field array
    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, type_node, "failed to allocate fields");
        ret nil;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    # resolve each field
    var offset: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        val field_name: str = ast.get_name(field_node);
        val ft_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (ft_node != nil) {
            field_type = resolve_type(sema, ft_node);
        }

        if (field_type == nil) {
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        var field_align: usize = 1;
        var field_size: usize = 0;
        if (field_type != nil) {
            field_align = field_type.align;
            field_size = field_type.size;
            if (field_align > max_align) {
                max_align = field_align;
            }
        }

        if (field_align > 0) {
            offset = (offset + field_align - 1) & ~(field_align - 1);
        }

        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = offset;

        offset = offset + field_size;
        i = i + 1;
    }

    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    val res: Result[*ty.Type, str] = ty.record_type(ctx, nil, fields, field_count);
    if (res.is_err()) {
        report_error_node(sema, type_node, "failed to create anonymous record type");
        ret nil;
    }

    val rec_type: *ty.Type = res.unwrap_ok();
    rec_type.size = offset;
    rec_type.align = max_align;

    ret rec_type;
}

# resolve_anon_union_type: resolve an anonymous union type expression.
fun resolve_anon_union_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # variants are stored in children as *List
    val fields_list: *ast.List = type_node.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        val res: Result[*ty.Type, str] = ty.union_type(ctx, nil, nil, 0);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    val field_count: i32 = fields_list.count;

    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, type_node, "failed to allocate variants");
        ret nil;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    var max_size: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        val field_name: str = ast.get_name(field_node);
        val ft_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (ft_node != nil) {
            field_type = resolve_type(sema, ft_node);
        }

        if (field_type == nil) {
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        if (field_type != nil) {
            if (field_type.size > max_size) {
                max_size = field_type.size;
            }
            if (field_type.align > max_align) {
                max_align = field_type.align;
            }
        }

        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = 0;

        i = i + 1;
    }

    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    val total_size: usize = max_size + 8;
    if (max_align < 8) {
        max_align = 8;
    }

    val res: Result[*ty.Type, str] = ty.union_type(ctx, nil, fields, field_count);
    if (res.is_err()) {
        report_error_node(sema, type_node, "failed to create anonymous union type");
        ret nil;
    }

    val uni_type: *ty.Type = res.unwrap_ok();
    uni_type.size = total_size;
    uni_type.align = max_align;

    ret uni_type;
}

# resolve_type_name: resolve a named type (primitive or user-defined).
fun resolve_type_name(sema: *Sema, type_node: *ast.Node) *ty.Type {
    val name: str = ast.get_name(type_node);
    if (name == nil) {
        report_error_node(sema, type_node, "type name is nil");
        ret nil;
    }

    val ctx: *ty.TypeContext = ?sema.types;

    # check if this is a generic instantiation (has children that are type args)
    # generic args are stored as a NODE_GENERIC node in children
    var has_generic_args: bool = false;
    if (type_node.count > 0 && type_node.children != nil) {
        val first_child: *ast.Node = type_node.children;
        if (first_child != nil && first_child.kind == ast.NODE_GENERIC) {
            has_generic_args = true;
        }
    }

    # check for primitive type (primitives can't have generic args)
    val prim_opt: Option[ty.TypeKind] = ty.primitive_kind_from_name(name);
    if (prim_opt.is_some()) {
        if (has_generic_args) {
            report_error_node(sema, type_node, "primitive types cannot have generic arguments");
            ret nil;
        }
        val prim_kind: ty.TypeKind = prim_opt.unwrap();
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, prim_kind);
        if (res.is_err()) {
            report_error_node(sema, type_node, "failed to get primitive type");
            ret nil;
        }
        ret res.unwrap_ok();
    }

    # look up user-defined type in symbol table
    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        report_error_node(sema, type_node, "undefined type");
        ret nil;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    if (!symbol.is_type_symbol(sym)) {
        report_error_node(sema, type_node, "not a type");
        ret nil;
    }

    # cycle detection: check if type is currently being resolved
    if (sym.is_being_resolved) {
        report_error_node(sema, type_node, "circular type dependency detected");
        ret nil;
    }

    if (sym.resolved_type == nil) {
        report_error_node(sema, type_node, "type not yet resolved");
        ret nil;
    }

    # if this is a generic instantiation, create an instantiated type
    if (has_generic_args) {
        ret resolve_generic_instantiation(sema, type_node, sym);
    }

    ret sym.resolved_type;
}

# resolve_generic_instantiation: resolve a generic type with type arguments.
# ---
# sema:      analyzer
# type_node: AST node with generic args in children
# generic_sym: the symbol for the generic type being instantiated
# ret:       instantiated type or nil on error
fun resolve_generic_instantiation(sema: *Sema, type_node: *ast.Node, generic_sym: *symbol.Symbol) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val base_type: *ty.Type = generic_sym.resolved_type;

    if (base_type == nil) {
        report_error_node(sema, type_node, "generic type not yet resolved");
        ret nil;
    }

    # check that the symbol is actually generic
    if (!generic_sym.is_generic || generic_sym.generic_node == nil) {
        # not a generic type, just return the base type
        ret base_type;
    }

    # get the generic args node from the type_node
    val generic_args_node: *ast.Node = type_node.children;
    if (generic_args_node == nil || generic_args_node.kind != ast.NODE_GENERIC) {
        report_error_node(sema, type_node, "invalid generic arguments");
        ret nil;
    }

    # generic args are stored in the generic node's children as *List
    val args_list: *ast.List = generic_args_node.children::*ast.List;
    if (args_list == nil || args_list.count == 0) {
        report_error_node(sema, type_node, "empty generic arguments");
        ret nil;
    }

    # get generic params from the symbol's generic_node
    val params_node: *ast.Node = generic_sym.generic_node;
    val params_list: *ast.List = params_node.children::*ast.List;
    if (params_list == nil) {
        report_error_node(sema, type_node, "invalid generic declaration");
        ret nil;
    }

    # check that arg count matches param count
    if (args_list.count != params_list.count) {
        report_error_node(sema, type_node, "wrong number of generic arguments");
        ret nil;
    }

    val arg_count: i32 = args_list.count;

    # resolve each type argument
    val resolved_args_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](arg_count::usize);
    if (resolved_args_res.is_err()) {
        report_error_node(sema, type_node, "allocation failed");
        ret nil;
    }
    val resolved_args: **ty.Type = resolved_args_res.unwrap_ok();

    var i: i32 = 0;
    for (i < arg_count) {
        val arg_node: *ast.Node = args_list.nodes[i];
        if (arg_node == nil) {
            report_error_node(sema, type_node, "nil type argument");
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }

        val arg_type: *ty.Type = resolve_type(sema, arg_node);
        if (arg_type == nil) {
            # error already reported
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }
        resolved_args[i] = arg_type;
        i = i + 1;
    }

    # generate mangled name for caching: <name>I<type_args>E
    # for now, use a simple concatenation since we don't have full string building
    # we'll look up by checking against existing instantiations

    # check cache for existing instantiation with same args
    val cached: *ty.Type = find_cached_instantiation(sema, base_type, resolved_args, arg_count);
    if (cached != nil) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret cached;
    }

    # create scope with generic param bindings for field type resolution
    val push_res: Result[bool, str] = symbol.push_scope(?sema.symbols);
    if (push_res.is_err()) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # bind each generic parameter to its concrete type
    i = 0;
    for (i < arg_count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node != nil) {
            val param_name: str = param_node.data::str;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = symbol.define(?sema.symbols, param_name, symbol.SYM_GENERIC);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # now resolve fields with the bound generic params
    var inst_type: *ty.Type = nil;

    if (base_type.kind == ty.TY_RECORD) {
        inst_type = instantiate_record_type(sema, generic_sym, resolved_args, arg_count);
    } or {
        if (base_type.kind == ty.TY_UNION) {
            inst_type = instantiate_union_type(sema, generic_sym, resolved_args, arg_count);
        } or {
            # for other types, just return base with args attached
            val create_res: Result[*ty.Type, str] = ty.create_type(ctx, base_type.kind);
            if (create_res.is_ok()) {
                inst_type = create_res.unwrap_ok();
                inst_type.name = base_type.name;
                ty.set_generic_args(ctx, inst_type, resolved_args, arg_count);
                ty.set_base_generic(inst_type, base_type);
            }
        }
    }

    # pop the generic param scope
    val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);

    if (inst_type == nil) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # attach generic args to instantiated type
    ty.set_generic_args(ctx, inst_type, resolved_args, arg_count);
    ty.set_base_generic(inst_type, base_type);

    ret inst_type;
}

# find_cached_instantiation: look for an existing instantiation with the same args.
fun find_cached_instantiation(sema: *Sema, base_type: *ty.Type, args: **ty.Type, arg_count: i32) *ty.Type {
    # iterate through all types in the context and find a matching instantiation
    val ctx: *ty.TypeContext = ?sema.types;

    var i: i32 = 0;
    for (i < ctx.type_count) {
        val t: *ty.Type = ctx.types[i];
        if (t != nil && t.base_generic == base_type && t.generic_arg_count == arg_count) {
            # check if all args match
            var match: bool = true;
            var j: i32 = 0;
            for (j < arg_count && match) {
                if (!ty.types_equal(t.generic_args[j], args[j])) {
                    match = false;
                }
                j = j + 1;
            }
            if (match) {
                ret t;
            }
        }
        i = i + 1;
    }

    ret nil;
}

# instantiate_record_type: create an instantiated record type with resolved fields.
fun instantiate_record_type(sema: *Sema, generic_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val decl: *ast.Node = generic_sym.decl_node;

    if (decl == nil || decl.kind != ast.NODE_DECL_REC) {
        ret nil;
    }

    # get fields from declaration
    val fields_list: *ast.List = decl.children::*ast.List;
    val field_count: i32 = 0;
    if (fields_list != nil) {
        field_count = fields_list.count;
    }

    # allocate fields array
    var fields: *ty.Field = nil;
    if (field_count > 0) {
        val alloc_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
        if (alloc_res.is_err()) {
            ret nil;
        }
        fields = alloc_res.unwrap_ok();

        # resolve each field type with generic params bound
        var offset: usize = 0;
        var max_align: usize = 1;
        var i: i32 = 0;
        for (i < field_count) {
            val field_node: *ast.Node = fields_list.nodes[i];
            if (field_node != nil && field_node.kind == ast.NODE_FIELD) {
                fields[i].name = field_node.data::str;

                # resolve field type - generic params are bound in current scope
                if (field_node.children != nil) {
                    fields[i].ty = resolve_type(sema, field_node.children);
                }

                # compute offset with alignment
                if (fields[i].ty != nil) {
                    val align: usize = fields[i].ty.align;
                    if (align > 0) {
                        offset = (offset + align - 1) & ~(align - 1);
                    }
                    fields[i].offset = offset;
                    offset = offset + fields[i].ty.size;
                    if (align > max_align) {
                        max_align = align;
                    }
                }
            }
            i = i + 1;
        }

        # create the instantiated record type
        val rec_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_RECORD);
        if (rec_res.is_err()) {
            sema.alloc.free[ty.Field](fields, field_count::usize);
            ret nil;
        }

        val inst: *ty.Type = rec_res.unwrap_ok();
        inst.name = generic_sym.name;
        inst.fields = fields;
        inst.field_count = field_count;

        # align total size
        if (max_align > 0) {
            offset = (offset + max_align - 1) & ~(max_align - 1);
        }
        inst.size = offset;
        inst.align = max_align;

        ret inst;
    }

    # no fields - create empty record
    val rec_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_RECORD);
    if (rec_res.is_ok()) {
        val inst: *ty.Type = rec_res.unwrap_ok();
        inst.name = generic_sym.name;
        ret inst;
    }

    ret nil;
}

# instantiate_union_type: create an instantiated union type with resolved variants.
fun instantiate_union_type(sema: *Sema, generic_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val decl: *ast.Node = generic_sym.decl_node;

    if (decl == nil || decl.kind != ast.NODE_DECL_UNI) {
        ret nil;
    }

    # get variants from declaration
    val fields_list: *ast.List = decl.children::*ast.List;
    val field_count: i32 = 0;
    if (fields_list != nil) {
        field_count = fields_list.count;
    }

    # allocate fields array
    var fields: *ty.Field = nil;
    if (field_count > 0) {
        val alloc_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
        if (alloc_res.is_err()) {
            ret nil;
        }
        fields = alloc_res.unwrap_ok();

        # resolve each variant type with generic params bound
        var max_size: usize = 0;
        var max_align: usize = 8;  # minimum align for tag
        var i: i32 = 0;
        for (i < field_count) {
            val field_node: *ast.Node = fields_list.nodes[i];
            if (field_node != nil && field_node.kind == ast.NODE_FIELD) {
                fields[i].name = field_node.data::str;
                fields[i].offset = 8;  # after tag

                # resolve variant type
                if (field_node.children != nil) {
                    fields[i].ty = resolve_type(sema, field_node.children);
                }

                if (fields[i].ty != nil) {
                    if (fields[i].ty.size > max_size) {
                        max_size = fields[i].ty.size;
                    }
                    if (fields[i].ty.align > max_align) {
                        max_align = fields[i].ty.align;
                    }
                }
            }
            i = i + 1;
        }

        # create the instantiated union type
        val uni_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_UNION);
        if (uni_res.is_err()) {
            sema.alloc.free[ty.Field](fields, field_count::usize);
            ret nil;
        }

        val inst: *ty.Type = uni_res.unwrap_ok();
        inst.name = generic_sym.name;
        inst.fields = fields;
        inst.field_count = field_count;

        # size = tag (8) + max variant size, aligned
        var size: usize = 8 + max_size;
        if (max_align > 0) {
            size = (size + max_align - 1) & ~(max_align - 1);
        }
        inst.size = size;
        inst.align = max_align;

        ret inst;
    }

    # no variants - create empty union
    val uni_res: Result[*ty.Type, str] = ty.create_type(ctx, ty.TY_UNION);
    if (uni_res.is_ok()) {
        val inst: *ty.Type = uni_res.unwrap_ok();
        inst.name = generic_sym.name;
        inst.size = 8;  # just tag
        inst.align = 8;
        ret inst;
    }

    ret nil;
}

# instantiate_generic_function: instantiate a generic function with type arguments.
# ---
# sema:         analyzer
# type_args_node: NODE_GENERIC node containing type arguments
# generic_sym:  symbol for the generic function
# ret:          instantiated function type or nil on error
fun instantiate_generic_function(sema: *Sema, type_args_node: *ast.Node, generic_sym: *symbol.Symbol) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    if (type_args_node == nil || type_args_node.kind != ast.NODE_GENERIC) {
        report_error_node(sema, type_args_node, "invalid generic arguments");
        ret nil;
    }

    if (!generic_sym.is_generic || generic_sym.generic_node == nil) {
        # not a generic function, just return the resolved type
        ret generic_sym.resolved_type;
    }

    # get type arguments from the call
    val args_list: *ast.List = type_args_node.children::*ast.List;
    if (args_list == nil || args_list.count == 0) {
        report_error_node(sema, type_args_node, "empty generic arguments");
        ret nil;
    }

    # get generic params from the symbol's generic_node
    val params_node: *ast.Node = generic_sym.generic_node;
    val params_list: *ast.List = params_node.children::*ast.List;
    if (params_list == nil) {
        report_error_node(sema, type_args_node, "invalid generic declaration");
        ret nil;
    }

    # check arg count matches param count
    if (args_list.count != params_list.count) {
        report_error_node(sema, type_args_node, "wrong number of generic arguments");
        ret nil;
    }

    val arg_count: i32 = args_list.count;

    # resolve each type argument
    val resolved_args_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](arg_count::usize);
    if (resolved_args_res.is_err()) {
        report_error_node(sema, type_args_node, "allocation failed");
        ret nil;
    }
    val resolved_args: **ty.Type = resolved_args_res.unwrap_ok();

    var i: i32 = 0;
    for (i < arg_count) {
        val arg_node: *ast.Node = args_list.nodes[i];
        if (arg_node == nil) {
            report_error_node(sema, type_args_node, "nil type argument");
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }

        val arg_type: *ty.Type = resolve_type(sema, arg_node);
        if (arg_type == nil) {
            sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
            ret nil;
        }
        resolved_args[i] = arg_type;
        i = i + 1;
    }

    # check cache for existing instantiation
    val cached: *ty.Type = find_cached_function_instantiation(sema, generic_sym, resolved_args, arg_count);
    if (cached != nil) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret cached;
    }

    # create scope with generic param bindings for type resolution
    val push_res: Result[bool, str] = symbol.push_scope(?sema.symbols);
    if (push_res.is_err()) {
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # bind each generic parameter to its concrete type
    i = 0;
    for (i < arg_count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node != nil) {
            val param_name: str = param_node.data::str;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = symbol.define(?sema.symbols, param_name, symbol.SYM_GENERIC);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # resolve parameter and return types with generic params bound
    val decl: *ast.Node = generic_sym.decl_node;
    if (decl == nil || decl.kind != ast.NODE_DECL_FUN) {
        val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    # get parameter list from decl.extra
    val params_decl: *ast.List = decl.extra::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_decl != nil && params_decl.count > 0) {
        param_count = params_decl.count;

        val alloc_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (alloc_res.is_ok()) {
            param_types = alloc_res.unwrap_ok();

            var j: i32 = 0;
            for (j < param_count) {
                val param_node: *ast.Node = params_decl.nodes[j];
                if (param_node != nil && param_node.children != nil) {
                    param_types[j] = resolve_type(sema, param_node.children);
                } or {
                    param_types[j] = nil;
                }
                j = j + 1;
            }
        }
    }

    # resolve return type from decl.ret_type
    var ret_type: *ty.Type = nil;
    if (decl.ret_type != nil) {
        ret_type = resolve_type(sema, decl.ret_type);
    }

    if (ret_type == nil) {
        # default to void
        val void_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (void_res.is_ok()) {
            ret_type = void_res.unwrap_ok();
        }
    }

    # pop the generic param scope
    val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);

    # create the instantiated function type
    val fn_res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (fn_res.is_err()) {
        if (param_types != nil) {
            sema.alloc.free[*ty.Type](param_types, param_count::usize);
        }
        sema.alloc.free[*ty.Type](resolved_args, arg_count::usize);
        ret nil;
    }

    val inst_type: *ty.Type = fn_res.unwrap_ok();

    # attach generic args to the instantiated type
    ty.set_generic_args(ctx, inst_type, resolved_args, arg_count);

    # link to base function's type if available
    if (generic_sym.resolved_type != nil) {
        ty.set_base_generic(inst_type, generic_sym.resolved_type);
    }

    ret inst_type;
}

# find_cached_function_instantiation: look for an existing function instantiation.
fun find_cached_function_instantiation(sema: *Sema, generic_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;
    val base_type: *ty.Type = generic_sym.resolved_type;

    if (base_type == nil) {
        ret nil;
    }

    var i: i32 = 0;
    for (i < ctx.type_count) {
        val t: *ty.Type = ctx.types[i];
        if (t != nil && t.kind == ty.TY_FUN && t.base_generic == base_type && t.generic_arg_count == arg_count) {
            # check if all args match
            var match: bool = true;
            var j: i32 = 0;
            for (j < arg_count && match) {
                if (!ty.types_equal(t.generic_args[j], args[j])) {
                    match = false;
                }
                j = j + 1;
            }
            if (match) {
                ret t;
            }
        }
        i = i + 1;
    }

    ret nil;
}

# resolve_qualified_type_name: resolve a qualified type name like module.Type.
# ---
# handles dotted names where the name contains '.' (e.g., "std.types.Result")
fun resolve_qualified_type_name(sema: *Sema, name: str) *ty.Type {
    # qualified names are stored as "module.Type" in the name field
    # we need to look up through module scopes

    if (name == nil) {
        ret nil;
    }

    # for now, try direct lookup first
    # full implementation would split on '.' and traverse
    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_some()) {
        val sym: *symbol.Symbol = sym_opt.unwrap();
        if (symbol.is_type_symbol(sym) && sym.resolved_type != nil) {
            ret sym.resolved_type;
        }
    }

    # type not found with full path
    ret nil;
}

# resolve_function_type: resolve a function type signature.
fun resolve_function_type(sema: *Sema, type_node: *ast.Node) *ty.Type {
    # function type nodes store params in data as *List and return type in extra
    val ctx: *ty.TypeContext = ?sema.types;

    # resolve return type
    var ret_type: *ty.Type = nil;
    if (type_node.extra != nil) {
        ret_type = resolve_type(sema, type_node.extra::*ast.Node);
    }
    if (ret_type == nil) {
        # default to void
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (res.is_ok()) {
            ret_type = res.unwrap_ok();
        }
    }

    # resolve parameter types
    val params_list: *ast.List = type_node.data::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_list != nil && params_list.count > 0) {
        param_count = params_list.count;

        # allocate param type array
        val ptypes_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.zalloc[*ty.Type](param_count::usize);
        if (ptypes_res.is_ok()) {
            param_types = ptypes_res.unwrap_ok();

            # resolve each parameter type
            var i: i32 = 0;
            for (i < param_count) {
                val param_node: *ast.Node = params_list.nodes[i];
                if (param_node != nil) {
                    # param types can be stored directly or in children
                    if (ast.is_type(param_node)) {
                        param_types[i] = resolve_type(sema, param_node);
                    } or {
                        if (param_node.children != nil) {
                            param_types[i] = resolve_type(sema, param_node.children);
                        }
                    }
                }
                i = i + 1;
            }
        }
    }

    val res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (res.is_err()) {
        report_error_node(sema, type_node, "failed to create function type");
        ret nil;
    }

    ret res.unwrap_ok();
}

# --- expression type checking ---

# check_expr: type-check an expression and return its type.
# ---
# sema: analyzer
# expr: expression AST node
# ret:  type of expression or nil on error
pub fun check_expr(sema: *Sema, expr: *ast.Node) *ty.Type {
    if (sema == nil || expr == nil) {
        ret nil;
    }

    val kind: ast.NodeKind = expr.kind;
    val ctx: *ty.TypeContext = ?sema.types;

    # literals
    if (kind == ast.NODE_EXPR_LIT_INT) {
        # default to i64 for integer literals
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_I64);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    if (kind == ast.NODE_EXPR_LIT_FLOAT) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_F64);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    if (kind == ast.NODE_EXPR_LIT_CHAR) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_U8);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    if (kind == ast.NODE_EXPR_LIT_STR) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_STR);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    if (kind == ast.NODE_EXPR_LIT_NIL) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_NIL);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    if (kind == ast.NODE_EXPR_LIT_BOOL) {
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_BOOL);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # identifier
    if (kind == ast.NODE_EXPR_IDENT) {
        ret check_ident(sema, expr);
    }

    # binary expression
    if (kind == ast.NODE_EXPR_BINARY) {
        ret check_binary(sema, expr);
    }

    # unary expression
    if (kind == ast.NODE_EXPR_UNARY) {
        ret check_unary(sema, expr);
    }

    # function call
    if (kind == ast.NODE_EXPR_CALL) {
        ret check_call(sema, expr);
    }

    # field access
    if (kind == ast.NODE_EXPR_FIELD) {
        ret check_field(sema, expr);
    }

    # index
    if (kind == ast.NODE_EXPR_INDEX) {
        ret check_index(sema, expr);
    }

    # cast
    if (kind == ast.NODE_EXPR_CAST) {
        ret check_cast(sema, expr);
    }

    # address-of
    if (kind == ast.NODE_EXPR_ADDR) {
        ret check_addr(sema, expr);
    }

    # dereference
    if (kind == ast.NODE_EXPR_DEREF) {
        ret check_deref(sema, expr);
    }

    # parenthesized expression
    if (kind == ast.NODE_EXPR_PAREN) {
        ret check_expr(sema, expr.children);
    }

    # array literal
    if (kind == ast.NODE_EXPR_ARRAY_LIT) {
        ret check_array_lit(sema, expr);
    }

    # struct literal
    if (kind == ast.NODE_EXPR_STRUCT_LIT) {
        ret check_struct_lit(sema, expr);
    }

    report_error_node(sema, expr, "unsupported expression");
    ret nil;
}

# check_array_lit: type-check an array literal expression.
fun check_array_lit(sema: *Sema, expr: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # array literal elements are in data as *List
    val elems_list: *ast.List = expr.data::*ast.List;
    if (elems_list == nil || elems_list.count == 0) {
        # empty array - need type annotation
        report_error_node(sema, expr, "cannot infer type of empty array literal");
        ret nil;
    }

    # check first element to determine array type
    val first: *ast.Node = elems_list.nodes[0];
    if (first == nil) {
        report_error_node(sema, expr, "array element is nil");
        ret nil;
    }

    val elem_type: *ty.Type = check_expr(sema, first);
    if (elem_type == nil) {
        ret nil;
    }

    # check remaining elements have compatible types
    var i: i32 = 1;
    for (i < elems_list.count) {
        val elem: *ast.Node = elems_list.nodes[i];
        if (elem != nil) {
            val et: *ty.Type = check_expr(sema, elem);
            if (et != nil && !ty.can_assign(et, elem_type)) {
                report_error_node(sema, elem, "array element type mismatch");
            }
        }
        i = i + 1;
    }

    # create array type
    val arr_res: Result[*ty.Type, str] = ty.array_type(ctx, elem_type, elems_list.count::usize);
    if (arr_res.is_err()) {
        report_error_node(sema, expr, "failed to create array type");
        ret nil;
    }

    ret arr_res.unwrap_ok();
}

# check_struct_lit: type-check a struct literal expression.
fun check_struct_lit(sema: *Sema, expr: *ast.Node) *ty.Type {
    # struct literal: TypeName { field: value, ... }
    # type name is in data, field inits are in children as *List

    val type_name: str = expr.data::str;
    if (type_name == nil) {
        report_error_node(sema, expr, "struct literal missing type name");
        ret nil;
    }

    # look up struct type
    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, type_name);
    if (sym_opt.is_none()) {
        report_error_node(sema, expr, "undefined struct type");
        ret nil;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    if (sym.resolved_type == nil) {
        report_error_node(sema, expr, "struct type not resolved");
        ret nil;
    }

    val struct_type: *ty.Type = sym.resolved_type;
    if (!ty.is_record(struct_type)) {
        report_error_node(sema, expr, "not a struct type");
        ret nil;
    }

    # check field initializers
    val inits_list: *ast.List = expr.children::*ast.List;
    if (inits_list != nil) {
        var i: i32 = 0;
        for (i < inits_list.count) {
            val init_node: *ast.Node = inits_list.nodes[i];
            if (init_node != nil) {
                # field init: name = value
                val field_name: str = ast.get_name(init_node);
                if (field_name != nil) {
                    # look up field in struct type
                    val field_opt: Option[*ty.Field] = ty.get_field(struct_type, field_name);
                    if (field_opt.is_none()) {
                        report_error_node(sema, init_node, "undefined field");
                    } or {
                        # check value type
                        val value_node: *ast.Node = init_node.children;
                        if (value_node != nil) {
                            val value_type: *ty.Type = check_expr(sema, value_node);
                            val field: *ty.Field = field_opt.unwrap();
                            if (value_type != nil && field.ty != nil && !ty.can_assign(value_type, field.ty)) {
                                report_error_node(sema, value_node, "field initializer type mismatch");
                            }
                        }
                    }
                }
            }
            i = i + 1;
        }
    }

    ret struct_type;
}

# check_ident: type-check an identifier expression.
fun check_ident(sema: *Sema, expr: *ast.Node) *ty.Type {
    val name: str = ast.get_name(expr);
    if (name == nil) {
        report_error_node(sema, expr, "identifier has no name");
        ret nil;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        report_error_node(sema, expr, "undefined identifier");
        ret nil;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    if (sym.resolved_type == nil) {
        report_error_node(sema, expr, "identifier type not resolved");
        ret nil;
    }

    ret sym.resolved_type;
}

# check_binary: type-check a binary expression.
fun check_binary(sema: *Sema, expr: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    # binary expression has two children: left and right
    val left: *ast.Node = ast.get_child(expr, 0);
    val right: *ast.Node = ast.get_child(expr, 1);

    if (left == nil || right == nil) {
        report_error_node(sema, expr, "binary expression missing operand");
        ret nil;
    }

    val left_type: *ty.Type = check_expr(sema, left);
    val right_type: *ty.Type = check_expr(sema, right);

    if (left_type == nil || right_type == nil) {
        ret nil;
    }

    # operator is stored in data as token tag
    val op: u8 = expr.data::u8;

    # arithmetic operators: +, -, *, /, %
    if (op == token.TAG_PLUS || op == token.TAG_MINUS ||
        op == token.TAG_STAR || op == token.TAG_SLASH || op == token.TAG_PERCENT) {
        if (!ty.is_numeric(left_type) || !ty.is_numeric(right_type)) {
            report_error_node(sema, expr, "arithmetic requires numeric operands");
            ret nil;
        }
        # result is the wider type (simplified: just use left)
        ret left_type;
    }

    # comparison operators: ==, !=, <, >, <=, >=
    if (op == token.TAG_EQ_EQ || op == token.TAG_BANG_EQ ||
        op == token.TAG_LESS || op == token.TAG_GREATER ||
        op == token.TAG_LESS_EQ || op == token.TAG_GREATER_EQ) {
        # comparison always returns bool
        val res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_BOOL);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # logical operators: &&, ||
    if (op == token.TAG_AMP_AMP || op == token.TAG_PIPE_PIPE) {
        if (!ty.is_bool(left_type) || !ty.is_bool(right_type)) {
            report_error_node(sema, expr, "logical operators require bool operands");
            ret nil;
        }
        ret left_type;
    }

    # bitwise operators: &, |, ^, <<, >>
    if (op == token.TAG_AMP || op == token.TAG_PIPE || op == token.TAG_CARET ||
        op == token.TAG_LESS_LESS || op == token.TAG_GREATER_GREATER) {
        if (!ty.is_integer(left_type) || !ty.is_integer(right_type)) {
            report_error_node(sema, expr, "bitwise operators require integer operands");
            ret nil;
        }
        ret left_type;
    }

    # assignment operator: =
    if (op == token.TAG_EQ) {
        if (!ty.can_assign(right_type, left_type)) {
            report_error_node(sema, expr, "type mismatch in assignment");
            ret nil;
        }
        ret left_type;
    }

    report_error_node(sema, expr, "unknown binary operator");
    ret nil;
}

# check_unary: type-check a unary expression.
fun check_unary(sema: *Sema, expr: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    val operand: *ast.Node = expr.children;
    if (operand == nil) {
        report_error_node(sema, expr, "unary expression missing operand");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    # operator stored in data
    val op: u8 = expr.data::u8;

    # negation: -
    if (op == token.TAG_MINUS) {
        if (!ty.is_numeric(operand_type)) {
            report_error_node(sema, expr, "negation requires numeric operand");
            ret nil;
        }
        ret operand_type;
    }

    # logical not: !
    if (op == token.TAG_BANG) {
        if (!ty.is_bool(operand_type)) {
            report_error_node(sema, expr, "logical not requires bool operand");
            ret nil;
        }
        ret operand_type;
    }

    # bitwise not: ~
    if (op == token.TAG_TILDE) {
        if (!ty.is_integer(operand_type)) {
            report_error_node(sema, expr, "bitwise not requires integer operand");
            ret nil;
        }
        ret operand_type;
    }

    # dereference: * (as prefix)
    if (op == token.TAG_STAR) {
        if (!ty.is_pointer(operand_type)) {
            report_error_node(sema, expr, "dereference requires pointer operand");
            ret nil;
        }
        ret ty.get_element_type(operand_type);
    }

    # address-of: @ or &
    if (op == token.TAG_AT || op == token.TAG_AMP) {
        val res: Result[*ty.Type, str] = ty.pointer_type(ctx, operand_type, op == token.TAG_AT);
        if (res.is_ok()) {
            ret res.unwrap_ok();
        }
        ret nil;
    }

    # try operator: ? (unwrap Result or Option)
    if (op == token.TAG_QUESTION) {
        # try operator extracts the inner type from Result[T, E] or Option[T]
        # for now, just pass through the type (proper handling requires generic analysis)
        # TODO: properly check Result/Option and extract inner type
        ret operand_type;
    }

    report_error_node(sema, expr, "unknown unary operator");
    ret nil;
}

# check_call: type-check a function call.
fun check_call(sema: *Sema, expr: *ast.Node) *ty.Type {
    # callee is first child, arguments are in data as *List
    val callee: *ast.Node = ast.get_child(expr, 0);
    if (callee == nil) {
        report_error_node(sema, expr, "call missing callee");
        ret nil;
    }

    # check if this is a generic function call (has type args in expr.generics)
    var callee_type: *ty.Type = nil;

    if (expr.generics != nil && callee.kind == ast.NODE_EXPR_IDENT) {
        # generic function call: func[T](args)
        # look up the function symbol and instantiate it
        val func_name: str = callee.data::str;
        if (func_name != nil) {
            val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, func_name);
            if (sym_opt.is_some()) {
                val func_sym: *symbol.Symbol = sym_opt.unwrap();
                if (func_sym.is_generic && symbol.is_callable(func_sym)) {
                    # instantiate the generic function with type args
                    callee_type = instantiate_generic_function(sema, expr.generics, func_sym);
                } or {
                    # not a generic function but called with type args
                    report_error_node(sema, expr, "function is not generic");
                    ret nil;
                }
            } or {
                report_error_node(sema, expr, "undefined function");
                ret nil;
            }
        }
    } or {
        # regular (non-generic) function call
        callee_type = check_expr(sema, callee);
    }

    if (callee_type == nil) {
        ret nil;
    }

    if (!ty.is_function(callee_type)) {
        report_error_node(sema, expr, "cannot call non-function");
        ret nil;
    }

    # check argument types match parameters
    val args_list: *ast.List = expr.data::*ast.List;
    var arg_count: i32 = 0;
    if (args_list != nil) {
        arg_count = args_list.count;
    }

    # check argument count
    if (arg_count != callee_type.param_count) {
        report_error_node(sema, expr, "wrong number of arguments");
        # continue to check what we can
    }

    # check each argument type
    if (args_list != nil) {
        var i: i32 = 0;
        for (i < args_list.count) {
            val arg_node: *ast.Node = args_list.nodes[i];
            if (arg_node != nil) {
                val arg_type: *ty.Type = check_expr(sema, arg_node);

                # check against parameter type if available
                if (arg_type != nil && i < callee_type.param_count && callee_type.params != nil) {
                    val param_type: *ty.Type = callee_type.params[i];
                    if (param_type != nil && !ty.can_assign(arg_type, param_type)) {
                        report_error_node(sema, arg_node, "argument type mismatch");
                    }
                }
            }
            i = i + 1;
        }
    }

    ret callee_type.ret_type;
}

# check_field: type-check field access (expr.field).
fun check_field(sema: *Sema, expr: *ast.Node) *ty.Type {
    val base: *ast.Node = ast.get_child(expr, 0);
    if (base == nil) {
        report_error_node(sema, expr, "field access missing base");
        ret nil;
    }

    val base_type: *ty.Type = check_expr(sema, base);
    if (base_type == nil) {
        ret nil;
    }

    # auto-dereference pointers for field access
    var target_type: *ty.Type = base_type;
    if (ty.is_pointer(base_type)) {
        target_type = ty.get_element_type(base_type);
    }

    val field_name: str = ast.get_name(expr);
    if (field_name == nil) {
        report_error_node(sema, expr, "field name missing");
        ret nil;
    }

    # first, try to find a field with this name
    if (ty.is_record(target_type) || ty.is_union(target_type)) {
        val field_opt: Option[*ty.Field] = ty.get_field(target_type, field_name);
        if (field_opt.is_some()) {
            ret field_opt.unwrap().ty;
        }
    }

    # not a field, try to find a method with this name
    val method_type: *ty.Type = lookup_method(sema, target_type, field_name);
    if (method_type != nil) {
        ret method_type;
    }

    # neither field nor method found
    if (ty.is_record(target_type) || ty.is_union(target_type)) {
        report_error_node(sema, expr, "undefined field or method");
    } or {
        report_error_node(sema, expr, "field access requires record or union type");
    }
    ret nil;
}

# lookup_method: look up a method on a type by name.
# ---
# handles generic method instantiation for instantiated generic types.
fun lookup_method(sema: *Sema, target_type: *ty.Type, method_name: str) *ty.Type {
    if (target_type == nil || method_name == nil) {
        ret nil;
    }

    # get the type name to look up methods
    val type_name: str = target_type.name;
    if (type_name == nil) {
        ret nil;
    }

    # for instantiated generic types, use the base generic's name for method lookup
    var lookup_name: str = type_name;
    var is_instantiated_generic: bool = false;
    var generic_args: **ty.Type = nil;
    var generic_arg_count: i32 = 0;

    if (target_type.base_generic != nil) {
        is_instantiated_generic = true;
        generic_args = target_type.generic_args;
        generic_arg_count = target_type.generic_arg_count;
        if (target_type.base_generic.name != nil) {
            lookup_name = target_type.base_generic.name;
        }
    }

    # look up method by iterating through symbols
    # methods are registered with receiver_name set to the type name
    val table: *symbol.Table = ?sema.symbols;
    val method_sym: *symbol.Symbol = find_method_symbol(table, lookup_name, method_name);

    if (method_sym == nil) {
        ret nil;
    }

    # if the method is generic and we have an instantiated receiver, instantiate the method
    if (method_sym.is_generic && is_instantiated_generic && generic_arg_count > 0) {
        ret instantiate_method_for_generic_receiver(sema, method_sym, generic_args, generic_arg_count);
    }

    # return the method's resolved type
    ret method_sym.resolved_type;
}

# find_method_symbol: find a method symbol by receiver type name and method name.
fun find_method_symbol(table: *symbol.Table, receiver_name: str, method_name: str) *symbol.Symbol {
    if (table == nil || receiver_name == nil || method_name == nil) {
        ret nil;
    }

    # search through all scopes for a matching method
    var scope: *symbol.Scope = table.current;
    for (scope != nil) {
        var i: i32 = 0;
        for (i < scope.symbol_count) {
            val sym: *symbol.Symbol = ?scope.symbols[i];
            if (sym.is_method && sym.receiver_name != nil && sym.name != nil) {
                if (sym.receiver_name.equals(receiver_name) && sym.name.equals(method_name)) {
                    ret sym;
                }
            }
            i = i + 1;
        }
        scope = scope.parent;
    }

    ret nil;
}

# instantiate_method_for_generic_receiver: instantiate a method with the receiver's type args.
fun instantiate_method_for_generic_receiver(sema: *Sema, method_sym: *symbol.Symbol, args: **ty.Type, arg_count: i32) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    if (method_sym == nil || method_sym.generic_node == nil || args == nil || arg_count <= 0) {
        ret method_sym.resolved_type;
    }

    # get generic params from the method's generic_node
    val params_node: *ast.Node = method_sym.generic_node;
    val params_list: *ast.List = params_node.children::*ast.List;
    if (params_list == nil || params_list.count != arg_count) {
        ret method_sym.resolved_type;
    }

    # check cache for existing instantiation
    val cached: *ty.Type = find_cached_function_instantiation(sema, method_sym, args, arg_count);
    if (cached != nil) {
        ret cached;
    }

    # create scope with generic param bindings
    val push_res: Result[bool, str] = symbol.push_scope(?sema.symbols);
    if (push_res.is_err()) {
        ret method_sym.resolved_type;
    }

    # bind each generic parameter to its concrete type
    var i: i32 = 0;
    for (i < arg_count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node != nil) {
            val param_name: str = param_node.data::str;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = symbol.define(?sema.symbols, param_name, symbol.SYM_GENERIC);
                if (bind_res.is_ok()) {
                    val bind_sym: *symbol.Symbol = bind_res.unwrap_ok();
                    bind_sym.resolved_type = args[i];
                }
            }
        }
        i = i + 1;
    }

    # resolve parameter and return types with generic params bound
    val decl: *ast.Node = method_sym.decl_node;
    if (decl == nil || decl.kind != ast.NODE_DECL_FUN) {
        val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);
        ret method_sym.resolved_type;
    }

    # get parameter list from decl.extra
    val params_decl: *ast.List = decl.extra::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_decl != nil && params_decl.count > 0) {
        param_count = params_decl.count;

        val alloc_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](param_count::usize);
        if (alloc_res.is_ok()) {
            param_types = alloc_res.unwrap_ok();

            var j: i32 = 0;
            for (j < param_count) {
                val param_node: *ast.Node = params_decl.nodes[j];
                if (param_node != nil && param_node.children != nil) {
                    param_types[j] = resolve_type(sema, param_node.children);
                } or {
                    param_types[j] = nil;
                }
                j = j + 1;
            }
        }
    }

    # resolve return type from decl.ret_type
    var ret_type: *ty.Type = nil;
    if (decl.ret_type != nil) {
        ret_type = resolve_type(sema, decl.ret_type);
    }

    if (ret_type == nil) {
        # default to void
        val void_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (void_res.is_ok()) {
            ret_type = void_res.unwrap_ok();
        }
    }

    # pop the generic param scope
    val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);

    # create the instantiated function type
    val fn_res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (fn_res.is_err()) {
        if (param_types != nil) {
            sema.alloc.free[*ty.Type](param_types, param_count::usize);
        }
        ret method_sym.resolved_type;
    }

    val inst_type: *ty.Type = fn_res.unwrap_ok();

    # attach generic args to the instantiated type
    ty.set_generic_args(ctx, inst_type, args, arg_count);

    # link to base method's type
    if (method_sym.resolved_type != nil) {
        ty.set_base_generic(inst_type, method_sym.resolved_type);
    }

    ret inst_type;
}

# check_index: type-check array/pointer indexing.
fun check_index(sema: *Sema, expr: *ast.Node) *ty.Type {
    val base: *ast.Node = ast.get_child(expr, 0);
    val index: *ast.Node = ast.get_child(expr, 1);

    if (base == nil || index == nil) {
        report_error_node(sema, expr, "index expression missing operand");
        ret nil;
    }

    val base_type: *ty.Type = check_expr(sema, base);
    val index_type: *ty.Type = check_expr(sema, index);

    if (base_type == nil || index_type == nil) {
        ret nil;
    }

    if (!ty.is_array(base_type) && !ty.is_pointer(base_type)) {
        report_error_node(sema, expr, "cannot index non-array/pointer type");
        ret nil;
    }

    if (!ty.is_integer(index_type)) {
        report_error_node(sema, expr, "index must be integer");
        ret nil;
    }

    ret ty.get_element_type(base_type);
}

# check_cast: type-check a type cast (expr::Type).
fun check_cast(sema: *Sema, expr: *ast.Node) *ty.Type {
    val operand: *ast.Node = ast.get_child(expr, 0);
    val target_type_node: *ast.Node = expr.extra::*ast.Node;

    if (operand == nil) {
        report_error_node(sema, expr, "cast missing operand");
        ret nil;
    }

    if (target_type_node == nil) {
        report_error_node(sema, expr, "cast missing target type");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    val target_type: *ty.Type = resolve_type(sema, target_type_node);
    if (target_type == nil) {
        ret nil;
    }

    if (!ty.can_cast(operand_type, target_type)) {
        report_error_node(sema, expr, "invalid cast");
        ret nil;
    }

    ret target_type;
}

# check_addr: type-check address-of expression.
fun check_addr(sema: *Sema, expr: *ast.Node) *ty.Type {
    val ctx: *ty.TypeContext = ?sema.types;

    val operand: *ast.Node = expr.children;
    if (operand == nil) {
        report_error_node(sema, expr, "address-of missing operand");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    # TODO: check operand is lvalue

    val res: Result[*ty.Type, str] = ty.pointer_type(ctx, operand_type, true);
    if (res.is_ok()) {
        ret res.unwrap_ok();
    }

    report_error_node(sema, expr, "failed to create pointer type");
    ret nil;
}

# check_deref: type-check dereference expression.
fun check_deref(sema: *Sema, expr: *ast.Node) *ty.Type {
    val operand: *ast.Node = expr.children;
    if (operand == nil) {
        report_error_node(sema, expr, "dereference missing operand");
        ret nil;
    }

    val operand_type: *ty.Type = check_expr(sema, operand);
    if (operand_type == nil) {
        ret nil;
    }

    if (!ty.is_pointer(operand_type)) {
        report_error_node(sema, expr, "cannot dereference non-pointer");
        ret nil;
    }

    ret ty.get_element_type(operand_type);
}

# --- statement checking ---

# check_stmt: type-check a statement.
# ---
# sema: analyzer
# stmt: statement AST node
# ret:  true on success, false on error
pub fun check_stmt(sema: *Sema, stmt: *ast.Node) bool {
    if (sema == nil || stmt == nil) {
        ret false;
    }

    val kind: ast.NodeKind = stmt.kind;

    # variable declarations
    if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
        ret check_var_decl(sema, stmt);
    }

    # expression statement
    if (kind == ast.NODE_STMT_EXPR) {
        val expr_type: *ty.Type = check_expr(sema, stmt.children);
        ret expr_type != nil;
    }

    # block statement
    if (kind == ast.NODE_STMT_BLOCK) {
        ret check_block(sema, stmt);
    }

    # if statement
    if (kind == ast.NODE_STMT_IF) {
        ret check_if(sema, stmt);
    }

    # for loop
    if (kind == ast.NODE_STMT_FOR) {
        ret check_for(sema, stmt);
    }

    # return statement
    if (kind == ast.NODE_STMT_RET) {
        ret check_return(sema, stmt);
    }

    # break statement
    if (kind == ast.NODE_STMT_BRK) {
        if (sema.loop_depth <= 0) {
            report_error_node(sema, stmt, "break outside of loop");
            ret false;
        }
        ret true;
    }

    # continue statement
    if (kind == ast.NODE_STMT_CNT) {
        if (sema.loop_depth <= 0) {
            report_error_node(sema, stmt, "continue outside of loop");
            ret false;
        }
        ret true;
    }

    # defer statement
    if (kind == ast.NODE_STMT_FIN) {
        ret check_stmt(sema, stmt.children);
    }

    # inline assembly - skip type checking
    if (kind == ast.NODE_STMT_MASM) {
        ret true;
    }

    # declarations at statement level
    if (kind == ast.NODE_DECL_FUN) {
        ret check_function(sema, stmt);
    }

    if (kind == ast.NODE_DECL_REC || kind == ast.NODE_DECL_UNI) {
        # type declarations are handled in collection pass
        ret true;
    }

    report_error_node(sema, stmt, "unsupported statement");
    ret false;
}

# check_var_decl: check a val/var declaration.
fun check_var_decl(sema: *Sema, stmt: *ast.Node) bool {
    val name: str = ast.get_name(stmt);
    if (name == nil) {
        report_error_node(sema, stmt, "declaration missing name");
        ret false;
    }

    val is_mutable: bool = stmt.kind == ast.NODE_DECL_VAR;
    val sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
    if (is_mutable) {
        # SymbolKind constant
    }

    # define symbol
    val def_res: Result[*symbol.Symbol, str] = symbol.define(
        ?sema.symbols,
        name,
        sym_kind
    );

    if (def_res.is_err()) {
        report_error_node(sema, stmt, "redefinition of symbol");
        ret false;
    }

    val sym: *symbol.Symbol = def_res.unwrap_ok();
    sym.decl_node = stmt;
    sym.is_mutable = is_mutable;

    # resolve declared type if present
    var declared_type: *ty.Type = nil;
    if (stmt.extra != nil) {
        declared_type = resolve_type(sema, stmt.extra::*ast.Node);
    }

    # check initializer if present
    var init_type: *ty.Type = nil;
    if (stmt.children != nil) {
        init_type = check_expr(sema, stmt.children);
    }

    # determine symbol type
    if (declared_type != nil) {
        sym.resolved_type = declared_type;
        if (init_type != nil && !ty.can_assign(init_type, declared_type)) {
            report_error_node(sema, stmt, "initializer type mismatch");
            ret false;
        }
    } or {
        if (init_type != nil) {
            sym.resolved_type = init_type;
        } or {
            report_error_node(sema, stmt, "cannot infer type without initializer");
            ret false;
        }
    }

    ret true;
}

# check_block: check a block statement.
fun check_block(sema: *Sema, stmt: *ast.Node) bool {
    # push new scope
    val push_res: Result[bool, str] = symbol.push_scope(?sema.symbols);
    if (push_res.is_err()) {
        report_error_node(sema, stmt, "failed to push scope");
        ret false;
    }

    var success: bool = true;
    var terminated: bool = false;

    # check each statement in block
    val list: *ast.List = ast.get_list(stmt);
    if (list != nil) {
        var i: i32 = 0;
        for (i < list.count) {
            val s: *ast.Node = list.nodes[i];
            if (s == nil) {
                i = i + 1;
                cnt;
            }

            # check for unreachable code
            if (terminated) {
                report_error_node(sema, s, "unreachable code");
                # still check the statement for other errors
            }

            if (!check_stmt(sema, s)) {
                success = false;
            }

            # check if this statement terminates the block
            if (is_terminal_stmt(s)) {
                terminated = true;
            }

            i = i + 1;
        }
    }

    # pop scope
    val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);
    if (pop_res.is_err()) {
        # this shouldn't happen
    }

    ret success;
}

# is_terminal_stmt: check if a statement terminates control flow.
fun is_terminal_stmt(stmt: *ast.Node) bool {
    if (stmt == nil) {
        ret false;
    }

    val kind: ast.NodeKind = stmt.kind;

    # ret, brk, cnt are terminal
    if (kind == ast.NODE_STMT_RET || kind == ast.NODE_STMT_BRK || kind == ast.NODE_STMT_CNT) {
        ret true;
    }

    # a block is terminal if its last statement is terminal
    if (kind == ast.NODE_STMT_BLOCK) {
        val list: *ast.List = ast.get_list(stmt);
        if (list != nil && list.count > 0) {
            ret is_terminal_stmt(list.nodes[list.count - 1]);
        }
        ret false;
    }

    # if/or is terminal if both branches are terminal
    if (kind == ast.NODE_STMT_IF) {
        val then_branch: *ast.Node = ast.get_child(stmt, 1);
        val else_branch: *ast.Node = ast.get_child(stmt, 2);

        # must have else branch to be terminal
        if (else_branch == nil) {
            ret false;
        }

        ret is_terminal_stmt(then_branch) && is_terminal_stmt(else_branch);
    }

    # for with no condition (infinite loop) that contains no break could be terminal
    # but conservatively, we don't consider for loops terminal
    ret false;
}

# block_returns: check if a block always returns.
# ---
# used to detect missing returns in non-void functions.
# returns true if all execution paths through the block end with a return.
fun block_returns(stmt: *ast.Node) bool {
    if (stmt == nil) {
        ret false;
    }

    val kind: ast.NodeKind = stmt.kind;

    # a return statement always returns
    if (kind == ast.NODE_STMT_RET) {
        ret true;
    }

    # a block returns if its last statement returns, or if any unconditional return exists
    if (kind == ast.NODE_STMT_BLOCK) {
        val list: *ast.List = ast.get_list(stmt);
        if (list == nil || list.count == 0) {
            ret false;
        }

        # check if any statement in the block is an unconditional return
        var i: i32 = 0;
        for (i < list.count) {
            val s: *ast.Node = list.nodes[i];
            if (s != nil && s.kind == ast.NODE_STMT_RET) {
                ret true;
            }
            i = i + 1;
        }

        # check if last statement returns
        val last: *ast.Node = list.nodes[list.count - 1];
        ret block_returns(last);
    }

    # an if/or returns if both branches return
    if (kind == ast.NODE_STMT_IF) {
        val then_branch: *ast.Node = ast.get_child(stmt, 1);
        val else_branch: *ast.Node = ast.get_child(stmt, 2);

        # must have else branch for guaranteed return
        if (else_branch == nil) {
            ret false;
        }

        ret block_returns(then_branch) && block_returns(else_branch);
    }

    # for loops don't guarantee return (condition could be false)
    if (kind == ast.NODE_STMT_FOR) {
        ret false;
    }

    # break/continue don't return
    if (kind == ast.NODE_STMT_BRK || kind == ast.NODE_STMT_CNT) {
        ret false;
    }

    # expression statements don't return
    if (kind == ast.NODE_STMT_EXPR) {
        ret false;
    }

    # defer doesn't return
    if (kind == ast.NODE_STMT_FIN) {
        ret false;
    }

    ret false;
}

# check_if: check an if statement.
fun check_if(sema: *Sema, stmt: *ast.Node) bool {
    # condition is first child
    val cond: *ast.Node = ast.get_child(stmt, 0);
    if (cond != nil) {
        val cond_type: *ty.Type = check_expr(sema, cond);
        if (cond_type != nil && !ty.is_bool(cond_type)) {
            report_error_node(sema, cond, "if condition must be bool");
        }
    }

    # then branch is second child
    val then_branch: *ast.Node = ast.get_child(stmt, 1);
    if (then_branch != nil) {
        check_stmt(sema, then_branch);
    }

    # else/or branch is third child (if present)
    val else_branch: *ast.Node = ast.get_child(stmt, 2);
    if (else_branch != nil) {
        check_stmt(sema, else_branch);
    }

    ret true;
}

# check_for: check a for loop.
fun check_for(sema: *Sema, stmt: *ast.Node) bool {
    sema.loop_depth = sema.loop_depth + 1;

    # condition is first child (may be nil for infinite loop)
    val cond: *ast.Node = ast.get_child(stmt, 0);
    if (cond != nil) {
        val cond_type: *ty.Type = check_expr(sema, cond);
        if (cond_type != nil && !ty.is_bool(cond_type)) {
            report_error_node(sema, cond, "for condition must be bool");
        }
    }

    # body is second child
    val body: *ast.Node = ast.get_child(stmt, 1);
    if (body != nil) {
        check_stmt(sema, body);
    }

    sema.loop_depth = sema.loop_depth - 1;
    ret true;
}

# check_return: check a return statement.
fun check_return(sema: *Sema, stmt: *ast.Node) bool {
    var ret_type: *ty.Type = nil;

    if (stmt.children != nil) {
        ret_type = check_expr(sema, stmt.children);
    }

    # check against current function's return type
    if (sema.current_fn_ret != nil) {
        if (ret_type == nil) {
            if (!ty.is_void(sema.current_fn_ret)) {
                report_error_node(sema, stmt, "missing return value");
                ret false;
            }
        } or {
            if (!ty.can_assign(ret_type, sema.current_fn_ret)) {
                report_error_node(sema, stmt, "return type mismatch");
                ret false;
            }
        }
    }

    ret true;
}

# define_parameters: define function parameters in current scope.
fun define_parameters(sema: *Sema, decl: *ast.Node) bool {
    # params are stored in node.extra as *List
    val params_list: *ast.List = decl.extra::*ast.List;
    if (params_list == nil || params_list.count == 0) {
        ret true;
    }

    var i: i32 = 0;
    for (i < params_list.count) {
        val param_node: *ast.Node = params_list.nodes[i];
        if (param_node == nil) {
            i = i + 1;
            cnt;
        }

        val param_name: str = ast.get_name(param_node);
        if (param_name == nil) {
            i = i + 1;
            cnt;
        }

        # define parameter symbol
        val def_res: Result[*symbol.Symbol, str] = symbol.define(
            ?sema.symbols,
            param_name,
            symbol.SYM_PARAM
        );

        if (def_res.is_ok()) {
            val param_sym: *symbol.Symbol = def_res.unwrap_ok();
            param_sym.decl_node = param_node;
            param_sym.is_mutable = false;  # parameters are immutable by default

            # resolve parameter type
            if (param_node.children != nil) {
                param_sym.resolved_type = resolve_type(sema, param_node.children);
            }
        }

        i = i + 1;
    }

    ret true;
}

# check_function: check a function declaration.
fun check_function(sema: *Sema, stmt: *ast.Node) bool {
    val name: str = ast.get_name(stmt);
    if (name == nil) {
        report_error_node(sema, stmt, "function missing name");
        ret false;
    }

    # lookup or define symbol
    var sym: *symbol.Symbol = nil;
    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_some()) {
        sym = sym_opt.unwrap();
    } or {
        val def_res: Result[*symbol.Symbol, str] = symbol.define(
            ?sema.symbols,
            name,
            symbol.SYM_FUN
        );
        if (def_res.is_err()) {
            report_error_node(sema, stmt, "failed to define function");
            ret false;
        }
        sym = def_res.unwrap_ok();
    }

    sym.decl_node = stmt;

    # save previous function context
    val prev_fn: *symbol.Symbol = sema.current_fn;
    val prev_ret: *ty.Type = sema.current_fn_ret;

    sema.current_fn = sym;

    # get return type from resolved function type if available
    if (sym.resolved_type != nil && ty.is_function(sym.resolved_type)) {
        sema.current_fn_ret = sym.resolved_type.ret_type;
    } or {
        # fallback: try to resolve from AST ret_type field
        if (stmt.ret_type != nil) {
            sema.current_fn_ret = resolve_type(sema, stmt.ret_type);
        } or {
            # default void return
            val res: Result[*ty.Type, str] = ty.primitive_type(?sema.types, ty.TY_VOID);
            if (res.is_ok()) {
                sema.current_fn_ret = res.unwrap_ok();
            }
        }
    }

    # update symbol type if not already set
    if (sym.resolved_type == nil) {
        sym.resolved_type = sema.current_fn_ret;
    }

    # push function scope for parameters and body
    val push_res: Result[bool, str] = symbol.push_scope(?sema.symbols);
    if (push_res.is_err()) {
        ret false;
    }

    # define parameters in scope
    define_parameters(sema, stmt);

    # check function body (stored directly in children)
    var body: *ast.Node = stmt.children;

    var check_result: bool = true;
    if (body != nil && body.kind == ast.NODE_STMT_BLOCK) {
        check_result = check_block(sema, body);

        # check for missing return in non-void functions
        if (sema.current_fn_ret != nil && !ty.is_void(sema.current_fn_ret)) {
            if (!block_returns(body)) {
                report_error_node(sema, stmt, "function may not return a value");
            }
        }
    }

    # pop function scope
    val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);

    # restore previous function context
    sema.current_fn = prev_fn;
    sema.current_fn_ret = prev_ret;

    ret check_result;
}

# --- multi-pass analysis ---

# collect_declarations: first pass - collect all top-level declarations.
fun collect_declarations(sema: *Sema, program: *ast.Node) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }

    val list: *ast.List = ast.get_list(program);
    if (list == nil) {
        ret true;
    }

    var success: bool = true;

    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;
        var name: str = ast.get_name(decl);
        var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
        var is_public: bool = false;

        # handle pub modifier - it wraps the actual declaration
        var actual_decl: *ast.Node = decl;
        var actual_kind: ast.NodeKind = kind;
        if (kind == ast.NODE_DECL_PUB) {
            is_public = true;
            # the wrapped declaration is in children
            actual_decl = decl.children;
            if (actual_decl != nil) {
                actual_kind = actual_decl.kind;
                name = ast.get_name(actual_decl);
            } or {
                i = i + 1;
                cnt;
            }
        }

        if (actual_kind == ast.NODE_DECL_VAL) {
            sym_kind = symbol.SYM_VAL;
        } or {
            if (actual_kind == ast.NODE_DECL_VAR) {
                sym_kind = symbol.SYM_VAR;
            } or {
                if (actual_kind == ast.NODE_DECL_FUN) {
                    sym_kind = symbol.SYM_FUN;
                } or {
                    if (actual_kind == ast.NODE_DECL_REC) {
                        sym_kind = symbol.SYM_REC;
                    } or {
                        if (actual_kind == ast.NODE_DECL_UNI) {
                            sym_kind = symbol.SYM_UNI;
                        } or {
                            if (actual_kind == ast.NODE_DECL_DEF) {
                                sym_kind = symbol.SYM_TYPE;
                            } or {
                                if (actual_kind == ast.NODE_DECL_EXT) {
                                    sym_kind = symbol.SYM_EXT;
                                } or {
                                    if (actual_kind == ast.NODE_DECL_USE) {
                                        # handle use declarations separately
                                        collect_use_decl(sema, actual_decl);
                                        i = i + 1;
                                        cnt;
                                    } or {
                                        # skip test, etc.
                                        i = i + 1;
                                        cnt;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        # for methods, use qualified name "ReceiverType.methodName"
        var use_name: str = name;
        var receiver_type_name: str = nil;
        var is_method: bool = false;

        if (actual_kind == ast.NODE_DECL_FUN && actual_decl.receiver != nil) {
            is_method = true;
            # extract receiver type name from receiver node
            val receiver: *ast.Node = actual_decl.receiver;
            if (receiver.children != nil) {
                receiver_type_name = get_receiver_type_name(receiver.children);
            }
            # use qualified name for method lookup (we still also register by plain name)
        }

        if (name != nil) {
            val def_res: Result[*symbol.Symbol, str] = symbol.define(
                ?sema.symbols,
                name,
                sym_kind
            );

            if (def_res.is_ok()) {
                val sym: *symbol.Symbol = def_res.unwrap_ok();
                sym.decl_node = actual_decl;
                sym.is_public = is_public;

                # detect generic declarations via node.generics field
                if (actual_decl.generics != nil) {
                    sym.is_generic = true;
                    sym.generic_node = actual_decl.generics;
                }

                # detect methods
                if (is_method) {
                    sym.is_method = true;
                    sym.receiver_name = receiver_type_name;

                    # for methods on generic types, inherit generic params from receiver
                    if (receiver_type_name != nil && actual_decl.generics == nil) {
                        # look up the receiver type to get its generic params
                        val recv_sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, receiver_type_name);
                        if (recv_sym_opt.is_some()) {
                            val recv_sym: *symbol.Symbol = recv_sym_opt.unwrap();
                            if (recv_sym.is_generic && recv_sym.generic_node != nil) {
                                sym.is_generic = true;
                                sym.generic_node = recv_sym.generic_node;
                            }
                        }
                    }
                }
            } or {
                report_error_node(sema, decl, "duplicate definition");
                success = false;
            }
        }

        i = i + 1;
    }

    ret success;
}

# collect_use_decl: handle a use declaration.
# ---
# registers the imported module path for later resolution.
fun collect_use_decl(sema: *Sema, decl: *ast.Node) {
    if (sema == nil || decl == nil) {
        ret;
    }

    # path is stored in data
    val path: str = ast.get_name(decl);
    if (path == nil) {
        ret;
    }

    # check if there's an alias (count > 0 means alias was provided)
    # for aliased imports like "use foo: bar.baz;", we create a symbol for the alias
    if (decl.count > 0) {
        # has alias - the alias would need to be extracted differently
        # for now, just register the module path
        # TODO: properly extract alias name and register it
    }

    # register the module as a symbol if it has a simple name
    # this allows "use foo;" to make "foo" available
    # for qualified paths like "std.types", we'd need module resolution

    # for simple unaliased imports, create a module symbol
    val def_res: Result[*symbol.Symbol, str] = symbol.define(
        ?sema.symbols,
        path,
        symbol.SYM_MODULE
    );

    if (def_res.is_ok()) {
        val sym: *symbol.Symbol = def_res.unwrap_ok();
        sym.decl_node = decl;
        # module type resolution happens during import loading
    }
    # ignore duplicate module imports
}

# resolve_types: second pass - resolve all type references.
fun resolve_types(sema: *Sema, program: *ast.Node) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }

    val list: *ast.List = ast.get_list(program);
    if (list == nil) {
        ret true;
    }

    var success: bool = true;

    # first pass: create type shells for records/unions (allows forward references)
    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # create record type shell
        if (kind == ast.NODE_DECL_REC) {
            val name: str = ast.get_name(decl);
            if (name != nil) {
                val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
                if (sym_opt.is_some()) {
                    val sym: *symbol.Symbol = sym_opt.unwrap();
                    if (sym.resolved_type == nil) {
                        val ctx: *ty.TypeContext = ?sema.types;
                        val res: Result[*ty.Type, str] = ty.record_type(ctx, name, nil, 0);
                        if (res.is_ok()) {
                            sym.resolved_type = res.unwrap_ok();
                        }
                    }
                }
            }
        }

        # create union type shell
        if (kind == ast.NODE_DECL_UNI) {
            val name: str = ast.get_name(decl);
            if (name != nil) {
                val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
                if (sym_opt.is_some()) {
                    val sym: *symbol.Symbol = sym_opt.unwrap();
                    if (sym.resolved_type == nil) {
                        val ctx: *ty.TypeContext = ?sema.types;
                        val res: Result[*ty.Type, str] = ty.union_type(ctx, name, nil, 0);
                        if (res.is_ok()) {
                            sym.resolved_type = res.unwrap_ok();
                        }
                    }
                }
            }
        }

        i = i + 1;
    }

    # second pass: resolve type aliases (def)
    i = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl != nil && decl.kind == ast.NODE_DECL_DEF) {
            if (!resolve_def_type(sema, decl)) {
                success = false;
            }
        }
        i = i + 1;
    }

    # third pass: resolve record/union fields (now all types are known)
    i = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # resolve record field types
        if (kind == ast.NODE_DECL_REC) {
            if (!resolve_record_type(sema, decl)) {
                success = false;
            }
        }

        # resolve union variant types
        if (kind == ast.NODE_DECL_UNI) {
            if (!resolve_union_type(sema, decl)) {
                success = false;
            }
        }

        i = i + 1;
    }

    # fourth pass: resolve function types
    i = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        if (kind == ast.NODE_DECL_FUN) {
            if (!resolve_function_decl(sema, decl)) {
                success = false;
            }
        }

        if (kind == ast.NODE_DECL_EXT) {
            if (!resolve_ext_decl(sema, decl)) {
                success = false;
            }
        }

        if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
            if (!resolve_var_decl_type(sema, decl)) {
                success = false;
            }
        }

        i = i + 1;
    }

    ret success;
}

# resolve_record_type: resolve a record type declaration.
fun resolve_record_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = ast.get_name(decl);
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    val ctx: *ty.TypeContext = ?sema.types;

    # cycle detection
    if (sym.is_being_resolved) {
        report_error_node(sema, decl, "circular type dependency detected");
        ret false;
    }

    # if already resolved, skip
    if (sym.resolved_type != nil && sym.resolved_type.field_count > 0) {
        ret true;
    }

    sym.is_being_resolved = true;

    # create type first to allow self-references (with nil fields)
    var rec_type: *ty.Type = sym.resolved_type;
    if (rec_type == nil) {
        val res: Result[*ty.Type, str] = ty.record_type(ctx, name, nil, 0);
        if (res.is_err()) {
            sym.is_being_resolved = false;
            report_error_node(sema, decl, "failed to create record type");
            ret false;
        }
        rec_type = res.unwrap_ok();
        sym.resolved_type = rec_type;
    }

    # now resolve field types
    # fields are stored in node.children as a *List (cast from *Node)
    val fields_list: *ast.List = decl.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        # empty record
        ret true;
    }

    val field_count: i32 = fields_list.count;

    # allocate Field array
    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, decl, "failed to allocate fields");
        ret false;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    # resolve each field
    var offset: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        # field name is in data
        val field_name: str = ast.get_name(field_node);

        # field type is in children
        val type_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (type_node != nil) {
            field_type = resolve_type(sema, type_node);
        }

        if (field_type == nil) {
            # use error type as placeholder
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        # compute alignment and offset
        var field_align: usize = 1;
        var field_size: usize = 0;
        if (field_type != nil) {
            field_align = field_type.align;
            field_size = field_type.size;
            if (field_align > max_align) {
                max_align = field_align;
            }
        }

        # align offset
        if (field_align > 0) {
            offset = (offset + field_align - 1) & ~(field_align - 1);
        }

        # store field
        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = offset;

        offset = offset + field_size;
        i = i + 1;
    }

    # final padding for struct alignment
    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    # update record type with resolved fields
    rec_type.fields = fields;
    rec_type.field_count = field_count;
    rec_type.size = offset;
    rec_type.align = max_align;

    sym.is_being_resolved = false;
    ret true;
}

# resolve_union_type: resolve a union type declaration.
fun resolve_union_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = ast.get_name(decl);
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    val ctx: *ty.TypeContext = ?sema.types;

    # cycle detection
    if (sym.is_being_resolved) {
        report_error_node(sema, decl, "circular type dependency detected");
        ret false;
    }

    # if already resolved, skip
    if (sym.resolved_type != nil && sym.resolved_type.field_count > 0) {
        ret true;
    }

    sym.is_being_resolved = true;

    # create type first to allow self-references (with nil fields)
    var uni_type: *ty.Type = sym.resolved_type;
    if (uni_type == nil) {
        val res: Result[*ty.Type, str] = ty.union_type(ctx, name, nil, 0);
        if (res.is_err()) {
            sym.is_being_resolved = false;
            report_error_node(sema, decl, "failed to create union type");
            ret false;
        }
        uni_type = res.unwrap_ok();
        sym.resolved_type = uni_type;
    }

    # now resolve variant types
    # variants are stored in node.children as a *List (cast from *Node)
    val fields_list: *ast.List = decl.children::*ast.List;
    if (fields_list == nil || fields_list.count == 0) {
        # empty union
        ret true;
    }

    val field_count: i32 = fields_list.count;

    # allocate Field array
    val fields_res: Result[*ty.Field, allocator.AllocError] = sema.alloc.zalloc[ty.Field](field_count::usize);
    if (fields_res.is_err()) {
        report_error_node(sema, decl, "failed to allocate variants");
        ret false;
    }

    val fields: *ty.Field = fields_res.unwrap_ok();

    # resolve each variant
    var max_size: usize = 0;
    var max_align: usize = 1;
    var i: i32 = 0;

    for (i < field_count) {
        val field_node: *ast.Node = fields_list.nodes[i];
        if (field_node == nil) {
            i = i + 1;
            cnt;
        }

        # variant name is in data
        val field_name: str = ast.get_name(field_node);

        # variant type is in children
        val type_node: *ast.Node = field_node.children;
        var field_type: *ty.Type = nil;

        if (type_node != nil) {
            field_type = resolve_type(sema, type_node);
        }

        if (field_type == nil) {
            # use error type as placeholder
            val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
            if (err_res.is_ok()) {
                field_type = err_res.unwrap_ok();
            }
        }

        # track max size and alignment
        if (field_type != nil) {
            if (field_type.size > max_size) {
                max_size = field_type.size;
            }
            if (field_type.align > max_align) {
                max_align = field_type.align;
            }
        }

        # store variant (all variants at offset 0)
        fields[i].name = field_name;
        fields[i].ty = field_type;
        fields[i].offset = 0;

        i = i + 1;
    }

    # align max_size
    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    # add 8 bytes for tag
    val total_size: usize = max_size + 8;
    if (max_align < 8) {
        max_align = 8;
    }

    # update union type with resolved variants
    uni_type.fields = fields;
    uni_type.field_count = field_count;
    uni_type.size = total_size;
    uni_type.align = max_align;

    sym.is_being_resolved = false;
    ret true;
}

# resolve_def_type: resolve a type alias definition.
fun resolve_def_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = ast.get_name(decl);
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # the aliased type is in children
    val type_node: *ast.Node = decl.children;
    if (type_node == nil) {
        report_error_node(sema, decl, "type alias missing target type");
        ret false;
    }

    val aliased_type: *ty.Type = resolve_type(sema, type_node);
    if (aliased_type == nil) {
        report_error_node(sema, decl, "failed to resolve aliased type");
        ret false;
    }

    sym.resolved_type = aliased_type;
    ret true;
}

# resolve_function_type: resolve a function declaration's type.
fun resolve_function_decl(sema: *Sema, decl: *ast.Node) bool {
    val name: str = ast.get_name(decl);
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();
    val ctx: *ty.TypeContext = ?sema.types;

    # get parameter list from node.extra (stored as *List)
    val params_list: *ast.List = decl.extra::*ast.List;
    var param_count: i32 = 0;
    var param_types: **ty.Type = nil;

    if (params_list != nil && params_list.count > 0) {
        param_count = params_list.count;

        # allocate param type array
        val ptypes_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.zalloc[*ty.Type](param_count::usize);
        if (ptypes_res.is_err()) {
            report_error_node(sema, decl, "failed to allocate param types");
            ret false;
        }

        param_types = ptypes_res.unwrap_ok();

        # resolve each parameter type
        var i: i32 = 0;
        for (i < param_count) {
            val param_node: *ast.Node = params_list.nodes[i];
            if (param_node != nil && param_node.children != nil) {
                param_types[i] = resolve_type(sema, param_node.children);
            }
            if (param_types[i] == nil) {
                # use error type as placeholder
                val err_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_ERROR);
                if (err_res.is_ok()) {
                    param_types[i] = err_res.unwrap_ok();
                }
            }
            i = i + 1;
        }
    }

    # resolve return type from the ret_type field
    var ret_type: *ty.Type = nil;

    if (decl.ret_type != nil) {
        ret_type = resolve_type(sema, decl.ret_type);
    }

    if (ret_type == nil) {
        # default to void
        val void_res: Result[*ty.Type, str] = ty.primitive_type(ctx, ty.TY_VOID);
        if (void_res.is_ok()) {
            ret_type = void_res.unwrap_ok();
        }
    }

    # create function type
    val fn_res: Result[*ty.Type, str] = ty.function_type(ctx, param_types, param_count, ret_type);
    if (fn_res.is_err()) {
        report_error_node(sema, decl, "failed to create function type");
        ret false;
    }

    sym.resolved_type = fn_res.unwrap_ok();
    ret true;
}

# resolve_ext_decl: resolve an external declaration's type.
fun resolve_ext_decl(sema: *Sema, decl: *ast.Node) bool {
    # ext declarations wrap a function signature in children
    val inner: *ast.Node = decl.children;
    if (inner == nil) {
        ret true;  # just a module import
    }

    if (inner.kind == ast.NODE_DECL_FUN) {
        ret resolve_function_decl(sema, inner);
    }

    ret true;
}

# resolve_var_type: resolve a variable/constant declaration's type.
fun resolve_var_decl_type(sema: *Sema, decl: *ast.Node) bool {
    val name: str = ast.get_name(decl);
    if (name == nil) {
        ret false;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.lookup(?sema.symbols, name);
    if (sym_opt.is_none()) {
        ret false;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # declared type is in extra (as type node)
    if (decl.extra != nil) {
        val type_node: *ast.Node = decl.extra::*ast.Node;
        sym.resolved_type = resolve_type(sema, type_node);
    }

    # if no declared type, will be inferred during check pass
    ret true;
}

# check_declarations: third pass - type-check all declarations.
fun check_declarations(sema: *Sema, program: *ast.Node) bool {
    if (program == nil || program.kind != ast.NODE_PROGRAM) {
        ret false;
    }

    val list: *ast.List = ast.get_list(program);
    if (list == nil) {
        ret true;
    }

    var success: bool = true;

    var i: i32 = 0;
    for (i < list.count) {
        val decl: *ast.Node = list.nodes[i];
        if (decl == nil) {
            i = i + 1;
            cnt;
        }

        val kind: ast.NodeKind = decl.kind;

        # check functions
        if (kind == ast.NODE_DECL_FUN) {
            if (!check_function(sema, decl)) {
                success = false;
            }
        }

        # check values
        if (kind == ast.NODE_DECL_VAL || kind == ast.NODE_DECL_VAR) {
            if (!check_var_decl(sema, decl)) {
                success = false;
            }
        }

        # check test blocks (similar to functions)
        if (kind == ast.NODE_DECL_TEST) {
            if (!check_test(sema, decl)) {
                success = false;
            }
        }

        i = i + 1;
    }

    ret success;
}

# check_test: check a test block.
fun check_test(sema: *Sema, decl: *ast.Node) bool {
    # test blocks are like void functions
    val prev_fn: *symbol.Symbol = sema.current_fn;
    val prev_ret: *ty.Type = sema.current_fn_ret;

    sema.current_fn = nil;

    val res: Result[*ty.Type, str] = ty.primitive_type(?sema.types, ty.TY_VOID);
    if (res.is_ok()) {
        sema.current_fn_ret = res.unwrap_ok();
    }

    val push_res: Result[bool, str] = symbol.push_scope(?sema.symbols);
    if (push_res.is_err()) {
        ret false;
    }

    # check test body
    val body: *ast.Node = decl.children;
    if (body != nil) {
        check_stmt(sema, body);
    }

    val pop_res: Result[bool, str] = symbol.pop_scope(?sema.symbols);

    sema.current_fn = prev_fn;
    sema.current_fn_ret = prev_ret;

    ret true;
}

# --- main entry point ---

# analyze: perform semantic analysis on an AST.
# ---
# sema: analyzer context
# root: AST root (program node)
# ret:  Ok(true) on success (may have errors), Err(str) on fatal error
pub fun analyze(sema: *Sema, root: *ast.Node) Result[bool, str] {
    if (sema == nil) {
        ret err[bool, str]("sema is nil");
    }

    if (root == nil) {
        ret err[bool, str]("AST is nil");
    }

    # pass 1: collect top-level declarations
    collect_declarations(sema, root);

    # pass 2: resolve type references
    resolve_types(sema, root);

    # pass 3: type-check expressions and statements
    check_declarations(sema, root);

    # pass 4: control flow validation (TODO)

    ret ok[bool, str](!has_errors(sema));
}

# --- utilities ---

# print_errors: print all errors to stderr.
pub fun print_errors(sema: *Sema) {
    if (sema == nil || sema.errors == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < sema.error_count) {
        val e: *SemaError = ?sema.errors[i];

        # print error location and message
        # format: file:line:col: error: message
        if (sema.file_path != nil) {
            # would need std.io for proper printing
            # for now, just record errors are available via get_error_count
        }

        i = i + 1;
    }
}

# get_error: get error at index.
pub fun get_error(sema: *Sema, idx: i32) *SemaError {
    if (sema == nil || sema.errors == nil || idx < 0 || idx >= sema.error_count) {
        ret nil;
    }
    ret ?sema.errors[idx];
}

# format_error: format an error message with location info.
pub fun format_error(sema: *Sema, e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    # return just the message for now
    # full formatting would need string concatenation
    ret e.message;
}

# get_source_line: extract a specific line from source text.
# ---
# source: full source text
# line:   1-based line number
# ret:    the line content or nil if not found
pub fun get_source_line(source: str, line: i32) str {
    if (source == nil || line < 1) {
        ret nil;
    }

    # find the start of the requested line
    var current_line: i32 = 1;
    var line_start: i32 = 0;
    var i: i32 = 0;
    val len: i32 = source.len()::i32;

    # find start of target line
    for (i < len && current_line < line) {
        if (source.byte_at(i::usize) == '\n') {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) {
        ret nil;
    }

    # find end of line
    var line_end: i32 = line_start;
    for (line_end < len && source.byte_at(line_end::usize) != '\n') {
        line_end = line_end + 1;
    }

    # extract the line (would need substring support)
    # for now, return nil - actual implementation needs string slicing
    ret nil;
}

# format_error_context: format an error with source context.
# ---
# sema: analyzer context
# e:    error to format
# ret:  formatted error string or nil
# note: returns components separately since we can't easily concatenate strings
pub fun get_error_location(e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    # would format as "line:col" but need string formatting
    ret nil;
}

# make_caret_line: create a line with spaces and a caret at the column.
# ---
# col: 1-based column number
# ret: string with spaces followed by '^'
# note: would need string building support
pub fun get_error_col(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.col;
}

# get_error_line: get the line number of an error.
pub fun get_error_line(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.line;
}

# get_error_message: get the error message.
pub fun get_error_message(e: *SemaError) str {
    if (e == nil) {
        ret nil;
    }
    ret e.message;
}

# get_error_pos: get the byte position of an error.
pub fun get_error_pos(e: *SemaError) i32 {
    if (e == nil) {
        ret 0;
    }
    ret e.pos;
}
