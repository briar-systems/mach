# collect_rec_decl: register a record declaration in symbol table.
# ---
# sema: analyzer context
# node: record declaration node
# ret:  none
fun collect_rec_decl(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        report_error_node(sema, node, "record has no name");
        ret;
    }

    # check for duplicate
    val existing_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (existing_opt.is_some()) {
        report_error_node(sema, node, "duplicate type definition");
        ret;
    }

    # create symbol
    val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(name, symbol.SYM_REC);
    if (sym_res.is_err()) {
        report_error_node(sema, node, "failed to create symbol");
        ret;
    }

    val sym: *symbol.Symbol = sym_res.unwrap_ok();
    sym.decl_node = node;
    sym.is_public = node.count > 0;  # node.count indicates public

    # check for generics
    if (node.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.generics;
    }
}

# collect_uni_decl: register a union declaration in symbol table.
# ---
# sema: analyzer context
# node: union declaration node
# ret:  none
fun collect_uni_decl(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        report_error_node(sema, node, "union has no name");
        ret;
    }

    # check for duplicate
    val existing_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (existing_opt.is_some()) {
        report_error_node(sema, node, "duplicate type definition");
        ret;
    }

    # create symbol
    val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(name, symbol.SYM_UNI);
    if (sym_res.is_err()) {
        report_error_node(sema, node, "failed to create symbol");
        ret;
    }

    val sym: *symbol.Symbol = sym_res.unwrap_ok();
    sym.decl_node = node;
    sym.is_public = node.count > 0;  # node.count indicates public

    # check for generics
    if (node.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.generics;
    }
}

# resolve_types: pass 2 - resolve all types.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
fun resolve_types(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.data::*ast.List;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # resolve type for this declaration
        resolve_node_type(sema, node);

        i = i + 1;
    }
}

# resolve_node_type: resolve the type for a declaration node.
# ---
# sema: analyzer context
# node: declaration node
# ret:  none
fun resolve_node_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # type declaration - resolve the underlying type
    if (node.kind == ast.NODE_DECL_DEF) {
        val type_node: *ast.Node = node.get_child(0);
        if (type_node != nil) {
            val t: *ty.Type = resolve_type_expr(sema, type_node);
            if (t != nil) {
                node.ty = t;
                # update symbol's resolved type
                val name: str = node.get_name();
                if (name != nil) {
                    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
                    if (sym_opt.is_some()) {
                        sym_opt.unwrap().resolved_type = t;
                    }
                }
            }
        }
        ret;
    }

    # function declaration - resolve signature
    if (node.kind == ast.NODE_DECL_FUN) {
        val fun_type: *ty.Type = resolve_function_type(sema, node);
        if (fun_type != nil) {
            node.ty = fun_type;
            
            # update symbol's type
            val name2: str = node.get_name();
            if (name2 != nil) {
                val sym_opt2: Option[*symbol.Symbol] = sema.symbols.lookup(name2);
                if (sym_opt2.is_some()) {
                    val sym2: *symbol.Symbol = sym_opt2.unwrap();
                    sym2.resolved_type = fun_type;
                }
            }
        }
        ret;
    }

    # variable/constant declaration - resolve initializer type
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val init_node: *ast.Node = node.extra::*ast.Node;
        if (init_node != nil) {
            val init_type: *ty.Type = resolve_expr_type(sema, init_node);
            if (init_type != nil) {
                node.ty = init_type;
                
            # update symbol's type
            val name: str = node.get_name();
            if (name != nil) {
                val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
                if (sym_opt.is_some()) {
                    val sym: *symbol.Symbol = sym_opt.unwrap();
                    sym.resolved_type = fun_type;
                }
            }
            }
        }
        ret;
    }

    # comptime if - process taken branch for type resolution
    if (node.kind == ast.NODE_COMPTIME_IF) {
        # the taken branch was set during collect_declarations
        val taken: *ast.Node = node.extra::*ast.Node;
        if (taken != nil) {
            resolve_comptime_if_types(sema, taken);
        }
        ret;
    }

    # record declaration - create type and update symbol
    if (node.kind == ast.NODE_DECL_REC) {
        resolve_rec_type(sema, node);
        ret;
    }

    # union declaration - create type and update symbol
    if (node.kind == ast.NODE_DECL_UNI) {
        resolve_uni_type(sema, node);
        ret;
    }

    # pub wrapper - process inner declaration
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.children;
        if (inner != nil) {
            resolve_node_type(sema, inner);
        }
        ret;
    }
}

# resolve_rec_type: resolve types for a record declaration.
# ---
# sema: analyzer context
# node: record declaration node
# ret:  none
fun resolve_rec_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        ret;
    }

    # get symbol
    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (!sym_opt.is_some()) {
        ret;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # if already resolved, skip
    if (sym.resolved_type != nil) {
        ret;
    }

    # if generic, don't resolve fields yet - wait for instantiation
    if (sym.is_generic) {
        # create placeholder generic type
        val gen_res: Result[*ty.Type, str] = ty.generic_type(sema.types, name);
        if (gen_res.is_ok()) {
            sym.resolved_type = gen_res.unwrap_ok();
            node.ty = sym.resolved_type;
        }
        ret;
    }

    # non-generic record: create record type with fields
    # for now, just create an empty record type - field resolution happens elsewhere
    val rec_res: Result[*ty.Type, str] = ty.record_type(sema.types, name, nil, 0);
    if (rec_res.is_ok()) {
        sym.resolved_type = rec_res.unwrap_ok();
        node.ty = sym.resolved_type;
    }
}

# resolve_uni_type: resolve types for a union declaration.
# ---
# sema: analyzer context
# node: union declaration node
# ret:  none
fun resolve_uni_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.get_name();
    if (name == nil) {
        ret;
    }

    # get symbol
    val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (!sym_opt.is_some()) {
        ret;
    }

    val sym: *symbol.Symbol = sym_opt.unwrap();

    # if already resolved, skip
    if (sym.resolved_type != nil) {
        ret;
    }

    # if generic, don't resolve fields yet - wait for instantiation
    if (sym.is_generic) {
        # create placeholder generic type
        val gen_res: Result[*ty.Type, str] = ty.generic_type(sema.types, name);
        if (gen_res.is_ok()) {
            sym.resolved_type = gen_res.unwrap_ok();
            node.ty = sym.resolved_type;
        }
        ret;
    }

    # non-generic union: create union type with variants
    # for now, just create an empty union type - variant resolution happens elsewhere
    val uni_res: Result[*ty.Type, str] = ty.union_type(sema.types, name, nil, 0);
    if (uni_res.is_ok()) {
        sym.resolved_type = uni_res.unwrap_ok();
        node.ty = sym.resolved_type;
    }
}

# maybe_resolve_symbol_type_in_module: resolve a type symbol in its module context if needed.
# ---
# sema: analyzer context
# mod:  module containing the symbol (may be nil for current)
# sym:  symbol to resolve
fun maybe_resolve_symbol_type_in_module(sema: *Sema, mod: *SemaModule, sym: *symbol.Symbol) {
    if (sema == nil || sym == nil) {
        ret;
    }
    if (sym.resolved_type != nil || sym.decl_node == nil) {
        ret;
    }
    if (sym.is_being_resolved) {
        ret;
    }

    sym.is_being_resolved = true;

    # save context
    val saved_module: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;

    if (mod != nil) {
        sema.current_module = mod;
        sema.symbols = mod.table;
        sema.file_path = mod.file_path;
        sema.source = mod.source;
    }

    resolve_node_type(sema, sym.decl_node);

    sym.is_being_resolved = false;

    # restore context
    sema.current_module = saved_module;
    sema.symbols = saved_symbols;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
}

# lookup_type_symbol: look up a type symbol by name, checking local scope and imports.
# ---
# sema: analyzer context
# name: type name (may be dotted like "alias.Type")
# ret:  symbol if found, nil otherwise
fun lookup_type_symbol(sema: *Sema, name: str) *symbol.Symbol {
    if (sema == nil || name == nil) {
        ret nil;
    }

    # check for dotted path (alias.Type)
    var pos: usize = 0;
    var found_dot: bool = false;
    val name_len: usize = name.len();
    var i: usize = 0;
    for (i < name_len) {
        if (name[i] == '.') {
            pos = i;
            found_dot = true;
            brk;
        }
        i = i + 1;
    }
    if (found_dot) {
        if (pos > 0 && sema.current_module != nil) {
            # extract alias and type name
            # alias is name[0..pos], type_name is name[pos+1..]
            # name_len already computed
            
            # find the alias in current module's aliases
            var alias_entry: *ModuleAlias = sema.current_module.aliases;
            for (alias_entry != nil) {
                if (alias_entry.alias != nil) {
                    val alias_len: usize = alias_entry.alias.len();
                    if (alias_len == pos) {
                        # compare alias prefix
                        var match: bool = true;
                        var i: usize = 0;
                        for (i < pos) {
                            if (name[i] != alias_entry.alias[i]) {
                                match = false;
                                brk;
                            }
                            i = i + 1;
                        }
                        
                        if (match) {
                            # found matching alias - look up type in that module
                            val target_mod: *SemaModule = alias_entry.module;
                            if (target_mod != nil && target_mod.table != nil) {
                                # extract type name after the dot
                                val type_start: usize = pos + 1;
                                val type_len: usize = name_len - type_start;
                                
                                # look up in that module's root scope
                                val root: *symbol.Scope = target_mod.table.root;
                                if (root != nil) {
                                    var si: i32 = 0;
                                    var fallback: *symbol.Symbol = nil;
                                    for (si < root.symbol_count) {
                                        val sym: *symbol.Symbol = ?root.symbols[si::usize];
                                        if (sym.name != nil) {
                                            val sym_len: usize = sym.name.len();
                                            if (sym_len == type_len) {
                                                # compare type name
                                                var tmatch: bool = true;
                                                var ti: usize = 0;
                                                for (ti < type_len) {
                                                    if (name[type_start + ti] != sym.name[ti]) {
                                                        tmatch = false;
                                                        brk;
                                                    }
                                                    ti = ti + 1;
                                                }
                                                if (tmatch && (sym.kind == symbol.SYM_TYPE || 
                                                               sym.kind == symbol.SYM_REC || 
                                                               sym.kind == symbol.SYM_UNI)) {
                                                    if (sym.is_public) {
                                                        maybe_resolve_symbol_type_in_module(sema, target_mod, sym);
                                                        ret sym;
                                                    }
                                                    if (fallback == nil) {
                                                        fallback = sym;
                                                    }
                                                }
                                            }
                                        }
                                        si = si + 1;
                                    }
                                    if (fallback != nil) {
                                        maybe_resolve_symbol_type_in_module(sema, target_mod, fallback);
                                        ret fallback;
                                    }
                                }
                            }
                            ret nil;  # alias found but type not found
                        }
                    }
                }
                alias_entry = alias_entry.next;
            }
        }
        # dotted name but alias not found - fall through to local lookup
    }

    # unqualified type: check local symbol table
    val local_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
    if (local_opt.is_some()) {
        val sym: *symbol.Symbol = local_opt.unwrap();
        if (sym.kind == symbol.SYM_TYPE || sym.kind == symbol.SYM_REC || sym.kind == symbol.SYM_UNI) {
            maybe_resolve_symbol_type_in_module(sema, sema.current_module, sym);
            ret sym;
        }
    }

    # check unaliased imports (use foo.bar; brings public symbols into scope)
    if (sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                val root: *symbol.Scope = imp.module.table.root;
                if (root != nil) {
                    var i: i32 = 0;
                    for (i < root.symbol_count) {
                        val sym: *symbol.Symbol = ?root.symbols[i::usize];
                        if (sym.name != nil && sym.is_public && sym.name.equals(name)) {
                            if (sym.kind == symbol.SYM_TYPE || 
                                sym.kind == symbol.SYM_REC || 
                                sym.kind == symbol.SYM_UNI) {
                                maybe_resolve_symbol_type_in_module(sema, imp.module, sym);
                                ret sym;
                            }
                        }
                        i = i + 1;
                    }
                }
            }
            imp = imp.next;
        }
    }

    ret nil;
}

# resolve_type_expr: resolve a type expression to a Type.
# ---
# sema: analyzer context
# node: type expression node
# ret:  resolved type or nil
fun resolve_type_expr(sema: *Sema, node: *ast.Node) *ty.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # named type (primitive or typedef)
    if (node.kind == ast.NODE_TYPE_NAME) {
        val name: str = node.get_name();
        if (name != nil) {
            # lookup primitive type
            if (name.equals("void")) { ret ty.get_void(sema.types); }
            if (name.equals("bool")) { ret ty.get_bool(sema.types); }
            if (name.equals("u8")) { ret ty.get_u8(sema.types); }
            if (name.equals("u16")) { ret ty.get_u16(sema.types); }
            if (name.equals("u32")) { ret ty.get_u32(sema.types); }
            if (name.equals("u64")) { ret ty.get_u64(sema.types); }
            if (name.equals("i8")) { ret ty.get_i8(sema.types); }
            if (name.equals("i16")) { ret ty.get_i16(sema.types); }
            if (name.equals("i32")) { ret ty.get_i32(sema.types); }
            if (name.equals("i64")) { ret ty.get_i64(sema.types); }
            if (name.equals("f32")) { ret ty.get_f32(sema.types); }
            if (name.equals("f64")) { ret ty.get_f64(sema.types); }
            if (name.equals("ptr")) { ret ty.get_ptr(sema.types); }
            if (name.equals("usize")) { ret ty.get_usize(sema.types); }
            if (name.equals("isize")) { ret ty.get_isize(sema.types); }
            if (name.equals("str")) { ret ty.get_str(sema.types); }

            # lookup type symbol (local and imports)
            val sym: *symbol.Symbol = lookup_type_symbol(sema, name);
            if (sym != nil) {
                # if type is already resolved, return it
                if (sym.resolved_type != nil) {
                    ret sym.resolved_type;
                }
                # try to resolve on-demand from decl_node (for forward references)
                if (sym.decl_node != nil && sym.decl_node.kind == ast.NODE_DECL_DEF) {
                    val inner: *ast.Node = sym.decl_node.get_child(0);
                    if (inner != nil) {
                        val t: *ty.Type = resolve_type_expr(sema, inner);
                        if (t != nil) {
                            sym.resolved_type = t;
                            sym.decl_node.ty = t;
                            ret t;
                        }
                    }
                }
                # for rec/uni, check if decl_node.ty is set
                if (sym.decl_node != nil && sym.decl_node.ty != nil) {
                    sym.resolved_type = sym.decl_node.ty;
                    ret sym.decl_node.ty;
                }
            }

            report_error_node(sema, node, "undefined type");
        }
        ret nil;
    }

    # pointer type
    if (node.kind == ast.NODE_TYPE_PTR || node.kind == ast.NODE_TYPE_REF) {
        val elem_type: *ty.Type = resolve_type_expr(sema, node.get_child(0));
        if (elem_type != nil) {
            val is_mutable: bool = node.kind == ast.NODE_TYPE_PTR;
            val ptr_res: Result[*ty.Type, str] = ty.pointer_type(sema.types, elem_type, is_mutable);
            if (ptr_res.is_ok()) {
                ret ptr_res.unwrap_ok();
            }
        }
        ret nil;
    }

    # array type
    if (node.kind == ast.NODE_TYPE_ARRAY) {
        val elem_type: *ty.Type = resolve_type_expr(sema, node.get_child(0));
        val size_node: *ast.Node = node.get_child(1);
        
        var size: usize = 0;
        if (size_node != nil && size_node.kind == ast.NODE_EXPR_LIT_INT) {
            size = size_node.get_int_value()::usize;
        }
        
        if (elem_type != nil && size > 0) {
            val arr_res: Result[*ty.Type, str] = ty.array_type(sema.types, elem_type, size);
            if (arr_res.is_ok()) {
                ret arr_res.unwrap_ok();
            }
        }
        ret nil;
    }

    # function type
    if (node.kind == ast.NODE_TYPE_FUN) {
        ret resolve_function_type(sema, node);
    }

    ret nil;
}

# resolve_function_type: resolve a function type.
# ---
# sema: analyzer context
# node: function type or declaration node
# ret:  function type or nil
fun resolve_function_type(sema: *Sema, node: *ast.Node) *ty.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # check if this is a method on a generic type - if so, bind type parameters
    var pushed_scope: bool = false;
    if (node.receiver != nil) {
        pushed_scope = bind_method_type_params(sema, node.receiver);
    }

    # get return type
    var ret_type: *ty.Type = ty.get_void(sema.types);
    if (node.ret_type != nil) {
        val rt: *ty.Type = resolve_type_expr(sema, node.ret_type);
        if (rt != nil) {
            ret_type = rt;
        }
    }

    # get parameter types
    var param_types: **ty.Type = nil;
    var param_count: i32 = 0;
    
    val params: *ast.List = node.extra::*ast.List;
    if (params != nil && params.count > 0) {
        val pt_res: Result[**ty.Type, allocator.AllocError] = sema.alloc.alloc[*ty.Type](params.count::usize);
        if (pt_res.is_ok()) {
            param_types = pt_res.unwrap_ok();
            param_count = params.count;
            
            var i: i32 = 0;
            for (i < params.count) {
                val param: *ast.Node = params.nodes[i];
                if (param != nil) {
                    val pt: *ty.Type = resolve_type_expr(sema, param);
                    if (pt != nil) {
                        param_types[i] = pt;
                    } or {
                        param_types[i] = ty.get_void(sema.types);
                    }
                }
                i = i + 1;
            }
        }
    }

    # pop the method type parameter scope if we pushed one
    if (pushed_scope) {
        sema.symbols.pop_scope();
    }

    # create function type
    val fun_res: Result[*ty.Type, str] = ty.function_type(sema.types, param_types, param_count, ret_type);
    if (param_types != nil) {
        sema.alloc.free[*ty.Type](param_types, param_count::usize);
    }
    
    if (fun_res.is_ok()) {
        ret fun_res.unwrap_ok();
    }
    ret nil;
}

# bind_method_type_params: for a method on a generic type, bind type parameters in scope.
# ---
# sema:     analyzer context
# receiver: receiver node (NODE_PARAM with type as children)
# ret:      true if a scope was pushed, false otherwise
fun bind_method_type_params(sema: *Sema, receiver: *ast.Node) bool {
    if (sema == nil || receiver == nil) {
        ret false;
    }

    # get the receiver type node
    var recv_type: *ast.Node = receiver.children;
    if (recv_type == nil) {
        ret false;
    }

    # unwrap pointer/ref types to get base type
    for (recv_type != nil && (recv_type.kind == ast.NODE_TYPE_PTR || recv_type.kind == ast.NODE_TYPE_REF)) {
        recv_type = recv_type.get_child(0);
    }

    if (recv_type == nil || recv_type.kind != ast.NODE_TYPE_NAME) {
        ret false;
    }

    # check if the receiver type has generic args (e.g., Option[T])
    # recv_type.children is a NODE_GENERIC node containing the args list
    val generic_args_node: *ast.Node = recv_type.children;
    if (generic_args_node == nil || generic_args_node.kind != ast.NODE_GENERIC) {
        ret false;
    }

    # get the generic args list from the NODE_GENERIC node
    val args_list: *ast.List = generic_args_node.children::*ast.List;
    if (args_list == nil || args_list.count == 0) {
        ret false;
    }

    # look up the receiver type's declaration to get formal params
    val recv_name: str = recv_type.get_name();
    if (recv_name == nil) {
        ret false;
    }

    val sym: *symbol.Symbol = lookup_type_symbol(sema, recv_name);
    if (sym == nil || !sym.is_generic || sym.decl_node == nil) {
        ret false;
    }

    # get formal generic parameters from the declaration
    val formal_generics: *ast.Node = sym.decl_node.generics;
    if (formal_generics == nil) {
        ret false;
    }

    val formal_list: *ast.List = formal_generics.children::*ast.List;
    if (formal_list == nil || formal_list.count != args_list.count) {
        ret false;
    }

    # push a new scope for type parameter bindings
    val push_res: Result[bool, str] = sema.symbols.push_scope();
    if (push_res.is_err()) {
        ret false;
    }

    # bind each actual arg name to a type parameter symbol
    # e.g., for Option[T], bind "T" as a type symbol with a generic param type
    var i: i32 = 0;
    for (i < args_list.count) {
        val actual: *ast.Node = args_list.nodes[i];
        if (actual != nil && actual.kind == ast.NODE_TYPE_NAME) {
            val param_name: str = actual.get_name();
            if (param_name != nil) {
                # create a type symbol for this parameter
                val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, symbol.SYM_TYPE);
                if (sym_res.is_ok()) {
                    val param_sym: *symbol.Symbol = sym_res.unwrap_ok();
                    # create a generic parameter type for this binding
                    val gen_res: Result[*ty.Type, str] = ty.generic_param_type(sema.types, param_name);
                    if (gen_res.is_ok()) {
                        param_sym.resolved_type = gen_res.unwrap_ok();
                    }
                }
            }
        }
        i = i + 1;
    }

    ret true;
}

# resolve_expr_type: infer the type of an expression.
# ---
# sema: analyzer context
# node: expression node
# ret:  inferred type or nil
fun resolve_expr_type(sema: *Sema, node: *ast.Node) *ty.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # if node already has a type, return it
    if (node.ty != nil) {
        ret node.ty;
    }

    # integer literal - default to i64
    if (node.kind == ast.NODE_EXPR_LIT_INT) {
        node.ty = ty.get_i64(sema.types);
        ret node.ty;
    }

    # string literal
    if (node.kind == ast.NODE_EXPR_LIT_STR) {
        node.ty = ty.get_str(sema.types);
        ret node.ty;
    }

    # boolean literal
    if (node.kind == ast.NODE_EXPR_LIT_BOOL) {
        node.ty = ty.get_bool(sema.types);
        ret node.ty;
    }

    # identifier - lookup symbol type
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.get_name();
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.symbols.lookup(name);
            if (sym_opt.is_some()) {
                val sym: *symbol.Symbol = sym_opt.unwrap();
                if (sym.resolved_type != nil) {
                    node.ty = sym.resolved_type;
                    ret node.ty;
                }
            }
            report_error_node(sema, node, "undefined identifier");
        }
        ret nil;
    }

    # binary expression
    if (node.kind == ast.NODE_EXPR_BINARY) {
        val lhs_type: *ty.Type = resolve_expr_type(sema, node.get_child(0));
        val rhs_type: *ty.Type = resolve_expr_type(sema, node.get_child(1));
        
        if (lhs_type != nil) {
            node.ty = lhs_type;
            ret node.ty;
        }
        if (rhs_type != nil) {
            node.ty = rhs_type;
            ret node.ty;
        }
        ret nil;
    }

    # unary expression
    if (node.kind == ast.NODE_EXPR_UNARY) {
        val operand_type: *ty.Type = resolve_expr_type(sema, node.get_child(0));
        if (operand_type != nil) {
            node.ty = operand_type;
            ret node.ty;
        }
        ret nil;
    }

    # function call
    if (node.kind == ast.NODE_EXPR_CALL) {
        val callee: *ast.Node = node.get_child(0);
        if (callee != nil) {
            val callee_type: *ty.Type = resolve_expr_type(sema, callee);
            if (callee_type != nil && callee_type.kind == ty.TY_FUN) {
                node.ty = callee_type.ret_type;
                ret node.ty;
            }
        }
        ret nil;
    }

    # address-of
    if (node.kind == ast.NODE_EXPR_ADDR) {
        val operand_type: *ty.Type = resolve_expr_type(sema, node.get_child(0));
        if (operand_type != nil) {
            val ptr_res: Result[*ty.Type, str] = ty.pointer_type(sema.types, operand_type, true);
            if (ptr_res.is_ok()) {
                node.ty = ptr_res.unwrap_ok();
                ret node.ty;
            }
        }
        ret nil;
    }

    # dereference
    if (node.kind == ast.NODE_EXPR_DEREF) {
        val operand_type: *ty.Type = resolve_expr_type(sema, node.get_child(0));
        if (operand_type != nil && operand_type.kind == ty.TY_POINTER) {
            node.ty = operand_type.inner;
            ret node.ty;
        }
        ret nil;
    }

    # nil
    if (node.kind == ast.NODE_EXPR_LIT_NIL) {
        node.ty = ty.get_nil(sema.types);
        ret node.ty;
    }

    ret nil;
}

# analyze_functions: pass 3 - analyze function bodies.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
fun analyze_functions(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.data::*ast.List;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # analyze function body
        if (node.kind == ast.NODE_DECL_FUN) {
            analyze_function(sema, node);
        }

        # comptime if - analyze functions in taken branch
        if (node.kind == ast.NODE_COMPTIME_IF) {
            val taken: *ast.Node = node.extra::*ast.Node;
            if (taken != nil) {
                analyze_comptime_if_functions(sema, taken);
            }
        }

        i = i + 1;
    }
}

# analyze_comptime_if_functions: analyze functions in a $if taken branch.
# ---
# sema: analyzer context
# body: taken branch body node
# ret:  none
fun analyze_comptime_if_functions(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    # body should be a block node
    if (body.kind != ast.NODE_STMT_BLOCK) {
        # single declaration
        if (body.kind == ast.NODE_DECL_FUN) {
            analyze_function(sema, body);
        }
        if (body.kind == ast.NODE_COMPTIME_IF) {
            val taken: *ast.Node = body.extra::*ast.Node;
            if (taken != nil) {
                analyze_comptime_if_functions(sema, taken);
            }
        }
        ret;
    }

    # get declarations from block
    val decls: *ast.List = body.data::*ast.List;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            if (node.kind == ast.NODE_DECL_FUN) {
                analyze_function(sema, node);
            }
            if (node.kind == ast.NODE_COMPTIME_IF) {
                val taken: *ast.Node = node.extra::*ast.Node;
                if (taken != nil) {
                    analyze_comptime_if_functions(sema, taken);
                }
            }
        }
        i = i + 1;
    }
}

# analyze_function: analyze a function body.
# ---
# sema: analyzer context
# node: function declaration node
# ret:  none
fun analyze_function(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # set current function
    sema.current_fn = node;
    
    # get function return type
    if (node.ty != nil && node.ty.kind == ty.TY_FUN) {
        sema.current_fn_ret = node.ty.ret_type;
    } or {
        sema.current_fn_ret = ty.get_void(sema.types);
    }

    # create new scope for function
    val push_res: Result[bool, str] = push_scope(sema);
    if (push_res.is_err()) {
        report_error_node(sema, node, "failed to create function scope");
        ret;
    }

    # add parameters to scope
    val params: *ast.List = node.extra::*ast.List;
    if (params != nil) {
        var i: i32 = 0;
        for (i < params.count) {
            val param: *ast.Node = params.nodes[i];
            if (param != nil) {
                val param_name: str = param.get_name();
                if (param_name != nil) {
                    var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
                    if (node.kind == ast.NODE_DECL_VAR) {
                        sym_kind = symbol.SYM_VAR;
                    }
                    val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(param_name, sym_kind);
                    if (sym_res.is_ok()) {
                        val sym: *symbol.Symbol = sym_res.unwrap_ok();
                        sym.resolved_type = param.ty;
                        sym.decl_node = param;
                    }
                }
            }
            i = i + 1;
        }
    }

    # analyze function body
    val body: *ast.Node = node.get_child(0);
    if (body != nil) {
        analyze_stmt(sema, body);
    }

    # pop function scope
    pop_scope(sema);

    # clear current function
    sema.current_fn = nil;
    sema.current_fn_ret = nil;
}

# analyze_stmt: analyze a statement.
# ---
# sema: analyzer context
# node: statement node
# ret:  none
fun analyze_stmt(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # block statement
    if (node.kind == ast.NODE_STMT_BLOCK) {
        # create new scope for block
        val push_res: Result[bool, str] = push_scope(sema);
        if (push_res.is_ok()) {
            val stmts: *ast.List = node.data::*ast.List;
            if (stmts != nil) {
                var i: i32 = 0;
                for (i < stmts.count) {
                    analyze_stmt(sema, stmts.nodes[i]);
                    i = i + 1;
                }
            }
            pop_scope(sema);
        }
        ret;
    }

    # expression statement
    if (node.kind == ast.NODE_STMT_EXPR) {
        val expr: *ast.Node = node.get_child(0);
        if (expr != nil) {
            resolve_expr_type(sema, expr);
        }
        ret;
    }

    # variable declaration
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val name: str = node.get_name();
        val init: *ast.Node = node.extra::*ast.Node;
        
        if (init != nil) {
            val init_type: *ty.Type = resolve_expr_type(sema, init);
            if (init_type != nil) {
                node.ty = init_type;
            }
        }
        
        if (name != nil) {
            var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
            if (node.kind == ast.NODE_DECL_VAR) {
                sym_kind = symbol.SYM_VAR;
            }
            val sym_res: Result[*symbol.Symbol, str] = sema.symbols.define(name, sym_kind);
            if (sym_res.is_ok()) {
                val sym: *symbol.Symbol = sym_res.unwrap_ok();
                sym.resolved_type = node.ty;
                sym.decl_node = node;
            }
        }
        ret;
    }

    # return statement
    if (node.kind == ast.NODE_STMT_RET) {
        val ret_expr: *ast.Node = node.get_child(0);
        if (ret_expr != nil) {
            val ret_type: *ty.Type = resolve_expr_type(sema, ret_expr);
            # check against function return type
            if (sema.current_fn_ret != nil && ret_type != nil) {
                if (!ty.types_equal(sema.current_fn_ret, ret_type)) {
                    report_error_node(sema, node, "return type mismatch");
                }
            }
        } or {
            # void return - check function returns void
            if (sema.current_fn_ret != nil && sema.current_fn_ret.kind != ty.TY_VOID) {
                report_error_node(sema, node, "missing return value");
            }
        }
        ret;
    }

    # if statement
    if (node.kind == ast.NODE_STMT_IF) {
        val cond: *ast.Node = node.get_child(0);
        if (cond != nil) {
            val cond_type: *ty.Type = resolve_expr_type(sema, cond);
            # condition should be boolean or integer
            if (cond_type != nil && cond_type.kind != ty.TY_BOOL && !cond_type.is_integer()) {
                report_error_node(sema, cond, "condition must be boolean or integer");
            }
        }
        
        val then_stmt: *ast.Node = node.get_child(1);
        if (then_stmt != nil) {
            analyze_stmt(sema, then_stmt);
        }
        
        val else_stmt: *ast.Node = node.get_child(2);
        if (else_stmt != nil) {
            analyze_stmt(sema, else_stmt);
        }
        ret;
    }

    # while/for loop
    if (node.kind == ast.NODE_STMT_FOR) {
        val cond: *ast.Node = node.get_child(0);
        if (cond != nil) {
            val cond_type: *ty.Type = resolve_expr_type(sema, cond);
            if (cond_type != nil && cond_type.kind != ty.TY_BOOL && !cond_type.is_integer()) {
                report_error_node(sema, cond, "loop condition must be boolean or integer");
            }
        }
        
        val body: *ast.Node = node.get_child(1);
        if (body != nil) {
            analyze_stmt(sema, body);
        }
        ret;
    }

    # assignment
    if (node.kind == ast.NODE_STMT_EXPR) {
        val lhs: *ast.Node = node.get_child(0);
        val rhs: *ast.Node = node.get_child(1);
        
        if (lhs != nil && rhs != nil) {
            val lhs_type: *ty.Type = resolve_expr_type(sema, lhs);
            val rhs_type: *ty.Type = resolve_expr_type(sema, rhs);
            
            if (lhs_type != nil && rhs_type != nil) {
                if (!ty.types_equal(lhs_type, rhs_type)) {
                    # check if types are compatible
                    if (!ty.can_assign(rhs_type, lhs_type)) {
                        report_error_node(sema, node, "type mismatch in assignment");
                    }
                }
            }
        }
        ret;
    }

    # comptime if ($if) - statement context
    if (node.kind == ast.NODE_COMPTIME_IF) {
        process_comptime_if(sema, node, false);
        ret;
    }
}

# --- module resolution helpers ---

# build_file_from_root: build file path from base directory and module path rest.
# ---
# sema:     analyzer context (for allocator)
# base_dir: base directory path
# rest:     module path after prefix (e.g., "cli.main" -> "cli/main.mach")
# ret:      file path or nil on error
fun build_file_from_root(sema: *Sema, base_dir: str, rest: str) str {
    if (sema == nil || base_dir == nil) {
        ret nil;
    }

    # handle empty rest (just the module prefix itself)
    if (rest == nil || rest.len() == 0) {
        # just base_dir + ".mach" - but this is usually not valid
        ret nil;
    }

    val base_len: usize = base_dir.len();
    val rest_len: usize = rest.len();
    # base + '/' + rest (with dots as slashes) + ".mach" + '\0'
    val total_len: usize = base_len + 1 + rest_len + 5 + 1;

    val buf_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total_len);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy base_dir
    var i: usize = 0;
    for (i < base_len) {
        buf[pos] = base_dir[i];
        pos = pos + 1;
        i = i + 1;
    }

    # add separator
    buf[pos] = 47; # '/'
    pos = pos + 1;

    # copy rest, replacing dots with slashes
    i = 0;
    for (i < rest_len) {
        val c: u8 = rest[i];
        if (c == 46) { # '.'
            buf[pos] = 47; # '/'
        } or {
            buf[pos] = c;
        }
        pos = pos + 1;
        i = i + 1;
    }

    # append ".mach"
    buf[pos] = 46; pos = pos + 1;     # '.'
    buf[pos] = 109; pos = pos + 1;    # 'm'
    buf[pos] = 97; pos = pos + 1;     # 'a'
    buf[pos] = 99; pos = pos + 1;     # 'c'
    buf[pos] = 104; pos = pos + 1;    # 'h'
    buf[pos] = 0;                      # null terminator

    ret buf::&u8;
}

# load_dep_project_id: load a dependency's project id from its mach.toml.
# ---
# sema:     analyzer context
# dep_name: dependency directory name
# ret:      project id or nil if not found
fun load_dep_project_id(sema: *Sema, dep_name: str) str {
    if (sema == nil || sema.dep_root == nil || dep_name == nil) {
        ret nil;
    }

    # build path: dep_root/dep_name/mach.toml
    val dep_root_len: usize = sema.dep_root.len();
    val dep_name_len: usize = dep_name.len();
    val toml_len: usize = 10; # "/mach.toml"
    val total: usize = dep_root_len + 1 + dep_name_len + toml_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](total);
    if (buf_res.is_err()) {
        ret nil;
    }

    val buf: *u8 = buf_res.unwrap_ok();
    var pos: usize = 0;

    # copy dep_root
    var i: usize = 0;
    for (i < dep_root_len) {
        buf[pos] = sema.dep_root[i];
        pos = pos + 1;
        i = i + 1;
    }

    buf[pos] = 47; pos = pos + 1; # '/'

    # copy dep_name
    i = 0;
    for (i < dep_name_len) {
        buf[pos] = dep_name[i];
        pos = pos + 1;
        i = i + 1;
    }

    # copy "/mach.toml"
    buf[pos] = 47; pos = pos + 1;   # '/'
    buf[pos] = 109; pos = pos + 1;  # 'm'
    buf[pos] = 97; pos = pos + 1;   # 'a'
    buf[pos] = 99; pos = pos + 1;   # 'c'
    buf[pos] = 104; pos = pos + 1;  # 'h'
    buf[pos] = 46; pos = pos + 1;   # '.'
    buf[pos] = 116; pos = pos + 1;  # 't'
    buf[pos] = 111; pos = pos + 1;  # 'o'
    buf[pos] = 109; pos = pos + 1;  # 'm'
    buf[pos] = 108; pos = pos + 1;  # 'l'
    buf[pos] = 0;

    val config_path: str = buf::&u8;

    # load the config
    val cfg_res: Result[config.Config, str] = config.load(config_path, sema.alloc);
    if (cfg_res.is_err()) {
        ret nil;
    }

    val cfg: config.Config = cfg_res.unwrap_ok();
    ret cfg.id;
}

# resolve_module_path: resolve a module path to a file path.
# ---
# sema:        analyzer context
# module_path: module path (e.g., "std.filesystem")
# ret:         file path or nil if not found
fun resolve_module_path(sema: *Sema, module_path: str) str {
    if (sema == nil || module_path == nil) {
        ret nil;
    }

    val mod_len: usize = module_path.len();
    if (mod_len == 0) {
        ret nil;
    }

    # 1) check project_id -> src_root mapping
    if (sema.project_id != nil && sema.src_root != nil) {
        val id_len: usize = sema.project_id.len();
        if (module_path.starts_with(sema.project_id)) {
            # check if it's followed by '.' or end of string
            if (mod_len == id_len || (mod_len > id_len && module_path[id_len] == 46)) {
                # get the rest after the prefix
                var rest: str = nil;
                if (mod_len > id_len) {
                    rest = (module_path::usize + id_len + 1)::str;  # skip prefix and dot
                }
                ret build_file_from_root(sema, sema.src_root, rest);
            }
        }
    }

    # 2) check dependencies
    if (sema.deps != nil && sema.dep_count > 0 && sema.dep_root != nil) {
        var i: i32 = 0;
        for (i < sema.dep_count) {
            # deps is *Dep (array), so sema.deps[i] gives us Dep
            val dep_name: str = sema.deps[i].name;
            if (dep_name == nil) {
                i = i + 1;
                cnt;
            }

            # load the dependency's project id from its mach.toml
            val dep_project_id: str = load_dep_project_id(sema, dep_name);
            if (dep_project_id == nil) {
                i = i + 1;
                cnt;
            }

            val dep_id_len: usize = dep_project_id.len();
            if (module_path.starts_with(dep_project_id)) {
                if (mod_len == dep_id_len || (mod_len > dep_id_len && module_path[dep_id_len] == 46)) {
                    # get the rest after the prefix
                    var rest: str = nil;
                    if (mod_len > dep_id_len) {
                        rest = (module_path::usize + dep_id_len + 1)::str;
                    }

                    # build base dir: dep_root/dep_name/src (default to "src")
                    val dep_root_len: usize = sema.dep_root.len();
                    val dep_name_len: usize = dep_name.len();
                    val src_dir: str = "src";
                    val src_len: usize = 3;
                    val base_total: usize = dep_root_len + 1 + dep_name_len + 1 + src_len + 1;

                    val base_res: Result[*u8, allocator.AllocError] = sema.alloc.alloc[u8](base_total);
                    if (base_res.is_err()) {
                        i = i + 1;
                        cnt;
                    }

                    val base_buf: *u8 = base_res.unwrap_ok();
                    var pos: usize = 0;

                    # copy dep_root
                    var j: usize = 0;
                    for (j < dep_root_len) {
                        base_buf[pos] = sema.dep_root[j];
                        pos = pos + 1;
                        j = j + 1;
                    }

                    base_buf[pos] = 47; pos = pos + 1; # '/'

                    # copy dep_name
                    j = 0;
                    for (j < dep_name_len) {
                        base_buf[pos] = dep_name[j];
                        pos = pos + 1;
                        j = j + 1;
                    }

                    base_buf[pos] = 47; pos = pos + 1; # '/'

                    # copy "src"
                    base_buf[pos] = 115; pos = pos + 1; # 's'
                    base_buf[pos] = 114; pos = pos + 1; # 'r'
                    base_buf[pos] = 99; pos = pos + 1;  # 'c'
                    base_buf[pos] = 0;

                    val base_dir: str = base_buf::&u8;
                    ret build_file_from_root(sema, base_dir, rest);
                }
            }

            i = i + 1;
        }
    }

    ret nil;
}

# has_module_resolution: check if module resolution is configured.
# ---
# sema: analyzer context
# ret:  true if module roots are configured
fun has_module_resolution(sema: *Sema) bool {
    if (sema == nil) {
        ret false;
    }
    # have project mapping
    if (sema.project_id != nil && sema.src_root != nil) {
        ret true;
    }
    # have dependencies
    if (sema.deps != nil && sema.dep_count > 0 && sema.dep_root != nil) {
        ret true;
    }
    ret false;
}

# set_module_roots: set project context for module import resolution.
# ---
# sema:       analyzer context
# project_id: project identifier for module path prefix
# src_root:   source root directory path
# dep_root:   dependency root directory path
# deps:       array of dependency configurations
# dep_count:  number of dependencies
# ret:        none
pub fun set_module_roots(sema: *Sema, project_id: str, src_root: str, dep_root: str, deps: *config.Dep, dep_count: i32) {
    if (sema == nil) {
        ret;
    }
    sema.project_id = project_id;
    sema.src_root = src_root;
    sema.dep_root = dep_root;
    sema.deps = deps;
    sema.dep_count = dep_count;
}

# load_module: load a module by path.
# ---
# sema: analyzer context
# path: module path (e.g., "mach.cli.main")
# ret:  loaded module or nil
pub fun load_module(sema: *Sema, mod_path: str) *SemaModule {
    if (sema == nil || mod_path == nil) {
        ret nil;
    }

    # check if already loaded
    var existing: *SemaModule = sema.modules;
    for (existing != nil) {
        if (existing.path != nil && existing.path.equals(mod_path)) {
            ret existing;
        }
        existing = existing.next;
    }

    # resolve module path to file path
    val file_path: str = resolve_module_path(sema, mod_path);
    if (file_path == nil) {
        ret nil;
    }

    # read the source file
    val source_res: Result[str, str] = utilfs.read_file(file_path, sema.alloc);
    if (source_res.is_err()) {
        ret nil;
    }

    val source: str = source_res.unwrap_ok();

    # parse the source
    var p: parser.Parser = parser.init(source, sema.alloc);

    val parse_res: Result[*ast.Node, str] = p.parse_program();
    if (parse_res.is_err()) {
        p.deinit();
        ret nil;
    }

    val mod_ast: *ast.Node = parse_res.unwrap_ok();

    if (p.had_error || mod_ast == nil) {
        p.deinit();
        ret nil;
    }

    # create the module record
    val mod_res: Result[*SemaModule, allocator.AllocError] = sema.alloc.alloc[SemaModule](1);
    if (mod_res.is_err()) {
        p.deinit();
        ret nil;
    }

    val mod: *SemaModule = mod_res.unwrap_ok();
    mod.path = mod_path;
    mod.file_path = file_path;
    mod.source = source;
    mod.ast = mod_ast;
    mod.is_analyzed = false;
    mod.aliases = nil;
    mod.imports = nil;
    mod.table = nil;

    # add to module list (prepend)
    mod.next = sema.modules;
    sema.modules = mod;
    sema.module_count = sema.module_count + 1;

    # save current context
    val saved_module: *SemaModule = sema.current_module;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;
    val saved_symbols: *symbol.Table = sema.symbols;

    # create a new symbol table for this module
    val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
    if (table_res.is_err()) {
        p.deinit();
        ret nil;
    }

    # allocate space for the table and copy
    val table_ptr_res: Result[*symbol.Table, allocator.AllocError] = sema.alloc.alloc[symbol.Table](1);
    if (table_ptr_res.is_err()) {
        p.deinit();
        ret nil;
    }
    val table_ptr: *symbol.Table = table_ptr_res.unwrap_ok();
    @table_ptr = table_res.unwrap_ok();

    # store table on module for cross-module lookups
    mod.table = table_ptr;

    # set module context
    sema.current_module = mod;
    sema.file_path = file_path;
    sema.source = source;
    sema.symbols = table_ptr;

    # analyze the module: pass 1 - collect declarations
    collect_declarations(sema, mod_ast);

    # analyze the module: pass 2 - resolve types
    resolve_types(sema, mod_ast);

    # mark as analyzed
    mod.is_analyzed = true;

    # restore context
    sema.current_module = saved_module;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
    sema.symbols = saved_symbols;

    p.deinit();
    ret mod;
}

# lookup_module_alias: lookup an aliased import.
# ---
# sema:  analyzer context
# alias: alias name
# ret:   module or nil
pub fun lookup_module_alias(sema: *Sema, alias: str) *SemaModule {
    if (sema == nil || alias == nil) {
        ret nil;
    }

    var mod: *SemaModule = sema.modules;
    for (mod != nil) {
        var ma: *ModuleAlias = mod.aliases;
        for (ma != nil) {
            if (ma.alias != nil && ma.alias.equals(alias)) {
                ret ma.module;
            }
            ma = ma.next;
        }
        mod = mod.next;
    }

    ret nil;
}

# deinit: cleanup sema resources.
# ---
# sema: analyzer context
# ret:  none
pub fun deinit(sema: *Sema) {
    if (sema == nil) {
        ret;
    }

    # cleanup scopes
    for (sema.current_scope != nil) {
        pop_scope(sema);
    }

    # note: full cleanup would free all allocated resources
    # but we use arena allocation, so it's not strictly necessary
}
