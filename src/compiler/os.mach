use std.types.bool;
use std.types.size;
use std.types.string;

# mach.compiler.masm.os.spec: OS specification interface.
# ---
# defines the interface for operating system-specific code generation details.

# OSKind tag constants
pub val OS_LINUX:   u8 = 0;
pub val OS_DARWIN:  u8 = 1;
pub val OS_WINDOWS: u8 = 2;
pub val OS_UNKNOWN: u8 = 3;

# OSKind: target operating system identifier (tagged record pattern for enum-like behavior).
# ---
# tag: OS_LINUX, OS_DARWIN, OS_WINDOWS, or OS_UNKNOWN
pub rec OSKind {
    tag: u8;
}

# OSKind constructors
pub fun os_linux() OSKind {
    ret OSKind { tag: OS_LINUX };
}

pub fun os_darwin() OSKind {
    ret OSKind { tag: OS_DARWIN };
}

pub fun os_windows() OSKind {
    ret OSKind { tag: OS_WINDOWS };
}

pub fun os_unknown() OSKind {
    ret OSKind { tag: OS_UNKNOWN };
}

# OS: operating system specification.
# ---
# kind:              OS identifier
# name:              OS name string
# default_exe_ext:   default executable extension (empty for Linux/macOS)
# default_obj_ext:   default object file extension
# default_lib_ext:   default static library extension
# default_dll_ext:   default shared library extension
# path_separator:    path separator character
# uses_underscore:   true if C symbols have underscore prefix
pub rec OS {
    kind:             OSKind;
    name:             str;
    default_exe_ext:  str;
    default_obj_ext:  str;
    default_lib_ext:  str;
    default_dll_ext:  str;
    path_separator:   u8;
    uses_underscore:  bool;
}

# get_exe_extension: get the executable file extension for an OS.
# ---
# os: OS specification
# ret: extension string (e.g. ".exe" or "")
pub fun get_exe_extension(os: *OS) str {
    if (os == nil) {
        ret "";
    }
    ret os.default_exe_ext;
}

# get_obj_extension: get the object file extension for an OS.
# ---
# os: OS specification
# ret: extension string (e.g. ".o" or ".obj")
pub fun get_obj_extension(os: *OS) str {
    if (os == nil) {
        ret ".o";
    }
    ret os.default_obj_ext;
}

# get_lib_extension: get the static library extension for an OS.
# ---
# os: OS specification
# ret: extension string (e.g. ".a" or ".lib")
pub fun get_lib_extension(os: *OS) str {
    if (os == nil) {
        ret ".a";
    }
    ret os.default_lib_ext;
}

# get_dll_extension: get the shared library extension for an OS.
# ---
# os: OS specification
# ret: extension string (e.g. ".so", ".dylib", or ".dll")
pub fun get_dll_extension(os: *OS) str {
    if (os == nil) {
        ret ".so";
    }
    ret os.default_dll_ext;
}

# mangle_symbol: apply OS-specific symbol mangling.
# ---
# os:   OS specification
# name: symbol name to mangle
# ret:  mangled symbol name
pub fun mangle_symbol(os: *OS, name: str) str {
    if (os == nil || name == nil) {
        ret name;
    }

    # on macOS/Windows, C symbols typically have underscore prefix
    if (os.uses_underscore) {
        # TODO: allocate and prepend underscore
        # for now, return unmangled
        ret name;
    }

    ret name;
}

# is_unix_like: check if the OS is Unix-like.
# ---
# os: OS specification
# ret: true if Linux, macOS, or other Unix-like OS
pub fun is_unix_like(os: *OS) bool {
    if (os == nil) {
        ret false;
    }

    val tag: u8 = os.kind.tag;
    ret tag == OS_LINUX || tag == OS_DARWIN;
}

# is_windows: check if the OS is Windows.
# ---
# os: OS specification
# ret: true if Windows
pub fun is_windows(os: *OS) bool {
    if (os == nil) {
        ret false;
    }

    ret os.kind.tag == OS_WINDOWS;
}

# get_linker_name: get the default linker name for the OS.
# ---
# os: OS specification
# ret: linker executable name
pub fun get_linker_name(os: *OS) str {
    if (os == nil) {
        ret "ld";
    }

    # TODO: check os.kind
    # Linux: ld or ld.lld
    # macOS: ld
    # Windows: link.exe or lld-link

    ret "ld";
}

# get_libc_name: get the C library name for the OS.
# ---
# os: OS specification
# ret: C library name
pub fun get_libc_name(os: *OS) str {
    if (os == nil) {
        ret "c";
    }

    # most Unix-like systems use "c" (libc.so or libc.dylib)
    # Windows uses msvcrt or similar
    ret "c";
}
