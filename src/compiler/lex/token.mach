# token types, spans, and operator metadata for the lexer

use std.types.bool;
use std.types.string;

pub def Tag: u8;

pub val TAG_IDENT:      Tag = 0;
pub val TAG_LIT_INT:    Tag = 1;
pub val TAG_LIT_FLOAT:  Tag = 2;
pub val TAG_LIT_CHAR:   Tag = 3;
pub val TAG_LIT_STRING: Tag = 4;

pub val TAG_LPAREN:   Tag = 5;
pub val TAG_RPAREN:   Tag = 6;
pub val TAG_LBRACE:   Tag = 7;
pub val TAG_RBRACE:   Tag = 8;
pub val TAG_LBRACKET: Tag = 9;
pub val TAG_RBRACKET: Tag = 10;

pub val TAG_SEMI:     Tag = 11;
pub val TAG_COLON:    Tag = 12;
pub val TAG_COMMA:    Tag = 13;
pub val TAG_DOT:      Tag = 14;
pub val TAG_QUESTION: Tag = 15;
pub val TAG_AT:       Tag = 16;
pub val TAG_DOLLAR:   Tag = 17;
pub val TAG_HASH:     Tag = 18;
pub val TAG_AMP:      Tag = 19;
pub val TAG_STAR:     Tag = 20;

pub val TAG_PLUS:        Tag = 21;
pub val TAG_MINUS:       Tag = 22;
pub val TAG_SLASH:       Tag = 23;
pub val TAG_PERCENT:     Tag = 24;
pub val TAG_EQ:          Tag = 25;
pub val TAG_EQ_EQ:       Tag = 26;
pub val TAG_BANG:        Tag = 27;
pub val TAG_BANG_EQ:     Tag = 28;
pub val TAG_LT:          Tag = 29;
pub val TAG_LT_EQ:       Tag = 30;
pub val TAG_LT_LT:       Tag = 31;
pub val TAG_GT:          Tag = 32;
pub val TAG_GT_EQ:       Tag = 33;
pub val TAG_GT_GT:       Tag = 34;
pub val TAG_AMP_AMP:     Tag = 35;
pub val TAG_PIPE:        Tag = 36;
pub val TAG_PIPE_PIPE:   Tag = 37;
pub val TAG_CARET:       Tag = 38;
pub val TAG_TILDE:       Tag = 39;
pub val TAG_COLON_COLON: Tag = 40;
pub val TAG_DOT_DOT_DOT: Tag = 41;

pub val TAG_EOF:   Tag = 254;
pub val TAG_ERROR: Tag = 255;

# byte range within the source text
pub rec Span {
    offset: u32;
    len:    u16;
}

pub rec Token {
    span: Span;
    tag:  Tag;
}

# make: construct a token from its components
# ---
# tag:    token tag
# offset: byte offset into source
# len:    byte length
# ret:    a new Token
pub fun make(tag: Tag, offset: u32, len: u16) Token {
    var tok: Token;
    tok.tag = tag;
    tok.span.offset = offset;
    tok.span.len = len;
    ret tok;
}

# infix_precedence: return the binding power for Pratt parsing
#
# returns 0 for tags that are not infix operators.
# ---
# tag: token tag to query
# ret: precedence level (0 = not infix, 1-10 from lowest to highest)
pub fun infix_precedence(tag: Tag) u8 {
    if (tag == TAG_PIPE_PIPE)   { ret 1; }
    if (tag == TAG_AMP_AMP)     { ret 2; }
    if (tag == TAG_PIPE)        { ret 3; }
    if (tag == TAG_CARET)       { ret 4; }
    if (tag == TAG_AMP)         { ret 5; }
    if (tag == TAG_EQ_EQ)       { ret 6; }
    if (tag == TAG_BANG_EQ)     { ret 6; }
    if (tag == TAG_LT)          { ret 7; }
    if (tag == TAG_LT_EQ)       { ret 7; }
    if (tag == TAG_GT)          { ret 7; }
    if (tag == TAG_GT_EQ)       { ret 7; }
    if (tag == TAG_LT_LT)       { ret 8; }
    if (tag == TAG_GT_GT)       { ret 8; }
    if (tag == TAG_PLUS)        { ret 9; }
    if (tag == TAG_MINUS)       { ret 9; }
    if (tag == TAG_STAR)        { ret 10; }
    if (tag == TAG_SLASH)       { ret 10; }
    if (tag == TAG_PERCENT)     { ret 10; }
    ret 0;
}

# is_right_assoc: check whether an infix operator is right-associative
# ---
# tag: token tag to query
# ret: true only for assignment (TAG_EQ)
pub fun is_right_assoc(tag: Tag) bool {
    ret tag == TAG_EQ;
}

# tag_str: return a display string for a token tag
# ---
# tag: token tag to describe
# ret: human-readable name
pub fun tag_str(tag: Tag) str {
    if (tag == TAG_IDENT)      { ret "ident"; }
    if (tag == TAG_LIT_INT)    { ret "int"; }
    if (tag == TAG_LIT_FLOAT)  { ret "float"; }
    if (tag == TAG_LIT_CHAR)   { ret "char"; }
    if (tag == TAG_LIT_STRING) { ret "string"; }
    if (tag == TAG_LPAREN)     { ret "("; }
    if (tag == TAG_RPAREN)     { ret ")"; }
    if (tag == TAG_LBRACE)     { ret "{"; }
    if (tag == TAG_RBRACE)     { ret "}"; }
    if (tag == TAG_LBRACKET)   { ret "["; }
    if (tag == TAG_RBRACKET)   { ret "]"; }
    if (tag == TAG_SEMI)       { ret ";"; }
    if (tag == TAG_COLON)      { ret ":"; }
    if (tag == TAG_COMMA)      { ret ","; }
    if (tag == TAG_DOT)        { ret "."; }
    if (tag == TAG_QUESTION)   { ret "?"; }
    if (tag == TAG_AT)         { ret "@"; }
    if (tag == TAG_DOLLAR)     { ret "$"; }
    if (tag == TAG_HASH)       { ret "#"; }
    if (tag == TAG_AMP)        { ret "&"; }
    if (tag == TAG_STAR)       { ret "*"; }
    if (tag == TAG_PLUS)       { ret "+"; }
    if (tag == TAG_MINUS)      { ret "-"; }
    if (tag == TAG_SLASH)      { ret "/"; }
    if (tag == TAG_PERCENT)    { ret "%"; }
    if (tag == TAG_EQ)         { ret "="; }
    if (tag == TAG_EQ_EQ)      { ret "=="; }
    if (tag == TAG_BANG)       { ret "!"; }
    if (tag == TAG_BANG_EQ)    { ret "!="; }
    if (tag == TAG_LT)         { ret "<"; }
    if (tag == TAG_LT_EQ)      { ret "<="; }
    if (tag == TAG_LT_LT)      { ret "<<"; }
    if (tag == TAG_GT)         { ret ">"; }
    if (tag == TAG_GT_EQ)      { ret ">="; }
    if (tag == TAG_GT_GT)      { ret ">>"; }
    if (tag == TAG_AMP_AMP)    { ret "&&"; }
    if (tag == TAG_PIPE)       { ret "|"; }
    if (tag == TAG_PIPE_PIPE)  { ret "||"; }
    if (tag == TAG_CARET)      { ret "^"; }
    if (tag == TAG_TILDE)      { ret "~"; }
    if (tag == TAG_COLON_COLON) { ret "::"; }
    if (tag == TAG_DOT_DOT_DOT) { ret "..."; }
    if (tag == TAG_EOF)        { ret "eof"; }
    if (tag == TAG_ERROR)      { ret "error"; }
    ret "unknown";
}

test "token: precedence of arithmetic operators" {
    if (infix_precedence(TAG_PLUS) != 9) { ret 0; }
    if (infix_precedence(TAG_MINUS) != 9) { ret 0; }
    if (infix_precedence(TAG_STAR) != 10) { ret 0; }
    if (infix_precedence(TAG_SLASH) != 10) { ret 0; }
    if (infix_precedence(TAG_PERCENT) != 10) { ret 0; }
    ret 1;
}

test "token: precedence of comparison operators" {
    if (infix_precedence(TAG_EQ_EQ) != 6) { ret 0; }
    if (infix_precedence(TAG_BANG_EQ) != 6) { ret 0; }
    if (infix_precedence(TAG_LT) != 7) { ret 0; }
    if (infix_precedence(TAG_LT_EQ) != 7) { ret 0; }
    if (infix_precedence(TAG_GT) != 7) { ret 0; }
    if (infix_precedence(TAG_GT_EQ) != 7) { ret 0; }
    ret 1;
}

test "token: precedence of logical operators" {
    if (infix_precedence(TAG_AMP_AMP) != 2) { ret 0; }
    if (infix_precedence(TAG_PIPE_PIPE) != 1) { ret 0; }
    ret 1;
}

test "token: precedence of bitwise operators" {
    if (infix_precedence(TAG_AMP) != 5) { ret 0; }
    if (infix_precedence(TAG_PIPE) != 3) { ret 0; }
    if (infix_precedence(TAG_CARET) != 4) { ret 0; }
    if (infix_precedence(TAG_LT_LT) != 8) { ret 0; }
    if (infix_precedence(TAG_GT_GT) != 8) { ret 0; }
    ret 1;
}

test "token: non-infix returns zero precedence" {
    if (infix_precedence(TAG_LPAREN) != 0) { ret 0; }
    if (infix_precedence(TAG_SEMI) != 0) { ret 0; }
    if (infix_precedence(TAG_IDENT) != 0) { ret 0; }
    if (infix_precedence(TAG_EOF) != 0) { ret 0; }
    ret 1;
}

test "token: right associativity" {
    if (!is_right_assoc(TAG_EQ)) { ret 0; }
    if (is_right_assoc(TAG_PLUS)) { ret 0; }
    if (is_right_assoc(TAG_STAR)) { ret 0; }
    if (is_right_assoc(TAG_EQ_EQ)) { ret 0; }
    ret 1;
}

test "token: tag_str for delimiters" {
    if (!str_equals(tag_str(TAG_LPAREN), "(")) { ret 0; }
    if (!str_equals(tag_str(TAG_RBRACE), "}")) { ret 0; }
    if (!str_equals(tag_str(TAG_LBRACKET), "[")) { ret 0; }
    ret 1;
}

test "token: tag_str for operators" {
    if (!str_equals(tag_str(TAG_EQ_EQ), "==")) { ret 0; }
    if (!str_equals(tag_str(TAG_BANG_EQ), "!=")) { ret 0; }
    if (!str_equals(tag_str(TAG_COLON_COLON), "::")) { ret 0; }
    if (!str_equals(tag_str(TAG_DOT_DOT_DOT), "...")) { ret 0; }
    ret 1;
}

test "token: tag_str for literals and special" {
    if (!str_equals(tag_str(TAG_IDENT), "ident")) { ret 0; }
    if (!str_equals(tag_str(TAG_LIT_INT), "int")) { ret 0; }
    if (!str_equals(tag_str(TAG_EOF), "eof")) { ret 0; }
    if (!str_equals(tag_str(TAG_ERROR), "error")) { ret 0; }
    ret 1;
}

test "token: make constructs correct token" {
    val tok: Token = make(TAG_IDENT, 10, 5);
    if (tok.tag != TAG_IDENT) { ret 0; }
    if (tok.span.offset != 10) { ret 0; }
    if (tok.span.len != 5) { ret 0; }
    ret 1;
}
