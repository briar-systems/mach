# mach.compiler.lex.lexer: single-pass tokenizer producing a flat token stream from source text

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allo: std.allocator;
use page: std.allocator.page;

use token: mach.compiler.lex.token;
use diag:  mach.compiler.diag;

pub rec TokenStream {
    tokens: *token.Token;
    count:  u32;
    source: str;
}

val INITIAL_CAP: u32 = 256;

# tokenize: lex entire source into a flat array of tokens
# ---
# source: null-terminated source text
# alloc:  allocator for the token array
# ret:    a TokenStream containing all tokens including a trailing EOF
pub fun tokenize(source: str, alloc: *allo.Allocator, dl: *diag.DiagList, file_path: str) TokenStream {
    var stream: TokenStream;
    stream.source = source;
    stream.count = 0;

    var cap: u32 = INITIAL_CAP;
    val res_allocate: Result[*token.Token, str] = allo.allocate[token.Token](alloc, cap::usize);
    if (is_err[*token.Token, str](res_allocate)) {
        stream.tokens = nil;
        if (dl != nil) {
            diag.error(dl, diag.make_loc(file_path, 0, 0), "failed to allocate token array");
        }
        ret stream;
    }
    stream.tokens = unwrap_ok[*token.Token, str](res_allocate);

    var pos: u32 = 0;

    for (source[pos] != 0) {
        val c: u8 = source[pos];

        if (c == ' ' || c == '\t' || c == '\n' || c == '\r') {
            pos = pos + 1;
            cnt;
        }

        if (c == '#') {
            for (source[pos] != 0 && source[pos] != '\n') {
                pos = pos + 1;
            }
            cnt;
        }

        var tok: token.Token;

        if (c == '(' ) { tok = token.make(token.TAG_LPAREN,   pos, 1); pos = pos + 1; }
        or (c == ')') { tok = token.make(token.TAG_RPAREN,   pos, 1); pos = pos + 1; }
        or (c == '{') { tok = token.make(token.TAG_LBRACE,   pos, 1); pos = pos + 1; }
        or (c == '}') { tok = token.make(token.TAG_RBRACE,   pos, 1); pos = pos + 1; }
        or (c == '[') { tok = token.make(token.TAG_LBRACKET, pos, 1); pos = pos + 1; }
        or (c == ']') { tok = token.make(token.TAG_RBRACKET, pos, 1); pos = pos + 1; }
        or (c == ';') { tok = token.make(token.TAG_SEMI,     pos, 1); pos = pos + 1; }
        or (c == ',') { tok = token.make(token.TAG_COMMA,    pos, 1); pos = pos + 1; }
        or (c == '?') { tok = token.make(token.TAG_QUESTION, pos, 1); pos = pos + 1; }
        or (c == '@') { tok = token.make(token.TAG_AT,       pos, 1); pos = pos + 1; }
        or (c == '$') { tok = token.make(token.TAG_DOLLAR,   pos, 1); pos = pos + 1; }
        or (c == '~') { tok = token.make(token.TAG_TILDE,    pos, 1); pos = pos + 1; }
        or (c == ':') {
            if (source[pos + 1] == ':') {
                tok = token.make(token.TAG_COLON_COLON, pos, 2);
                pos = pos + 2;
            } or {
                tok = token.make(token.TAG_COLON, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '.') {
            if (source[pos + 1] == '.' && source[pos + 2] == '.') {
                tok = token.make(token.TAG_DOT_DOT_DOT, pos, 3);
                pos = pos + 3;
            } or {
                tok = token.make(token.TAG_DOT, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '+') { tok = token.make(token.TAG_PLUS,  pos, 1); pos = pos + 1; }
        or (c == '-') { tok = token.make(token.TAG_MINUS, pos, 1); pos = pos + 1; }
        or (c == '/') { tok = token.make(token.TAG_SLASH, pos, 1); pos = pos + 1; }
        or (c == '%') { tok = token.make(token.TAG_PERCENT, pos, 1); pos = pos + 1; }
        or (c == '^') { tok = token.make(token.TAG_CARET, pos, 1); pos = pos + 1; }
        or (c == '*') { tok = token.make(token.TAG_STAR,  pos, 1); pos = pos + 1; }
        or (c == '=') {
            if (source[pos + 1] == '=') {
                tok = token.make(token.TAG_EQ_EQ, pos, 2);
                pos = pos + 2;
            } or {
                tok = token.make(token.TAG_EQ, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '!') {
            if (source[pos + 1] == '=') {
                tok = token.make(token.TAG_BANG_EQ, pos, 2);
                pos = pos + 2;
            } or {
                tok = token.make(token.TAG_BANG, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '<') {
            if (source[pos + 1] == '=') {
                tok = token.make(token.TAG_LT_EQ, pos, 2);
                pos = pos + 2;
            }
            or (source[pos + 1] == '<') {
                tok = token.make(token.TAG_LT_LT, pos, 2);
                pos = pos + 2;
            }
            or {
                tok = token.make(token.TAG_LT, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '>') {
            if (source[pos + 1] == '=') {
                tok = token.make(token.TAG_GT_EQ, pos, 2);
                pos = pos + 2;
            }
            or (source[pos + 1] == '>') {
                tok = token.make(token.TAG_GT_GT, pos, 2);
                pos = pos + 2;
            }
            or {
                tok = token.make(token.TAG_GT, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '&') {
            if (source[pos + 1] == '&') {
                tok = token.make(token.TAG_AMP_AMP, pos, 2);
                pos = pos + 2;
            } or {
                tok = token.make(token.TAG_AMP, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '|') {
            if (source[pos + 1] == '|') {
                tok = token.make(token.TAG_PIPE_PIPE, pos, 2);
                pos = pos + 2;
            } or {
                tok = token.make(token.TAG_PIPE, pos, 1);
                pos = pos + 1;
            }
        }
        or (c == '"') {
            val start: u32 = pos;
            pos = pos + 1;
            for (source[pos] != 0 && source[pos] != '"') {
                if (source[pos] == '\\') {
                    pos = pos + 1;
                    if (source[pos] == 'x' && source[pos + 1] != 0 && source[pos + 2] != 0) {
                        pos = pos + 3;
                        cnt;
                    }
                }
                if (source[pos] != 0) { pos = pos + 1; }
            }
            if (source[pos] == '"') {
                pos = pos + 1;
            }
            tok = token.make(token.TAG_LIT_STRING, start, (pos - start)::u16);
        }
        or (c == '\'') {
            val start: u32 = pos;
            pos = pos + 1;
            for (source[pos] != 0 && source[pos] != '\'') {
                if (source[pos] == '\\') {
                    pos = pos + 1;
                    if (source[pos] == 'x' && source[pos + 1] != 0 && source[pos + 2] != 0) {
                        pos = pos + 3;
                        cnt;
                    }
                }
                if (source[pos] != 0) { pos = pos + 1; }
            }
            if (source[pos] == '\'') {
                pos = pos + 1;
            }
            tok = token.make(token.TAG_LIT_CHAR, start, (pos - start)::u16);
        }
        or (c >= '0' && c <= '9') {
            val start: u32 = pos;
            var is_float: bool = false;

            if (c == '0' && source[pos + 1] == 'x') {
                pos = pos + 2;
                for (is_hex_char(source[pos]) || source[pos] == '_') {
                    pos = pos + 1;
                }
            }
            or (c == '0' && source[pos + 1] == 'b') {
                pos = pos + 2;
                for (source[pos] == '0' || source[pos] == '1' || source[pos] == '_') {
                    pos = pos + 1;
                }
            }
            or (c == '0' && source[pos + 1] == 'o') {
                pos = pos + 2;
                for (source[pos] >= '0' && source[pos] <= '7' || source[pos] == '_') {
                    pos = pos + 1;
                }
            }
            or {
                for (source[pos] >= '0' && source[pos] <= '9' || source[pos] == '_') {
                    pos = pos + 1;
                }
                if (source[pos] == '.' && source[pos + 1] >= '0' && source[pos + 1] <= '9') {
                    is_float = true;
                    pos = pos + 1;
                    for (source[pos] >= '0' && source[pos] <= '9' || source[pos] == '_') {
                        pos = pos + 1;
                    }
                }
            }

            if (is_float) {
                if (source[pos] == 'f') {
                    pos = pos + 1;
                    for (source[pos] >= '0' && source[pos] <= '9') {
                        pos = pos + 1;
                    }
                }
                tok = token.make(token.TAG_LIT_FLOAT, start, (pos - start)::u16);
            } or {
                if (source[pos] == 'u' || source[pos] == 'i') {
                    pos = pos + 1;
                    for (source[pos] >= '0' && source[pos] <= '9') {
                        pos = pos + 1;
                    }
                }
                tok = token.make(token.TAG_LIT_INT, start, (pos - start)::u16);
            }
        }
        or (is_ident_start(c)) {
            val start: u32 = pos;
            for (is_ident_char(source[pos])) {
                pos = pos + 1;
            }
            tok = token.make(token.TAG_IDENT, start, (pos - start)::u16);
        }
        or {
            tok = token.make(token.TAG_ERROR, pos, 1);
            if (dl != nil) {
                val err_line: u32 = line_of(source, pos);
                val err_col: u32 = col_of(source, pos);
                diag.error(dl, diag.make_loc(file_path, err_line, err_col), "unexpected character");
            }
            pos = pos + 1;
        }

        if (stream.count == cap) {
            val new_cap: u32 = cap * 2;
            val res_reallocate: Result[*token.Token, str] = allo.reallocate[token.Token](alloc, stream.tokens, cap::usize, new_cap::usize);
            if (is_err[*token.Token, str](res_reallocate)) {
                if (dl != nil) {
                    diag.error(dl, diag.make_loc(file_path, 0, 0), "failed to grow token array");
                }
                ret stream;
            }
            stream.tokens = unwrap_ok[*token.Token, str](res_reallocate);
            cap = new_cap;
        }

        stream.tokens[stream.count] = tok;
        stream.count = stream.count + 1;
    }

    if (stream.count == cap) {
        val new_cap: u32 = cap * 2;
        val res_reallocate: Result[*token.Token, str] = allo.reallocate[token.Token](alloc, stream.tokens, cap::usize, new_cap::usize);
        if (is_err[*token.Token, str](res_reallocate)) {
            if (dl != nil) {
                diag.error(dl, diag.make_loc(file_path, 0, 0), "failed to grow token array");
            }
            ret stream;
        }
        stream.tokens = unwrap_ok[*token.Token, str](res_reallocate);
        cap = new_cap;
    }

    stream.tokens[stream.count] = token.make(token.TAG_EOF, pos, 0);
    stream.count = stream.count + 1;

    ret stream;
}

# text: extract the source text for a token
#
# returns a pointer into the original source buffer at the token's offset.
# the caller uses tok.span.len for the length since mach strings are
# null-terminated and the returned pointer shares the source's storage.
# ---
# stream: token stream containing the source reference
# tok:    token whose text to extract
# ret:    pointer into source at tok.span.offset
pub fun text(stream: *TokenStream, tok: token.Token) str {
    ret (stream.source::usize + tok.span.offset::usize)::str;
}

# line_of: compute the 1-based line number for a byte offset
# ---
# source: null-terminated source text
# offset: byte offset into source
# ret:    1-based line number
pub fun line_of(source: str, offset: u32) u32 {
    var line: u32 = 1;
    var i: u32 = 0;
    for (i < offset && source[i] != 0) {
        if (source[i] == '\n') {
            line = line + 1;
        }
        i = i + 1;
    }
    ret line;
}

# col_of: compute the 1-based column number for a byte offset
# ---
# source: null-terminated source text
# offset: byte offset into source
# ret:    1-based column number
pub fun col_of(source: str, offset: u32) u32 {
    var col: u32 = 1;
    var i: u32 = 0;
    for (i < offset && source[i] != 0) {
        if (source[i] == '\n') {
            col = 1;
        } or {
            col = col + 1;
        }
        i = i + 1;
    }
    ret col;
}

fun is_ident_start(c: u8) bool {
    ret (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_';
}

fun is_ident_char(c: u8) bool {
    ret is_ident_start(c) || (c >= '0' && c <= '9');
}

fun is_hex_char(c: u8) bool {
    ret (c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F');
}

test "lexer: tokenize simple var decl" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("val x: i32 = 42;", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    # val x : i32 = 42 ;  EOF
    if (stream.count != 8) { ret 0; }
    if (stream.tokens[0].tag != token.TAG_IDENT)   { ret 0; }
    if (stream.tokens[1].tag != token.TAG_IDENT)   { ret 0; }
    if (stream.tokens[2].tag != token.TAG_COLON)   { ret 0; }
    if (stream.tokens[3].tag != token.TAG_IDENT)   { ret 0; }
    if (stream.tokens[4].tag != token.TAG_EQ)      { ret 0; }
    if (stream.tokens[5].tag != token.TAG_LIT_INT) { ret 0; }
    if (stream.tokens[6].tag != token.TAG_SEMI)    { ret 0; }
    if (stream.tokens[7].tag != token.TAG_EOF)     { ret 0; }
    ret 1;
}

test "lexer: tokenize operators" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("== != <= >= << >> && || :: ...", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.tokens[0].tag != token.TAG_EQ_EQ)       { ret 0; }
    if (stream.tokens[1].tag != token.TAG_BANG_EQ)      { ret 0; }
    if (stream.tokens[2].tag != token.TAG_LT_EQ)        { ret 0; }
    if (stream.tokens[3].tag != token.TAG_GT_EQ)        { ret 0; }
    if (stream.tokens[4].tag != token.TAG_LT_LT)        { ret 0; }
    if (stream.tokens[5].tag != token.TAG_GT_GT)        { ret 0; }
    if (stream.tokens[6].tag != token.TAG_AMP_AMP)      { ret 0; }
    if (stream.tokens[7].tag != token.TAG_PIPE_PIPE)    { ret 0; }
    if (stream.tokens[8].tag != token.TAG_COLON_COLON)  { ret 0; }
    if (stream.tokens[9].tag != token.TAG_DOT_DOT_DOT)  { ret 0; }
    if (stream.tokens[10].tag != token.TAG_EOF)         { ret 0; }
    ret 1;
}

test "lexer: tokenize string and char literals" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("\"hello\" 'x'", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.tokens[0].tag != token.TAG_LIT_STRING) { ret 0; }
    if (stream.tokens[1].tag != token.TAG_LIT_CHAR)   { ret 0; }
    if (stream.tokens[2].tag != token.TAG_EOF)        { ret 0; }
    ret 1;
}

test "lexer: tokenize hex and binary literals" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("0xFF 0b1010 0o77", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.tokens[0].tag != token.TAG_LIT_INT) { ret 0; }
    if (stream.tokens[1].tag != token.TAG_LIT_INT) { ret 0; }
    if (stream.tokens[2].tag != token.TAG_LIT_INT) { ret 0; }
    if (stream.tokens[3].tag != token.TAG_EOF)     { ret 0; }
    ret 1;
}

test "lexer: tokenize float literal" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("3.14 1.0f32", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.tokens[0].tag != token.TAG_LIT_FLOAT) { ret 0; }
    if (stream.tokens[1].tag != token.TAG_LIT_FLOAT) { ret 0; }
    if (stream.tokens[2].tag != token.TAG_EOF)       { ret 0; }
    ret 1;
}

test "lexer: comments are skipped" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("a # comment\nb", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.count != 3) { ret 0; }
    if (stream.tokens[0].tag != token.TAG_IDENT) { ret 0; }
    if (stream.tokens[1].tag != token.TAG_IDENT) { ret 0; }
    if (stream.tokens[2].tag != token.TAG_EOF)   { ret 0; }
    ret 1;
}

test "lexer: line_of and col_of" {
    val src: str = "ab\ncd\nef";
    if (line_of(src, 0) != 1) { ret 0; }
    if (line_of(src, 1) != 1) { ret 0; }
    if (line_of(src, 3) != 2) { ret 0; }
    if (line_of(src, 6) != 3) { ret 0; }
    if (col_of(src, 0) != 1) { ret 0; }
    if (col_of(src, 1) != 2) { ret 0; }
    if (col_of(src, 3) != 1) { ret 0; }
    if (col_of(src, 4) != 2) { ret 0; }
    ret 1;
}

test "lexer: integer with type suffix" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("42u8 100i64", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.tokens[0].tag != token.TAG_LIT_INT) { ret 0; }
    if (stream.tokens[1].tag != token.TAG_LIT_INT) { ret 0; }
    if (stream.tokens[2].tag != token.TAG_EOF)     { ret 0; }
    ret 1;
}

test "lexer: all delimiters" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("(){}[]", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.tokens[0].tag != token.TAG_LPAREN)   { ret 0; }
    if (stream.tokens[1].tag != token.TAG_RPAREN)   { ret 0; }
    if (stream.tokens[2].tag != token.TAG_LBRACE)   { ret 0; }
    if (stream.tokens[3].tag != token.TAG_RBRACE)   { ret 0; }
    if (stream.tokens[4].tag != token.TAG_LBRACKET) { ret 0; }
    if (stream.tokens[5].tag != token.TAG_RBRACKET) { ret 0; }
    if (stream.tokens[6].tag != token.TAG_EOF)      { ret 0; }
    ret 1;
}

test "lexer: empty source produces only EOF" {
    var a: allo.Allocator;
    page.make(?a);

    val stream: TokenStream = tokenize("", ?a, nil, nil);
    if (stream.tokens == nil) { ret 0; }

    if (stream.count != 1) { ret 0; }
    if (stream.tokens[0].tag != token.TAG_EOF) { ret 0; }
    ret 1;
}
