use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use token:  mach.compiler.token;
use ty:     mach.compiler.type;
use tyctx:  mach.compiler.type_context;
use target: mach.compiler.masm.target;

# mach.compiler.comptime: compile-time evaluation.
# ---
# handles $if, $error, $size_of, $align_of, and other compile-time constructs.

# ComptimeValue: a value computed at compile time.
# ---
# kind:       type of value
# int_val:    integer value (for int kind)
# bool_val:   boolean value (for bool kind)
# str_val:    string value (for string kind)
pub rec ComptimeValue {
    kind:     ComptimeKind;
    int_val:  i64;
    bool_val: bool;
    str_val:  str;
}

# ComptimeKind: the type of a compile-time value.
# ---
# ct_int:    integer value
# ct_bool:   boolean value
# ct_string: string value
# ct_nil:    nil/void
# ct_error:  evaluation error
pub uni ComptimeKind {
    ct_int:    u8;
    ct_bool:   u8;
    ct_string: u8;
    ct_nil:    u8;
    ct_error:  u8;
}

# ComptimeContext: context for compile-time evaluation.
# ---
# alloc:       allocator for values
# symbols:     symbol table for lookups
# types:       type context
# target_os:   target OS identifier
# target_isa:  target ISA identifier
# target_abi:  target ABI identifier
pub rec ComptimeContext {
    alloc:      *allocator.Allocator;
    symbols:    *symbol.Table;
    types:      *tyctx.TypeContext;
    target_os:  str;
    target_isa: str;
    target_abi: str;
    tgt:        target.Target;
}

# init: create a new compile-time evaluation context.
# ---
# alloc:   allocator to use
# symbols: symbol table for lookups
# types:   type context for type queries
# ret:     initialized ComptimeContext
pub fun init(alloc: *allocator.Allocator, symbols: *symbol.Table, types: *tyctx.TypeContext, tgt: target.Target) ComptimeContext {
    var ctx: ComptimeContext;
    ctx.alloc = alloc;
    ctx.symbols = symbols;
    ctx.types = types;
    ctx.tgt = tgt;

    if (tgt.os.tag == target.OS_LINUX) { ctx.target_os = "linux"; }
    or (tgt.os.tag == target.OS_DARWIN) { ctx.target_os = "darwin"; }
    or (tgt.os.tag == target.OS_WINDOWS) { ctx.target_os = "windows"; }
    or { ctx.target_os = "unknown"; }

    if (tgt.isa.tag == target.ISA_X86_64) { ctx.target_isa = "x86_64"; }
    or (tgt.isa.tag == target.ISA_AARCH64) { ctx.target_isa = "aarch64"; }
    or { ctx.target_isa = "unknown"; }

    if (tgt.abi.tag == target.ABI_SYSV64) { ctx.target_abi = "sysv64"; }
    or (tgt.abi.tag == target.ABI_WIN64) { ctx.target_abi = "win64"; }
    or { ctx.target_abi = "unknown"; }
    ret ctx;
}

# set_target: set target platform information.
# ---
# ctx: comptime context
# os:  target OS (e.g. "linux", "darwin", "windows")
# isa: target ISA (e.g. "x86_64", "aarch64")
# abi: target ABI (e.g. "sysv64", "win64")
# ret: none
pub fun set_target(ctx: *ComptimeContext, os: str, isa: str, abi: str) {
    if (ctx == nil) {
        ret;
    }

    ctx.target_os = os;
    ctx.target_isa = isa;
    ctx.target_abi = abi;
}

# eval: evaluate a compile-time expression.
# ---
# ctx:  comptime context
# expr: AST expression node to evaluate
# ret:  Ok(ComptimeValue) on success, Err(str) on failure
pub fun eval(ctx: *ComptimeContext, expr: *ast.Node) Result[ComptimeValue, str] {
    if (ctx == nil) {
        ret err[ComptimeValue, str]("context is nil");
    }

    if (expr == nil) {
        ret err[ComptimeValue, str]("expression is nil");
    }

    val kind: ast.NodeKind = expr.kind;

    # integer literal
    if (kind == ast.NODE_EXPR_LIT_INT) {
        val int_val: i64 = ast.node_get_int_value(expr);
        ret ok[ComptimeValue, str](make_int(int_val));
    }

    # boolean literal
    if (kind == ast.NODE_EXPR_LIT_BOOL) {
        val bool_text: str = expr.info.lit_expr.text;
        val bool_val: bool = bool_text != nil && str_equals(bool_text, "true");
        ret ok[ComptimeValue, str](make_bool(bool_val));
    }

    # string literal
    if (kind == ast.NODE_EXPR_LIT_STR) {
        val str_val: str = expr.info.lit_expr.text;
        ret ok[ComptimeValue, str](make_string(str_val));
    }

    # nil literal
    if (kind == ast.NODE_EXPR_LIT_NIL) {
        ret ok[ComptimeValue, str](make_nil());
    }

    # parenthesized expression
    if (kind == ast.NODE_EXPR_PAREN) {
        if (expr.info.wrapper.inner == nil) {
            ret err[ComptimeValue, str]("empty paren expression");
        }
        ret eval(ctx, expr.info.wrapper.inner);
    }

    # unary expression
    if (kind == ast.NODE_EXPR_UNARY) {
        ret eval_unary(ctx, expr);
    }

    # binary expression
    if (kind == ast.NODE_EXPR_BINARY) {
        ret eval_binary(ctx, expr);
    }

    # identifier - look up compile-time constant
    if (kind == ast.NODE_EXPR_IDENT) {
        ret eval_ident(ctx, expr);
    }

    # field access - for $mach.* intrinsics
    if (kind == ast.NODE_EXPR_FIELD) {
        ret eval_field(ctx, expr);
    }

    # comptime expression ($mach.build.target.pointer_width etc)
    if (kind == ast.NODE_COMPTIME) {
        # flatten the path into segments and evaluate
        if (expr.info.wrapper.inner != nil) {
            ret eval_comptime_path(ctx, expr.info.wrapper.inner);
        }
        ret err[ComptimeValue, str]("cannot evaluate comptime expression");
    }

    ret err[ComptimeValue, str]("expression cannot be evaluated at compile time");
}

# eval_unary: evaluate a unary expression at compile time.
fun eval_unary(ctx: *ComptimeContext, expr: *ast.Node) Result[ComptimeValue, str] {
    if (expr.info.unary_expr.expr == nil) {
        ret err[ComptimeValue, str]("unary expression has no operand");
    }

    val operand_res: Result[ComptimeValue, str] = eval(ctx, expr.info.unary_expr.expr);
    if (result_is_err[ComptimeValue, str](operand_res)) {
        ret operand_res;
    }

    val operand: ComptimeValue = result_unwrap_ok[ComptimeValue, str](operand_res);
    val op: u8 = expr.tok.tag;

    # logical not
    if (op == token.TAG_BANG) {
        ret ok[ComptimeValue, str](make_bool(!operand.bool_val));
    }

    # arithmetic negation
    if (op == token.TAG_MINUS) {
        ret ok[ComptimeValue, str](make_int(-operand.int_val));
    }

    # bitwise not
    if (op == token.TAG_TILDE) {
        ret ok[ComptimeValue, str](make_int(~operand.int_val));
    }

    ret err[ComptimeValue, str]("unsupported unary operator in comptime");
}

# eval_binary: evaluate a binary expression at compile time.
fun eval_binary(ctx: *ComptimeContext, expr: *ast.Node) Result[ComptimeValue, str] {
    if (expr.info.binary_expr.left == nil || expr.info.binary_expr.right == nil) {
        ret err[ComptimeValue, str]("binary expression missing operands");
    }

    val lhs_res: Result[ComptimeValue, str] = eval(ctx, expr.info.binary_expr.left);
    if (result_is_err[ComptimeValue, str](lhs_res)) {
        ret lhs_res;
    }

    val rhs_res: Result[ComptimeValue, str] = eval(ctx, expr.info.binary_expr.right);
    if (result_is_err[ComptimeValue, str](rhs_res)) {
        ret rhs_res;
    }

    val lhs: ComptimeValue = result_unwrap_ok[ComptimeValue, str](lhs_res);
    val rhs: ComptimeValue = result_unwrap_ok[ComptimeValue, str](rhs_res);
    val op: u8 = expr.info.binary_expr.op;

    # arithmetic operators
    if (op == token.TAG_PLUS) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val + rhs.int_val));
    }
    if (op == token.TAG_MINUS) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val - rhs.int_val));
    }
    if (op == token.TAG_STAR) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val * rhs.int_val));
    }
    if (op == token.TAG_SLASH) {
        if (rhs.int_val == 0) {
            ret err[ComptimeValue, str]("division by zero");
        }
        ret ok[ComptimeValue, str](make_int(lhs.int_val / rhs.int_val));
    }
    if (op == token.TAG_PERCENT) {
        if (rhs.int_val == 0) {
            ret err[ComptimeValue, str]("modulo by zero");
        }
        ret ok[ComptimeValue, str](make_int(lhs.int_val % rhs.int_val));
    }

    # comparison operators
    if (op == token.TAG_EQ_EQ) {
        ret ok[ComptimeValue, str](make_bool(lhs.int_val == rhs.int_val));
    }
    if (op == token.TAG_BANG_EQ) {
        ret ok[ComptimeValue, str](make_bool(lhs.int_val != rhs.int_val));
    }
    if (op == token.TAG_LT) {
        ret ok[ComptimeValue, str](make_bool(lhs.int_val < rhs.int_val));
    }
    if (op == token.TAG_LT_EQ) {
        ret ok[ComptimeValue, str](make_bool(lhs.int_val <= rhs.int_val));
    }
    if (op == token.TAG_GT) {
        ret ok[ComptimeValue, str](make_bool(lhs.int_val > rhs.int_val));
    }
    if (op == token.TAG_GT_EQ) {
        ret ok[ComptimeValue, str](make_bool(lhs.int_val >= rhs.int_val));
    }

    # logical operators
    if (op == token.TAG_AMP_AMP) {
        ret ok[ComptimeValue, str](make_bool(lhs.bool_val && rhs.bool_val));
    }
    if (op == token.TAG_PIPE_PIPE) {
        ret ok[ComptimeValue, str](make_bool(lhs.bool_val || rhs.bool_val));
    }

    # bitwise operators
    if (op == token.TAG_AMP) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val & rhs.int_val));
    }
    if (op == token.TAG_PIPE) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val | rhs.int_val));
    }
    if (op == token.TAG_CARET) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val ^ rhs.int_val));
    }
    if (op == token.TAG_LT_LT) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val << rhs.int_val));
    }
    if (op == token.TAG_GT_GT) {
        ret ok[ComptimeValue, str](make_int(lhs.int_val >> rhs.int_val));
    }

    ret err[ComptimeValue, str]("unsupported binary operator in comptime");
}

# eval_ident: evaluate an identifier at compile time.
fun eval_ident(ctx: *ComptimeContext, expr: *ast.Node) Result[ComptimeValue, str] {
    val name: str = expr.info.ident_expr.name;
    if (name == nil) {
        ret err[ComptimeValue, str]("identifier has no name");
    }

    # check for built-in constants
    if (str_equals(name, "nil")) {
        ret ok[ComptimeValue, str](make_nil());
    }

    # look up in symbol table for compile-time constants
    if (ctx.symbols != nil) {
        val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(ctx.symbols, name);
        if (option_is_some[*symbol.Symbol](sym_opt)) {
            val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
            # check if it's a val (immutable) with a known value
            if (sym.kind == symbol.SYM_VAL && sym.decl_node != nil) {
                ret eval(ctx, sym.decl_node);
            }
        }
    }

    ret err[ComptimeValue, str]("identifier is not a compile-time constant");
}



# eval_field: evaluate a field access at compile time (for $mach.* intrinsics).
fun eval_field(ctx: *ComptimeContext, expr: *ast.Node) Result[ComptimeValue, str] {
    # field access nodes have base as children and field name in data
    if (expr == nil) {
        ret err[ComptimeValue, str]("expression is nil");
    }
    if (expr.info.field_expr.object == nil) {
        ret err[ComptimeValue, str]("field access has no base");
    }

    # for field access, flatten and evaluate as comptime path
    ret eval_comptime_path(ctx, expr);
}

# flatten_path: collect path segments from a field access chain.
# returns segments in order [root, ..., leaf], e.g. ["mach", "build", "target", "pointer_width"]
fun flatten_path(expr: *ast.Node, segments: *[16]str, count: *i32) bool {
    if (expr == nil || segments == nil || count == nil) {
        ret false;
    }

    if (expr.kind == ast.NODE_EXPR_IDENT) {
        # base case: identifier
        val name: str = expr.info.ident_expr.name;
        if (name != nil && @count < 16) {
            (@segments)[@count] = name;
            @count = @count + 1;
            ret true;
        }
        ret false;
    }

    if (expr.kind == ast.NODE_EXPR_FIELD) {
        # recursive case: field access
        val base: *ast.Node = expr.info.field_expr.object;
        if (base == nil) {
            ret false;
        }
        # first flatten the base
        if (!flatten_path(base, segments, count)) {
            ret false;
        }
        # then add this field name
        val field: str = expr.info.field_expr.field;
        if (field != nil && @count < 16) {
            (@segments)[@count] = field;
            @count = @count + 1;
            ret true;
        }
        ret false;
    }

    # comptime node - recurse into its inner (the actual path expression)
    if (expr.kind == ast.NODE_COMPTIME) {
        if (expr.info.wrapper.inner != nil) {
            ret flatten_path(expr.info.wrapper.inner, segments, count);
        }
        ret false;
    }

    ret false;
}

# eval_comptime_path: evaluate a $mach.* path expression.
fun eval_comptime_path(ctx: *ComptimeContext, expr: *ast.Node) Result[ComptimeValue, str] {
    var segments: [16]str;
    var count: i32 = 0;

    if (!flatten_path(expr, ?segments, ?count)) {
        ret err[ComptimeValue, str]("failed to flatten comptime path");
    }

    if (count < 1) {
        ret err[ComptimeValue, str]("empty comptime path");
    }

    # path must start with "mach"
    if (!str_equals(segments[0], "mach")) {
        ret err[ComptimeValue, str]("comptime path must start with 'mach'");
    }

    # $mach.compiler.version
    if (count == 3 && str_equals(segments[1], "compiler") && str_equals(segments[2], "version")) {
        ret ok[ComptimeValue, str](make_string("0.1.0"));
    }

    # $mach.compiler.name
    if (count == 3 && str_equals(segments[1], "compiler") && str_equals(segments[2], "name")) {
        ret ok[ComptimeValue, str](make_string("mach"));
    }

    # $mach.build.target.pointer_width
    if (count == 4 && str_equals(segments[1], "build") && str_equals(segments[2], "target") && str_equals(segments[3], "pointer_width")) {
        ret ok[ComptimeValue, str](make_int(target.pointer_size(?ctx.tgt)::i64));
    }

    # $mach.build.target.os
    if (count == 4 && str_equals(segments[1], "build") && str_equals(segments[2], "target") && str_equals(segments[3], "os")) {
        ret ok[ComptimeValue, str](make_string(ctx.target_os));
    }

    # $mach.build.target.arch
    if (count == 4 && str_equals(segments[1], "build") && str_equals(segments[2], "target") && str_equals(segments[3], "arch")) {
        ret ok[ComptimeValue, str](make_string(ctx.target_isa));
    }

    # $mach.build.target.os.id
    if (count == 5 && str_equals(segments[1], "build") && str_equals(segments[2], "target") && str_equals(segments[3], "os") && str_equals(segments[4], "id")) {
        ret ok[ComptimeValue, str](make_int(os_id_from_name(ctx.target_os)));
    }

    # $mach.build.target.arch.id
    if (count == 5 && str_equals(segments[1], "build") && str_equals(segments[2], "target") && str_equals(segments[3], "arch") && str_equals(segments[4], "id")) {
        ret ok[ComptimeValue, str](make_int(arch_id_from_name(ctx.target_isa)));
    }

    # $mach.os.<name>.id - e.g. $mach.os.linux.id
    if (count == 4 && str_equals(segments[1], "os") && str_equals(segments[3], "id")) {
        ret ok[ComptimeValue, str](make_int(os_id_from_name(segments[2])));
    }

    # $mach.arch.<name>.id - e.g. $mach.arch.x86_64.id
    if (count == 4 && str_equals(segments[1], "arch") && str_equals(segments[3], "id")) {
        ret ok[ComptimeValue, str](make_int(arch_id_from_name(segments[2])));
    }

    ret err[ComptimeValue, str]("unknown $mach intrinsic path");
}

# os_id_from_name: convert OS name to numeric ID.
fun os_id_from_name(name: str) i64 {
    if (name == nil) {
        ret 0;
    }
    if (str_equals(name, "linux")) {
        ret 1;
    }
    if (str_equals(name, "macos") || str_equals(name, "darwin")) {
        ret 2;
    }
    if (str_equals(name, "windows")) {
        ret 3;
    }
    ret 0;
}

# arch_id_from_name: convert architecture name to numeric ID.
fun arch_id_from_name(name: str) i64 {
    if (name == nil) {
        ret 0;
    }
    if (str_equals(name, "x86_64")) {
        ret 1;
    }
    if (str_equals(name, "arm64") || str_equals(name, "aarch64")) {
        ret 2;
    }
    ret 0;
}

# eval_condition: evaluate a compile-time boolean condition (for $if).
# ---
# ctx:  comptime context
# cond: condition expression
# ret:  Ok(bool) on success, Err(str) on failure
pub fun eval_condition(ctx: *ComptimeContext, cond: *ast.Node) Result[bool, str] {
    val res: Result[ComptimeValue, str] = eval(ctx, cond);
    if (result_is_err[ComptimeValue, str](res)) {
        ret err[bool, str](result_unwrap_err[ComptimeValue, str](res));
    }

    val value: ComptimeValue = result_unwrap_ok[ComptimeValue, str](res);

    # the value should be boolean - return bool_val
    # note: for integer comparisons, the result is already a bool via make_bool
    ret ok[bool, str](value.bool_val);
}

# size_of: get the size of a type at compile time.
# ---
# ctx:       comptime context
# type_node: AST node representing the type
# ret:       Ok(size in bytes) on success, Err(str) on failure
pub fun size_of(ctx: *ComptimeContext, type_node: *ast.Node) Result[usize, str] {
    if (ctx == nil) {
        ret err[usize, str]("context is nil");
    }

    if (type_node == nil) {
        ret err[usize, str]("type node is nil");
    }

    # handle primitive type names
    if (type_node.kind == ast.NODE_TYPE_NAME) {
        val name: str = type_node.info.type_name.path;
        if (name != nil) {
            ret size_of_primitive(name, ?ctx.tgt);
        }
    }

    # handle pointer types
    if (type_node.kind == ast.NODE_TYPE_PTR || type_node.kind == ast.NODE_TYPE_REF) {
        ret ok[usize, str](target.pointer_size(?ctx.tgt));
    }

    # handle array types
    if (type_node.kind == ast.NODE_TYPE_ARRAY) {
        # would need to extract element type and count
        ret err[usize, str]("array size_of not yet implemented");
    }

    ret err[usize, str]("cannot determine size of type");
}

# primitive_size_align: get size and alignment of a primitive type.
# For all current primitives, size == alignment.
fun primitive_size_align(name: str, out_size: *usize, out_align: *usize, tgt: *target.Target) bool {
    if (name == nil) {
        ret false;
    }

    var ptr_sz: usize = 8;
    if (tgt != nil) { ptr_sz = target.pointer_size(tgt); }

    var sz: usize = 0;

    # signed integers
    if (str_equals(name, "i8")) { sz = 1; }
    if (str_equals(name, "i16")) { sz = 2; }
    if (str_equals(name, "i32")) { sz = 4; }
    if (str_equals(name, "i64")) { sz = 8; }
    if (str_equals(name, "isize")) { sz = ptr_sz; }

    # unsigned integers
    if (str_equals(name, "u8")) { sz = 1; }
    if (str_equals(name, "u16")) { sz = 2; }
    if (str_equals(name, "u32")) { sz = 4; }
    if (str_equals(name, "u64")) { sz = 8; }
    if (str_equals(name, "usize")) { sz = ptr_sz; }

    # floats
    if (str_equals(name, "f32")) { sz = 4; }
    if (str_equals(name, "f64")) { sz = 8; }

    # boolean
    if (str_equals(name, "bool")) { sz = 1; }

    # pointers and strings
    if (str_equals(name, "ptr")) { sz = ptr_sz; }
    if (str_equals(name, "str")) { sz = ptr_sz; }

    if (sz == 0) {
        ret false;
    }

    @out_size = sz;
    @out_align = sz;
    ret true;
}

# size_of_primitive: get size of a primitive type by name.
fun size_of_primitive(name: str, tgt: *target.Target) Result[usize, str] {
    var sz: usize = 0;
    var al: usize = 0;
    if (primitive_size_align(name, ?sz, ?al, tgt)) {
        ret ok[usize, str](sz);
    }
    ret err[usize, str]("unknown primitive type");
}

# align_of: get the alignment of a type at compile time.
# ---
# ctx:       comptime context
# type_node: AST node representing the type
# ret:       Ok(alignment in bytes) on success, Err(str) on failure
pub fun align_of(ctx: *ComptimeContext, type_node: *ast.Node) Result[usize, str] {
    ret align_of_type(ctx, type_node);
}

# align_of_type: internal implementation of align_of to avoid recursion issues.
fun align_of_type(ctx: *ComptimeContext, type_node: *ast.Node) Result[usize, str] {
    if (ctx == nil) {
        ret err[usize, str]("context is nil");
    }

    if (type_node == nil) {
        ret err[usize, str]("type node is nil");
    }

    # handle primitive type names - alignment equals size for most primitives
    if (type_node.kind == ast.NODE_TYPE_NAME) {
        val name: str = type_node.info.type_name.path;
        if (name != nil) {
            ret align_of_primitive(name, ?ctx.tgt);
        }
    }

    # handle pointer types
    if (type_node.kind == ast.NODE_TYPE_PTR || type_node.kind == ast.NODE_TYPE_REF) {
        ret ok[usize, str](target.pointer_align(?ctx.tgt));
    }

    # handle array types - alignment is alignment of element type
    if (type_node.kind == ast.NODE_TYPE_ARRAY) {
        if (type_node.info.type_array.elem_type != nil) {
            ret align_of_type(ctx, type_node.info.type_array.elem_type);
        }
        ret err[usize, str]("array has no element type");
    }

    ret err[usize, str]("cannot determine alignment of type");
}

# align_of_primitive: get alignment of a primitive type by name.
fun align_of_primitive(name: str, tgt: *target.Target) Result[usize, str] {
    var sz: usize = 0;
    var al: usize = 0;
    if (primitive_size_align(name, ?sz, ?al, tgt)) {
        ret ok[usize, str](al);
    }
    ret err[usize, str]("unknown primitive type");
}

# is_target_os: check if the current target OS matches.
# ---
# ctx: comptime context
# os:  OS name to check (e.g. "linux")
# ret: true if target OS matches
pub fun is_target_os(ctx: *ComptimeContext, os: str) bool {
    if (ctx == nil || os == nil) {
        ret false;
    }

    if (ctx.target_os == nil) {
        ret false;
    }

    ret str_equals(ctx.target_os, os);
}

# is_target_isa: check if the current target ISA matches.
# ---
# ctx: comptime context
# isa: ISA name to check (e.g. "x86_64")
# ret: true if target ISA matches
pub fun is_target_isa(ctx: *ComptimeContext, isa: str) bool {
    if (ctx == nil || isa == nil) {
        ret false;
    }

    if (ctx.target_isa == nil) {
        ret false;
    }

    ret str_equals(ctx.target_isa, isa);
}

# make_int: create an integer compile-time value.
# ---
# val: integer value
# ret: ComptimeValue with integer kind
pub fun make_int(value: i64) ComptimeValue {
    var v: ComptimeValue;
    v.kind = ComptimeKind { ct_int: 0 };
    v.int_val = value;
    v.bool_val = false;
    v.str_val = nil;
    ret v;
}

# make_bool: create a boolean compile-time value.
# ---
# val: boolean value
# ret: ComptimeValue with boolean kind
pub fun make_bool(value: bool) ComptimeValue {
    var v: ComptimeValue;
    v.kind = ComptimeKind { ct_bool: 0 };
    v.int_val = 0;
    v.bool_val = value;
    v.str_val = nil;
    ret v;
}

# make_string: create a string compile-time value.
# ---
# val: string value
# ret: ComptimeValue with string kind
pub fun make_string(value: str) ComptimeValue {
    var v: ComptimeValue;
    v.kind = ComptimeKind { ct_string: 0 };
    v.int_val = 0;
    v.bool_val = false;
    v.str_val = value;
    ret v;
}

# make_nil: create a nil compile-time value.
# ---
# ret: ComptimeValue with nil kind
pub fun make_nil() ComptimeValue {
    var v: ComptimeValue;
    v.kind = ComptimeKind { ct_nil: 0 };
    v.int_val = 0;
    v.bool_val = false;
    v.str_val = nil;
    ret v;
}
