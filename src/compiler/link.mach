use std.types.bool;
use std.types.size;
use std.types.string;

use target: mach.compiler.target;
use os:     mach.compiler.os;

# mach.compiler.link: object file linking.
# ---
# bridges object files to executables via the OS interface.
# all linker configuration (CRT paths, library flags, etc.) is
# handled internally by the OS implementation.

# link: link object files into an executable.
# returns 0 on success, nonzero on failure.
pub fun link(objects: *str, count: i32, output: str,
             tgt: *target.Target) i64 {
    if (tgt == nil || objects == nil || output == nil) { ret 1; }

    val o: *os.OS = ?tgt.os;
    ret o.link(o.ctx, objects, count, output);
}

# entry_point: get the entry point symbol name for the target.
pub fun entry_point(tgt: *target.Target) str {
    if (tgt == nil) { ret nil; }
    val o: *os.OS = ?tgt.os;
    ret o.entry_point(o.ctx);
}
