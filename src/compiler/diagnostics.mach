use          std.text.ascii;
use          std.types.bool;
use          std.types.option;
use          std.types.size;
use          std.types.string;
use console: std.io.console;
use tokens:  std.lang.tokens;

use mach.compiler.stages;

pub def ErrorLevel:    u8;
pub val ERROR_WARNING: ErrorLevel = 0;
pub val ERROR_ERROR:   ErrorLevel = 1;
pub val ERROR_FATAL:   ErrorLevel = 2;

pub fun (this: ErrorLevel) name() string {
    if (this == ERROR_WARNING) { ret "warning"; }
    if (this == ERROR_ERROR) { ret "error"; }
    if (this == ERROR_FATAL) { ret "fatal"; }
    ret "note";
}

pub rec Diagnostic {
    level:   ErrorLevel;
    stage:   PipelineStage;
    span:    tokens.Span;
    message: string;
}

# format and print a single diagnostic
pub fun (this: Diagnostic) print(source: string, file_path: string) {
	# determine severity prefix
	val prefix:      string = this.level.name();
	val stage_label: string = this.stage.name();
	
	# print main diagnostic line
	console.print("%s:%d:%d: %s (%s): %s\n", 
		file_path, 
		this.span.line, 
		this.span.column, 
		prefix,
		stage_label,
		this.message);
	
	# extract and print the source line if possible
	if (source.data != nil && source.len > 0) {
		val line_opt: Option[string] = extract_source_line(source, this.span.line);
		if (line_opt.is_some()) {
			val line: string = line_opt.unwrap();
			console.print("  %s\n", line);
			
			# print caret indicator
			print_caret_line(this.span.column, this.span.length);
		}
	}
}

# extract a specific line from source code
fun extract_source_line(source: string, line_num: usize) Option[string] {
	if (source.data == nil || line_num == 0) {
		ret none[string]();
	}
	
	var current_line: usize = 1;
	var line_start: usize = 0;
	var i: usize = 0;
	
	# find the line
	for (i < source.len) {
		val ch: u8 = @(source.data + i);
		
		if (current_line == line_num && ch == '\n') {
			# found the end of our target line
			val line_len: usize = i - line_start;
			ret some[string](string{ (source.data + line_start), line_len });
		}
		
		if (ch == '\n') {
			current_line = current_line + 1;
			line_start = i + 1;
		}
		
		i = i + 1;
	}
	
	# handle last line without newline
	if (current_line == line_num) {
		val line_len: usize = source.len - line_start;
		ret some[string](string{ (source.data + line_start), line_len });
	}
	
	ret none[string]();
}

# print caret indicator line
fun print_caret_line(column: usize, length: usize) {
	console.print("  ");
	
	# print spaces up to the column
	var i: usize = 1;
	for (i < column) {
		console.print(" ");
		i = i + 1;
	}
	
	# print carets
	var caret_len: usize = length;
	if (caret_len == 0) {
		caret_len = 1;
	}
	
	i = 0;
	for (i < caret_len) {
		console.print("^");
		i = i + 1;
	}
	
	console.print("\n");
}
