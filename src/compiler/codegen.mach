# mach.compiler.codegen: thin codegen dispatcher.
# ---
# delegates per-function code generation to the ISA backend via the
# opaque codegen_function entry point. the orchestrator never touches
# machine instruction internals.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;

use target:    mach.compiler.target;
use fn:        masm.function;
use module:    masm.module;
use msym:      masm.symbol;
use isa:       mach.compiler.target.isa;
use abi:       mach.compiler.target.abi;
use section:   mach.compiler.target.of.section;
use objstate:  mach.compiler.codegen.objstate;
use emasm:     mach.compiler.codegen.emit_asm;
use xcg:       mach.compiler.target.isa.x86_64.codegen;

# codegen: run the backend pipeline for all functions in a module.
# dispatches each function to the ISA backend. returns false if any fail.
pub fun codegen(mod: *module.Module, obj: *objstate.ObjState, tgt: *target.Target,
            alloc: *allocator.Allocator, verbose: bool,
            asm_w: *emasm.AsmWriter) bool {
    if (mod == nil || obj == nil || tgt == nil || alloc == nil) { ret false; }

    val i: *isa.ISA = ?tgt.isa;

    if (verbose) {
        print.eprintf("[verbose] codegen: starting (%d IR functions)\n",
            mod.functions.len::i64);
    }

    val text_res: Result[*section.Section, str] = objstate.get_or_create_section(
        obj, ".text", msym.SEC_TEXT);
    if (result_is_err[*section.Section, str](text_res)) { ret false; }
    val text_sec: *section.Section = result_unwrap_ok[*section.Section, str](text_res);
    val text_idx: i32 = objstate.get_section_index(obj, ".text");

    var ok: bool = true;

    var fi: i32 = 0;
    for (fi < mod.functions.len::i32) {
        val func: *fn.Function = mod.functions.data[fi];
        if (func == nil) { fi = fi + 1; cnt; }

        if (verbose) {
            print.eprintf("[verbose] codegen: func[%d] '%s'\n", fi::i64, func.name);
        }

        var req: xcg.CodegenRequest;
        req.func = func;
        req.text_sec = text_sec;
        req.text_idx = text_idx;
        req.obj = obj;
        req.abi = ?tgt.abi;
        req.isa = i;
        req.alloc = alloc;
        req.asm_w = asm_w;
        req.verbose = verbose;

        val result: isa.BackendResult = i.codegen_function(i.ctx, ?req::ptr);

        if (!result.ok) {
            print.eprintf("[verbose] codegen:   backend FAILED for '%s'\n", func.name);
            ok = false;
            fi = fi + 1;
            cnt;
        }

        if (verbose) {
            print.eprintf("[verbose] codegen:   backend: ir=%d inst=%d spill=%d frame=%d\n",
                result.ir_count::i64, result.inst_count::i64,
                result.spill_count::i64, result.frame_size::i64);
        }

        fi = fi + 1;
    }

    if (verbose) { print.eprint("[verbose] codegen: complete\n"); }
    ret ok;
}
