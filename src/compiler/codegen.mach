# mach.compiler.codegen: per-function compilation pipeline

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use iobuf:     std.io.buffer;

use masm_fn:     masm.function;
use masm_verify: masm.verify;
use masm_cfg:    masm.cfg;
use masm_pool:   masm.pool;

use target:   mach.compiler.target.target;
use isa:      mach.compiler.target.isa;
use of:       mach.compiler.target.of;
use pass:     mach.compiler.opt.pass;
use ra:       mach.compiler.regalloc;

pub rec CodegenResult {
    ok:          bool;
    spill_size:  usize;
    callee_mask: u32;
    local_size:  usize;
}

pub fun compile_function(func: *masm_fn.Function, local_size: usize,
                         tgt: *target.Target, opt: *pass.PassPipeline,
                         alloc: *allocator.Allocator, obj: *of.ObjWriter,
                         asm_buf: *iobuf.WriteBuf) CodegenResult {
    var result: CodegenResult;
    result.ok          = false;
    result.spill_size  = 0;
    result.callee_mask = 0;
    result.local_size  = local_size;

    if (func == nil || tgt == nil) { ret result; }

    if (!verify(func))            { ret result; }
    if (!optimize(opt, func))     { ret result; }

    var isel_buf: isa.InstBuf = select_instructions(tgt, func, alloc);
    if (isel_buf.insts == nil) { ret result; }

    var cfg: masm_cfg.CFG = masm_cfg.build_cfg(alloc, func);
    var live: masm_cfg.LiveSets = masm_cfg.compute_liveness(alloc, ?cfg, func);

    var ra_result: ra.RegAllocResult = ra.alloc_function(
        alloc, ?tgt.isa, ?tgt.abi, ?isel_buf, local_size, ?cfg, ?live
    );
    isa.buf_dnit(?isel_buf);
    if (!ra_result.ok) {
        isa.buf_dnit(?ra_result.out);
        ret result;
    }

    result.spill_size  = ra_result.spill_size;
    result.callee_mask = ra_result.callee_mask;
    result.local_size  = compute_frame_size(local_size, ra_result.spill_size);

    var is_naked: bool = is_naked_asm(?ra_result.out);
    var final_buf: isa.InstBuf;
    if (is_naked) {
        final_buf = ra_result.out;
    } or {
        final_buf = insert_prologue_epilogue(tgt, alloc, ?ra_result.out, result.local_size);
        isa.buf_dnit(?ra_result.out);
    }

    if (asm_buf != nil && tgt.isa.print_inst != nil) {
        var ai: i32 = 0;
        for (ai < final_buf.count) {
            tgt.isa.print_inst(tgt.isa.ctx, ?final_buf.insts[ai], asm_buf);
            ai = ai + 1;
        }
    }

    if (!encode_and_emit(tgt, alloc, obj, func, ?final_buf)) {
        isa.buf_dnit(?final_buf);
        ret result;
    }

    isa.buf_dnit(?final_buf);
    result.ok = true;
    ret result;
}

fun verify(func: *masm_fn.Function) bool {
    val res: Result[bool, str] = masm_verify.verify_function(func);
    if (is_err[bool, str](res)) { ret false; }
    ret unwrap_ok[bool, str](res);
}

fun optimize(opt: *pass.PassPipeline, func: *masm_fn.Function) bool {
    if (opt == nil) { ret true; }
    ret pass.run(opt, func);
}

fun select_instructions(tgt: *target.Target, func: *masm_fn.Function,
                        alloc: *allocator.Allocator) isa.InstBuf {
    var buf: isa.InstBuf = isa.buf_init(alloc);

    val isel_fn: fun(ptr, ptr, ptr, *isa.InstBuf) bool = tgt.isa.isel;
    if (isel_fn == nil) {
        isa.buf_dnit(?buf);
        buf.insts = nil;
        ret buf;
    }

    if (!isel_fn(tgt.isa.ctx, nil, func::ptr, ?buf)) {
        isa.buf_dnit(?buf);
        buf.insts = nil;
        ret buf;
    }

    ret buf;
}

fun is_naked_asm(buf: *isa.InstBuf) bool {
    if (buf.count == 0) { ret false; }
    var i: i32 = 0;
    for (i < buf.count) {
        if (buf.insts[i].opcode != isa.ISA_ASM_MARKER) { ret false; }
        i = i + 1;
    }
    ret true;
}

fun compute_frame_size(local_size: usize, spill_size: usize) usize {
    var total: usize = local_size + spill_size;
    if (total > 0) {
        total = (total + 15) & ~15::usize;
    }
    ret total;
}

fun insert_prologue_epilogue(tgt: *target.Target, alloc: *allocator.Allocator,
                             ra_out: *isa.InstBuf, frame_size: usize) isa.InstBuf {
    var buf: isa.InstBuf = isa.buf_init(alloc);
    if (tgt.isa.emit_prologue != nil) {
        tgt.isa.emit_prologue(tgt.isa.ctx, ?buf, frame_size);
    }

    var i: i32 = 0;
    for (i < ra_out.count) {
        val inst: isa.Inst = ra_out.insts[i];
        if (tgt.isa.is_ret != nil && tgt.isa.is_ret(tgt.isa.ctx, ?ra_out.insts[i])) {
            if (tgt.isa.emit_epilogue != nil) {
                tgt.isa.emit_epilogue(tgt.isa.ctx, ?buf);
            }
        }
        isa.buf_append(?buf, inst);
        i = i + 1;
    }

    ret buf;
}

fun emit_label_reloc(tgt: *target.Target, obj: *of.ObjWriter,
                     mi: *isa.Inst, inst_size: i32, base_offset: usize) {
    if (obj.add_symbol == nil || obj.add_reloc == nil) { ret; }

    emit_operand_reloc(tgt, obj, ?mi.dst, inst_size, base_offset);
    emit_operand_reloc(tgt, obj, ?mi.src1, inst_size, base_offset);
}

fun emit_operand_reloc(tgt: *target.Target, obj: *of.ObjWriter,
                       op: *isa.Operand, inst_size: i32, base_offset: usize) {
    if (op.label == nil || inst_size < 4) { ret; }
    if (obj.add_symbol == nil || obj.add_reloc == nil) { ret; }

    val sym_id: u32 = obj.add_symbol(obj.ctx, op.label, -1, 0, 0, true);
    val disp_off: usize = base_offset + (inst_size - 4)::usize;

    if (op.kind == isa.OPK_LABEL) {
        obj.add_reloc(obj.ctx, 0, disp_off, of.RK_PC32, sym_id, -4::i64);
    } or (op.kind == isa.OPK_MEM) {
        obj.add_reloc(obj.ctx, 0, disp_off, of.RK_ABS32S, sym_id, 0);
    }
}

fun encode_and_emit(tgt: *target.Target, alloc: *allocator.Allocator,
                    obj: *of.ObjWriter, func: *masm_fn.Function,
                    buf: *isa.InstBuf) bool {
    val encode_fn: fun(ptr, *isa.Inst, ptr, *allocator.Allocator) i32 = tgt.isa.encode;
    if (encode_fn == nil) { ret false; }

    var text_sec_ptr: *of.Section = nil;
    if (obj != nil && obj.get_section != nil) {
        text_sec_ptr = obj.get_section(obj.ctx, 0);
    }
    if (text_sec_ptr == nil) { ret false; }

    val start_offset: usize = text_sec_ptr.size;

    val debug_line_fn: fun(ptr, u64, u16, u32, u32) = tgt.of.debug.add_line;
    val debug_file_fn: fun(ptr, str, str) u16 = tgt.of.debug.add_file;
    val debug_ctx: ptr = tgt.of.debug.ctx;

    var addr: u64 = 0;
    var i: i32 = 0;
    for (i < buf.count) {
        if (buf.insts[i].opcode == isa.ISA_ASM_MARKER) {
            val lbl_idx: u16 = buf.insts[i].dst.imm::u16;
            val asm_text: str = masm_pool.label_get(?func.labels, lbl_idx::i32);
            if (asm_text != nil && tgt.isa.parse_asm != nil) {
                var asm_buf: isa.InstBuf = isa.buf_init(alloc);
                tgt.isa.parse_asm(tgt.isa.ctx, asm_text, ?asm_buf, alloc);

                var ai: i32 = 0;
                for (ai < asm_buf.count) {
                    val asm_inst_size: i32 = encode_fn(tgt.isa.ctx, ?asm_buf.insts[ai], text_sec_ptr::ptr, alloc);

                    if (asm_inst_size > 0) {
                        emit_label_reloc(tgt, obj, ?asm_buf.insts[ai], asm_inst_size, start_offset + addr::usize);
                    }

                    if (asm_inst_size > 0) { addr = addr + asm_inst_size::u64; }
                    ai = ai + 1;
                }
                isa.buf_dnit(?asm_buf);
            }
            i = i + 1;
            cnt;
        }

        val inst_size: i32 = encode_fn(tgt.isa.ctx, ?buf.insts[i], text_sec_ptr::ptr, alloc);

        if (inst_size > 0) {
            emit_label_reloc(tgt, obj, ?buf.insts[i], inst_size, start_offset + addr::usize);
        }

        if (debug_line_fn != nil && debug_ctx != nil) {
            val src_line: u32 = buf.insts[i].src_line;
            val src_file: str = buf.insts[i].src_file;
            if (src_line > 0 && src_file != nil) {
                val file_idx: u16 = debug_file_fn(debug_ctx, src_file, ".");
                if (file_idx > 0) {
                    debug_line_fn(debug_ctx, addr, file_idx, src_line, 0);
                }
            }
        }

        if (inst_size > 0) { addr = addr + inst_size::u64; }
        i = i + 1;
    }

    if (obj.add_symbol != nil && func.name != nil) {
        obj.add_symbol(obj.ctx, func.name, 0, start_offset, addr::usize, true);
    }

    if (debug_ctx != nil && tgt.of.debug.add_function != nil && func.name != nil) {
        var fn_file_idx: u16 = 0;
        if (buf.count > 0) {
            val first_file: str = buf.insts[0].src_file;
            if (first_file != nil) {
                fn_file_idx = debug_file_fn(debug_ctx, first_file, ".");
            }
        }
        var fn_line: u32 = 0;
        if (buf.count > 0) {
            fn_line = buf.insts[0].src_line;
        }
        tgt.of.debug.add_function(debug_ctx, func.name, fn_file_idx, fn_line, 0, addr);
    }

    ret true;
}

