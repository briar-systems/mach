# mach.compiler.codegen: per-function compilation pipeline
#
# orchestrates the backend pipeline for a single function. this is the
# parallelism boundary -- each function is compiled independently through
# verify, optimize, CFG, liveness, ISel, peephole, regalloc, frame
# layout, prologue/epilogue, and encoding.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use masm_fn:     masm.function;
use masm_verify: masm.verify;
use masm_cfg:    masm.cfg;

use target: mach.compiler.target.target;
use isa:    mach.compiler.target.isa;
use of:     mach.compiler.target.of;
use pass:   mach.compiler.opt.pass;
use ra:     mach.compiler.regalloc;

# result of compiling a single function
# ---
# ok:          true if compilation succeeded
# spill_size:  bytes consumed by register spill slots
# callee_mask: bitmask of callee-saved registers used
# local_size:  bytes of local variables on the stack
pub rec CodegenResult {
    ok:          bool;
    spill_size:  usize;
    callee_mask: u32;
    local_size:  usize;
}

# compile_function: compile a single MASM IR function through the full backend pipeline.
#
# pipeline steps:
# 1. verify IR structure
# 2. run optimization passes
# 3. build CFG
# 4. compute liveness
# 5. instruction selection (IR -> machine instructions)
# 6. peephole optimization
# 7. register allocation
# 8. frame layout
# 9. prologue/epilogue insertion
# 10. encoding (machine instructions -> bytes)
# ---
# func:       MASM IR function to compile
# local_size: bytes of local variables from lowering
# tgt:        target descriptor (ISA, ABI, OS, object format)
# opt:        optimization pipeline to run
# alloc:      backing allocator
# obj:        object writer for encoded output
# ret:        compilation result
pub fun compile_function(func: *masm_fn.Function, local_size: usize,
                         tgt: *target.Target, opt: *pass.PassPipeline,
                         alloc: *allocator.Allocator, obj: *of.ObjWriter) CodegenResult {
    var result: CodegenResult;
    result.ok          = false;
    result.spill_size  = 0;
    result.callee_mask = 0;
    result.local_size  = local_size;

    if (func == nil || tgt == nil) { ret result; }

    # 1. verify IR
    if (!masm_verify.verify_function(func)) {
        ret result;
    }

    # 2. optimization passes
    if (opt != nil) {
        if (!pass.run(opt, func)) {
            ret result;
        }
    }

    # 3. build CFG
    var cfg: masm_cfg.CFG = masm_cfg.build_cfg(alloc, func);

    # 4. compute liveness
    var live: masm_cfg.LiveSets = masm_cfg.compute_liveness(alloc, ?cfg, func);

    # 5. instruction selection
    var isel_buf: isa.InstBuf = isa.buf_init(alloc);

    val isel_fn: fun(ptr, ptr, ptr, *isa.InstBuf) bool = tgt.isa.isel;
    if (isel_fn != nil) {
        val isel_ok: bool = isel_fn(tgt.isa.ctx, nil, func::ptr, ?isel_buf);
        if (!isel_ok) {
            isa.buf_dnit(?isel_buf);
            ret result;
        }
    }

    # 6. peephole optimization (no-op until ISA backends provide it)

    # 7. register allocation
    var ra_result: ra.RegAllocResult = ra.alloc_function(
        alloc, ?tgt.isa, ?tgt.abi, ?isel_buf, local_size, ?cfg, ?live
    );

    isa.buf_dnit(?isel_buf);

    if (!ra_result.ok) {
        isa.buf_dnit(?ra_result.out);
        ret result;
    }

    result.spill_size  = ra_result.spill_size;
    result.callee_mask = ra_result.callee_mask;

    # 8. frame layout
    val frame_size: usize = local_size + ra_result.spill_size;
    result.local_size = frame_size;

    # 9. prologue/epilogue (no-op until ISA backends provide it)

    # 10. encode and collect debug line info
    val encode_fn: fun(ptr, *isa.Inst, ptr, &allocator.Allocator) i32 = tgt.isa.encode;
    var text_sec: ptr = nil;
    if (obj != nil && obj.get_section != nil) {
        val sec_ptr: *of.Section = obj.get_section(obj.ctx, 0);
        if (sec_ptr != nil) {
            text_sec = sec_ptr::ptr;
        }
    }
    if (encode_fn != nil && text_sec != nil) {
        var addr: u64 = 0;
        val debug_fn: fun(ptr, u64, u16, u32, u32) = tgt.of.debug.add_line;
        val debug_file_fn: fun(ptr, str, str) u16 = tgt.of.debug.add_file;
        val debug_ctx: ptr = tgt.of.debug.ctx;

        var ei: i32 = 0;
        for (ei < ra_result.out.count) {
            val inst_size: i32 = encode_fn(tgt.isa.ctx, ?ra_result.out.insts[ei], text_sec, alloc);

            if (debug_fn != nil && debug_ctx != nil) {
                val src_line: u32 = ra_result.out.insts[ei].src_line;
                val src_file: str = ra_result.out.insts[ei].src_file;
                if (src_line > 0 && src_file != nil) {
                    val file_idx: u16 = debug_file_fn(debug_ctx, src_file, ".");
                    if (file_idx > 0) {
                        debug_fn(debug_ctx, addr, file_idx, src_line, 0);
                    }
                }
            }

            if (inst_size > 0) { addr = addr + inst_size::u64; }
            ei = ei + 1;
        }

        if (debug_ctx != nil && tgt.of.debug.add_function != nil && func.name != nil) {
            var fn_file_idx: u16 = 0;
            if (ra_result.out.count > 0) {
                val first_file: str = ra_result.out.insts[0].src_file;
                if (first_file != nil) {
                    fn_file_idx = debug_file_fn(debug_ctx, first_file, ".");
                }
            }
            var fn_line: u32 = 0;
            if (ra_result.out.count > 0) {
                fn_line = ra_result.out.insts[0].src_line;
            }
            tgt.of.debug.add_function(debug_ctx, func.name, fn_file_idx, fn_line, 0, addr);
        }
    }

    isa.buf_dnit(?ra_result.out);

    result.ok = true;
    ret result;
}
