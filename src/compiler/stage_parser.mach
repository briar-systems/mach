use          std.types.bool;
use          std.types.list;
use          std.types.option;
use          std.types.result;
use          std.types.string;
use          std.lang.tokens;

use          mach.compiler.compilation_unit;
use          mach.compiler.stages;

# placeholder parser stage - ensures tokens are available before parsing
pub fun run(cu: *CompilationUnit) Result[bool, string] {
    if (cu.reached_stage(STAGE_PARSER)) {
        ret ok[bool, string](true);
    }

    val tokens_opt: Option[List[Token]] = cu.get_tokens();
    if (tokens_opt.is_none()) {
        ret err[bool, string]("lexer stage must run before parser");
    }

    ret err[bool, string]("parser stage not implemented");
}
