use std.lang.ast;
use std.lang.files;
use std.lang.parser;
use std.lang.tokens;
use std.types.bool;
use std.types.list;
use std.types.option;
use std.types.result;
use std.types.string;

use mach.compiler.compilation_unit;
use mach.compiler.diagnostics;
use mach.compiler.stages;

# run the parser stage on a compilation unit
pub fun run(cu: *CompilationUnit) Result[bool, string] {
    if (cu.reached_stage(STAGE_PARSER)) {
        ret ok[bool, string](true);
    }

    val tokens_opt: Option[List[Token]] = cu.get_tokens();
    if (tokens_opt.is_none()) {
        ret err[bool, string]("lexer stage must run before parser");
    }

    var tokens: List[Token] = tokens_opt.unwrap();
    var tokens_ptr: *List[Token] = ?tokens;

    var ast: AST;
    val ast_init_err: Option[string] = ast.init();
    if (ast_init_err.is_some()) {
        val err_msg: string = ast_init_err.unwrap();
        var empty_span: Span;
        empty_span.offset  = 0;
        empty_span.length  = 0;
        empty_span.line    = 0;
        empty_span.column  = 0;
        empty_span.file_id = FILE_ID_INVALID;
        cu.add_diagnostic(
            ERROR_ERROR,
            STAGE_PARSER,
            empty_span,
            err_msg
        );
        ret err[bool, string](err_msg);
    }

    var ast_ptr: *AST = ?ast;

    var parser: Parser;
    val init_err: Option[string] = parser.init(tokens_ptr, ast_ptr);
    if (init_err.is_some()) {
        val err_msg: string = init_err.unwrap();
        parser.skip_comments();
        val err_span: Span = parser.current().span;
        cu.add_diagnostic(
            ERROR_ERROR,
            STAGE_PARSER,
            err_span,
            err_msg
        );
        parser.dnit();
        ast_ptr.dnit();
        ret err[bool, string](err_msg);
    }

    val parse_res: Result[AST, string] = parser.parse_module();
    if (parse_res.is_err()) {
        val err_msg: string = parse_res.unwrap_err();
        parser.skip_comments();
        val err_span: Span = parser.current().span;
        cu.add_diagnostic(
            ERROR_ERROR,
            STAGE_PARSER,
            err_span,
            err_msg
        );
        parser.dnit();
        ast_ptr.dnit();
        ret err[bool, string](err_msg);
    }

    if (cu.ast.is_some()) {
        var old_ast_ptr: *AST = ?cu.ast.value;
        old_ast_ptr.dnit();
        cu.ast = none[AST]();
    }

    cu.ast = some[AST](ast);
    cu.mark_stage(STAGE_PARSER);

    parser.dnit();

    if (cu.has_errors) {
        ret ok[bool, string](false);
    }

    ret ok[bool, string](true);
}
