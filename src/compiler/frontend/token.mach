# mach.compiler.frontend.token: token types for the lexer
# ---
# defines the token kinds and token structure used during lexical analysis

use std.types.bool;
use std.types.size;
use std.types.string;

# identifiers and literals
pub val TAG_IDENT:       u8 = 0;
pub val TAG_LIT_INT:     u8 = 1;
pub val TAG_LIT_FLOAT:   u8 = 2;
pub val TAG_LIT_CHAR:    u8 = 3;
pub val TAG_LIT_STRING:  u8 = 4;

# delimiters
pub val TAG_LPAREN:      u8 = 5;
pub val TAG_RPAREN:      u8 = 6;
pub val TAG_LBRACE:      u8 = 7;
pub val TAG_RBRACE:      u8 = 8;
pub val TAG_LBRACKET:    u8 = 9;
pub val TAG_RBRACKET:    u8 = 10;

# punctuation
pub val TAG_SEMI:        u8 = 11;
pub val TAG_COLON:       u8 = 12;
pub val TAG_COMMA:       u8 = 13;
pub val TAG_DOT:         u8 = 14;
pub val TAG_QUESTION:    u8 = 15;
pub val TAG_AT:          u8 = 16;
pub val TAG_DOLLAR:      u8 = 17;
pub val TAG_HASH:        u8 = 18;
pub val TAG_AMP:         u8 = 19;
pub val TAG_STAR:        u8 = 20;

# operators
pub val TAG_PLUS:        u8 = 21;
pub val TAG_MINUS:       u8 = 22;
pub val TAG_SLASH:       u8 = 23;
pub val TAG_PERCENT:     u8 = 24;
pub val TAG_EQ:          u8 = 25;
pub val TAG_EQ_EQ:       u8 = 26;
pub val TAG_BANG:        u8 = 27;
pub val TAG_BANG_EQ:     u8 = 28;
pub val TAG_LT:          u8 = 29;
pub val TAG_LT_EQ:       u8 = 30;
pub val TAG_LT_LT:       u8 = 31;
pub val TAG_GT:          u8 = 32;
pub val TAG_GT_EQ:       u8 = 33;
pub val TAG_GT_GT:       u8 = 34;
pub val TAG_AMP_AMP:     u8 = 35;
pub val TAG_PIPE:        u8 = 36;
pub val TAG_PIPE_PIPE:   u8 = 37;
pub val TAG_CARET:       u8 = 38;
pub val TAG_TILDE:       u8 = 39;
pub val TAG_COLON_COLON: u8 = 40;

# special
pub val TAG_EOF:         u8 = 254;
pub val TAG_ERROR:       u8 = 255;

# precedence levels for Pratt parsing
# ---
# higher values bind tighter
pub val PREC_NONE:       u8 = 0;   # not an operator / lowest
pub val PREC_ASSIGN:     u8 = 1;   # = (assignment, right-associative)
pub val PREC_OR:         u8 = 2;   # || (logical or)
pub val PREC_AND:        u8 = 3;   # && (logical and)
pub val PREC_BITOR:      u8 = 4;   # | (bitwise or)
pub val PREC_BITXOR:     u8 = 5;   # ^ (bitwise xor)
pub val PREC_BITAND:     u8 = 6;   # & (bitwise and)
pub val PREC_EQUALITY:   u8 = 7;   # == != (equality)
pub val PREC_COMPARISON: u8 = 8;   # < > <= >= (comparison)
pub val PREC_SHIFT:      u8 = 9;   # << >> (bit shift)
pub val PREC_TERM:       u8 = 10;  # + - (addition, subtraction)
pub val PREC_FACTOR:     u8 = 11;  # * / % (multiplication, division, modulo)
pub val PREC_UNARY:      u8 = 12;  # ! - ~ ? @ (unary prefix)
pub val PREC_CALL:       u8 = 13;  # () [] . :: (postfix)
pub val PREC_PRIMARY:    u8 = 14;  # highest / literals, identifiers

# a single token from the source
# ---
# pos: byte offset in source where token starts
# len: length of token in bytes
# tag: token kind tag
pub rec Token {
    pos: i32;
    len: i32;
    tag: u8;
}

# create an identifier token
# ---
# pos: byte offset in source
# len: length in bytes
# ret: new Token with TAG_IDENT
pub fun create_ident(pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: TAG_IDENT };
}

# create an integer literal token
# ---
# pos: byte offset in source
# len: length in bytes
# ret: new Token with TAG_LIT_INT
pub fun create_int(pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: TAG_LIT_INT };
}

# create a float literal token
# ---
# pos: byte offset in source
# len: length in bytes
# ret: new Token with TAG_LIT_FLOAT
pub fun create_float(pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: TAG_LIT_FLOAT };
}

# create a char literal token
# ---
# pos: byte offset in source
# len: length in bytes
# ret: new Token with TAG_LIT_CHAR
pub fun create_char(pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: TAG_LIT_CHAR };
}

# create a string literal token
# ---
# pos: byte offset in source
# len: length in bytes
# ret: new Token with TAG_LIT_STRING
pub fun create_string(pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: TAG_LIT_STRING };
}

# create an error token
# ---
# pos: byte offset in source
# len: length in bytes
# ret: new Token with TAG_ERROR
pub fun create_error(pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: TAG_ERROR };
}

# create an end-of-file token
# ---
# pos: byte offset in source
# ret: new Token with TAG_EOF and zero length
pub fun create_eof(pos: i32) Token {
    ret Token { pos: pos, len: 0, tag: TAG_EOF };
}

# check if a token is a literal
# ---
# tok: token to check
# ret: true if the tag represents a literal value
pub fun token_is_literal(tok: *Token) bool {
    if (tok == nil) {
        ret false;
    }
    ret tok.tag >= TAG_LIT_INT && tok.tag <= TAG_LIT_STRING;
}

# check if a token is an operator
# ---
# tok: token to check
# ret: true if the tag represents an operator
pub fun token_is_operator(tok: *Token) bool {
    if (tok == nil) {
        ret false;
    }
    ret tok.tag >= TAG_QUESTION && tok.tag <= TAG_COLON_COLON;
}

# check if a token is end-of-file
# ---
# tok: token to check
# ret: true if the token is EOF, or if tok is nil
pub fun token_is_eof(tok: *Token) bool {
    if (tok == nil) {
        ret true;
    }
    ret tok.tag == TAG_EOF;
}

# check if a token is an error token
# ---
# tok: token to check
# ret: true if the token is an error token
pub fun token_is_error(tok: *Token) bool {
    if (tok == nil) {
        ret false;
    }
    ret tok.tag == TAG_ERROR;
}

# check if a token has a specific tag
# ---
# tok: token to check
# tag: tag to compare against
# ret: true if the token has the given tag
pub fun token_has_tag(tok: *Token, tag: u8) bool {
    if (tok == nil) {
        ret false;
    }
    ret tok.tag == tag;
}

# convert a token tag to a human-readable string
# ---
# tag: token tag to convert
# ret: string representation of the kind
pub fun tag_to_str(tag: u8) str {
    # literals
    if (tag == TAG_IDENT)      { ret "identifier"; }
    if (tag == TAG_LIT_INT)    { ret "integer"; }
    if (tag == TAG_LIT_FLOAT)  { ret "float"; }
    if (tag == TAG_LIT_CHAR)   { ret "char"; }
    if (tag == TAG_LIT_STRING) { ret "string"; }

    # punctuation
    if (tag == TAG_LPAREN)   { ret "("; }
    if (tag == TAG_RPAREN)   { ret ")"; }
    if (tag == TAG_LBRACE)   { ret "{"; }
    if (tag == TAG_RBRACE)   { ret "}"; }
    if (tag == TAG_LBRACKET) { ret "["; }
    if (tag == TAG_RBRACKET) { ret "]"; }
    if (tag == TAG_SEMI)     { ret ";"; }
    if (tag == TAG_COLON)    { ret ":"; }
    if (tag == TAG_COMMA)    { ret ","; }
    if (tag == TAG_DOT)      { ret "."; }
    if (tag == TAG_QUESTION) { ret "?"; }
    if (tag == TAG_AT)       { ret "@"; }
    if (tag == TAG_DOLLAR)   { ret "$"; }
    if (tag == TAG_HASH)     { ret "#"; }
    if (tag == TAG_AMP)      { ret "&"; }
    if (tag == TAG_STAR)     { ret "*"; }

    # operators
    if (tag == TAG_PLUS)        { ret "+"; }
    if (tag == TAG_MINUS)       { ret "-"; }
    if (tag == TAG_SLASH)       { ret "/"; }
    if (tag == TAG_PERCENT)     { ret "%"; }
    if (tag == TAG_EQ)          { ret "="; }
    if (tag == TAG_EQ_EQ)       { ret "=="; }
    if (tag == TAG_BANG)        { ret "!"; }
    if (tag == TAG_BANG_EQ)     { ret "!="; }
    if (tag == TAG_LT)          { ret "<"; }
    if (tag == TAG_LT_EQ)       { ret "<="; }
    if (tag == TAG_LT_LT)       { ret "<<"; }
    if (tag == TAG_GT)          { ret ">"; }
    if (tag == TAG_GT_EQ)       { ret ">="; }
    if (tag == TAG_GT_GT)       { ret ">>"; }
    if (tag == TAG_AMP_AMP)     { ret "&&"; }
    if (tag == TAG_PIPE)        { ret "|"; }
    if (tag == TAG_PIPE_PIPE)   { ret "||"; }
    if (tag == TAG_CARET)       { ret "^"; }
    if (tag == TAG_TILDE)       { ret "~"; }
    if (tag == TAG_COLON_COLON) { ret "::"; }

    # special
    if (tag == TAG_EOF)   { ret "eof"; }
    if (tag == TAG_ERROR) { ret "error"; }

    ret "<unknown>";
}

# get precedence for infix/binary operators
# ---
# tag: token tag to check
# ret: precedence level (PREC_NONE if not an infix operator)
pub fun get_infix_precedence(tag: u8) u8 {
    # assignment: =
    if (tag == TAG_EQ) { ret PREC_ASSIGN; }

    # logical or: ||
    if (tag == TAG_PIPE_PIPE) { ret PREC_OR; }

    # logical and: &&
    if (tag == TAG_AMP_AMP) { ret PREC_AND; }

    # bitwise or: |
    if (tag == TAG_PIPE) { ret PREC_BITOR; }

    # bitwise xor: ^
    if (tag == TAG_CARET) { ret PREC_BITXOR; }

    # bitwise and: &
    if (tag == TAG_AMP) { ret PREC_BITAND; }

    # equality: == !=
    if (tag == TAG_EQ_EQ || tag == TAG_BANG_EQ) { ret PREC_EQUALITY; }

    # comparison: < <= > >=
    if (tag == TAG_LT || tag == TAG_LT_EQ || tag == TAG_GT || tag == TAG_GT_EQ) {
        ret PREC_COMPARISON;
    }

    # shift: << >>
    if (tag == TAG_LT_LT || tag == TAG_GT_GT) { ret PREC_SHIFT; }

    # term: + -
    if (tag == TAG_PLUS || tag == TAG_MINUS) { ret PREC_TERM; }

    # factor: * / %
    if (tag == TAG_STAR || tag == TAG_SLASH || tag == TAG_PERCENT) { ret PREC_FACTOR; }

    # call/postfix: ( [ . ::
    if (tag == TAG_LPAREN || tag == TAG_LBRACKET || tag == TAG_DOT || tag == TAG_COLON_COLON) {
        ret PREC_CALL;
    }

    ret PREC_NONE;
}

# check if an operator is right-associative
# ---
# tag: token tag to check
# ret: true if right-associative (currently only assignment)
pub fun is_right_associative(tag: u8) bool {
    # assignment (=) is right-associative
    ret tag == TAG_EQ;
}

# create a punctuation/operator token
# ---
# tag: punctuation tag
# pos: position in source
# len: length in bytes
# ret: new Token
pub fun create_punct(tag: u8, pos: i32, len: i32) Token {
    ret Token { pos: pos, len: len, tag: tag };
}
