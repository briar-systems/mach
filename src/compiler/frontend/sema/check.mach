# validation (phase 4).
#
# read-only pass that checks resolved types and expressions for
# correctness: return type consistency, condition types, etc.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.frontend.ast;
use symbol: mach.compiler.frontend.symbol;
use type:     mach.compiler.frontend.type;
use sema_err: mach.compiler.frontend.sema.error;

use mach.compiler.frontend.sema;

# run phase 4 on all modules in dependency order
pub fun check_all_modules(sema: *Sema) {
    if (sema == nil) { ret; }

    var mod: *SemaModule = sema.modules;
    for (mod != nil) {
        if (mod.phase < PHASE_CHECKED) {
            check_module(sema, mod);
        }
        mod = mod.next;
    }
}

# run phase 4 on a single module
pub fun check_module(sema: *Sema, mod: *SemaModule) {
    if (sema == nil || mod == nil || mod.ast == nil) { ret; }

    val stmts: *ast.List = mod.ast.info.block_stmt.stmts;
    if (stmts == nil) { ret; }

    var i: i32 = 0;
    for (i < stmts.count) {
        val node: *ast.Node = stmts.nodes[i];
        if (node != nil) {
            check_top_level(sema, mod, node);
        }
        i = i + 1;
    }

    mod.phase = PHASE_CHECKED;
    mod.is_analyzed = true;
}

fun check_top_level(sema: *Sema, mod: *SemaModule, node: *ast.Node) {
    if (node == nil) { ret; }

    if (node.kind == ast.NODE_DECL_FUN) {
        check_function(sema, mod, node);
        ret;
    }

    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { check_top_level(sema, mod, inner); }
        ret;
    }

    if (node.kind == ast.NODE_COMPTIME_IF || node.kind == ast.NODE_COMPTIME_OR) {
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            if (body.kind == ast.NODE_STMT_BLOCK || body.kind == ast.NODE_STMT_LIST) {
                val stmts: *ast.List = body.info.block_stmt.stmts;
                if (stmts != nil) {
                    var i: i32 = 0;
                    for (i < stmts.count) {
                        if (stmts.nodes[i] != nil) { check_top_level(sema, mod, stmts.nodes[i]); }
                        i = i + 1;
                    }
                }
            } or {
                check_top_level(sema, mod, body);
            }
        }
    }
}

# check a function declaration
fun check_function(sema: *Sema, mod: *SemaModule, node: *ast.Node) {
    if (node == nil) { ret; }

    val sym: *symbol.Symbol = node.symbol::*symbol.Symbol;
    if (sym == nil || sym.is_generic) { ret; }

    val decl: *ast.FunDecl = ?node.info.fun_decl;
    val body: *ast.Node = decl.body;
    if (body == nil) { ret; }

    var ret_type: *type.Type = type.get_primitive(sema.types, type.TYPE_VOID);
    if (sym.resolved_type != nil && sym.resolved_type.ret_type != nil) {
        ret_type = sym.resolved_type.ret_type;
    }

    var fn_ctx: FnContext;
    fn_ctx.func_node = node;
    fn_ctx.ret_type = ret_type;

    check_stmt(sema, mod, body, ?fn_ctx);
}

# check a statement
fun check_stmt(sema: *Sema, mod: *SemaModule, node: *ast.Node, fn_ctx: *FnContext) {
    if (node == nil) { ret; }

    if (node.kind == ast.NODE_STMT_BLOCK) {
        val stmts: *ast.List = node.info.block_stmt.stmts;
        if (stmts != nil) {
            var i: i32 = 0;
            for (i < stmts.count) {
                if (stmts.nodes[i] != nil) {
                    check_stmt(sema, mod, stmts.nodes[i], fn_ctx);
                }
                i = i + 1;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_IF) {
        check_if_condition(sema, mod, node);
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) { check_stmt(sema, mod, body, fn_ctx); }
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) { check_stmt(sema, mod, or_branch, fn_ctx); }
        ret;
    }

    if (node.kind == ast.NODE_STMT_OR || node.kind == ast.NODE_OR_BRANCH) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) {
            check_condition_type(sema, mod, cond);
        }
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) { check_stmt(sema, mod, body, fn_ctx); }
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) { check_stmt(sema, mod, or_branch, fn_ctx); }
        ret;
    }

    if (node.kind == ast.NODE_STMT_FOR) {
        val cond: *ast.Node = node.info.for_stmt.cond;
        if (cond != nil) {
            check_condition_type(sema, mod, cond);
        }
        val body: *ast.Node = node.info.for_stmt.body;
        if (body != nil) { check_stmt(sema, mod, body, fn_ctx); }
        ret;
    }

    if (node.kind == ast.NODE_STMT_RET) {
        check_return_type(sema, mod, node, fn_ctx);
        ret;
    }

    if (node.kind == ast.NODE_STMT_FIN) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { check_stmt(sema, mod, inner, fn_ctx); }
        ret;
    }

    if (node.kind == ast.NODE_DECL_VAL || node.kind == ast.NODE_DECL_VAR) {
        check_var_init(sema, mod, node);
        ret;
    }
}

# check that an if condition is a valid boolean-like type
fun check_if_condition(sema: *Sema, mod: *SemaModule, node: *ast.Node) {
    if (node == nil) { ret; }
    val cond: *ast.Node = node.info.cond_stmt.cond;
    check_condition_type(sema, mod, cond);
}

# validate a condition expression's type
fun check_condition_type(sema: *Sema, mod: *SemaModule, cond: *ast.Node) {
    if (cond == nil) { ret; }
    val t: *type.Type = cond.type;
    if (t == nil) { ret; }

    # conditions must be integer, pointer, or bool (which is u8)
    if (type.type_is_integer(t)) { ret; }
    if (type.type_is_pointer(t)) { ret; }

    report_error_node(sema, mod, cond, "condition must be a boolean or comparable type");
}

# check a return statement's value type against the function's return type
fun check_return_type(sema: *Sema, mod: *SemaModule, node: *ast.Node, fn_ctx: *FnContext) {
    if (node == nil || fn_ctx == nil) { ret; }

    val inner: *ast.Node = node.info.wrapper.inner;
    val expected: *type.Type = fn_ctx.ret_type;
    if (expected == nil) { ret; }

    if (inner == nil) {
        # bare return — only valid if function returns void
        if (!type.type_is_void(expected)) {
            report_error_node(sema, mod, node, "missing return value");
        }
        ret;
    }

    val actual: *type.Type = inner.type;
    if (actual == nil) { ret; }

    if (!type.can_assign(actual, expected)) {
        # allow nil assignment to pointer return types
        if (type.type_is_nil(actual) && type.type_is_pointer(expected)) { ret; }
        report_error_node(sema, mod, node,
            sema_err.concat_msg(sema.alloc,
                sema_err.concat_msg(sema.alloc, "return type mismatch: expected '", sema_err.type_display_name(expected), "', got '"),
                sema_err.type_display_name(actual), "'"));
    }
}

# check a variable initialization for type compatibility
fun check_var_init(sema: *Sema, mod: *SemaModule, node: *ast.Node) {
    if (node == nil) { ret; }

    val sym: *symbol.Symbol = node.symbol::*symbol.Symbol;
    if (sym == nil || sym.resolved_type == nil) { ret; }

    val init: *ast.Node = node.info.var_decl.init;
    if (init == nil) { ret; }

    val init_type: *type.Type = init.type;
    if (init_type == nil) { ret; }

    if (!type.can_assign(init_type, sym.resolved_type)) {
        if (type.type_is_nil(init_type) && type.type_is_pointer(sym.resolved_type)) { ret; }
        report_error_node(sema, mod, node,
            sema_err.concat_msg(sema.alloc,
                sema_err.concat_msg(sema.alloc, "initializer type mismatch: expected '",
                    sema_err.type_display_name(sym.resolved_type), "', got '"),
                sema_err.type_display_name(init_type), "'"));
    }
}

