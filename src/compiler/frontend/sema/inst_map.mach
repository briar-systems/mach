# sema instantiation dedup hash table.
#
# open-addressing FNV-1a hash table for O(1) generic instantiation dedup.
# keyed by mangled type name, stores persistent name pointers.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# a single entry in the instantiation dedup hash table.
# ---
# key:   mangled name string (nil if slot is empty)
# value: persistent mangled name pointer
pub rec Entry {
    key:   str;
    value: str;
}

val INIT_CAP: i32 = 64;

# open-addressing hash table for O(1) instantiation dedup.
# ---
# entries:  flat array of buckets
# count:    number of occupied slots
# capacity: current bucket count (power of two)
pub rec Map {
    entries:  *Entry;
    count:    i32;
    capacity: i32;
}

# look up a mangled name in the hash table.
# ---
# m:   hash table
# key: mangled name to find
# ret: persistent name if found, nil otherwise
pub fun get(m: *Map, key: str) str {
    if (m == nil || m.entries == nil || key == nil) { ret nil; }
    var idx: i32 = hash(key, m.capacity);
    var probes: i32 = 0;
    for (probes < m.capacity) {
        val e: *Entry = ?m.entries[idx];
        if (e.key == nil) { ret nil; }
        if (str_equals(e.key, key)) { ret e.value; }
        idx = (idx + 1) & (m.capacity - 1);
        probes = probes + 1;
    }
    ret nil;
}

# insert a mangled name into the hash table.
# ---
# m:        hash table
# alloc:    allocator
# key:      mangled name
# val_name: persistent name
pub fun put(m: *Map, alloc: *allocator.Allocator, key: str, val_name: str) {
    if (m == nil || alloc == nil || key == nil) { ret; }
    if (m.entries == nil) {
        val cap: i32 = INIT_CAP;
        val res: Result[*Entry, allocator.AllocError] =
            allocator.allocator_zalloc[Entry](alloc, cap::usize);
        if (result_is_err[*Entry, allocator.AllocError](res)) { ret; }
        m.entries = result_unwrap_ok[*Entry, allocator.AllocError](res);
        m.capacity = cap;
    }
    if (m.count * 4 >= m.capacity * 3) {
        if (!grow(m, alloc)) { ret; }
    }
    put_inner(m, key, val_name);
}

fun hash(s: str, cap: i32) i32 {
    if (s == nil) { ret 0; }
    var h: u64 = 14695981039346656037;
    val len: usize = str_len(s);
    var i: usize = 0;
    for (i < len) {
        h = h ^ s[i]::u64;
        h = h * 1099511628211;
        i = i + 1;
    }
    ret (h & (cap - 1)::u64)::i32;
}

fun grow(m: *Map, alloc: *allocator.Allocator) bool {
    val old_entries: *Entry = m.entries;
    val old_cap: i32 = m.capacity;
    val new_cap: i32 = old_cap * 2;

    val res: Result[*Entry, allocator.AllocError] =
        allocator.allocator_zalloc[Entry](alloc, new_cap::usize);
    if (result_is_err[*Entry, allocator.AllocError](res)) { ret false; }

    m.entries = result_unwrap_ok[*Entry, allocator.AllocError](res);
    m.capacity = new_cap;
    m.count = 0;

    var i: i32 = 0;
    for (i < old_cap) {
        val e: *Entry = ?old_entries[i];
        if (e.key != nil) {
            put_inner(m, e.key, e.value);
        }
        i = i + 1;
    }
    allocator.allocator_free[Entry](alloc, old_entries, old_cap::usize);
    ret true;
}

fun put_inner(m: *Map, key: str, val_name: str) {
    var idx: i32 = hash(key, m.capacity);
    var probes: i32 = 0;
    for (probes < m.capacity) {
        val e: *Entry = ?m.entries[idx];
        if (e.key == nil) {
            e.key = key;
            e.value = val_name;
            m.count = m.count + 1;
            ret;
        }
        if (str_equals(e.key, key)) { ret; }
        idx = (idx + 1) & (m.capacity - 1);
        probes = probes + 1;
    }
}
