# sema shared error utilities.
#
# provides position conversion, string concatenation, and error line
# rendering used across all sema phases.

use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use print:     std.print;
use type:      mach.compiler.frontend.type;

# convert a byte position to a 1-based line number.
# ---
# source: full source text
# pos:    byte position (0-based)
# ret:    1-based line number
pub fun pos_to_line(source: str, pos: i32) i32 {
    if (source == nil || pos < 0) { ret 1; }
    var line: i32 = 1;
    var i: i32 = 0;
    val len: i32 = str_len(source)::i32;
    for (i < pos && i < len) {
        if (source[i] == '\n') { line = line + 1; }
        i = i + 1;
    }
    ret line;
}

# convert a byte position to a 1-based column number.
# ---
# source: full source text
# pos:    byte position (0-based)
# ret:    1-based column number
pub fun pos_to_col(source: str, pos: i32) i32 {
    if (source == nil || pos < 0) { ret 1; }
    var col: i32 = 1;
    var i: i32 = 0;
    val len: i32 = str_len(source)::i32;
    for (i < pos && i < len) {
        if (source[i] == '\n') {
            col = 1;
        } or {
            col = col + 1;
        }
        i = i + 1;
    }
    ret col;
}

# concatenate up to three strings into a newly allocated string.
# ---
# alloc: allocator for the result buffer
# a:     first string (required)
# b:     second string (optional, nil to skip)
# c:     third string (optional, nil to skip)
# ret:   concatenated string, or a on allocation failure
pub fun concat_msg(alloc: *allocator.Allocator, a: str, b: str, c: str) str {
    if (a == nil) { ret nil; }
    val a_len: usize = str_len(a);
    var b_len: usize = 0;
    var c_len: usize = 0;
    if (b != nil) { b_len = str_len(b); }
    if (c != nil) { c_len = str_len(c); }

    val total: usize = a_len + b_len + c_len + 1;
    val r: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](alloc, total);
    if (!r.tag) { ret a; }

    val buf: *u8 = r.value.ok;
    var pos: usize = 0;
    var i: usize = 0;
    for (i < a_len) { buf[pos] = a[i]; pos = pos + 1; i = i + 1; }
    i = 0;
    for (i < b_len) { buf[pos] = b[i]; pos = pos + 1; i = i + 1; }
    i = 0;
    for (i < c_len) { buf[pos] = c[i]; pos = pos + 1; i = i + 1; }
    buf[pos] = 0;
    ret buf::str;
}

# print a source line with a caret at the error column.
pub fun print_error_line(source: str, line: i32, col: i32) {
    if (source == nil || line < 1) { ret; }

    var current_line: i32 = 1;
    var line_start: i32 = 0;
    var i: i32 = 0;
    val len: i32 = str_len(source)::i32;

    for (i < len && current_line < line) {
        if (source[i] == '\n') {
            current_line = current_line + 1;
            line_start = i + 1;
        }
        i = i + 1;
    }

    if (current_line != line) { ret; }

    var line_end: i32 = line_start;
    for (line_end < len && source[line_end] != '\n') {
        line_end = line_end + 1;
    }

    print.eprintf("  %d | ", line::i64);
    i = line_start;
    for (i < line_end) {
        var ch: [2]u8;
        ch[0] = source[i];
        ch[1] = 0;
        print.eprint((?ch[0])::str);
        i = i + 1;
    }
    print.eprintln("");

    var digits: i32 = 1;
    var tmp: i32 = line;
    for (tmp >= 10) {
        digits = digits + 1;
        tmp = tmp / 10;
    }
    var pad: i32 = 0;
    for (pad < digits + 2) {
        print.eprint(" ");
        pad = pad + 1;
    }
    print.eprint(" | ");
    var c: i32 = 1;
    for (c < col) {
        print.eprint(" ");
        c = c + 1;
    }
    print.eprintln("^");
}

# get a display name for a type (kind name or type name if available).
# ---
# t:   type to display
# ret: display name string
pub fun type_display_name(t: *type.Type) str {
    if (t == nil) { ret "<unknown>"; }
    if (t.name != nil) { ret t.name; }
    ret type.kind_name(t.kind);
}
