# declaration collection
#
# registers all top-level symbols in each module's symbol table.
# handles pub wrappers and comptime conditionals for non-use declarations.
# use declarations are already processed by the loader (phase 0).

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.frontend.ast;
use symbol: mach.compiler.frontend.symbol;

use mach.compiler.frontend.sema;

# run phase 1 on all modules in dependency order
pub fun collect_all_modules(sema: *Sema) {
    if (sema == nil) { ret; }

    var mod: *SemaModule = sema.modules;
    for (mod != nil) {
        if (mod.phase < PHASE_COLLECTED) {
            collect_module(sema, mod);
        }
        mod = mod.next;
    }
}

# run phase 1 on a single module
pub fun collect_module(sema: *Sema, mod: *SemaModule) {
    if (sema == nil || mod == nil || mod.ast == nil || mod.table == nil) { ret; }

    collect_top_level(sema, mod, mod.ast);
    mod.phase = PHASE_COLLECTED;
}

# walk top-level declarations in a module
fun collect_top_level(sema: *Sema, mod: *SemaModule, program: *ast.Node) {
    if (program == nil) { ret; }

    val stmts: *ast.List = program.info.block_stmt.stmts;
    if (stmts == nil) { ret; }

    var i: i32 = 0;
    for (i < stmts.count) {
        val node: *ast.Node = stmts.nodes[i];
        if (node != nil) {
            collect_decl(sema, mod, node, false);
        }
        i = i + 1;
    }
}

# collect a single declaration, optionally marking it public
fun collect_decl(sema: *Sema, mod: *SemaModule, node: *ast.Node, is_pub: bool) {
    if (node == nil) { ret; }

    if (node.kind == ast.NODE_DECL_FUN) {
        define_symbol(sema, mod, node, node.info.fun_decl.name, symbol.SYM_FUN, is_pub);
        # tag generics
        val sym: *symbol.Symbol = node.symbol::*symbol.Symbol;
        if (sym != nil && node.info.fun_decl.generics != nil) {
            sym.is_generic = true;
            sym.generic_node = node.info.fun_decl.generics;
        }
        ret;
    }

    if (node.kind == ast.NODE_DECL_VAL) {
        define_symbol(sema, mod, node, node.info.var_decl.name, symbol.SYM_VAL, is_pub);
        ret;
    }

    if (node.kind == ast.NODE_DECL_VAR) {
        define_symbol(sema, mod, node, node.info.var_decl.name, symbol.SYM_VAR, is_pub);
        ret;
    }

    if (node.kind == ast.NODE_DECL_DEF) {
        define_symbol(sema, mod, node, node.info.def_decl.name, symbol.SYM_TYPE, is_pub);
        ret;
    }

    if (node.kind == ast.NODE_DECL_EXT) {
        define_symbol(sema, mod, node, node.info.ext_decl.name, symbol.SYM_EXT, is_pub);
        ret;
    }

    if (node.kind == ast.NODE_DECL_REC) {
        define_symbol(sema, mod, node, node.info.type_decl.name, symbol.SYM_REC, is_pub);
        val sym: *symbol.Symbol = node.symbol::*symbol.Symbol;
        if (sym != nil && node.info.type_decl.generics != nil) {
            sym.is_generic = true;
            sym.generic_node = node.info.type_decl.generics;
        }
        ret;
    }

    if (node.kind == ast.NODE_DECL_UNI) {
        define_symbol(sema, mod, node, node.info.type_decl.name, symbol.SYM_UNI, is_pub);
        val sym: *symbol.Symbol = node.symbol::*symbol.Symbol;
        if (sym != nil && node.info.type_decl.generics != nil) {
            sym.is_generic = true;
            sym.generic_node = node.info.type_decl.generics;
        }
        ret;
    }

    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            collect_decl(sema, mod, inner, true);
        }
        ret;
    }

    if (node.kind == ast.NODE_COMPTIME_IF || node.kind == ast.NODE_COMPTIME_OR) {
        collect_comptime_if(sema, mod, node);
        ret;
    }

    # use declarations are already handled by the loader — skip
}

# process a $if/$or conditional at declaration level
fun collect_comptime_if(sema: *Sema, mod: *SemaModule, node: *ast.Node) {
    if (node == nil) { ret; }
    if (node.kind != ast.NODE_COMPTIME_IF && node.kind != ast.NODE_COMPTIME_OR) { ret; }

    val eval_res: Result[bool, str] = eval_comptime_cond(sema, node);
    if (!eval_res.tag) { ret; }

    if (eval_res.value.ok) {
        # taken — collect body, trim else
        val body: *ast.Node = node.info.cond_stmt.body;
        node.info.cond_stmt.or_branch = nil;
        if (body != nil) {
            collect_comptime_body(sema, mod, body);
        }
    } or {
        # not taken — null body, try else
        node.info.cond_stmt.body = nil;
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) {
            collect_comptime_if(sema, mod, or_branch);
            node.info.cond_stmt.body = or_branch.info.cond_stmt.body;
            node.info.cond_stmt.or_branch = nil;
        }
    }
}

# collect declarations inside a comptime body
fun collect_comptime_body(sema: *Sema, mod: *SemaModule, body: *ast.Node) {
    if (body == nil) { ret; }

    if (body.kind == ast.NODE_STMT_BLOCK || body.kind == ast.NODE_STMT_LIST) {
        val stmts: *ast.List = body.info.block_stmt.stmts;
        if (stmts == nil) { ret; }
        var i: i32 = 0;
        for (i < stmts.count) {
            val node: *ast.Node = stmts.nodes[i];
            if (node != nil) {
                collect_decl(sema, mod, node, false);
            }
            i = i + 1;
        }
        ret;
    }

    collect_decl(sema, mod, body, false);
}

# register a symbol in a module's symbol table
fun define_symbol(sema: *Sema, mod: *SemaModule, node: *ast.Node, name: str, kind: symbol.SymbolKind, is_pub: bool) {
    if (sema == nil || mod == nil || mod.table == nil || node == nil) { ret; }

    if (name == nil) {
        report_error_node(sema, mod, node, "declaration has no name");
        ret;
    }

    # check for duplicate in current scope
    val existing: Option[*symbol.Symbol] = symbol.scope_lookup_local(
        symbol.table_current_scope(mod.table), name);
    if (existing.has_value) {
        report_error_node(sema, mod, node, "duplicate declaration");
        ret;
    }

    val sym_res: Result[*symbol.Symbol, str] = symbol.table_define(mod.table, name, kind);
    if (!sym_res.tag) {
        report_error_node(sema, mod, node, "failed to define symbol");
        ret;
    }

    val sym: *symbol.Symbol = sym_res.value.ok;
    sym.decl_node = node;
    sym.is_public = is_pub;
    sym.module_path = mod.path;
    node.symbol = sym::ptr;
}
