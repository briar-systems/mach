use std.types.bool;
use std.types.size;
use std.types.string;

use isa: mach.compiler.isa;

# mach.compiler.abi: calling convention interface.
# ---
# abstracts all calling convention decisions behind function pointers.
# lowering and call codegen use this interface exclusively — they never
# hardcode register assignments or stack layout.
#
# the Target composition root selects the ABI implementation and
# passes it to pipeline stages that need it.

# ParamClass: how a value is passed or returned.
pub def ParamClass: u8;

pub val CLASS_GP:    ParamClass = 0;   # in a GP register
pub val CLASS_FP:    ParamClass = 1;   # in an FP/SSE register
pub val CLASS_STACK: ParamClass = 2;   # on the stack
pub val CLASS_SRET:  ParamClass = 3;   # struct return via hidden pointer
pub val CLASS_BYREF: ParamClass = 4;   # passed by reference (caller copies)
pub val CLASS_GP2:   ParamClass = 5;   # in two consecutive GP registers

# ParamSlot: classification result for a parameter or return value.
pub rec ParamSlot {
    class:  ParamClass;
    reg:    isa.Register;   # first register (CLASS_GP, CLASS_FP, CLASS_GP2)
    reg2:   isa.Register;   # second register (CLASS_GP2 only)
    offset: i64;            # stack offset (CLASS_STACK)
    size:   usize;          # value size in bytes
}

# VariadicInfo: ABI-specific variadic call requirements.
pub rec VariadicInfo {
    needs_fp_count: bool;           # does this ABI need an FP arg count?
    fp_count_reg:   isa.Register;   # if yes, which register (e.g. AL for SysV64)
}

# VarargLayout: ABI-specific layout for variadic function handling.
# describes the register save area and va_list structure so that
# lowering can emit target-independent IR for va_start/va_arg.
pub rec VarargLayout {
    # register save area
    save_area_size:    usize;   # total bytes to allocate on stack
    save_area_align:   usize;   # alignment requirement

    # va_list field offsets (byte offset within va_list struct)
    gp_offset_off:     i64;     # byte offset of gp_offset field
    gp_offset_size:    u8;      # byte size of gp_offset field
    fp_offset_off:     i64;     # byte offset of fp_offset field
    fp_offset_size:    u8;      # byte size of fp_offset field
    overflow_area_off: i64;     # byte offset of overflow_arg_area pointer
    reg_save_area_off: i64;     # byte offset of reg_save_area pointer

    # register slot sizes within save area
    gp_slot_size:      i64;     # bytes per GP register slot
    fp_slot_size:      i64;     # bytes per FP register slot
    fp_area_base:      i64;     # fp_offset base value (gp_count * gp_slot_size)

    # stack argument area
    stack_args_base:   i64;     # frame pointer offset to first stack arg
    stack_slot_size:   i64;     # bytes per stack argument slot

    # va_arg thresholds
    gp_threshold:      i64;     # gp_offset >= this -> use stack path
    gp_increment:      i64;     # advance per GP va_arg

    # va_list type dimensions (ABI-specific)
    va_list_size:      usize;   # sizeof(va_list) in bytes
    va_list_align:     usize;   # alignof(va_list) in bytes
}

# ABI: calling convention interface.
pub rec ABI {
    ctx: ptr;

    # classify how parameter at `index` should be passed.
    # gp_used/fp_used track how many param regs are consumed so far.
    classify_param: fun(ptr, i32, usize, usize,
                        bool, bool,
                        i32, i32) ParamSlot;

    # classify how the return value should be handled.
    classify_return: fun(ptr, usize, usize,
                         bool, bool) ParamSlot;

    # ordered GP registers for parameter passing.
    gp_param_regs: fun(ptr) isa.RegisterFile;

    # ordered FP registers for parameter passing.
    fp_param_regs: fun(ptr) isa.RegisterFile;

    # callee-saved registers that must be preserved across calls.
    callee_saved: fun(ptr) isa.RegisterFile;

    # required stack alignment in bytes.
    stack_align: fun(ptr) usize;

    # red zone size in bytes (0 if none).
    red_zone: fun(ptr) usize;

    # variadic call requirements.
    variadic_info: fun(ptr) VariadicInfo;

    # variadic function layout for callee-side va_list handling.
    vararg_layout: fun(ptr) VarargLayout;

    # size of the callee's frame header in bytes.
    # on x86-64 SysV this is 16 (saved RBP + return address).
    # stack-passed parameters start at FP + this offset.
    frame_header_size: fun(ptr) i64;

    # reset internal stack offset counter.
    # must be called before each classify_param sequence (params or call args).
    reset_stack: fun(ptr);
}
