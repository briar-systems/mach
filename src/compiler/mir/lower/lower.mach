# mach.compiler.mir.lower.lower: AST → MIR lowering driver
#
# transforms typed AST (sema output) into MIR. dispatches to expr, stmt,
# and data sub-modules. context and utilities live in ctx.mach.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use allocator: std.allocator;
use diag:      mach.compiler.diag;

use sema_mod: mach.compiler.sema.sema;
use type:     mach.compiler.sema.type;
use scope:    mach.compiler.sema.scope;
use smod:     mach.compiler.sema.module;
use mono:     mach.compiler.sema.mono;

use ast:     mach.compiler.parse.ast;
use linemap: mach.compiler.lex.linemap;

use op:       mach.compiler.mir.op;
use ir:       mach.compiler.mir.ir;
use builder:  mach.compiler.mir.builder;
use lctx:     mach.compiler.mir.lower.ctx;
use stmt_mod: mach.compiler.mir.lower.stmt;
use expr_mod: mach.compiler.mir.lower.expr;
use data_mod: mach.compiler.mir.lower.data;

# lower all top-level declarations in a module into MIR
pub fun lower_module(ctx: *lctx.LowerCtx, mod_id: smod.ModuleId) {
    if (ctx == nil || ctx.sema == nil) { ret; }

    ctx.current_mod = mod_id;
    val m: *smod.Module = smod.get(ctx.sema.modules, mod_id);
    val store: *ast.NodeStore = ?m.store;
    val res_lm: Result[*linemap.LineMap, str] = allocator.allocate[linemap.LineMap](ctx.alloc, 1);
    if (is_ok[*linemap.LineMap, str](res_lm)) {
        val lm_ptr: *linemap.LineMap = unwrap_ok[*linemap.LineMap, str](res_lm);
        @lm_ptr = linemap.build(ctx.alloc, m.source);
        ctx.line_map = lm_ptr;
    }
    ctx.src_path = m.file_path;

    val file_res: Result[u16, str] = builder.module_add_file(ctx.mb, m.file_path);
    if (is_ok[u16, str](file_res)) {
        ctx.file_idx = unwrap_ok[u16, str](file_res);
    }

    val root: ast.NodeId = m.root;
    if (root::u32 == ast.NODE_NIL::u32) { ret; }

    val root_node: *ast.Node = ast.get(store, root);
    if (root_node.kind != ast.NK_PROGRAM && root_node.kind != ast.NK_STMT_BLOCK) { ret; }

    val stmts: ast.NodeSpan = ast.block_stmts(store, root);
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
        if (child_id::u32 != ast.NODE_NIL::u32) {
            lower_top_level(ctx, child_id, store);
        }
        i = i + 1;
    }

    if (ctx.sema.mono != nil) {
        val mc: *mono.MonoCache = ctx.sema.mono;
        val count: u32 = mono.fn_count(mc);
        var mi: u32 = 0;
        for (mi < count) {
            val fi: *mono.FnInst = mono.get_fn(mc, mi);
            if (fi != nil && fi.body_resolved && fi.origin_module::u32 == mod_id::u32) {
                lower_instantiation(ctx, fi, ?smod.get(ctx.sema.modules, fi.origin_module).store);
            }
            mi = mi + 1;
        }
    }
}

fun lower_top_level(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }
    val node: *ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_DECL_FUN) {
        lower_function(ctx, node_id, store);
    } or (node.kind == ast.NK_DECL_VAL || node.kind == ast.NK_DECL_VAR) {
        data_mod.lower_global_var(ctx, node_id, store);
    } or (node.kind == ast.NK_DECL_EXT) {
        lower_extern(ctx, node_id, store);
    } or (node.kind == ast.NK_DECL_PUB) {
        val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        if (inner_id::u32 != ast.NODE_NIL::u32) {
            lower_top_level(ctx, inner_id, store);
        }
    }
}

fun lower_extern(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val node: *ast.Node = ast.get(store, node_id);
    val name_sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
    var name: str = ast.get_str(store, name_sid);
    if (name == nil) { ret; }

    val fn_mod: *smod.Module = smod.get(ctx.sema.modules, ctx.current_mod);
    val opt_sym: Option[scope.SymbolId] = scope.lookup_from(ctx.sema.symbols, fn_mod.scope, name);
    if (is_some[scope.SymbolId](opt_sym)) {
        val sym_id: scope.SymbolId = unwrap[scope.SymbolId](opt_sym);
        val sym: *scope.Symbol = scope.get_sym(ctx.sema.symbols, sym_id);
        if (sym.export_name != nil) {
            name = sym.export_name;
        }
    }

    builder.module_add_symbol(ctx.mb, name, true);
}

fun lower_function(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    if (ctx == nil) { ret; }

    val name_sid: ast.StrId = ast.fun_name(store, node_id);
    var name: str = ast.get_str(store, name_sid);
    if (name == nil) { ret; }

    val generics: ast.NodeId = ast.fun_generics(store, node_id);
    if (generics::u32 != ast.NODE_NIL::u32) { ret; }

    val fn_mod: *smod.Module = smod.get(ctx.sema.modules, ctx.current_mod);
    val opt_fn_sym: Option[scope.SymbolId] = scope.lookup_from(ctx.sema.symbols, fn_mod.scope, name);
    if (is_some[scope.SymbolId](opt_fn_sym)) {
        val fn_sym: scope.SymbolId = unwrap[scope.SymbolId](opt_fn_sym);
        val sym: *scope.Symbol = scope.get_sym(ctx.sema.symbols, fn_sym);
        if (sym.export_name != nil) {
            name = sym.export_name;
        } or {
            name = lctx.mangle_symbol(ctx, fn_mod.path, name);
        }
    } or {
        name = lctx.mangle_symbol(ctx, fn_mod.path, name);
    }

    val ret_type_node: ast.NodeId = ast.fun_ret_type(store, node_id);
    var ret_tid: type.TypeId = type.primitive(ctx.sema.types, type.TK_VOID);
    var fn_tid: type.TypeId = type.TYPE_NIL;
    if (is_some[scope.SymbolId](opt_fn_sym)) {
        fn_tid = lctx.sym_type(ctx, unwrap[scope.SymbolId](opt_fn_sym));
    }
    if (fn_tid::u32 != type.TYPE_NIL::u32) {
        val ft: *type.Type = type.get(ctx.sema.types, fn_tid);
        if (ft.kind == type.TK_FUN) {
            ret_tid = ft.ret_type;
        }
    }

    ctx.fb = builder.func_init(ctx.alloc, name, ret_tid, ctx.src_path);
    ctx.local_count    = 0;
    ctx.ds.count       = 0;
    ctx.ds.mark        = 0;
    ctx.ls.brk_block   = ir.BLOCK_NONE;
    ctx.ls.cnt_block   = ir.BLOCK_NONE;
    ctx.rs.ret_type    = ret_tid;

    var fn_variadic: bool = false;
    if (fn_tid::u32 != type.TYPE_NIL::u32) {
        val ft2: *type.Type = type.get(ctx.sema.types, fn_tid);
        if (ft2.kind == type.TK_FUN && ft2.is_variadic) {
            fn_variadic = true;
            builder.func_set_variadic(?ctx.fb);
            ctx.fn_is_variadic = true;
        }
    }

    val entry_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "entry");
    if (is_err[ir.BlockId, str](entry_res)) {
        val eloc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        lctx.emit_error(ctx, eloc, "failed to create entry block");
        ret;
    }
    val entry_block: ir.BlockId = unwrap_ok[ir.BlockId, str](entry_res);
    builder.switch_to_block(?ctx.fb, entry_block);

    val ret_sz: u32 = lctx.type_size(ctx, ret_tid);
    val needs_sret: bool = lctx.is_aggregate(ctx, ret_tid) && ret_sz > ctx.max_reg_ret;
    var param_offset: u32 = 0;
    if (needs_sret) {
        val ptr_tid: type.TypeId = type.make_pointer(ctx.sema.types, ret_tid);
        val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        val sret_res: Result[ir.ValueId, str] = builder.build_param(?ctx.fb, ptr_tid, 0, loc);
        if (is_ok[ir.ValueId, str](sret_res)) {
            val sret_val: ir.ValueId = unwrap_ok[ir.ValueId, str](sret_res);
            val al_res: Result[ir.ValueId, str] = builder.build_alloca(?ctx.fb, ptr_tid, 8, 8, loc);
            if (is_ok[ir.ValueId, str](al_res)) {
                val al: ir.ValueId = unwrap_ok[ir.ValueId, str](al_res);
                builder.build_store(?ctx.fb, al, sret_val, loc);
                lctx.push_local_with_ptr(ctx, "$sret", ptr_tid, al);
            }
        }
        param_offset = 1;
    }

    val params: ast.NodeSpan = ast.fun_params(store, node_id);
    var pi: u32 = 0;
    for (pi < params.len) {
        val param_nid: ast.NodeId = ast.get_extra(store, params.start + pi)::ast.NodeId;
        if (param_nid::u32 != ast.NODE_NIL::u32) {
            val pn: *ast.Node = ast.get(store, param_nid);
            val pn_name_sid: ast.StrId = ast.get_extra(store, pn.payload)::ast.StrId;
            val pn_name: str = ast.get_str(store, pn_name_sid);
            if (pn_name != nil && str_equals(pn_name, "...")) {
                pi = pi + 1;
                cnt;
            }
            lower_param(ctx, param_nid, pi + param_offset, store);
        }
        pi = pi + 1;
    }

    val body: ast.NodeId = ast.fun_body(store, node_id);
    if (body::u32 != ast.NODE_NIL::u32) {
        stmt_mod.lower_stmt(ctx, body, store);
    }

    if (!builder.is_block_terminated(?ctx.fb)) {
        val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        builder.build_ret(?ctx.fb, ir.VALUE_NONE, loc);
    }

    builder.finalize_blocks(?ctx.fb);

    val func: ir.Function = builder.func_finish(?ctx.fb);
    val add_res: Result[u32, str] = builder.module_add_func(ctx.mb, func);
    if (is_err[u32, str](add_res)) {
        val eloc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        lctx.emit_error(ctx, eloc, "failed to add function to module");
    }
}

fun lower_param(ctx: *lctx.LowerCtx, param_nid: ast.NodeId, idx: u32, store: *ast.NodeStore) {
    val pnode: *ast.Node = ast.get(store, param_nid);
    val p_payload: u32 = pnode.payload;
    val pname_sid: ast.StrId = ast.get_extra(store, p_payload)::ast.StrId;
    val pname: str = ast.get_str(store, pname_sid);
    val param_tid: type.TypeId = lctx.node_type(ctx, param_nid);
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, param_nid);

    val param_res: Result[ir.ValueId, str] = builder.build_param(?ctx.fb, param_tid, idx, loc);
    if (is_err[ir.ValueId, str](param_res)) {
        lctx.emit_error(ctx, loc, "failed to lower parameter");
        ret;
    }
    val param_val: ir.ValueId = unwrap_ok[ir.ValueId, str](param_res);

    if (pname != nil) {
        val ptr_res: Result[ir.ValueId, str] = lctx.push_local(ctx, pname, param_tid, loc);
        if (is_err[ir.ValueId, str](ptr_res)) {
            lctx.emit_error(ctx, loc, "failed to allocate local for parameter");
            ret;
        }
        val ptr: ir.ValueId = unwrap_ok[ir.ValueId, str](ptr_res);

        if (lctx.is_aggregate(ctx, param_tid)) {
            val sz: u32 = lctx.type_size(ctx, param_tid);
            builder.build_copy(?ctx.fb, ptr, param_val, sz::u64, loc);
        } or {
            builder.build_store(?ctx.fb, ptr, param_val, loc);
        }
    }
}

fun lower_instantiation(ctx: *lctx.LowerCtx, fi: *mono.FnInst, store: *ast.NodeStore) {
    if (fi == nil || fi.mangled_name == nil) { ret; }
    if (fi.func_node::u32 == ast.NODE_NIL::u32) { ret; }

    val node_id: ast.NodeId = fi.func_node;
    val fn_t: *type.Type = type.get(ctx.sema.types, fi.func_type);

    var ret_tid: type.TypeId = type.primitive(ctx.sema.types, type.TK_VOID);
    if (fn_t.kind == type.TK_FUN) {
        ret_tid = fn_t.ret_type;
    }

    val saved_etm: ptr = ctx.inst_etm;
    val saved_scope: u32 = ctx.inst_scope;
    ctx.inst_etm   = (?fi.inst_etm)::ptr;
    ctx.inst_scope = fi.scope_id;

    ctx.fb = builder.func_init(ctx.alloc, fi.mangled_name, ret_tid, ctx.src_path);
    ctx.local_count    = 0;
    ctx.ds.count       = 0;
    ctx.ds.mark        = 0;
    ctx.ls.brk_block   = ir.BLOCK_NONE;
    ctx.ls.cnt_block   = ir.BLOCK_NONE;
    ctx.rs.ret_type    = ret_tid;

    val entry_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "entry");
    if (is_err[ir.BlockId, str](entry_res)) {
        val eloc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        lctx.emit_error(ctx, eloc, "failed to create entry block");
        ctx.inst_etm   = saved_etm;
        ctx.inst_scope = saved_scope;
        ret;
    }
    builder.switch_to_block(?ctx.fb, unwrap_ok[ir.BlockId, str](entry_res));

    val ret_sz: u32 = lctx.type_size(ctx, ret_tid);
    val needs_sret: bool = lctx.is_aggregate(ctx, ret_tid) && ret_sz > ctx.max_reg_ret;
    var param_offset: u32 = 0;
    if (needs_sret) {
        val ptr_tid: type.TypeId = type.make_pointer(ctx.sema.types, ret_tid);
        val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        val sret_res: Result[ir.ValueId, str] = builder.build_param(?ctx.fb, ptr_tid, 0, loc);
        if (is_ok[ir.ValueId, str](sret_res)) {
            val sret_val: ir.ValueId = unwrap_ok[ir.ValueId, str](sret_res);
            val al_res: Result[ir.ValueId, str] = builder.build_alloca(?ctx.fb, ptr_tid, 8, 8, loc);
            if (is_ok[ir.ValueId, str](al_res)) {
                val al: ir.ValueId = unwrap_ok[ir.ValueId, str](al_res);
                builder.build_store(?ctx.fb, al, sret_val, loc);
                lctx.push_local_with_ptr(ctx, "$sret", ptr_tid, al);
            }
        }
        param_offset = 1;
    }

    val params: ast.NodeSpan = ast.fun_params(store, node_id);
    var pi: u32 = 0;
    for (pi < params.len) {
        val param_nid: ast.NodeId = ast.get_extra(store, params.start + pi)::ast.NodeId;
        if (param_nid::u32 != ast.NODE_NIL::u32) {
            val pnode: *ast.Node = ast.get(store, param_nid);
            val pname_sid: ast.StrId = ast.get_extra(store, pnode.payload)::ast.StrId;
            val pname: str = ast.get_str(store, pname_sid);

            var param_tid: type.TypeId = type.TYPE_NIL;
            if (fn_t.kind == type.TK_FUN && pi::u16 < fn_t.param_count) {
                param_tid = fn_t.params[pi];
            }
            val loc: ir.SrcRef = lctx.make_loc(ctx, store, param_nid);

            val param_res: Result[ir.ValueId, str] = builder.build_param(?ctx.fb, param_tid, pi + param_offset, loc);
            if (is_err[ir.ValueId, str](param_res)) { pi = pi + 1; cnt; }
            val param_val: ir.ValueId = unwrap_ok[ir.ValueId, str](param_res);

            if (pname != nil) {
                val ptr_res: Result[ir.ValueId, str] = lctx.push_local(ctx, pname, param_tid, loc);
                if (is_ok[ir.ValueId, str](ptr_res)) {
                    val ptr: ir.ValueId = unwrap_ok[ir.ValueId, str](ptr_res);
                    if (lctx.is_aggregate(ctx, param_tid)) {
                        val sz: u32 = lctx.type_size(ctx, param_tid);
                        builder.build_copy(?ctx.fb, ptr, param_val, sz::u64, loc);
                    } or {
                        builder.build_store(?ctx.fb, ptr, param_val, loc);
                    }
                }
            }
        }
        pi = pi + 1;
    }

    val body: ast.NodeId = ast.fun_body(store, node_id);
    if (body::u32 != ast.NODE_NIL::u32) {
        stmt_mod.lower_stmt(ctx, body, store);
    }

    if (!builder.is_block_terminated(?ctx.fb)) {
        val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        builder.build_ret(?ctx.fb, ir.VALUE_NONE, loc);
    }

    builder.finalize_blocks(?ctx.fb);

    val func: ir.Function = builder.func_finish(?ctx.fb);
    val add_res: Result[u32, str] = builder.module_add_func(ctx.mb, func);
    if (is_err[u32, str](add_res)) {
        val eloc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        lctx.emit_error(ctx, eloc, "failed to add instantiation to module");
    }

    ctx.inst_etm   = saved_etm;
    ctx.inst_scope = saved_scope;
}
