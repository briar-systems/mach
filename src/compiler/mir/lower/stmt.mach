# mach.compiler.mir.lower.stmt: AST statement → MIR lowering
#
# lowers control flow, declarations, and statement-level constructs
# into MIR blocks and instructions.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;
use type:      mach.compiler.sema.type;
use scope:     mach.compiler.sema.scope;
use smod:      mach.compiler.sema.module;
use ast:       mach.compiler.parse.ast;

use op:       mach.compiler.mir.op;
use ir:       mach.compiler.mir.ir;
use builder:  mach.compiler.mir.builder;
use lctx:     mach.compiler.mir.lower.ctx;
use expr_mod: mach.compiler.mir.lower.expr;

# lower any statement node
pub fun lower_stmt(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }
    if (builder.is_block_terminated(?ctx.fb)) { ret; }
    val node: *ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_STMT_BLOCK)  { lower_block(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_EXPR)   { lower_expr_stmt(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_DECL_VAL)    { lower_var_decl(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_DECL_VAR)    { lower_var_decl(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_IF)     { lower_if(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_FOR)    { lower_for(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_RET)    { lower_ret(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_BRK)    { lower_brk(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_CNT)    { lower_cnt(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_FIN)    { lower_fin(ctx, node_id, store); ret; }
    if (node.kind == ast.NK_STMT_ASM)    { lower_asm(ctx, node_id, store); ret; }

    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
    lctx.emit_error(ctx, loc, "unhandled statement kind in MIR lowering");
}

fun lower_block(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val saved_locals: i32 = lctx.save_locals(ctx);
    val saved_defer: i32 = lctx.defer_mark(ctx);

    val stmts: ast.NodeSpan = ast.block_stmts(store, node_id);
    var i: u32 = 0;
    for (i < stmts.len) {
        if (builder.is_block_terminated(?ctx.fb)) {
            i = i + 1;
            cnt;
        }
        val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
        if (child_id::u32 != ast.NODE_NIL::u32) {
            lower_stmt(ctx, child_id, store);
        }
        i = i + 1;
    }

    emit_deferred(ctx, saved_defer, store);
    lctx.restore_locals(ctx, saved_locals);
}

fun lower_expr_stmt(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val node: *ast.Node = ast.get(store, node_id);
    val expr_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    expr_mod.lower_expr(ctx, expr_id, store);
}

fun lower_var_decl(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val name_sid: ast.StrId = ast.var_name(store, node_id);
    val name: str = ast.get_str(store, name_sid);
    val tid: type.TypeId = lctx.node_type(ctx, node_id);
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);

    if (tid::u32 == type.TYPE_NIL::u32) {
        lctx.emit_error(ctx, loc, "variable has no resolved type");
        ret;
    }

    val ptr_res: Result[ir.ValueId, str] = lctx.push_local(ctx, name, tid, loc);
    if (is_err[ir.ValueId, str](ptr_res)) {
        lctx.emit_error(ctx, loc, "failed to allocate local variable");
        ret;
    }
    val ptr: ir.ValueId = unwrap_ok[ir.ValueId, str](ptr_res);

    val init_id: ast.NodeId = ast.var_init(store, node_id);
    if (init_id::u32 != ast.NODE_NIL::u32) {
        val init_val: ir.ValueId = expr_mod.lower_expr(ctx, init_id, store);
        if (init_val::u32 != ir.VALUE_NONE::u32) {
            val sz: u32 = lctx.type_size(ctx, tid);
            if (lctx.is_aggregate(ctx, tid) && sz == 0) {
            } or (lctx.is_aggregate(ctx, tid) && sz > 0 && sz <= 8) {
                builder.build_agg_store(?ctx.fb, ptr, init_val, sz, loc);
            } or (lctx.is_aggregate(ctx, tid) && sz > 8) {
                builder.build_copy(?ctx.fb, ptr, init_val, sz::u64, loc);
            } or {
                builder.build_store(?ctx.fb, ptr, init_val, loc);
            }
        }
    }
}

fun lower_if(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);

    val end_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "if_end");
    if (is_err[ir.BlockId, str](end_res)) {
        lctx.emit_error(ctx, loc, "failed to create if-end block");
        ret;
    }
    val end_block: ir.BlockId = unwrap_ok[ir.BlockId, str](end_res);

    lower_if_chain(ctx, node_id, store, end_block);

    if (!builder.is_block_terminated(?ctx.fb)) {
        builder.build_br(?ctx.fb, end_block, nil, 0, loc);
    }

    builder.switch_to_block(?ctx.fb, end_block);
}

fun lower_if_chain(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore, end_block: ir.BlockId) {
    val node: *ast.Node = ast.get(store, node_id);
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);

    if (node.kind != ast.NK_STMT_IF && node.kind != ast.NK_STMT_OR) { ret; }

    val cond_id: ast.NodeId = ast.cond_expr(store, node_id);
    val body_id: ast.NodeId = ast.cond_body(store, node_id);
    val else_id: ast.NodeId = ast.cond_or_chain(store, node_id);

    val then_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "if_then");
    val else_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "if_else");
    if (is_err[ir.BlockId, str](then_res) || is_err[ir.BlockId, str](else_res)) {
        lctx.emit_error(ctx, loc, "failed to create if blocks");
        ret;
    }
    val then_block: ir.BlockId = unwrap_ok[ir.BlockId, str](then_res);
    val else_block: ir.BlockId = unwrap_ok[ir.BlockId, str](else_res);

    val cond: ir.ValueId = expr_mod.lower_expr(ctx, cond_id, store);
    if (cond::u32 == ir.VALUE_NONE::u32) { ret; }
    builder.build_cond_br(?ctx.fb, cond, then_block, nil, 0, else_block, nil, 0, loc);

    builder.switch_to_block(?ctx.fb, then_block);
    lower_stmt(ctx, body_id, store);
    if (!builder.is_block_terminated(?ctx.fb)) {
        builder.build_br(?ctx.fb, end_block, nil, 0, loc);
    }

    builder.switch_to_block(?ctx.fb, else_block);
    if (else_id::u32 != ast.NODE_NIL::u32) {
        val else_node: *ast.Node = ast.get(store, else_id);
        if (else_node.kind == ast.NK_STMT_OR) {
            val or_cond: ast.NodeId = ast.cond_expr(store, else_id);
            if (or_cond::u32 != ast.NODE_NIL::u32) {
                lower_if_chain(ctx, else_id, store, end_block);
            } or {
                val or_body: ast.NodeId = ast.cond_body(store, else_id);
                lower_stmt(ctx, or_body, store);
            }
        } or {
            lower_stmt(ctx, else_id, store);
        }
    }
    if (!builder.is_block_terminated(?ctx.fb)) {
        builder.build_br(?ctx.fb, end_block, nil, 0, loc);
    }
}

fun lower_for(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val node: *ast.Node = ast.get(store, node_id);
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);

    val cond_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "for_cond");
    val body_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "for_body");
    val end_res: Result[ir.BlockId, str] = builder.create_block(?ctx.fb, "for_end");
    if (is_err[ir.BlockId, str](cond_res) || is_err[ir.BlockId, str](body_res) || is_err[ir.BlockId, str](end_res)) {
        lctx.emit_error(ctx, loc, "failed to create for-loop blocks");
        ret;
    }
    val cond_block: ir.BlockId = unwrap_ok[ir.BlockId, str](cond_res);
    val body_block: ir.BlockId = unwrap_ok[ir.BlockId, str](body_res);
    val end_block: ir.BlockId = unwrap_ok[ir.BlockId, str](end_res);

    val saved_ls: lctx.LoopState = ctx.ls;
    ctx.ls.brk_block = end_block;
    ctx.ls.cnt_block = cond_block;

    builder.build_br(?ctx.fb, cond_block, nil, 0, loc);

    builder.switch_to_block(?ctx.fb, cond_block);
    val cond_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    if (cond_id::u32 != ast.NODE_NIL::u32) {
        val cond: ir.ValueId = expr_mod.lower_expr(ctx, cond_id, store);
        if (cond::u32 != ir.VALUE_NONE::u32) {
            builder.build_cond_br(?ctx.fb, cond, body_block, nil, 0, end_block, nil, 0, loc);
        } or {
            builder.build_br(?ctx.fb, body_block, nil, 0, loc);
        }
    } or {
        builder.build_br(?ctx.fb, body_block, nil, 0, loc);
    }

    builder.switch_to_block(?ctx.fb, body_block);
    val body_id: ast.NodeId = ast.get_extra(store, node.payload + 1)::ast.NodeId;
    if (body_id::u32 != ast.NODE_NIL::u32) {
        lower_stmt(ctx, body_id, store);
    }
    if (!builder.is_block_terminated(?ctx.fb)) {
        builder.build_br(?ctx.fb, cond_block, nil, 0, loc);
    }

    builder.switch_to_block(?ctx.fb, end_block);
    ctx.ls = saved_ls;
}

fun lower_ret(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val node: *ast.Node = ast.get(store, node_id);
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);

    val value_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    if (value_id::u32 != ast.NODE_NIL::u32) {
        val value: ir.ValueId = expr_mod.lower_expr(ctx, value_id, store);
        if (value::u32 == ir.VALUE_NONE::u32) {
            lctx.emit_error(ctx, loc, "failed to lower return value");
        }

        var ret_tid: type.TypeId = ctx.rs.ret_type;
        val val_tid: type.TypeId = lctx.node_type(ctx, value_id);
        if (val_tid::u32 != type.TYPE_NIL::u32 && lctx.is_aggregate(ctx, val_tid)) {
            ret_tid = val_tid;
        }
        val ret_sz: u32 = lctx.type_size(ctx, ret_tid);
        if (lctx.is_aggregate(ctx, ret_tid) && ret_sz > ctx.max_reg_ret) {
            val sret_ptr: ir.ValueId = lctx.find_local(ctx, "$sret");
            if (sret_ptr::u32 != ir.VALUE_NONE::u32) {
                val sret_ld: Result[ir.ValueId, str] = builder.build_load(?ctx.fb, type.TK_POINTER::type.TypeId, sret_ptr, loc);
                if (is_ok[ir.ValueId, str](sret_ld)) {
                    val dst: ir.ValueId = unwrap_ok[ir.ValueId, str](sret_ld);
                    builder.build_copy(?ctx.fb, dst, value, ret_sz::u64, loc);
                    builder.build_ret(?ctx.fb, dst, loc);
                    ret;
                }
            }
        }
        if (lctx.is_aggregate(ctx, ret_tid) && ret_sz == 0) {
            builder.build_ret(?ctx.fb, ir.VALUE_NONE, loc);
        } or (lctx.is_aggregate(ctx, ret_tid) && ret_sz > 0 && ret_sz <= ctx.max_reg_ret) {
            builder.build_ret_agg(?ctx.fb, value, ret_sz::u16, loc);
        } or {
            builder.build_ret(?ctx.fb, value, loc);
        }
    } or {
        builder.build_ret(?ctx.fb, ir.VALUE_NONE, loc);
    }
}

fun lower_brk(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
    if (ctx.ls.brk_block::u32 != ir.BLOCK_NONE::u32) {
        builder.build_br(?ctx.fb, ctx.ls.brk_block, nil, 0, loc);
    }
}

fun lower_cnt(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
    if (ctx.ls.cnt_block::u32 != ir.BLOCK_NONE::u32) {
        builder.build_br(?ctx.fb, ctx.ls.cnt_block, nil, 0, loc);
    }
}

fun lower_fin(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val node: *ast.Node = ast.get(store, node_id);
    val body_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    if (body_id::u32 != ast.NODE_NIL::u32) {
        lctx.defer_push(ctx, body_id);
    }
}

fun lower_asm(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    val node: *ast.Node = ast.get(store, node_id);
    val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
    val asm_sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
    val asm_text: str = ast.get_str(store, asm_sid);
    val isa_sid: ast.StrId = ast.get_extra(store, node.payload + 1)::ast.StrId;

    if (asm_text == nil) { ret; }

    # ISA-specific assembly block with operand constraints
    if (isa_sid::u32 != ast.STR_NIL::u32) {
        lower_isa_asm(ctx, node_id, store, asm_text, loc);
        ret;
    }

    if (str_equals(asm_text, "trap")) {
        builder.build_unreachable(?ctx.fb, loc);
        ret;
    }

    if (str_equals(asm_text, "hint.pause")) {
        builder.emit(?ctx.fb, op.OP_ASM, 0, type.TK_VOID::type.TypeId,
                     nil, 0, ir.BLOCK_NONE, ir.BLOCK_NONE, 0, loc);
        ret;
    }

    if (str_starts_with(asm_text, "fence")) {
        var mo: op.MemOrder = op.MO_SEQ_CST;
        if (str_contains(asm_text, "relaxed"))  { mo = op.MO_RELAXED; }
        if (str_contains(asm_text, "acquire"))  { mo = op.MO_ACQUIRE; }
        if (str_contains(asm_text, "release"))  { mo = op.MO_RELEASE; }
        if (str_contains(asm_text, "acq_rel"))  { mo = op.MO_ACQ_REL; }
        builder.build_fence(?ctx.fb, mo, loc);
        ret;
    }

    if (str_starts_with(asm_text, "syscall")) {
        lower_asm_syscall(ctx, node_id, store, loc);
        ret;
    }

    if (str_starts_with(asm_text, "atomic.")) {
        lower_asm_atomic(ctx, node_id, store, asm_text, loc);
        ret;
    }

    val sym_res: Result[ir.SymId, str] = builder.module_add_symbol(ctx.mb, asm_text, false);
    if (is_ok[ir.SymId, str](sym_res)) {
        val sid: ir.SymId = unwrap_ok[ir.SymId, str](sym_res);
        builder.emit(?ctx.fb, op.OP_ASM, 0, type.TK_VOID::type.TypeId,
                     nil, 0, ir.BLOCK_NONE, ir.BLOCK_NONE, sid::u64, loc);
    } or {
        val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        lctx.emit_error(ctx, loc, "failed to register inline asm symbol");
    }
}

# lower ISA-specific assembly with in/out operand constraints
# emits OP_ASM with input operand values as arguments
fun lower_isa_asm(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore,
                  asm_text: str, loc: ir.SrcRef) {
    val node: *ast.Node = ast.get(store, node_id);
    val specs_start: u32 = ast.get_extra(store, node.payload + 2);
    val specs_count: u32 = ast.get_extra(store, node.payload + 3);

    var in_vals: [16]ir.ValueId;
    var in_count: u16 = 0;

    var si: u32 = 0;
    for (si < specs_count && in_count < 16) {
        val spec_id: ast.NodeId = ast.get_extra(store, specs_start + si)::ast.NodeId;
        if (spec_id::u32 != ast.NODE_NIL::u32) {
            val spec_node: *ast.Node = ast.get(store, spec_id);
            val kind: u32 = ast.get_extra(store, spec_node.payload);

            if (kind == 1) {
                val expr_id: ast.NodeId = ast.get_extra(store, spec_node.payload + 2)::ast.NodeId;
                if (expr_id::u32 != ast.NODE_NIL::u32) {
                    in_vals[in_count] = expr_mod.lower_expr(ctx, expr_id, store);
                    in_count = in_count + 1;
                }
            }
        }
        si = si + 1;
    }

    val sym_res: Result[ir.SymId, str] = builder.module_add_symbol(ctx.mb, asm_text, false);
    if (is_err[ir.SymId, str](sym_res)) {
        val loc: ir.SrcRef = lctx.make_loc(ctx, store, node_id);
        lctx.emit_error(ctx, loc, "failed to register asm symbol");
        ret;
    }
    val sid: ir.SymId = unwrap_ok[ir.SymId, str](sym_res);

    builder.emit(?ctx.fb, op.OP_ASM, 0, type.TK_VOID::type.TypeId,
                 ?in_vals[0], in_count, ir.BLOCK_NONE, ir.BLOCK_NONE, sid::u64, loc);
}

fun lower_asm_syscall(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore, loc: ir.SrcRef) {
    val node: *ast.Node = ast.get(store, node_id);
    val specs_start: u32 = ast.get_extra(store, node.payload + 2);
    val specs_count: u32 = ast.get_extra(store, node.payload + 3);

    var args: [8]ir.ValueId;
    var arg_count: u16 = 0;
    var out_name: str = nil;

    if (specs_count > 0) {
        var si: u32 = 0;
        for (si < specs_count && arg_count < 8) {
            val spec_id: ast.NodeId = ast.get_extra(store, specs_start + si)::ast.NodeId;
            if (spec_id::u32 != ast.NODE_NIL::u32) {
                val spec_node: *ast.Node = ast.get(store, spec_id);
                val kind: u32 = ast.get_extra(store, spec_node.payload);
                if (kind == 1) {
                    val expr_id: ast.NodeId = ast.get_extra(store, spec_node.payload + 2)::ast.NodeId;
                    if (expr_id::u32 != ast.NODE_NIL::u32) {
                        args[arg_count] = expr_mod.lower_expr(ctx, expr_id, store);
                        arg_count = arg_count + 1;
                    }
                }
            }
            si = si + 1;
        }
    } or {
        val asm_sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
        val text: str = ast.get_str(store, asm_sid);
        if (text != nil) {
            var names: [8]str;
            var name_count: i32 = 0;
            var i: usize = 0;
            val len: usize = str_len(text);
            for (i < len) {
                val c: u8 = text[i];
                if (c == '{' && i + 1 < len) {
                    val start: usize = i + 1;
                    var end: usize = start;
                    for (end < len && text[end] != '}') { end = end + 1; }
                    if (end > start && end < len && name_count < 8) {
                        names[name_count] = (text::usize + start)::str;
                        val nlen: usize = end - start;
                        val interned: ast.StrId = ast.intern(store, names[name_count], nlen::u32);
                        names[name_count] = ast.get_str(store, interned);
                        name_count = name_count + 1;
                    }
                    i = end + 1;
                } or {
                    i = i + 1;
                }
            }
            if (name_count > 0) { out_name = names[0]; }
            var ni: i32 = 1;
            for (ni < name_count && arg_count < 8) {
                val lp: ir.ValueId = lctx.find_local(ctx, names[ni]);
                if (lp::u32 != ir.VALUE_NONE::u32) {
                    val tid: type.TypeId = type.TK_U64::type.TypeId;
                    val ld_res: Result[ir.ValueId, str] = builder.build_load(?ctx.fb, tid, lp, loc);
                    if (is_ok[ir.ValueId, str](ld_res)) {
                        args[arg_count] = unwrap_ok[ir.ValueId, str](ld_res);
                        arg_count = arg_count + 1;
                    }
                }
                ni = ni + 1;
            }
        }
    }

    val ret_tid: type.TypeId = type.TK_I64::type.TypeId;
    val sc_res: Result[ir.ValueId, str] = builder.build_syscall(?ctx.fb, ret_tid, ?args[0], arg_count, loc);

    if (out_name != nil && is_ok[ir.ValueId, str](sc_res)) {
        val sc_val: ir.ValueId = unwrap_ok[ir.ValueId, str](sc_res);
        val out_ptr: ir.ValueId = lctx.find_local(ctx, out_name);
        if (out_ptr::u32 != ir.VALUE_NONE::u32) {
            builder.build_store(?ctx.fb, out_ptr, sc_val, loc);
        }
    }
}

fun lower_asm_atomic(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore,
                     asm_text: str, loc: ir.SrcRef) {
    val node: *ast.Node = ast.get(store, node_id);
    val specs_start: u32 = ast.get_extra(store, node.payload + 2);
    val specs_count: u32 = ast.get_extra(store, node.payload + 3);

    var mo: op.MemOrder = op.MO_SEQ_CST;
    if (str_contains(asm_text, "relaxed"))  { mo = op.MO_RELAXED; }
    if (str_contains(asm_text, "acquire"))  { mo = op.MO_ACQUIRE; }
    if (str_contains(asm_text, "release"))  { mo = op.MO_RELEASE; }
    if (str_contains(asm_text, "acq_rel"))  { mo = op.MO_ACQ_REL; }

    var arg_vals: [4]ir.ValueId;
    var arg_count: u16 = 0;

    var si: u32 = 0;
    for (si < specs_count && arg_count < 4) {
        val spec_id: ast.NodeId = ast.get_extra(store, specs_start + si)::ast.NodeId;
        if (spec_id::u32 != ast.NODE_NIL::u32) {
            val spec_node: *ast.Node = ast.get(store, spec_id);
            val kind: u32 = ast.get_extra(store, spec_node.payload);
            if (kind == 1) {
                val expr_id: ast.NodeId = ast.get_extra(store, spec_node.payload + 2)::ast.NodeId;
                if (expr_id::u32 != ast.NODE_NIL::u32) {
                    arg_vals[arg_count] = expr_mod.lower_expr(ctx, expr_id, store);
                    arg_count = arg_count + 1;
                }
            }
        }
        si = si + 1;
    }

    val ptr_tid: type.TypeId = type.TK_U64::type.TypeId;

    if (str_starts_with(asm_text, "atomic.load")) {
        if (arg_count >= 1) {
            var a: [1]ir.ValueId;
            a[0] = arg_vals[0];
            builder.emit(?ctx.fb, op.OP_ATOMIC_LOAD, mo::u16, ptr_tid,
                         ?a[0], 1, ir.BLOCK_NONE, ir.BLOCK_NONE, 0, loc);
        }
    } or (str_starts_with(asm_text, "atomic.store")) {
        if (arg_count >= 2) {
            var a: [2]ir.ValueId;
            a[0] = arg_vals[0];
            a[1] = arg_vals[1];
            builder.emit(?ctx.fb, op.OP_ATOMIC_STORE, mo::u16, type.TK_VOID::type.TypeId,
                         ?a[0], 2, ir.BLOCK_NONE, ir.BLOCK_NONE, 0, loc);
        }
    } or (str_starts_with(asm_text, "atomic.cas")) {
        if (arg_count >= 3) {
            var a: [3]ir.ValueId;
            a[0] = arg_vals[0];
            a[1] = arg_vals[1];
            a[2] = arg_vals[2];
            builder.emit(?ctx.fb, op.OP_ATOMIC_CAS, mo::u16, ptr_tid,
                         ?a[0], 3, ir.BLOCK_NONE, ir.BLOCK_NONE, 0, loc);
        }
    } or (str_starts_with(asm_text, "atomic.rmw")) {
        if (arg_count >= 2) {
            var rmw: op.RmwOp = op.RMW_ADD;
            if (str_contains(asm_text, "sub"))  { rmw = op.RMW_SUB; }
            if (str_contains(asm_text, "and"))  { rmw = op.RMW_AND; }
            if (str_contains(asm_text, "or"))   { rmw = op.RMW_OR; }
            if (str_contains(asm_text, "xor"))  { rmw = op.RMW_XOR; }
            if (str_contains(asm_text, "xchg")) { rmw = op.RMW_XCHG; }
            var a: [2]ir.ValueId;
            a[0] = arg_vals[0];
            a[1] = arg_vals[1];
            builder.emit(?ctx.fb, op.OP_ATOMIC_RMW, mo::u16, ptr_tid,
                         ?a[0], 2, ir.BLOCK_NONE, ir.BLOCK_NONE, rmw::u64, loc);
        }
    }
}

# emit deferred statements in LIFO order from mark to current count
pub fun emit_deferred(ctx: *lctx.LowerCtx, mark: i32, store: *ast.NodeStore) {
    if (ctx.ds.nodes == nil) { ret; }
    var i: i32 = ctx.ds.count - 1;
    for (i >= mark) {
        val deferred_id: ast.NodeId = ctx.ds.nodes[i];
        if (deferred_id::u32 != ast.NODE_NIL::u32) {
            lower_stmt(ctx, deferred_id, store);
        }
        i = i - 1;
    }
    ctx.ds.count = mark;
}

fun str_starts_with(s: str, prefix: str) bool {
    if (s == nil || prefix == nil) { ret false; }
    val slen: usize = str_len(s);
    val plen: usize = str_len(prefix);
    if (plen > slen) { ret false; }
    var i: usize = 0;
    for (i < plen) {
        val sc_ptr: *u8 = (s::usize + i)::*u8;
        val sc: u8 = sc_ptr[0];
        val pc_ptr: *u8 = (prefix::usize + i)::*u8;
        val pc: u8 = pc_ptr[0];
        if (sc != pc) { ret false; }
        i = i + 1;
    }
    ret true;
}

fun str_contains(s: str, sub: str) bool {
    if (s == nil || sub == nil) { ret false; }
    val slen: usize = str_len(s);
    val sublen: usize = str_len(sub);
    if (sublen > slen) { ret false; }
    var i: usize = 0;
    for (i <= slen - sublen) {
        var match: bool = true;
        var j: usize = 0;
        for (j < sublen) {
            val sc_ptr: *u8 = (s::usize + i + j)::*u8;
            val sc: u8 = sc_ptr[0];
            val pc_ptr: *u8 = (sub::usize + j)::*u8;
            val pc: u8 = pc_ptr[0];
            if (sc != pc) { match = false; }
            j = j + 1;
        }
        if (match) { ret true; }
        i = i + 1;
    }
    ret false;
}
