# mach.compiler.mir.lower.data: global data declarations → MIR lowering
#
# lowers global val/var declarations to MIR Global records.
# handles string constant pooling for string literals.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.mem;
use type:      mach.compiler.sema.type;
use scope:     mach.compiler.sema.scope;
use smod:      mach.compiler.sema.module;
use ast:       mach.compiler.parse.ast;

use ir:      mach.compiler.mir.ir;
use builder: mach.compiler.mir.builder;
use lctx:    mach.compiler.mir.lower.ctx;

# lower a global val or var declaration
pub fun lower_global_var(ctx: *lctx.LowerCtx, node_id: ast.NodeId, store: *ast.NodeStore) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }

    val name_sid: ast.StrId = ast.var_name(store, node_id);
    var name: str = ast.get_str(store, name_sid);
    if (name == nil) { ret; }

    val tid: type.TypeId = lctx.node_type(ctx, node_id);
    val sz: u32 = lctx.type_size(ctx, tid);
    val al: u32 = lctx.type_align(ctx, tid);

    val sym_id: scope.SymbolId = lctx.node_sym(ctx, node_id);
    if (sym_id::u32 != scope.SYM_NIL::u32) {
        val sym: *scope.Symbol = lctx.get_sym(ctx, sym_id);
        if (sym != nil && sym.export_name != nil) {
            name = sym.export_name;
        } or {
            val fn_mod: *smod.Module = smod.get(ctx.sema.modules, ctx.current_mod);
            name = lctx.mangle_symbol(ctx, fn_mod.path, name);
        }
    }

    val node: *ast.Node = ast.get(store, node_id);
    val is_const: bool = node.kind == ast.NK_DECL_VAL;

    var glob: ir.Global;
    glob.name     = name;
    glob.type_id  = tid;
    glob.size     = sz;
    glob.align    = al;
    glob.data     = nil;
    glob.data_len = 0;
    glob.is_const = is_const;

    builder.module_add_global(ctx.mb, glob);
}

# add a string constant as a global read-only data declaration
# called from expr lowering when encountering string literals
pub fun add_string_constant(ctx: *lctx.LowerCtx, label: str, text: str) {
    if (text == nil) { ret; }

    val text_len: usize = mem.str_len(text);
    val total_len: u32 = text_len::u32 + 1;

    var data: *u8 = nil;
    val res: Result[*u8, str] = allocator.allocate[u8](ctx.alloc, total_len::usize);
    if (res::bool) {
        data = unwrap_ok[*u8, str](res);
        mem.raw_copy(data::ptr, text, text_len);
        data[text_len] = 0;
    }

    var glob: ir.Global;
    glob.name     = label;
    glob.type_id  = type.TK_OPAQUE_PTR::type.TypeId;
    glob.size     = total_len;
    glob.align    = 1;
    glob.data     = data;
    glob.data_len = total_len;
    glob.is_const = true;

    builder.module_add_global(ctx.mb, glob);
}
