# mach.compiler.mir.frame: stack frame layout from MIR allocas
#
# scans a MIR function for OP_ALLOCA instructions and assigns each a
# stack frame offset. completely target-agnostic — the resulting offsets
# are consumed by the target-specific ISel.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use op:  mach.compiler.mir.op;
use ir:  mach.compiler.mir.ir;

val MAX_ALLOCAS: u32 = 512;

# maps an alloca ValueId to its frame offset
pub rec AllocaSlot {
    value:  ir.ValueId;   # the alloca result value
    offset: i64;          # negative offset from frame pointer
    size:   u64;
    align:  u16;
}

# collected frame layout for a function
pub rec FrameLayout {
    slots:      *AllocaSlot;
    slot_count: u32;
    frame_size: usize;    # total bytes of stack space (positive)
}

# scan a MIR function and assign stack offsets to all allocas
pub fun compute(alloc: *allocator.Allocator, func: *ir.Function) FrameLayout {
    var layout: FrameLayout;
    layout.slots      = nil;
    layout.slot_count = 0;
    layout.frame_size = 0;

    val res: Result[*AllocaSlot, str] = allocator.allocate[AllocaSlot](alloc, MAX_ALLOCAS::usize);
    if (is_err[*AllocaSlot, str](res)) { ret layout; }
    layout.slots = unwrap_ok[*AllocaSlot, str](res);

    var offset: i64 = 0;

    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];

            if (inst.op == op.OP_ALLOCA && layout.slot_count < MAX_ALLOCAS) {
                val size: u64 = inst.imm;
                val align: u16 = inst.flags;
                var al: u64 = 1;
                if (align::u64 > 0) { al = align::u64; }

                offset = offset - size::i64;
                if (al > 1) {
                    val mask: i64 = al::i64 - 1;
                    offset = (offset - mask) & ~mask;
                }

                val idx: u32 = layout.slot_count;
                layout.slots[idx].value  = inst.result;
                layout.slots[idx].offset = offset;
                layout.slots[idx].size   = size;
                layout.slots[idx].align  = align;
                layout.slot_count = idx + 1;
            }

            ii = ii + 1;
        }
        bi = bi + 1;
    }

    if (offset < 0) {
        layout.frame_size = ((-offset)::usize + 15) & ~15::usize;
    }

    ret layout;
}

# look up the stack offset for an alloca value
pub fun slot_offset(layout: *FrameLayout, v: ir.ValueId) i64 {
    if (layout.slots == nil) { ret 0; }
    var i: u32 = 0;
    for (i < layout.slot_count) {
        if (layout.slots[i].value::u32 == v::u32) {
            ret layout.slots[i].offset;
        }
        i = i + 1;
    }
    ret 0;
}

# returns true if a value was produced by an alloca
pub fun is_alloca(layout: *FrameLayout, v: ir.ValueId) bool {
    if (layout.slots == nil) { ret false; }
    var i: u32 = 0;
    for (i < layout.slot_count) {
        if (layout.slots[i].value::u32 == v::u32) { ret true; }
        i = i + 1;
    }
    ret false;
}
