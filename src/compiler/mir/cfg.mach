# mach.compiler.mir.cfg: control flow graph types for register allocation
#
# standalone type definitions for CFG, basic blocks, liveness sets, and
# register bitsets. used by the MIR backend and register allocator.

use std.types.bool;
use std.types.size;

pub rec RegSet {
    bits:       *u64;
    word_count: u16;
}

pub rec LiveSets {
    live_in:  *RegSet;
    live_out: *RegSet;
    count:    u16;
}

pub rec BasicBlock {
    id:     u16;
    preds:  *u16;
    npreds: u16;
    succs:  *u16;
    nsuccs: u16;
}

pub rec CFG {
    blocks:      *BasicBlock;
    block_count: u16;
    entry:       u16;
}
