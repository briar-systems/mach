# mach.compiler.mir.ir: core MIR data structures
#
# SSA intermediate representation. every Value is defined exactly once.
# control flow joins use block arguments (not phi nodes). types reference
# the sema TypeTable directly via TypeId.

use std.types.bool;
use std.types.size;
use std.types.string;

use type: mach.compiler.sema.type;
use op:   mach.compiler.mir.op;

pub def ValueId: u32;
pub def InstId:  u32;
pub def BlockId: u32;
pub def SymId:   u32;

pub val VALUE_NONE: ValueId = 0xFFFFFFFF;
pub val INST_NONE:  InstId  = 0xFFFFFFFF;
pub val BLOCK_NONE: BlockId = 0xFFFFFFFF;
pub val SYM_NONE:   SymId   = 0xFFFFFFFF;

# how a value was defined
pub def ValueKind: u8;
pub val VK_INST:        ValueKind = 0;  # defined by an instruction result
pub val VK_BLOCK_PARAM: ValueKind = 1;  # defined as a block parameter

# an SSA value — defined exactly once, used zero or more times
#
# kind:     how this value was defined (instruction or block parameter)
# type_id:  sema type of this value
# def_inst: if VK_INST, the instruction that defines this value
# block:    block where this value is defined
# param_idx: if VK_BLOCK_PARAM, which parameter of the block
pub rec Value {
    kind:      ValueKind;
    type_id:   type.TypeId;
    def_inst:  InstId;
    block:     BlockId;
    param_idx: u16;
}

# compact source reference for diagnostics
#
# line:     1-based line number
# file_idx: index into the module's file table
pub rec SrcRef {
    line:     u32;
    file_idx: u16;
}

# an SSA instruction
#
# op:           opcode (determines semantics and operand interpretation)
# flags:        per-opcode modifier (condition code, memory ordering, etc.)
# result:       value defined by this instruction (VALUE_NONE if void)
# type_id:      result type
# arg_start:    start index into function's arg pool
# arg_count:    number of value arguments in arg pool
# target:       primary block target for branches/jumps (BLOCK_NONE if N/A)
# else_target:  secondary block target for cond_br (BLOCK_NONE if N/A)
# imm:          immediate data (integer constants, field indices, sizes, symbol refs)
# loc:          source location
pub rec Inst {
    op:          op.Op;
    flags:       u16;
    result:      ValueId;
    type_id:     type.TypeId;
    arg_start:   u32;
    arg_count:   u16;
    target:      BlockId;
    else_target: BlockId;
    imm:         u64;
    loc:         SrcRef;
}

# a block parameter — defines a Value at a block entry point.
# incoming values are provided by predecessor branches.
#
# value:   the SSA value this parameter defines
# type_id: type of the parameter
pub rec BlockParam {
    value:   ValueId;
    type_id: type.TypeId;
}

# a basic block in SSA form
#
# id:          block index within the function
# name:        debug label (optional, for printing)
# params:      block parameters (SSA values defined at entry)
# param_count: number of block parameters
# param_cap:   allocated capacity for params
# insts:       ordered instruction IDs in this block
# inst_count:  number of instructions
# inst_cap:    allocated capacity for insts
pub rec Block {
    id:          BlockId;
    name:        str;
    params:      *BlockParam;
    param_count: u32;
    param_cap:   u32;
    insts:       *InstId;
    inst_count:  u32;
    inst_cap:    u32;
}

# a global data declaration
#
# name:     symbol name
# type_id:  type of the global
# size:     byte size
# align:    byte alignment
# data:     initial value bytes (nil for zero-initialized / BSS)
# data_len: length of initial value
# is_const: true for read-only data
pub rec Global {
    name:     str;
    type_id:  type.TypeId;
    size:     u32;
    align:    u32;
    data:     *u8;
    data_len: u32;
    is_const: bool;
}

# a symbol reference (function or global variable)
#
# name:      symbol name
# is_extern: true if defined externally (no body/data in this module)
pub rec Symbol {
    name:      str;
    is_extern: bool;
}

# a function in SSA form
#
# name:        symbol name
# params:      function parameter types (entry block params mirror these)
# param_count: number of parameters
# ret_type:    return type
# is_variadic: true if function accepts variadic arguments
# blocks:      ordered basic blocks (blocks[0] is the entry block)
# block_count: number of blocks
# block_cap:   allocated capacity
# values:      all SSA values defined in this function
# value_count: total number of values
# value_cap:   allocated capacity
# insts:       all instructions in this function
# inst_count:  total number of instructions
# inst_cap:    allocated capacity
# args:        flat pool of instruction operands (ValueIds)
# arg_count:   total operands in pool
# arg_cap:     allocated capacity
# src_path:    source file path for debug info
pub rec Function {
    name:        str;
    params:      *type.TypeId;
    param_count: u32;
    ret_type:    type.TypeId;
    is_variadic: bool;

    blocks:      *Block;
    block_count: u32;
    block_cap:   u32;

    values:      *Value;
    value_count: u32;
    value_cap:   u32;

    insts:       *Inst;
    inst_count:  u32;
    inst_cap:    u32;

    args:        *ValueId;
    arg_count:   u32;
    arg_cap:     u32;

    src_path:    str;
    types:       *type.TypeTable;
}

# a MIR module — self-contained unit of compilation
#
# functions:  all functions in this module
# func_count: number of functions
# func_cap:   allocated capacity
# globals:    global data declarations
# glob_count: number of globals
# glob_cap:   allocated capacity
# symbols:    symbol table (functions + extern refs)
# sym_count:  number of symbols
# sym_cap:    allocated capacity
# types:      reference to the sema type table (not owned)
# files:      source file paths for debug info
# file_count: number of source files
pub rec Module {
    functions:  *Function;
    func_count: u32;
    func_cap:   u32;

    globals:    *Global;
    glob_count: u32;
    glob_cap:   u32;

    symbols:    *Symbol;
    sym_count:  u32;
    sym_cap:    u32;

    types:      *type.TypeTable;

    files:      *str;
    file_count: u16;
    file_cap:   u16;
}

# returns the instruction that defines a value (nil if block param)
pub fun value_def_inst(func: *Function, v: ValueId) *Inst {
    if (v::u32 >= func.value_count) { ret nil; }
    val value: *Value = ?func.values[v::u32];
    if (value.kind != VK_INST) { ret nil; }
    if (value.def_inst::u32 >= func.inst_count) { ret nil; }
    ret ?func.insts[value.def_inst::u32];
}

# returns the type of a value
pub fun value_type(func: *Function, v: ValueId) type.TypeId {
    if (v::u32 >= func.value_count) { ret type.TYPE_NIL; }
    ret func.values[v::u32].type_id;
}

# returns the argument ValueId at position idx for an instruction
pub fun inst_arg(func: *Function, inst: *Inst, idx: u16) ValueId {
    val pos: u32 = inst.arg_start + idx::u32;
    if (pos >= func.arg_count) { ret VALUE_NONE; }
    ret func.args[pos];
}

# returns the number of instructions in a block
pub fun block_inst_count(block: *Block) u32 {
    ret block.inst_count;
}

# returns the last instruction in a block (INST_NONE if empty)
pub fun block_terminator(func: *Function, block: *Block) *Inst {
    if (block.inst_count == 0) { ret nil; }
    val last_id: InstId = block.insts[block.inst_count - 1];
    ret ?func.insts[last_id::u32];
}

# returns true if the block ends with a terminator instruction
pub fun block_is_terminated(func: *Function, block: *Block) bool {
    val term: *Inst = block_terminator(func, block);
    if (term == nil) { ret false; }
    ret op.is_terminator(term.op);
}
