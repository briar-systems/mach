# mach.compiler.mir.op: MIR opcode definitions
#
# SSA instruction opcodes for the mid-level intermediate representation.
# every instruction that produces a result defines exactly one Value.
# operands are always Values (SSA references), never mutable registers.

pub def Op: u8;

# constants
pub val OP_ICONST:        Op = 0;   # integer constant (imm = value)
pub val OP_FCONST:        Op = 1;   # float constant (imm = f64 bits)
pub val OP_BCONST:        Op = 2;   # bool constant (imm = 0 or 1)
pub val OP_NULLPTR:       Op = 3;   # null pointer constant
pub val OP_GLOBAL_ADDR:   Op = 4;   # address of global/function (imm = symbol index)

# integer arithmetic (args: [lhs, rhs])
pub val OP_ADD:           Op = 10;
pub val OP_SUB:           Op = 11;
pub val OP_MUL:           Op = 12;
pub val OP_UDIV:          Op = 13;  # unsigned division
pub val OP_SDIV:          Op = 14;  # signed division
pub val OP_UREM:          Op = 15;  # unsigned remainder
pub val OP_SREM:          Op = 16;  # signed remainder

# float arithmetic (args: [lhs, rhs])
pub val OP_FADD:          Op = 17;
pub val OP_FSUB:          Op = 18;
pub val OP_FMUL:          Op = 19;
pub val OP_FDIV:          Op = 20;

# unary (args: [operand])
pub val OP_NEG:           Op = 21;  # integer negate
pub val OP_FNEG:          Op = 22;  # float negate
pub val OP_NOT:           Op = 23;  # bitwise not
pub val OP_LNOT:          Op = 24;  # logical not (bool → bool)

# bitwise (args: [lhs, rhs])
pub val OP_AND:           Op = 30;
pub val OP_OR:            Op = 31;
pub val OP_XOR:           Op = 32;
pub val OP_SHL:           Op = 33;  # shift left
pub val OP_LSHR:          Op = 34;  # logical shift right
pub val OP_ASHR:          Op = 35;  # arithmetic shift right

# integer comparison (args: [lhs, rhs], flags = condition code)
pub val OP_ICMP:          Op = 40;

# float comparison (args: [lhs, rhs], flags = condition code)
pub val OP_FCMP:          Op = 41;

# condition codes (stored in Inst.flags for ICMP/FCMP)
pub def CC: u16;
pub val CC_EQ:            CC = 0;
pub val CC_NE:            CC = 1;
pub val CC_SLT:           CC = 2;   # signed less than
pub val CC_SLE:           CC = 3;   # signed less or equal
pub val CC_SGT:           CC = 4;   # signed greater than
pub val CC_SGE:           CC = 5;   # signed greater or equal
pub val CC_ULT:           CC = 6;   # unsigned less than
pub val CC_ULE:           CC = 7;   # unsigned less or equal
pub val CC_UGT:           CC = 8;   # unsigned greater than
pub val CC_UGE:           CC = 9;   # unsigned greater or equal

# memory (args vary per op)
pub val OP_LOAD:          Op = 50;  # load from pointer (args: [ptr])
pub val OP_STORE:         Op = 51;  # store to pointer (args: [ptr, value]), no result
pub val OP_ALLOCA:        Op = 52;  # stack allocation (imm = size, flags = align), result = ptr
pub val OP_FIELD_PTR:     Op = 53;  # record field address (args: [record_ptr], imm = field index)
pub val OP_INDEX_PTR:     Op = 54;  # array element address (args: [array_ptr, index])
pub val OP_COPY:          Op = 55;  # memcpy (args: [dst_ptr, src_ptr], imm = byte count), no result

# type conversions (args: [operand])
pub val OP_ZEXT:          Op = 60;  # zero extend
pub val OP_SEXT:          Op = 61;  # sign extend
pub val OP_TRUNC:         Op = 62;  # truncate
pub val OP_ITOF:          Op = 63;  # integer to float
pub val OP_FTOI:          Op = 64;  # float to integer
pub val OP_FEXT:          Op = 65;  # float extend (f32 → f64)
pub val OP_FTRUNC:        Op = 66;  # float truncate (f64 → f32)
pub val OP_BITCAST:       Op = 67;  # reinterpret bits (same size, different type)
pub val OP_PTR_TO_INT:    Op = 68;  # pointer to integer
pub val OP_INT_TO_PTR:    Op = 69;  # integer to pointer

# control flow
pub val OP_BR:            Op = 80;  # unconditional branch (target = block, args = block args)
pub val OP_COND_BR:       Op = 81;  # conditional branch (args[0] = cond, target = then, else_target = else)
                                    # remaining args split by flags: args[1..1+flags] = then_args,
                                    # args[1+flags..] = else_args
pub val OP_CALL:          Op = 82;  # direct call (imm = symbol index, args = [arg0, arg1, ...])
pub val OP_CALL_INDIRECT: Op = 83;  # indirect call (args = [callee_ptr, arg0, arg1, ...])
pub val OP_RET:           Op = 84;  # return (args = [value] or empty for void)
pub val OP_UNREACHABLE:   Op = 85;  # trap / unreachable code

# function parameters
pub val OP_PARAM:         Op = 90;  # function parameter (imm = param index), defines a value

# atomics (args vary, flags = memory ordering)
pub val OP_ATOMIC_LOAD:   Op = 100; # atomic load (args: [ptr])
pub val OP_ATOMIC_STORE:  Op = 101; # atomic store (args: [ptr, value]), no result
pub val OP_ATOMIC_CAS:    Op = 102; # compare-and-swap (args: [ptr, expected, desired])
pub val OP_ATOMIC_RMW:    Op = 103; # read-modify-write (args: [ptr, value], imm = rmw_op)
pub val OP_FENCE:         Op = 104; # memory fence, no result

# memory orderings (stored in Inst.flags for atomics)
pub def MemOrder: u16;
pub val MO_RELAXED:       MemOrder = 0;
pub val MO_ACQUIRE:       MemOrder = 1;
pub val MO_RELEASE:       MemOrder = 2;
pub val MO_ACQ_REL:       MemOrder = 3;
pub val MO_SEQ_CST:       MemOrder = 4;

# atomic RMW operations (stored in Inst.imm for ATOMIC_RMW)
pub def RmwOp: u64;
pub val RMW_ADD:          RmwOp = 0;
pub val RMW_SUB:          RmwOp = 1;
pub val RMW_AND:          RmwOp = 2;
pub val RMW_OR:           RmwOp = 3;
pub val RMW_XOR:          RmwOp = 4;
pub val RMW_XCHG:         RmwOp = 5;

# special
pub val OP_SYSCALL:       Op = 110; # system call (args: [number, arg0..arg5])
pub val OP_ASM:           Op = 111; # inline assembly (imm = asm string index)

# variadic intrinsics
pub val OP_VA_START:      Op = 120; # initialize va_list (args: [va_list_ptr]), no result
pub val OP_VA_ARG:        Op = 121; # read next variadic arg (args: [va_list_ptr]), result = value

# returns true if the opcode is a block terminator
pub fun is_terminator(op: Op) bool {
    if (op == OP_BR)          { ret true; }
    if (op == OP_COND_BR)     { ret true; }
    if (op == OP_RET)         { ret true; }
    if (op == OP_UNREACHABLE) { ret true; }
    ret false;
}

# returns true if the opcode produces a result value
pub fun has_result(op: Op) bool {
    if (op == OP_STORE)        { ret false; }
    if (op == OP_COPY)         { ret false; }
    if (op == OP_BR)           { ret false; }
    if (op == OP_COND_BR)      { ret false; }
    if (op == OP_RET)          { ret false; }
    if (op == OP_UNREACHABLE)  { ret false; }
    if (op == OP_ATOMIC_STORE) { ret false; }
    if (op == OP_FENCE)        { ret false; }
    if (op == OP_VA_START)     { ret false; }
    ret true;
}

# returns the name of an opcode for debug printing
pub fun name(op: Op) str {
    if (op == OP_ICONST)        { ret "iconst"; }
    if (op == OP_FCONST)        { ret "fconst"; }
    if (op == OP_BCONST)        { ret "bconst"; }
    if (op == OP_NULLPTR)       { ret "nullptr"; }
    if (op == OP_GLOBAL_ADDR)   { ret "global_addr"; }
    if (op == OP_ADD)           { ret "add"; }
    if (op == OP_SUB)           { ret "sub"; }
    if (op == OP_MUL)           { ret "mul"; }
    if (op == OP_UDIV)          { ret "udiv"; }
    if (op == OP_SDIV)          { ret "sdiv"; }
    if (op == OP_UREM)          { ret "urem"; }
    if (op == OP_SREM)          { ret "srem"; }
    if (op == OP_FADD)          { ret "fadd"; }
    if (op == OP_FSUB)          { ret "fsub"; }
    if (op == OP_FMUL)          { ret "fmul"; }
    if (op == OP_FDIV)          { ret "fdiv"; }
    if (op == OP_NEG)           { ret "neg"; }
    if (op == OP_FNEG)          { ret "fneg"; }
    if (op == OP_NOT)           { ret "not"; }
    if (op == OP_LNOT)          { ret "lnot"; }
    if (op == OP_AND)           { ret "and"; }
    if (op == OP_OR)            { ret "or"; }
    if (op == OP_XOR)           { ret "xor"; }
    if (op == OP_SHL)           { ret "shl"; }
    if (op == OP_LSHR)          { ret "lshr"; }
    if (op == OP_ASHR)          { ret "ashr"; }
    if (op == OP_ICMP)          { ret "icmp"; }
    if (op == OP_FCMP)          { ret "fcmp"; }
    if (op == OP_LOAD)          { ret "load"; }
    if (op == OP_STORE)         { ret "store"; }
    if (op == OP_ALLOCA)        { ret "alloca"; }
    if (op == OP_FIELD_PTR)     { ret "field_ptr"; }
    if (op == OP_INDEX_PTR)     { ret "index_ptr"; }
    if (op == OP_COPY)          { ret "copy"; }
    if (op == OP_ZEXT)          { ret "zext"; }
    if (op == OP_SEXT)          { ret "sext"; }
    if (op == OP_TRUNC)         { ret "trunc"; }
    if (op == OP_ITOF)          { ret "itof"; }
    if (op == OP_FTOI)          { ret "ftoi"; }
    if (op == OP_FEXT)          { ret "fext"; }
    if (op == OP_FTRUNC)        { ret "ftrunc"; }
    if (op == OP_BITCAST)       { ret "bitcast"; }
    if (op == OP_PTR_TO_INT)    { ret "ptr_to_int"; }
    if (op == OP_INT_TO_PTR)    { ret "int_to_ptr"; }
    if (op == OP_BR)            { ret "br"; }
    if (op == OP_COND_BR)       { ret "cond_br"; }
    if (op == OP_CALL)          { ret "call"; }
    if (op == OP_CALL_INDIRECT) { ret "call_indirect"; }
    if (op == OP_RET)           { ret "ret"; }
    if (op == OP_UNREACHABLE)   { ret "unreachable"; }
    if (op == OP_PARAM)         { ret "param"; }
    if (op == OP_ATOMIC_LOAD)   { ret "atomic_load"; }
    if (op == OP_ATOMIC_STORE)  { ret "atomic_store"; }
    if (op == OP_ATOMIC_CAS)    { ret "atomic_cas"; }
    if (op == OP_ATOMIC_RMW)    { ret "atomic_rmw"; }
    if (op == OP_FENCE)         { ret "fence"; }
    if (op == OP_SYSCALL)       { ret "syscall"; }
    if (op == OP_ASM)           { ret "asm"; }
    if (op == OP_VA_START)      { ret "va_start"; }
    if (op == OP_VA_ARG)        { ret "va_arg"; }
    ret "unknown";
}

# returns the name of a condition code
pub fun cc_name(cc: CC) str {
    if (cc == CC_EQ)  { ret "eq"; }
    if (cc == CC_NE)  { ret "ne"; }
    if (cc == CC_SLT) { ret "slt"; }
    if (cc == CC_SLE) { ret "sle"; }
    if (cc == CC_SGT) { ret "sgt"; }
    if (cc == CC_SGE) { ret "sge"; }
    if (cc == CC_ULT) { ret "ult"; }
    if (cc == CC_ULE) { ret "ule"; }
    if (cc == CC_UGT) { ret "ugt"; }
    if (cc == CC_UGE) { ret "uge"; }
    ret "??";
}
