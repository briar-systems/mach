# mach.compiler.mir.opt.mem2reg: promote alloca+load+store to SSA values
#
# the standard mem2reg pass. identifies alloca instructions whose address
# is only used by loads and stores (not taken, not passed to calls, not
# used in field_ptr/index_ptr/copy). for those allocas, replaces loads
# with the reaching definition and stores with direct value flow. at
# control-flow join points, inserts block parameters (SSA phi equivalent).
#
# this eliminates the alloca vreg visibility problem: after mem2reg,
# promoted locals are direct SSA values that the regalloc can see and
# track through the entire function. only non-promotable allocas
# (address-taken, aggregates) keep the alloca+load+store pattern.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use type:      mach.compiler.sema.type;
use op:        mach.compiler.mir.op;
use ir:        mach.compiler.mir.ir;

val MAX_PROMOTABLE: u32 = 256;
val MAX_USES:       u32 = 256;

pub fun run(func: *ir.Function, alloc: *allocator.Allocator) bool {
    if (func == nil || func.block_count == 0 || func.inst_count == 0) { ret false; }

    val res_alloca_vals: Result[*ir.ValueId, str] = allocator.allocate[ir.ValueId](alloc, MAX_PROMOTABLE::usize);
    val res_alloca_tids: Result[*type.TypeId, str] = allocator.allocate[type.TypeId](alloc, MAX_PROMOTABLE::usize);
    val res_promotable: Result[*bool, str] = allocator.allocate[bool](alloc, MAX_PROMOTABLE::usize);
    if (is_err[*ir.ValueId, str](res_alloca_vals) || is_err[*type.TypeId, str](res_alloca_tids) ||
        is_err[*bool, str](res_promotable)) { ret false; }
    val alloca_vals: *ir.ValueId = unwrap_ok[*ir.ValueId, str](res_alloca_vals);
    val alloca_tids: *type.TypeId = unwrap_ok[*type.TypeId, str](res_alloca_tids);
    val promotable: *bool = unwrap_ok[*bool, str](res_promotable);
    var alloca_count: u32 = 0;

    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];
            if (inst.op == op.OP_ALLOCA && alloca_count < MAX_PROMOTABLE) {
                alloca_vals[alloca_count] = inst.result;
                alloca_tids[alloca_count] = type.TYPE_NIL;
                promotable[alloca_count] = true;
                alloca_count = alloca_count + 1;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    if (alloca_count == 0) {
        allocator.deallocate[ir.ValueId](alloc, alloca_vals, MAX_PROMOTABLE::usize);
        allocator.deallocate[type.TypeId](alloc, alloca_tids, MAX_PROMOTABLE::usize);
        allocator.deallocate[bool](alloc, promotable, MAX_PROMOTABLE::usize);
        ret false;
    }

    bi = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];
            var ai: u16 = 0;
            for (ai < inst.arg_count) {
                val arg: ir.ValueId = ir.inst_arg(func, inst, ai);
                var ci: u32 = 0;
                for (ci < alloca_count) {
                    if (arg::u32 == alloca_vals[ci]::u32 && promotable[ci]) {
                        if (inst.op == op.OP_LOAD && ai == 0) {
                            # ok: load from alloca
                        } or (inst.op == op.OP_STORE && ai == 0) {
                            # ok: store to alloca — record the stored type
                            if (inst.arg_count > 1) {
                                val stored: ir.ValueId = ir.inst_arg(func, inst, 1);
                                if (stored::u32 < func.value_count) {
                                    alloca_tids[ci] = func.values[stored::u32].type_id;
                                }
                            }
                        } or {
                            # any other use (copy, call arg, field_ptr, etc.) → not promotable
                            promotable[ci] = false;
                        }
                    }
                    ci = ci + 1;
                }
                ai = ai + 1;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    var changed: bool = false;

    val orig_value_count: u32 = func.value_count;
    val res_vmap: Result[*ir.ValueId, str] = allocator.allocate[ir.ValueId](alloc, func.value_count::usize);
    if (is_err[*ir.ValueId, str](res_vmap)) {
        allocator.deallocate[ir.ValueId](alloc, alloca_vals, MAX_PROMOTABLE::usize);
        allocator.deallocate[type.TypeId](alloc, alloca_tids, MAX_PROMOTABLE::usize);
        allocator.deallocate[bool](alloc, promotable, MAX_PROMOTABLE::usize);
        ret false;
    }
    val vmap: *ir.ValueId = unwrap_ok[*ir.ValueId, str](res_vmap);
    var vi: u32 = 0;
    for (vi < func.value_count) {
        vmap[vi] = vi::ir.ValueId;
        vi = vi + 1;
    }

    val res_dead: Result[*bool, str] = allocator.allocate[bool](alloc, func.inst_count::usize);
    if (is_err[*bool, str](res_dead)) {
        allocator.deallocate[ir.ValueId](alloc, vmap, func.value_count::usize);
        allocator.deallocate[ir.ValueId](alloc, alloca_vals, MAX_PROMOTABLE::usize);
        allocator.deallocate[type.TypeId](alloc, alloca_tids, MAX_PROMOTABLE::usize);
        allocator.deallocate[bool](alloc, promotable, MAX_PROMOTABLE::usize);
        ret false;
    }
    val dead: *bool = unwrap_ok[*bool, str](res_dead);
    var di: u32 = 0;
    for (di < func.inst_count) { dead[di] = false; di = di + 1; }

    var ci: u32 = 0;
    for (ci < alloca_count) {
        if (!promotable[ci]) { ci = ci + 1; cnt; }
        if (promote_single_block(func, alloca_vals[ci], vmap, dead)) {
            changed = true;
            promotable[ci] = false;
        }
        ci = ci + 1;
    }

    ci = 0;
    for (ci < alloca_count) {
        if (!promotable[ci]) { ci = ci + 1; cnt; }
        if (promote_single_store(func, alloca_vals[ci], vmap, dead)) {
            changed = true;
            promotable[ci] = false;
        }
        ci = ci + 1;
    }

    ci = 0;
    for (ci < alloca_count) {
        if (!promotable[ci]) { ci = ci + 1; cnt; }
        if (promote_multi_block(func, alloc, alloca_vals[ci], alloca_tids[ci], vmap, dead, orig_value_count)) {
            changed = true;
            promotable[ci] = false;
        }
        ci = ci + 1;
    }

    if (changed) {
        apply_vmap(func, vmap, orig_value_count);
        compact_blocks(func, dead);
    }

    allocator.deallocate[bool](alloc, dead, func.inst_count::usize);
    allocator.deallocate[ir.ValueId](alloc, vmap, orig_value_count::usize);
    allocator.deallocate[ir.ValueId](alloc, alloca_vals, MAX_PROMOTABLE::usize);
    allocator.deallocate[type.TypeId](alloc, alloca_tids, MAX_PROMOTABLE::usize);
    allocator.deallocate[bool](alloc, promotable, MAX_PROMOTABLE::usize);
    ret changed;
}

# promote_single_block: fast path for allocas used entirely within one block.
# walks the block linearly, replacing each load with the most recent store value.
# returns true if any loads were replaced.
fun promote_single_block(func: *ir.Function, alloca_val: ir.ValueId,
                          vmap: *ir.ValueId, dead: *bool) bool {
    var def_block: u32 = 0xFFFFFFFF;
    var all_same_block: bool = true;

    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];

            var uses_alloca: bool = false;
            if (inst.op == op.OP_ALLOCA && inst.result::u32 == alloca_val::u32) {
                uses_alloca = true;
            }
            if (inst.op == op.OP_LOAD || inst.op == op.OP_STORE) {
                if (inst.arg_count > 0 && ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
                    uses_alloca = true;
                }
            }

            if (uses_alloca) {
                if (def_block == 0xFFFFFFFF) {
                    def_block = bi;
                } or (def_block != bi) {
                    all_same_block = false;
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    if (!all_same_block || def_block == 0xFFFFFFFF) { ret false; }

    val block: *ir.Block = ?func.blocks[def_block];
    var reaching: ir.ValueId = ir.VALUE_NONE;
    var promoted: bool = false;

    var ii: u32 = 0;
    for (ii < block.inst_count) {
        val inst_id: ir.InstId = block.insts[ii];
        if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
        val inst: *ir.Inst = ?func.insts[inst_id::u32];

        if (inst.op == op.OP_ALLOCA && inst.result::u32 == alloca_val::u32) {
            dead[inst_id::u32] = true;
            promoted = true;
        }
        if (inst.op == op.OP_STORE && inst.arg_count > 0 &&
            ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
            if (inst.arg_count > 1) {
                reaching = ir.inst_arg(func, inst, 1);
            }
            dead[inst_id::u32] = true;
            promoted = true;
        }
        if (inst.op == op.OP_LOAD && inst.arg_count > 0 &&
            ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
            if (reaching::u32 != ir.VALUE_NONE::u32) {
                vmap[inst.result::u32] = reaching;
            }
            dead[inst_id::u32] = true;
            promoted = true;
        }

        ii = ii + 1;
    }

    ret promoted;
}

# promote_single_store: promote an alloca with exactly one store across blocks.
#
# for val declarations (immutable), there's exactly one store (the init).
# the stored value directly replaces all loads. no block parameters needed
# because the value is the same on all paths.
fun promote_single_store(func: *ir.Function, alloca_val: ir.ValueId,
                          vmap: *ir.ValueId, dead: *bool) bool {
    var store_count: u32 = 0;
    var stored_val: ir.ValueId = ir.VALUE_NONE;
    var alloca_inst: ir.InstId = ir.INST_NONE;
    var store_block: u32 = 0xFFFFFFFF;

    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];
            if (inst.op == op.OP_ALLOCA && inst.result::u32 == alloca_val::u32) {
                alloca_inst = inst_id;
            }
            if (inst.op == op.OP_STORE && !dead[inst_id::u32] && inst.arg_count > 0 &&
                ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
                store_count = store_count + 1;
                store_block = bi;
                if (inst.arg_count > 1) {
                    stored_val = ir.inst_arg(func, inst, 1);
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    # only promote if single store is in the entry block (dominates all loads)
    if (store_count != 1 || stored_val::u32 == ir.VALUE_NONE::u32 || store_block != 0) { ret false; }

    # resolve stored value through vmap (handles chained promotions)
    var depth: u32 = 0;
    for (stored_val::u32 < func.value_count && vmap[stored_val::u32]::u32 != stored_val::u32 && depth < 16) {
        stored_val = vmap[stored_val::u32];
        depth = depth + 1;
    }

    # verify the stored value's definition is still alive
    if (stored_val::u32 < func.value_count) {
        val sv: *ir.Value = ?func.values[stored_val::u32];
        if (sv.kind == ir.VK_INST && sv.def_inst::u32 < func.inst_count && dead[sv.def_inst::u32]) {
            ret false;
        }
    }


    var promoted: bool = false;
    bi = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];
            if (dead[inst_id::u32]) { ii = ii + 1; cnt; }
            if (inst.op == op.OP_ALLOCA && inst.result::u32 == alloca_val::u32) {
                dead[inst_id::u32] = true;
                promoted = true;
            }
            if (inst.op == op.OP_STORE && inst.arg_count > 0 &&
                ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
                dead[inst_id::u32] = true;
                promoted = true;
            }
            if (inst.op == op.OP_LOAD && inst.arg_count > 0 &&
                ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
                if (inst.result::u32 < func.value_count) {
                    vmap[inst.result::u32] = stored_val;
                }
                dead[inst_id::u32] = true;
                promoted = true;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    ret promoted;
}

val MAX_BLOCKS:     u32 = 512;
val MAX_PREDS:      u32 = 8;
val MAX_PRED_TOTAL: u32 = MAX_BLOCKS * MAX_PREDS;
val NONE_BLOCK:     u32 = 0xFFFFFFFF;

# promote_multi_block: promote an alloca used across multiple blocks using the
# iterated dominance frontier (IDF) algorithm (Cytron et al. 1991).
#
# 1. build predecessor lists from terminators
# 2. compute reverse postorder via iterative DFS
# 3. compute dominator tree via Cooper-Harvey-Kennedy iterative algorithm
# 4. compute dominance frontiers
# 5. compute IDF for the alloca's store blocks (phi placement)
# 6. insert block params at IDF blocks
# 7. rename in domtree preorder: replace loads, mark stores/allocas dead, add branch args
fun promote_multi_block(func: *ir.Function, alloc: *allocator.Allocator,
                         alloca_val: ir.ValueId, alloca_tid: type.TypeId,
                         vmap: *ir.ValueId, dead: *bool, vmap_size: u32) bool {
    val bc: u32 = func.block_count;
    if (bc == 0 || bc > MAX_BLOCKS) { ret false; }

    # resolve the promoted type: use alloca_tid if available, otherwise infer
    # from the type of a load result that uses this alloca.
    var tid: type.TypeId = alloca_tid;
    if (tid::u32 == type.TYPE_NIL::u32) {
        var bi: u32 = 0;
        for (bi < bc && tid::u32 == type.TYPE_NIL::u32) {
            val block: *ir.Block = ?func.blocks[bi];
            var ii: u32 = 0;
            for (ii < block.inst_count && tid::u32 == type.TYPE_NIL::u32) {
                val inst_id: ir.InstId = block.insts[ii];
                if (inst_id::u32 < func.inst_count) {
                    val inst: *ir.Inst = ?func.insts[inst_id::u32];
                    if (inst.op == op.OP_LOAD && inst.arg_count > 0 &&
                        ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
                        if (inst.result::u32 < func.value_count) {
                            tid = func.values[inst.result::u32].type_id;
                        }
                    }
                }
                ii = ii + 1;
            }
            bi = bi + 1;
        }
    }
    if (tid::u32 == type.TYPE_NIL::u32) { ret false; }

    # allocate working memory:
    #   pred_starts[bc]  - start index into pred_pool for each block
    #   pred_counts[bc]  - predecessor count per block
    #   pred_pool[bc*MAX_PREDS] - flat pred storage
    #   rpo[bc]          - reverse postorder permutation
    #   rpo_pos[bc]      - RPO position of each block
    #   idom[bc]         - immediate dominator (block index)
    #   df_starts[bc]    - start index into df_pool
    #   df_counts[bc]    - DF set size per block
    #   df_pool[bc*MAX_PREDS] - flat DF storage
    #   has_phi[bc]      - IDF result: block needs a block param
    #   param_vid[bc]    - ValueId of inserted block param
    #   def_stack[bc+1]  - reaching-def stack for rename
    #   children_start[bc] - domtree children list start
    #   children_count[bc] - domtree children count
    #   children_pool[bc]  - flat domtree children storage
    #   dfs_stack[bc]    - explicit DFS stack for rename traversal
    #   dfs_child[bc]    - child cursor per DFS frame

    val total_u32: usize = bc::usize * 14 + 1 + MAX_PRED_TOTAL::usize * 2;
    val res_mem: Result[*u32, str] = allocator.allocate[u32](alloc, total_u32);
    if (is_err[*u32, str](res_mem)) { ret false; }
    val mem: *u32 = unwrap_ok[*u32, str](res_mem);

    var off: usize = 0;
    val pred_starts:    *u32 = ?mem[off]; off = off + bc::usize;
    val pred_counts:    *u32 = ?mem[off]; off = off + bc::usize;
    val pred_pool:      *u32 = ?mem[off]; off = off + MAX_PRED_TOTAL::usize;
    val rpo:            *u32 = ?mem[off]; off = off + bc::usize;
    val rpo_pos:        *u32 = ?mem[off]; off = off + bc::usize;
    val idom:           *u32 = ?mem[off]; off = off + bc::usize;
    val df_starts:      *u32 = ?mem[off]; off = off + bc::usize;
    val df_counts:      *u32 = ?mem[off]; off = off + bc::usize;
    val df_pool:        *u32 = ?mem[off]; off = off + MAX_PRED_TOTAL::usize;
    val children_start: *u32 = ?mem[off]; off = off + bc::usize;
    val children_count: *u32 = ?mem[off]; off = off + bc::usize;
    val children_pool:  *u32 = ?mem[off]; off = off + bc::usize;
    val dfs_stack:      *u32 = ?mem[off]; off = off + bc::usize;
    val dfs_child:      *u32 = ?mem[off]; off = off + bc::usize;
    val def_stack:      *u32 = ?mem[off];

    val res_flags: Result[*bool, str] = allocator.allocate[bool](alloc, bc::usize * 2);
    if (is_err[*bool, str](res_flags)) {
        allocator.deallocate[u32](alloc, mem, total_u32);
        ret false;
    }
    val flags_mem: *bool = unwrap_ok[*bool, str](res_flags);
    val has_phi:  *bool = ?flags_mem[0];
    val visited:  *bool = ?flags_mem[bc::usize];

    val res_param_vid: Result[*ir.ValueId, str] = allocator.allocate[ir.ValueId](alloc, bc::usize);
    if (is_err[*ir.ValueId, str](res_param_vid)) {
        allocator.deallocate[bool](alloc, flags_mem, bc::usize * 2);
        allocator.deallocate[u32](alloc, mem, total_u32);
        ret false;
    }
    val param_vid: *ir.ValueId = unwrap_ok[*ir.ValueId, str](res_param_vid);

    var i: u32 = 0;
    for (i < bc) {
        pred_starts[i] = 0;
        pred_counts[i] = 0;
        rpo[i] = 0;
        rpo_pos[i] = NONE_BLOCK;
        idom[i] = NONE_BLOCK;
        df_starts[i] = 0;
        df_counts[i] = 0;
        has_phi[i] = false;
        visited[i] = false;
        param_vid[i] = ir.VALUE_NONE;
        children_start[i] = 0;
        children_count[i] = 0;
        children_pool[i] = 0;
        dfs_stack[i] = 0;
        dfs_child[i] = 0;
        i = i + 1;
    }
    def_stack[0] = ir.VALUE_NONE::u32;

    # step 1: build predecessor lists by scanning terminators
    var pred_total: u32 = 0;
    var bi: u32 = 0;
    for (bi < bc) {
        val block: *ir.Block = ?func.blocks[bi];
        if (block.inst_count == 0) { bi = bi + 1; cnt; }
        val last_id: ir.InstId = block.insts[block.inst_count - 1];
        if (last_id::u32 >= func.inst_count) { bi = bi + 1; cnt; }
        val last: *ir.Inst = ?func.insts[last_id::u32];
        if (last.target::u32 < bc) {
            val t: u32 = last.target::u32;
            if (pred_counts[t] < MAX_PREDS && pred_total < MAX_PRED_TOTAL) {
                pred_pool[pred_total] = bi;
                pred_total = pred_total + 1;
                pred_counts[t] = pred_counts[t] + 1;
            }
        }
        if (last.else_target::u32 < bc && last.else_target::u32 != last.target::u32) {
            val e: u32 = last.else_target::u32;
            if (pred_counts[e] < MAX_PREDS && pred_total < MAX_PRED_TOTAL) {
                pred_pool[pred_total] = bi;
                pred_total = pred_total + 1;
                pred_counts[e] = pred_counts[e] + 1;
            }
        }
        bi = bi + 1;
    }

    # compute pred_starts from pred_counts (exclusive prefix sum), then re-scatter
    var running: u32 = 0;
    bi = 0;
    for (bi < bc) {
        pred_starts[bi] = running;
        running = running + pred_counts[bi];
        pred_counts[bi] = 0;
        bi = bi + 1;
    }

    val res_pred_buf: Result[*u32, str] = allocator.allocate[u32](alloc, pred_total::usize + 1);
    if (is_err[*u32, str](res_pred_buf)) {
        allocator.deallocate[ir.ValueId](alloc, param_vid, bc::usize);
        allocator.deallocate[bool](alloc, flags_mem, bc::usize * 2);
        allocator.deallocate[u32](alloc, mem, total_u32);
        ret false;
    }
    val pred_buf: *u32 = unwrap_ok[*u32, str](res_pred_buf);

    bi = 0;
    for (bi < bc) {
        val block: *ir.Block = ?func.blocks[bi];
        if (block.inst_count == 0) { bi = bi + 1; cnt; }
        val last_id: ir.InstId = block.insts[block.inst_count - 1];
        if (last_id::u32 >= func.inst_count) { bi = bi + 1; cnt; }
        val last: *ir.Inst = ?func.insts[last_id::u32];
        if (last.target::u32 < bc) {
            val t: u32 = last.target::u32;
            if (pred_counts[t] < MAX_PREDS) {
                pred_buf[pred_starts[t] + pred_counts[t]] = bi;
                pred_counts[t] = pred_counts[t] + 1;
            }
        }
        if (last.else_target::u32 < bc && last.else_target::u32 != last.target::u32) {
            val e: u32 = last.else_target::u32;
            if (pred_counts[e] < MAX_PREDS) {
                pred_buf[pred_starts[e] + pred_counts[e]] = bi;
                pred_counts[e] = pred_counts[e] + 1;
            }
        }
        bi = bi + 1;
    }

    # step 2: reverse postorder via iterative DFS from block 0
    var rpo_count: u32 = 0;
    var dfs_top: u32 = 0;
    dfs_stack[0] = 0;
    dfs_child[0] = 0;
    visited[0] = true;
    dfs_top = 1;

    for (dfs_top > 0) {
        val cur: u32 = dfs_stack[dfs_top - 1];
        val cur_block: *ir.Block = ?func.blocks[cur];
        var pushed: bool = false;

        if (cur_block.inst_count > 0) {
            val lid: ir.InstId = cur_block.insts[cur_block.inst_count - 1];
            if (lid::u32 < func.inst_count) {
                val linst: *ir.Inst = ?func.insts[lid::u32];
                var succ_idx: u32 = dfs_child[dfs_top - 1];
                for (succ_idx < 2 && !pushed) {
                    var s: u32 = NONE_BLOCK;
                    if (succ_idx == 0 && linst.target::u32 < bc) { s = linst.target::u32; }
                    if (succ_idx == 1 && linst.else_target::u32 < bc &&
                        linst.else_target::u32 != linst.target::u32) {
                        s = linst.else_target::u32;
                    }
                    succ_idx = succ_idx + 1;
                    dfs_child[dfs_top - 1] = succ_idx;
                    if (s != NONE_BLOCK && !visited[s]) {
                        visited[s] = true;
                        dfs_stack[dfs_top] = s;
                        dfs_child[dfs_top] = 0;
                        dfs_top = dfs_top + 1;
                        pushed = true;
                    }
                }
            }
        }

        if (!pushed) {
            rpo[rpo_count] = cur;
            rpo_count = rpo_count + 1;
            dfs_top = dfs_top - 1;
        }
    }

    # rpo[] is in reverse-postorder-reversed (postorder). reverse it in place.
    var lo: u32 = 0;
    var hi: u32 = rpo_count;
    if (hi > 0) { hi = hi - 1; }
    for (lo < hi) {
        val tmp: u32 = rpo[lo];
        rpo[lo] = rpo[hi];
        rpo[hi] = tmp;
        lo = lo + 1;
        hi = hi - 1;
    }

    bi = 0;
    for (bi < rpo_count) {
        rpo_pos[rpo[bi]] = bi;
        bi = bi + 1;
    }

    # step 3: dominator tree — Cooper-Harvey-Kennedy iterative algorithm
    # "A Simple, Fast Dominance Algorithm" (2001)
    idom[rpo[0]] = rpo[0];

    var dom_changed: bool = true;
    for (dom_changed) {
        dom_changed = false;
        var ri: u32 = 1;
        for (ri < rpo_count) {
            val b: u32 = rpo[ri];
            var new_idom: u32 = NONE_BLOCK;
            var pi: u32 = 0;
            for (pi < pred_counts[b]) {
                val p: u32 = pred_buf[pred_starts[b] + pi];
                if (idom[p] != NONE_BLOCK) {
                    if (new_idom == NONE_BLOCK) {
                        new_idom = p;
                    } or {
                        new_idom = intersect_dom(rpo_pos, idom, new_idom, p);
                    }
                }
                pi = pi + 1;
            }
            if (new_idom != NONE_BLOCK && idom[b] != new_idom) {
                idom[b] = new_idom;
                dom_changed = true;
            }
            ri = ri + 1;
        }
    }

    # step 4: dominance frontiers
    # DF(b) = { y : exists pred p of y such that b dominates p but does not strictly dominate y }
    compute_dom_frontiers(func, bc, pred_buf, pred_starts, pred_counts,
                          idom, rpo_pos, df_pool, df_starts, df_counts);

    # step 5: IDF computation — seed worklist with store blocks, propagate through DF
    # reuse dfs_stack as worklist
    var wl_size: u32 = 0;
    bi = 0;
    for (bi < bc) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        var is_store_block: bool = false;
        for (ii < block.inst_count && !is_store_block) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 < func.inst_count) {
                val inst: *ir.Inst = ?func.insts[inst_id::u32];
                if (inst.op == op.OP_STORE && inst.arg_count > 0 &&
                    ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
                    is_store_block = true;
                }
            }
            ii = ii + 1;
        }
        if (is_store_block && wl_size < bc) {
            dfs_stack[wl_size] = bi;
            wl_size = wl_size + 1;
        }
        bi = bi + 1;
    }

    # also seed block 0 into the worklist if the alloca is defined there
    # (block 0 provides the implicit "undef" initial definition)
    var has_alloca_in_entry: bool = false;
    if (bc > 0) {
        val entry: *ir.Block = ?func.blocks[0];
        var ii: u32 = 0;
        for (ii < entry.inst_count) {
            val inst_id: ir.InstId = entry.insts[ii];
            if (inst_id::u32 < func.inst_count) {
                val inst: *ir.Inst = ?func.insts[inst_id::u32];
                if (inst.op == op.OP_ALLOCA && inst.result::u32 == alloca_val::u32) {
                    has_alloca_in_entry = true;
                }
            }
            ii = ii + 1;
        }
    }
    if (has_alloca_in_entry) {
        var already: bool = false;
        var wi: u32 = 0;
        for (wi < wl_size) {
            if (dfs_stack[wi] == 0) { already = true; }
            wi = wi + 1;
        }
        if (!already && wl_size < bc) {
            dfs_stack[wl_size] = 0;
            wl_size = wl_size + 1;
        }
    }

    var wl_head: u32 = 0;
    for (wl_head < wl_size) {
        val d: u32 = dfs_stack[wl_head];
        wl_head = wl_head + 1;
        var di: u32 = 0;
        for (di < df_counts[d]) {
            val y: u32 = df_pool[df_starts[d] + di];
            if (!has_phi[y]) {
                has_phi[y] = true;
                if (wl_size < bc) {
                    dfs_stack[wl_size] = y;
                    wl_size = wl_size + 1;
                }
            }
            di = di + 1;
        }
    }

    # don't place a phi in the entry block — it has no predecessors
    has_phi[0] = false;

    # step 6: insert block params at IDF blocks
    bi = 0;
    for (bi < bc) {
        if (has_phi[bi]) {
            val vid: ir.ValueId = add_block_param(func, alloc, bi::ir.BlockId, tid);
            if (vid::u32 != ir.VALUE_NONE::u32) {
                param_vid[bi] = vid;
            } or {
                has_phi[bi] = false;
            }
        }
        bi = bi + 1;
    }

    # step 7: rename — walk domtree in preorder using reaching-def stack
    # build domtree children lists from idom[]
    bi = 0;
    for (bi < bc) { children_count[bi] = 0; bi = bi + 1; }
    bi = 0;
    for (bi < bc) {
        if (idom[bi] != NONE_BLOCK && idom[bi] != bi) {
            children_count[idom[bi]] = children_count[idom[bi]] + 1;
        }
        bi = bi + 1;
    }

    running = 0;
    bi = 0;
    for (bi < bc) {
        children_start[bi] = running;
        running = running + children_count[bi];
        children_count[bi] = 0;
        bi = bi + 1;
    }

    # scatter children into children_pool
    bi = 0;
    for (bi < bc) {
        if (idom[bi] != NONE_BLOCK && idom[bi] != bi) {
            val parent: u32 = idom[bi];
            children_pool[children_start[parent] + children_count[parent]] = bi;
            children_count[parent] = children_count[parent] + 1;
        }
        bi = bi + 1;
    }

    val undef_val: ir.ValueId = make_zero_const(func, alloc, tid);

    var promoted: bool = false;
    var stack_top: u32 = 1;
    def_stack[0] = undef_val::u32;

    # iterative preorder DFS over domtree
    # the standard Cytron rename: for each block, process instructions (push
    # stores, replace loads), then add branch args to successor phis using the
    # current top of the reaching-def stack. recurse into domtree children.
    # on backtrack, restore the stack to its entry height.
    dfs_top = 0;
    dfs_stack[0] = rpo[0];
    dfs_child[0] = 0;
    dfs_top = 1;

    val frame_base: *u32 = pred_pool;
    frame_base[0] = stack_top;

    # process root block
    val root: u32 = rpo[0];
    if (rename_block(func, root, alloca_val, has_phi, param_vid,
                     vmap, dead, vmap_size, def_stack, ?stack_top)) {
        promoted = true;
    }
    add_successor_args(func, alloc, root, bc, has_phi,
                       def_stack[stack_top - 1]::ir.ValueId);

    for (dfs_top > 0) {
        val frame: u32 = dfs_top - 1;
        val cur: u32 = dfs_stack[frame];
        val child_idx: u32 = dfs_child[frame];

        if (child_idx < children_count[cur]) {
            dfs_child[frame] = child_idx + 1;
            val child: u32 = children_pool[children_start[cur] + child_idx];

            dfs_stack[dfs_top] = child;
            dfs_child[dfs_top] = 0;
            frame_base[dfs_top] = stack_top;
            dfs_top = dfs_top + 1;

            if (rename_block(func, child, alloca_val, has_phi, param_vid,
                             vmap, dead, vmap_size, def_stack, ?stack_top)) {
                promoted = true;
            }
            add_successor_args(func, alloc, child, bc, has_phi,
                               def_stack[stack_top - 1]::ir.ValueId);
        } or {
            stack_top = frame_base[frame];
            dfs_top = dfs_top - 1;
        }
    }

    allocator.deallocate[u32](alloc, pred_buf, pred_total::usize + 1);
    allocator.deallocate[ir.ValueId](alloc, param_vid, bc::usize);
    allocator.deallocate[bool](alloc, flags_mem, bc::usize * 2);
    allocator.deallocate[u32](alloc, mem, total_u32);
    ret promoted;
}

# intersect_dom: find the common dominator of two blocks using RPO numbering.
# this is the "intersect" helper from Cooper-Harvey-Kennedy.
fun intersect_dom(rpo_pos: *u32, idom: *u32, b1: u32, b2: u32) u32 {
    var f1: u32 = b1;
    var f2: u32 = b2;
    for (f1 != f2) {
        for (rpo_pos[f1] > rpo_pos[f2]) { f1 = idom[f1]; }
        for (rpo_pos[f2] > rpo_pos[f1]) { f2 = idom[f2]; }
    }
    ret f1;
}

# compute_dom_frontiers: compute DF sets from scratch using the standard algorithm.
# for each block y with >= 2 predecessors, walk each predecessor p up to idom[y],
# adding y to DF(runner) at each step.
fun compute_dom_frontiers(func: *ir.Function, bc: u32,
                           pred_buf: *u32, pred_starts: *u32, pred_counts: *u32,
                           idom: *u32, rpo_pos: *u32,
                           df_pool: *u32, df_starts: *u32, df_counts: *u32) {
    var bi: u32 = 0;
    for (bi < bc) {
        df_counts[bi] = 0;
        bi = bi + 1;
    }

    # first pass: count DF entries per block
    bi = 0;
    for (bi < bc) {
        if (pred_counts[bi] >= 2) {
            var pi: u32 = 0;
            for (pi < pred_counts[bi]) {
                var runner: u32 = pred_buf[pred_starts[bi] + pi];
                for (runner != NONE_BLOCK && runner != idom[bi]) {
                    df_counts[runner] = df_counts[runner] + 1;
                    runner = idom[runner];
                }
                pi = pi + 1;
            }
        }
        bi = bi + 1;
    }

    # prefix sum for df_starts
    var running: u32 = 0;
    bi = 0;
    for (bi < bc) {
        df_starts[bi] = running;
        running = running + df_counts[bi];
        df_counts[bi] = 0;
        bi = bi + 1;
    }

    # second pass: scatter DF entries (may include duplicates)
    bi = 0;
    for (bi < bc) {
        if (pred_counts[bi] >= 2) {
            var pi: u32 = 0;
            for (pi < pred_counts[bi]) {
                var runner: u32 = pred_buf[pred_starts[bi] + pi];
                for (runner != NONE_BLOCK && runner != idom[bi]) {
                    df_pool[df_starts[runner] + df_counts[runner]] = bi;
                    df_counts[runner] = df_counts[runner] + 1;
                    runner = idom[runner];
                }
                pi = pi + 1;
            }
        }
        bi = bi + 1;
    }

    # third pass: deduplicate each block's DF set in place
    bi = 0;
    for (bi < bc) {
        if (df_counts[bi] > 1) {
            val start: u32 = df_starts[bi];
            var write: u32 = 0;
            var ri: u32 = 0;
            for (ri < df_counts[bi]) {
                val v: u32 = df_pool[start + ri];
                var dup: bool = false;
                var wi: u32 = 0;
                for (wi < write) {
                    if (df_pool[start + wi] == v) { dup = true; }
                    wi = wi + 1;
                }
                if (!dup) {
                    df_pool[start + write] = v;
                    write = write + 1;
                }
                ri = ri + 1;
            }
            df_counts[bi] = write;
        }
        bi = bi + 1;
    }
}

# rename_block: process a single block during the Cytron rename traversal.
# pushes phis and stores onto the reaching-def stack, replaces loads with the
# current reaching def. returns true if any instruction was promoted.
# loads are only marked dead when a valid reaching def exists.
fun rename_block(func: *ir.Function, block_idx: u32,
                  alloca_val: ir.ValueId,
                  has_phi: *bool, param_vid: *ir.ValueId,
                  vmap: *ir.ValueId, dead: *bool, vmap_size: u32,
                  def_stack: *u32, stack_top: *u32) bool {
    val block: *ir.Block = ?func.blocks[block_idx];
    var did_promote: bool = false;

    if (has_phi[block_idx] && param_vid[block_idx]::u32 != ir.VALUE_NONE::u32) {
        val st: u32 = @stack_top;
        def_stack[st] = param_vid[block_idx]::u32;
        @stack_top = st + 1;
    }

    var ii: u32 = 0;
    for (ii < block.inst_count) {
        val inst_id: ir.InstId = block.insts[ii];
        if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
        val inst: *ir.Inst = ?func.insts[inst_id::u32];

        if (inst.op == op.OP_ALLOCA && inst.result::u32 == alloca_val::u32) {
            dead[inst_id::u32] = true;
            did_promote = true;
        }
        if (inst.op == op.OP_STORE && inst.arg_count > 0 &&
            ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
            if (inst.arg_count > 1) {
                val stored: ir.ValueId = ir.inst_arg(func, inst, 1);
                val st: u32 = @stack_top;
                def_stack[st] = stored::u32;
                @stack_top = st + 1;
            }
            dead[inst_id::u32] = true;
            did_promote = true;
        }
        if (inst.op == op.OP_LOAD && inst.arg_count > 0 &&
            ir.inst_arg(func, inst, 0)::u32 == alloca_val::u32) {
            val st: u32 = @stack_top;
            if (st > 0) {
                val reaching: ir.ValueId = def_stack[st - 1]::ir.ValueId;
                if (reaching::u32 != ir.VALUE_NONE::u32 &&
                    inst.result::u32 < vmap_size) {
                    vmap[inst.result::u32] = reaching;
                    dead[inst_id::u32] = true;
                    did_promote = true;
                }
            }
        }

        ii = ii + 1;
    }

    ret did_promote;
}

# add_successor_args: after processing a block during rename, pass the current
# reaching def as a branch argument to any successor block that has a phi.
# this is called immediately after rename_block, so the reaching def on top
# of the def_stack is the correct exit value for this block.
fun add_successor_args(func: *ir.Function, alloc: *allocator.Allocator,
                        block_idx: u32, bc: u32,
                        has_phi: *bool, reaching: ir.ValueId) {
    val block: *ir.Block = ?func.blocks[block_idx];
    if (block.inst_count == 0) { ret; }
    val last_id: ir.InstId = block.insts[block.inst_count - 1];
    if (last_id::u32 >= func.inst_count) { ret; }
    val last: *ir.Inst = ?func.insts[last_id::u32];

    if (last.op == op.OP_BR && last.target::u32 < bc) {
        if (has_phi[last.target::u32]) {
            add_branch_arg(func, alloc, last, reaching);
        }
    }
    if (last.op == op.OP_COND_BR) {
        val add_then: bool = last.target::u32 < bc && has_phi[last.target::u32];
        val add_else: bool = last.else_target::u32 < bc && has_phi[last.else_target::u32];
        if (add_then || add_else) {
            add_cond_br_args(func, alloc, last, reaching, add_then, add_else);
        }
    }
}

# add_block_param: add a block parameter directly on the Function (not via builder)
fun add_block_param(func: *ir.Function, alloc: *allocator.Allocator,
                     block_id: ir.BlockId, tid: type.TypeId) ir.ValueId {
    if (block_id::u32 >= func.block_count) { ret ir.VALUE_NONE; }
    val block: *ir.Block = ?func.blocks[block_id::u32];

    if (block.param_count >= block.param_cap) {
        var new_cap: u32 = block.param_cap * 2;
        if (block.param_cap == 0) { new_cap = 4; }
        val res: Result[*ir.BlockParam, str] = allocator.reallocate[ir.BlockParam](
            alloc, block.params, block.param_cap::usize, new_cap::usize);
        if (is_err[*ir.BlockParam, str](res)) { ret ir.VALUE_NONE; }
        block.params = unwrap_ok[*ir.BlockParam, str](res);
        block.param_cap = new_cap;
    }

    # allocate a new value
    if (func.value_count >= func.value_cap) {
        var new_cap: u32 = func.value_cap * 2;
        if (func.value_cap == 0) { new_cap = 64; }
        val res: Result[*ir.Value, str] = allocator.reallocate[ir.Value](
            alloc, func.values, func.value_cap::usize, new_cap::usize);
        if (is_err[*ir.Value, str](res)) { ret ir.VALUE_NONE; }
        func.values = unwrap_ok[*ir.Value, str](res);
        func.value_cap = new_cap;
    }
    val vid: ir.ValueId = func.value_count::ir.ValueId;
    var psz: u8 = 8;
    if (func.types != nil) {
        val pt: *type.Type = type.get(func.types, tid);
        if (pt != nil && pt.size > 0 && pt.size <= 255) { psz = pt.size::u8; }
    }
    func.values[func.value_count].kind = ir.VK_BLOCK_PARAM;
    func.values[func.value_count].type_id = tid;
    func.values[func.value_count].def_inst = ir.INST_NONE;
    func.values[func.value_count].block = block_id;
    func.values[func.value_count].param_idx = block.param_count::u16;
    func.values[func.value_count].size = psz;
    func.value_count = func.value_count + 1;

    block.params[block.param_count].value = vid;
    block.params[block.param_count].type_id = tid;
    block.param_count = block.param_count + 1;
    ret vid;
}

# make_zero_const: create an ICONST 0 instruction in the entry block and return
# its ValueId. used as the initial reaching definition for uninitialized paths
# so that branch args are always valid value IDs (never VALUE_NONE).
fun make_zero_const(func: *ir.Function, alloc: *allocator.Allocator,
                     tid: type.TypeId) ir.ValueId {
    if (func.inst_count >= func.inst_cap) {
        var new_cap: u32 = func.inst_cap * 2;
        if (func.inst_cap == 0) { new_cap = 64; }
        val res: Result[*ir.Inst, str] = allocator.reallocate[ir.Inst](
            alloc, func.insts, func.inst_cap::usize, new_cap::usize);
        if (is_err[*ir.Inst, str](res)) { ret ir.VALUE_NONE; }
        func.insts = unwrap_ok[*ir.Inst, str](res);
        func.inst_cap = new_cap;
    }
    if (func.value_count >= func.value_cap) {
        var new_cap: u32 = func.value_cap * 2;
        if (func.value_cap == 0) { new_cap = 64; }
        val res: Result[*ir.Value, str] = allocator.reallocate[ir.Value](
            alloc, func.values, func.value_cap::usize, new_cap::usize);
        if (is_err[*ir.Value, str](res)) { ret ir.VALUE_NONE; }
        func.values = unwrap_ok[*ir.Value, str](res);
        func.value_cap = new_cap;
    }

    val iid: ir.InstId = func.inst_count::ir.InstId;
    val vid: ir.ValueId = func.value_count::ir.ValueId;

    var psz: u8 = 8;
    if (func.types != nil) {
        val pt: *type.Type = type.get(func.types, tid);
        if (pt != nil && pt.size > 0 && pt.size <= 255) { psz = pt.size::u8; }
    }

    func.insts[func.inst_count].op = op.OP_ICONST;
    func.insts[func.inst_count].flags = 0;
    func.insts[func.inst_count].result = vid;
    func.insts[func.inst_count].type_id = tid;
    func.insts[func.inst_count].arg_start = 0;
    func.insts[func.inst_count].arg_count = 0;
    func.insts[func.inst_count].target = ir.BLOCK_NONE;
    func.insts[func.inst_count].else_target = ir.BLOCK_NONE;
    func.insts[func.inst_count].imm = 0;
    func.inst_count = func.inst_count + 1;

    func.values[func.value_count].kind = ir.VK_INST;
    func.values[func.value_count].type_id = tid;
    func.values[func.value_count].def_inst = iid;
    func.values[func.value_count].block = 0::ir.BlockId;
    func.values[func.value_count].param_idx = 0;
    func.values[func.value_count].size = psz;
    func.value_count = func.value_count + 1;

    val entry: *ir.Block = ?func.blocks[0];
    if (entry.inst_count >= entry.inst_cap) {
        var new_cap: u32 = entry.inst_cap * 2;
        if (entry.inst_cap == 0) { new_cap = 16; }
        val res: Result[*ir.InstId, str] = allocator.reallocate[ir.InstId](
            alloc, entry.insts, entry.inst_cap::usize, new_cap::usize);
        if (is_err[*ir.InstId, str](res)) { ret vid; }
        entry.insts = unwrap_ok[*ir.InstId, str](res);
        entry.inst_cap = new_cap;
    }
    var si: u32 = entry.inst_count;
    for (si > 0) {
        entry.insts[si] = entry.insts[si - 1];
        si = si - 1;
    }
    entry.insts[0] = iid;
    entry.inst_count = entry.inst_count + 1;

    ret vid;
}

# grow the args pool and append a value
fun push_arg(func: *ir.Function, alloc: *allocator.Allocator, val_: ir.ValueId) u32 {
    if (func.arg_count >= func.arg_cap) {
        var new_cap: u32 = func.arg_cap * 2;
        if (func.arg_cap == 0) { new_cap = 64; }
        val res: Result[*ir.ValueId, str] = allocator.reallocate[ir.ValueId](
            alloc, func.args, func.arg_cap::usize, new_cap::usize);
        if (is_err[*ir.ValueId, str](res)) { ret 0xFFFFFFFF; }
        func.args = unwrap_ok[*ir.ValueId, str](res);
        func.arg_cap = new_cap;
    }
    val pos: u32 = func.arg_count;
    func.args[pos] = val_;
    func.arg_count = pos + 1;
    ret pos;
}

# add_branch_arg: append one arg to a BR instruction's arg list
fun add_branch_arg(func: *ir.Function, alloc: *allocator.Allocator,
                    inst: *ir.Inst, val_: ir.ValueId) {
    if (inst.op != op.OP_BR) { ret; }
    # copy existing args + new arg to end of pool
    val new_start: u32 = func.arg_count;
    var i: u16 = 0;
    for (i < inst.arg_count) {
        push_arg(func, alloc, ir.inst_arg(func, inst, i));
        i = i + 1;
    }
    push_arg(func, alloc, val_);
    inst.arg_start = new_start;
    inst.arg_count = inst.arg_count + 1;
}

# add_cond_br_args: atomically append args to cond_br then/else targets.
# handles the case where both targets need params without stale flags.
fun add_cond_br_args(func: *ir.Function, alloc: *allocator.Allocator,
                      inst: *ir.Inst, val_: ir.ValueId,
                      add_then: bool, add_else: bool) {
    if (inst.op != op.OP_COND_BR) { ret; }
    val then_count: u16 = inst.flags;
    val total: u16 = inst.arg_count;
    val else_count: u16 = total - 1 - then_count;

    val new_start: u32 = func.arg_count;
    push_arg(func, alloc, ir.inst_arg(func, inst, 0));

    var i: u16 = 0;
    for (i < then_count) {
        push_arg(func, alloc, ir.inst_arg(func, inst, 1 + i));
        i = i + 1;
    }
    if (add_then) { push_arg(func, alloc, val_); }

    i = 0;
    for (i < else_count) {
        push_arg(func, alloc, ir.inst_arg(func, inst, 1 + then_count + i));
        i = i + 1;
    }
    if (add_else) { push_arg(func, alloc, val_); }

    var added: u16 = 0;
    if (add_then) { added = added + 1; }
    if (add_else) { added = added + 1; }

    inst.arg_start = new_start;
    inst.arg_count = total + added;
    if (add_then) { inst.flags = then_count + 1; }
}

# apply_vmap: replace all value references using the replacement map.
# resolves transitive chains first (A→B, B→C becomes A→C).
fun apply_vmap(func: *ir.Function, vmap: *ir.ValueId, vmap_size: u32) {
    var ri: u32 = 0;
    for (ri < vmap_size) {
        var v: ir.ValueId = vmap[ri];
        var depth: u32 = 0;
        for (v::u32 < vmap_size && vmap[v::u32]::u32 != v::u32 && depth < 256) {
            v = vmap[v::u32];
            depth = depth + 1;
        }
        vmap[ri] = v;
        ri = ri + 1;
    }

    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];
            var ai: u32 = 0;
            for (ai < inst.arg_count::u32) {
                val pos: u32 = inst.arg_start + ai;
                if (pos < func.arg_count) {
                    val old: ir.ValueId = func.args[pos];
                    if (old::u32 < vmap_size && vmap[old::u32]::u32 != old::u32) {
                        func.args[pos] = vmap[old::u32];
                    }
                }
                ai = ai + 1;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
}

# compact_blocks: remove dead instructions from each block's inst list.
fun compact_blocks(func: *ir.Function, dead: *bool) {
    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        var write: u32 = 0;
        var read: u32 = 0;
        for (read < block.inst_count) {
            val inst_id: ir.InstId = block.insts[read];
            if (inst_id::u32 < func.inst_count && !dead[inst_id::u32]) {
                block.insts[write] = inst_id;
                write = write + 1;
            }
            read = read + 1;
        }
        block.inst_count = write;
        bi = bi + 1;
    }
}
