# mach.compiler.mir.opt.pass: MIR optimization pass manager
#
# runs a sequence of optimization passes on MIR functions. each pass
# returns true if it made changes. the pipeline re-runs all passes in
# a fixed-point loop until no pass reports changes, or a maximum
# iteration count is reached.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use ir: mach.compiler.mir.ir;

pub def PassFn: fun(*ir.Function, *allocator.Allocator) bool;

val MAX_ITERATIONS: u32 = 16;

pub rec PassPipeline {
    alloc:  *allocator.Allocator;
    passes: *PassFn;
    count:  u32;
    cap:    u32;
}

pub fun init(alloc: *allocator.Allocator) PassPipeline {
    var pp: PassPipeline;
    pp.alloc  = alloc;
    pp.passes = nil;
    pp.count  = 0;
    pp.cap    = 0;
    ret pp;
}

pub fun add(pp: *PassPipeline, pass: PassFn) {
    if (pp.count >= pp.cap) {
        var new_cap: u32 = 8;
        if (pp.cap > 0) { new_cap = pp.cap * 2; }
        val res: Result[*PassFn, str] = allocator.reallocate[PassFn](
            pp.alloc, pp.passes, pp.cap::usize, new_cap::usize);
        if (is_err[*PassFn, str](res)) { ret; }
        pp.passes = unwrap_ok[*PassFn, str](res);
        pp.cap = new_cap;
    }
    pp.passes[pp.count] = pass;
    pp.count = pp.count + 1;
}

pub fun run(pp: *PassPipeline, func: *ir.Function) {
    if (pp.count == 0 || func == nil) { ret; }

    var iteration: u32 = 0;
    var changed: bool = true;
    for (changed && iteration < MAX_ITERATIONS) {
        changed = false;
        var i: u32 = 0;
        for (i < pp.count) {
            val pass_fn: PassFn = pp.passes[i];
            if (pass_fn(func, pp.alloc)) {
                changed = true;
            }
            i = i + 1;
        }
        iteration = iteration + 1;
    }
}

pub fun run_module(pp: *PassPipeline, module: *ir.Module) {
    if (module == nil) { ret; }
    var fi: u32 = 0;
    for (fi < module.func_count) {
        run(pp, ?module.functions[fi]);
        fi = fi + 1;
    }
}

pub fun dnit(pp: *PassPipeline) {
    if (pp.passes != nil && pp.cap > 0) {
        allocator.deallocate[PassFn](pp.alloc, pp.passes, pp.cap::usize);
        pp.passes = nil;
    }
    pp.count = 0;
    pp.cap   = 0;
}
