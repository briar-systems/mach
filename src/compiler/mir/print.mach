# mach.compiler.mir.print: debug printer for MIR
#
# dumps MIR modules, functions, and instructions in a human-readable
# SSA format. output goes to stderr to avoid mixing with program output.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use print:  std.print;
use fmt:    std.format;
use writer: std.io.writer;
use type:   mach.compiler.sema.type;
use op:     mach.compiler.mir.op;
use ir:     mach.compiler.mir.ir;

# print a complete MIR module
pub fun dump_module(module: *ir.Module) {
    if (module == nil) {
        print.eprintln("(nil module)");
        ret;
    }

    var gi: u32 = 0;
    for (gi < module.glob_count) {
        dump_global(?module.globals[gi], module.types);
        gi = gi + 1;
    }

    var fi: u32 = 0;
    for (fi < module.func_count) {
        dump_function(?module.functions[fi], module.types);
        print.eprintln("");
        fi = fi + 1;
    }
}

# print a global data declaration
pub fun dump_global(glob: *ir.Global, types: *type.TypeTable) {
    if (glob.is_const) {
        print.eprintf("global const @%s : ", glob.name);
    } or {
        print.eprintf("global var @%s : ", glob.name);
    }
    print_type_name(types, glob.type_id);
    print.eprintf(" [%u bytes, align %u]", glob.size::u64, glob.align::u64);
    if (glob.data != nil) {
        print.eprint(" = <initialized>");
    } or {
        print.eprint(" = zeroinit");
    }
    print.eprintln("");
}

# print a complete function
pub fun dump_function(func: *ir.Function, types: *type.TypeTable) {
    if (func == nil) {
        print.eprintln("(nil function)");
        ret;
    }

    print.eprintf("fun @%s(", func.name);

    var pi: u32 = 0;
    for (pi < func.param_count) {
        if (pi > 0) { print.eprint(", "); }
        print_type_name(types, func.params[pi]);
        pi = pi + 1;
    }

    if (func.is_variadic) {
        if (func.param_count > 0) { print.eprint(", "); }
        print.eprint("...");
    }

    print.eprint(") -> ");
    print_type_name(types, func.ret_type);
    print.eprintln(" {");

    var bi: u32 = 0;
    for (bi < func.block_count) {
        dump_block(func, ?func.blocks[bi], types);
        bi = bi + 1;
    }

    print.eprintln("}");
}

# print a basic block with its parameters and instructions
fun dump_block(func: *ir.Function, block: *ir.Block, types: *type.TypeTable) {
    print.eprintf("  %s(", block.name);

    var pi: u32 = 0;
    for (pi < block.param_count) {
        if (pi > 0) { print.eprint(", "); }
        val bp: *ir.BlockParam = ?block.params[pi];
        print_value(bp.value);
        print.eprint(": ");
        print_type_name(types, bp.type_id);
        pi = pi + 1;
    }

    print.eprintln("):");

    var ii: u32 = 0;
    for (ii < block.inst_count) {
        val inst_id: ir.InstId = block.insts[ii];
        if (inst_id::u32 < func.inst_count) {
            dump_inst(func, ?func.insts[inst_id::u32], types);
        }
        ii = ii + 1;
    }
}

# print a single instruction
fun dump_inst(func: *ir.Function, inst: *ir.Inst, types: *type.TypeTable) {
    print.eprint("    ");

    if (inst.result::u32 != ir.VALUE_NONE::u32) {
        print_value(inst.result);
        print.eprint(" = ");
    }

    print.eprint(op.name(inst.op));

    print_inst_flags(inst);

    if (op.has_result(inst.op)) {
        print.eprint(" ");
        print_type_name(types, inst.type_id);
    }

    print_inst_operands(func, inst, types);

    print.eprintln("");
}

# print opcode-specific flags
fun print_inst_flags(inst: *ir.Inst) {
    if (inst.op == op.OP_ICMP || inst.op == op.OP_FCMP) {
        print.eprintf(".%s", op.cc_name(inst.flags::op.CC));
    }

    if (inst.op == op.OP_ATOMIC_LOAD || inst.op == op.OP_ATOMIC_STORE ||
        inst.op == op.OP_ATOMIC_CAS || inst.op == op.OP_ATOMIC_RMW ||
        inst.op == op.OP_FENCE) {
        print_mem_order(inst.flags::op.MemOrder);
    }
}

# print instruction operands based on opcode
fun print_inst_operands(func: *ir.Function, inst: *ir.Inst, types: *type.TypeTable) {
    if (inst.op == op.OP_ICONST) {
        print.eprintf(" %u", inst.imm);
        ret;
    }
    if (inst.op == op.OP_FCONST) {
        print.eprintf(" 0x%x", inst.imm);
        ret;
    }
    if (inst.op == op.OP_BCONST) {
        if (inst.imm != 0) { print.eprint(" true"); } or { print.eprint(" false"); }
        ret;
    }
    if (inst.op == op.OP_NULLPTR) { ret; }

    if (inst.op == op.OP_GLOBAL_ADDR) {
        print.eprintf(" @sym%u", inst.imm);
        ret;
    }

    if (inst.op == op.OP_PARAM) {
        print.eprintf(" $%u", inst.imm);
        ret;
    }

    if (inst.op == op.OP_FIELD_PTR) {
        print_value_args(func, inst);
        print.eprintf(", field %u", inst.imm);
        ret;
    }

    if (inst.op == op.OP_ALLOCA) {
        print.eprintf(" %u, align %u", inst.imm, inst.flags::u64);
        ret;
    }

    if (inst.op == op.OP_COPY) {
        print_value_args(func, inst);
        print.eprintf(", %u bytes", inst.imm);
        ret;
    }

    if (inst.op == op.OP_BR) {
        print.eprintf(" %s", block_name(func, inst.target));
        print_branch_args(func, inst, 0, inst.arg_count);
        ret;
    }

    if (inst.op == op.OP_COND_BR) {
        if (inst.arg_count > 0) {
            print.eprint(" ");
            print_value(ir.inst_arg(func, inst, 0));
        }
        val then_count: u16 = inst.flags;
        val else_count: u16 = inst.arg_count - 1 - then_count;
        print.eprintf(", %s", block_name(func, inst.target));
        print_branch_args(func, inst, 1, then_count);
        print.eprintf(", %s", block_name(func, inst.else_target));
        print_branch_args(func, inst, 1 + then_count, else_count);
        ret;
    }

    if (inst.op == op.OP_CALL) {
        print.eprintf(" @sym%u", inst.imm);
        print_call_args(func, inst, 0);
        ret;
    }

    if (inst.op == op.OP_CALL_INDIRECT) {
        if (inst.arg_count > 0) {
            print.eprint(" ");
            print_value(ir.inst_arg(func, inst, 0));
        }
        print_call_args(func, inst, 1);
        ret;
    }

    if (inst.op == op.OP_RET) {
        if (inst.arg_count > 0) {
            print.eprint(" ");
            print_value(ir.inst_arg(func, inst, 0));
        }
        ret;
    }

    print_value_args(func, inst);
}

# print value arguments as a comma-separated list
fun print_value_args(func: *ir.Function, inst: *ir.Inst) {
    var ai: u16 = 0;
    for (ai < inst.arg_count) {
        if (ai == 0) { print.eprint(" "); } or { print.eprint(", "); }
        print_value(ir.inst_arg(func, inst, ai));
        ai = ai + 1;
    }
}

# print call arguments in parentheses (starting from offset)
fun print_call_args(func: *ir.Function, inst: *ir.Inst, start: u16) {
    print.eprint("(");
    var ai: u16 = start;
    for (ai < inst.arg_count) {
        if (ai > start) { print.eprint(", "); }
        print_value(ir.inst_arg(func, inst, ai));
        ai = ai + 1;
    }
    print.eprint(")");
}

# print branch block arguments in parentheses
fun print_branch_args(func: *ir.Function, inst: *ir.Inst, start: u16, count: u16) {
    if (count == 0) { ret; }
    print.eprint("(");
    var ai: u16 = 0;
    for (ai < count) {
        if (ai > 0) { print.eprint(", "); }
        print_value(ir.inst_arg(func, inst, start + ai));
        ai = ai + 1;
    }
    print.eprint(")");
}

# print a value reference (%N)
fun print_value(v: ir.ValueId) {
    if (v::u32 == ir.VALUE_NONE::u32) {
        print.eprint("_");
    } or {
        print.eprintf("%%%u", v::u64);
    }
}

# print a type name from the sema type table
fun print_type_name(types: *type.TypeTable, tid: type.TypeId) {
    if (types == nil || tid::u32 == type.TYPE_NIL::u32) {
        print.eprint("???");
        ret;
    }
    if (tid::u32 >= types.count) {
        print.eprintf("type<%u>", tid::u64);
        ret;
    }
    val t: *type.Type = ?types.types[tid::u32];
    if (t.name != nil) {
        print.eprintf("%s", t.name);
    } or {
        print.eprintf("type<%u>", tid::u64);
    }
}

# print a memory ordering
fun print_mem_order(mo: op.MemOrder) {
    if (mo == op.MO_RELAXED) { print.eprint(".relaxed"); }
    if (mo == op.MO_ACQUIRE) { print.eprint(".acquire"); }
    if (mo == op.MO_RELEASE) { print.eprint(".release"); }
    if (mo == op.MO_ACQ_REL) { print.eprint(".acq_rel"); }
    if (mo == op.MO_SEQ_CST) { print.eprint(".seq_cst"); }
}

# get block name for printing (returns the block's label or a generated name)
fun block_name(func: *ir.Function, bid: ir.BlockId) str {
    if (bid::u32 == ir.BLOCK_NONE::u32) { ret "???"; }
    if (bid::u32 >= func.block_count) { ret "???"; }
    val b: *ir.Block = ?func.blocks[bid::u32];
    if (b.name != nil) { ret b.name; }
    ret "block";
}

pub fun write_module(w: *writer.Writer, module: *ir.Module) {
    if (module == nil) { fmt.format(w, "(nil module)\n"); ret; }

    var gi: u32 = 0;
    for (gi < module.glob_count) {
        write_global(w, ?module.globals[gi], module.types);
        gi = gi + 1;
    }

    var fi: u32 = 0;
    for (fi < module.func_count) {
        write_function(w, ?module.functions[fi], module.types);
        fmt.format(w, "\n");
        fi = fi + 1;
    }
}

fun write_global(w: *writer.Writer, glob: *ir.Global, types: *type.TypeTable) {
    if (glob.is_const) {
        fmt.format(w, "global const @%s : ", glob.name);
    } or {
        fmt.format(w, "global var @%s : ", glob.name);
    }
    write_type_name(w, types, glob.type_id);
    fmt.format(w, " [%u bytes, align %u]", glob.size::u64, glob.align::u64);
    if (glob.data != nil) {
        fmt.format(w, " = <initialized>");
    } or {
        fmt.format(w, " = zeroinit");
    }
    fmt.format(w, "\n");
}

fun write_function(w: *writer.Writer, func: *ir.Function, types: *type.TypeTable) {
    if (func == nil) { fmt.format(w, "(nil function)\n"); ret; }

    fmt.format(w, "fun @%s(", func.name);
    var pi: u32 = 0;
    for (pi < func.param_count) {
        if (pi > 0) { fmt.format(w, ", "); }
        write_type_name(w, types, func.params[pi]);
        pi = pi + 1;
    }
    if (func.is_variadic) {
        if (func.param_count > 0) { fmt.format(w, ", "); }
        fmt.format(w, "...");
    }
    fmt.format(w, ") -> ");
    write_type_name(w, types, func.ret_type);
    fmt.format(w, " {\n");

    var bi: u32 = 0;
    for (bi < func.block_count) {
        write_block(w, func, ?func.blocks[bi], types);
        bi = bi + 1;
    }
    fmt.format(w, "}\n");
}

fun write_block(w: *writer.Writer, func: *ir.Function, block: *ir.Block, types: *type.TypeTable) {
    fmt.format(w, "  %s(", block.name);
    var pi: u32 = 0;
    for (pi < block.param_count) {
        if (pi > 0) { fmt.format(w, ", "); }
        val bp: *ir.BlockParam = ?block.params[pi];
        write_value(w, bp.value);
        fmt.format(w, ": ");
        write_type_name(w, types, bp.type_id);
        pi = pi + 1;
    }
    fmt.format(w, "):\n");

    var ii: u32 = 0;
    for (ii < block.inst_count) {
        val inst_id: ir.InstId = block.insts[ii];
        if (inst_id::u32 < func.inst_count) {
            write_inst(w, func, ?func.insts[inst_id::u32], types);
        }
        ii = ii + 1;
    }
}

fun write_inst(w: *writer.Writer, func: *ir.Function, inst: *ir.Inst, types: *type.TypeTable) {
    fmt.format(w, "    ");
    if (inst.result::u32 != ir.VALUE_NONE::u32) {
        write_value(w, inst.result);
        fmt.format(w, " = ");
    }
    fmt.format(w, "%s", op.name(inst.op));
    write_inst_flags_w(w, inst);
    if (op.has_result(inst.op)) {
        fmt.format(w, " ");
        write_type_name(w, types, inst.type_id);
    }
    write_inst_operands_w(w, func, inst, types);
    fmt.format(w, "\n");
}

fun write_inst_flags_w(w: *writer.Writer, inst: *ir.Inst) {
    if (inst.op == op.OP_ICMP || inst.op == op.OP_FCMP) {
        fmt.format(w, ".%s", op.cc_name(inst.flags::op.CC));
    }
}

fun write_inst_operands_w(w: *writer.Writer, func: *ir.Function, inst: *ir.Inst, types: *type.TypeTable) {
    if (inst.op == op.OP_ICONST) { fmt.format(w, " %u", inst.imm); ret; }
    if (inst.op == op.OP_FCONST) { fmt.format(w, " 0x%x", inst.imm); ret; }
    if (inst.op == op.OP_BCONST) {
        if (inst.imm != 0) { fmt.format(w, " true"); } or { fmt.format(w, " false"); }
        ret;
    }
    if (inst.op == op.OP_NULLPTR) { ret; }
    if (inst.op == op.OP_GLOBAL_ADDR) { fmt.format(w, " @sym%u", inst.imm); ret; }
    if (inst.op == op.OP_PARAM) { fmt.format(w, " $%u", inst.imm); ret; }
    if (inst.op == op.OP_FIELD_PTR) {
        write_value_args_w(w, func, inst);
        fmt.format(w, ", field %u", inst.imm);
        ret;
    }
    if (inst.op == op.OP_ALLOCA) { fmt.format(w, " %u, align %u", inst.imm, inst.flags::u64); ret; }
    if (inst.op == op.OP_COPY) {
        write_value_args_w(w, func, inst);
        fmt.format(w, ", %u bytes", inst.imm);
        ret;
    }
    if (inst.op == op.OP_BR) {
        fmt.format(w, " %s", block_name(func, inst.target));
        write_branch_args_w(w, func, inst, 0, inst.arg_count);
        ret;
    }
    if (inst.op == op.OP_COND_BR) {
        if (inst.arg_count > 0) { fmt.format(w, " "); write_value(w, ir.inst_arg(func, inst, 0)); }
        val then_count: u16 = inst.flags;
        val else_count: u16 = inst.arg_count - 1 - then_count;
        fmt.format(w, ", %s", block_name(func, inst.target));
        write_branch_args_w(w, func, inst, 1, then_count);
        fmt.format(w, ", %s", block_name(func, inst.else_target));
        write_branch_args_w(w, func, inst, 1 + then_count, else_count);
        ret;
    }
    if (inst.op == op.OP_CALL) {
        fmt.format(w, " @sym%u", inst.imm);
        write_call_args_w(w, func, inst, 0);
        ret;
    }
    if (inst.op == op.OP_CALL_INDIRECT) {
        if (inst.arg_count > 0) { fmt.format(w, " "); write_value(w, ir.inst_arg(func, inst, 0)); }
        write_call_args_w(w, func, inst, 1);
        ret;
    }
    if (inst.op == op.OP_RET) {
        if (inst.arg_count > 0) { fmt.format(w, " "); write_value(w, ir.inst_arg(func, inst, 0)); }
        ret;
    }
    write_value_args_w(w, func, inst);
}

fun write_value(w: *writer.Writer, v: ir.ValueId) {
    if (v::u32 == ir.VALUE_NONE::u32) { fmt.format(w, "_"); }
    or { fmt.format(w, "%%%u", v::u64); }
}

fun write_type_name(w: *writer.Writer, types: *type.TypeTable, tid: type.TypeId) {
    if (types == nil || tid::u32 == type.TYPE_NIL::u32) { fmt.format(w, "???"); ret; }
    if (tid::u32 >= types.count) { fmt.format(w, "type<%u>", tid::u64); ret; }
    val t: *type.Type = ?types.types[tid::u32];
    if (t.name != nil) { fmt.format(w, "%s", t.name); }
    or { fmt.format(w, "type<%u>", tid::u64); }
}

fun write_value_args_w(w: *writer.Writer, func: *ir.Function, inst: *ir.Inst) {
    var ai: u16 = 0;
    for (ai < inst.arg_count) {
        if (ai == 0) { fmt.format(w, " "); } or { fmt.format(w, ", "); }
        write_value(w, ir.inst_arg(func, inst, ai));
        ai = ai + 1;
    }
}

fun write_call_args_w(w: *writer.Writer, func: *ir.Function, inst: *ir.Inst, start: u16) {
    fmt.format(w, "(");
    var ai: u16 = start;
    for (ai < inst.arg_count) {
        if (ai > start) { fmt.format(w, ", "); }
        write_value(w, ir.inst_arg(func, inst, ai));
        ai = ai + 1;
    }
    fmt.format(w, ")");
}

fun write_branch_args_w(w: *writer.Writer, func: *ir.Function, inst: *ir.Inst, start: u16, count: u16) {
    if (count == 0) { ret; }
    fmt.format(w, "(");
    var ai: u16 = 0;
    for (ai < count) {
        if (ai > 0) { fmt.format(w, ", "); }
        write_value(w, ir.inst_arg(func, inst, start + ai));
        ai = ai + 1;
    }
    fmt.format(w, ")");
}
