# mach.compiler.mir.print: MIR text format printer
#
# produces human-readable, parseable SSA text from MIR modules.
# when buf is nil, output goes to stderr. when buf is provided,
# output is written to the buffer for file emission.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use print: std.print;
use iobuf: std.io.buffer;
use type:  mach.compiler.sema.type;
use op:    mach.compiler.mir.op;
use ir:    mach.compiler.mir.ir;

fun w(buf: *iobuf.WriteBuf, s: str) {
    if (buf != nil) {
        iobuf.wbuf_write_bytes(buf, s::*u8, str_len(s));
    } or {
        print.eprint(s);
    }
}

fun wu(buf: *iobuf.WriteBuf, v: u64) {
    if (buf != nil) {
        var tmp: [32]u8;
        var i: usize = 30;
        var n: u64 = v;
        if (n == 0) { tmp[30] = 0x30; i = 29; }
        or { for (n > 0) { tmp[i] = (n % 10)::u8 + 0x30; n = n / 10; i = i - 1; } }
        iobuf.wbuf_write_bytes(buf, ((?tmp[0])::usize + i + 1)::*u8, 30 - i);
    } or {
        print.eprintf("%u", v);
    }
}

fun wi(buf: *iobuf.WriteBuf, v: i64) {
    if (v < 0) {
        w(buf, "-");
        wu(buf, (0 - v)::u64);
    } or {
        wu(buf, v::u64);
    }
}

fun wln(buf: *iobuf.WriteBuf) {
    w(buf, "\n");
}

fun whex(buf: *iobuf.WriteBuf, data: *u8, len: u32) {
    val hex: str = "0123456789abcdef";
    var hi: u32 = 0;
    for (hi < len) {
        if (hi > 0 && (hi & 15) == 0) { w(buf, "\n                     "); }
        or (hi > 0) { w(buf, " "); }
        val b: u8 = data[hi];
        var pair: [2]u8;
        pair[0] = hex[(b >> 4)::usize];
        pair[1] = hex[(b & 0x0F)::usize];
        if (buf != nil) {
            iobuf.wbuf_write_bytes(buf, ?pair[0], 2);
        } or {
            print.eprintf("%c%c", pair[0]::u64, pair[1]::u64);
        }
        hi = hi + 1;
    }
}

pub fun dump_module(module: *ir.Module) {
    dump_module_buf(module, nil);
}

pub fun dump_module_buf(module: *ir.Module, buf: *iobuf.WriteBuf) {
    if (module == nil) {
        w(buf, "; (nil module)\n");
        ret;
    }

    var gi: u32 = 0;
    for (gi < module.glob_count) {
        dump_global_buf(?module.globals[gi], buf);
        gi = gi + 1;
    }
    if (module.glob_count > 0) { wln(buf); }

    var si: u32 = 0;
    for (si < module.sym_count) {
        w(buf, "declare @");
        if (module.symbols[si].name != nil) { w(buf, module.symbols[si].name); }
        or { w(buf, "???"); }
        if (module.symbols[si].is_extern) { w(buf, " extern"); }
        wln(buf);
        si = si + 1;
    }
    if (module.sym_count > 0) { wln(buf); }

    var fi: u32 = 0;
    for (fi < module.func_count) {
        dump_function_buf_mod(?module.functions[fi], module, buf);
        wln(buf);
        fi = fi + 1;
    }
}

fun dump_global_buf(glob: *ir.Global, buf: *iobuf.WriteBuf) {
    if (glob.is_const) { w(buf, "const @"); }
    or { w(buf, "var @"); }
    if (glob.name != nil) { w(buf, glob.name); }
    or { w(buf, "???"); }
    w(buf, " : [");
    wu(buf, glob.size::u64);
    w(buf, " x i8], align ");
    wu(buf, glob.align::u64);
    if (glob.data != nil && glob.data_len > 0) {
        w(buf, " = { ");
        whex(buf, glob.data, glob.data_len);
        w(buf, " }");
    } or {
        w(buf, " = zeroinit");
    }
    wln(buf);
}

fun dump_function_buf(func: *ir.Function, buf: *iobuf.WriteBuf) {
    dump_function_buf_mod(func, nil, buf);
}

fun dump_function_buf_mod(func: *ir.Function, module: *ir.Module, buf: *iobuf.WriteBuf) {
    if (func == nil) {
        w(buf, "; (nil function)\n");
        ret;
    }

    w(buf, "define ");
    if (func.name != nil) { w(buf, func.name); }
    or { w(buf, "<anon>"); }
    w(buf, "(");
    var pi: u32 = 0;
    for (pi < func.param_count) {
        if (pi > 0) { w(buf, ", "); }
        w(buf, "p");
        wu(buf, pi::u64);
        pi = pi + 1;
    }
    w(buf, ")");
    if (func.is_variadic) { w(buf, " variadic"); }
    w(buf, " {");
    wln(buf);

    var bi: u32 = 0;
    for (bi < func.block_count) {
        val block: *ir.Block = ?func.blocks[bi];
        if (bi > 0) { wln(buf); }
        w(buf, "  ");
        if (block.name != nil) { w(buf, block.name); }
        or { w(buf, "bb"); wu(buf, bi::u64); }
        if (block.param_count > 0) {
            w(buf, "(");
            var bpi: u32 = 0;
            for (bpi < block.param_count) {
                if (bpi > 0) { w(buf, ", "); }
                w(buf, "%");
                wu(buf, block.params[bpi].value::u64);
                bpi = bpi + 1;
            }
            w(buf, ")");
        }
        w(buf, ":");
        wln(buf);

        var ii: u32 = 0;
        for (ii < block.inst_count) {
            val inst_id: ir.InstId = block.insts[ii];
            if (inst_id::u32 >= func.inst_count) { ii = ii + 1; cnt; }
            val inst: *ir.Inst = ?func.insts[inst_id::u32];
            dump_inst_buf(func, inst, module, buf);
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    w(buf, "}");
    wln(buf);
}

fun write_block_ref(func: *ir.Function, bid: ir.BlockId, buf: *iobuf.WriteBuf) {
    if (bid::u32 < func.block_count && func.blocks[bid::u32].name != nil) {
        w(buf, func.blocks[bid::u32].name);
    } or {
        w(buf, "bb");
        wu(buf, bid::u64);
    }
}

fun dump_inst_buf(func: *ir.Function, inst: *ir.Inst, module: *ir.Module, buf: *iobuf.WriteBuf) {
    w(buf, "    ");
    if (inst.result::u32 != ir.VALUE_NONE::u32) {
        w(buf, "%");
        wu(buf, inst.result::u64);
        w(buf, " = ");
    }
    w(buf, op.name(inst.op));

    if (inst.op == op.OP_CALL || inst.op == op.OP_CALL_INDIRECT) {
        val sym_idx: u32 = inst.imm::u32;
        if (module != nil && sym_idx < module.sym_count && module.symbols[sym_idx].name != nil) {
            w(buf, " @");
            w(buf, module.symbols[sym_idx].name);
        } or {
            w(buf, " @sym(");
            wu(buf, inst.imm);
            w(buf, ")");
        }
    }

    if (inst.op == op.OP_ICONST || inst.op == op.OP_FCONST) {
        w(buf, " ");
        wu(buf, inst.imm);
    }
    if (inst.op == op.OP_ALLOCA) {
        w(buf, " ");
        wu(buf, inst.imm);
        w(buf, ", align ");
        wu(buf, inst.flags::u64);
    }

    if (inst.op == op.OP_ICMP || inst.op == op.OP_FCMP) {
        w(buf, " ");
        w(buf, op.cc_name(inst.flags::op.CC));
    }

    if (inst.arg_count > 0) {
        w(buf, " ");
        var ai: u16 = 0;
        for (ai < inst.arg_count) {
            if (ai > 0) { w(buf, ", "); }
            val arg: ir.ValueId = ir.inst_arg(func, inst, ai);
            w(buf, "%");
            wu(buf, arg::u64);
            ai = ai + 1;
        }
    }

    if (inst.op == op.OP_FIELD_PTR || inst.op == op.OP_INDEX_PTR) {
        if (inst.imm != 0) {
            w(buf, ", offset ");
            wu(buf, inst.imm);
        }
    }

    if (inst.op == op.OP_COPY) {
        w(buf, ", bytes ");
        wu(buf, inst.imm);
    }

    if (inst.op == op.OP_BR && inst.target::u32 != ir.BLOCK_NONE::u32) {
        w(buf, " ");
        write_block_ref(func, inst.target, buf);
        if (inst.arg_count > 0) {
            w(buf, "(");
            var bai: u16 = 0;
            for (bai < inst.arg_count) {
                if (bai > 0) { w(buf, ", "); }
                w(buf, "%");
                wu(buf, ir.inst_arg(func, inst, bai)::u64);
                bai = bai + 1;
            }
            w(buf, ")");
        }
    } or (inst.op == op.OP_COND_BR) {
        if (inst.target::u32 != ir.BLOCK_NONE::u32) {
            w(buf, ", ");
            write_block_ref(func, inst.target, buf);
        }
        if (inst.else_target::u32 != ir.BLOCK_NONE::u32) {
            w(buf, ", ");
            write_block_ref(func, inst.else_target, buf);
        }
    } or {
        if (inst.target::u32 != ir.BLOCK_NONE::u32) {
            w(buf, ", ");
            write_block_ref(func, inst.target, buf);
        }
        if (inst.else_target::u32 != ir.BLOCK_NONE::u32) {
            w(buf, ", ");
            write_block_ref(func, inst.else_target, buf);
        }
    }

    wln(buf);
}
