use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use di:        mach.compiler.di;
use of:        mach.compiler.of;

# mach.compiler.di.dwarf: DWARF v4 debug information implementation.
# ---
# produces three ELF sections:
#   .debug_abbrev — fixed abbreviation table (CU + subprogram tags)
#   .debug_info   — compilation unit DIE + subprogram DIEs
#   .debug_line   — line number program (file/line → address mapping)
#
# follows the DebugInfo interface from mach.compiler.di.

# --- DWARF constants ---

# tags
val DW_TAG_compile_unit: u8 = 0x11;
val DW_TAG_subprogram:   u8 = 0x2e;

# attributes
val DW_AT_name:      u8 = 0x03;
val DW_AT_stmt_list: u8 = 0x10;
val DW_AT_low_pc:    u8 = 0x11;
val DW_AT_high_pc:   u8 = 0x12;
val DW_AT_language:  u8 = 0x13;
val DW_AT_producer:  u8 = 0x25;
val DW_AT_comp_dir:  u8 = 0x1b;
val DW_AT_decl_file: u8 = 0x3a;
val DW_AT_decl_line: u8 = 0x3b;

# forms
val DW_FORM_addr:       u8 = 0x01;
val DW_FORM_data2:      u8 = 0x05;
val DW_FORM_data4:      u8 = 0x06;
val DW_FORM_string:     u8 = 0x08;
val DW_FORM_data1:      u8 = 0x0b;
val DW_FORM_sec_offset: u8 = 0x17;

# children
val DW_CHILDREN_yes: u8 = 1;
val DW_CHILDREN_no:  u8 = 0;

# language
val DW_LANG_lo_user: u16 = 0x8000;

# line number program opcodes
val DW_LNS_copy:             u8 = 1;
val DW_LNS_advance_pc:       u8 = 2;
val DW_LNS_advance_line:     u8 = 3;
val DW_LNS_set_file:         u8 = 4;
val DW_LNS_set_column:       u8 = 5;
val DW_LNS_negate_stmt:      u8 = 6;

# extended opcodes
val DW_LNE_end_sequence:     u8 = 1;
val DW_LNE_set_address:      u8 = 2;

# initial capacities
val INITIAL_FILE_CAP:   i32 = 16;
val INITIAL_SUB_CAP:    i32 = 256;
val INITIAL_LINE_CAP:   i32 = 1024;
val MAX_DEBUG_SECTIONS:  i32 = 3;

# --- internal records ---

rec DWARFFile {
    path: str;
    dir:  str;
}

rec DWARFContext {
    alloc:     *allocator.Allocator;
    ptr_size:  usize;
    endian:    u8;

    files:     *DWARFFile;
    file_count: i32;
    file_cap:   i32;

    subs:      *di.DISubprogram;
    sub_count: i32;
    sub_cap:   i32;

    lines:     *di.DILineEntry;
    line_count: i32;
    line_cap:   i32;

    # finalized output
    sections:   [3]di.DebugSection;
    sec_count:  i32;

    # per-.o file index mapping (set by read_line, used by read_info)
    last_file_map:       *u16;
    last_file_map_count: i32;

    # serialized buffers
    abbrev_buf: of.OutputBuffer;
    info_buf:   of.OutputBuffer;
    line_buf:   of.OutputBuffer;
}

# create: construct a DWARF v4 DebugInfo implementation.
# ptr_size: target pointer size in bytes (4 or 8).
# endian: target endianness (ENDIAN_LITTLE or ENDIAN_BIG).
pub fun create(alloc: *allocator.Allocator, ptr_size: usize, endian: u8) Result[di.DebugInfo, str] {
    if (alloc == nil) {
        ret err[di.DebugInfo, str]("allocator is nil");
    }

    val ctx_r: Result[*DWARFContext, allocator.AllocError] =
        allocator.allocator_zalloc[DWARFContext](alloc, 1);
    if (result_is_err[*DWARFContext, allocator.AllocError](ctx_r)) {
        ret err[di.DebugInfo, str]("out of memory");
    }
    val ctx: *DWARFContext =
        result_unwrap_ok[*DWARFContext, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;
    ctx.ptr_size = ptr_size;
    ctx.endian = endian;

    # pre-allocate arrays
    val fr: Result[*DWARFFile, allocator.AllocError] =
        allocator.allocator_zalloc[DWARFFile](alloc, INITIAL_FILE_CAP::usize);
    if (result_is_err[*DWARFFile, allocator.AllocError](fr)) {
        ret err[di.DebugInfo, str]("out of memory");
    }
    ctx.files = result_unwrap_ok[*DWARFFile, allocator.AllocError](fr);
    ctx.file_cap = INITIAL_FILE_CAP;

    val sr: Result[*di.DISubprogram, allocator.AllocError] =
        allocator.allocator_zalloc[di.DISubprogram](alloc, INITIAL_SUB_CAP::usize);
    if (result_is_err[*di.DISubprogram, allocator.AllocError](sr)) {
        ret err[di.DebugInfo, str]("out of memory");
    }
    ctx.subs = result_unwrap_ok[*di.DISubprogram, allocator.AllocError](sr);
    ctx.sub_cap = INITIAL_SUB_CAP;

    val lr: Result[*di.DILineEntry, allocator.AllocError] =
        allocator.allocator_zalloc[di.DILineEntry](alloc, INITIAL_LINE_CAP::usize);
    if (result_is_err[*di.DILineEntry, allocator.AllocError](lr)) {
        ret err[di.DebugInfo, str]("out of memory");
    }
    ctx.lines = result_unwrap_ok[*di.DILineEntry, allocator.AllocError](lr);
    ctx.line_cap = INITIAL_LINE_CAP;

    var d: di.DebugInfo;
    d.ctx = ctx::ptr;
    d.add_file = dwarf_add_file;
    d.add_subprogram = dwarf_add_subprogram;
    d.add_line = dwarf_add_line;
    d.read_info = dwarf_read_info;
    d.read_line = dwarf_read_line;
    d.finalize = dwarf_finalize;
    d.get_sections = dwarf_get_sections;
    d.destroy = dwarf_destroy;

    ret ok[di.DebugInfo, str](d);
}

# --- interface implementations ---

fun dwarf_add_file(ctx: ptr, path: str, dir: str) u16 {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || path == nil) { ret 0; }

    # deduplicate
    var i: i32 = 0;
    for (i < d.file_count) {
        if (d.files[i].path != nil && str_equals(d.files[i].path, path)) {
            ret (i + 1)::u16;
        }
        i = i + 1;
    }

    # grow if needed
    if (d.file_count >= d.file_cap) {
        val new_cap: i32 = d.file_cap * 2;
        val r: Result[*DWARFFile, allocator.AllocError] =
            allocator.allocator_resize[DWARFFile](d.alloc, d.files,
                d.file_cap::usize, new_cap::usize);
        if (result_is_err[*DWARFFile, allocator.AllocError](r)) { ret 0; }
        d.files = result_unwrap_ok[*DWARFFile, allocator.AllocError](r);
        d.file_cap = new_cap;
    }

    val idx: i32 = d.file_count;
    d.files[idx].path = path;
    d.files[idx].dir = dir;
    d.file_count = d.file_count + 1;
    ret (idx + 1)::u16;
}

fun dwarf_add_subprogram(ctx: ptr, sub: *di.DISubprogram) {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || sub == nil) { ret; }

    # grow if needed
    if (d.sub_count >= d.sub_cap) {
        val new_cap: i32 = d.sub_cap * 2;
        val r: Result[*di.DISubprogram, allocator.AllocError] =
            allocator.allocator_resize[di.DISubprogram](d.alloc, d.subs,
                d.sub_cap::usize, new_cap::usize);
        if (result_is_err[*di.DISubprogram, allocator.AllocError](r)) { ret; }
        d.subs = result_unwrap_ok[*di.DISubprogram, allocator.AllocError](r);
        d.sub_cap = new_cap;
    }

    val idx: i32 = d.sub_count;
    d.subs[idx].name = sub.name;
    d.subs[idx].file_idx = sub.file_idx;
    d.subs[idx].line = sub.line;
    d.subs[idx].low_pc = sub.low_pc;
    d.subs[idx].high_pc = sub.high_pc;
    d.sub_count = d.sub_count + 1;
}

fun dwarf_add_line(ctx: ptr, entry: *di.DILineEntry) {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || entry == nil) { ret; }

    # grow if needed
    if (d.line_count >= d.line_cap) {
        val new_cap: i32 = d.line_cap * 2;
        val r: Result[*di.DILineEntry, allocator.AllocError] =
            allocator.allocator_resize[di.DILineEntry](d.alloc, d.lines,
                d.line_cap::usize, new_cap::usize);
        if (result_is_err[*di.DILineEntry, allocator.AllocError](r)) { ret; }
        d.lines = result_unwrap_ok[*di.DILineEntry, allocator.AllocError](r);
        d.line_cap = new_cap;
    }

    val idx: i32 = d.line_count;
    d.lines[idx].address = entry.address;
    d.lines[idx].file_idx = entry.file_idx;
    d.lines[idx].line = entry.line;
    d.line_count = d.line_count + 1;
}

# --- .debug_info reader ---
#
# parses a .debug_info section produced by our DWARF emitter.
# extracts subprogram entries (abbrev code 2) with adjusted addresses.
# format (known because we control the emitter):
#   [unit header: 4B length, 2B version, 4B abbrev_off, 1B addr_size]
#   [CU DIE (abbrev 1): producer string, language u16, name string,
#    comp_dir string, low_pc addr, high_pc addr, stmt_list u32]
#   [subprogram DIEs (abbrev 2): name string, file_idx u16,
#    line u32, low_pc addr, high_pc addr]*
#   [0 terminator]

fun dwarf_read_info(ctx: ptr, data: *u8, size: usize, addr_offset: u64,
                    alloc: *allocator.Allocator) {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || data == nil || size < 11 || alloc == nil) { ret; }

    val addr_sz: usize = d.ptr_size;
    var pos: usize = 0;

    # skip unit header (11 bytes)
    pos = 11;
    if (pos >= size) { ret; }

    # read CU DIE abbrev code — must be 1
    val cu_abbrev: u64 = read_uleb128_r(data, size, ?pos);
    if (cu_abbrev != 1) { ret; }

    # skip CU DIE fields:
    #   producer (string), language (u16), name (string), comp_dir (string)
    skip_string(data, size, ?pos);    # producer
    pos = pos + 2;                    # language
    skip_string(data, size, ?pos);    # name
    skip_string(data, size, ?pos);    # comp_dir
    #   low_pc (addr), high_pc (addr), stmt_list (u32)
    pos = pos + addr_sz + addr_sz + 4;

    if (pos >= size) { ret; }

    # read subprogram DIEs until null terminator
    for (pos < size) {
        val abbrev: u64 = read_uleb128_r(data, size, ?pos);
        if (abbrev == 0) { brk; }   # null terminator
        if (abbrev != 2) { brk; }   # unexpected abbrev — stop

        if (pos >= size) { brk; }

        # name (null-terminated string)
        val name: str = (data::usize + pos)::str;
        skip_string(data, size, ?pos);

        # file_idx (u16)
        if (pos + 2 > size) { brk; }
        val file_idx: u16 = read_u16_le_r(data, pos);
        pos = pos + 2;

        # line (u32)
        if (pos + 4 > size) { brk; }
        val line: u32 = read_u32_le_r(data, pos);
        pos = pos + 4;

        # low_pc (addr)
        if (pos + addr_sz > size) { brk; }
        val low_pc: u64 = read_addr_le_r(data, pos, addr_sz) + addr_offset;
        pos = pos + addr_sz;

        # high_pc (addr)
        if (pos + addr_sz > size) { brk; }
        val high_pc: u64 = read_addr_le_r(data, pos, addr_sz) + addr_offset;
        pos = pos + addr_sz;

        # remap file index using the map built by dwarf_read_line
        var sub: di.DISubprogram;
        sub.name = name;
        sub.file_idx = map_file_idx(d.last_file_map, d.last_file_map_count, file_idx);
        sub.line = line::i32;
        sub.low_pc = low_pc;
        sub.high_pc = high_pc;
        dwarf_add_subprogram(ctx, ?sub);
    }
}

# --- .debug_line reader ---
#
# parses a .debug_line section produced by our DWARF emitter.
# extracts file entries and line mappings with adjusted addresses.
# format (known because we control the emitter):
#   [unit header: 4B length, 2B version, 4B header_length]
#   [prologue params: min_inst_len, max_ops, default_stmt,
#    line_base, line_range, opcode_base, 12 opcode lengths]
#   [include directories: 0 terminator]
#   [file entries: (name string, dir uleb128, mtime uleb128, size uleb128)*, 0]
#   [line program opcodes]

fun dwarf_read_line(ctx: ptr, data: *u8, size: usize, addr_offset: u64,
                    alloc: *allocator.Allocator) {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || data == nil || size < 10 || alloc == nil) { ret; }

    val addr_sz: usize = d.ptr_size;
    var pos: usize = 0;

    # unit header
    pos = 4;                              # skip unit_length
    val version: u16 = read_u16_le_r(data, pos);
    pos = pos + 2;
    if (version != 4) { ret; }

    val header_length: u32 = read_u32_le_r(data, pos);
    pos = pos + 4;

    val program_start: usize = pos + header_length::usize;

    # skip prologue params (1+1+1+1+1+1 + 12 = 18 bytes)
    pos = pos + 18;
    if (pos >= size) { ret; }

    # skip include directories (null-terminated list, we have 0 = none)
    if (data[pos] == 0) {
        pos = pos + 1;
    } or {
        for (pos < size && data[pos] != 0) {
            skip_string(data, size, ?pos);
        }
        if (pos < size) { pos = pos + 1; }
    }

    # read file entries: (name, dir_idx, mtime, size), terminated by 0
    # build a file index map: .o file_idx → merged file_idx
    val max_files: i32 = 128;
    val fidx_r: Result[*u16, allocator.AllocError] =
        allocator.allocator_zalloc[u16](alloc, max_files::usize);
    if (result_is_err[*u16, allocator.AllocError](fidx_r)) { ret; }
    val file_map: *u16 = result_unwrap_ok[*u16, allocator.AllocError](fidx_r);
    var file_count: i32 = 0;

    for (pos < size && data[pos] != 0) {
        val file_name: str = (data::usize + pos)::str;
        skip_string(data, size, ?pos);
        read_uleb128_r(data, size, ?pos);  # dir_idx
        read_uleb128_r(data, size, ?pos);  # mtime
        read_uleb128_r(data, size, ?pos);  # file_size

        # register file in the merged DebugInfo (1-based indexing)
        if (file_count < max_files) {
            val merged_idx: u16 = dwarf_add_file(ctx, file_name, ".");
            file_map[file_count] = merged_idx;
            file_count = file_count + 1;
        }
    }
    if (pos < size) { pos = pos + 1; } # skip terminating 0

    # advance to program start
    if (program_start > pos) { pos = program_start; }

    # store file map in context for dwarf_read_info to remap file indices
    d.last_file_map = file_map;
    d.last_file_map_count = file_count;

    # execute the line number program
    # addresses in .o are section-relative; start from addr_offset
    var cur_addr: u64 = addr_offset;
    var cur_file: u16 = 1;
    var cur_line: i32 = 1;

    for (pos < size) {
        val opcode: u8 = data[pos];
        pos = pos + 1;

        if (opcode == 0) {
            # extended opcode
            val ext_len: u64 = read_uleb128_r(data, size, ?pos);
            if (pos >= size) { brk; }
            val ext_op: u8 = data[pos];
            pos = pos + 1;

            if (ext_op == DW_LNE_end_sequence) {
                brk;
            } or (ext_op == DW_LNE_set_address) {
                if (pos + addr_sz > size) { brk; }
                cur_addr = read_addr_le_r(data, pos, addr_sz) + addr_offset;
                pos = pos + addr_sz;
            } or {
                # skip unknown extended opcode
                if (ext_len > 1) {
                    pos = pos + (ext_len - 1)::usize;
                }
            }
        } or (opcode == DW_LNS_copy) {
            # emit a row
            val mapped_file: u16 = map_file_idx(file_map, file_count, cur_file);
            var entry: di.DILineEntry;
            entry.address = cur_addr;
            entry.file_idx = mapped_file;
            entry.line = cur_line;
            dwarf_add_line(ctx, ?entry);
        } or (opcode == DW_LNS_advance_pc) {
            val adv: u64 = read_uleb128_r(data, size, ?pos);
            cur_addr = cur_addr + adv;
        } or (opcode == DW_LNS_advance_line) {
            val adv: i64 = read_sleb128_r(data, size, ?pos);
            cur_line = cur_line + adv::i32;
        } or (opcode == DW_LNS_set_file) {
            val fi: u64 = read_uleb128_r(data, size, ?pos);
            cur_file = fi::u16;
        } or (opcode == DW_LNS_set_column) {
            read_uleb128_r(data, size, ?pos); # skip column
        } or (opcode == DW_LNS_negate_stmt) {
            # skip
        } or (opcode >= 13) {
            # special opcode — skip (we don't emit these, but handle gracefully)
        } or {
            # other standard opcodes (7-12): skip their arguments
            # opcodes 7,8,10,11 have 0 args; 9,12 have 1 arg
            if (opcode == 9 || opcode == 12) {
                read_uleb128_r(data, size, ?pos);
            }
        }
    }

    # file_map is kept alive in d.last_file_map for dwarf_read_info
}

# --- reader helpers ---

fun read_u16_le_r(data: *u8, pos: usize) u16 {
    ret data[pos]::u16 | (data[pos + 1]::u16 << 8);
}

fun read_u32_le_r(data: *u8, pos: usize) u32 {
    ret data[pos]::u32 | (data[pos + 1]::u32 << 8)
        | (data[pos + 2]::u32 << 16) | (data[pos + 3]::u32 << 24);
}

fun read_u64_le_r(data: *u8, pos: usize) u64 {
    ret data[pos]::u64 | (data[pos + 1]::u64 << 8)
        | (data[pos + 2]::u64 << 16) | (data[pos + 3]::u64 << 24)
        | (data[pos + 4]::u64 << 32) | (data[pos + 5]::u64 << 40)
        | (data[pos + 6]::u64 << 48) | (data[pos + 7]::u64 << 56);
}

fun read_addr_le_r(data: *u8, pos: usize, addr_sz: usize) u64 {
    if (addr_sz == 4) { ret read_u32_le_r(data, pos)::u64; }
    ret read_u64_le_r(data, pos);
}

fun read_uleb128_r(data: *u8, size: usize, pos: *usize) u64 {
    var result: u64 = 0;
    var shift: u64 = 0;
    for (@pos < size) {
        val b: u8 = data[@pos];
        @pos = @pos + 1;
        result = result | ((b & 0x7f)::u64 << shift);
        if ((b & 0x80) == 0) { brk; }
        shift = shift + 7;
    }
    ret result;
}

fun read_sleb128_r(data: *u8, size: usize, pos: *usize) i64 {
    var result: i64 = 0;
    var shift: i64 = 0;
    var b: u8 = 0;
    for (@pos < size) {
        b = data[@pos];
        @pos = @pos + 1;
        result = result | ((b & 0x7f)::i64 << shift);
        shift = shift + 7;
        if ((b & 0x80) == 0) { brk; }
    }
    if (shift < 64 && (b & 0x40) != 0) {
        result = result | ((-1::i64) << shift);
    }
    ret result;
}

fun skip_string(data: *u8, size: usize, pos: *usize) {
    for (@pos < size && data[@pos] != 0) {
        @pos = @pos + 1;
    }
    if (@pos < size) { @pos = @pos + 1; } # skip null terminator
}

fun map_file_idx(file_map: *u16, count: i32, idx: u16) u16 {
    # DWARF file indices are 1-based; file_map is 0-based
    val i: i32 = idx::i32 - 1;
    if (i >= 0 && i < count && file_map != nil) {
        ret file_map[i];
    }
    ret idx;
}

fun dwarf_destroy(ctx: ptr) {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || d.alloc == nil) { ret; }

    if (d.files != nil) {
        allocator.allocator_free[DWARFFile](d.alloc, d.files, d.file_cap::usize);
    }
    if (d.subs != nil) {
        allocator.allocator_free[di.DISubprogram](d.alloc, d.subs, d.sub_cap::usize);
    }
    if (d.lines != nil) {
        allocator.allocator_free[di.DILineEntry](d.alloc, d.lines, d.line_cap::usize);
    }
    if (d.last_file_map != nil) {
        allocator.allocator_free[u16](d.alloc, d.last_file_map, 128);
    }
    of.buf_destroy(?d.abbrev_buf);
    of.buf_destroy(?d.info_buf);
    of.buf_destroy(?d.line_buf);
    allocator.allocator_free[DWARFContext](d.alloc, d, 1);
}

fun dwarf_get_sections(ctx: ptr, count: *i32) *di.DebugSection {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || count == nil) { ret nil; }
    @count = d.sec_count;
    ret ?d.sections[0];
}

# --- finalize: serialize DWARF binary format ---

fun dwarf_finalize(ctx: ptr, alloc: *allocator.Allocator) {
    val d: *DWARFContext = ctx::*DWARFContext;
    if (d == nil || alloc == nil) { ret; }

    of.buf_init(?d.abbrev_buf, alloc, d.endian);
    of.buf_init(?d.info_buf, alloc, d.endian);
    of.buf_init(?d.line_buf, alloc, d.endian);

    emit_abbrev(d);
    emit_info(d);
    emit_line(d);

    d.sec_count = 0;

    if (d.abbrev_buf.size > 0) {
        d.sections[d.sec_count].name = ".debug_abbrev";
        d.sections[d.sec_count].data = d.abbrev_buf.data;
        d.sections[d.sec_count].size = d.abbrev_buf.size;
        d.sec_count = d.sec_count + 1;
    }

    if (d.info_buf.size > 0) {
        d.sections[d.sec_count].name = ".debug_info";
        d.sections[d.sec_count].data = d.info_buf.data;
        d.sections[d.sec_count].size = d.info_buf.size;
        d.sec_count = d.sec_count + 1;
    }

    if (d.line_buf.size > 0) {
        d.sections[d.sec_count].name = ".debug_line";
        d.sections[d.sec_count].data = d.line_buf.data;
        d.sections[d.sec_count].size = d.line_buf.size;
        d.sec_count = d.sec_count + 1;
    }
}

# --- .debug_abbrev ---
#
# abbreviation table defining two tags:
#   1: DW_TAG_compile_unit (has children)
#      - DW_AT_producer  (DW_FORM_string)
#      - DW_AT_language  (DW_FORM_data2)
#      - DW_AT_name      (DW_FORM_string)
#      - DW_AT_comp_dir  (DW_FORM_string)
#      - DW_AT_low_pc    (DW_FORM_addr)
#      - DW_AT_high_pc   (DW_FORM_addr)
#      - DW_AT_stmt_list (DW_FORM_sec_offset)
#   2: DW_TAG_subprogram (no children)
#      - DW_AT_name      (DW_FORM_string)
#      - DW_AT_decl_file (DW_FORM_data2)
#      - DW_AT_decl_line (DW_FORM_data4)
#      - DW_AT_low_pc    (DW_FORM_addr)
#      - DW_AT_high_pc   (DW_FORM_addr)

fun emit_abbrev(d: *DWARFContext) {
    val out: *of.OutputBuffer = ?d.abbrev_buf;

    # abbrev 1: compile_unit
    write_uleb128(out, 1);                       # abbrev code
    write_uleb128(out, DW_TAG_compile_unit::u64); # tag
    of.buf_write_u8(out, DW_CHILDREN_yes);       # has children

    write_uleb128(out, DW_AT_producer::u64);
    write_uleb128(out, DW_FORM_string::u64);
    write_uleb128(out, DW_AT_language::u64);
    write_uleb128(out, DW_FORM_data2::u64);
    write_uleb128(out, DW_AT_name::u64);
    write_uleb128(out, DW_FORM_string::u64);
    write_uleb128(out, DW_AT_comp_dir::u64);
    write_uleb128(out, DW_FORM_string::u64);
    write_uleb128(out, DW_AT_low_pc::u64);
    write_uleb128(out, DW_FORM_addr::u64);
    write_uleb128(out, DW_AT_high_pc::u64);
    write_uleb128(out, DW_FORM_addr::u64);
    write_uleb128(out, DW_AT_stmt_list::u64);
    write_uleb128(out, DW_FORM_sec_offset::u64);
    write_uleb128(out, 0); # attr terminator
    write_uleb128(out, 0); # form terminator

    # abbrev 2: subprogram
    write_uleb128(out, 2);                       # abbrev code
    write_uleb128(out, DW_TAG_subprogram::u64);  # tag
    of.buf_write_u8(out, DW_CHILDREN_no);        # no children

    write_uleb128(out, DW_AT_name::u64);
    write_uleb128(out, DW_FORM_string::u64);
    write_uleb128(out, DW_AT_decl_file::u64);
    write_uleb128(out, DW_FORM_data2::u64);
    write_uleb128(out, DW_AT_decl_line::u64);
    write_uleb128(out, DW_FORM_data4::u64);
    write_uleb128(out, DW_AT_low_pc::u64);
    write_uleb128(out, DW_FORM_addr::u64);
    write_uleb128(out, DW_AT_high_pc::u64);
    write_uleb128(out, DW_FORM_addr::u64);
    write_uleb128(out, 0); # attr terminator
    write_uleb128(out, 0); # form terminator

    # end of abbreviation table
    write_uleb128(out, 0);
}

# --- .debug_info ---
#
# DWARF v4 compilation unit:
#   unit_length (4 bytes, excludes self)
#   version     (2 bytes = 4)
#   debug_abbrev_offset (4 bytes = 0)
#   address_size (1 byte = 8)
#   [CU DIE]
#   [subprogram DIEs...]
#   [null terminator]

fun emit_info(d: *DWARFContext) {
    val out: *of.OutputBuffer = ?d.info_buf;

    # unit header (11 bytes: 4 + 2 + 4 + 1)
    val header_off: usize = out.size;
    of.buf_write_u32(out, 0);       # unit_length placeholder
    of.buf_write_u16(out, 4);       # version = DWARF 4
    of.buf_write_u32(out, 0);       # debug_abbrev_offset = 0
    of.buf_write_u8(out, d.ptr_size::u8); # address_size

    # CU DIE (abbrev 1)
    write_uleb128(out, 1);          # abbrev code

    # DW_AT_producer: inline string
    write_string(out, "mach compiler");

    # DW_AT_language: DW_LANG_lo_user (mach is a custom language)
    of.buf_write_u16(out, DW_LANG_lo_user);

    # DW_AT_name: compilation unit name
    write_string(out, "<mach>");

    # DW_AT_comp_dir: compilation directory
    write_string(out, ".");

    # DW_AT_low_pc: lowest address in CU
    var cu_low: u64 = 0;
    var cu_high: u64 = 0;
    if (d.sub_count > 0) {
        cu_low = d.subs[0].low_pc;
        cu_high = d.subs[0].high_pc;
        var si: i32 = 1;
        for (si < d.sub_count) {
            if (d.subs[si].low_pc < cu_low) {
                cu_low = d.subs[si].low_pc;
            }
            if (d.subs[si].high_pc > cu_high) {
                cu_high = d.subs[si].high_pc;
            }
            si = si + 1;
        }
    }
    write_addr(out, cu_low, d.ptr_size);

    # DW_AT_high_pc: highest address in CU
    write_addr(out, cu_high, d.ptr_size);

    # DW_AT_stmt_list: offset into .debug_line (always 0)
    of.buf_write_u32(out, 0);

    # subprogram DIEs (abbrev 2)
    var si: i32 = 0;
    for (si < d.sub_count) {
        write_uleb128(out, 2);      # abbrev code

        # DW_AT_name
        if (d.subs[si].name != nil) {
            write_string(out, d.subs[si].name);
        } or {
            write_string(out, "<unknown>");
        }

        # DW_AT_decl_file
        of.buf_write_u16(out, d.subs[si].file_idx);

        # DW_AT_decl_line
        of.buf_write_u32(out, d.subs[si].line::u32);

        # DW_AT_low_pc
        write_addr(out, d.subs[si].low_pc, d.ptr_size);

        # DW_AT_high_pc
        write_addr(out, d.subs[si].high_pc, d.ptr_size);

        si = si + 1;
    }

    # null terminator (end of CU children)
    of.buf_write_u8(out, 0);

    # patch unit_length
    val unit_len: u32 = (out.size - header_off - 4)::u32;
    of.buf_patch_u32(out, header_off, unit_len);
}

# --- .debug_line ---
#
# minimal DWARF v4 line number program.
# if no line entries exist, emits a valid but empty program.

fun emit_line(d: *DWARFContext) {
    val out: *of.OutputBuffer = ?d.line_buf;

    # unit header
    val header_off: usize = out.size;
    of.buf_write_u32(out, 0);      # unit_length placeholder
    of.buf_write_u16(out, 4);      # version = DWARF 4

    val prologue_off: usize = out.size;
    of.buf_write_u32(out, 0);      # header_length placeholder

    # line number program parameters
    of.buf_write_u8(out, 1);       # minimum_instruction_length
    of.buf_write_u8(out, 1);       # maximum_operations_per_instruction
    of.buf_write_u8(out, 1);       # default_is_stmt
    of.buf_write_u8(out, 0xf6::u8); # line_base = -10 (signed)
    of.buf_write_u8(out, 245);     # line_range = 245
    of.buf_write_u8(out, 13);      # opcode_base
    # standard_opcode_lengths (12 entries for opcodes 1..12)
    of.buf_write_u8(out, 0);       # DW_LNS_copy
    of.buf_write_u8(out, 1);       # DW_LNS_advance_pc
    of.buf_write_u8(out, 1);       # DW_LNS_advance_line
    of.buf_write_u8(out, 1);       # DW_LNS_set_file
    of.buf_write_u8(out, 1);       # DW_LNS_set_column
    of.buf_write_u8(out, 0);       # DW_LNS_negate_stmt
    of.buf_write_u8(out, 0);       # DW_LNS_set_basic_block
    of.buf_write_u8(out, 0);       # DW_LNS_const_add_pc
    of.buf_write_u8(out, 1);       # DW_LNS_fixed_advance_pc
    of.buf_write_u8(out, 0);       # DW_LNS_set_prologue_end
    of.buf_write_u8(out, 0);       # DW_LNS_set_epilogue_begin
    of.buf_write_u8(out, 1);       # DW_LNS_set_isa

    # include_directories (null-terminated list)
    of.buf_write_u8(out, 0);       # no include directories

    # file_names (null-terminated list of entries)
    var fi: i32 = 0;
    for (fi < d.file_count) {
        if (d.files[fi].path != nil) {
            write_string(out, d.files[fi].path);  # file name
        } or {
            write_string(out, "<unknown>");
        }
        write_uleb128(out, 0);     # directory index (0 = current)
        write_uleb128(out, 0);     # last modification time
        write_uleb128(out, 0);     # file size
        fi = fi + 1;
    }
    of.buf_write_u8(out, 0);       # end of file_names list

    # patch header_length
    val header_len: u32 = (out.size - prologue_off - 4)::u32;
    of.buf_patch_u32(out, prologue_off, header_len);

    # line number program instructions
    if (d.line_count > 0) {
        var cur_addr: u64 = 0;
        var cur_file: u16 = 1;
        var cur_line: i32 = 1;

        var li: i32 = 0;
        for (li < d.line_count) {
            val entry: *di.DILineEntry = ?d.lines[li];

            # set file if changed
            if (entry.file_idx != cur_file && entry.file_idx > 0) {
                of.buf_write_u8(out, DW_LNS_set_file);
                write_uleb128(out, entry.file_idx::u64);
                cur_file = entry.file_idx;
            }

            # advance line if changed
            if (entry.line != cur_line) {
                of.buf_write_u8(out, DW_LNS_advance_line);
                write_sleb128(out, (entry.line - cur_line)::i64);
                cur_line = entry.line;
            }

            # advance PC
            if (entry.address > cur_addr) {
                of.buf_write_u8(out, DW_LNS_advance_pc);
                write_uleb128(out, entry.address - cur_addr);
                cur_addr = entry.address;
            } or (entry.address != cur_addr) {
                # address went backwards — use set_address
                of.buf_write_u8(out, 0);         # extended opcode marker
                write_uleb128(out, (1 + d.ptr_size)::u64); # length: 1 + ptr_size
                of.buf_write_u8(out, DW_LNE_set_address);
                write_addr(out, entry.address, d.ptr_size);
                cur_addr = entry.address;
            }

            # emit row
            of.buf_write_u8(out, DW_LNS_copy);

            li = li + 1;
        }
    }

    # end sequence (extended opcode)
    of.buf_write_u8(out, 0);                 # extended opcode marker
    write_uleb128(out, 1);                   # length = 1
    of.buf_write_u8(out, DW_LNE_end_sequence);

    # patch unit_length
    val unit_len: u32 = (out.size - header_off - 4)::u32;
    of.buf_patch_u32(out, header_off, unit_len);
}

# --- encoding helpers ---

# write_addr: write an address using the target's pointer size.
fun write_addr(out: *of.OutputBuffer, addr: u64, ptr_size: usize) {
    if (ptr_size == 4) {
        of.buf_write_u32(out, addr::u32);
    } or {
        of.buf_write_u64(out, addr);
    }
}

# write_uleb128: encode an unsigned LEB128 value.
fun write_uleb128(out: *of.OutputBuffer, value: u64) {
    var v: u64 = value;
    for (v >= 128) {
        of.buf_write_u8(out, ((v & 0x7f) | 0x80)::u8);
        v = v >> 7;
    }
    of.buf_write_u8(out, (v & 0x7f)::u8);
}

# write_sleb128: encode a signed LEB128 value.
fun write_sleb128(out: *of.OutputBuffer, value: i64) {
    var v: i64 = value;
    var more: bool = true;
    for (more) {
        var b: u8 = (v & 0x7f)::u8;
        v = v >> 7;
        if ((v == 0 && (b & 0x40) == 0) || (v == -1 && (b & 0x40) != 0)) {
            more = false;
        } or {
            b = b | 0x80;
        }
        of.buf_write_u8(out, b);
    }
}

# write_string: write a null-terminated string.
fun write_string(out: *of.OutputBuffer, s: str) {
    if (s == nil) {
        of.buf_write_u8(out, 0);
        ret;
    }
    var i: usize = 0;
    for (s[i] != 0) {
        of.buf_write_u8(out, s[i]);
        i = i + 1;
    }
    of.buf_write_u8(out, 0);
}

# str_equals: compare two null-terminated strings.
fun str_equals(a: str, b: str) bool {
    if (a == nil && b == nil) { ret true; }
    if (a == nil || b == nil) { ret false; }
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}
