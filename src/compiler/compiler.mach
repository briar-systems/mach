# mach.compiler.compiler: public API for the mach compiler
#
# convenience wrappers for compiling projects and individual files. these
# functions create a session, configure the target, and run the pipeline.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use path:      std.types.path;
use print:     std.print;

use session: mach.compiler.session;
use module:  mach.compiler.sema.module;
use target:  mach.compiler.target.target;
use diag:    mach.compiler.diag;
use linker:  mach.compiler.linker;
use project: mach.config.project;

$if ($mach.build.target.os.id == $mach.os.linux.id) {
    val DEFAULT_OS:  str = "linux";
    val DEFAULT_FMT: str = "elf";
}
$or ($mach.build.target.os.id == $mach.os.macos.id) {
    val DEFAULT_OS:  str = "darwin";
    val DEFAULT_FMT: str = "macho";
}
$or ($mach.build.target.os.id == $mach.os.windows.id) {
    val DEFAULT_OS:  str = "windows";
    val DEFAULT_FMT: str = "pe";
}
$or {
    val DEFAULT_OS:  str = "linux";
    val DEFAULT_FMT: str = "elf";
}

$if ($mach.build.target.arch.id == $mach.arch.x86_64.id) {
    val DEFAULT_ISA: str = "x86_64";
    val DEFAULT_ABI: str = "sysv64";
}
$or ($mach.build.target.arch.id == $mach.arch.arm64.id) {
    val DEFAULT_ISA: str = "aarch64";
    val DEFAULT_ABI: str = "aapcs";
}
$or {
    val DEFAULT_ISA: str = "x86_64";
    val DEFAULT_ABI: str = "sysv64";
}

use masm_mod: masm.module;

fun lookup_source(ctx: ptr, path: str) str {
    if (ctx == nil || path == nil) { ret nil; }
    val table: *module.ModuleTable = ctx::*module.ModuleTable;
    var i: u32 = 0;
    for (i < table.count) {
        if (table.modules[i].file_path != nil && str_equals(table.modules[i].file_path, path)) {
            ret table.modules[i].source;
        }
        i = i + 1;
    }
    ret nil;
}

# compile_project: compile a mach project from its root directory.
#
# loads mach.toml, resolves dependencies, and compiles all source files
# in the project.
# ---
# alloc:        backing allocator
# project_path: path to the project root (containing mach.toml)
# target_name:  target configuration name (from mach.toml [targets.*])
# opts:         compilation options
# ret:          compilation result
pub fun compile_project(alloc: *allocator.Allocator, project_path: str, target_name: str, output_override: str, artifacts_override: str, opts: session.CompileOpts) session.CompileResult {
    var result: session.CompileResult;
    result.ok        = false;
    result.obj_paths = nil;
    result.obj_count = 0;
    result.binary    = nil;

    val res_toml_path: Result[path.Path, str] = path.join(alloc, project_path, "mach.toml");
    if (is_err[path.Path, str](res_toml_path)) {
        print.eprintf("error: failed to construct config path: %s\n", unwrap_err[path.Path, str](res_toml_path));
        ret result;
    }
    val toml_path: str = unwrap_ok[path.Path, str](res_toml_path);
    val res_load: Result[project.ProjectConfig, str] = project.load(alloc, toml_path);
    if (is_err[project.ProjectConfig, str](res_load)) {
        print.eprintf("error: failed to load mach.toml: %s\n", unwrap_err[project.ProjectConfig, str](res_load));
        ret result;
    }
    var config: project.ProjectConfig = unwrap_ok[project.ProjectConfig, str](res_load);

    var tc: *project.TargetConfig = nil;
    if (target_name != nil) {
        tc = project.find_target(?config, target_name);
        if (tc == nil) {
            print.eprintf("error: target '%s' not found in mach.toml\n", target_name);
            project.dnit(?config);
            ret result;
        }
    } or {
        if (config.default_target != nil) {
            tc = project.find_target(?config, config.default_target);
        }
        if (tc == nil && config.target_count > 0) {
            tc = ?config.targets[0];
        }
        if (tc == nil) {
            print.eprintf("error: no target configured in mach.toml\n");
            project.dnit(?config);
            ret result;
        }
    }

    var arch: str = DEFAULT_ISA;
    var os_name: str = DEFAULT_OS;
    var abi_name: str = DEFAULT_ABI;
    var fmt: str = DEFAULT_FMT;
    if (tc.isa != nil) { arch = tc.isa; }
    if (tc.os != nil) { os_name = tc.os; }
    if (tc.abi != nil) { abi_name = tc.abi; }

    val res_target: Result[target.Target, str] = target.select(arch, os_name, abi_name, fmt, alloc);
    if (is_err[target.Target, str](res_target)) {
        print.eprintf("error: failed to select target: %s\n", unwrap_err[target.Target, str](res_target));
        project.dnit(?config);
        ret result;
    }
    var tgt: target.Target = unwrap_ok[target.Target, str](res_target);

    var sess: session.Session = session.init(alloc, opts, tgt.ptr_size::u32);
    sess.target = ?tgt;

    var entrypoint: str = tc.entrypoint;
    if (entrypoint == nil) {
        print.eprintf("error: no entrypoint specified in target config\n");
        session.dnit(?sess);
        target.dnit(?tgt);
        project.dnit(?config);
        ret result;
    }

    var src_root: str = config.dir_src;
    if (src_root == nil) { src_root = "src"; }
    var dep_root: str = config.dir_dep;
    if (dep_root == nil) { dep_root = "dep"; }

    val res_entry_path: Result[path.Path, str] = path.join(alloc, src_root, entrypoint);
    if (is_err[path.Path, str](res_entry_path)) {
        print.eprintf("error: failed to construct entrypoint path: %s\n", unwrap_err[path.Path, str](res_entry_path));
        session.dnit(?sess);
        target.dnit(?tgt);
        project.dnit(?config);
        ret result;
    }
    val entry_path: str = unwrap_ok[path.Path, str](res_entry_path);

    val res_source: Result[str, str] = fs.read_all(alloc, entry_path);
    if (is_err[str, str](res_source)) {
        print.eprintf("error: failed to read entrypoint '%s': %s\n", entry_path, unwrap_err[str, str](res_source));
        session.dnit(?sess);
        target.dnit(?tgt);
        project.dnit(?config);
        ret result;
    }
    val source: str = unwrap_ok[str, str](res_source);

    var dep_maps: *module.DepMapping = nil;
    var dep_map_count: u32 = 0;
    if (config.dep_count > 0) {
        val res_deps: Result[*module.DepMapping, str] = allocator.allocate[module.DepMapping](alloc, config.dep_count::usize);
        if (is_ok[*module.DepMapping, str](res_deps)) {
            dep_maps = unwrap_ok[*module.DepMapping, str](res_deps);
            var di: u32 = 0;
            for (di < config.dep_count) {
                val dep_name: str = config.deps[di].name;
                if (dep_name == nil) {
                    di = di + 1;
                    cnt;
                }

                val res_dep_toml: Result[path.Path, str] = path.join(alloc, dep_root, dep_name);
                if (is_err[path.Path, str](res_dep_toml)) {
                    di = di + 1;
                    cnt;
                }
                val dep_dir: str = unwrap_ok[path.Path, str](res_dep_toml);
                val res_dep_cfg_path: Result[path.Path, str] = path.join(alloc, dep_dir, "mach.toml");
                if (is_err[path.Path, str](res_dep_cfg_path)) {
                    di = di + 1;
                    cnt;
                }
                val dep_cfg_path: str = unwrap_ok[path.Path, str](res_dep_cfg_path);

                val res_dep_cfg: Result[project.ProjectConfig, str] = project.load(alloc, dep_cfg_path);
                if (is_ok[project.ProjectConfig, str](res_dep_cfg)) {
                    val dcfg: project.ProjectConfig = unwrap_ok[project.ProjectConfig, str](res_dep_cfg);
                    var dep_src: str = dcfg.dir_src;
                    if (dep_src == nil) { dep_src = "src"; }

                    dep_maps[dep_map_count].project_id = dcfg.id;
                    dep_maps[dep_map_count].dir_name   = dep_name;
                    dep_maps[dep_map_count].dir_src    = dep_src;
                    dep_map_count = dep_map_count + 1;
                }
                di = di + 1;
            }
        }
    }

    session.load(?sess, config.id, entry_path, source, src_root, dep_root, config.id, dep_maps, dep_map_count);

    session.analyze(?sess);
    if (diag.had_errors(?sess.diag)) {
        diag.print_terminal(?sess.diag, lookup_source, (?sess.modules)::ptr);
        session.dnit(?sess);
        target.dnit(?tgt);
        project.dnit(?config);
        ret result;
    }

    var dir_out: str = config.dir_out;
    if (dir_out == nil) { dir_out = "out"; }

    var binary_path: str = output_override;
    if (binary_path == nil && tc.binary != nil) {
        val res_bin: Result[path.Path, str] = path.join(alloc, dir_out, tc.binary);
        if (is_ok[path.Path, str](res_bin)) {
            binary_path = unwrap_ok[path.Path, str](res_bin);
        }
    }
    if (binary_path == nil) { binary_path = "a.out"; }
    var artifacts_name: str = artifacts_override;
    if (artifacts_name == nil) { artifacts_name = tc.artifacts; }

    var artifacts_dir: str = dir_out;
    if (artifacts_name != nil) {
        val res_art: Result[path.Path, str] = path.join(alloc, dir_out, artifacts_name);
        if (is_ok[path.Path, str](res_art)) {
            artifacts_dir = unwrap_ok[path.Path, str](res_art);
        }
    }

    result = session.compile_all(?sess, artifacts_dir);

    val res_bin_dir: Result[path.Path, str] = path.parent(alloc, binary_path);
    if (is_ok[path.Path, str](res_bin_dir)) {
        val bin_dir: str = unwrap_ok[path.Path, str](res_bin_dir);
        if (bin_dir != nil && !fs.is_dir(bin_dir)) {
            fs.create_dir_all(alloc, bin_dir, 0o755);
        }
    }

    val link_result: linker.LinkResult = session.link_all(?sess, result.obj_paths, result.obj_count, binary_path);
    if (!link_result.ok) {
        if (link_result.error != nil) {
            print.eprintf("error: link failed: %s\n", link_result.error);
        }
    } or {
        result.binary = link_result.output_path;
        result.ok = true;
    }

    session.dnit(?sess);
    target.dnit(?tgt);
    project.dnit(?config);

    ret result;
}

# compile_file: compile a single source file to a binary.
# ---
# alloc:       backing allocator
# source_path: path to the .mach source file
# output_path: path for the output binary
# opts:        compilation options
# ret:         compilation result
pub fun compile_file(alloc: *allocator.Allocator, source_path: str, output_path: str, opts: session.CompileOpts) session.CompileResult {
    var result: session.CompileResult;
    result.ok        = false;
    result.obj_paths = nil;
    result.obj_count = 0;
    result.binary    = nil;

    val res_target: Result[target.Target, str] = target.select_native(alloc);
    if (is_err[target.Target, str](res_target)) {
        print.eprintf("error: failed to select native target: %s\n", unwrap_err[target.Target, str](res_target));
        ret result;
    }
    var tgt: target.Target = unwrap_ok[target.Target, str](res_target);

    var sess: session.Session = session.init(alloc, opts, tgt.ptr_size::u32);
    sess.target = ?tgt;

    val res_source: Result[str, str] = fs.read_all(alloc, source_path);
    if (is_err[str, str](res_source)) {
        print.eprintf("error: failed to read '%s': %s\n", source_path, unwrap_err[str, str](res_source));
        session.dnit(?sess);
        target.dnit(?tgt);
        ret result;
    }
    val source: str = unwrap_ok[str, str](res_source);

    session.load(?sess, source_path, source_path, source, "src", "dep", source_path, nil, 0);

    session.analyze(?sess);
    if (diag.had_errors(?sess.diag)) {
        diag.print_terminal(?sess.diag, lookup_source, (?sess.modules)::ptr);
        session.dnit(?sess);
        target.dnit(?tgt);
        ret result;
    }

    result = session.compile_all(?sess, nil);

    val link_result: linker.LinkResult = session.link_all(?sess, result.obj_paths, result.obj_count, output_path);
    if (!link_result.ok) {
        if (link_result.error != nil) {
            print.eprintf("error: link failed: %s\n", link_result.error);
        }
    } or {
        result.binary = link_result.output_path;
    }

    result.ok = true;

    session.dnit(?sess);
    target.dnit(?tgt);

    ret result;
}
