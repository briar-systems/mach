use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use token: mach.compiler.token;
use ty:    mach.compiler.type;

# mach.compiler.ast: abstract syntax tree types.
# ---
# defines the AST node types used by the parser to represent parsed Mach code.
# uses a tagged union (Node.info) for type-safe per-kind field access.

# NodeKind: type alias for node kind tags.
pub def NodeKind: u8;

# NodeKind tag constants for efficient comparison.
pub val NODE_PROGRAM:        NodeKind = 0;
pub val NODE_STMT_LIST:      NodeKind = 1;

# declarations
pub val NODE_DECL_USE:       NodeKind = 2;
pub val NODE_DECL_PUB:       NodeKind = 3;
pub val NODE_DECL_EXT:       NodeKind = 4;
pub val NODE_DECL_DEF:       NodeKind = 5;
pub val NODE_DECL_REC:       NodeKind = 6;
pub val NODE_DECL_UNI:       NodeKind = 7;
pub val NODE_DECL_VAL:       NodeKind = 8;
pub val NODE_DECL_VAR:       NodeKind = 9;
pub val NODE_DECL_FUN:       NodeKind = 10;
pub val NODE_DECL_TEST:      NodeKind = 11;

# statements
pub val NODE_STMT_EXPR:      NodeKind = 12;
pub val NODE_STMT_BLOCK:     NodeKind = 13;
pub val NODE_STMT_IF:        NodeKind = 14;
pub val NODE_STMT_OR:        NodeKind = 15;
pub val NODE_STMT_FOR:       NodeKind = 16;
pub val NODE_STMT_RET:       NodeKind = 17;
pub val NODE_STMT_BRK:       NodeKind = 18;
pub val NODE_STMT_CNT:       NodeKind = 19;
pub val NODE_STMT_FIN:       NodeKind = 20;
pub val NODE_STMT_MASM:      NodeKind = 21;

# comptime
pub val NODE_COMPTIME_IF:    NodeKind = 22;
pub val NODE_COMPTIME_OR:    NodeKind = 23;
pub val NODE_COMPTIME:       NodeKind = 24;

# expressions
pub val NODE_EXPR_IDENT:     NodeKind = 25;
pub val NODE_EXPR_LIT_INT:   NodeKind = 26;
pub val NODE_EXPR_LIT_FLOAT: NodeKind = 27;
pub val NODE_EXPR_LIT_CHAR:  NodeKind = 28;
pub val NODE_EXPR_LIT_STR:   NodeKind = 29;
pub val NODE_EXPR_LIT_NIL:   NodeKind = 30;
pub val NODE_EXPR_LIT_BOOL:  NodeKind = 31;
pub val NODE_EXPR_BINARY:    NodeKind = 32;
pub val NODE_EXPR_UNARY:     NodeKind = 33;
pub val NODE_EXPR_CALL:      NodeKind = 34;
pub val NODE_EXPR_INDEX:     NodeKind = 35;
pub val NODE_EXPR_FIELD:     NodeKind = 36;
pub val NODE_EXPR_CAST:      NodeKind = 37;
pub val NODE_EXPR_ADDR:      NodeKind = 38;
pub val NODE_EXPR_DEREF:     NodeKind = 39;
pub val NODE_EXPR_PAREN:     NodeKind = 40;
pub val NODE_EXPR_ARRAY_LIT: NodeKind = 41;
pub val NODE_EXPR_STRUCT_LIT: NodeKind = 42;

# types
pub val NODE_TYPE_NAME:      NodeKind = 43;
pub val NODE_TYPE_PTR:       NodeKind = 44;
pub val NODE_TYPE_REF:       NodeKind = 45;
pub val NODE_TYPE_ARRAY:     NodeKind = 46;
pub val NODE_TYPE_FUN:       NodeKind = 47;
pub val NODE_TYPE_REC:       NodeKind = 48;
pub val NODE_TYPE_UNI:       NodeKind = 49;

# misc
pub val NODE_PARAM:          NodeKind = 50;
pub val NODE_FIELD:          NodeKind = 51;
pub val NODE_GENERIC:        NodeKind = 52;
pub val NODE_OR_BRANCH:      NodeKind = 53;
pub val NODE_VARIADIC:       NodeKind = 54;

# --- variant records ---

pub rec UseDecl      { path: str; alias: str; }
pub rec ExtDecl      { name: str; inner: *Node; }
pub rec DefDecl      { name: str; type_node: *Node; generics: *Node; }
pub rec VarDecl      { name: str; type_node: *Node; init: *Node; }
pub rec FunDecl      { name: str; params: *List; body: *Node;
                       generics: *Node; ret_type: *Node;
                       is_variadic: bool; }
pub rec TestDecl     { name: str; body: *Node; }
pub rec TypeDecl     { name: str; fields: *List; generics: *Node; }
pub rec FieldDecl    { name: str; type_node: *Node; }
pub rec WrapperNode  { inner: *Node; }
pub rec BlockStmt    { stmts: *List; }
pub rec CondStmt     { cond: *Node; body: *Node; or_branch: *Node; }
pub rec ForStmt      { cond: *Node; body: *Node; }
pub rec MasmStmt     { content: str; }
pub rec IdentExpr    { name: str; }
pub rec LitExpr      { text: str; }
pub rec BinaryExpr   { left: *Node; right: *Node; op: u8; }
pub rec UnaryExpr    { expr: *Node; op: u8; }
pub rec CallExpr     { callee: *Node; args: *List; type_args: *Node; }
pub rec IndexExpr    { base: *Node; index: *Node; }
pub rec FieldExpr    { object: *Node; field: str; }
pub rec CastExpr     { expr: *Node; type_node: *Node; }
pub rec ArrayLit     { size: *Node; type_node: *Node; elements: *List; }
pub rec StructLit    { type_node: *Node; fields: *List; }
pub rec TypeName     { path: str; args: *Node; }
pub rec TypePtr      { inner: *Node; }
pub rec TypeArray    { elem_type: *Node; size: *Node; }
pub rec TypeFun      { params: *List; ret_type: *Node; }
pub rec GenericNode  { args: *List; }

# Node: an AST node with typed union payload.
# ---
# kind:     type of node (use NODE_* constants for comparison)
# tok:      token associated with this node (for error reporting)
# ty:       resolved type (filled during semantic analysis)
# symbol:   resolved symbol (filled during semantic analysis, ptr to avoid circular dep)
# info:     tagged union of per-kind fields
pub rec Node {
    kind:     NodeKind;
    tok:      token.Token;
    ty:       *ty.Type;
    symbol:   ptr;
    info:     uni {
        use_decl:     UseDecl;
        ext_decl:     ExtDecl;
        def_decl:     DefDecl;
        var_decl:     VarDecl;
        fun_decl:     FunDecl;
        test_decl:    TestDecl;
        type_decl:    TypeDecl;
        field_decl:   FieldDecl;
        wrapper:      WrapperNode;
        block_stmt:   BlockStmt;
        cond_stmt:    CondStmt;
        for_stmt:     ForStmt;
        masm_stmt:    MasmStmt;
        ident_expr:   IdentExpr;
        lit_expr:     LitExpr;
        binary_expr:  BinaryExpr;
        unary_expr:   UnaryExpr;
        call_expr:    CallExpr;
        index_expr:   IndexExpr;
        field_expr:   FieldExpr;
        cast_expr:    CastExpr;
        array_lit:    ArrayLit;
        struct_lit:   StructLit;
        type_name:    TypeName;
        type_ptr:     TypePtr;
        type_array:   TypeArray;
        type_fun:     TypeFun;
        generic_node: GenericNode;
    };
}

# List: a list of AST nodes (for parameters, fields, statements, etc.).
# ---
# nodes:    array of node pointers
# count:    number of nodes in the list
# capacity: allocated capacity
pub rec List {
    nodes:    **Node;
    count:    i32;
    capacity: i32;
}

# create_node: allocate and initialize a new AST node.
# ---
# alloc: allocator to use
# kind:  node kind (NODE_* constant)
# tok:   associated token
# ret:   Ok(*Node) on success, Err(str) on failure
pub fun create_node(alloc: *allocator.Allocator, kind: NodeKind, tok: token.Token) Result[*Node, str] {
    if (alloc == nil) {
        ret err[*Node, str]("allocator is nil");
    }

    val r: Result[*Node, allocator.AllocError] = allocator.allocator_zalloc[Node](alloc, 1);
    if (result_is_err[*Node, allocator.AllocError](r)) {
        ret err[*Node, str](result_unwrap_err[*Node, allocator.AllocError](r));
    }

    val node: *Node = result_unwrap_ok[*Node, allocator.AllocError](r);
    node.kind = kind;
    node.tok = tok;

    ret ok[*Node, str](node);
}

# create_list: allocate and initialize a new AST list.
# ---
# alloc: allocator to use
# ret:   Ok(*List) on success, Err(str) on failure
pub fun create_list(alloc: *allocator.Allocator) Result[*List, str] {
    if (alloc == nil) {
        ret err[*List, str]("allocator is nil");
    }

    val r: Result[*List, allocator.AllocError] = allocator.allocator_zalloc[List](alloc, 1);
    if (result_is_err[*List, allocator.AllocError](r)) {
        ret err[*List, str](result_unwrap_err[*List, allocator.AllocError](r));
    }

    val list: *List = result_unwrap_ok[*List, allocator.AllocError](r);
    list.nodes = nil;
    list.count = 0;
    list.capacity = 0;

    ret ok[*List, str](list);
}

# append: append a node to this list.
# ---
# alloc: allocator for resizing
# node:  node to append
# ret:   Ok(true) on success, Err(str) on failure
pub fun list_append(this: *List, alloc: *allocator.Allocator, node: *Node) Result[bool, str] {
    if (alloc == nil) {
        ret err[bool, str]("allocator is nil");
    }

    if (this == nil) {
        ret err[bool, str]("list is nil");
    }

    if (this.count >= this.capacity) {
        var new_cap: i32 = 8;
        if (this.capacity > 0) {
            new_cap = this.capacity * 2;
        }

        val r: Result[**Node, allocator.AllocError] = allocator.allocator_resize[*Node](alloc, this.nodes, this.capacity::usize, new_cap::usize);
        if (result_is_err[**Node, allocator.AllocError](r)) {
            ret err[bool, str](result_unwrap_err[**Node, allocator.AllocError](r));
        }

        this.nodes = result_unwrap_ok[**Node, allocator.AllocError](r);
        this.capacity = new_cap;
    }

    this.nodes[this.count] = node;
    this.count = this.count + 1;

    ret ok[bool, str](true);
}

# free_node: recursively free an AST node and its children.
# ---
# alloc: allocator used for allocation
# node:  node to free
# ret:   none
pub fun free_node(alloc: *allocator.Allocator, node: *Node) {
    if (alloc == nil || node == nil) {
        ret;
    }

    # TODO: recursively free children
    # TODO: free node-specific data

    allocator.allocator_free[Node](alloc, node, 1);
}

# free_list: free an AST list and optionally its nodes.
# ---
# alloc:      allocator used for allocation
# list:       list to free
# free_nodes: if true, also free each node in the list
# ret:        none
pub fun free_list(alloc: *allocator.Allocator, list: *List, free_nodes: bool) {
    if (alloc == nil || list == nil) {
        ret;
    }

    if (free_nodes && list.nodes != nil) {
        var i: i32 = 0;
        for (i < list.count) {
            free_node(alloc, list.nodes[i]);
            i = i + 1;
        }
    }

    if (list.nodes != nil) {
        allocator.allocator_free[*Node](alloc, list.nodes, list.capacity::usize);
    }

    allocator.allocator_free[List](alloc, list, 1);
}

# clone_list: deep-clone an AST list and all its nodes.
# ---
# alloc: allocator to use for new allocations
# list:  list to clone (nil returns ok(nil))
# ret:   Ok(*List) on success, Err(str) on failure
pub fun clone_list(alloc: *allocator.Allocator, list: *List) Result[*List, str] {
    if (list == nil) {
        ret ok[*List, str](nil);
    }

    val new_list_res: Result[*List, str] = create_list(alloc);
    if (result_is_err[*List, str](new_list_res)) {
        ret new_list_res;
    }
    val new_list: *List = result_unwrap_ok[*List, str](new_list_res);

    var i: i32 = 0;
    for (i < list.count) {
        val clone_res: Result[*Node, str] = clone_node(alloc, list.nodes[i]);
        if (result_is_err[*Node, str](clone_res)) {
            ret err[*List, str](result_unwrap_err[*Node, str](clone_res));
        }
        val cloned: *Node = result_unwrap_ok[*Node, str](clone_res);
        val append_res: Result[bool, str] = list_append(new_list, alloc, cloned);
        if (result_is_err[bool, str](append_res)) {
            ret err[*List, str](result_unwrap_err[bool, str](append_res));
        }
        i = i + 1;
    }

    ret ok[*List, str](new_list);
}

# clone_node: deep-clone an AST node and all its children.
# ---
# alloc: allocator to use for new allocations
# node:  node to clone (nil returns ok(nil))
# ret:   Ok(*Node) on success, Err(str) on failure
#
# string fields (names, paths, text) are shared, not cloned.
# ty and symbol pointers are copied as-is initially.
pub fun clone_node(alloc: *allocator.Allocator, node: *Node) Result[*Node, str] {
    if (node == nil) {
        ret ok[*Node, str](nil);
    }

    val res: Result[*Node, str] = create_node(alloc, node.kind, node.tok);
    if (result_is_err[*Node, str](res)) {
        ret res;
    }
    val n: *Node = result_unwrap_ok[*Node, str](res);
    n.ty = node.ty;
    n.symbol = node.symbol;

    val k: NodeKind = node.kind;

    # use_decl: string fields shared
    if (k == NODE_DECL_USE) {
        n.info.use_decl.path = node.info.use_decl.path;
        n.info.use_decl.alias = node.info.use_decl.alias;
        ret ok[*Node, str](n);
    }

    # wrapper: inner
    if (k == NODE_DECL_PUB || k == NODE_STMT_EXPR || k == NODE_STMT_RET ||
        k == NODE_EXPR_PAREN || k == NODE_COMPTIME || k == NODE_STMT_FIN) {
        val inner_res: Result[*Node, str] = clone_node(alloc, node.info.wrapper.inner);
        if (result_is_err[*Node, str](inner_res)) { ret inner_res; }
        n.info.wrapper.inner = result_unwrap_ok[*Node, str](inner_res);
        ret ok[*Node, str](n);
    }

    # ext_decl: name (shared), inner
    if (k == NODE_DECL_EXT) {
        n.info.ext_decl.name = node.info.ext_decl.name;
        val inner_res: Result[*Node, str] = clone_node(alloc, node.info.ext_decl.inner);
        if (result_is_err[*Node, str](inner_res)) { ret inner_res; }
        n.info.ext_decl.inner = result_unwrap_ok[*Node, str](inner_res);
        ret ok[*Node, str](n);
    }

    # def_decl: name (shared), type_node, generics
    if (k == NODE_DECL_DEF) {
        n.info.def_decl.name = node.info.def_decl.name;
        val tn_res: Result[*Node, str] = clone_node(alloc, node.info.def_decl.type_node);
        if (result_is_err[*Node, str](tn_res)) { ret tn_res; }
        n.info.def_decl.type_node = result_unwrap_ok[*Node, str](tn_res);
        val gen_res: Result[*Node, str] = clone_node(alloc, node.info.def_decl.generics);
        if (result_is_err[*Node, str](gen_res)) { ret gen_res; }
        n.info.def_decl.generics = result_unwrap_ok[*Node, str](gen_res);
        ret ok[*Node, str](n);
    }

    # var_decl: name (shared), type_node, init
    if (k == NODE_DECL_VAL || k == NODE_DECL_VAR) {
        n.info.var_decl.name = node.info.var_decl.name;
        val tn_res: Result[*Node, str] = clone_node(alloc, node.info.var_decl.type_node);
        if (result_is_err[*Node, str](tn_res)) { ret tn_res; }
        n.info.var_decl.type_node = result_unwrap_ok[*Node, str](tn_res);
        val init_res: Result[*Node, str] = clone_node(alloc, node.info.var_decl.init);
        if (result_is_err[*Node, str](init_res)) { ret init_res; }
        n.info.var_decl.init = result_unwrap_ok[*Node, str](init_res);
        ret ok[*Node, str](n);
    }

    # fun_decl: name (shared), params (list), body, generics, ret_type, is_variadic
    if (k == NODE_DECL_FUN) {
        n.info.fun_decl.name = node.info.fun_decl.name;
        n.info.fun_decl.is_variadic = node.info.fun_decl.is_variadic;
        val params_res: Result[*List, str] = clone_list(alloc, node.info.fun_decl.params);
        if (result_is_err[*List, str](params_res)) { ret err[*Node, str](result_unwrap_err[*List, str](params_res)); }
        n.info.fun_decl.params = result_unwrap_ok[*List, str](params_res);
        val body_res: Result[*Node, str] = clone_node(alloc, node.info.fun_decl.body);
        if (result_is_err[*Node, str](body_res)) { ret body_res; }
        n.info.fun_decl.body = result_unwrap_ok[*Node, str](body_res);
        val gen_res: Result[*Node, str] = clone_node(alloc, node.info.fun_decl.generics);
        if (result_is_err[*Node, str](gen_res)) { ret gen_res; }
        n.info.fun_decl.generics = result_unwrap_ok[*Node, str](gen_res);
        val ret_res: Result[*Node, str] = clone_node(alloc, node.info.fun_decl.ret_type);
        if (result_is_err[*Node, str](ret_res)) { ret ret_res; }
        n.info.fun_decl.ret_type = result_unwrap_ok[*Node, str](ret_res);
        ret ok[*Node, str](n);
    }

    # test_decl: name (shared), body
    if (k == NODE_DECL_TEST) {
        n.info.test_decl.name = node.info.test_decl.name;
        val body_res: Result[*Node, str] = clone_node(alloc, node.info.test_decl.body);
        if (result_is_err[*Node, str](body_res)) { ret body_res; }
        n.info.test_decl.body = result_unwrap_ok[*Node, str](body_res);
        ret ok[*Node, str](n);
    }

    # type_decl: name (shared), fields (list), generics
    if (k == NODE_DECL_REC || k == NODE_DECL_UNI || k == NODE_TYPE_REC || k == NODE_TYPE_UNI) {
        n.info.type_decl.name = node.info.type_decl.name;
        val fields_res: Result[*List, str] = clone_list(alloc, node.info.type_decl.fields);
        if (result_is_err[*List, str](fields_res)) { ret err[*Node, str](result_unwrap_err[*List, str](fields_res)); }
        n.info.type_decl.fields = result_unwrap_ok[*List, str](fields_res);
        val gen_res: Result[*Node, str] = clone_node(alloc, node.info.type_decl.generics);
        if (result_is_err[*Node, str](gen_res)) { ret gen_res; }
        n.info.type_decl.generics = result_unwrap_ok[*Node, str](gen_res);
        ret ok[*Node, str](n);
    }

    # field_decl: name (shared), type_node
    if (k == NODE_PARAM || k == NODE_FIELD) {
        n.info.field_decl.name = node.info.field_decl.name;
        val tn_res: Result[*Node, str] = clone_node(alloc, node.info.field_decl.type_node);
        if (result_is_err[*Node, str](tn_res)) { ret tn_res; }
        n.info.field_decl.type_node = result_unwrap_ok[*Node, str](tn_res);
        ret ok[*Node, str](n);
    }

    # block_stmt: stmts (list)
    if (k == NODE_PROGRAM || k == NODE_STMT_LIST || k == NODE_STMT_BLOCK) {
        val stmts_res: Result[*List, str] = clone_list(alloc, node.info.block_stmt.stmts);
        if (result_is_err[*List, str](stmts_res)) { ret err[*Node, str](result_unwrap_err[*List, str](stmts_res)); }
        n.info.block_stmt.stmts = result_unwrap_ok[*List, str](stmts_res);
        ret ok[*Node, str](n);
    }

    # cond_stmt: cond, body, or_branch
    if (k == NODE_STMT_IF || k == NODE_STMT_OR || k == NODE_COMPTIME_IF ||
        k == NODE_COMPTIME_OR || k == NODE_OR_BRANCH) {
        val cond_res: Result[*Node, str] = clone_node(alloc, node.info.cond_stmt.cond);
        if (result_is_err[*Node, str](cond_res)) { ret cond_res; }
        n.info.cond_stmt.cond = result_unwrap_ok[*Node, str](cond_res);
        val body_res: Result[*Node, str] = clone_node(alloc, node.info.cond_stmt.body);
        if (result_is_err[*Node, str](body_res)) { ret body_res; }
        n.info.cond_stmt.body = result_unwrap_ok[*Node, str](body_res);
        val or_res: Result[*Node, str] = clone_node(alloc, node.info.cond_stmt.or_branch);
        if (result_is_err[*Node, str](or_res)) { ret or_res; }
        n.info.cond_stmt.or_branch = result_unwrap_ok[*Node, str](or_res);
        ret ok[*Node, str](n);
    }

    # for_stmt: cond, body
    if (k == NODE_STMT_FOR) {
        val cond_res: Result[*Node, str] = clone_node(alloc, node.info.for_stmt.cond);
        if (result_is_err[*Node, str](cond_res)) { ret cond_res; }
        n.info.for_stmt.cond = result_unwrap_ok[*Node, str](cond_res);
        val body_res: Result[*Node, str] = clone_node(alloc, node.info.for_stmt.body);
        if (result_is_err[*Node, str](body_res)) { ret body_res; }
        n.info.for_stmt.body = result_unwrap_ok[*Node, str](body_res);
        ret ok[*Node, str](n);
    }

    # leaf statements: no children
    if (k == NODE_STMT_BRK || k == NODE_STMT_CNT || k == NODE_VARIADIC) {
        ret ok[*Node, str](n);
    }

    # masm_stmt: content (shared)
    if (k == NODE_STMT_MASM) {
        n.info.masm_stmt.content = node.info.masm_stmt.content;
        ret ok[*Node, str](n);
    }

    # ident_expr: name (shared)
    if (k == NODE_EXPR_IDENT) {
        n.info.ident_expr.name = node.info.ident_expr.name;
        ret ok[*Node, str](n);
    }

    # lit_expr: text (shared)
    if (k == NODE_EXPR_LIT_INT || k == NODE_EXPR_LIT_FLOAT || k == NODE_EXPR_LIT_CHAR ||
        k == NODE_EXPR_LIT_STR || k == NODE_EXPR_LIT_NIL || k == NODE_EXPR_LIT_BOOL) {
        n.info.lit_expr.text = node.info.lit_expr.text;
        ret ok[*Node, str](n);
    }

    # binary_expr: left, right, op
    if (k == NODE_EXPR_BINARY) {
        n.info.binary_expr.op = node.info.binary_expr.op;
        val left_res: Result[*Node, str] = clone_node(alloc, node.info.binary_expr.left);
        if (result_is_err[*Node, str](left_res)) { ret left_res; }
        n.info.binary_expr.left = result_unwrap_ok[*Node, str](left_res);
        val right_res: Result[*Node, str] = clone_node(alloc, node.info.binary_expr.right);
        if (result_is_err[*Node, str](right_res)) { ret right_res; }
        n.info.binary_expr.right = result_unwrap_ok[*Node, str](right_res);
        ret ok[*Node, str](n);
    }

    # unary_expr: expr, op
    if (k == NODE_EXPR_UNARY || k == NODE_EXPR_ADDR || k == NODE_EXPR_DEREF) {
        n.info.unary_expr.op = node.info.unary_expr.op;
        val expr_res: Result[*Node, str] = clone_node(alloc, node.info.unary_expr.expr);
        if (result_is_err[*Node, str](expr_res)) { ret expr_res; }
        n.info.unary_expr.expr = result_unwrap_ok[*Node, str](expr_res);
        ret ok[*Node, str](n);
    }

    # call_expr: callee, args (list), type_args
    if (k == NODE_EXPR_CALL) {
        val callee_res: Result[*Node, str] = clone_node(alloc, node.info.call_expr.callee);
        if (result_is_err[*Node, str](callee_res)) { ret callee_res; }
        n.info.call_expr.callee = result_unwrap_ok[*Node, str](callee_res);
        val args_res: Result[*List, str] = clone_list(alloc, node.info.call_expr.args);
        if (result_is_err[*List, str](args_res)) { ret err[*Node, str](result_unwrap_err[*List, str](args_res)); }
        n.info.call_expr.args = result_unwrap_ok[*List, str](args_res);
        val ta_res: Result[*Node, str] = clone_node(alloc, node.info.call_expr.type_args);
        if (result_is_err[*Node, str](ta_res)) { ret ta_res; }
        n.info.call_expr.type_args = result_unwrap_ok[*Node, str](ta_res);
        ret ok[*Node, str](n);
    }

    # index_expr: base, index
    if (k == NODE_EXPR_INDEX) {
        val base_res: Result[*Node, str] = clone_node(alloc, node.info.index_expr.base);
        if (result_is_err[*Node, str](base_res)) { ret base_res; }
        n.info.index_expr.base = result_unwrap_ok[*Node, str](base_res);
        val idx_res: Result[*Node, str] = clone_node(alloc, node.info.index_expr.index);
        if (result_is_err[*Node, str](idx_res)) { ret idx_res; }
        n.info.index_expr.index = result_unwrap_ok[*Node, str](idx_res);
        ret ok[*Node, str](n);
    }

    # field_expr: object, field (shared)
    if (k == NODE_EXPR_FIELD) {
        n.info.field_expr.field = node.info.field_expr.field;
        val obj_res: Result[*Node, str] = clone_node(alloc, node.info.field_expr.object);
        if (result_is_err[*Node, str](obj_res)) { ret obj_res; }
        n.info.field_expr.object = result_unwrap_ok[*Node, str](obj_res);
        ret ok[*Node, str](n);
    }

    # cast_expr: expr, type_node
    if (k == NODE_EXPR_CAST) {
        val expr_res: Result[*Node, str] = clone_node(alloc, node.info.cast_expr.expr);
        if (result_is_err[*Node, str](expr_res)) { ret expr_res; }
        n.info.cast_expr.expr = result_unwrap_ok[*Node, str](expr_res);
        val tn_res: Result[*Node, str] = clone_node(alloc, node.info.cast_expr.type_node);
        if (result_is_err[*Node, str](tn_res)) { ret tn_res; }
        n.info.cast_expr.type_node = result_unwrap_ok[*Node, str](tn_res);
        ret ok[*Node, str](n);
    }

    # array_lit: size, type_node, elements (list)
    if (k == NODE_EXPR_ARRAY_LIT) {
        val size_res: Result[*Node, str] = clone_node(alloc, node.info.array_lit.size);
        if (result_is_err[*Node, str](size_res)) { ret size_res; }
        n.info.array_lit.size = result_unwrap_ok[*Node, str](size_res);
        val tn_res: Result[*Node, str] = clone_node(alloc, node.info.array_lit.type_node);
        if (result_is_err[*Node, str](tn_res)) { ret tn_res; }
        n.info.array_lit.type_node = result_unwrap_ok[*Node, str](tn_res);
        val elems_res: Result[*List, str] = clone_list(alloc, node.info.array_lit.elements);
        if (result_is_err[*List, str](elems_res)) { ret err[*Node, str](result_unwrap_err[*List, str](elems_res)); }
        n.info.array_lit.elements = result_unwrap_ok[*List, str](elems_res);
        ret ok[*Node, str](n);
    }

    # struct_lit: type_node, fields (list)
    if (k == NODE_EXPR_STRUCT_LIT) {
        val tn_res: Result[*Node, str] = clone_node(alloc, node.info.struct_lit.type_node);
        if (result_is_err[*Node, str](tn_res)) { ret tn_res; }
        n.info.struct_lit.type_node = result_unwrap_ok[*Node, str](tn_res);
        val fields_res: Result[*List, str] = clone_list(alloc, node.info.struct_lit.fields);
        if (result_is_err[*List, str](fields_res)) { ret err[*Node, str](result_unwrap_err[*List, str](fields_res)); }
        n.info.struct_lit.fields = result_unwrap_ok[*List, str](fields_res);
        ret ok[*Node, str](n);
    }

    # type_name: path (shared), args
    if (k == NODE_TYPE_NAME) {
        n.info.type_name.path = node.info.type_name.path;
        val args_res: Result[*Node, str] = clone_node(alloc, node.info.type_name.args);
        if (result_is_err[*Node, str](args_res)) { ret args_res; }
        n.info.type_name.args = result_unwrap_ok[*Node, str](args_res);
        ret ok[*Node, str](n);
    }

    # type_ptr: inner
    if (k == NODE_TYPE_PTR || k == NODE_TYPE_REF) {
        val inner_res: Result[*Node, str] = clone_node(alloc, node.info.type_ptr.inner);
        if (result_is_err[*Node, str](inner_res)) { ret inner_res; }
        n.info.type_ptr.inner = result_unwrap_ok[*Node, str](inner_res);
        ret ok[*Node, str](n);
    }

    # type_array: elem_type, size
    if (k == NODE_TYPE_ARRAY) {
        val elem_res: Result[*Node, str] = clone_node(alloc, node.info.type_array.elem_type);
        if (result_is_err[*Node, str](elem_res)) { ret elem_res; }
        n.info.type_array.elem_type = result_unwrap_ok[*Node, str](elem_res);
        val size_res: Result[*Node, str] = clone_node(alloc, node.info.type_array.size);
        if (result_is_err[*Node, str](size_res)) { ret size_res; }
        n.info.type_array.size = result_unwrap_ok[*Node, str](size_res);
        ret ok[*Node, str](n);
    }

    # type_fun: params (list), ret_type
    if (k == NODE_TYPE_FUN) {
        val params_res: Result[*List, str] = clone_list(alloc, node.info.type_fun.params);
        if (result_is_err[*List, str](params_res)) { ret err[*Node, str](result_unwrap_err[*List, str](params_res)); }
        n.info.type_fun.params = result_unwrap_ok[*List, str](params_res);
        val ret_res: Result[*Node, str] = clone_node(alloc, node.info.type_fun.ret_type);
        if (result_is_err[*Node, str](ret_res)) { ret ret_res; }
        n.info.type_fun.ret_type = result_unwrap_ok[*Node, str](ret_res);
        ret ok[*Node, str](n);
    }

    # generic_node: args (list)
    if (k == NODE_GENERIC) {
        val args_res: Result[*List, str] = clone_list(alloc, node.info.generic_node.args);
        if (result_is_err[*List, str](args_res)) { ret err[*Node, str](result_unwrap_err[*List, str](args_res)); }
        n.info.generic_node.args = result_unwrap_ok[*List, str](args_res);
        ret ok[*Node, str](n);
    }

    # unknown kind: return shallow copy
    ret ok[*Node, str](n);
}

# --- node kind classification helpers ---

# is_decl: check if this node is a declaration.
pub fun node_is_decl(this: &Node) bool {
    if (this == nil) {
        ret false;
    }
    val k: NodeKind = this.kind;
    ret k == NODE_DECL_USE || k == NODE_DECL_PUB || k == NODE_DECL_EXT ||
        k == NODE_DECL_DEF || k == NODE_DECL_REC || k == NODE_DECL_UNI ||
        k == NODE_DECL_VAL || k == NODE_DECL_VAR || k == NODE_DECL_FUN ||
        k == NODE_DECL_TEST;
}

# is_stmt: check if this node is a statement.
pub fun node_is_stmt(this: &Node) bool {
    if (this == nil) {
        ret false;
    }
    val k: NodeKind = this.kind;
    ret k == NODE_STMT_EXPR || k == NODE_STMT_BLOCK || k == NODE_STMT_IF ||
        k == NODE_STMT_FOR || k == NODE_STMT_RET || k == NODE_STMT_BRK ||
        k == NODE_STMT_CNT || k == NODE_STMT_FIN || k == NODE_STMT_MASM;
}

# is_expr: check if this node is an expression.
pub fun node_is_expr(this: &Node) bool {
    if (this == nil) {
        ret false;
    }
    val k: NodeKind = this.kind;
    ret k == NODE_EXPR_IDENT || k == NODE_EXPR_LIT_INT || k == NODE_EXPR_LIT_FLOAT ||
        k == NODE_EXPR_LIT_CHAR || k == NODE_EXPR_LIT_STR || k == NODE_EXPR_LIT_NIL ||
        k == NODE_EXPR_LIT_BOOL || k == NODE_EXPR_BINARY || k == NODE_EXPR_UNARY ||
        k == NODE_EXPR_CALL || k == NODE_EXPR_INDEX || k == NODE_EXPR_FIELD ||
        k == NODE_EXPR_CAST || k == NODE_EXPR_ADDR || k == NODE_EXPR_DEREF ||
        k == NODE_EXPR_PAREN || k == NODE_EXPR_ARRAY_LIT || k == NODE_EXPR_STRUCT_LIT;
}

# is_type: check if this node is a type expression.
pub fun node_is_type(this: &Node) bool {
    if (this == nil) {
        ret false;
    }
    val k: NodeKind = this.kind;
    ret k == NODE_TYPE_NAME || k == NODE_TYPE_PTR || k == NODE_TYPE_REF ||
        k == NODE_TYPE_ARRAY || k == NODE_TYPE_FUN || k == NODE_TYPE_REC ||
        k == NODE_TYPE_UNI;
}

# is_literal: check if this node is a literal expression.
pub fun node_is_literal(this: &Node) bool {
    if (this == nil) {
        ret false;
    }
    val k: NodeKind = this.kind;
    ret k == NODE_EXPR_LIT_INT || k == NODE_EXPR_LIT_FLOAT || k == NODE_EXPR_LIT_CHAR ||
        k == NODE_EXPR_LIT_STR || k == NODE_EXPR_LIT_NIL || k == NODE_EXPR_LIT_BOOL;
}

# --- data accessors ---

# get_int_value: get the integer value from an int literal node.
# parses the string representation stored in info.lit_expr.text to an integer.
pub fun node_get_int_value(this: &Node) i64 {
    if (this == nil || this.kind != NODE_EXPR_LIT_INT) {
        ret 0;
    }
    val text: str = this.info.lit_expr.text;
    if (text == nil) {
        ret 0;
    }
    # parse string to integer
    var result: i64 = 0;
    var i: i32 = 0;
    var negative: bool = false;
    val len: i32 = str_len(text)::i32;

    # handle optional sign
    if (i < len && text[i] == '-') {
        negative = true;
        i = i + 1;
    } or {
        if (i < len && text[i] == '+') {
            i = i + 1;
        }
    }

    # check for base prefix: 0x (hex), 0o (octal), 0b (binary)
    if (i + 1 < len && text[i] == '0') {
        val prefix: u8 = text[i + 1];
        if (prefix == 'x' || prefix == 'X') {
            # hexadecimal
            i = i + 2;
            for (i < len) {
                val c: u8 = text[i];
                if (c >= '0' && c <= '9') {
                    result = result * 16 + (c - '0')::i64;
                } or (c >= 'a' && c <= 'f') {
                    result = result * 16 + (c - 'a')::i64 + 10;
                } or (c >= 'A' && c <= 'F') {
                    result = result * 16 + (c - 'A')::i64 + 10;
                } or (c == '_') {
                    # skip underscores
                } or {
                    brk;
                }
                i = i + 1;
            }
            if (negative) { ret -result; }
            ret result;
        } or (prefix == 'o' || prefix == 'O') {
            # octal
            i = i + 2;
            for (i < len) {
                val c: u8 = text[i];
                if (c >= '0' && c <= '7') {
                    result = result * 8 + (c - '0')::i64;
                } or (c == '_') {
                    # skip underscores
                } or {
                    brk;
                }
                i = i + 1;
            }
            if (negative) { ret -result; }
            ret result;
        } or (prefix == 'b' || prefix == 'B') {
            # binary
            i = i + 2;
            for (i < len) {
                val c: u8 = text[i];
                if (c == '0' || c == '1') {
                    result = result * 2 + (c - '0')::i64;
                } or (c == '_') {
                    # skip underscores
                } or {
                    brk;
                }
                i = i + 1;
            }
            if (negative) { ret -result; }
            ret result;
        }
    }

    # parse decimal digits
    for (i < len) {
        val c: u8 = text[i];
        if (c >= '0' && c <= '9') {
            result = result * 10 + (c - '0')::i64;
        } or (c == '_') {
            # skip underscores
        } or {
            # stop at non-digit (handles suffixes, etc.)
            brk;
        }
        i = i + 1;
    }

    if (negative) {
        ret -result;
    }
    ret result;
}

# kind_name: get a string representation of a node kind.
pub fun kind_name(kind: NodeKind) str {
    if (kind == NODE_PROGRAM)        { ret "program"; }
    if (kind == NODE_STMT_LIST)      { ret "stmt_list"; }
    if (kind == NODE_DECL_USE)       { ret "use"; }
    if (kind == NODE_DECL_PUB)       { ret "pub"; }
    if (kind == NODE_DECL_EXT)       { ret "ext"; }
    if (kind == NODE_DECL_DEF)       { ret "def"; }
    if (kind == NODE_DECL_REC)       { ret "rec"; }
    if (kind == NODE_DECL_UNI)       { ret "uni"; }
    if (kind == NODE_DECL_VAL)       { ret "val"; }
    if (kind == NODE_DECL_VAR)       { ret "var"; }
    if (kind == NODE_DECL_FUN)       { ret "fun"; }
    if (kind == NODE_DECL_TEST)      { ret "test"; }
    if (kind == NODE_STMT_EXPR)      { ret "expr_stmt"; }
    if (kind == NODE_STMT_BLOCK)     { ret "block"; }
    if (kind == NODE_STMT_IF)        { ret "if"; }
    if (kind == NODE_STMT_OR)        { ret "or"; }
    if (kind == NODE_STMT_FOR)       { ret "for"; }
    if (kind == NODE_STMT_RET)       { ret "ret"; }
    if (kind == NODE_STMT_BRK)       { ret "brk"; }
    if (kind == NODE_STMT_CNT)       { ret "cnt"; }
    if (kind == NODE_STMT_FIN)       { ret "fin"; }
    if (kind == NODE_STMT_MASM)      { ret "asm"; }
    if (kind == NODE_COMPTIME_IF)    { ret "comptime_if"; }
    if (kind == NODE_COMPTIME_OR)    { ret "comptime_or"; }
    if (kind == NODE_COMPTIME)       { ret "comptime"; }
    if (kind == NODE_EXPR_IDENT)     { ret "identifier"; }
    if (kind == NODE_EXPR_LIT_INT)   { ret "int_literal"; }
    if (kind == NODE_EXPR_LIT_FLOAT) { ret "float_literal"; }
    if (kind == NODE_EXPR_LIT_CHAR)  { ret "char_literal"; }
    if (kind == NODE_EXPR_LIT_STR)   { ret "string_literal"; }
    if (kind == NODE_EXPR_LIT_NIL)   { ret "nil"; }
    if (kind == NODE_EXPR_LIT_BOOL)  { ret "bool_literal"; }
    if (kind == NODE_EXPR_BINARY)    { ret "binary_expr"; }
    if (kind == NODE_EXPR_UNARY)     { ret "unary_expr"; }
    if (kind == NODE_EXPR_CALL)      { ret "call"; }
    if (kind == NODE_EXPR_INDEX)     { ret "index"; }
    if (kind == NODE_EXPR_FIELD)     { ret "field_access"; }
    if (kind == NODE_EXPR_CAST)      { ret "cast"; }
    if (kind == NODE_EXPR_ADDR)      { ret "address_of"; }
    if (kind == NODE_EXPR_DEREF)     { ret "deref"; }
    if (kind == NODE_EXPR_PAREN)     { ret "paren"; }
    if (kind == NODE_EXPR_ARRAY_LIT) { ret "array_literal"; }
    if (kind == NODE_EXPR_STRUCT_LIT) { ret "struct_literal"; }
    if (kind == NODE_TYPE_NAME)      { ret "type_name"; }
    if (kind == NODE_TYPE_PTR)       { ret "pointer_type"; }
    if (kind == NODE_TYPE_REF)       { ret "ref_type"; }
    if (kind == NODE_TYPE_ARRAY)     { ret "array_type"; }
    if (kind == NODE_TYPE_FUN)       { ret "function_type"; }
    if (kind == NODE_TYPE_REC)       { ret "record_type"; }
    if (kind == NODE_TYPE_UNI)       { ret "union_type"; }
    if (kind == NODE_PARAM)          { ret "param"; }
    if (kind == NODE_FIELD)          { ret "field"; }
    if (kind == NODE_GENERIC)        { ret "generic"; }
    if (kind == NODE_OR_BRANCH)      { ret "or_branch"; }
    ret "unknown";
}
