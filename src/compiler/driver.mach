use mem: std.system.memory;

use mach.compiler.session;

## Driver is the main entry point for the Mach compiler.
pub rec Driver {
    session: Session;
}

## Initializes the driver.
##
## ret: optional error message on failure
pub fun (this: *Driver) init() Option[str] {
    mem.zero[Driver](this, 1);

    val res_session_init: Option[str] = this.session.init();
    if (res_session_init.is_some()) {
        ret res_session_init;
    }

    ret none[str]();
}

## Deinitializes the driver.
pub fun (this: *Driver) dnit() {
    this.session.dnit();
    mem.zero[Driver](this, 1);
}
