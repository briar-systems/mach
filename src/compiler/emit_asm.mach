use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use fs:        std.filesystem;
use stream:    std.stream;
use fmt:       std.fmt;

# mach.compiler.emit_asm: assembly text file lifecycle.
# ---
# thin lifecycle module for .s output files. actual instruction
# formatting is delegated to the ISA's format_inst function.

# AsmWriter: wraps a file descriptor and stream writer for .s output.
pub rec AsmWriter {
    w:  stream.Writer;
    fd: i32;
}

# open: create a new .s file for writing assembly text.
# returns a heap-allocated AsmWriter, or nil on failure.
pub fun open(output_path: str, alloc: *allocator.Allocator) *AsmWriter {
    if (output_path == nil || alloc == nil) { ret nil; }

    val f_res: Result[fs.File, str] = fs.create(output_path, 438);
    if (result_is_err[fs.File, str](f_res)) { ret nil; }

    val aw_res: Result[*AsmWriter, allocator.AllocError] =
        allocator.allocator_alloc[AsmWriter](alloc, 1);
    if (result_is_err[*AsmWriter, allocator.AllocError](aw_res)) { ret nil; }

    val aw: *AsmWriter = result_unwrap_ok[*AsmWriter, allocator.AllocError](aw_res);
    val f: fs.File = result_unwrap_ok[fs.File, str](f_res);
    aw.fd = f.fd;
    aw.w = stream.writer(f.fd);
    ret aw;
}

# close: close the .s file.
pub fun close(aw: *AsmWriter) {
    if (aw == nil) { ret; }
    var f: fs.File;
    f.fd = aw.fd;
    fs.file_close(?f);
}

# emit_func_header: write a function label to the .s file.
pub fun emit_func_header(aw: *AsmWriter, name: str) {
    if (aw == nil || name == nil) { ret; }
    fmt.write_str(?aw.w, name);
    fmt.write_str(?aw.w, ":\n");
}

# emit_prologue_comment: write a prologue descriptor comment.
pub fun emit_prologue_comment(aw: *AsmWriter, frame_size: usize, callee_mask: u32) {
    if (aw == nil) { ret; }
    fmt.format(?aw.w, "    ; prologue: frame=%u callee_mask=0x%x\n",
        frame_size::u64, callee_mask::u64);
}

# emit_epilogue_comment: write an epilogue descriptor comment.
pub fun emit_epilogue_comment(aw: *AsmWriter, callee_mask: u32) {
    if (aw == nil) { ret; }
    fmt.format(?aw.w, "    ; epilogue: callee_mask=0x%x\n", callee_mask::u64);
}

# emit_label: write a label line.
pub fun emit_label(aw: *AsmWriter, name: str) {
    if (aw == nil || name == nil) { ret; }
    fmt.write_str(?aw.w, name);
    fmt.write_str(?aw.w, ":\n");
}

# emit_newline: write a blank line separator.
pub fun emit_newline(aw: *AsmWriter) {
    if (aw == nil) { ret; }
    fmt.write_newline(?aw.w);
}
