use std.types.bool;
use std.types.size;
use std.types.string;

# mach.compiler.token: token types for the lexer.
# ---
# defines the token kinds and token structure used during lexical analysis.

# TokenKind: enumeration of all token types.
# ---
# each variant represents a distinct token category.
pub uni TokenKind {
    # literals
    ident:      u8;
    lit_int:    u8;
    lit_float:  u8;
    lit_char:   u8;
    lit_string: u8;

    # keywords
    kw_use:  u8;
    kw_pub:  u8;
    kw_ext:  u8;
    kw_def:  u8;
    kw_rec:  u8;
    kw_uni:  u8;
    kw_val:  u8;
    kw_var:  u8;
    kw_fun:  u8;
    kw_ret:  u8;
    kw_if:   u8;
    kw_or:   u8;
    kw_for:  u8;
    kw_cnt:  u8;
    kw_brk:  u8;
    kw_fin:  u8;
    kw_masm: u8;
    kw_test: u8;
    kw_nil:  u8;
    kw_true: u8;
    kw_false: u8;

    # punctuation
    lparen:    u8;  # (
    rparen:    u8;  # )
    lbrace:    u8;  # {
    rbrace:    u8;  # }
    lbracket:  u8;  # [
    rbracket:  u8;  # ]
    semi:      u8;  # ;
    colon:     u8;  # :
    comma:     u8;  # ,
    dot:       u8;  # .
    question:  u8;  # ?
    at:        u8;  # @
    dollar:    u8;  # $
    hash:      u8;  # #
    amp:       u8;  # &
    star:      u8;  # *

    # operators
    plus:       u8;  # +
    minus:      u8;  # -
    slash:      u8;  # /
    percent:    u8;  # %
    eq:         u8;  # =
    eq_eq:      u8;  # ==
    bang:       u8;  # !
    bang_eq:    u8;  # !=
    lt:         u8;  # <
    lt_eq:      u8;  # <=
    lt_lt:      u8;  # <<
    gt:         u8;  # >
    gt_eq:      u8;  # >=
    gt_gt:      u8;  # >>
    amp_amp:    u8;  # &&
    pipe:       u8;  # |
    pipe_pipe:  u8;  # ||
    caret:      u8;  # ^
    tilde:      u8;  # ~
    colon_colon: u8; # ::

    # special
    eof:     u8;
    error:   u8;
    newline: u8;
}

# Token: a single token from the source.
# ---
# kind:   type of token
# pos:    byte offset in source where token starts
# len:    length of token in bytes
pub rec Token {
    kind: TokenKind;
    pos:  i32;
    len:  i32;
}

# create: create a new token.
# ---
# kind: token kind
# pos:  position in source
# len:  length in bytes
# ret:  new Token
pub fun create(kind: TokenKind, pos: i32, len: i32) Token {
    ret Token { kind: kind, pos: pos, len: len };
}

# is_keyword: check if a token kind is a keyword.
# ---
# kind: token kind to check
# ret:  true if the kind represents a keyword
pub fun is_keyword(kind: TokenKind) bool {
    # TODO: implement when union tag comparison is available
    # for now, return false as a stub
    ret false;
}

# is_literal: check if a token kind is a literal.
# ---
# kind: token kind to check
# ret:  true if the kind represents a literal value
pub fun is_literal(kind: TokenKind) bool {
    # TODO: implement when union tag comparison is available
    ret false;
}

# is_operator: check if a token kind is an operator.
# ---
# kind: token kind to check
# ret:  true if the kind represents an operator
pub fun is_operator(kind: TokenKind) bool {
    # TODO: implement when union tag comparison is available
    ret false;
}

# keyword_from_str: convert a string to a keyword token kind if it matches.
# ---
# s:   string to check
# ret: keyword TokenKind if s is a keyword, or ident if not
pub fun keyword_from_str(s: str) TokenKind {
    if (s == nil) {
        ret TokenKind { ident: 0 };
    }

    if (s.equals("use"))   { ret TokenKind { kw_use: 0 }; }
    if (s.equals("pub"))   { ret TokenKind { kw_pub: 0 }; }
    if (s.equals("ext"))   { ret TokenKind { kw_ext: 0 }; }
    if (s.equals("def"))   { ret TokenKind { kw_def: 0 }; }
    if (s.equals("rec"))   { ret TokenKind { kw_rec: 0 }; }
    if (s.equals("uni"))   { ret TokenKind { kw_uni: 0 }; }
    if (s.equals("val"))   { ret TokenKind { kw_val: 0 }; }
    if (s.equals("var"))   { ret TokenKind { kw_var: 0 }; }
    if (s.equals("fun"))   { ret TokenKind { kw_fun: 0 }; }
    if (s.equals("ret"))   { ret TokenKind { kw_ret: 0 }; }
    if (s.equals("if"))    { ret TokenKind { kw_if: 0 }; }
    if (s.equals("or"))    { ret TokenKind { kw_or: 0 }; }
    if (s.equals("for"))   { ret TokenKind { kw_for: 0 }; }
    if (s.equals("cnt"))   { ret TokenKind { kw_cnt: 0 }; }
    if (s.equals("brk"))   { ret TokenKind { kw_brk: 0 }; }
    if (s.equals("fin"))   { ret TokenKind { kw_fin: 0 }; }
    if (s.equals("masm"))  { ret TokenKind { kw_masm: 0 }; }
    if (s.equals("test"))  { ret TokenKind { kw_test: 0 }; }
    if (s.equals("nil"))   { ret TokenKind { kw_nil: 0 }; }
    if (s.equals("true"))  { ret TokenKind { kw_true: 0 }; }
    if (s.equals("false")) { ret TokenKind { kw_false: 0 }; }

    ret TokenKind { ident: 0 };
}

# kind_to_str: convert a token kind to a human-readable string.
# ---
# kind: token kind to convert
# ret:  string representation of the kind
pub fun kind_to_str(kind: TokenKind) str {
    # TODO: implement when union tag comparison is available
    # for now return a placeholder
    ret "<token>";
}
