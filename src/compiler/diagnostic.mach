use std.types.string;

pub def DiagnosticLevel: u8;

pub val DIAG_INFO:    DiagnosticLevel = $iota();
pub val DIAG_WARNING: DiagnosticLevel = $iota();
pub val DIAG_ERROR:   DiagnosticLevel = $iota();
pub val DIAG_FATAL:   DiagnosticLevel = $iota();

## Get the string representation of the diagnostic level.
pub fun (this: DiagnosticLevel) to_str() str {
    if (this == DIAG_INFO)    { ret "info"; }
    if (this == DIAG_WARNING) { ret "warning"; }
    if (this == DIAG_ERROR)   { ret "error"; }
    if (this == DIAG_FATAL)   { ret "fatal"; }
    ret "unknown";
}

## Diagnostic structure representing a compiler diagnostic message.
pub rec Diagnostic {
    level:   DiagnosticLevel;
    token:   Token;
    message: str;
}

## Create a new diagnostic.
##
## level:   diagnostic severity level
## token:   associated token
## message: diagnostic message
pub fun diagnostic_make(level: DiagnosticLevel, token: Token, message: str) Diagnostic {
    ret Diagnostic {
        level:   level,
        token:   token,
        message: message,
    };
}

## Format and print a single diagnostic. Output is formatted as:
##
## <severity>: <message>
## | <file_path>:<line>:<column>
## | <line num> | <source line>
## |            | <caret>
##
## Example formatted output:
##
## error: undefined identifier `foo`
## | src/main.mach:10:13
## |    10 | val x: u32 = foo + 1;
## |       |              ^^^
##
## source:    full source string
## file_path: path to source file
pub fun (this: Diagnostic) print(source: str, file_path: str) {
    val prefix: str = this.level.to_str();

    # diagnostic descriptor
    console.print("%s: %s\n", prefix, this.message);

    # diagnostic location
    console.print(" | %s:%d:%d\n",
        file_path,
        this.token.row,
        this.token.col);

    # print source line header (line number)
    console.print(" | %d | ", this.token.row);
    
    # print source line with indicator
    val opt_line: Option[str] = extract_line(source, this.token.row);
    if (opt_line.is_none()) {
        ret;
    }

    val line: str = opt_line.unwrap_some();
    console.print("%s\n", line);

    print_caret_line(this.token.col, this.token.len);
}

## Extract a specific line from the source string (1-based).
## Returns none if the line does not exist.
##
## line_num: 1-based line number to extract
## source:   full source string
fun extract_line(source: str, line_num: usize) Option[str] {
    var row_cur:    usize = 1;
    var line_start: usize = 0;

    # find line start
    var i: usize = 0;
    for (i < source.len) {
        if (row_cur == line_num) {
            line_start = i;
            brk;
        }

        if (source[i] == '\n') {
            row_cur = row_cur + 1;
        }

        i = i + 1;
    }

    # line not found
    if (row_cur != line_num) {
        ret none[str]();
    }

    # find line end
    var line_end: usize = line_start;
    for (line_end < source.len) {
        if (source[line_end] == '\n') {
            brk;
        }
        line_end = line_end + 1;
    }

    ret some[str](source.substring(line_start, line_end));
}


## Print a caret line indicating the position of the diagnostic.
##
## col: 1-based column number
## len: length of the highlighted section
fun print_caret_line(col: usize, len: usize) {
    # padding for line number and separator
    console.print(" |       | ");

    # print spaces up to column
    var i: usize = 1;
    for (i < col) {
        console.print(" ");
        i = i + 1;
    }

    var j: usize = 0;
    for (j < len) {
        console.print("^");
        j = j + 1;
    }

    console.print("\n");
}
