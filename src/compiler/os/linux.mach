use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use platform:  std.system.platform;
use os:        mach.compiler.os;

# mach.compiler.os.linux: Linux OS implementation.
# ---
# entry point: _start
# linker: ld with glibc CRT objects
# CRT ordering: crt1.o crti.o <objects> -lc crtn.o

# CRT and linker paths (Debian/Ubuntu x86_64)
val LD_PATH:     str = "/usr/bin/ld";
val DYN_LINKER:  str = "/lib64/ld-linux-x86-64.so.2";
val CRT1:        str = "/usr/lib/x86_64-linux-gnu/crt1.o";
val CRTI:        str = "/usr/lib/x86_64-linux-gnu/crti.o";
val CRTN:        str = "/usr/lib/x86_64-linux-gnu/crtn.o";
val LIB_PATH1:   str = "-L/lib/x86_64-linux-gnu";
val LIB_PATH2:   str = "-L/usr/lib/x86_64-linux-gnu";

# maximum number of object files + fixed args
val MAX_ARGV: i32 = 128;

rec LinuxContext {
    alloc: *allocator.Allocator;
}

# create: construct the Linux OS implementation.
pub fun create(alloc: *allocator.Allocator) Result[os.OS, str] {
    if (alloc == nil) {
        ret err[os.OS, str]("allocator is nil");
    }

    val ctx_r: Result[*LinuxContext, allocator.AllocError] =
        allocator.allocator_zalloc[LinuxContext](alloc, 1);
    if (result_is_err[*LinuxContext, allocator.AllocError](ctx_r)) {
        ret err[os.OS, str]("out of memory");
    }
    val ctx: *LinuxContext = result_unwrap_ok[*LinuxContext, allocator.AllocError](ctx_r);
    ctx.alloc = alloc;

    var o: os.OS;
    o.ctx = ctx::ptr;
    o.entry_point = linux_entry_point;
    o.link = linux_link;

    ret ok[os.OS, str](o);
}

# --- interface implementations ---

fun linux_entry_point(ctx: ptr) str {
    ret "_start";
}

# linux_link: invoke ld to link object files into an executable.
#
# builds argv:
#   ld -o <output>
#      -dynamic-linker /lib64/ld-linux-x86-64.so.2
#      /usr/lib/x86_64-linux-gnu/crt1.o
#      /usr/lib/x86_64-linux-gnu/crti.o
#      <user objects...>
#      -lc
#      -L/lib/x86_64-linux-gnu
#      -L/usr/lib/x86_64-linux-gnu
#      /usr/lib/x86_64-linux-gnu/crtn.o
fun linux_link(ctx: ptr, objects: *str, count: i32, output: str) i64 {
    if (objects == nil || count <= 0 || output == nil) { ret 1; }

    # build argv on the stack
    var argv: [128]&u8;
    var ai: i32 = 0;

    argv[ai] = LD_PATH;       ai = ai + 1;
    argv[ai] = "-o";          ai = ai + 1;
    argv[ai] = output;        ai = ai + 1;
    argv[ai] = "-dynamic-linker"; ai = ai + 1;
    argv[ai] = DYN_LINKER;    ai = ai + 1;
    argv[ai] = CRT1;          ai = ai + 1;
    argv[ai] = CRTI;          ai = ai + 1;

    # user objects
    var oi: i32 = 0;
    for (oi < count && ai < MAX_ARGV - 5) {
        argv[ai] = objects[oi];
        ai = ai + 1;
        oi = oi + 1;
    }

    argv[ai] = "-lc";         ai = ai + 1;
    argv[ai] = LIB_PATH1;     ai = ai + 1;
    argv[ai] = LIB_PATH2;     ai = ai + 1;
    argv[ai] = CRTN;          ai = ai + 1;
    argv[ai] = nil;

    # empty environment
    var envp: [1]&u8;
    envp[0] = nil;

    # fork + exec
    val pid: i64 = platform.fork();
    if (pid < 0) { ret 1; }

    if (pid == 0) {
        # child: exec the linker
        platform.execve(LD_PATH, ?argv[0], ?envp[0]);
        # if execve returns, it failed
        platform.terminate(1);
    }

    # parent: wait for child
    var status: i32 = 0;
    val wait_result: i64 = platform.waitpid(pid, ?status, 0);
    if (wait_result < 0) { ret 1; }

    if (platform.wifexited(status)) {
        ret platform.wexitstatus(status)::i64;
    }

    ret 1;
}
