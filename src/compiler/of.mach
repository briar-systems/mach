use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

# mach.compiler.of: object format interface.
# ---
# abstracts all object file writing behind function pointers.
# the emission stage works identically regardless of output format
# (ELF, Mach-O, PE/COFF, raw binary).
#
# OF defines record shapes (OFSymbol, OFReloc) but NO constants.
# binding, kind, and relocation type values come from MASM and are
# passed through as opaque u8/u32 values. OF implementations map
# them internally to format-specific values.

# OFSymbol: a symbol to be written to the object file.
# binding and kind use abstract constants defined by MASM.
pub rec OFSymbol {
    name:    str;
    section: u64;    # section index (0 = undefined/external)
    offset:  usize;  # offset within section
    size:    usize;
    binding: u8;     # abstract binding (local/global/weak)
    kind:    u8;     # abstract kind (func/object/section/file)
}

# OFReloc: a relocation entry.
# rtype uses abstract relocation constants defined by MASM.
pub rec OFReloc {
    section: u64;    # section the reloc applies to
    offset:  usize;  # offset within that section
    symbol:  u64;    # symbol index
    rtype:   u32;    # abstract relocation type
    addend:  i64;
}

# --- object reader (format-agnostic .o consumption) ---
#
# ObjectReader is the read-side counterpart to ObjectFormat.
# all records use MASM abstract constants — no format-specific values.
# OF implementations map from format-specific values internally.

# ObjSection: a section read from an object file.
pub rec ObjSection {
    name:  str;
    kind:  u8;       # abstract section kind (SEC_TEXT, SEC_DATA, etc.)
    flags: u32;      # abstract section flags (FLAG_WRITE, FLAG_EXEC, FLAG_ALLOC)
    data:  *u8;
    size:  usize;
    align: usize;
}

# ObjSymbol: a symbol read from an object file.
pub rec ObjSymbol {
    name:    str;
    binding: u8;     # abstract binding (BIND_LOCAL, BIND_GLOBAL, BIND_WEAK)
    kind:    u8;     # abstract kind (SYM_FUNC, SYM_OBJECT, etc.)
    section: i32;    # section index (-1 = undefined/external)
    offset:  usize;
    size:    usize;
    defined: bool;
}

# ObjReloc: a relocation read from an object file.
pub rec ObjReloc {
    section:     i32;    # index into ObjFile.sections
    offset:      usize;  # offset within that section
    symbol_name: str;    # resolved symbol name (not an index)
    rtype:       u8;     # abstract relocation type (RELOC_*)
    addend:      i64;
}

# ObjFile: a complete parsed object file.
pub rec ObjFile {
    sections:    *ObjSection;
    sec_count:   i32;
    symbols:     *ObjSymbol;
    sym_count:   i32;
    relocs:      *ObjReloc;
    reloc_count: i32;
    source_path: str;
    alloc:       *allocator.Allocator;
}

# ObjectReader: interface for reading relocatable object files.
# ---
# mirrors ObjectFormat (writer). selected per-target.
# the linker uses this interface — no format-specific code.
pub rec ObjectReader {
    ctx: ptr;

    # read a .o file from disk into an ObjFile.
    read: fun(ptr, str, *allocator.Allocator) *ObjFile;

    # free all memory associated with an ObjFile.
    destroy_obj: fun(ptr, *ObjFile);

    # release all reader resources.
    destroy: fun(ptr);
}

# --- executable format ---

# ExecSection: a section with a resolved virtual address for executable emission.
pub rec ExecSection {
    data:   *u8;
    size:   usize;
    vaddr:  u64;
    flags:  u32;    # abstract section flags (FLAG_WRITE, FLAG_EXEC, FLAG_ALLOC)
    align:  usize;
}

# ExecFormat: executable file format interface.
# ---
# parallel to ObjectFormat (which produces relocatable .o files).
# ExecFormat produces linked executables or shared libraries.
# all sections are pre-resolved — relocations have been applied.
pub rec ExecFormat {
    ctx: ptr;

    # emit an executable from resolved sections.
    # entry: virtual address of the entry point symbol.
    emit: fun(ptr, *ExecSection, i32, u64, *OutputBuffer);

    # release all resources.
    destroy: fun(ptr);
}

# --- output buffer ---

# OutputBuffer: growable byte buffer for finalized output.
pub rec OutputBuffer {
    data:     *u8;
    size:     usize;
    capacity: usize;
    alloc:    *allocator.Allocator;
}

# ObjectFormat: object file format interface.
pub rec ObjectFormat {
    ctx: ptr;

    # add a section. returns section index.
    # flags are abstract section flag values from MASM.
    add_section: fun(ptr, str, u8, u32, usize) u64;

    # append data to a section.
    write: fun(ptr, u64, *u8, usize);

    # set total size of a section without writing data (BSS-like).
    set_size: fun(ptr, u64, usize);

    # get current write offset within a section.
    section_offset: fun(ptr, u64) usize;

    # add a symbol. returns symbol index.
    add_symbol: fun(ptr, *OFSymbol) u64;

    # add a relocation.
    add_reloc: fun(ptr, *OFReloc);

    # finalize: resolve references, write headers, produce output.
    finalize: fun(ptr, *OutputBuffer);

    # release all resources.
    destroy: fun(ptr);
}

# --- OutputBuffer operations ---

# buf_init: initialize an output buffer.
pub fun buf_init(buf: *OutputBuffer, alloc: *allocator.Allocator) {
    if (buf == nil) { ret; }
    buf.data = nil;
    buf.size = 0;
    buf.capacity = 0;
    buf.alloc = alloc;
}

# buf_write: append bytes to an output buffer.
pub fun buf_write(buf: *OutputBuffer, data: *u8, len: usize) bool {
    if (buf == nil || buf.alloc == nil || len == 0) { ret false; }

    val needed: usize = buf.size + len;
    if (needed > buf.capacity) {
        var new_cap: usize = 4096;
        if (buf.capacity > 0) { new_cap = buf.capacity * 2; }
        for (new_cap < needed) { new_cap = new_cap * 2; }

        val r: Result[*u8, allocator.AllocError] =
            allocator.allocator_resize[u8](buf.alloc, buf.data, buf.capacity, new_cap);
        if (result_is_err[*u8, allocator.AllocError](r)) { ret false; }

        buf.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        buf.capacity = new_cap;
    }

    var i: usize = 0;
    for (i < len) {
        buf.data[buf.size + i] = data[i];
        i = i + 1;
    }
    buf.size = buf.size + len;
    ret true;
}

# buf_write_u8: append a single byte.
pub fun buf_write_u8(buf: *OutputBuffer, v: u8) bool {
    var b: u8 = v;
    ret buf_write(buf, ?b, 1);
}

# buf_write_u16: append 16-bit little-endian.
pub fun buf_write_u16(buf: *OutputBuffer, v: u16) bool {
    var bytes: [2]u8;
    bytes[0] = (v & 255)::u8;
    bytes[1] = ((v >> 8) & 255)::u8;
    ret buf_write(buf, ?bytes[0], 2);
}

# buf_write_u32: append 32-bit little-endian.
pub fun buf_write_u32(buf: *OutputBuffer, v: u32) bool {
    var bytes: [4]u8;
    bytes[0] = (v & 255)::u8;
    bytes[1] = ((v >> 8) & 255)::u8;
    bytes[2] = ((v >> 16) & 255)::u8;
    bytes[3] = ((v >> 24) & 255)::u8;
    ret buf_write(buf, ?bytes[0], 4);
}

# buf_write_u64: append 64-bit little-endian.
pub fun buf_write_u64(buf: *OutputBuffer, v: u64) bool {
    var bytes: [8]u8;
    bytes[0] = (v & 255)::u8;
    bytes[1] = ((v >> 8) & 255)::u8;
    bytes[2] = ((v >> 16) & 255)::u8;
    bytes[3] = ((v >> 24) & 255)::u8;
    bytes[4] = ((v >> 32) & 255)::u8;
    bytes[5] = ((v >> 40) & 255)::u8;
    bytes[6] = ((v >> 48) & 255)::u8;
    bytes[7] = ((v >> 56) & 255)::u8;
    ret buf_write(buf, ?bytes[0], 8);
}

# buf_write_zeros: append zero bytes.
pub fun buf_write_zeros(buf: *OutputBuffer, len: usize) bool {
    if (buf == nil || len == 0) { ret false; }

    val needed: usize = buf.size + len;
    if (needed > buf.capacity) {
        var new_cap: usize = 4096;
        if (buf.capacity > 0) { new_cap = buf.capacity * 2; }
        for (new_cap < needed) { new_cap = new_cap * 2; }

        val r: Result[*u8, allocator.AllocError] =
            allocator.allocator_resize[u8](buf.alloc, buf.data, buf.capacity, new_cap);
        if (result_is_err[*u8, allocator.AllocError](r)) { ret false; }

        buf.data = result_unwrap_ok[*u8, allocator.AllocError](r);
        buf.capacity = new_cap;
    }

    var i: usize = 0;
    for (i < len) {
        buf.data[buf.size + i] = 0;
        i = i + 1;
    }
    buf.size = buf.size + len;
    ret true;
}

# buf_align: align buffer position to boundary.
pub fun buf_align(buf: *OutputBuffer, align: usize) bool {
    if (buf == nil || align <= 1) { ret true; }
    val mask: usize = align - 1;
    val aligned: usize = (buf.size + mask) & ~mask;
    val pad: usize = aligned - buf.size;
    if (pad > 0) { ret buf_write_zeros(buf, pad); }
    ret true;
}

# buf_patch_u32: overwrite a 32-bit value at a given offset.
pub fun buf_patch_u32(buf: *OutputBuffer, offset: usize, v: u32) {
    if (buf == nil || buf.data == nil || offset + 4 > buf.size) { ret; }
    buf.data[offset] = (v & 255)::u8;
    buf.data[offset + 1] = ((v >> 8) & 255)::u8;
    buf.data[offset + 2] = ((v >> 16) & 255)::u8;
    buf.data[offset + 3] = ((v >> 24) & 255)::u8;
}

# buf_patch_u64: overwrite a 64-bit value at a given offset.
pub fun buf_patch_u64(buf: *OutputBuffer, offset: usize, v: u64) {
    if (buf == nil || buf.data == nil || offset + 8 > buf.size) { ret; }
    buf.data[offset] = (v & 255)::u8;
    buf.data[offset + 1] = ((v >> 8) & 255)::u8;
    buf.data[offset + 2] = ((v >> 16) & 255)::u8;
    buf.data[offset + 3] = ((v >> 24) & 255)::u8;
    buf.data[offset + 4] = ((v >> 32) & 255)::u8;
    buf.data[offset + 5] = ((v >> 40) & 255)::u8;
    buf.data[offset + 6] = ((v >> 48) & 255)::u8;
    buf.data[offset + 7] = ((v >> 56) & 255)::u8;
}

# buf_destroy: free buffer resources.
pub fun buf_destroy(buf: *OutputBuffer) {
    if (buf == nil || buf.alloc == nil) { ret; }
    if (buf.data != nil) {
        allocator.allocator_free[u8](buf.alloc, buf.data, buf.capacity);
    }
    buf.data = nil;
    buf.size = 0;
    buf.capacity = 0;
}
