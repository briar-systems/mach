use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast: mach.compiler.ast;

# mach.compiler.type: type system for semantic analysis.
# ---
# provides type representation, comparison, and resolution.

# TypeKind: the category of a type.
# ---
# each variant represents a distinct type category.
pub uni TypeKind {
    # primitive types
    ty_void:    u8;
    ty_bool:    u8;
    ty_u8:      u8;
    ty_u16:     u8;
    ty_u32:     u8;
    ty_u64:     u8;
    ty_i8:      u8;
    ty_i16:     u8;
    ty_i32:     u8;
    ty_i64:     u8;
    ty_f32:     u8;
    ty_f64:     u8;
    ty_ptr:     u8;  # raw pointer (ptr)
    ty_usize:   u8;
    ty_isize:   u8;

    # composite types
    ty_pointer: u8;  # *T or &T
    ty_array:   u8;  # [N]T
    ty_record:  u8;  # rec { ... }
    ty_union:   u8;  # uni { ... }
    ty_fun:     u8;  # fun(...) T

    # special types
    ty_str:     u8;  # str (alias for &u8)
    ty_nil:     u8;  # nil literal type
    ty_error:   u8;  # error/unknown type
    ty_generic: u8;  # generic type parameter
}

# Type: a resolved type in the type system.
# ---
# kind:       category of this type
# name:       type name (for named types)
# inner:      inner type (for pointers, arrays)
# size:       size in bytes (0 if unknown)
# align:      alignment in bytes
# is_mutable: for pointers, true if *T, false if &T
# fields:     for records/unions, array of field types
# field_count: number of fields
# params:     for functions, parameter types
# param_count: number of parameters
# ret_type:   for functions, return type
# array_len:  for arrays, element count
pub rec Type {
    kind:        TypeKind;
    name:        str;
    inner:       *Type;
    size:        usize;
    align:       usize;
    is_mutable:  bool;
    fields:      *Type;
    field_count: i32;
    params:      *Type;
    param_count: i32;
    ret_type:    *Type;
    array_len:   usize;
}

# TypeContext: context for type resolution and caching.
# ---
# alloc:       allocator for type allocations
# types:       array of all allocated types
# type_count:  number of types
# type_cap:    allocated capacity
pub rec TypeContext {
    alloc:      *allocator.Allocator;
    types:      **Type;
    type_count: i32;
    type_cap:   i32;
}

# init_context: create a new type context.
# ---
# alloc: allocator to use
# ret:   Ok(TypeContext) on success, Err(str) on failure
pub fun init_context(alloc: *allocator.Allocator) Result[TypeContext, str] {
    if (alloc == nil) {
        ret err[TypeContext, str]("allocator is nil");
    }

    var ctx: TypeContext;
    ctx.alloc = alloc;
    ctx.types = nil;
    ctx.type_count = 0;
    ctx.type_cap = 0;

    ret ok[TypeContext, str](ctx);
}

# deinit_context: free all resources in a type context.
# ---
# ctx: context to clean up
# ret: none
pub fun deinit_context(ctx: *TypeContext) {
    if (ctx == nil || ctx.alloc == nil) {
        ret;
    }

    # TODO: free all types
    if (ctx.types != nil) {
        ctx.alloc.free[*Type](ctx.types, ctx.type_cap::usize);
    }
}

# create_type: allocate a new type.
# ---
# ctx:  type context
# kind: type kind
# ret:  Ok(*Type) on success, Err(str) on failure
pub fun create_type(ctx: *TypeContext, kind: TypeKind) Result[*Type, str] {
    if (ctx == nil) {
        ret err[*Type, str]("context is nil");
    }

    if (ctx.alloc == nil) {
        ret err[*Type, str]("allocator is nil");
    }

    val type_res: Result[*Type, allocator.AllocError] = ctx.alloc.zalloc[Type](1);
    if (type_res.is_err()) {
        ret err[*Type, str](type_res.unwrap_err());
    }

    val t: *Type = type_res.unwrap_ok();
    t.kind = kind;
    t.name = nil;
    t.inner = nil;
    t.size = 0;
    t.align = 0;
    t.is_mutable = false;
    t.fields = nil;
    t.field_count = 0;
    t.params = nil;
    t.param_count = 0;
    t.ret_type = nil;
    t.array_len = 0;

    # TODO: register type in context for caching

    ret ok[*Type, str](t);
}

# primitive_type: get a primitive type by kind.
# ---
# ctx:  type context
# kind: primitive type kind
# ret:  Ok(*Type) on success, Err(str) on failure
pub fun primitive_type(ctx: *TypeContext, kind: TypeKind) Result[*Type, str] {
    # TODO: cache primitive types
    ret create_type(ctx, kind);
}

# pointer_type: create a pointer type.
# ---
# ctx:     type context
# inner:   type being pointed to
# mutable: true for *T, false for &T
# ret:     Ok(*Type) on success, Err(str) on failure
pub fun pointer_type(ctx: *TypeContext, inner: *Type, mutable: bool) Result[*Type, str] {
    val res: Result[*Type, str] = create_type(ctx, TypeKind { ty_pointer: 0 });
    if (res.is_err()) {
        ret res;
    }

    val t: *Type = res.unwrap_ok();
    t.inner = inner;
    t.is_mutable = mutable;
    t.size = 8;  # assume 64-bit pointers
    t.align = 8;

    ret ok[*Type, str](t);
}

# array_type: create an array type.
# ---
# ctx:     type context
# inner:   element type
# len:     number of elements
# ret:     Ok(*Type) on success, Err(str) on failure
pub fun array_type(ctx: *TypeContext, inner: *Type, len: usize) Result[*Type, str] {
    val res: Result[*Type, str] = create_type(ctx, TypeKind { ty_array: 0 });
    if (res.is_err()) {
        ret res;
    }

    val t: *Type = res.unwrap_ok();
    t.inner = inner;
    t.array_len = len;

    if (inner != nil) {
        t.size = inner.size * len;
        t.align = inner.align;
    }

    ret ok[*Type, str](t);
}

# types_equal: check if two types are equal.
# ---
# a: first type
# b: second type
# ret: true if types are equal
pub fun types_equal(a: *Type, b: *Type) bool {
    if (a == nil && b == nil) {
        ret true;
    }

    if (a == nil || b == nil) {
        ret false;
    }

    # TODO: implement proper type comparison
    # for now, compare by pointer identity
    ret a == b;
}

# is_integer: check if a type is an integer type.
# ---
# t: type to check
# ret: true if t is an integer type
pub fun is_integer(t: *Type) bool {
    if (t == nil) {
        ret false;
    }

    # TODO: check kind against integer types
    ret false;
}

# is_float: check if a type is a floating-point type.
# ---
# t: type to check
# ret: true if t is a float type
pub fun is_float(t: *Type) bool {
    if (t == nil) {
        ret false;
    }

    # TODO: check kind against float types
    ret false;
}

# is_numeric: check if a type is numeric (integer or float).
# ---
# t: type to check
# ret: true if t is numeric
pub fun is_numeric(t: *Type) bool {
    ret is_integer(t) || is_float(t);
}

# is_pointer: check if a type is a pointer type.
# ---
# t: type to check
# ret: true if t is a pointer type
pub fun is_pointer(t: *Type) bool {
    if (t == nil) {
        ret false;
    }

    # TODO: check kind against pointer types
    ret false;
}

# type_size: get the size of a type in bytes.
# ---
# t: type to query
# ret: size in bytes, or 0 if unknown
pub fun type_size(t: *Type) usize {
    if (t == nil) {
        ret 0;
    }
    ret t.size;
}

# type_align: get the alignment of a type in bytes.
# ---
# t: type to query
# ret: alignment in bytes, or 0 if unknown
pub fun type_align(t: *Type) usize {
    if (t == nil) {
        ret 0;
    }
    ret t.align;
}
