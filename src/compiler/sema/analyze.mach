use std.types.bool;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use ast:      mach.compiler.ast;
use symbol:   mach.compiler.symbol;
use comptime: mach.compiler.comptime;

use mach.compiler.sema.sema;
use mach.compiler.sema.errors;
use mach.compiler.sema.collect;
use mach.compiler.sema.resolve;
use mach.compiler.sema.check;

# mach.compiler.sema.analyze: top-level analysis entry point.

# analyze: perform semantic analysis on the AST.
# ---
# sema:    analyzer context
# module:  module root node
# file:    source file path
# src:     source text
# cctx:    compile-time context
# ret:     Ok(true) if analysis succeeds, Err(str) if errors occurred
pub fun analyze(sema: *Sema, module: *ast.Node, file: str, src: str, cctx: *comptime.ComptimeContext) Result[bool, str] {
    if (sema == nil || module == nil) {
        ret err[bool, str]("invalid arguments");
    }

    sema.file_path = file;
    sema.source = src;
    sema.comptime_ctx = cctx;

    # set main module path for symbol mangling
    if (sema.module_path == nil) {
        if (sema.project_id != nil) {
            sema.module_path = sema.project_id;
        } or {
            sema.module_path = "main";
        }
    }

    # reset error state
    sema.error_count = 0;
    sema.had_error = false;

    # create symbol table for main module if not already present
    if (sema.symbols == nil) {
        val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
        if (result_is_err[symbol.Table, str](table_res)) {
            ret err[bool, str]("failed to create symbol table");
        }

        val table_ptr_res: Result[*symbol.Table, allocator.AllocError] = allocator.allocator_alloc[symbol.Table](sema.alloc, 1);
        if (result_is_err[*symbol.Table, allocator.AllocError](table_ptr_res)) {
            ret err[bool, str]("failed to allocate symbol table");
        }
        val table_ptr: *symbol.Table = result_unwrap_ok[*symbol.Table, allocator.AllocError](table_ptr_res);
        @table_ptr = result_unwrap_ok[symbol.Table, str](table_res);
        sema.symbols = table_ptr;
    }

    # create a SemaModule for the main module so aliases/imports are tracked
    if (sema.current_module == nil) {
        val main_mod_res: Result[*SemaModule, allocator.AllocError] = allocator.allocator_alloc[SemaModule](sema.alloc, 1);
        if (result_is_ok[*SemaModule, allocator.AllocError](main_mod_res)) {
            val main_mod: *SemaModule = result_unwrap_ok[*SemaModule, allocator.AllocError](main_mod_res);
            main_mod.path = sema.module_path;
            main_mod.file_path = file;
            main_mod.source = src;
            main_mod.ast = module;
            main_mod.is_analyzed = false;
            main_mod.next = nil;
            main_mod.aliases = nil;
            main_mod.imports = nil;
            main_mod.table = sema.symbols;
            sema.current_module = main_mod;
        }
    }

    # create root scope
    val push_res: Result[bool, str] = push_scope(sema);
    if (result_is_err[bool, str](push_res)) {
        ret err[bool, str]("failed to create root scope");
    }

    # pass 1: collect all declarations and add to symbol table
    collect_declarations(sema, module);

    # pass 2: resolve types and build type information
    # skip if declaration collection had errors to avoid cascading
    if (sema.error_count == 0) {
        resolve_types(sema, module);
    }

    # pass 2b: resolve types in function bodies
    # after this, every node.ty is set and every call node.symbol is resolved
    if (sema.error_count == 0) {
        resolve_functions(sema, module);
    }

    # pass 3: validate function bodies (read-only)
    # purely checks types — never mutates AST or symbol table
    if (sema.error_count == 0) {
        check_functions(sema, module);
    }

    # pass 4: finalize
    if (sema.error_count == 0) {
        sema.current_module.is_analyzed = true;
    }

    # cleanup
    for (sema.current_scope != nil) {
        pop_scope(sema);
    }

    # check for errors
    if (sema.error_count > 0) {
        print_errors(sema);
        ret err[bool, str]("semantic errors found");
    }

    ret ok[bool, str](true);
}
