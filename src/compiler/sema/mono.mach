# mach.compiler.sema.mono: monomorphization cache and name mangling
#
# caches monomorphized function and type instances keyed by mangled names.
# type instantiation is handled by resolve.mach via scope-based substitution;
# this module provides the cache, registration, and Itanium-style mangling.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.system.panic;

use allocator: std.allocator;
use map:       std.collections.map;
use set:       std.collections.set;
use mem:       std.memory;
use ast:       mach.compiler.parse.ast;
use type:      mach.compiler.sema.type;
use module:    mach.compiler.sema.module;
use st:        mach.compiler.sema.sidetable;

val MAX_DEPTH:      u32 = 64;
val INITIAL_FN_CAP: u32 = 16;

# a monomorphized function instance
# ---
# mangled_name:  mangled name encoding the concrete type arguments
# func_node:     AST node of the original function
# func_store:    node store containing the instantiated AST
# func_type:     resolved function type
# param_names:   parameter name array
# param_types:   parameter type array
# param_count:   number of parameters
# origin_module: module where the generic function was defined
# body_resolved: true if the body has been type-checked
pub rec FnInst {
    mangled_name:   str;
    func_node:      ast.NodeId;
    func_store:     ast.NodeStore;
    func_type:      type.TypeId;
    param_names:    *str;
    param_types:    *type.TypeId;
    param_count:    u32;
    type_args:      *type.TypeId;
    type_arg_count: u32;
    origin_module:  module.ModuleId;
    body_resolved:  bool;
    scope_id:       u32;
    inst_etm:       st.ExprTypeMap;
    inst_nsm:       st.NodeSymMap;
}

# cache of monomorphized types and functions
# ---
# alloc:     backing allocator
# type_map:  mangled name to resolved type id
# fn_map:    mangled name to fn_insts index
# fn_insts:  array of monomorphized function instances
# fn_count:  number of instances
# fn_cap:    allocated capacity for fn_insts
# in_flight: set of mangled names currently being instantiated (cycle detection)
# depth:     current instantiation depth (overflow guard)
pub rec MonoCache {
    alloc:     *allocator.Allocator;
    type_map:  map.Map[str, type.TypeId];
    fn_map:    map.Map[str, u32];
    fn_insts:  *FnInst;
    fn_count:  u32;
    fn_cap:    u32;
    in_flight: set.Set[str];
    depth:     u32;
}

# init: create an empty monomorphization cache
# ---
# alloc: allocator for all internal storage
# ret:   initialized MonoCache
pub fun init(alloc: *allocator.Allocator) MonoCache {
    var cache: MonoCache;
    cache.alloc     = alloc;
    cache.type_map  = map.init[str, type.TypeId](alloc, map.hash_str, map.eq_str);
    cache.fn_map    = map.init[str, u32](alloc, map.hash_str, map.eq_str);
    cache.fn_insts  = nil;
    cache.fn_count  = 0;
    cache.fn_cap    = 0;
    cache.in_flight = set.init[str](alloc, map.hash_str, map.eq_str);
    cache.depth     = 0;
    ret cache;
}

# dnit: destroy the monomorphization cache
# ---
# cache: cache to destroy
pub fun dnit(cache: *MonoCache) {
    if (cache == nil) { ret; }

    map.dnit[str, type.TypeId](?cache.type_map);
    map.dnit[str, u32](?cache.fn_map);
    set.dnit[str](?cache.in_flight);

    if (cache.fn_insts != nil && cache.fn_cap > 0) {
        allocator.deallocate[FnInst](cache.alloc, cache.fn_insts, cache.fn_cap::usize);
        cache.fn_insts = nil;
    }

    cache.fn_count = 0;
    cache.fn_cap   = 0;
    cache.depth    = 0;
}

# fn_count: return the number of instantiated functions
# ---
# cache: mono cache
# ret:   count
pub fun fn_count(cache: *MonoCache) u32 {
    ret cache.fn_count;
}

# get_fn: return a pointer to the function instance at the given index
# ---
# cache: mono cache
# idx:   index into fn_insts
# ret:   pointer to FnInst
pub fun get_fn(cache: *MonoCache, idx: u32) *FnInst {
    ret ?cache.fn_insts[idx];
}

pub fun lookup_fn(cache: *MonoCache, mangled: str) type.TypeId {
    val key: str = mangled;
    val res: Result[*u32, str] = map.get[str, u32](?cache.fn_map, ?key);
    if (is_ok[*u32, str](res)) {
        val idx: u32 = @unwrap_ok[*u32, str](res);
        ret cache.fn_insts[idx].func_type;
    }
    ret type.TYPE_NIL;
}

pub fun lookup_type(cache: *MonoCache, mangled: str) type.TypeId {
    val key: str = mangled;
    val res: Result[*type.TypeId, str] = map.get[str, type.TypeId](?cache.type_map, ?key);
    if (is_ok[*type.TypeId, str](res)) {
        ret @unwrap_ok[*type.TypeId, str](res);
    }
    ret type.TYPE_NIL;
}

pub fun register_type(cache: *MonoCache, mangled: str, tid: type.TypeId) {
    map.insert[str, type.TypeId](?cache.type_map, mangled, tid);
}

pub fun register_fn(cache: *MonoCache, mangled: str,
                    func_node: ast.NodeId, func_store: ast.NodeStore,
                    func_type: type.TypeId,
                    origin_module: module.ModuleId,
                    type_args: *type.TypeId, type_arg_count: u32) {
    grow_fn_insts(cache);

    val idx: u32 = cache.fn_count;
    val inst: *FnInst = ?cache.fn_insts[idx];
    inst.mangled_name  = mangled;
    inst.func_node     = func_node;
    inst.func_store    = func_store;
    inst.func_type     = func_type;
    inst.param_names    = nil;
    inst.param_types    = nil;
    inst.param_count    = 0;
    inst.type_args      = nil;
    inst.type_arg_count = 0;
    inst.origin_module  = origin_module;
    inst.body_resolved  = false;
    inst.scope_id       = 0;
    inst.inst_etm.types = nil;
    inst.inst_etm.count = 0;

    if (type_args != nil && type_arg_count > 0) {
        val res: Result[*type.TypeId, str] = allocator.allocate[type.TypeId](cache.alloc, type_arg_count::usize);
        if (res.tag) {
            inst.type_args      = res.value.ok;
            inst.type_arg_count = type_arg_count;
            var ti: u32 = 0;
            for (ti < type_arg_count) {
                inst.type_args[ti] = type_args[ti];
                ti = ti + 1;
            }
        }
    }

    cache.fn_count = cache.fn_count + 1;
    map.insert[str, u32](?cache.fn_map, mangled, idx);
}

# mangle_name: build an Itanium-style mangled name from a base name and type arguments
# ---
# cache: mono cache (for allocator)
# base:  base name of the generic symbol
# args:  array of concrete TypeId arguments
# count: number of arguments
# types: type table for resolving type names
# ret:   mangled name string, or nil on failure
pub fun mangle_name(cache: *MonoCache, module_path: str, base: str,
                    args: *type.TypeId, count: u32,
                    types: *type.TypeTable) str {
    val buf_cap: u32 = 2048;
    val res_buf: Result[*u8, str] = allocator.allocate[u8](cache.alloc, buf_cap::usize);
    if (is_err[*u8, str](res_buf)) { ret nil; }
    var buf: *u8 = unwrap_ok[*u8, str](res_buf);
    var off: u32 = 0;

    buf[off] = '_'; off = off + 1;
    buf[off] = 'M'; off = off + 1;

    if (module_path != nil) {
        var mi: usize = 0;
        var seg_start: usize = 0;
        val mp_len: usize = str_len(module_path);
        var pi: usize = 0;
        for (pi <= mp_len && off < buf_cap - 112) {
            if (pi == mp_len || module_path[pi] == '.') {
                val seg_len: usize = pi - seg_start;
                if (seg_len > 0) {
                    off = write_u32(buf, off, buf_cap, seg_len::u32);
                    var j: usize = 0;
                    for (j < seg_len) {
                        buf[off] = module_path[seg_start + j];
                        off = off + 1;
                        j = j + 1;
                    }
                }
                seg_start = pi + 1;
            }
            pi = pi + 1;
        }
    }

    buf[off] = 'N'; off = off + 1;

    if (base != nil) {
        val nm_len: usize = str_len(base);
        off = write_u32(buf, off, buf_cap, nm_len::u32);
        var bi: usize = 0;
        for (bi < nm_len && off < buf_cap - 32) {
            buf[off] = base[bi];
            off = off + 1;
            bi = bi + 1;
        }
    }

    if (off < buf_cap - 1) { buf[off] = 'I'; off = off + 1; }

    var i: u32 = 0;
    for (i < count && off < buf_cap - 12) {
        off = encode_type_code(buf, off, buf_cap - 2, types, args[i]);
        i = i + 1;
    }

    if (off < buf_cap - 1) { buf[off] = 'E'; off = off + 1; }
    buf[off] = 0;

    ret buf::str;
}

fun encode_type_code(buf: *u8, off: u32, cap: u32,
                     types: *type.TypeTable, tid: type.TypeId) u32 {
    val cid: type.TypeId = type.canonical(types, tid);
    val t: *type.Type = type.get(types, cid);
    var pos: u32 = off;

    if (t.kind == type.TK_VOID)       { if (pos < cap) { buf[pos] = 'v'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_U8)         { if (pos < cap) { buf[pos] = 'h'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_U16)        { if (pos < cap) { buf[pos] = 't'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_U32)        { if (pos < cap) { buf[pos] = 'j'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_U64)        { if (pos < cap) { buf[pos] = 'm'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_I8)         { if (pos < cap) { buf[pos] = 'a'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_I16)        { if (pos < cap) { buf[pos] = 's'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_I32)        { if (pos < cap) { buf[pos] = 'i'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_I64)        { if (pos < cap) { buf[pos] = 'x'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_F32)        { if (pos < cap) { buf[pos] = 'f'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_F64)        { if (pos < cap) { buf[pos] = 'd'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_BOOL)       { if (pos < cap) { buf[pos] = 'b'; pos = pos + 1; } ret pos; }
    if (t.kind == type.TK_OPAQUE_PTR) { if (pos + 1 < cap) { buf[pos] = 'P'; buf[pos + 1] = 'v'; pos = pos + 2; } ret pos; }

    if (t.kind == type.TK_POINTER) {
        if (pos < cap) { buf[pos] = 'P'; pos = pos + 1; }
        pos = encode_type_code(buf, pos, cap, types, t.pointee);
        ret pos;
    }

    if (t.kind == type.TK_ARRAY) {
        if (pos < cap) { buf[pos] = 'A'; pos = pos + 1; }
        pos = write_u32(buf, pos, cap, t.array_len);
        if (pos < cap) { buf[pos] = '_'; pos = pos + 1; }
        pos = encode_type_code(buf, pos, cap, types, t.elem);
        ret pos;
    }

    if (t.name != nil) {
        if (t.decl_sym != type.DECL_SYM_NONE) {
            pos = write_u32(buf, pos, cap, t.decl_sym);
            if (pos < cap) { buf[pos] = '_'; pos = pos + 1; }
        }
        val name_len: usize = str_len(t.name);
        pos = write_u32(buf, pos, cap, name_len::u32);
        var ni: usize = 0;
        for (ni < name_len && pos < cap) {
            buf[pos] = t.name[ni];
            pos = pos + 1;
            ni = ni + 1;
        }
        ret pos;
    }

    if (pos < cap) { buf[pos] = 'v'; pos = pos + 1; }
    ret pos;
}

fun write_u32(buf: *u8, off: u32, cap: u32, val_in: u32) u32 {
    var digits: [10]u8;
    var count: u32 = 0;
    var v: u32 = val_in;

    if (v == 0) {
        if (off < cap) { buf[off] = '0'; }
        ret off + 1;
    }

    for (v > 0) {
        digits[count] = (v % 10)::u8 + '0';
        count = count + 1;
        v = v / 10;
    }

    var pos: u32 = off;
    var di: u32 = count;
    for (di > 0 && pos < cap) {
        di = di - 1;
        buf[pos] = digits[di];
        pos = pos + 1;
    }

    ret pos;
}

fun grow_fn_insts(cache: *MonoCache) {
    if (cache.fn_count < cache.fn_cap) { ret; }

    var new_cap: u32 = INITIAL_FN_CAP;
    if (cache.fn_cap > 0) {
        new_cap = cache.fn_cap * 2;
    }

    val res_realloc: Result[*FnInst, str] = allocator.reallocate[FnInst](
        cache.alloc, cache.fn_insts, cache.fn_cap::usize, new_cap::usize
    );
    if (is_err[*FnInst, str](res_realloc)) { panic("mono.grow_fn_insts: allocation failed\n"); }

    cache.fn_insts = unwrap_ok[*FnInst, str](res_realloc);
    cache.fn_cap   = new_cap;
}
