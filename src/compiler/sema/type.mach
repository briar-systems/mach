# mach.compiler.sema.type: type representation, construction, and layout
#
# flat TypeTable indexed by TypeId. primitives occupy fixed slots 0-13,
# TK_ERROR occupies slot 14. all compound types are appended via add().
# ---
# provides type storage, predicates, equality, compatibility, and layout
# computation for the semantic analysis type system.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use page:      std.allocator.page;

pub def TypeId: u32;
pub val TYPE_NIL: TypeId = 0xFFFFFFFF;

pub def TypeKind: u8;
pub val TK_VOID:          TypeKind = 0;
pub val TK_U8:            TypeKind = 1;
pub val TK_U16:           TypeKind = 2;
pub val TK_U32:           TypeKind = 3;
pub val TK_U64:           TypeKind = 4;
pub val TK_I8:            TypeKind = 5;
pub val TK_I16:           TypeKind = 6;
pub val TK_I32:           TypeKind = 7;
pub val TK_I64:           TypeKind = 8;
pub val TK_F32:           TypeKind = 9;
pub val TK_F64:           TypeKind = 10;
pub val TK_BOOL:          TypeKind = 11;
pub val TK_OPAQUE_PTR:    TypeKind = 12;
pub val TK_NIL:           TypeKind = 13;
pub val TK_POINTER:       TypeKind = 14;
pub val TK_ARRAY:         TypeKind = 15;
pub val TK_RECORD:        TypeKind = 16;
pub val TK_UNION:         TypeKind = 17;
pub val TK_FUN:           TypeKind = 18;
pub val TK_GENERIC_PARAM: TypeKind = 19;
pub val TK_ALIAS:         TypeKind = 20;
pub val TK_ERROR:         TypeKind = 255;

val PRIM_SLOT_COUNT: u32 = 15;
val INIT_CAP:        u32 = 64;
val MAX_ALIAS_DEPTH: u32 = 64;

# a field in a record or union type
# ---
# name:    field name
# type_id: type of this field
# offset:  byte offset from start of containing type
pub rec TypeField {
    name:    str;
    type_id: TypeId;
    offset:  u32;
}

# a resolved type in the type system
# ---
# kind:           category of this type
# name:           type name (for named types)
# size:           size in bytes
# align:          alignment in bytes
# pointee:        for pointers, the pointee type
# elem:           for arrays, the element type
# array_len:      for arrays, element count
# underlying:     for aliases, the underlying type
# fields:         for records/unions, array of fields
# field_count:    number of fields
# params:         for functions, parameter types
# param_count:    number of parameters
# ret_type:       for functions, return type
# is_variadic:    for functions, true if variadic
# generic_params: for generic declarations, parameter names
# generic_args:   for instantiated types, concrete type arguments
# gp_count:       number of generic params or args
# base_type:      for instantiated types, link to original generic
# decl_sym:       back-pointer to declaring symbol (opaque index)
pub rec Type {
    kind:           TypeKind;
    name:           str;
    size:           u32;
    align:          u32;
    pointee:        TypeId;
    elem:           TypeId;
    array_len:      u32;
    underlying:     TypeId;
    fields:         *TypeField;
    field_count:    u16;
    params:         *TypeId;
    param_count:    u16;
    ret_type:       TypeId;
    is_variadic:    bool;
    generic_params: *str;
    generic_args:   *TypeId;
    gp_count:       u16;
    base_type:      TypeId;
    decl_sym:       u32;
}

# flat type table indexed by TypeId
# ---
# alloc:     allocator for the types array
# types:     contiguous array of Type records
# count:     number of types in the table
# cap:       allocated capacity
# ptr_size:  pointer size for this target
# ptr_align: pointer alignment for this target
pub rec TypeTable {
    alloc:     &allocator.Allocator;
    types:     *Type;
    count:     u32;
    cap:       u32;
    ptr_size:  u32;
    ptr_align: u32;
}

# init: initialize a type table and pre-populate primitive slots
# ---
# alloc:     allocator for heap storage
# ptr_size:  pointer size in bytes for this target
# ptr_align: pointer alignment in bytes for this target
# ret:       initialized TypeTable
pub fun init(alloc: &allocator.Allocator, ptr_size: u32, ptr_align: u32) TypeTable {
    var table: TypeTable;
    table.alloc     = alloc;
    table.ptr_size  = ptr_size;
    table.ptr_align = ptr_align;
    table.count     = 0;
    table.cap       = 0;
    table.types     = nil;

    grow(?table, INIT_CAP);

    fill_prim(?table, TK_VOID,       "void", 0,        0);
    fill_prim(?table, TK_U8,         "u8",   1,        1);
    fill_prim(?table, TK_U16,        "u16",  2,        2);
    fill_prim(?table, TK_U32,        "u32",  4,        4);
    fill_prim(?table, TK_U64,        "u64",  8,        8);
    fill_prim(?table, TK_I8,         "i8",   1,        1);
    fill_prim(?table, TK_I16,        "i16",  2,        2);
    fill_prim(?table, TK_I32,        "i32",  4,        4);
    fill_prim(?table, TK_I64,        "i64",  8,        8);
    fill_prim(?table, TK_F32,        "f32",  4,        4);
    fill_prim(?table, TK_F64,        "f64",  8,        8);
    fill_prim(?table, TK_BOOL,       "bool", 1,        1);
    fill_prim(?table, TK_OPAQUE_PTR, "ptr",  ptr_size, ptr_align);
    fill_prim(?table, TK_NIL,        "nil",  0,        0);

    val err_id: TypeId = add(?table, TK_ERROR);
    val err_t: *Type = ?table.types[err_id];
    err_t.name = "<error>";

    init_va_list(?table);

    ret table;
}

# dnit: deallocate the types array
# ---
# table: table to tear down
pub fun dnit(table: *TypeTable) {
    if (table == nil) { ret; }
    if (table.types != nil && table.cap > 0) {
        allocator.deallocate[Type](table.alloc, table.types, table.cap::usize);
    }
    table.types = nil;
    table.count = 0;
    table.cap   = 0;
}

# get: return a pointer to the type at the given index
# ---
# table: type table
# id:    index into the table
# ret:   pointer to the Type record
pub fun get(table: &TypeTable, id: TypeId) &Type {
    if (id::u32 >= table.count) {
        ret ?table.types[0];
    }
    ret ?table.types[id];
}

# add: append a zeroed type with the given kind and return its index
# ---
# table: type table
# kind:  kind tag for the new type
# ret:   TypeId of the newly added type
pub fun add(table: *TypeTable, kind: TypeKind) TypeId {
    if (table.count >= table.cap) {
        var new_cap: u32 = table.cap * 2;
        if (new_cap < INIT_CAP) {
            new_cap = INIT_CAP;
        }
        grow(table, new_cap);
    }

    val id: TypeId = table.count;
    val t: *Type = ?table.types[id];

    t.kind       = kind;
    t.name       = nil;
    t.size       = 0;
    t.align      = 0;
    t.pointee    = TYPE_NIL;
    t.elem       = TYPE_NIL;
    t.array_len  = 0;
    t.underlying = TYPE_NIL;
    t.fields     = nil;
    t.field_count = 0;
    t.params     = nil;
    t.param_count = 0;
    t.ret_type   = TYPE_NIL;
    t.is_variadic = false;
    t.generic_params = nil;
    t.generic_args   = nil;
    t.gp_count   = 0;
    t.base_type  = TYPE_NIL;
    t.decl_sym   = 0xFFFFFFFF;

    table.count = table.count + 1;
    ret id;
}

# primitive: return the TypeId for a primitive kind
#
# for TK_VOID through TK_NIL, the kind value is the table index directly.
# for TK_ERROR, return 14. for anything else, return TYPE_NIL.
# ---
# table: type table
# kind:  primitive kind tag
# ret:   TypeId or TYPE_NIL if not a primitive
pub fun primitive(table: &TypeTable, kind: TypeKind) TypeId {
    if (kind::u8 <= TK_NIL::u8) {
        ret kind::TypeId;
    }
    if (kind == TK_ERROR) {
        ret 14;
    }
    ret TYPE_NIL;
}

# primitive_by_name: look up a primitive type by name
# ---
# table: type table
# name:  type name string
# ret:   TypeId or TYPE_NIL if not a primitive name
pub fun primitive_by_name(table: &TypeTable, name: str) TypeId {
    if (name == nil) { ret TYPE_NIL; }

    if (str_equals(name, "void")) { ret 0; }
    if (str_equals(name, "u8"))   { ret 1; }
    if (str_equals(name, "u16"))  { ret 2; }
    if (str_equals(name, "u32"))  { ret 3; }
    if (str_equals(name, "u64"))  { ret 4; }
    if (str_equals(name, "i8"))   { ret 5; }
    if (str_equals(name, "i16"))  { ret 6; }
    if (str_equals(name, "i32"))  { ret 7; }
    if (str_equals(name, "i64"))  { ret 8; }
    if (str_equals(name, "f32"))  { ret 9; }
    if (str_equals(name, "f64"))  { ret 10; }
    if (str_equals(name, "bool")) { ret 11; }
    if (str_equals(name, "ptr"))  { ret 12; }
    if (str_equals(name, "nil"))  { ret 13; }

    ret TYPE_NIL;
}

# make_pointer: create a pointer type
# ---
# table:   type table
# pointee: TypeId of the pointee
# ret:     TypeId of the new pointer type
pub fun make_pointer(table: *TypeTable, pointee: TypeId) TypeId {
    val id: TypeId = add(table, TK_POINTER);
    val t: *Type = ?table.types[id];
    t.pointee = pointee;
    t.size    = table.ptr_size;
    t.align   = table.ptr_align;
    ret id;
}

# make_array: create an array type
# ---
# table: type table
# elem:  TypeId of the element type
# len:   number of elements
# ret:   TypeId of the new array type
pub fun make_array(table: *TypeTable, elem: TypeId, len: u32) TypeId {
    val id: TypeId = add(table, TK_ARRAY);
    val t: *Type = ?table.types[id];
    t.elem      = elem;
    t.array_len = len;

    val et: &Type = get(table, elem);
    t.size  = et.size * len;
    t.align = et.align;

    ret id;
}

# make_record: create a record type
#
# does not compute layout; caller must invoke compute_record_layout after
# populating fields with resolved type ids.
# ---
# table: type table
# name:  record name
# fields: array of TypeField (offsets not yet set)
# count:  number of fields
# ret:    TypeId of the new record type
pub fun make_record(table: *TypeTable, name: str, fields: *TypeField, count: u16) TypeId {
    val id: TypeId = add(table, TK_RECORD);
    val t: *Type = ?table.types[id];
    t.name        = name;
    t.fields      = fields;
    t.field_count = count;
    ret id;
}

# make_union: create a union type
# ---
# table:  type table
# name:   union name
# fields: array of TypeField
# count:  number of fields
# ret:    TypeId of the new union type
pub fun make_union(table: *TypeTable, name: str, fields: *TypeField, count: u16) TypeId {
    val id: TypeId = add(table, TK_UNION);
    val t: *Type = ?table.types[id];
    t.name        = name;
    t.fields      = fields;
    t.field_count = count;
    ret id;
}

# make_function: create a function type
# ---
# table:    type table
# params:   array of parameter TypeIds
# count:    number of parameters
# ret_type: return type
# variadic: true if function is variadic
# ret:      TypeId of the new function type
pub fun make_function(table: *TypeTable, params: *TypeId, count: u16, ret_type: TypeId, variadic: bool) TypeId {
    val id: TypeId = add(table, TK_FUN);
    val t: *Type = ?table.types[id];
    t.params      = params;
    t.param_count = count;
    t.ret_type    = ret_type;
    t.is_variadic = variadic;
    t.size        = table.ptr_size;
    t.align       = table.ptr_align;
    ret id;
}

# make_alias: create a type alias
# ---
# table:      type table
# name:       alias name
# underlying: TypeId of the aliased type
# ret:        TypeId of the new alias type
pub fun make_alias(table: *TypeTable, name: str, underlying: TypeId) TypeId {
    val id: TypeId = add(table, TK_ALIAS);
    val t: *Type = ?table.types[id];
    t.name       = name;
    t.underlying = underlying;

    val ut: &Type = get(table, underlying);
    t.size  = ut.size;
    t.align = ut.align;

    ret id;
}

# canonical: follow TK_ALIAS chain until a non-alias type is reached
# ---
# table: type table
# id:    starting TypeId
# ret:   canonical (non-alias) TypeId
pub fun canonical(table: &TypeTable, id: TypeId) TypeId {
    var cur: TypeId = id;
    var depth: u32 = 0;
    for (depth < MAX_ALIAS_DEPTH) {
        val t: &Type = get(table, cur);
        if (t.kind != TK_ALIAS) {
            ret cur;
        }
        cur = t.underlying;
        depth = depth + 1;
    }
    ret cur;
}

# is_integer: check if type is an integer (u8..u64, i8..i64)
# ---
# table: type table
# id:    TypeId to check
# ret:   true if integer type
pub fun is_integer(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind >= TK_U8 && t.kind <= TK_I64;
}

# is_float: check if type is a floating-point type
# ---
# table: type table
# id:    TypeId to check
# ret:   true if float type
pub fun is_float(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind == TK_F32 || t.kind == TK_F64;
}

# is_numeric: check if type is numeric (integer or float)
# ---
# table: type table
# id:    TypeId to check
# ret:   true if numeric type
pub fun is_numeric(table: &TypeTable, id: TypeId) bool {
    ret is_integer(table, id) || is_float(table, id);
}

# is_pointer: check if type is a pointer (typed or opaque)
# ---
# table: type table
# id:    TypeId to check
# ret:   true if pointer type
pub fun is_pointer(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind == TK_POINTER || t.kind == TK_OPAQUE_PTR;
}

pub fun is_pointer_like(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind == TK_POINTER || t.kind == TK_OPAQUE_PTR || t.kind == TK_FUN;
}

# is_record: check if type is a record
# ---
# table: type table
# id:    TypeId to check
# ret:   true if record type
pub fun is_record(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind == TK_RECORD;
}

# is_aggregate: check if type is an aggregate (record, union, or array)
# ---
# table: type table
# id:    TypeId to check
# ret:   true if aggregate type
pub fun is_aggregate(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind == TK_RECORD || t.kind == TK_UNION || t.kind == TK_ARRAY;
}

# is_error: check if type is the error sentinel
# ---
# table: type table
# id:    TypeId to check
# ret:   true if error type
pub fun is_error(table: &TypeTable, id: TypeId) bool {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);
    ret t.kind == TK_ERROR;
}

# types_equal: check if two types are equal
#
# resolves aliases, then compares canonical ids. for pointers and arrays,
# falls back to structural comparison if ids differ.
# ---
# table: type table
# a:     first TypeId
# b:     second TypeId
# ret:   true if types are equal
pub fun types_equal(table: &TypeTable, a: TypeId, b: TypeId) bool {
    val ca: TypeId = canonical(table, a);
    val cb: TypeId = canonical(table, b);

    if (ca == cb) {
        ret true;
    }

    val ta: &Type = get(table, ca);
    val tb: &Type = get(table, cb);

    if (ta.kind != tb.kind) {
        ret false;
    }

    if (ta.kind == TK_POINTER) {
        ret types_equal(table, ta.pointee, tb.pointee);
    }

    if (ta.kind == TK_ARRAY) {
        ret ta.array_len == tb.array_len && types_equal(table, ta.elem, tb.elem);
    }

    if (ta.kind == TK_FUN) {
        if (ta.param_count != tb.param_count) { ret false; }
        if (ta.is_variadic != tb.is_variadic) { ret false; }
        if (!types_equal(table, ta.ret_type, tb.ret_type)) { ret false; }
        var i: u16 = 0;
        for (i < ta.param_count) {
            if (!types_equal(table, ta.params[i], tb.params[i])) { ret false; }
            i = i + 1;
        }
        ret true;
    }

    if (ta.kind == TK_RECORD || ta.kind == TK_UNION) {
        if (ta.name != nil && tb.name != nil && str_equals(ta.name, tb.name)) {
            if (ta.field_count == tb.field_count) {
                var i: u16 = 0;
                for (i < ta.field_count) {
                    if (ta.fields == nil || tb.fields == nil) { ret false; }
                    if (!str_equals(ta.fields[i].name, tb.fields[i].name)) { ret false; }
                    if (!types_equal(table, ta.fields[i].type_id, tb.fields[i].type_id)) { ret false; }
                    i = i + 1;
                }
                ret true;
            }
        }
        ret false;
    }

    ret false;
}

# can_assign: check if a value of type `from` can be assigned to a location of type `to`
# ---
# table: type table
# from:  source TypeId
# to:    target TypeId
# ret:   true if assignment is valid
pub fun can_assign(table: &TypeTable, from: TypeId, to: TypeId) bool {
    if (types_equal(table, from, to)) {
        ret true;
    }

    val cf: TypeId = canonical(table, from);
    val ct: TypeId = canonical(table, to);
    val tf: &Type = get(table, cf);
    val tt: &Type = get(table, ct);

    # nil assignable to any pointer or function type
    if (tf.kind == TK_NIL && (tt.kind == TK_POINTER || tt.kind == TK_OPAQUE_PTR || tt.kind == TK_FUN)) {
        ret true;
    }

    # opaque ptr <-> any typed pointer
    if (tf.kind == TK_OPAQUE_PTR && tt.kind == TK_POINTER) {
        ret true;
    }
    if (tf.kind == TK_POINTER && tt.kind == TK_OPAQUE_PTR) {
        ret true;
    }

    # integer widening: smaller unsigned/signed -> larger of same signedness
    if (is_integer(table, cf) && is_integer(table, ct)) {
        val from_unsigned: bool = tf.kind >= TK_U8 && tf.kind <= TK_U64;
        val to_unsigned: bool = tt.kind >= TK_U8 && tt.kind <= TK_U64;
        if (from_unsigned == to_unsigned && tf.size <= tt.size) {
            ret true;
        }
    }

    ret false;
}

# can_cast: check if a cast from `from` to `to` is valid
# ---
# table: type table
# from:  source TypeId
# to:    target TypeId
# ret:   true if cast is valid
pub fun can_cast(table: &TypeTable, from: TypeId, to: TypeId) bool {
    if (can_assign(table, from, to)) {
        ret true;
    }

    val cf: TypeId = canonical(table, from);
    val ct: TypeId = canonical(table, to);
    val tf: &Type = get(table, cf);
    val tt: &Type = get(table, ct);

    # numeric <-> numeric
    if (is_numeric(table, cf) && is_numeric(table, ct)) {
        ret true;
    }

    # integer <-> pointer/function
    if (is_integer(table, cf) && is_pointer_like(table, ct)) {
        ret true;
    }
    if (is_pointer_like(table, cf) && is_integer(table, ct)) {
        ret true;
    }

    # pointer/function <-> pointer/function
    if (is_pointer_like(table, cf) && is_pointer_like(table, ct)) {
        ret true;
    }

    # same-size record/union <-> numeric bitcast
    if (tf.size > 0 && tf.size == tt.size) {
        if ((tf.kind == TK_RECORD || tf.kind == TK_UNION) && is_numeric(table, ct)) {
            ret true;
        }
        if (is_numeric(table, cf) && (tt.kind == TK_RECORD || tt.kind == TK_UNION)) {
            ret true;
        }
    }

    ret false;
}

# compute_record_layout: compute field offsets, total size, and alignment for a record type
# ---
# table: type table (used to look up field types)
# id:    TypeId of the record to lay out
pub fun compute_record_layout(table: *TypeTable, id: TypeId) {
    if (id::u32 >= table.count) { ret; }
    val t: *Type = ?table.types[id];
    var offset: u32 = 0;
    var max_align: u32 = 1;

    var i: u16 = 0;
    for (i < t.field_count) {
        val ft: &Type = get(table, t.fields[i].type_id);
        val fa: u32 = ft.align;
        if (fa > max_align) {
            max_align = fa;
        }
        if (fa > 0) {
            offset = (offset + fa - 1) & ~(fa - 1);
        }
        t.fields[i].offset = offset;
        offset = offset + ft.size;
        i = i + 1;
    }

    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    t.size  = offset;
    t.align = max_align;
}

# compute_union_layout: compute size and alignment for a union type (all fields at offset 0)
# ---
# table: type table
# id:    TypeId of the union to lay out
pub fun compute_union_layout(table: *TypeTable, id: TypeId) {
    if (id::u32 >= table.count) { ret; }
    val t: *Type = ?table.types[id];
    var max_size:  u32 = 0;
    var max_align: u32 = 1;

    var i: u16 = 0;
    for (i < t.field_count) {
        val ft: &Type = get(table, t.fields[i].type_id);
        if (ft.size > max_size) {
            max_size = ft.size;
        }
        if (ft.align > max_align) {
            max_align = ft.align;
        }
        t.fields[i].offset = 0;
        i = i + 1;
    }

    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    t.size  = max_size;
    t.align = max_align;
}

# get_field: find a field by name in a record or union type
# ---
# table: type table
# id:    TypeId of the record or union
# name:  field name to find
# ret:   pointer to the matching TypeField, or nil if not found
pub fun get_field(table: &TypeTable, id: TypeId, name: str) *TypeField {
    val cid: TypeId = canonical(table, id);
    val t: &Type = get(table, cid);

    if (t.kind != TK_RECORD && t.kind != TK_UNION) {
        ret nil;
    }

    var i: u16 = 0;
    for (i < t.field_count) {
        if (t.fields[i].name != nil && str_equals(t.fields[i].name, name)) {
            ret ?t.fields[i];
        }
        i = i + 1;
    }

    ret nil;
}

# display_name: return a human-readable name for a type
# ---
# table: type table
# id:    TypeId to display
# ret:   string representation
pub fun display_name(table: &TypeTable, id: TypeId) str {
    val t: &Type = get(table, id);

    if (t.kind == TK_ALIAS) {
        if (t.name != nil) { ret t.name; }
    }

    if (t.kind == TK_ERROR) { ret "<error>"; }

    if (t.name != nil) {
        ret t.name;
    }

    if (t.kind == TK_POINTER) { ret "*"; }

    ret "?";
}

fun grow(table: *TypeTable, new_cap: u32) {
    val res_realloc: Result[*Type, str] = allocator.reallocate[Type](
        table.alloc,
        table.types,
        table.cap::usize,
        new_cap::usize
    );
    if (!res_realloc.tag) { ret; }
    table.types = res_realloc.value.ok;
    table.cap   = new_cap;
}

fun fill_prim(table: *TypeTable, kind: TypeKind, name: str, size: u32, align: u32) {
    val id: TypeId = add(table, kind);
    val t: *Type = ?table.types[id];
    t.name  = name;
    t.size  = size;
    t.align = align;
}

var va_list_id: TypeId = TYPE_NIL;

fun init_va_list(table: *TypeTable) {
    val res_alloc: Result[*TypeField, str] = allocator.allocate[TypeField](table.alloc, 4);
    if (is_err[*TypeField, str](res_alloc)) { ret; }
    val fields: *TypeField = unwrap_ok[*TypeField, str](res_alloc);

    fields[0].name    = "gp_offset";
    fields[0].type_id = primitive(table, TK_U32);
    fields[0].offset  = 0;

    fields[1].name    = "fp_offset";
    fields[1].type_id = primitive(table, TK_U32);
    fields[1].offset  = 4;

    fields[2].name    = "overflow_arg_area";
    fields[2].type_id = primitive(table, TK_OPAQUE_PTR);
    fields[2].offset  = 8;

    fields[3].name    = "reg_save_area";
    fields[3].type_id = primitive(table, TK_OPAQUE_PTR);
    fields[3].offset  = 16;

    val id: TypeId = add(table, TK_RECORD);
    val t: *Type = ?table.types[id];
    t.name        = "va_list";
    t.fields      = fields;
    t.field_count = 4;
    t.size        = 24;
    t.align       = 8;

    va_list_id = id;
}

pub fun builtin_va_list(table: &TypeTable) TypeId {
    ret va_list_id;
}

test "type: primitive u32 has size 4" {
    var backing: allocator.Allocator;
    page.make(?backing);
    var table: TypeTable = init(?backing, 8, 8);
    val id: TypeId = primitive(?table, TK_U32);
    val t: &Type = get(?table, id);
    if (t.size != 4) { ret 0; }
    dnit(?table);
    ret 1;
}

test "type: make_pointer has ptr_size" {
    var backing: allocator.Allocator;
    page.make(?backing);
    var table: TypeTable = init(?backing, 8, 8);
    val pid: TypeId = make_pointer(?table, primitive(?table, TK_U32));
    val pt: &Type = get(?table, pid);
    if (pt.size != 8) { ret 0; }
    dnit(?table);
    ret 1;
}

test "type: make_alias canonical unwraps" {
    var backing: allocator.Allocator;
    page.make(?backing);
    var table: TypeTable = init(?backing, 8, 8);
    val u32_id: TypeId = primitive(?table, TK_U32);
    val alias_id: TypeId = make_alias(?table, "MyInt", u32_id);
    val cid: TypeId = canonical(?table, alias_id);
    if (cid != u32_id) { ret 0; }
    dnit(?table);
    ret 1;
}

test "type: can_assign nil to pointer" {
    var backing: allocator.Allocator;
    page.make(?backing);
    var table: TypeTable = init(?backing, 8, 8);
    val nil_id: TypeId = primitive(?table, TK_NIL);
    val ptr_id: TypeId = make_pointer(?table, primitive(?table, TK_U8));
    if (!can_assign(?table, nil_id, ptr_id)) { ret 0; }
    val i32_id: TypeId = primitive(?table, TK_I32);
    val u32_id: TypeId = primitive(?table, TK_U32);
    if (can_assign(?table, i32_id, u32_id)) { ret 0; }
    dnit(?table);
    ret 1;
}

test "type: is_integer u64 true, f32 false" {
    var backing: allocator.Allocator;
    page.make(?backing);
    var table: TypeTable = init(?backing, 8, 8);
    if (!is_integer(?table, primitive(?table, TK_U64))) { ret 0; }
    if (is_integer(?table, primitive(?table, TK_F32)))  { ret 0; }
    dnit(?table);
    ret 1;
}
