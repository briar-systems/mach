# mach.compiler.sema.comptime: compile-time expression evaluation
#
# evaluates compile-time expressions for constant folding, $if target
# conditions, and $size_of/$align_of/$offset_of intrinsics. operates on
# AST nodes and the type table without emitting code.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use ast:    mach.compiler.parse.ast;
use token:  mach.compiler.lex.token;
use type:   mach.compiler.sema.type;
use module: mach.compiler.sema.module;
use scope:  mach.compiler.sema.scope;
use sema:   mach.compiler.sema.sema;

pub def CKind: u8;
pub val CK_INT:    CKind = 1;
pub val CK_BOOL:   CKind = 2;
pub val CK_STRING: CKind = 3;
pub val CK_NIL:    CKind = 4;

# a compile-time evaluated value
# ---
# kind:     value category
# int_val:  integer value (for CK_INT)
# bool_val: boolean value (for CK_BOOL)
# str_val:  string value (for CK_STRING)
pub rec CValue {
    kind:     CKind;
    int_val:  i64;
    bool_val: bool;
    str_val:  str;
}

fun make_int(v: i64) CValue {
    var cv: CValue;
    cv.kind     = CK_INT;
    cv.int_val  = v;
    cv.bool_val = false;
    cv.str_val  = nil;
    ret cv;
}

fun make_bool(v: bool) CValue {
    var cv: CValue;
    cv.kind     = CK_BOOL;
    cv.int_val  = 0;
    cv.bool_val = v;
    cv.str_val  = nil;
    ret cv;
}

fun make_string(v: str) CValue {
    var cv: CValue;
    cv.kind     = CK_STRING;
    cv.int_val  = 0;
    cv.bool_val = false;
    cv.str_val  = v;
    ret cv;
}

fun make_nil() CValue {
    var cv: CValue;
    cv.kind     = CK_NIL;
    cv.int_val  = 0;
    cv.bool_val = false;
    cv.str_val  = nil;
    ret cv;
}

# platform identity constants — same values as cmach's comptime.c
pub val OS_LINUX:   i64 = 1;
pub val OS_MACOS:   i64 = 2;
pub val OS_WINDOWS: i64 = 3;

pub val ARCH_X86_64: i64 = 1;
pub val ARCH_ARM64:  i64 = 2;

# host platform — detected at compile time by whoever builds us.
$if ($mach.build.target.os.id == $mach.os.linux.id) {
    val HOST_OS_ID:   i64 = 1;
    val HOST_OS_NAME: str = "linux";
}
$or ($mach.build.target.os.id == $mach.os.macos.id) {
    val HOST_OS_ID:   i64 = 2;
    val HOST_OS_NAME: str = "macos";
}
$or ($mach.build.target.os.id == $mach.os.windows.id) {
    val HOST_OS_ID:   i64 = 3;
    val HOST_OS_NAME: str = "windows";
}
$or {
    val HOST_OS_ID:   i64 = 1;
    val HOST_OS_NAME: str = "linux";
}

$if ($mach.build.target.arch.id == $mach.arch.x86_64.id) {
    val HOST_ARCH_ID:   i64 = 1;
    val HOST_ARCH_NAME: str = "x86_64";
}
$or ($mach.build.target.arch.id == $mach.arch.arm64.id) {
    val HOST_ARCH_ID:   i64 = 2;
    val HOST_ARCH_NAME: str = "arm64";
}
$or {
    val HOST_ARCH_ID:   i64 = 1;
    val HOST_ARCH_NAME: str = "x86_64";
}

val HOST_PTR_WIDTH: i64 = 8;

fun os_name_to_id(name: str) i64 {
    if (str_equals(name, "linux"))   { ret OS_LINUX; }
    if (str_equals(name, "macos"))   { ret OS_MACOS; }
    if (str_equals(name, "windows")) { ret OS_WINDOWS; }
    ret 0;
}

fun arch_name_to_id(name: str) i64 {
    if (str_equals(name, "x86_64")) { ret ARCH_X86_64; }
    if (str_equals(name, "arm64"))  { ret ARCH_ARM64; }
    ret 0;
}

# resolve_builtin_path: resolve a $mach.* comptime builtin path to a value
#
# handles:
#   $mach.build.target.os       → host OS name string
#   $mach.build.target.os.id    → host OS integer id
#   $mach.build.target.arch     → host arch name string
#   $mach.build.target.arch.id  → host arch integer id
#   $mach.build.target.pointer_width → pointer size integer
#   $mach.os.linux.id           → OS_LINUX (1)
#   $mach.os.macos.id           → OS_MACOS (2)
#   $mach.os.windows.id         → OS_WINDOWS (3)
#   $mach.arch.x86_64.id        → ARCH_X86_64 (1)
#   $mach.arch.arm64.id         → ARCH_ARM64 (2)
#   $mach.compiler.version      → version string
#   $mach.compiler.name         → "mach"
# ---
# store:   AST node store
# node_id: the $comptime node
# ret:     resolved value or error
pub fun resolve_builtin_path(store: *ast.NodeStore, node_id: ast.NodeId) Result[CValue, str] {
    # flatten the dotted path into segments by walking NK_EXPR_FIELD nodes
    # the inner expression is field.field.field...ident
    val node: *ast.Node = ast.get(store, node_id);
    if (node.kind != ast.NK_COMPTIME) {
        ret err[CValue, str]("not a comptime node");
    }

    val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    if (inner_id::u32 == ast.NODE_NIL::u32) {
        ret err[CValue, str]("empty comptime expression");
    }

    # collect path segments by walking field access chain
    var segs: [8]str;
    var seg_count: i32 = 0;
    var cur: ast.NodeId = inner_id;

    for (seg_count < 8) {
        val n: *ast.Node = ast.get(store, cur);
        if (n.kind == ast.NK_EXPR_FIELD) {
            val field_name_sid: ast.StrId = ast.get_extra(store, n.payload + 1)::ast.StrId;
            segs[seg_count] = ast.get_str(store, field_name_sid);
            seg_count = seg_count + 1;
            cur = ast.get_extra(store, n.payload)::ast.NodeId;
        } or (n.kind == ast.NK_EXPR_IDENT) {
            val ident_sid: ast.StrId = ast.get_extra(store, n.payload)::ast.StrId;
            segs[seg_count] = ast.get_str(store, ident_sid);
            seg_count = seg_count + 1;
            brk;
        } or {
            brk;
        }
    }

    # reverse segments (they were collected leaf-first)
    var ri: i32 = 0;
    var rj: i32 = seg_count - 1;
    for (ri < rj) {
        val tmp: str = segs[ri];
        segs[ri] = segs[rj];
        segs[rj] = tmp;
        ri = ri + 1;
        rj = rj - 1;
    }

    # must start with "mach"
    if (seg_count < 2 || !str_equals(segs[0], "mach")) {
        ret err[CValue, str]("not a $mach builtin");
    }

    # $mach.compiler.*
    if (seg_count == 3 && str_equals(segs[1], "compiler")) {
        if (str_equals(segs[2], "version")) {
            ret ok[CValue, str](make_string("0.9.0"));
        }
        if (str_equals(segs[2], "name")) {
            ret ok[CValue, str](make_string("mach"));
        }
    }

    # $mach.build.target.*
    if (seg_count >= 4 && str_equals(segs[1], "build") && str_equals(segs[2], "target")) {
        if (seg_count == 4) {
            if (str_equals(segs[3], "os")) {
                ret ok[CValue, str](make_string(HOST_OS_NAME));
            }
            if (str_equals(segs[3], "arch")) {
                ret ok[CValue, str](make_string(HOST_ARCH_NAME));
            }
            if (str_equals(segs[3], "pointer_width")) {
                ret ok[CValue, str](make_int(HOST_PTR_WIDTH));
            }
        }
        if (seg_count == 5 && str_equals(segs[4], "id")) {
            if (str_equals(segs[3], "os")) {
                ret ok[CValue, str](make_int(HOST_OS_ID));
            }
            if (str_equals(segs[3], "arch")) {
                ret ok[CValue, str](make_int(HOST_ARCH_ID));
            }
        }
    }

    # $mach.os.<name>.id
    if (seg_count == 4 && str_equals(segs[1], "os") && str_equals(segs[3], "id")) {
        if (str_equals(segs[2], "linux"))   { ret ok[CValue, str](make_int(OS_LINUX)); }
        if (str_equals(segs[2], "macos"))   { ret ok[CValue, str](make_int(OS_MACOS)); }
        if (str_equals(segs[2], "windows")) { ret ok[CValue, str](make_int(OS_WINDOWS)); }
    }

    # $mach.arch.<name>.id
    if (seg_count == 4 && str_equals(segs[1], "arch") && str_equals(segs[3], "id")) {
        if (str_equals(segs[2], "x86_64")) { ret ok[CValue, str](make_int(ARCH_X86_64)); }
        if (str_equals(segs[2], "arm64"))  { ret ok[CValue, str](make_int(ARCH_ARM64)); }
    }

    ret err[CValue, str]("unknown $mach builtin");
}

# eval_target_condition: evaluate a $if target predicate
#
# handles expressions like `target.os == "linux"` and `target.isa == "x86_64"`.
# the condition must be a binary == or != comparing a target field access
# against a string literal.
# ---
# store:      AST node store containing the condition
# node_id:    root node of the condition expression
# target_os:  current target OS string
# target_isa: current target ISA string
# ret:        true/false for the condition, or error string
pub fun eval_target_condition(store: *ast.NodeStore, node_id: ast.NodeId,
                              target_os: str, target_isa: str) Result[bool, str] {
    if (node_id::u32 == ast.NODE_NIL::u32) {
        ret err[bool, str]("nil condition node");
    }

    val node: *ast.Node = ast.get(store, node_id);
    if (node.kind != ast.NK_EXPR_BINARY) {
        ret err[bool, str]("expected binary expression in target condition");
    }

    val op: u8 = ast.binary_op(store, node_id);
    if (op != token.TAG_EQ_EQ::u8 && op != token.TAG_BANG_EQ::u8) {
        ret err[bool, str]("expected == or != in target condition");
    }

    val lhs_id: ast.NodeId = ast.binary_lhs(store, node_id);
    val rhs_id: ast.NodeId = ast.binary_rhs(store, node_id);

    var field_name: str = nil;
    var lit_val: str = nil;

    if (!extract_field_and_literal(store, lhs_id, rhs_id, ?field_name, ?lit_val)) {
        if (!extract_field_and_literal(store, rhs_id, lhs_id, ?field_name, ?lit_val)) {
            ret err[bool, str]("expected target.field == \"value\" in condition");
        }
    }

    if (field_name == nil || lit_val == nil) {
        ret err[bool, str]("could not extract field and literal from condition");
    }

    var actual: str = nil;
    if (str_equals(field_name, "os")) {
        actual = target_os;
    } or (str_equals(field_name, "isa")) {
        actual = target_isa;
    } or {
        ret err[bool, str]("unknown target field in condition");
    }

    val matches: bool = str_equals(actual, lit_val);
    if (op == token.TAG_EQ_EQ::u8) {
        ret ok[bool, str](matches);
    }
    ret ok[bool, str](!matches);
}

fun extract_field_and_literal(store: *ast.NodeStore,
                              field_id: ast.NodeId, lit_id: ast.NodeId,
                              out_field: *str, out_lit: *str) bool {
    val field_node: *ast.Node = ast.get(store, field_id);
    val lit_node: *ast.Node = ast.get(store, lit_id);

    if (field_node.kind != ast.NK_EXPR_FIELD) { ret false; }
    if (lit_node.kind != ast.NK_EXPR_LIT_STR) { ret false; }

    val base_id: ast.NodeId = ast.get_extra(store, field_node.payload)::ast.NodeId;
    val base_node: *ast.Node = ast.get(store, base_id);
    if (base_node.kind != ast.NK_EXPR_IDENT) { ret false; }

    val base_name_sid: ast.StrId = ast.get_extra(store, base_node.payload)::ast.StrId;
    val base_name: str = ast.get_str(store, base_name_sid);
    if (!str_equals(base_name, "target")) { ret false; }

    val fname_sid: ast.StrId = ast.get_extra(store, field_node.payload + 1)::ast.StrId;
    @out_field = ast.get_str(store, fname_sid);

    val lit_sid: ast.StrId = ast.get_extra(store, lit_node.payload)::ast.StrId;
    val raw: str = ast.get_str(store, lit_sid);
    @out_lit = strip_quotes(raw);

    ret true;
}

fun strip_quotes(s: str) str {
    if (s == nil) { ret nil; }
    val len: usize = str_len(s);
    if (len < 2) { ret s; }
    if (s[0] == '"' && s[len - 1] == '"') {
        val inner: *u8 = (s::usize + 1)::*u8;
        inner[len - 2] = 0;
        ret inner::str;
    }
    ret s;
}

# eval: evaluate a compile-time expression
#
# handles integer/string/bool literals, binary arithmetic and comparisons,
# unary minus, and $size_of/$align_of/$offset_of intrinsics.
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     evaluated CValue, or CK_NIL on failure
pub fun eval(s: *sema.Sema, mod_id: module.ModuleId,
             scope_id: scope.ScopeId, node_id: ast.NodeId) CValue {
    if (node_id::u32 == ast.NODE_NIL::u32) {
        ret make_nil();
    }

    val m: *module.Module = module.get(s.modules, mod_id);
    val node: *ast.Node = ast.get(?m.store, node_id);

    if (node.kind == ast.NK_EXPR_LIT_INT) {
        val text_sid: ast.StrId = ast.get_extra(?m.store, node.payload)::ast.StrId;
        val text: str = ast.get_str(?m.store, text_sid);
        ret make_int(parse_int_literal(text));
    }

    if (node.kind == ast.NK_EXPR_LIT_BOOL) {
        val bval: u32 = ast.get_extra(?m.store, node.payload);
        ret make_bool(bval != 0);
    }

    if (node.kind == ast.NK_EXPR_LIT_STR) {
        val text_sid: ast.StrId = ast.get_extra(?m.store, node.payload)::ast.StrId;
        val text: str = ast.get_str(?m.store, text_sid);
        ret make_string(strip_quotes(text));
    }

    if (node.kind == ast.NK_EXPR_LIT_NIL) {
        ret make_nil();
    }

    if (node.kind == ast.NK_EXPR_PAREN) {
        val inner_id: ast.NodeId = ast.get_extra(?m.store, node.payload)::ast.NodeId;
        ret eval(s, mod_id, scope_id, inner_id);
    }

    if (node.kind == ast.NK_EXPR_UNARY) {
        ret eval_unary(s, mod_id, scope_id, node_id);
    }

    if (node.kind == ast.NK_EXPR_BINARY) {
        ret eval_binary(s, mod_id, scope_id, node_id);
    }

    if (node.kind == ast.NK_EXPR_CALL) {
        ret eval_call_intrinsic(s, mod_id, scope_id, node_id);
    }

    if (node.kind == ast.NK_COMPTIME) {
        val res_builtin: Result[CValue, str] = resolve_builtin_path(?m.store, node_id);
        if (is_ok[CValue, str](res_builtin)) {
            ret unwrap_ok[CValue, str](res_builtin);
        }
        val inner_id: ast.NodeId = ast.get_extra(?m.store, node.payload)::ast.NodeId;
        eval_comptime_assign(s, mod_id, inner_id);
        ret eval(s, mod_id, scope_id, inner_id);
    }

    ret make_nil();
}

fun eval_comptime_assign(s: *sema.Sema, mod_id: module.ModuleId, node_id: ast.NodeId) {
    if (s == nil) { ret; }
    val m: *module.Module = module.get(s.modules, mod_id);
    val node: *ast.Node = ast.get(?m.store, node_id);
    if (node.kind != ast.NK_EXPR_BINARY) { ret; }

    val op: u32 = ast.get_extra(?m.store, node.payload + 2);
    if (op != token.TAG_EQ::u32) { ret; }

    val lhs_id: ast.NodeId = ast.get_extra(?m.store, node.payload)::ast.NodeId;
    val rhs_id: ast.NodeId = ast.get_extra(?m.store, node.payload + 1)::ast.NodeId;

    val lhs_node: *ast.Node = ast.get(?m.store, lhs_id);
    if (lhs_node.kind != ast.NK_EXPR_FIELD) { ret; }

    val obj_id: ast.NodeId = ast.get_extra(?m.store, lhs_node.payload)::ast.NodeId;
    val field_sid: ast.StrId = ast.get_extra(?m.store, lhs_node.payload + 1)::ast.StrId;
    val field_name: str = ast.get_str(?m.store, field_sid);

    val obj_node: *ast.Node = ast.get(?m.store, obj_id);
    if (obj_node.kind != ast.NK_EXPR_IDENT) { ret; }
    val obj_name_sid: ast.StrId = ast.get_extra(?m.store, obj_node.payload)::ast.StrId;
    val obj_name: str = ast.get_str(?m.store, obj_name_sid);

    val opt_lookup: Option[scope.SymbolId] = scope.lookup_from(s.symbols, m.scope, obj_name);
    if (is_none[scope.SymbolId](opt_lookup)) { ret; }
    val sym_id: scope.SymbolId = unwrap[scope.SymbolId](opt_lookup);

    val rhs_val: CValue = eval(s, mod_id, m.scope, rhs_id);

    if (str_equals(field_name, "symbol") || str_equals(field_name, "name")) {
        if (rhs_val.kind == CK_STRING && rhs_val.str_val != nil) {
            val sym: *scope.Symbol = scope.get_sym_mut(s.symbols, sym_id);
            sym.export_name = rhs_val.str_val;
        }
    }
}

fun eval_unary(s: *sema.Sema, mod_id: module.ModuleId,
               scope_id: scope.ScopeId, node_id: ast.NodeId) CValue {
    val m: *module.Module = module.get(s.modules, mod_id);
    val operand_id: ast.NodeId = ast.get_extra(?m.store,
        ast.get(?m.store, node_id).payload)::ast.NodeId;
    val op: u32 = ast.get_extra(?m.store, ast.get(?m.store, node_id).payload + 1);

    val operand: CValue = eval(s, mod_id, scope_id, operand_id);

    if (op == token.TAG_MINUS::u32 && operand.kind == CK_INT) {
        ret make_int(0 - operand.int_val);
    }

    if (op == token.TAG_BANG::u32 && operand.kind == CK_BOOL) {
        ret make_bool(!operand.bool_val);
    }

    ret make_nil();
}

fun eval_binary(s: *sema.Sema, mod_id: module.ModuleId,
                scope_id: scope.ScopeId, node_id: ast.NodeId) CValue {
    val m: *module.Module = module.get(s.modules, mod_id);
    val lhs_id: ast.NodeId = ast.binary_lhs(?m.store, node_id);
    val rhs_id: ast.NodeId = ast.binary_rhs(?m.store, node_id);
    val op: u8 = ast.binary_op(?m.store, node_id);

    val lhs: CValue = eval(s, mod_id, scope_id, lhs_id);
    val rhs: CValue = eval(s, mod_id, scope_id, rhs_id);

    if (lhs.kind == CK_INT && rhs.kind == CK_INT) {
        if (op == token.TAG_PLUS::u8)    { ret make_int(lhs.int_val + rhs.int_val); }
        if (op == token.TAG_MINUS::u8)   { ret make_int(lhs.int_val - rhs.int_val); }
        if (op == token.TAG_STAR::u8)    { ret make_int(lhs.int_val * rhs.int_val); }
        if (op == token.TAG_SLASH::u8) {
            if (rhs.int_val == 0) { ret make_nil(); }
            ret make_int(lhs.int_val / rhs.int_val);
        }
        if (op == token.TAG_EQ_EQ::u8)   { ret make_bool(lhs.int_val == rhs.int_val); }
        if (op == token.TAG_BANG_EQ::u8)  { ret make_bool(lhs.int_val != rhs.int_val); }
        if (op == token.TAG_LT::u8)      { ret make_bool(lhs.int_val < rhs.int_val); }
        if (op == token.TAG_GT::u8)      { ret make_bool(lhs.int_val > rhs.int_val); }
        if (op == token.TAG_LT_EQ::u8)   { ret make_bool(lhs.int_val <= rhs.int_val); }
        if (op == token.TAG_GT_EQ::u8)   { ret make_bool(lhs.int_val >= rhs.int_val); }
    }

    if (lhs.kind == CK_BOOL && rhs.kind == CK_BOOL) {
        if (op == token.TAG_AMP_AMP::u8)  { ret make_bool(lhs.bool_val && rhs.bool_val); }
        if (op == token.TAG_PIPE_PIPE::u8) { ret make_bool(lhs.bool_val || rhs.bool_val); }
        if (op == token.TAG_EQ_EQ::u8)    { ret make_bool(lhs.bool_val == rhs.bool_val); }
        if (op == token.TAG_BANG_EQ::u8)   { ret make_bool(lhs.bool_val != rhs.bool_val); }
    }

    if (lhs.kind == CK_STRING && rhs.kind == CK_STRING) {
        if (op == token.TAG_EQ_EQ::u8)   { ret make_bool(str_equals(lhs.str_val, rhs.str_val)); }
        if (op == token.TAG_BANG_EQ::u8)  { ret make_bool(!str_equals(lhs.str_val, rhs.str_val)); }
    }

    ret make_nil();
}

fun eval_call_intrinsic(s: *sema.Sema, mod_id: module.ModuleId,
                        scope_id: scope.ScopeId, node_id: ast.NodeId) CValue {
    val m: *module.Module = module.get(s.modules, mod_id);
    val callee_id: ast.NodeId = ast.call_callee(?m.store, node_id);
    val callee_node: *ast.Node = ast.get(?m.store, callee_id);

    if (callee_node.kind != ast.NK_EXPR_IDENT) {
        ret make_nil();
    }

    val name_sid: ast.StrId = ast.get_extra(?m.store, callee_node.payload)::ast.StrId;
    val name: str = ast.get_str(?m.store, name_sid);
    if (name == nil) { ret make_nil(); }

    val args: ast.NodeSpan = ast.call_args(?m.store, node_id);

    if (str_equals(name, "size_of")) {
        if (args.len < 1) { ret make_nil(); }
        val arg_id: ast.NodeId = ast.get_extra(?m.store, args.start)::ast.NodeId;
        val type_id: type.TypeId = resolve_comptime_type_arg(s, mod_id, scope_id, arg_id);
        if (type_id::u32 == type.TYPE_NIL::u32) { ret make_nil(); }
        ret make_int(eval_size_of(s, type_id));
    }

    if (str_equals(name, "align_of")) {
        if (args.len < 1) { ret make_nil(); }
        val arg_id: ast.NodeId = ast.get_extra(?m.store, args.start)::ast.NodeId;
        val type_id: type.TypeId = resolve_comptime_type_arg(s, mod_id, scope_id, arg_id);
        if (type_id::u32 == type.TYPE_NIL::u32) { ret make_nil(); }
        ret make_int(eval_align_of(s, type_id));
    }

    if (str_equals(name, "offset_of")) {
        if (args.len < 2) { ret make_nil(); }
        val type_arg_id: ast.NodeId = ast.get_extra(?m.store, args.start)::ast.NodeId;
        val field_arg_id: ast.NodeId = ast.get_extra(?m.store, args.start + 1)::ast.NodeId;
        val type_id: type.TypeId = resolve_comptime_type_arg(s, mod_id, scope_id, type_arg_id);
        if (type_id::u32 == type.TYPE_NIL::u32) { ret make_nil(); }

        val field_node: *ast.Node = ast.get(?m.store, field_arg_id);
        var field_name: str = nil;
        if (field_node.kind == ast.NK_EXPR_IDENT) {
            val fsid: ast.StrId = ast.get_extra(?m.store, field_node.payload)::ast.StrId;
            field_name = ast.get_str(?m.store, fsid);
        } or (field_node.kind == ast.NK_EXPR_LIT_STR) {
            val fsid: ast.StrId = ast.get_extra(?m.store, field_node.payload)::ast.StrId;
            field_name = strip_quotes(ast.get_str(?m.store, fsid));
        }

        if (field_name == nil) { ret make_nil(); }
        val res_off: Result[i64, str] = eval_offset_of(s, type_id, field_name);
        if (is_err[i64, str](res_off)) { ret make_nil(); }
        ret make_int(unwrap_ok[i64, str](res_off));
    }

    ret make_nil();
}

fun resolve_comptime_type_arg(s: *sema.Sema, mod_id: module.ModuleId,
                              scope_id: scope.ScopeId,
                              node_id: ast.NodeId) type.TypeId {
    val m: *module.Module = module.get(s.modules, mod_id);
    val node: *ast.Node = ast.get(?m.store, node_id);

    if (node.kind == ast.NK_EXPR_IDENT) {
        val name_sid: ast.StrId = ast.get_extra(?m.store, node.payload)::ast.StrId;
        val name: str = ast.get_str(?m.store, name_sid);
        val opt_prim: Option[type.TypeId] = type.primitive_by_name(s.types, name);
        if (is_some[type.TypeId](opt_prim)) {
            ret unwrap[type.TypeId](opt_prim);
        }
        val opt_lookup_type: Option[scope.SymbolId] = scope.lookup_from(s.symbols, scope_id, name);
        if (is_some[scope.SymbolId](opt_lookup_type)) {
            val sym_id: scope.SymbolId = unwrap[scope.SymbolId](opt_lookup_type);
            val sym: *scope.Symbol = scope.get_sym(s.symbols, sym_id);
            if (sym.kind == scope.SK_TYPE && sym.type_id::u32 != 0xFFFFFFFF) {
                ret sym.type_id::type.TypeId;
            }
        }
    }

    ret type.TYPE_NIL;
}

# eval_condition: evaluate a condition expression to a boolean
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     true/false, or error if not a boolean
pub fun eval_condition(s: *sema.Sema, mod_id: module.ModuleId,
                       scope_id: scope.ScopeId,
                       node_id: ast.NodeId) Result[bool, str] {
    val cv: CValue = eval(s, mod_id, scope_id, node_id);
    if (cv.kind == CK_BOOL) {
        ret ok[bool, str](cv.bool_val);
    }
    if (cv.kind == CK_INT) {
        ret ok[bool, str](cv.int_val != 0);
    }
    ret err[bool, str]("comptime condition did not evaluate to boolean");
}

# eval_int: evaluate a compile-time expression and expect an integer result
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     ok(i64) on success, err(str) on failure
pub fun eval_int(s: *sema.Sema, mod_id: module.ModuleId,
                 scope_id: scope.ScopeId,
                 node_id: ast.NodeId) Result[i64, str] {
    val cv: CValue = eval(s, mod_id, scope_id, node_id);
    if (cv.kind == CK_INT) {
        ret ok[i64, str](cv.int_val);
    }
    ret err[i64, str]("comptime expression did not evaluate to integer");
}

# eval_bool: evaluate a compile-time expression and expect a boolean result
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     ok(bool) on success, err(str) on failure
pub fun eval_bool(s: *sema.Sema, mod_id: module.ModuleId,
                  scope_id: scope.ScopeId,
                  node_id: ast.NodeId) Result[bool, str] {
    val cv: CValue = eval(s, mod_id, scope_id, node_id);
    if (cv.kind == CK_BOOL) {
        ret ok[bool, str](cv.bool_val);
    }
    ret err[bool, str]("comptime expression did not evaluate to boolean");
}

# eval_size_of: return the byte size of a type
# ---
# s:       sema context
# type_id: type to measure
# ret:     size in bytes
pub fun eval_size_of(s: *sema.Sema, type_id: type.TypeId) i64 {
    val cid: type.TypeId = type.canonical(s.types, type_id);
    val t: *type.Type = type.get(s.types, cid);
    ret t.size::i64;
}

# eval_align_of: return the alignment of a type
# ---
# s:       sema context
# type_id: type to measure
# ret:     alignment in bytes
pub fun eval_align_of(s: *sema.Sema, type_id: type.TypeId) i64 {
    val cid: type.TypeId = type.canonical(s.types, type_id);
    val t: *type.Type = type.get(s.types, cid);
    ret t.align::i64;
}

# eval_offset_of: return the byte offset of a field in a record type
# ---
# s:       sema context
# type_id: record type to inspect
# field:   field name
# ret:     byte offset, or error if not a record or field not found
pub fun eval_offset_of(s: *sema.Sema, type_id: type.TypeId,
                       field: str) Result[i64, str] {
    val cid: type.TypeId = type.canonical(s.types, type_id);
    val t: *type.Type = type.get(s.types, cid);

    if (t.kind != type.TK_RECORD && t.kind != type.TK_UNION) {
        ret err[i64, str]("offset_of requires a record or union type");
    }

    var i: u16 = 0;
    for (i < t.field_count) {
        if (t.fields[i].name != nil && str_equals(t.fields[i].name, field)) {
            ret ok[i64, str](t.fields[i].offset::i64);
        }
        i = i + 1;
    }

    ret err[i64, str]("field not found in type");
}

# is_comptime: check whether an AST node is a compile-time evaluable expression
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to check
# ret:     true if the node can be evaluated at compile time
pub fun is_comptime(s: *sema.Sema, mod_id: module.ModuleId,
                    scope_id: scope.ScopeId, node_id: ast.NodeId) bool {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret false; }

    val m: *module.Module = module.get(s.modules, mod_id);
    val node: *ast.Node = ast.get(?m.store, node_id);

    if (node.kind == ast.NK_EXPR_LIT_INT)  { ret true; }
    if (node.kind == ast.NK_EXPR_LIT_BOOL) { ret true; }
    if (node.kind == ast.NK_EXPR_LIT_STR)  { ret true; }
    if (node.kind == ast.NK_EXPR_LIT_NIL)  { ret true; }

    if (node.kind == ast.NK_EXPR_PAREN) {
        val inner_id: ast.NodeId = ast.get_extra(?m.store, node.payload)::ast.NodeId;
        ret is_comptime(s, mod_id, scope_id, inner_id);
    }

    if (node.kind == ast.NK_EXPR_UNARY) {
        val operand_id: ast.NodeId = ast.get_extra(?m.store, node.payload)::ast.NodeId;
        ret is_comptime(s, mod_id, scope_id, operand_id);
    }

    if (node.kind == ast.NK_EXPR_BINARY) {
        val lhs_id: ast.NodeId = ast.binary_lhs(?m.store, node_id);
        val rhs_id: ast.NodeId = ast.binary_rhs(?m.store, node_id);
        ret is_comptime(s, mod_id, scope_id, lhs_id) && is_comptime(s, mod_id, scope_id, rhs_id);
    }

    ret false;
}

fun parse_int_literal(text: str) i64 {
    if (text == nil) { ret 0; }

    var val_acc: i64 = 0;
    var i: usize = 0;
    var neg: bool = false;

    if (text[0] == '-') {
        neg = true;
        i = 1;
    }

    if (text[i] == '0' && (text[i + 1] == 'x' || text[i + 1] == 'X')) {
        i = i + 2;
        for (text[i] != 0) {
            var digit: i64 = 0;
            if (text[i] >= '0' && text[i] <= '9')      { digit = (text[i] - '0')::i64; }
            or (text[i] >= 'a' && text[i] <= 'f') { digit = (text[i] - 'a')::i64 + 10; }
            or (text[i] >= 'A' && text[i] <= 'F') { digit = (text[i] - 'A')::i64 + 10; }
            or (text[i] == '_') { i = i + 1; cnt; }
            or { brk; }
            val_acc = val_acc * 16 + digit;
            i = i + 1;
        }
    } or (text[i] == '0' && (text[i + 1] == 'b' || text[i + 1] == 'B')) {
        i = i + 2;
        for (text[i] != 0) {
            if (text[i] == '_') { i = i + 1; cnt; }
            if (text[i] < '0' || text[i] > '1') { brk; }
            val_acc = val_acc * 2 + (text[i] - '0')::i64;
            i = i + 1;
        }
    } or (text[i] == '0' && (text[i + 1] == 'o' || text[i + 1] == 'O')) {
        i = i + 2;
        for (text[i] != 0) {
            if (text[i] == '_') { i = i + 1; cnt; }
            if (text[i] < '0' || text[i] > '7') { brk; }
            val_acc = val_acc * 8 + (text[i] - '0')::i64;
            i = i + 1;
        }
    } or {
        for (text[i] != 0) {
            if (text[i] == '_') { i = i + 1; cnt; }
            if (text[i] < '0' || text[i] > '9') { brk; }
            val_acc = val_acc * 10 + (text[i] - '0')::i64;
            i = i + 1;
        }
    }

    if (neg) { ret 0 - val_acc; }
    ret val_acc;
}
