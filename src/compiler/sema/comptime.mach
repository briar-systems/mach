# compiler.sema.comptime: compile-time evaluation
# stub -- implementation pending

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use ast:    compiler.parse.ast;
use type:   compiler.sema.type;
use module: compiler.sema.module;
use sema:   compiler.sema.sema;

pub def CKind: u8;
pub val CK_INT:    CKind = 1;
pub val CK_BOOL:   CKind = 2;
pub val CK_STRING: CKind = 3;
pub val CK_NIL:    CKind = 4;

# a compile-time evaluated value
# ---
# kind:     value category
# int_val:  integer value (for CK_INT)
# bool_val: boolean value (for CK_BOOL)
# str_val:  string value (for CK_STRING)
pub rec CValue {
    kind:     CKind;
    int_val:  i64;
    bool_val: bool;
    str_val:  str;
}

# evaluate a compile-time expression.
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     evaluated CValue, or CK_NIL on failure
pub fun eval(s: *sema.Sema, mod_id: module.ModuleId,
             node_id: ast.NodeId) CValue {
    var v: CValue;
    v.kind     = CK_NIL;
    v.int_val  = 0;
    v.bool_val = false;
    v.str_val  = nil;
    ret v;
}

# evaluate a compile-time expression and expect an integer result.
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     ok(i64) on success, err(str) on failure
pub fun eval_int(s: *sema.Sema, mod_id: module.ModuleId,
                 node_id: ast.NodeId) Result[i64, str] {
    ret err[i64, str]("comptime eval not implemented");
}

# evaluate a compile-time expression and expect a boolean result.
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to evaluate
# ret:     ok(bool) on success, err(str) on failure
pub fun eval_bool(s: *sema.Sema, mod_id: module.ModuleId,
                  node_id: ast.NodeId) Result[bool, str] {
    ret err[bool, str]("comptime eval not implemented");
}

# check whether an AST node is a compile-time evaluable expression.
# ---
# s:       sema context
# mod_id:  module containing the expression
# node_id: AST node to check
# ret:     true if the node can be evaluated at compile time
pub fun is_comptime(s: *sema.Sema, mod_id: module.ModuleId,
                    node_id: ast.NodeId) bool {
    ret false;
}
