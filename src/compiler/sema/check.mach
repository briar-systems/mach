use std.types.bool;

use ast:   mach.compiler.ast;
use ty:    mach.compiler.type;
use tyctx: mach.compiler.type_context;

use mach.compiler.sema;

# mach.compiler.sema.check: pass 3 — read-only validation of function bodies.

pub fun run(s: *sema.Sema, root: *ast.Node) {
    if (s == nil || root == nil) { ret; }
    val decls: *ast.List = root.info.block_stmt.stmts;
    if (decls == nil) { ret; }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            check_top_decl(s, node);
        }
        i = i + 1;
    }
}

# --- top-level dispatch ---

fun check_top_decl(s: *sema.Sema, node: *ast.Node) {
    if (node == nil) { ret; }

    if (node.kind == ast.NODE_DECL_FUN) {
        check_function(s, node);
        ret;
    }

    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil && inner.kind == ast.NODE_DECL_FUN) {
            check_function(s, inner);
        }
        ret;
    }

    if (node.kind == ast.NODE_COMPTIME_IF) {
        check_comptime_if_decls(s, node);
        ret;
    }
}

fun check_comptime_if_decls(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }

    val eval_res: Result[bool, str] = sema.eval_comptime(s, node);
    if (result_is_err[bool, str](eval_res)) { ret; }

    val taken: bool = result_unwrap_ok[bool, str](eval_res);
    if (taken) {
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            check_comptime_body(s, body);
        }
    } or {
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) {
            if (or_branch.kind == ast.NODE_COMPTIME_OR) {
                check_comptime_if_decls(s, or_branch);
            } or {
                check_comptime_body(s, or_branch);
            }
        }
    }
}

fun check_comptime_body(s: *sema.Sema, body: *ast.Node) {
    if (body == nil) { ret; }

    if (body.kind == ast.NODE_STMT_BLOCK || body.kind == ast.NODE_PROGRAM || body.kind == ast.NODE_STMT_LIST) {
        val stmts: *ast.List = body.info.block_stmt.stmts;
        if (stmts == nil) { ret; }
        var i: i32 = 0;
        for (i < stmts.count) {
            val node: *ast.Node = stmts.nodes[i];
            if (node != nil) { check_top_decl(s, node); }
            i = i + 1;
        }
    } or {
        check_top_decl(s, body);
    }
}

# --- function validation ---

fun check_function(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }

    s.current_fn = node;

    if (node.ty != nil && node.ty.kind == ty.TY_FUN) {
        s.fn_ret_type = node.ty.ret_type;
    } or {
        s.fn_ret_type = tyctx.get_void(s.types);
    }

    val body: *ast.Node = node.info.fun_decl.body;
    if (body != nil) {
        check_stmt(s, body);
    }

    s.current_fn = nil;
    s.fn_ret_type = nil;
}

# --- statement validation ---

fun check_stmt(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }

    if (node.kind == ast.NODE_STMT_RET)   { check_return(s, node); ret; }
    if (node.kind == ast.NODE_STMT_IF)    { check_if(s, node); ret; }
    if (node.kind == ast.NODE_STMT_OR)    { check_or(s, node); ret; }
    if (node.kind == ast.NODE_STMT_FOR)   { check_for(s, node); ret; }
    if (node.kind == ast.NODE_STMT_BLOCK) { check_block(s, node); ret; }
    if (node.kind == ast.NODE_COMPTIME_IF) {
        val eval_res: Result[bool, str] = sema.eval_comptime(s, node);
        if (result_is_err[bool, str](eval_res)) { ret; }
        val taken: bool = result_unwrap_ok[bool, str](eval_res);
        if (taken) {
            val body: *ast.Node = node.info.cond_stmt.body;
            if (body != nil) { check_stmt(s, body); }
        } or {
            val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
            if (or_branch != nil) {
                if (or_branch.kind == ast.NODE_COMPTIME_OR) {
                    check_stmt(s, or_branch);
                } or {
                    check_stmt(s, or_branch);
                }
            }
        }
        ret;
    }
}

fun check_return(s: *sema.Sema, node: *ast.Node) {
    val ret_expr: *ast.Node = node.info.wrapper.inner;
    if (ret_expr != nil) {
        val ret_type: *ty.Type = ret_expr.ty;
        if (s.fn_ret_type != nil && ret_type != nil) {
            if (!ty.can_assign(ret_type, s.fn_ret_type)) {
                sema.report_error(s, node, "return type mismatch");
            }
        }
    } or {
        if (s.fn_ret_type != nil && s.fn_ret_type.kind != ty.TY_VOID) {
            sema.report_error(s, node, "missing return value in non-void function");
        }
    }
}

fun check_if(s: *sema.Sema, node: *ast.Node) {
    val cond: *ast.Node = node.info.cond_stmt.cond;
    if (cond != nil && cond.ty != nil) {
        check_condition(s, cond);
    }

    val body: *ast.Node = node.info.cond_stmt.body;
    if (body != nil) { check_stmt(s, body); }

    val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
    if (or_branch != nil) { check_stmt(s, or_branch); }
}

fun check_or(s: *sema.Sema, node: *ast.Node) {
    val cond: *ast.Node = node.info.cond_stmt.cond;
    if (cond != nil && cond.ty != nil) {
        check_condition(s, cond);
    }

    val body: *ast.Node = node.info.cond_stmt.body;
    if (body != nil) { check_stmt(s, body); }

    val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
    if (or_branch != nil) { check_stmt(s, or_branch); }
}

fun check_for(s: *sema.Sema, node: *ast.Node) {
    val cond: *ast.Node = node.info.for_stmt.cond;
    if (cond != nil && cond.ty != nil) {
        check_condition(s, cond);
    }

    val body: *ast.Node = node.info.for_stmt.body;
    if (body != nil) { check_stmt(s, body); }
}

fun check_block(s: *sema.Sema, node: *ast.Node) {
    val stmts: *ast.List = node.info.block_stmt.stmts;
    if (stmts == nil) { ret; }

    var i: i32 = 0;
    for (i < stmts.count) {
        check_stmt(s, stmts.nodes[i]);
        i = i + 1;
    }
}

# --- condition validation ---

fun check_condition(s: *sema.Sema, cond: *ast.Node) {
    val ct: *ty.Type = cond.ty;
    if (ct == nil) { ret; }

    # integers, pointers, and nil are all valid conditions
    if (ty.type_is_integer(ct)) { ret; }
    if (ty.type_is_pointer(ct)) { ret; }
    if (ct.kind == ty.TY_NIL) { ret; }

    sema.report_error(s, cond, "condition must be boolean, integer, or pointer");
}
