# mach.compiler.sema.check: body resolution and validation (phases 3-4)
#
# resolves types within function bodies (phase 3) and validates that all
# non-void functions have complete return coverage (phase 4). expression
# types are stored in a per-module ExprTypeMap; identifier-to-symbol
# bindings are stored in a NodeSymMap.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;
use std.types.option;

use allocator: std.allocator;
use ast:       mach.compiler.parse.ast;
use diag:      mach.compiler.diag;
use lexer:     mach.compiler.lex.lexer;
use module:    mach.compiler.sema.module;
use mono:      mach.compiler.sema.mono;
use resolve:   mach.compiler.sema.resolve;
use scope:     mach.compiler.sema.scope;
use token:     mach.compiler.lex.token;
use type:      mach.compiler.sema.type;
use sema:      mach.compiler.sema.sema;
use st:        mach.compiler.sema.sidetable;
use comptime:  mach.compiler.sema.comptime;

# context for type-checking a function body
# ---
# fn_sym:     symbol of the function being checked
# ret_type:   expected return type
# loop_depth: current loop nesting depth
# mod_id:     module containing this function
# store:      AST node store for this function
# etm:        expression type map for this function's module
# nsm:        node symbol map for this function's module
pub rec FnContext {
    fn_sym:     scope.SymbolId;
    ret_type:   type.TypeId;
    loop_depth: u32;
    mod_id:     module.ModuleId;
    scope_id:   scope.ScopeId;
    store:      *ast.NodeStore;
    etm:        *st.ExprTypeMap;
    nsm:        *st.NodeSymMap;
}

val ERROR_TID: type.TypeId = type.TYPE_ERROR_ID;

# resolve_bodies: type-check all function bodies in every module
# ---
# s: sema context
pub fun resolve_bodies(s: *sema.Sema) {
    var i: u32 = 0;
    for (i < module.order_count(s.modules)) {
        val mod_id: module.ModuleId = module.order_at(s.modules, i);
        resolve_module_bodies(s, mod_id);
        i = i + 1;
    }
}

# resolve_instantiation_bodies: type-check bodies of monomorphized function instances
#
# runs a fixpoint loop: each pass checks unresolved fn_insts, which may
# trigger new instantiations. repeats until no new instances are created.
# ---
# s: sema context
pub fun resolve_instantiation_bodies(s: *sema.Sema) {
    if (s.mono == nil) { ret; }
    var prev_count: u32 = 0;
    for (prev_count < mono.fn_count(s.mono)) {
        val current: u32 = mono.fn_count(s.mono);
        var i: u32 = prev_count;
        for (i < current) {
            val inst: *mono.FnInst = mono.get_fn(s.mono, i);
            if (!inst.body_resolved) {
                val m: *module.Module = module.get(s.modules, inst.origin_module);
                if (m.expr_types.types == nil) {
                    m.expr_types = st.init_expr_types(s.alloc, m.store.node_count);
                }
                if (m.node_syms.syms == nil) {
                    m.node_syms = st.init_node_syms(s.alloc, m.store.node_count);
                }
                resolve_inst_body(s, inst, ?m.store, ?m.expr_types, ?m.node_syms);
                val inst_mut: *mono.FnInst = ?s.mono.fn_insts[i];
                inst_mut.body_resolved = true;
            }
            i = i + 1;
        }
        prev_count = current;
    }
}

# check_all: run final validation checks across all modules
# ---
# s: sema context
pub fun check_all(s: *sema.Sema) {
    var i: u32 = 0;
    for (i < module.order_count(s.modules)) {
        val mod_id: module.ModuleId = module.order_at(s.modules, i);
        check_module(s, mod_id);
        i = i + 1;
    }
}

# validate_sidetables: verify that expression nodes have resolved types
#
# walks every node in every module. for expression nodes (NK_EXPR_*),
# checks that expr_types contains a valid (non-NIL) type. missing entries
# indicate an internal compiler error — the check phase failed to assign
# a type to an expression that lowering will need.
# ---
# s: sema context
pub fun validate_sidetables(s: *sema.Sema) {
    var i: u32 = 0;
    for (i < module.order_count(s.modules)) {
        val mod_id: module.ModuleId = module.order_at(s.modules, i);
        validate_module_sidetables(s, mod_id);
        i = i + 1;
    }
}

fun validate_module_sidetables(s: *sema.Sema, mod_id: module.ModuleId) {
    val m: *module.Module = module.get(s.modules, mod_id);
    if (m.root::u32 == ast.NODE_NIL::u32) { ret; }
    if (m.expr_types.types == nil) { ret; }

    val store: *ast.NodeStore = ?m.store;
    var nid: u32 = 0;
    for (nid < store.node_count) {
        val node: *ast.Node = ast.get(store, nid::ast.NodeId);
        if (ast.is_expr(node.kind)) {
            val tid: type.TypeId = st.get_type(?m.expr_types, nid::ast.NodeId);
            if (tid::u32 == type.TYPE_NIL::u32) {
                var loc: diag.SourceLoc;
                loc.file   = m.file_path;
                loc.line   = 0;
                loc.col    = 0;
                loc.offset = 0;
                loc.len    = 0;
                if (node.tok_idx < m.tokens.count) {
                    val tok_offset: u32 = m.tokens.tokens[node.tok_idx].span.offset;
                    loc.offset = tok_offset;
                    loc.len    = m.tokens.tokens[node.tok_idx].span.len;
                    if (m.source != nil) {
                        loc.line = lexer.line_of(m.source, tok_offset);
                        loc.col  = lexer.col_of(m.source, tok_offset);
                    }
                }
                diag.warning(s.diag, loc, "ICE: expression has no resolved type");
            }
        }
        nid = nid + 1;
    }
}

fun resolve_module_bodies(s: *sema.Sema, mod_id: module.ModuleId) {
    val m: *module.Module = module.get(s.modules, mod_id);
    val store: *ast.NodeStore = ?m.store;

    if (m.root::u32 == ast.NODE_NIL::u32) { ret; }

    if (m.expr_types.types == nil) {
        m.expr_types = st.init_expr_types(s.alloc, store.node_count);
    }
    if (m.node_syms.syms == nil) {
        m.node_syms = st.init_node_syms(s.alloc, store.node_count);
    }

    val root: *ast.Node = ast.get(store, m.root);
    if (root.kind != ast.NK_PROGRAM) { ret; }

    val stmts: ast.NodeSpan = ast.block_stmts(store, m.root);
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
        resolve_toplevel_fun(s, mod_id, store, ?m.expr_types, ?m.node_syms, child_id);
        i = i + 1;
    }
}

fun resolve_toplevel_fun(s: *sema.Sema, mod_id: module.ModuleId,
                         store: *ast.NodeStore, etm: *st.ExprTypeMap,
                         nsm: *st.NodeSymMap, node_id: ast.NodeId) {
    resolve_fun_body(s, mod_id, store, etm, nsm, node_id, false);
}

fun resolve_fun_body(s: *sema.Sema, mod_id: module.ModuleId,
                     store: *ast.NodeStore, etm: *st.ExprTypeMap,
                     nsm: *st.NodeSymMap, node_id: ast.NodeId,
                     is_instantiation: bool) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }

    val node: *ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_DECL_PUB) {
        val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        resolve_fun_body(s, mod_id, store, etm, nsm, inner_id, is_instantiation);
        ret;
    }

    if (node.kind == ast.NK_DECL_TEST) {
        ret;
    }

    if (node.kind != ast.NK_DECL_FUN) { ret; }

    if (!is_instantiation) {
        val generics: ast.NodeId = ast.fun_generics(store, node_id);
        if (generics::u32 != ast.NODE_NIL::u32) { ret; }
    }

    val body_id: ast.NodeId = ast.fun_body(store, node_id);
    if (body_id::u32 == ast.NODE_NIL::u32) { ret; }

    val name_sid: ast.StrId = ast.fun_name(store, node_id);
    val name: str = ast.get_str(store, name_sid);

    val m: *module.Module = module.get(s.modules, mod_id);
    val opt_fn_sym: Option[scope.SymbolId] = resolve.lookup_symbol(s, mod_id, m.scope, name);
    if (is_none[scope.SymbolId](opt_fn_sym)) {
        val loc: diag.SourceLoc = node_loc(s, mod_id, store, node_id);
        diag.error(s.diag, loc, "internal: function symbol not found after collection");
        ret;
    }
    val fn_sym_id: scope.SymbolId = unwrap[scope.SymbolId](opt_fn_sym);

    val fn_sym: *scope.Symbol = scope.get_sym(s.symbols, fn_sym_id);
    if (fn_sym.type_id == scope.TYPE_ID_UNSET) {
        val loc: diag.SourceLoc = node_loc(s, mod_id, store, node_id);
        diag.error(s.diag, loc, "internal: function type not resolved");
        ret;
    }

    val fn_type: *type.Type = type.get(s.types, fn_sym.type_id::type.TypeId);
    if (fn_type.kind != type.TK_FUN) { ret; }
    val fn_scope: scope.ScopeId = scope.create_scope(s.symbols, m.scope);

    val params: ast.NodeSpan = ast.fun_params(store, node_id);
    var pi: u32 = 0;
    for (pi < params.len && pi::u16 < fn_type.param_count) {
        val param_nid: ast.NodeId = ast.get_extra(store, params.start + pi)::ast.NodeId;
        val param_node: *ast.Node = ast.get(store, param_nid);

        val p_payload: u32 = param_node.payload;
        val pname_sid: ast.StrId = ast.get_extra(store, p_payload)::ast.StrId;
        val pname: str = ast.get_str(store, pname_sid);

        if (str_equals(pname, "...")) {
            pi = pi + 1;
            cnt;
        }

        val param_type: type.TypeId = fn_type.params[pi];
        val res_define_param: Result[scope.SymbolId, str] = scope.define_in(s.symbols, fn_scope, pname, scope.SK_PARAM);
        if (is_ok[scope.SymbolId, str](res_define_param)) {
            val psym_id: scope.SymbolId = unwrap_ok[scope.SymbolId, str](res_define_param);
            val psym: *scope.Symbol = scope.get_sym_mut(s.symbols, psym_id);
            psym.type_id = param_type::u32;
            psym.decl_node = param_nid;
            psym.module = mod_id::u32;
        }
        st.set_type(etm, param_nid, param_type);
        pi = pi + 1;
    }

    var ctx: FnContext;
    ctx.fn_sym = fn_sym_id;
    ctx.ret_type = fn_type.ret_type;
    ctx.loop_depth = 0;
    ctx.mod_id = mod_id;
    ctx.scope_id = fn_scope;
    ctx.store = store;
    ctx.etm = etm;
    ctx.nsm = nsm;

    resolve_stmt(s, ?ctx, body_id);
}

fun resolve_inst_body(s: *sema.Sema, inst: *mono.FnInst,
                      store: *ast.NodeStore, etm: *st.ExprTypeMap,
                      nsm: *st.NodeSymMap) {
    val node_id: ast.NodeId = inst.func_node;
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }

    val node: *ast.Node = ast.get(store, node_id);
    if (node.kind == ast.NK_DECL_PUB) {
        val inner: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        val inner_node: *ast.Node = ast.get(store, inner);
        if (inner_node.kind != ast.NK_DECL_FUN) { ret; }
        resolve_inst_body_inner(s, inst, inner, store, etm, nsm);
        ret;
    }
    if (node.kind != ast.NK_DECL_FUN) { ret; }
    resolve_inst_body_inner(s, inst, node_id, store, etm, nsm);
}

fun resolve_inst_body_inner(s: *sema.Sema, inst: *mono.FnInst,
                            node_id: ast.NodeId, store: *ast.NodeStore,
                            etm: *st.ExprTypeMap, nsm: *st.NodeSymMap) {
    val body_id: ast.NodeId = ast.fun_body(store, node_id);
    if (body_id::u32 == ast.NODE_NIL::u32) { ret; }

    val fn_tid: type.TypeId = inst.func_type;
    if (fn_tid::u32 == type.TYPE_NIL::u32) {
        diag.error(s.diag, diag.make_loc(nil, 0, 0), "internal: instantiation function type not resolved");
        ret;
    }
    val fn_type: *type.Type = type.get(s.types, fn_tid);
    if (fn_type.kind != type.TK_FUN) { ret; }

    val mod_id: module.ModuleId = inst.origin_module;
    val m: *module.Module = module.get(s.modules, mod_id);
    val fn_scope: scope.ScopeId = scope.create_scope(s.symbols, m.scope);

    val generics: ast.NodeId = ast.fun_generics(store, node_id);
    if (generics::u32 != ast.NODE_NIL::u32 && inst.type_arg_count > 0) {
        val gp_node: *ast.Node = ast.get(store, generics);
        if (gp_node.kind == ast.NK_GENERIC_PARAMS) {
            val gp_start: u32 = ast.get_extra(store, gp_node.payload);
            val gp_count: u32 = ast.get_extra(store, gp_node.payload + 1);
            var gi: u32 = 0;
            for (gi < gp_count && gi < inst.type_arg_count) {
                val gp_id: ast.NodeId = ast.get_extra(store, gp_start + gi)::ast.NodeId;
                val gp_n: *ast.Node = ast.get(store, gp_id);
                val gp_name_sid: ast.StrId = ast.get_extra(store, gp_n.payload)::ast.StrId;
                val gp_name: str = ast.get_str(store, gp_name_sid);
                if (gp_name != nil && inst.type_args != nil) {
                    val res_define_gp: Result[scope.SymbolId, str] = scope.define_in(s.symbols, fn_scope, gp_name, scope.SK_TYPE);
                    if (is_ok[scope.SymbolId, str](res_define_gp)) {
                        val tsym: scope.SymbolId = unwrap_ok[scope.SymbolId, str](res_define_gp);
                        val ts: *scope.Symbol = scope.get_sym_mut(s.symbols, tsym);
                        ts.type_id = inst.type_args[gi]::u32;
                    }
                }
                gi = gi + 1;
            }
        }
    }

    val params: ast.NodeSpan = ast.fun_params(store, node_id);
    var pi: u32 = 0;
    for (pi < params.len && pi::u16 < fn_type.param_count) {
        val param_nid: ast.NodeId = ast.get_extra(store, params.start + pi)::ast.NodeId;
        val param_node: *ast.Node = ast.get(store, param_nid);
        val p_payload: u32 = param_node.payload;
        val pname_sid: ast.StrId = ast.get_extra(store, p_payload)::ast.StrId;
        val pname: str = ast.get_str(store, pname_sid);
        if (str_equals(pname, "...")) { pi = pi + 1; cnt; }
        val param_type: type.TypeId = fn_type.params[pi];
        val res_define_inst_param: Result[scope.SymbolId, str] = scope.define_in(s.symbols, fn_scope, pname, scope.SK_PARAM);
        if (is_ok[scope.SymbolId, str](res_define_inst_param)) {
            val psym_id: scope.SymbolId = unwrap_ok[scope.SymbolId, str](res_define_inst_param);
            val psym: *scope.Symbol = scope.get_sym_mut(s.symbols, psym_id);
            psym.type_id = param_type::u32;
            psym.decl_node = param_nid;
            psym.module = mod_id::u32;
        }
        st.set_type(etm, param_nid, param_type);
        pi = pi + 1;
    }

    val name_sid: ast.StrId = ast.fun_name(store, node_id);
    val name: str = ast.get_str(store, name_sid);
    val opt_fn_sym2: Option[scope.SymbolId] = resolve.lookup_symbol(s, mod_id, m.scope, name);
    val fn_sym_id: scope.SymbolId = unwrap_or[scope.SymbolId](opt_fn_sym2, scope.SYM_NIL);

    var ctx: FnContext;
    ctx.fn_sym = fn_sym_id;
    ctx.ret_type = fn_type.ret_type;
    ctx.loop_depth = 0;
    ctx.mod_id = mod_id;
    ctx.scope_id = fn_scope;
    ctx.store = store;
    ctx.etm = etm;
    ctx.nsm = nsm;

    resolve_stmt(s, ?ctx, body_id);
}

fun node_loc(s: *sema.Sema, mod_id: module.ModuleId, store: *ast.NodeStore,
             node_id: ast.NodeId) diag.SourceLoc {
    val m: *module.Module = module.get(s.modules, mod_id);
    val node: *ast.Node = ast.get(store, node_id);
    val tok: token.Token = m.tokens.tokens[node.tok_idx];

    var loc: diag.SourceLoc;
    loc.file = m.file_path;
    loc.line = lexer.line_of(m.source, tok.span.offset);
    loc.col = lexer.col_of(m.source, tok.span.offset);
    loc.offset = tok.span.offset;
    loc.len = tok.span.len;
    ret loc;
}

fun resolve_stmt(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }

    val node: *ast.Node = ast.get(ctx.store, node_id);
    val kind: ast.NodeKind = node.kind;

    if (kind == ast.NK_STMT_BLOCK) {
        resolve_block(s, ctx, node_id);
        ret;
    }
    if (kind == ast.NK_DECL_VAL) {
        resolve_val_decl(s, ctx, node_id, false);
        ret;
    }
    if (kind == ast.NK_DECL_VAR) {
        resolve_val_decl(s, ctx, node_id, true);
        ret;
    }
    if (kind == ast.NK_STMT_IF) {
        resolve_if_stmt(s, ctx, node_id);
        ret;
    }
    if (kind == ast.NK_STMT_FOR) {
        resolve_for_stmt(s, ctx, node_id);
        ret;
    }
    if (kind == ast.NK_STMT_RET) {
        resolve_ret_stmt(s, ctx, node_id);
        ret;
    }
    if (kind == ast.NK_STMT_BRK) {
        if (ctx.loop_depth == 0) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "'brk' outside of loop");
        }
        ret;
    }
    if (kind == ast.NK_STMT_CNT) {
        if (ctx.loop_depth == 0) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "'cnt' outside of loop");
        }
        ret;
    }
    if (kind == ast.NK_STMT_FIN) {
        val body_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
        resolve_stmt(s, ctx, body_id);
        ret;
    }
    if (kind == ast.NK_STMT_EXPR) {
        val inner_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
        resolve_expr(s, ctx, inner_id, type.TYPE_NIL);
        ret;
    }
    if (kind == ast.NK_STMT_ASM) {
        ret;
    }
    if (kind == ast.NK_COMPTIME) {
        comptime.eval(s, ctx.mod_id, ctx.scope_id, node_id);
        ret;
    }
}

fun resolve_block(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) {
    val block_scope: scope.ScopeId = scope.create_scope(s.symbols, ctx.scope_id);

    var block_ctx: FnContext;
    block_ctx.fn_sym = ctx.fn_sym;
    block_ctx.ret_type = ctx.ret_type;
    block_ctx.loop_depth = ctx.loop_depth;
    block_ctx.mod_id = ctx.mod_id;
    block_ctx.scope_id = block_scope;
    block_ctx.store = ctx.store;
    block_ctx.etm = ctx.etm;
    block_ctx.nsm = ctx.nsm;

    val stmts: ast.NodeSpan = ast.block_stmts(ctx.store, node_id);
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(ctx.store, stmts.start + i)::ast.NodeId;
        resolve_stmt(s, ?block_ctx, child_id);
        i = i + 1;
    }
}

fun resolve_val_decl(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                     is_mutable: bool) {
    val store: *ast.NodeStore = ctx.store;
    val name_sid: ast.StrId = ast.var_name(store, node_id);
    val name: str = ast.get_str(store, name_sid);
    val type_node: ast.NodeId = ast.var_type_node(store, node_id);
    val init_node: ast.NodeId = ast.var_init(store, node_id);

    var declared_type: type.TypeId = type.TYPE_NIL;
    if (type_node::u32 != ast.NODE_NIL::u32) {
        declared_type = resolve.resolve_type_expr(s, ctx.mod_id, ctx.scope_id, type_node);
    }

    var init_type: type.TypeId = type.TYPE_NIL;
    if (init_node::u32 != ast.NODE_NIL::u32) {
        init_type = resolve_expr(s, ctx, init_node, declared_type);
    }

    var final_type: type.TypeId = declared_type;
    if (declared_type::u32 == type.TYPE_NIL::u32) {
        if (init_type::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, init_type)) {
            final_type = init_type;
        } or {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, store, node_id);
            diag.error(s.diag, loc, "cannot infer type without annotation or initializer");
            final_type = ERROR_TID;
        }
    } or {
        if (init_type::u32 != type.TYPE_NIL::u32
            && !type.is_error(s.types, init_type)
            && !type.is_error(s.types, declared_type)
            && !type.can_assign(s.types, init_type, declared_type)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, store, node_id);
            diag.error(s.diag, loc, "initializer type incompatible with declared type");
        }
    }

    var sk: scope.SymbolKind = scope.SK_VAR;
    if (!is_mutable) {
        sk = scope.SK_VAL;
    }

    st.set_type(ctx.etm, node_id, final_type);

    val res_define_var: Result[scope.SymbolId, str] = scope.define_in(s.symbols, ctx.scope_id, name, sk);
    if (is_err[scope.SymbolId, str](res_define_var)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, store, node_id);
        diag.error(s.diag, loc, "redefinition of variable in same scope");
    } or {
        val sym_id: scope.SymbolId = unwrap_ok[scope.SymbolId, str](res_define_var);
        val sym: *scope.Symbol = scope.get_sym_mut(s.symbols, sym_id);
        sym.type_id = final_type::u32;
        sym.decl_node = node_id;
        sym.module = ctx.mod_id::u32;
        sym.is_mutable = is_mutable;
        st.set_sym(ctx.nsm, node_id, sym_id);
    }

    st.set_type(ctx.etm, node_id, final_type);
}

fun resolve_if_stmt(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) {
    val cond_id: ast.NodeId = ast.cond_expr(ctx.store, node_id);
    val body_id: ast.NodeId = ast.cond_body(ctx.store, node_id);
    val or_id: ast.NodeId = ast.cond_or_chain(ctx.store, node_id);

    if (cond_id::u32 != ast.NODE_NIL::u32) {
        val cond_type: type.TypeId = resolve_expr(s, ctx, cond_id, type.primitive(s.types, type.TK_BOOL));
        if (!type.is_error(s.types, cond_type)
            && !type.types_equal(s.types, cond_type, type.primitive(s.types, type.TK_BOOL))) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, cond_id);
            diag.error(s.diag, loc, "if condition must be bool");
        }
    }

    resolve_stmt(s, ctx, body_id);

    if (or_id::u32 != ast.NODE_NIL::u32) {
        resolve_or_chain(s, ctx, or_id);
    }
}

fun resolve_or_chain(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }

    val node: *ast.Node = ast.get(ctx.store, node_id);
    if (node.kind != ast.NK_STMT_OR) { ret; }

    val cond_id: ast.NodeId = ast.cond_expr(ctx.store, node_id);
    val body_id: ast.NodeId = ast.cond_body(ctx.store, node_id);
    val or_id: ast.NodeId = ast.cond_or_chain(ctx.store, node_id);

    if (cond_id::u32 != ast.NODE_NIL::u32) {
        val cond_type: type.TypeId = resolve_expr(s, ctx, cond_id, type.primitive(s.types, type.TK_BOOL));
        if (!type.is_error(s.types, cond_type)
            && !type.types_equal(s.types, cond_type, type.primitive(s.types, type.TK_BOOL))) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, cond_id);
            diag.error(s.diag, loc, "or condition must be bool");
        }
    }

    resolve_stmt(s, ctx, body_id);

    if (or_id::u32 != ast.NODE_NIL::u32) {
        resolve_or_chain(s, ctx, or_id);
    }
}

fun resolve_for_stmt(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val cond_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
    val body_id: ast.NodeId = ast.get_extra(ctx.store, node.payload + 1)::ast.NodeId;

    if (cond_id::u32 != ast.NODE_NIL::u32) {
        val cond_type: type.TypeId = resolve_expr(s, ctx, cond_id, type.primitive(s.types, type.TK_BOOL));
        if (!type.is_error(s.types, cond_type)
            && !type.types_equal(s.types, cond_type, type.primitive(s.types, type.TK_BOOL))) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, cond_id);
            diag.error(s.diag, loc, "for condition must be bool");
        }
    }

    ctx.loop_depth = ctx.loop_depth + 1;
    resolve_stmt(s, ctx, body_id);
    ctx.loop_depth = ctx.loop_depth - 1;
}

fun resolve_ret_stmt(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val value_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;

    if (value_id::u32 == ast.NODE_NIL::u32) {
        if (!type.types_equal(s.types, ctx.ret_type, type.primitive(s.types, type.TK_VOID))) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "non-void function must return a value");
        }
        ret;
    }

    val val_type: type.TypeId = resolve_expr(s, ctx, value_id, ctx.ret_type);

    if (type.is_error(s.types, val_type)) { ret; }
    if (type.is_error(s.types, ctx.ret_type)) { ret; }

    if (!type.can_assign(s.types, val_type, ctx.ret_type)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, value_id);
        diag.error(s.diag, loc, "return type mismatch");
    }
}

fun resolve_expr(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                 expected: type.TypeId) type.TypeId {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret ERROR_TID; }

    val node: *ast.Node = ast.get(ctx.store, node_id);
    val kind: ast.NodeKind = node.kind;

    if (kind == ast.NK_EXPR_ERROR) {
        st.set_type(ctx.etm, node_id, ERROR_TID);
        ret ERROR_TID;
    }

    var result: type.TypeId = ERROR_TID;

    if (kind == ast.NK_EXPR_LIT_INT) {
        result = resolve_lit_int(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_LIT_FLOAT) {
        result = resolve_lit_float(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_LIT_CHAR) {
        result = type.primitive(s.types, type.TK_U8);
    }
    or (kind == ast.NK_EXPR_LIT_STR) {
        result = type.make_pointer(s.types, type.primitive(s.types, type.TK_U8));
    }
    or (kind == ast.NK_EXPR_LIT_BOOL) {
        result = type.primitive(s.types, type.TK_BOOL);
    }
    or (kind == ast.NK_EXPR_LIT_NIL) {
        result = resolve_lit_nil(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_IDENT) {
        result = resolve_ident(s, ctx, node_id);
    }
    or (kind == ast.NK_EXPR_BINARY) {
        result = resolve_binary(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_UNARY) {
        result = resolve_unary(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_CALL) {
        result = resolve_call(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_FIELD) {
        result = resolve_field(s, ctx, node_id);
    }
    or (kind == ast.NK_EXPR_INDEX) {
        result = resolve_index(s, ctx, node_id);
    }
    or (kind == ast.NK_EXPR_CAST) {
        result = resolve_cast(s, ctx, node_id);
    }
    or (kind == ast.NK_EXPR_ADDR) {
        result = resolve_addr(s, ctx, node_id);
    }
    or (kind == ast.NK_EXPR_DEREF) {
        result = resolve_deref(s, ctx, node_id);
    }
    or (kind == ast.NK_EXPR_PAREN) {
        val inner_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
        result = resolve_expr(s, ctx, inner_id, expected);
    }
    or (kind == ast.NK_EXPR_STRUCT_LIT) {
        result = resolve_struct_lit(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_EXPR_ARRAY_LIT) {
        result = resolve_array_lit(s, ctx, node_id, expected);
    }
    or (kind == ast.NK_COMPTIME) {
        result = resolve_comptime_expr(s, ctx, node_id);
    }
    or {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "unsupported expression kind");
    }

    st.set_type(ctx.etm, node_id, result);
    ret result;
}

fun resolve_comptime_expr(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val inner_id: ast.NodeId = ast.get_extra(ctx.store, ast.get(ctx.store, node_id).payload)::ast.NodeId;
    if (inner_id::u32 == ast.NODE_NIL::u32) { ret ERROR_TID; }

    val inner: *ast.Node = ast.get(ctx.store, inner_id);
    if (inner.kind == ast.NK_EXPR_CALL) {
        val callee_id: ast.NodeId = ast.call_callee(ctx.store, inner_id);
        val callee: *ast.Node = ast.get(ctx.store, callee_id);
        if (callee.kind == ast.NK_EXPR_IDENT) {
            val name_sid: ast.StrId = ast.get_extra(ctx.store, callee.payload)::ast.StrId;
            val name: str = ast.get_str(ctx.store, name_sid);
            if (str_equals(name, "size_of") || str_equals(name, "align_of") || str_equals(name, "offset_of")) {
                comptime.eval(s, ctx.mod_id, ctx.scope_id, node_id);
                ret type.primitive(s.types, type.TK_U64);
            }
        }
    }

    comptime.eval(s, ctx.mod_id, ctx.scope_id, node_id);
    ret type.primitive(s.types, type.TK_VOID);
}

fun resolve_lit_int(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                    expected: type.TypeId) type.TypeId {
    if (expected::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, expected)) {
        if (type.is_integer(s.types, expected)) {
            ret expected;
        }
    }
    ret type.primitive(s.types, type.TK_I64);
}

fun resolve_lit_float(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                      expected: type.TypeId) type.TypeId {
    if (expected::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, expected)) {
        if (type.is_float(s.types, expected)) {
            ret expected;
        }
    }
    ret type.primitive(s.types, type.TK_F64);
}

fun resolve_lit_nil(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                    expected: type.TypeId) type.TypeId {
    if (expected::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, expected)) {
        if (type.is_pointer(s.types, expected)) {
            ret expected;
        }
    }
    ret type.primitive(s.types, type.TK_NIL);
}

fun resolve_ident(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val name_sid: ast.StrId = ast.get_extra(ctx.store, node.payload)::ast.StrId;
    val name: str = ast.get_str(ctx.store, name_sid);

    val opt_ident_sym: Option[scope.SymbolId] = scope.lookup_from(s.symbols, ctx.scope_id, name);
    if (is_none[scope.SymbolId](opt_ident_sym)) {
        val opt_rsym: Option[scope.SymbolId] = resolve.lookup_symbol(s, ctx.mod_id, ctx.scope_id, name);
        if (is_none[scope.SymbolId](opt_rsym)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "undefined identifier");
            ret ERROR_TID;
        }
        val rsym: scope.SymbolId = unwrap[scope.SymbolId](opt_rsym);
        st.set_sym(ctx.nsm, node_id, rsym);
        val rsym_ref: *scope.Symbol = scope.get_sym(s.symbols, rsym);
        if (rsym_ref.type_id == scope.TYPE_ID_UNSET) { ret ERROR_TID; }
        ret rsym_ref.type_id::type.TypeId;
    }

    val sym_id: scope.SymbolId = unwrap[scope.SymbolId](opt_ident_sym);
    st.set_sym(ctx.nsm, node_id, sym_id);
    val sym: *scope.Symbol = scope.get_sym(s.symbols, sym_id);
    if (sym.type_id == scope.TYPE_ID_UNSET) { ret ERROR_TID; }
    ret sym.type_id::type.TypeId;
}

fun resolve_binary(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                   expected: type.TypeId) type.TypeId {
    val lhs_id: ast.NodeId = ast.binary_lhs(ctx.store, node_id);
    val rhs_id: ast.NodeId = ast.binary_rhs(ctx.store, node_id);
    val op: u8 = ast.binary_op(ctx.store, node_id);

    if (op == token.TAG_EQ::u8) {
        ret resolve_assign(s, ctx, node_id, lhs_id, rhs_id);
    }

    if (op == token.TAG_AMP_AMP::u8 || op == token.TAG_PIPE_PIPE::u8) {
        ret resolve_logical(s, ctx, node_id, lhs_id, rhs_id, op);
    }

    if (op == token.TAG_EQ_EQ::u8 || op == token.TAG_BANG_EQ::u8
        || op == token.TAG_LT::u8 || op == token.TAG_LT_EQ::u8
        || op == token.TAG_GT::u8 || op == token.TAG_GT_EQ::u8) {
        ret resolve_comparison(s, ctx, node_id, lhs_id, rhs_id, op);
    }

    if (op == token.TAG_AMP::u8 || op == token.TAG_PIPE::u8
        || op == token.TAG_CARET::u8 || op == token.TAG_LT_LT::u8
        || op == token.TAG_GT_GT::u8) {
        ret resolve_bitwise(s, ctx, node_id, lhs_id, rhs_id, op, expected);
    }

    ret resolve_arithmetic(s, ctx, node_id, lhs_id, rhs_id, op, expected);
}

fun resolve_assign(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                   lhs_id: ast.NodeId, rhs_id: ast.NodeId) type.TypeId {
    val lhs_type: type.TypeId = resolve_expr(s, ctx, lhs_id, type.TYPE_NIL);
    if (type.is_error(s.types, lhs_type)) {
        resolve_expr(s, ctx, rhs_id, type.TYPE_NIL);
        ret ERROR_TID;
    }

    val rhs_type: type.TypeId = resolve_expr(s, ctx, rhs_id, lhs_type);
    if (type.is_error(s.types, rhs_type)) { ret ERROR_TID; }

    val lhs_sym_id: scope.SymbolId = st.get_sym(ctx.nsm, lhs_id);
    if (lhs_sym_id::u32 != scope.SYM_NIL::u32) {
        val lhs_sym: *scope.Symbol = scope.get_sym(s.symbols, lhs_sym_id);
        if (!lhs_sym.is_mutable && lhs_sym.kind != scope.SK_PARAM) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, lhs_id);
            diag.error(s.diag, loc, "cannot assign to immutable binding");
        }
    }

    if (!type.can_assign(s.types, rhs_type, lhs_type)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "assignment type mismatch");
    }

    ret type.primitive(s.types, type.TK_VOID);
}

fun resolve_logical(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                    lhs_id: ast.NodeId, rhs_id: ast.NodeId, op: u8) type.TypeId {
    val bool_tid: type.TypeId = type.primitive(s.types, type.TK_BOOL);

    val lhs_type: type.TypeId = resolve_expr(s, ctx, lhs_id, bool_tid);
    val rhs_type: type.TypeId = resolve_expr(s, ctx, rhs_id, bool_tid);

    if (type.is_error(s.types, lhs_type) || type.is_error(s.types, rhs_type)) {
        ret ERROR_TID;
    }

    if (!type.types_equal(s.types, lhs_type, bool_tid)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, lhs_id);
        diag.error(s.diag, loc, "logical operator requires bool operands");
        ret ERROR_TID;
    }
    if (!type.types_equal(s.types, rhs_type, bool_tid)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, rhs_id);
        diag.error(s.diag, loc, "logical operator requires bool operands");
        ret ERROR_TID;
    }

    ret bool_tid;
}

fun resolve_comparison(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                       lhs_id: ast.NodeId, rhs_id: ast.NodeId, op: u8) type.TypeId {
    val lhs_type: type.TypeId = resolve_expr(s, ctx, lhs_id, type.TYPE_NIL);
    if (type.is_error(s.types, lhs_type)) {
        resolve_expr(s, ctx, rhs_id, type.TYPE_NIL);
        ret ERROR_TID;
    }

    val rhs_type: type.TypeId = resolve_expr(s, ctx, rhs_id, lhs_type);
    if (type.is_error(s.types, rhs_type)) { ret ERROR_TID; }

    val can_eq: bool = op == token.TAG_EQ_EQ::u8 || op == token.TAG_BANG_EQ::u8;

    if (type.is_numeric(s.types, lhs_type) && type.is_numeric(s.types, rhs_type)) {
        ret type.primitive(s.types, type.TK_BOOL);
    }

    if (can_eq && type.is_pointer(s.types, lhs_type) && type.is_pointer(s.types, rhs_type)) {
        ret type.primitive(s.types, type.TK_BOOL);
    }

    if (can_eq && type.types_equal(s.types, lhs_type, type.primitive(s.types, type.TK_BOOL))
        && type.types_equal(s.types, rhs_type, type.primitive(s.types, type.TK_BOOL))) {
        ret type.primitive(s.types, type.TK_BOOL);
    }

    if (can_eq) {
        val cl: type.TypeId = type.canonical(s.types, lhs_type);
        val cr: type.TypeId = type.canonical(s.types, rhs_type);
        val tl: *type.Type = type.get(s.types, cl);
        val tr: *type.Type = type.get(s.types, cr);
        val lhs_nullable: bool = tl.kind == type.TK_POINTER || tl.kind == type.TK_OPAQUE_PTR || tl.kind == type.TK_FUN;
        val rhs_nullable: bool = tr.kind == type.TK_POINTER || tr.kind == type.TK_OPAQUE_PTR || tr.kind == type.TK_FUN;
        if (tl.kind == type.TK_NIL && rhs_nullable) {
            ret type.primitive(s.types, type.TK_BOOL);
        }
        if (tr.kind == type.TK_NIL && lhs_nullable) {
            ret type.primitive(s.types, type.TK_BOOL);
        }
    }

    val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
    diag.error(s.diag, loc, "invalid operand types for comparison");
    ret ERROR_TID;
}

fun resolve_bitwise(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                    lhs_id: ast.NodeId, rhs_id: ast.NodeId, op: u8,
                    expected: type.TypeId) type.TypeId {
    val lhs_type: type.TypeId = resolve_expr(s, ctx, lhs_id, expected);
    if (type.is_error(s.types, lhs_type)) {
        resolve_expr(s, ctx, rhs_id, expected);
        ret ERROR_TID;
    }

    val rhs_type: type.TypeId = resolve_expr(s, ctx, rhs_id, lhs_type);
    if (type.is_error(s.types, rhs_type)) { ret ERROR_TID; }

    if (!type.is_integer(s.types, lhs_type)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, lhs_id);
        diag.error(s.diag, loc, "bitwise operator requires integer operands");
        ret ERROR_TID;
    }
    if (!type.is_integer(s.types, rhs_type)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, rhs_id);
        diag.error(s.diag, loc, "bitwise operator requires integer operands");
        ret ERROR_TID;
    }

    ret lhs_type;
}

fun resolve_arithmetic(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                       lhs_id: ast.NodeId, rhs_id: ast.NodeId, op: u8,
                       expected: type.TypeId) type.TypeId {
    val lhs_type: type.TypeId = resolve_expr(s, ctx, lhs_id, expected);
    if (type.is_error(s.types, lhs_type)) {
        resolve_expr(s, ctx, rhs_id, expected);
        ret ERROR_TID;
    }

    val rhs_type: type.TypeId = resolve_expr(s, ctx, rhs_id, lhs_type);
    if (type.is_error(s.types, rhs_type)) { ret ERROR_TID; }

    if (type.is_numeric(s.types, lhs_type) && type.is_numeric(s.types, rhs_type)) {
        ret lhs_type;
    }

    if (type.is_pointer(s.types, lhs_type) && type.is_integer(s.types, rhs_type)) {
        if (op == token.TAG_PLUS::u8 || op == token.TAG_MINUS::u8) {
            ret lhs_type;
        }
    }

    val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
    diag.error(s.diag, loc, "invalid operand types for arithmetic");
    ret ERROR_TID;
}

fun resolve_unary(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                  expected: type.TypeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
    val op: u8 = ast.get_extra(ctx.store, node.payload + 1)::u8;

    if (op == token.TAG_MINUS::u8) {
        val operand_type: type.TypeId = resolve_expr(s, ctx, operand_id, expected);
        if (type.is_error(s.types, operand_type)) { ret ERROR_TID; }
        if (!type.is_numeric(s.types, operand_type)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "unary '-' requires numeric operand");
            ret ERROR_TID;
        }
        ret operand_type;
    }

    if (op == token.TAG_BANG::u8) {
        val operand_type: type.TypeId = resolve_expr(s, ctx, operand_id, type.primitive(s.types, type.TK_BOOL));
        if (type.is_error(s.types, operand_type)) { ret ERROR_TID; }
        val ct_op: type.TypeId = type.canonical(s.types, operand_type);
        val bool_ok: bool = type.types_equal(s.types, ct_op, type.primitive(s.types, type.TK_BOOL))
                         || type.types_equal(s.types, ct_op, type.primitive(s.types, type.TK_U8));
        if (!bool_ok) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "unary '!' requires bool operand");
            ret ERROR_TID;
        }
        ret type.primitive(s.types, type.TK_BOOL);
    }

    if (op == token.TAG_TILDE::u8) {
        val operand_type: type.TypeId = resolve_expr(s, ctx, operand_id, expected);
        if (type.is_error(s.types, operand_type)) { ret ERROR_TID; }
        if (!type.is_integer(s.types, operand_type)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "unary '~' requires integer operand");
            ret ERROR_TID;
        }
        ret operand_type;
    }

    val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
    diag.error(s.diag, loc, "unknown unary operator");
    ret ERROR_TID;
}

fun try_resolve_va_builtin(s: *sema.Sema, ctx: *FnContext,
                           node_id: ast.NodeId, callee_id: ast.NodeId,
                           args: ast.NodeSpan) type.TypeId {
    val callee_node: *ast.Node = ast.get(ctx.store, callee_id);
    if (callee_node.kind != ast.NK_EXPR_IDENT) { ret type.TYPE_NIL; }

    val name_sid: ast.StrId = ast.get_extra(ctx.store, callee_node.payload)::ast.StrId;
    val name: str = ast.get_str(ctx.store, name_sid);
    if (name == nil) { ret type.TYPE_NIL; }

    val va_list_type: type.TypeId = type.builtin_va_list(s.types);
    val va_list_ptr: type.TypeId = type.make_pointer(s.types, va_list_type);

    if (str_equals(name, "va_start") || str_equals(name, "va_end")) {
        if (args.len != 1) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "va_start/va_end require exactly 1 argument");
            ret ERROR_TID;
        }
        val arg_id: ast.NodeId = ast.get_extra(ctx.store, args.start)::ast.NodeId;
        val arg_type: type.TypeId = resolve_expr(s, ctx, arg_id, va_list_ptr);
        if (!type.is_error(s.types, arg_type) && !type.can_assign(s.types, arg_type, va_list_ptr)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, arg_id);
            diag.error(s.diag, loc, "va_start/va_end argument must be *va_list");
        }
        ret type.primitive(s.types, type.TK_VOID);
    }

    if (str_equals(name, "va_arg")) {
        if (args.len != 1) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "va_arg requires exactly 1 argument");
            ret ERROR_TID;
        }
        val arg_id: ast.NodeId = ast.get_extra(ctx.store, args.start)::ast.NodeId;
        val arg_type: type.TypeId = resolve_expr(s, ctx, arg_id, va_list_ptr);
        if (!type.is_error(s.types, arg_type) && !type.can_assign(s.types, arg_type, va_list_ptr)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, arg_id);
            diag.error(s.diag, loc, "va_arg argument must be *va_list");
        }
        val type_arg_node: ast.NodeId = ast.call_type_args(ctx.store, node_id);
        if (type_arg_node::u32 == ast.NODE_NIL::u32) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
            diag.error(s.diag, loc, "va_arg requires a type argument: va_arg[T](ap)");
            ret ERROR_TID;
        }
        val ta_node: *ast.Node = ast.get(ctx.store, type_arg_node);
        var first_type_node: ast.NodeId = type_arg_node;
        if (ta_node.kind == ast.NK_GENERIC_PARAMS) {
            val ta_start: u32 = ast.get_extra(ctx.store, ta_node.payload);
            first_type_node = ast.get_extra(ctx.store, ta_start)::ast.NodeId;
        }
        val result_type: type.TypeId = resolve.resolve_type_expr(s, ctx.mod_id, ctx.scope_id, first_type_node);
        if (type.is_error(s.types, result_type)) {
            ret ERROR_TID;
        }
        ret result_type;
    }

    ret type.TYPE_NIL;
}

fun get_inst_mangled_name(s: *sema.Sema, sym: *scope.Symbol, func_type: type.TypeId) str {
    if (s.mono == nil) { ret nil; }
    val count: u32 = mono.fn_count(s.mono);
    var i: u32 = 0;
    for (i < count) {
        val fi: *mono.FnInst = mono.get_fn(s.mono, i);
        if (fi != nil && fi.func_type::u32 == func_type::u32) {
            ret fi.mangled_name;
        }
        i = i + 1;
    }
    ret nil;
}

fun instantiate_generic_call(s: *sema.Sema, ctx: *FnContext,
                             fn_sym: scope.SymbolId,
                             type_args_node: ast.NodeId) type.TypeId {
    val sym: *scope.Symbol = scope.get_sym(s.symbols, fn_sym);
    val origin_mod: module.ModuleId = sym.module::module.ModuleId;
    val om: *module.Module = module.get(s.modules, origin_mod);
    val decl_node: ast.NodeId = sym.decl_node;

    val generics: ast.NodeId = ast.fun_generics(?om.store, decl_node);
    if (generics::u32 == ast.NODE_NIL::u32) { ret ERROR_TID; }
    val gp_node: *ast.Node = ast.get(?om.store, generics);
    if (gp_node.kind != ast.NK_GENERIC_PARAMS) { ret ERROR_TID; }
    val gp_start: u32 = ast.get_extra(?om.store, gp_node.payload);
    val gp_count: u32 = ast.get_extra(?om.store, gp_node.payload + 1);

    val ta_node: *ast.Node = ast.get(ctx.store, type_args_node);
    if (ta_node.kind != ast.NK_GENERIC_PARAMS) { ret ERROR_TID; }
    val ta_start: u32 = ast.get_extra(ctx.store, ta_node.payload);
    val ta_count: u32 = ast.get_extra(ctx.store, ta_node.payload + 1);
    if (gp_count != ta_count) { ret ERROR_TID; }

    var arg_types: [64]type.TypeId;
    var i: u32 = 0;
    for (i < ta_count && i < 64) {
        val ta_id: ast.NodeId = ast.get_extra(ctx.store, ta_start + i)::ast.NodeId;
        val resolved: type.TypeId = resolve.resolve_type_expr(s, ctx.mod_id, ctx.scope_id, ta_id);
        if (resolved::u32 == type.TYPE_NIL::u32 || type.is_error(s.types, resolved)) {
            ret ERROR_TID;
        }
        arg_types[i] = resolved;
        i = i + 1;
    }

    val mangled: str = mono.mangle_name(s.mono, om.path, sym.name, ?arg_types[0], ta_count, s.types);
    if (mangled == nil) { ret ERROR_TID; }

    val cached: type.TypeId = mono.lookup_fn(s.mono, mangled);
    if (cached::u32 != type.TYPE_NIL::u32) { ret cached; }

    val inst_scope: scope.ScopeId = scope.create_scope(s.symbols, om.scope);
    i = 0;
    for (i < gp_count) {
        val gp_id: ast.NodeId = ast.get_extra(?om.store, gp_start + i)::ast.NodeId;
        val gp_n: *ast.Node = ast.get(?om.store, gp_id);
        val gp_name_sid: ast.StrId = ast.get_extra(?om.store, gp_n.payload)::ast.StrId;
        val gp_name: str = ast.get_str(?om.store, gp_name_sid);

        val res_define_gp: Result[scope.SymbolId, str] = scope.define_in(s.symbols, inst_scope, gp_name, scope.SK_TYPE);
        if (is_ok[scope.SymbolId, str](res_define_gp)) {
            val tsym: scope.SymbolId = unwrap_ok[scope.SymbolId, str](res_define_gp);
            val ts: *scope.Symbol = scope.get_sym_mut(s.symbols, tsym);
            ts.type_id = arg_types[i]::u32;
        }
        i = i + 1;
    }

    val fun_type: type.TypeId = resolve.resolve_fun_signature(s, origin_mod, inst_scope,
                                                               ?om.store, decl_node, mangled);

    mono.register_fn(s.mono, mangled, decl_node, om.store, fun_type, origin_mod,
                     ?arg_types[0], ta_count);

    ret fun_type;
}

fun resolve_call(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                 expected: type.TypeId) type.TypeId {
    val callee_id: ast.NodeId = ast.call_callee(ctx.store, node_id);
    val args: ast.NodeSpan = ast.call_args(ctx.store, node_id);

    val builtin: type.TypeId = try_resolve_va_builtin(s, ctx, node_id, callee_id, args);
    if (builtin::u32 != type.TYPE_NIL::u32) {
        ret builtin;
    }

    var callee_type: type.TypeId = resolve_expr(s, ctx, callee_id, type.TYPE_NIL);

    val call_type_args: ast.NodeId = ast.call_type_args(ctx.store, node_id);
    if (call_type_args::u32 != ast.NODE_NIL::u32) {
        val callee_node: *ast.Node = ast.get(ctx.store, callee_id);
        var csym: scope.SymbolId = scope.SYM_NIL;
        if (callee_node.kind == ast.NK_EXPR_IDENT) {
            val csid: ast.StrId = ast.get_extra(ctx.store, callee_node.payload)::ast.StrId;
            val cname: str = ast.get_str(ctx.store, csid);
            val opt_csym: Option[scope.SymbolId] = resolve.lookup_symbol(s, ctx.mod_id, ctx.scope_id, cname);
            if (is_some[scope.SymbolId](opt_csym)) {
                csym = unwrap[scope.SymbolId](opt_csym);
            }
        } or (callee_node.kind == ast.NK_EXPR_FIELD) {
            val base_id: ast.NodeId = ast.get_extra(ctx.store, callee_node.payload)::ast.NodeId;
            val field_sid: ast.StrId = ast.get_extra(ctx.store, callee_node.payload + 1)::ast.StrId;
            val field_name: str = ast.get_str(ctx.store, field_sid);
            val base_node: *ast.Node = ast.get(ctx.store, base_id);
            if (base_node.kind == ast.NK_EXPR_IDENT) {
                val base_sid: ast.StrId = ast.get_extra(ctx.store, base_node.payload)::ast.StrId;
                val base_name: str = ast.get_str(ctx.store, base_sid);
                val alias_mod: module.ModuleId = module.resolve_alias(s.modules, ctx.mod_id, base_name);
                if (alias_mod::u32 != module.MOD_NIL::u32) {
                    val tm: *module.Module = module.get(s.modules, alias_mod);
                    if (tm.scope::u32 != scope.SCOPE_NIL::u32) {
                        val opt_callee_sym: Option[scope.SymbolId] = scope.lookup_local(s.symbols, tm.scope, field_name);
                        if (is_some[scope.SymbolId](opt_callee_sym)) {
                            csym = unwrap[scope.SymbolId](opt_callee_sym);
                        }
                    }
                }
            }
        }
        if (csym::u32 != scope.SYM_NIL::u32) {
            val cs: *scope.Symbol = scope.get_sym(s.symbols, csym);
            if (cs.is_generic && s.mono != nil) {
                callee_type = instantiate_generic_call(s, ctx, csym, call_type_args);
                if (!type.is_error(s.types, callee_type)) {
                    val res_alloc_inst: Result[scope.SymbolId, str] = scope.alloc_sym(s.symbols);
                    if (is_ok[scope.SymbolId, str](res_alloc_inst)) {
                        val inst_sym: scope.SymbolId = unwrap_ok[scope.SymbolId, str](res_alloc_inst);
                        val is: *scope.Symbol = scope.get_sym_mut(s.symbols, inst_sym);
                        is.name        = cs.name;
                        is.kind        = scope.SK_FUN;
                        is.type_id     = callee_type::u32;
                        is.module      = cs.module;
                        is.export_name = get_inst_mangled_name(s, cs, callee_type);
                        st.set_sym(ctx.nsm, callee_id, inst_sym);
                    }
                }
            }
        }
    }

    if (type.is_error(s.types, callee_type)) {
        var ai: u32 = 0;
        for (ai < args.len) {
            val arg_id: ast.NodeId = ast.get_extra(ctx.store, args.start + ai)::ast.NodeId;
            resolve_expr(s, ctx, arg_id, type.TYPE_NIL);
            ai = ai + 1;
        }
        ret ERROR_TID;
    }

    val ct: type.TypeId = type.canonical(s.types, callee_type);
    val fn_t: *type.Type = type.get(s.types, ct);

    if (fn_t.kind != type.TK_FUN) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, callee_id);
        diag.error(s.diag, loc, "called expression is not a function");
        var ai: u32 = 0;
        for (ai < args.len) {
            val arg_id: ast.NodeId = ast.get_extra(ctx.store, args.start + ai)::ast.NodeId;
            resolve_expr(s, ctx, arg_id, type.TYPE_NIL);
            ai = ai + 1;
        }
        ret ERROR_TID;
    }

    if (!fn_t.is_variadic && args.len != fn_t.param_count::u32) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "wrong number of arguments");
    }
    or (fn_t.is_variadic && args.len < fn_t.param_count::u32) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "too few arguments for variadic function");
    }

    var ai: u32 = 0;
    for (ai < args.len) {
        val arg_id: ast.NodeId = ast.get_extra(ctx.store, args.start + ai)::ast.NodeId;

        var param_type: type.TypeId = type.TYPE_NIL;
        if (ai::u16 < fn_t.param_count) {
            param_type = fn_t.params[ai];
        }

        val arg_type: type.TypeId = resolve_expr(s, ctx, arg_id, param_type);

        if (!type.is_error(s.types, arg_type) && param_type::u32 != type.TYPE_NIL::u32
            && !type.is_error(s.types, param_type)) {
            if (!type.can_assign(s.types, arg_type, param_type)) {
                val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, arg_id);
                diag.error(s.diag, loc, "argument type mismatch");
            }
        }

        ai = ai + 1;
    }

    ret fn_t.ret_type;
}

fun try_resolve_module_field(s: *sema.Sema, ctx: *FnContext,
                             node_id: ast.NodeId,
                             base_id: ast.NodeId,
                             field_name: str) type.TypeId {
    val base_node: *ast.Node = ast.get(ctx.store, base_id);
    if (base_node.kind != ast.NK_EXPR_IDENT) { ret type.TYPE_NIL; }

    val base_name_sid: ast.StrId = ast.get_extra(ctx.store, base_node.payload)::ast.StrId;
    val base_name: str = ast.get_str(ctx.store, base_name_sid);

    val alias_mod: module.ModuleId = module.resolve_alias(s.modules, ctx.mod_id, base_name);
    if (alias_mod::u32 == module.MOD_NIL::u32) { ret type.TYPE_NIL; }

    val tm: *module.Module = module.get(s.modules, alias_mod);
    if (tm.scope::u32 == scope.SCOPE_NIL::u32) { ret type.TYPE_NIL; }

    val opt_mod_field: Option[scope.SymbolId] = scope.lookup_local(s.symbols, tm.scope, field_name);
    if (is_none[scope.SymbolId](opt_mod_field)) {
        ret type.TYPE_NIL;
    }
    val found: scope.SymbolId = unwrap[scope.SymbolId](opt_mod_field);

    val fsym: *scope.Symbol = scope.get_sym(s.symbols, found);
    if (!fsym.is_public) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "symbol is not public");
        ret ERROR_TID;
    }

    resolve.ensure_symbol_resolved(s, found);
    st.set_sym(ctx.nsm, node_id, found);
    val fsym2: *scope.Symbol = scope.get_sym(s.symbols, found);
    if (fsym2.type_id == scope.TYPE_ID_UNSET) { ret ERROR_TID; }
    ret fsym2.type_id::type.TypeId;
}

fun resolve_field(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val base_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
    val field_sid: ast.StrId = ast.get_extra(ctx.store, node.payload + 1)::ast.StrId;
    val field_name: str = ast.get_str(ctx.store, field_sid);

    val mod_result: type.TypeId = try_resolve_module_field(s, ctx, node_id, base_id, field_name);
    if (mod_result::u32 != type.TYPE_NIL::u32) { ret mod_result; }

    val base_type: type.TypeId = resolve_expr(s, ctx, base_id, type.TYPE_NIL);
    if (type.is_error(s.types, base_type)) { ret ERROR_TID; }

    var rec_type: type.TypeId = base_type;
    val ct: type.TypeId = type.canonical(s.types, base_type);
    val bt: *type.Type = type.get(s.types, ct);

    if (bt.kind == type.TK_POINTER) {
        rec_type = bt.pointee;
    }

    val crt: type.TypeId = type.canonical(s.types, rec_type);
    val rt: *type.Type = type.get(s.types, crt);

    if (rt.kind != type.TK_RECORD && rt.kind != type.TK_UNION) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "field access on non-record type");
        ret ERROR_TID;
    }

    val field: *type.TypeField = type.get_field(s.types, crt, field_name);
    if (field == nil) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "no such field");
        ret ERROR_TID;
    }

    ret field.type_id;
}

fun resolve_index(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val base_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
    val index_id: ast.NodeId = ast.get_extra(ctx.store, node.payload + 1)::ast.NodeId;

    val base_type: type.TypeId = resolve_expr(s, ctx, base_id, type.TYPE_NIL);
    val index_type: type.TypeId = resolve_expr(s, ctx, index_id, type.primitive(s.types, type.TK_U64));

    if (type.is_error(s.types, base_type) || type.is_error(s.types, index_type)) {
        ret ERROR_TID;
    }

    if (!type.is_integer(s.types, index_type)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, index_id);
        diag.error(s.diag, loc, "index must be an integer");
        ret ERROR_TID;
    }

    val ct: type.TypeId = type.canonical(s.types, base_type);
    val bt: *type.Type = type.get(s.types, ct);

    if (bt.kind == type.TK_ARRAY) {
        ret bt.elem;
    }

    if (bt.kind == type.TK_POINTER) {
        ret bt.pointee;
    }

    val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, base_id);
    diag.error(s.diag, loc, "index operation requires array or pointer type");
    ret ERROR_TID;
}

fun resolve_cast(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
    val target_node: ast.NodeId = ast.get_extra(ctx.store, node.payload + 1)::ast.NodeId;

    val target_type: type.TypeId = resolve.resolve_type_expr(s, ctx.mod_id, ctx.scope_id, target_node);
    val src_type: type.TypeId = resolve_expr(s, ctx, operand_id, target_type);

    if (type.is_error(s.types, src_type) || type.is_error(s.types, target_type)) {
        ret ERROR_TID;
    }

    if (target_type::u32 == type.TYPE_NIL::u32) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, target_node);
        diag.error(s.diag, loc, "unresolved cast target type");
        ret ERROR_TID;
    }

    if (!type.can_cast(s.types, src_type, target_type)) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "invalid cast");
        ret ERROR_TID;
    }

    ret target_type;
}

fun resolve_addr(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;

    val operand_type: type.TypeId = resolve_expr(s, ctx, operand_id, type.TYPE_NIL);
    if (type.is_error(s.types, operand_type)) { ret ERROR_TID; }

    ret type.make_pointer(s.types, operand_type);
}

fun resolve_deref(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;

    val operand_type: type.TypeId = resolve_expr(s, ctx, operand_id, type.TYPE_NIL);
    if (type.is_error(s.types, operand_type)) { ret ERROR_TID; }

    val ct: type.TypeId = type.canonical(s.types, operand_type);
    val t: *type.Type = type.get(s.types, ct);

    if (t.kind != type.TK_POINTER && t.kind != type.TK_OPAQUE_PTR) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "dereference of non-pointer type");
        ret ERROR_TID;
    }

    if (t.kind == type.TK_OPAQUE_PTR) {
        ret type.primitive(s.types, type.TK_U8);
    }

    ret t.pointee;
}

fun resolve_struct_lit(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                       expected: type.TypeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val type_node_id: ast.NodeId = ast.get_extra(ctx.store, node.payload)::ast.NodeId;
    val fields_start: u32 = ast.get_extra(ctx.store, node.payload + 1);
    val fields_count: u32 = ast.get_extra(ctx.store, node.payload + 2);

    val rec_type: type.TypeId = resolve_expr(s, ctx, type_node_id, type.TYPE_NIL);

    if (rec_type::u32 == type.TYPE_NIL::u32 || type.is_error(s.types, rec_type)) {
        var fi: u32 = 0;
        for (fi < fields_count) {
            val fi_nid: ast.NodeId = ast.get_extra(ctx.store, fields_start + fi)::ast.NodeId;
            val fi_node: *ast.Node = ast.get(ctx.store, fi_nid);
            val fi_value: ast.NodeId = ast.get_extra(ctx.store, fi_node.payload + 1)::ast.NodeId;
            resolve_expr(s, ctx, fi_value, type.TYPE_NIL);
            fi = fi + 1;
        }
        ret ERROR_TID;
    }

    val crt: type.TypeId = type.canonical(s.types, rec_type);
    val rt: *type.Type = type.get(s.types, crt);

    if (rt.kind != type.TK_RECORD) {
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "struct literal for non-record type");
        ret ERROR_TID;
    }

    var fi: u32 = 0;
    for (fi < fields_count) {
        val fi_nid: ast.NodeId = ast.get_extra(ctx.store, fields_start + fi)::ast.NodeId;
        val fi_node: *ast.Node = ast.get(ctx.store, fi_nid);
        val fi_name_sid: ast.StrId = ast.get_extra(ctx.store, fi_node.payload)::ast.StrId;
        val fi_name: str = ast.get_str(ctx.store, fi_name_sid);
        val fi_value: ast.NodeId = ast.get_extra(ctx.store, fi_node.payload + 1)::ast.NodeId;

        val field: *type.TypeField = type.get_field(s.types, crt, fi_name);
        if (field == nil) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, fi_nid);
            diag.error(s.diag, loc, "no such field in struct literal");
            resolve_expr(s, ctx, fi_value, type.TYPE_NIL);
        } or {
            val fi_type: type.TypeId = resolve_expr(s, ctx, fi_value, field.type_id);
            if (!type.is_error(s.types, fi_type)
                && !type.can_assign(s.types, fi_type, field.type_id)) {
                val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, fi_value);
                diag.error(s.diag, loc, "field initializer type mismatch");
            }
        }

        fi = fi + 1;
    }

    ret rec_type;
}

fun resolve_array_lit(s: *sema.Sema, ctx: *FnContext, node_id: ast.NodeId,
                      expected: type.TypeId) type.TypeId {
    val node: *ast.Node = ast.get(ctx.store, node_id);
    val elems_start: u32 = ast.get_extra(ctx.store, node.payload);
    val elems_count: u32 = ast.get_extra(ctx.store, node.payload + 1);

    if (elems_count == 0) {
        if (expected::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, expected)) {
            val ct: type.TypeId = type.canonical(s.types, expected);
            val et: *type.Type = type.get(s.types, ct);
            if (et.kind == type.TK_ARRAY) {
                ret expected;
            }
        }
        val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, node_id);
        diag.error(s.diag, loc, "cannot infer type of empty array literal");
        ret ERROR_TID;
    }

    var elem_expected: type.TypeId = type.TYPE_NIL;
    if (expected::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, expected)) {
        val ct: type.TypeId = type.canonical(s.types, expected);
        val et: *type.Type = type.get(s.types, ct);
        if (et.kind == type.TK_ARRAY) {
            elem_expected = et.elem;
        }
    }

    val first_id: ast.NodeId = ast.get_extra(ctx.store, elems_start)::ast.NodeId;
    val first_type: type.TypeId = resolve_expr(s, ctx, first_id, elem_expected);

    if (type.is_error(s.types, first_type)) {
        var ei: u32 = 1;
        for (ei < elems_count) {
            val eid: ast.NodeId = ast.get_extra(ctx.store, elems_start + ei)::ast.NodeId;
            resolve_expr(s, ctx, eid, type.TYPE_NIL);
            ei = ei + 1;
        }
        ret ERROR_TID;
    }

    var elem_type: type.TypeId = first_type;
    if (elem_expected::u32 != type.TYPE_NIL::u32 && !type.is_error(s.types, elem_expected)) {
        elem_type = elem_expected;
    }

    var ei: u32 = 1;
    for (ei < elems_count) {
        val eid: ast.NodeId = ast.get_extra(ctx.store, elems_start + ei)::ast.NodeId;
        val et: type.TypeId = resolve_expr(s, ctx, eid, elem_type);
        if (!type.is_error(s.types, et) && !type.can_assign(s.types, et, elem_type)) {
            val loc: diag.SourceLoc = node_loc(s, ctx.mod_id, ctx.store, eid);
            diag.error(s.diag, loc, "array element type mismatch");
        }
        ei = ei + 1;
    }

    ret type.make_array(s.types, elem_type, elems_count);
}

fun check_module(s: *sema.Sema, mod_id: module.ModuleId) {
    val m: *module.Module = module.get(s.modules, mod_id);
    val store: *ast.NodeStore = ?m.store;

    if (m.root::u32 == ast.NODE_NIL::u32) { ret; }

    val root: *ast.Node = ast.get(store, m.root);
    if (root.kind != ast.NK_PROGRAM) { ret; }

    val stmts: ast.NodeSpan = ast.block_stmts(store, m.root);
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
        check_fun_returns(s, mod_id, store, child_id);
        i = i + 1;
    }
}

fun check_fun_returns(s: *sema.Sema, mod_id: module.ModuleId, store: *ast.NodeStore,
                      node_id: ast.NodeId) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }

    val node: *ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_DECL_PUB) {
        val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        check_fun_returns(s, mod_id, store, inner_id);
        ret;
    }

    if (node.kind != ast.NK_DECL_FUN) { ret; }

    val generics: ast.NodeId = ast.fun_generics(store, node_id);
    if (generics::u32 != ast.NODE_NIL::u32) { ret; }

    val body_id: ast.NodeId = ast.fun_body(store, node_id);
    if (body_id::u32 == ast.NODE_NIL::u32) { ret; }

    val name_sid: ast.StrId = ast.fun_name(store, node_id);
    val name: str = ast.get_str(store, name_sid);

    val cm: *module.Module = module.get(s.modules, mod_id);
    val opt_fn_sym_check: Option[scope.SymbolId] = resolve.lookup_symbol(s, mod_id, cm.scope, name);
    if (is_none[scope.SymbolId](opt_fn_sym_check)) { ret; }
    val fn_sym_id: scope.SymbolId = unwrap[scope.SymbolId](opt_fn_sym_check);

    val fn_sym: *scope.Symbol = scope.get_sym(s.symbols, fn_sym_id);
    if (fn_sym.type_id == scope.TYPE_ID_UNSET) { ret; }

    val fn_type: *type.Type = type.get(s.types, fn_sym.type_id::type.TypeId);
    if (fn_type.kind != type.TK_FUN) { ret; }

    if (type.types_equal(s.types, fn_type.ret_type, type.primitive(s.types, type.TK_VOID))) {
        ret;
    }

    if (!block_returns(store, body_id)) {
        val loc: diag.SourceLoc = node_loc(s, mod_id, store, node_id);
        diag.error(s.diag, loc, "non-void function may not return a value on all paths");
    }
}

fun block_returns(store: *ast.NodeStore, node_id: ast.NodeId) bool {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret false; }

    val node: *ast.Node = ast.get(store, node_id);
    if (node.kind != ast.NK_STMT_BLOCK) { ret stmt_returns(store, node_id); }

    val stmts: ast.NodeSpan = ast.block_stmts(store, node_id);
    if (stmts.len == 0) { ret false; }

    val last_id: ast.NodeId = ast.get_extra(store, stmts.start + stmts.len - 1)::ast.NodeId;
    ret stmt_returns(store, last_id);
}

fun stmt_returns(store: *ast.NodeStore, node_id: ast.NodeId) bool {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret false; }

    val node: *ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_STMT_RET) { ret true; }

    if (node.kind == ast.NK_STMT_IF) {
        val body_id: ast.NodeId = ast.cond_body(store, node_id);
        val or_id: ast.NodeId = ast.cond_or_chain(store, node_id);

        if (or_id::u32 == ast.NODE_NIL::u32) { ret false; }

        if (!block_returns(store, body_id)) { ret false; }

        ret or_chain_returns(store, or_id);
    }

    if (node.kind == ast.NK_STMT_BLOCK) {
        ret block_returns(store, node_id);
    }

    ret false;
}

fun or_chain_returns(store: *ast.NodeStore, node_id: ast.NodeId) bool {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret false; }

    val node: *ast.Node = ast.get(store, node_id);
    if (node.kind != ast.NK_STMT_OR) { ret false; }

    val cond_id: ast.NodeId = ast.cond_expr(store, node_id);
    val body_id: ast.NodeId = ast.cond_body(store, node_id);
    val next_or: ast.NodeId = ast.cond_or_chain(store, node_id);

    if (!block_returns(store, body_id)) { ret false; }

    if (cond_id::u32 == ast.NODE_NIL::u32) {
        ret true;
    }

    if (next_or::u32 == ast.NODE_NIL::u32) { ret false; }

    ret or_chain_returns(store, next_or);
}
