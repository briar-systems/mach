# mach.compiler.sema.module: module loading, dependency graph, topological ordering
#
# flat arena module table indexed by ModuleId. modules are loaded from source
# text, lexed, and parsed on creation. the dependency graph is built from
# import lists and topologically sorted for phase ordering.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use map:       std.collections.map;
use set:       std.collections.set;
use mem:       std.memory;
use fs:        std.filesystem;

use lexer:  mach.compiler.lex.lexer;
use ast:    mach.compiler.parse.ast;
use parser: mach.compiler.parse.parser;
use scope:  mach.compiler.sema.scope;
use type:   mach.compiler.sema.type;
use check:  mach.compiler.sema.check;

pub def ModuleId: u32;
pub val MOD_NIL: ModuleId = 0xFFFFFFFF;

pub def Phase: u8;
pub val PHASE_LOADED:    Phase = 0;
pub val PHASE_COLLECTED: Phase = 1;
pub val PHASE_RESOLVED:  Phase = 2;
pub val PHASE_CHECKED:   Phase = 3;

# a loaded compilation module
# ---
# path:         dot-separated module path
# file_path:    filesystem path to the source file
# source:       raw source text
# tokens:       lexed token stream
# store:        AST node store
# root:         root AST node id
# scope:        module-level scope
# phase:        current analysis phase
# aliases:      map from alias name to target module
# imports:      array of imported module ids
# import_count: number of imports
# import_cap:   allocated capacity for imports
# expr_types:   per-node resolved type side table
# node_syms:    per-node resolved symbol side table
# content_hash: hash of source text for incremental checks
pub rec Module {
    path:         str;
    file_path:    str;
    source:       str;
    tokens:       lexer.TokenStream;
    store:        ast.NodeStore;
    root:         ast.NodeId;
    scope:        scope.ScopeId;
    phase:        Phase;
    aliases:      map.Map[str, ModuleId];
    imports:      *ModuleId;
    import_count: u32;
    import_cap:   u32;
    expr_types:   check.ExprTypeMap;
    node_syms:    check.NodeSymMap;
    content_hash: u64;
}

# flat table of all modules in the compilation unit
# ---
# alloc:     backing allocator
# modules:   contiguous module array
# count:     number of modules
# cap:       allocated capacity
# path_map:  map from module path to ModuleId
# order:     topologically sorted module ids
# order_len: length of the order array
pub rec ModuleTable {
    alloc:     &allocator.Allocator;
    modules:   *Module;
    count:     u32;
    cap:       u32;
    path_map:  map.Map[str, ModuleId];
    order:     *ModuleId;
    order_len: u32;
}

val INITIAL_CAP:    u32 = 16;
val INITIAL_IMPORT: u32 = 8;

# init: create an empty module table
# ---
# alloc: allocator for all internal storage
# ret:   initialized ModuleTable
pub fun init(alloc: &allocator.Allocator) ModuleTable {
    var table: ModuleTable;
    table.alloc     = alloc;
    table.modules   = nil;
    table.count     = 0;
    table.cap       = 0;
    table.order     = nil;
    table.order_len = 0;
    table.path_map  = map.init[str, ModuleId](alloc, map.hash_str, map.eq_str);

    val res_alloc: Result[*Module, str] = allocator.allocate[Module](alloc, INITIAL_CAP::usize);
    if (is_ok[*Module, str](res_alloc)) {
        table.modules = unwrap_ok[*Module, str](res_alloc);
        table.cap     = INITIAL_CAP;
    }

    ret table;
}

# dnit: destroy the module table, freeing all internal storage
# ---
# table: module table to destroy
pub fun dnit(table: *ModuleTable) {
    if (table == nil) { ret; }

    var i: u32 = 0;
    for (i < table.count) {
        ast.dnit(?table.modules[i].store);
        map.dnit[str, ModuleId](?table.modules[i].aliases);
        if (table.modules[i].imports != nil && table.modules[i].import_cap > 0) {
            allocator.deallocate[ModuleId](
                table.alloc, table.modules[i].imports, table.modules[i].import_cap::usize
            );
        }
        if (table.modules[i].expr_types.types != nil && table.modules[i].expr_types.count > 0) {
            allocator.deallocate[type.TypeId](
                table.alloc, table.modules[i].expr_types.types, table.modules[i].expr_types.count::usize
            );
        }
        if (table.modules[i].node_syms.syms != nil && table.modules[i].node_syms.count > 0) {
            allocator.deallocate[scope.SymbolId](
                table.alloc, table.modules[i].node_syms.syms, table.modules[i].node_syms.count::usize
            );
        }
        i = i + 1;
    }

    if (table.modules != nil && table.cap > 0) {
        allocator.deallocate[Module](table.alloc, table.modules, table.cap::usize);
        table.modules = nil;
    }

    if (table.order != nil && table.order_len > 0) {
        allocator.deallocate[ModuleId](table.alloc, table.order, table.order_len::usize);
        table.order = nil;
    }

    map.dnit[str, ModuleId](?table.path_map);

    table.count     = 0;
    table.cap       = 0;
    table.order_len = 0;
}

# create: create a new module from source text
#
# lexes and parses the source, stores results, and registers the module
# in the path map. the caller is responsible for providing valid source
# with a null terminator.
# ---
# table:     module table
# path:      dot-separated module path
# file_path: filesystem path to the source file
# source:    null-terminated source text
# ret:       ModuleId of the newly created module
pub fun create(table: *ModuleTable, path: str, file_path: str, source: str) ModuleId {
    if (table.count >= table.cap) {
        var new_cap: u32 = INITIAL_CAP;
        if (table.cap > 0) {
            new_cap = table.cap * 2;
        }

        val res_realloc: Result[*Module, str] = allocator.reallocate[Module](
            table.alloc, table.modules, table.cap::usize, new_cap::usize
        );
        if (is_err[*Module, str](res_realloc)) {
            ret MOD_NIL;
        }

        table.modules = unwrap_ok[*Module, str](res_realloc);
        table.cap     = new_cap;
    }

    val id: u32 = table.count;
    val m: *Module = ?table.modules[id];

    m.path         = path;
    m.file_path    = file_path;
    m.source       = source;
    m.root         = ast.NODE_NIL;
    m.scope        = scope.SCOPE_NIL;
    m.phase        = PHASE_LOADED;
    m.imports      = nil;
    m.import_count = 0;
    m.import_cap   = 0;
    m.content_hash = 0;

    m.expr_types.types = nil;
    m.expr_types.count = 0;
    m.node_syms.syms   = nil;
    m.node_syms.count  = 0;

    m.tokens  = lexer.tokenize(source, table.alloc);
    m.store   = ast.init(table.alloc);
    m.aliases = map.init[str, ModuleId](table.alloc, map.hash_str, map.eq_str);

    table.count = table.count + 1;

    map.insert[str, ModuleId](?table.path_map, path, id::ModuleId);

    ret id::ModuleId;
}

# find: look up a module by its dot-separated path
# ---
# table: module table
# path:  module path to search for
# ret:   ModuleId if found, MOD_NIL otherwise
pub fun find(table: &ModuleTable, path: str) ModuleId {
    val key: str = path;
    val res_get: Result[*ModuleId, str] = map.get[str, ModuleId](?table.path_map, ?key);
    if (is_ok[*ModuleId, str](res_get)) {
        ret @unwrap_ok[*ModuleId, str](res_get);
    }
    ret MOD_NIL;
}

# get: return a read-only reference to a module by id
# ---
# table: module table
# id:    module id
# ret:   reference to the module
pub fun get(table: &ModuleTable, id: ModuleId) &Module {
    ret ?table.modules[id::u32];
}

# get_mut: return a mutable pointer to a module by id
# ---
# table: module table
# id:    module id
# ret:   mutable pointer to the module
pub fun get_mut(table: *ModuleTable, id: ModuleId) *Module {
    ret ?table.modules[id::u32];
}

# add_alias: register an alias on a module pointing to another module
# ---
# table:  module table
# on:     module that owns the alias
# alias:  alias name string
# target: module the alias points to
pub fun add_alias(table: *ModuleTable, on: ModuleId, alias: str, target: ModuleId) {
    map.insert[str, ModuleId](?table.modules[on::u32].aliases, alias, target);
}

# add_import: add an import dependency from one module to another
# ---
# table:  module table
# on:     importing module
# target: imported module
pub fun add_import(table: *ModuleTable, on: ModuleId, target: ModuleId) {
    val m: *Module = ?table.modules[on::u32];

    if (m.imports == nil) {
        val res_alloc: Result[*ModuleId, str] = allocator.allocate[ModuleId](
            table.alloc, INITIAL_IMPORT::usize
        );
        if (is_err[*ModuleId, str](res_alloc)) { ret; }
        m.imports    = unwrap_ok[*ModuleId, str](res_alloc);
        m.import_cap = INITIAL_IMPORT;
    }

    if (m.import_count >= m.import_cap) {
        val new_cap: u32 = m.import_cap * 2;
        val res_realloc: Result[*ModuleId, str] = allocator.reallocate[ModuleId](
            table.alloc, m.imports, m.import_cap::usize, new_cap::usize
        );
        if (is_err[*ModuleId, str](res_realloc)) { ret; }
        m.imports    = unwrap_ok[*ModuleId, str](res_realloc);
        m.import_cap = new_cap;
    }

    m.imports[m.import_count] = target;
    m.import_count = m.import_count + 1;
}

# topo_sort: topologically sort all modules by their import dependencies
#
# uses Kahn's algorithm. if a cycle is detected (order_len != count at end),
# returns false and order is not valid.
# ---
# table: module table
# ret:   true if sort succeeded, false if a cycle was detected
pub fun topo_sort(table: *ModuleTable) bool {
    if (table.count == 0) {
        table.order_len = 0;
        ret true;
    }

    val n: u32 = table.count;

    val res_deg: Result[*u32, str] = allocator.allocate[u32](table.alloc, n::usize);
    if (is_err[*u32, str](res_deg)) { ret false; }
    val in_deg: *u32 = unwrap_ok[*u32, str](res_deg);

    var i: u32 = 0;
    for (i < n) {
        in_deg[i] = 0;
        i = i + 1;
    }

    i = 0;
    for (i < n) {
        var j: u32 = 0;
        for (j < table.modules[i].import_count) {
            val dep: u32 = table.modules[i].imports[j]::u32;
            if (dep < n) {
                in_deg[dep] = in_deg[dep] + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    val res_queue: Result[*u32, str] = allocator.allocate[u32](table.alloc, n::usize);
    if (is_err[*u32, str](res_queue)) {
        allocator.deallocate[u32](table.alloc, in_deg, n::usize);
        ret false;
    }
    val queue: *u32 = unwrap_ok[*u32, str](res_queue);
    var q_head: u32 = 0;
    var q_tail: u32 = 0;

    i = 0;
    for (i < n) {
        if (in_deg[i] == 0) {
            queue[q_tail] = i;
            q_tail = q_tail + 1;
        }
        i = i + 1;
    }

    if (table.order != nil && table.order_len > 0) {
        allocator.deallocate[ModuleId](table.alloc, table.order, table.order_len::usize);
        table.order = nil;
    }

    val res_order: Result[*ModuleId, str] = allocator.allocate[ModuleId](table.alloc, n::usize);
    if (is_err[*ModuleId, str](res_order)) {
        allocator.deallocate[u32](table.alloc, in_deg, n::usize);
        allocator.deallocate[u32](table.alloc, queue, n::usize);
        ret false;
    }
    table.order     = unwrap_ok[*ModuleId, str](res_order);
    table.order_len = 0;

    for (q_head < q_tail) {
        val cur: u32 = queue[q_head];
        q_head = q_head + 1;

        table.order[table.order_len] = cur::ModuleId;
        table.order_len = table.order_len + 1;

        i = 0;
        for (i < n) {
            var j: u32 = 0;
            for (j < table.modules[i].import_count) {
                if (table.modules[i].imports[j]::u32 == cur) {
                    in_deg[i] = in_deg[i] - 1;
                    if (in_deg[i] == 0) {
                        queue[q_tail] = i;
                        q_tail = q_tail + 1;
                    }
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }

    allocator.deallocate[u32](table.alloc, in_deg, n::usize);
    allocator.deallocate[u32](table.alloc, queue, n::usize);

    ret table.order_len == n;
}

# order_count: return the number of modules in topological order
# ---
# table: module table
# ret:   number of entries in the order array
pub fun order_count(table: &ModuleTable) u32 {
    ret table.order_len;
}

# order_at: return the module id at a given position in topological order
# ---
# table: module table
# idx:   index into the order array
# ret:   ModuleId at that position
pub fun order_at(table: &ModuleTable, idx: u32) ModuleId {
    ret table.order[idx];
}

# resolve_alias: look up an alias on a module
# ---
# table: module table
# on:    module owning the alias
# alias: alias name to resolve
# ret:   target ModuleId, or MOD_NIL if not found
pub fun resolve_alias(table: &ModuleTable, on: ModuleId, alias: str) ModuleId {
    val key: str = alias;
    val res_get: Result[*ModuleId, str] = map.get[str, ModuleId](
        ?table.modules[on::u32].aliases, ?key
    );
    if (is_ok[*ModuleId, str](res_get)) {
        ret @unwrap_ok[*ModuleId, str](res_get);
    }
    ret MOD_NIL;
}

# invalidate: reset a module's phase to allow re-analysis
# ---
# table:    module table
# id:       module to invalidate
# to_phase: phase to reset to
pub fun invalidate(table: *ModuleTable, id: ModuleId, to_phase: Phase) {
    table.modules[id::u32].phase = to_phase;
}

# load_graph: load the module dependency graph starting from a root module
#
# recursively discovers imports from use declarations, reads and parses
# source files, builds the import graph, and topologically sorts it.
# ---
# table:      module table
# root:       root module id (must already exist)
# src_root:   source root directory path
# dep_root:   dependency root directory path
# project_id: project identifier string
pub fun load_graph(table: *ModuleTable, root: ModuleId, src_root: str,
                   dep_root: str, project_id: str) {
    var loading: set.Set[str] = set.init[str](table.alloc, map.hash_str, map.eq_str);
    discover_imports(table, root, src_root, dep_root, project_id, ?loading);
    set.dnit[str](?loading);
    topo_sort(table);
}

fun discover_imports(table: *ModuleTable, mod_id: ModuleId,
                     src_root: str, dep_root: str,
                     project_id: str, loading: *set.Set[str]) {
    if (mod_id::u32 == MOD_NIL::u32) { ret; }

    val m: *Module = ?table.modules[mod_id::u32];
    set.insert[str](loading, m.path);

    parse_module(table, mod_id);

    if (m.root::u32 == ast.NODE_NIL::u32) {
        set.remove[str](loading, ?m.path);
        ret;
    }

    val root_node: &ast.Node = ast.get(?m.store, m.root);
    if (root_node.kind != ast.NK_PROGRAM) {
        set.remove[str](loading, ?m.path);
        ret;
    }

    val stmts: ast.NodeSpan = ast.block_stmts(?m.store, m.root);
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(?m.store, stmts.start + i)::ast.NodeId;
        val child: &ast.Node = ast.get(?m.store, child_id);

        var use_node_id: ast.NodeId = ast.NODE_NIL;
        if (child.kind == ast.NK_DECL_USE) {
            use_node_id = child_id;
        } or (child.kind == ast.NK_DECL_PUB) {
            val inner_id: ast.NodeId = ast.get_extra(?m.store, child.payload)::ast.NodeId;
            if (inner_id::u32 != ast.NODE_NIL::u32) {
                val inner: &ast.Node = ast.get(?m.store, inner_id);
                if (inner.kind == ast.NK_DECL_USE) {
                    use_node_id = inner_id;
                }
            }
        }

        if (use_node_id::u32 != ast.NODE_NIL::u32) {
            process_use_decl(table, mod_id, use_node_id, src_root,
                             dep_root, project_id, loading);
        }

        i = i + 1;
    }

    set.remove[str](loading, ?m.path);
}

fun process_use_decl(table: *ModuleTable, mod_id: ModuleId,
                     use_id: ast.NodeId, src_root: str,
                     dep_root: str, project_id: str,
                     loading: *set.Set[str]) {
    val m: &Module = ?table.modules[mod_id::u32];
    val use_node: &ast.Node = ast.get(?m.store, use_id);

    val path_sid: ast.StrId = ast.get_extra(?m.store, use_node.payload)::ast.StrId;
    val alias_sid: ast.StrId = ast.get_extra(?m.store, use_node.payload + 1)::ast.StrId;

    val mod_path: str = ast.get_str(?m.store, path_sid);
    if (mod_path == nil) { ret; }

    val existing: ModuleId = find(table, mod_path);
    if (existing::u32 != MOD_NIL::u32) {
        add_import(table, mod_id, existing);
        if (alias_sid::u32 != ast.STR_NIL::u32) {
            val alias_name: str = ast.get_str(?m.store, alias_sid);
            if (alias_name != nil) {
                add_alias(table, mod_id, alias_name, existing);
            }
        }
        ret;
    }

    if (set.contains[str](loading, ?mod_path)) {
        ret;
    }

    var file_path_buf: [512]u8;
    val res_fp: bool = resolve_path(?file_path_buf[0], 512, src_root,
                                    dep_root, project_id, mod_path);
    if (!res_fp) { ret; }

    val file_path_str: str = ?file_path_buf[0]::str;
    if (!fs.is_file(file_path_str)) { ret; }

    val res_read: Result[str, str] = fs.read_all(table.alloc, file_path_str);
    if (is_err[str, str](res_read)) { ret; }
    val source: str = unwrap_ok[str, str](res_read);

    val fp_len: usize = str_len(file_path_str);
    val res_fp_alloc: Result[*u8, str] = allocator.allocate[u8](table.alloc, fp_len + 1);
    if (is_err[*u8, str](res_fp_alloc)) { ret; }
    val fp_copy: *u8 = unwrap_ok[*u8, str](res_fp_alloc);
    mem.raw_copy(fp_copy::ptr, file_path_str, fp_len + 1);

    val mp_len: usize = str_len(mod_path);
    val res_mp_alloc: Result[*u8, str] = allocator.allocate[u8](table.alloc, mp_len + 1);
    if (is_err[*u8, str](res_mp_alloc)) { ret; }
    val mp_copy: *u8 = unwrap_ok[*u8, str](res_mp_alloc);
    mem.raw_copy(mp_copy::ptr, mod_path, mp_len + 1);

    val new_id: ModuleId = create(table, mp_copy::str, fp_copy::str, source);
    if (new_id::u32 == MOD_NIL::u32) { ret; }

    add_import(table, mod_id, new_id);
    if (alias_sid::u32 != ast.STR_NIL::u32) {
        val alias_name: str = ast.get_str(?m.store, alias_sid);
        if (alias_name != nil) {
            add_alias(table, mod_id, alias_name, new_id);
        }
    }

    discover_imports(table, new_id, src_root, dep_root, project_id, loading);
}

fun parse_module(table: *ModuleTable, mod_id: ModuleId) {
    val m: *Module = ?table.modules[mod_id::u32];
    if (m.root::u32 != ast.NODE_NIL::u32) { ret; }
    if (m.source == nil) { ret; }

    val result: parser.ParseResult = parser.parse(?m.tokens, table.alloc);
    m.store = result.store;
    m.root  = result.root;

    m.expr_types = check.init_expr_types(table.alloc, m.store.node_count);
    m.node_syms  = check.init_node_syms(table.alloc, m.store.node_count);
}

fun resolve_path(buf: *u8, cap: u32, src_root: str,
                 dep_root: str, project_id: str,
                 mod_path: str) bool {
    if (mod_path == nil) { ret false; }

    var off: u32 = 0;
    var is_local: bool = false;

    if (project_id != nil) {
        val pid_len: usize = str_len(project_id);
        if (str_starts_with(mod_path, project_id)) {
            val mp_len: usize = str_len(mod_path);
            if (mp_len > pid_len && mod_path[pid_len] == '.') {
                is_local = true;
            }
            if (mp_len == pid_len) {
                is_local = true;
            }
        }
    }

    if (is_local) {
        val pid_len: usize = str_len(project_id);
        val root_len: usize = str_len(src_root);
        var ri: usize = 0;
        for (ri < root_len && off < cap - 1) {
            buf[off] = src_root[ri];
            off = off + 1;
            ri = ri + 1;
        }
        if (off < cap - 1) { buf[off] = '/'; off = off + 1; }

        val suffix: str = mod_path;
        val mp_len: usize = str_len(mod_path);
        var si: usize = pid_len;
        if (si < mp_len && mod_path[si] == '.') {
            si = si + 1;
        }
        for (si < mp_len && off < cap - 5) {
            if (suffix[si] == '.') {
                buf[off] = '/';
            } or {
                buf[off] = suffix[si];
            }
            off = off + 1;
            si = si + 1;
        }
    } or {
        val dep_len: usize = str_len(dep_root);
        var di: usize = 0;
        for (di < dep_len && off < cap - 1) {
            buf[off] = dep_root[di];
            off = off + 1;
            di = di + 1;
        }
        if (off < cap - 1) { buf[off] = '/'; off = off + 1; }

        val mp_len: usize = str_len(mod_path);
        var first_dot: usize = 0;
        var fi: usize = 0;
        for (fi < mp_len) {
            if (mod_path[fi] == '.') { first_dot = fi; brk; }
            fi = fi + 1;
        }
        if (first_dot == 0) { first_dot = mp_len; }

        var pi: usize = 0;
        for (pi < first_dot && off < cap - 1) {
            buf[off] = mod_path[pi];
            off = off + 1;
            pi = pi + 1;
        }

        val src_suffix: str = "/src/";
        var ss: usize = 0;
        for (src_suffix[ss] != 0 && off < cap - 1) {
            buf[off] = src_suffix[ss];
            off = off + 1;
            ss = ss + 1;
        }

        var si: usize = first_dot;
        if (si < mp_len && mod_path[si] == '.') {
            si = si + 1;
        }
        for (si < mp_len && off < cap - 5) {
            if (mod_path[si] == '.') {
                buf[off] = '/';
            } or {
                buf[off] = mod_path[si];
            }
            off = off + 1;
            si = si + 1;
        }
    }

    val ext: str = ".mach";
    var ei: usize = 0;
    for (ext[ei] != 0 && off < cap - 1) {
        buf[off] = ext[ei];
        off = off + 1;
        ei = ei + 1;
    }
    buf[off] = 0;

    ret true;
}
