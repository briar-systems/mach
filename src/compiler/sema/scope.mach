# compiler.sema.scope: symbols, scopes, and symbol table
#
# flat-arena symbol table with lexical scope chaining. symbols are stored in a
# contiguous array indexed by SymbolId. scopes form a tree via parent pointers,
# and each scope owns a hash map from name to SymbolId. lookup walks the scope
# chain from current to root.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use map:       std.collections.map;
use page:      std.allocator.page;

use ast: compiler.parse.ast;

pub def SymbolId: u32;
pub val SYM_NIL: SymbolId = 0xFFFFFFFF;

pub def ScopeId: u32;
pub val SCOPE_NIL: ScopeId = 0xFFFFFFFF;

pub def SymbolKind: u8;
pub val SK_VAL:    SymbolKind = 0;
pub val SK_VAR:    SymbolKind = 1;
pub val SK_FUN:    SymbolKind = 2;
pub val SK_TYPE:   SymbolKind = 3;
pub val SK_FIELD:  SymbolKind = 4;
pub val SK_PARAM:  SymbolKind = 5;
pub val SK_MODULE: SymbolKind = 6;
pub val SK_EXT:    SymbolKind = 7;

# a named symbol in the compilation unit
# ---
# name:         interned name string
# kind:         symbol kind (SK_* constant)
# decl_node:    AST node where this symbol was declared
# type_id:      associated type (type.TypeId, u32 alias)
# scope:        scope in which this symbol is defined
# module:       owning module (module.ModuleId, u32 alias)
# is_public:    visible outside the module
# is_mutable:   declared with var (not val)
# is_generic:   has generic type parameters
# is_resolving: currently being resolved (cycle detection)
# generic_node: AST node for generic parameters
# export_name:  linker-visible name (nil if not exported)
pub rec Symbol {
    name:         str;
    kind:         SymbolKind;
    decl_node:    ast.NodeId;
    type_id:      u32;
    scope:        ScopeId;
    module:       u32;
    is_public:    bool;
    is_mutable:   bool;
    is_generic:   bool;
    is_resolving: bool;
    generic_node: ast.NodeId;
    export_name:  str;
}

# a lexical scope containing name-to-symbol bindings
# ---
# parent:   parent scope id (SCOPE_NIL for the root)
# name_map: hash map from name string to SymbolId
pub rec Scope {
    parent:   ScopeId;
    name_map: map.Map[str, SymbolId];
}

# flat-arena symbol table with scope stack
# ---
# alloc:       backing allocator
# symbols:     contiguous symbol array
# sym_count:   number of symbols stored
# sym_cap:     allocated capacity for symbols
# scopes:      contiguous scope array
# scope_count: number of scopes stored
# scope_cap:   allocated capacity for scopes
# current:     id of the currently active scope
pub rec SymbolTable {
    alloc:       &allocator.Allocator;
    symbols:     *Symbol;
    sym_count:   u32;
    sym_cap:     u32;
    scopes:      *Scope;
    scope_count: u32;
    scope_cap:   u32;
    current:     ScopeId;
}

val INITIAL_SYM_CAP:   u32 = 256;
val INITIAL_SCOPE_CAP: u32 = 32;

# init: create a symbol table with a root scope
# ---
# alloc: allocator for all internal storage
# ret:   initialized SymbolTable with an empty root scope
pub fun init(alloc: &allocator.Allocator) SymbolTable {
    var table: SymbolTable;
    table.alloc       = alloc;
    table.symbols     = nil;
    table.sym_count   = 0;
    table.sym_cap     = 0;
    table.scope_count = 0;
    table.scope_cap   = 0;
    table.current     = SCOPE_NIL;

    val res_scopes: Result[*Scope, str] = allocator.allocate[Scope](alloc, INITIAL_SCOPE_CAP::usize);
    if (is_ok[*Scope, str](res_scopes)) {
        table.scopes    = unwrap_ok[*Scope, str](res_scopes);
        table.scope_cap = INITIAL_SCOPE_CAP;
    }

    val res_symbols: Result[*Symbol, str] = allocator.allocate[Symbol](alloc, INITIAL_SYM_CAP::usize);
    if (is_ok[*Symbol, str](res_symbols)) {
        table.symbols = unwrap_ok[*Symbol, str](res_symbols);
        table.sym_cap = INITIAL_SYM_CAP;
    }

    table.scopes[0].parent   = SCOPE_NIL;
    table.scopes[0].name_map = map.init[str, SymbolId](alloc, map.hash_str, map.eq_str);
    table.scope_count = 1;
    table.current     = 0::ScopeId;

    ret table;
}

# dnit: destroy the symbol table, freeing all internal storage
# ---
# table: symbol table to destroy
pub fun dnit(table: *SymbolTable) {
    if (table == nil) { ret; }

    var i: u32 = 0;
    for (i < table.scope_count) {
        map.dnit[str, SymbolId](?table.scopes[i].name_map);
        i = i + 1;
    }

    if (table.scopes != nil && table.scope_cap > 0) {
        allocator.deallocate[Scope](table.alloc, table.scopes, table.scope_cap::usize);
        table.scopes = nil;
    }

    if (table.symbols != nil && table.sym_cap > 0) {
        allocator.deallocate[Symbol](table.alloc, table.symbols, table.sym_cap::usize);
        table.symbols = nil;
    }

    table.sym_count   = 0;
    table.sym_cap     = 0;
    table.scope_count = 0;
    table.scope_cap   = 0;
    table.current     = SCOPE_NIL;
}

# push_scope: push a new child scope and make it current
# ---
# table: symbol table
# ret:   id of the newly created scope
pub fun push_scope(table: *SymbolTable) ScopeId {
    if (table.scope_count >= table.scope_cap) {
        var new_cap: u32 = INITIAL_SCOPE_CAP;
        if (table.scope_cap > 0) {
            new_cap = table.scope_cap * 2;
        }

        val res_realloc: Result[*Scope, str] = allocator.reallocate[Scope](
            table.alloc, table.scopes, table.scope_cap::usize, new_cap::usize
        );
        if (is_err[*Scope, str](res_realloc)) {
            ret SCOPE_NIL;
        }

        table.scopes    = unwrap_ok[*Scope, str](res_realloc);
        table.scope_cap = new_cap;
    }

    val id: u32 = table.scope_count;
    table.scopes[id].parent   = table.current;
    table.scopes[id].name_map = map.init[str, SymbolId](table.alloc, map.hash_str, map.eq_str);
    table.scope_count = table.scope_count + 1;
    table.current     = id::ScopeId;

    ret id::ScopeId;
}

# pop_scope: pop the current scope, restoring its parent as current
#
# asserts that the root scope is never popped.
# ---
# table: symbol table
pub fun pop_scope(table: *SymbolTable) {
    if (table.current::u32 == SCOPE_NIL::u32) { ret; }

    val parent: ScopeId = table.scopes[table.current::u32].parent;
    if (parent::u32 == SCOPE_NIL::u32) { ret; }

    table.current = parent;
}

# define: define a new symbol in the current scope
#
# returns SYM_NIL if the name is already defined in the current scope.
# ---
# table: symbol table
# name:  symbol name
# kind:  symbol kind
# ret:   id of the new symbol, or SYM_NIL on duplicate
pub fun define(table: *SymbolTable, name: str, kind: SymbolKind) SymbolId {
    ret define_in(table, table.current, name, kind);
}

# define_in: define a new symbol in a specific scope
#
# returns SYM_NIL if the name is already defined in that scope.
# ---
# table: symbol table
# scope: target scope
# name:  symbol name
# kind:  symbol kind
# ret:   id of the new symbol, or SYM_NIL on duplicate
pub fun define_in(table: *SymbolTable, scope: ScopeId, name: str, kind: SymbolKind) SymbolId {
    val key: str = name;
    if (map.contains[str, SymbolId](?table.scopes[scope::u32].name_map, ?key)) {
        ret SYM_NIL;
    }

    if (table.sym_count >= table.sym_cap) {
        var new_cap: u32 = INITIAL_SYM_CAP;
        if (table.sym_cap > 0) {
            new_cap = table.sym_cap * 2;
        }

        val res_realloc: Result[*Symbol, str] = allocator.reallocate[Symbol](
            table.alloc, table.symbols, table.sym_cap::usize, new_cap::usize
        );
        if (is_err[*Symbol, str](res_realloc)) {
            ret SYM_NIL;
        }

        table.symbols = unwrap_ok[*Symbol, str](res_realloc);
        table.sym_cap = new_cap;
    }

    val id: u32 = table.sym_count;
    table.symbols[id].name         = name;
    table.symbols[id].kind         = kind;
    table.symbols[id].decl_node    = ast.NODE_NIL;
    table.symbols[id].type_id      = 0xFFFFFFFF;
    table.symbols[id].scope        = scope;
    table.symbols[id].module       = 0xFFFFFFFF;
    table.symbols[id].is_public    = false;
    table.symbols[id].is_mutable   = false;
    table.symbols[id].is_generic   = false;
    table.symbols[id].is_resolving = false;
    table.symbols[id].generic_node = ast.NODE_NIL;
    table.symbols[id].export_name  = nil;
    table.sym_count = table.sym_count + 1;

    map.insert[str, SymbolId](?table.scopes[scope::u32].name_map, name, id::SymbolId);

    ret id::SymbolId;
}

# lookup: look up a name starting from the current scope, walking parents
# ---
# table: symbol table
# name:  name to look up
# ret:   SymbolId of the first match, or SYM_NIL if not found
pub fun lookup(table: &SymbolTable, name: str) SymbolId {
    var scope: ScopeId = table.current;

    for (scope::u32 != SCOPE_NIL::u32) {
        val key: str = name;
        val res_get: Result[*SymbolId, str] = map.get[str, SymbolId](?table.scopes[scope::u32].name_map, ?key);
        if (is_ok[*SymbolId, str](res_get)) {
            ret @unwrap_ok[*SymbolId, str](res_get);
        }
        scope = table.scopes[scope::u32].parent;
    }

    ret SYM_NIL;
}

# lookup_local: look up a name in a specific scope only, no parent walk
# ---
# table: symbol table
# scope: scope to search
# name:  name to look up
# ret:   SymbolId if found, or SYM_NIL
pub fun lookup_local(table: &SymbolTable, scope: ScopeId, name: str) SymbolId {
    if (scope::u32 == SCOPE_NIL::u32) { ret SYM_NIL; }

    val key: str = name;
    val res_get: Result[*SymbolId, str] = map.get[str, SymbolId](?table.scopes[scope::u32].name_map, ?key);
    if (is_ok[*SymbolId, str](res_get)) {
        ret @unwrap_ok[*SymbolId, str](res_get);
    }

    ret SYM_NIL;
}

# get_sym: return a read-only reference to a symbol by id
# ---
# table: symbol table
# id:    symbol id
# ret:   reference to the symbol
pub fun get_sym(table: &SymbolTable, id: SymbolId) &Symbol {
    ret ?table.symbols[id::u32];
}

# get_sym_mut: return a mutable pointer to a symbol by id
# ---
# table: symbol table
# id:    symbol id
# ret:   mutable pointer to the symbol
pub fun get_sym_mut(table: *SymbolTable, id: SymbolId) *Symbol {
    ret ?table.symbols[id::u32];
}

# current_scope: return the id of the currently active scope
# ---
# table: symbol table
# ret:   current scope id
pub fun current_scope(table: &SymbolTable) ScopeId {
    ret table.current;
}

test "scope: define and lookup" {
    var a: allocator.Allocator;
    page.make(?a);

    var table: SymbolTable = init(?a);

    val id: SymbolId = define(?table, "foo", SK_VAL);
    if (id::u32 == SYM_NIL::u32) { ret 0; }

    val found: SymbolId = lookup(?table, "foo");
    if (found::u32 == SYM_NIL::u32) { ret 0; }
    if (found::u32 != id::u32) { ret 0; }

    val sym: &Symbol = get_sym(?table, found);
    if (!str_equals(sym.name, "foo")) { ret 0; }
    if (sym.kind::u8 != SK_VAL::u8) { ret 0; }

    val missing: SymbolId = lookup(?table, "bar");
    if (missing::u32 != SYM_NIL::u32) { ret 0; }

    dnit(?table);
    ret 1;
}

test "scope: shadowing across scopes" {
    var a: allocator.Allocator;
    page.make(?a);

    var table: SymbolTable = init(?a);

    val outer_id: SymbolId = define(?table, "x", SK_VAL);
    if (outer_id::u32 == SYM_NIL::u32) { ret 0; }

    push_scope(?table);

    val inner_id: SymbolId = define(?table, "x", SK_VAR);
    if (inner_id::u32 == SYM_NIL::u32) { ret 0; }
    if (inner_id::u32 == outer_id::u32) { ret 0; }

    val found_inner: SymbolId = lookup(?table, "x");
    if (found_inner::u32 != inner_id::u32) { ret 0; }

    val inner_sym: &Symbol = get_sym(?table, found_inner);
    if (inner_sym.kind::u8 != SK_VAR::u8) { ret 0; }

    pop_scope(?table);

    val found_outer: SymbolId = lookup(?table, "x");
    if (found_outer::u32 != outer_id::u32) { ret 0; }

    val outer_sym: &Symbol = get_sym(?table, found_outer);
    if (outer_sym.kind::u8 != SK_VAL::u8) { ret 0; }

    dnit(?table);
    ret 1;
}
