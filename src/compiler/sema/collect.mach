# --- module resolution ---

# build_file_from_root: build file path from base directory and module path rest.
# ---
# sema:     analyzer context (for allocator)
# base_dir: base directory path
# rest:     module path after prefix (e.g., "cli.main" -> "cli/main.mach")
# ret:      file path or nil on error
fun build_file_from_root(sema: *Sema, base_dir: str, rest: str) str {
    if (sema == nil || base_dir == nil) {
        ret nil;
    }

    # handle empty rest (just the module prefix itself)
    if (rest == nil || str_len(rest) == 0) {
        # just base_dir + ".mach" - but this is usually not valid
        ret nil;
    }

    val base_len: usize = str_len(base_dir);
    val rest_len: usize = str_len(rest);
    # base + '/' + rest (with dots as slashes) + ".mach" + '\0'
    val total_len: usize = base_len + 1 + rest_len + 5 + 1;

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, total_len);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret nil;
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);
    var pos: usize = 0;

    # copy base_dir
    var i: usize = 0;
    for (i < base_len) {
        buf[pos] = base_dir[i];
        pos = pos + 1;
        i = i + 1;
    }

    # add separator
    buf[pos] = '/';
    pos = pos + 1;

    # copy rest, replacing dots with slashes
    i = 0;
    for (i < rest_len) {
        val c: u8 = rest[i];
        if (c == '.') {
            buf[pos] = '/';
        } or {
            buf[pos] = c;
        }
        pos = pos + 1;
        i = i + 1;
    }

    # append ".mach"
    buf[pos] = '.'; pos = pos + 1;
    buf[pos] = 'm'; pos = pos + 1;
    buf[pos] = 'a'; pos = pos + 1;
    buf[pos] = 'c'; pos = pos + 1;
    buf[pos] = 'h'; pos = pos + 1;
    buf[pos] = 0;

    ret buf::&u8;
}

# load_dep_project_id: load a dependency's project id from its mach.toml.
# ---
# sema:     analyzer context
# dep_name: dependency directory name
# ret:      project id or nil if not found
fun load_dep_project_id(sema: *Sema, dep_name: str) str {
    if (sema == nil || sema.dep_root == nil || dep_name == nil) {
        ret nil;
    }

    # build path: dep_root/dep_name/mach.toml
    val dep_root_len: usize = str_len(sema.dep_root);
    val dep_name_len: usize = str_len(dep_name);
    val toml_len: usize = 10; # "/mach.toml"
    val total: usize = dep_root_len + 1 + dep_name_len + toml_len + 1;

    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, total);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) {
        ret nil;
    }

    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);
    var pos: usize = 0;

    # copy dep_root
    var i: usize = 0;
    for (i < dep_root_len) {
        buf[pos] = sema.dep_root[i];
        pos = pos + 1;
        i = i + 1;
    }

    buf[pos] = '/'; pos = pos + 1;

    # copy dep_name
    i = 0;
    for (i < dep_name_len) {
        buf[pos] = dep_name[i];
        pos = pos + 1;
        i = i + 1;
    }

    # copy "/mach.toml"
    buf[pos] = '/'; pos = pos + 1;
    buf[pos] = 'm'; pos = pos + 1;
    buf[pos] = 'a'; pos = pos + 1;
    buf[pos] = 'c'; pos = pos + 1;
    buf[pos] = 'h'; pos = pos + 1;
    buf[pos] = '.'; pos = pos + 1;
    buf[pos] = 't'; pos = pos + 1;
    buf[pos] = 'o'; pos = pos + 1;
    buf[pos] = 'm'; pos = pos + 1;
    buf[pos] = 'l'; pos = pos + 1;
    buf[pos] = 0;

    val config_path: str = buf::&u8;

    # load the config
    val cfg_res: Result[config.Config, str] = config.load(config_path, sema.alloc);
    if (result_is_err[config.Config, str](cfg_res)) {
        ret nil;
    }

    val cfg: config.Config = result_unwrap_ok[config.Config, str](cfg_res);
    ret cfg.id;
}

# resolve_module_path: resolve a module path to a file path.
# ---
# sema:        analyzer context
# module_path: module path (e.g., "std.filesystem")
# ret:         file path or nil if not found
fun resolve_module_path(sema: *Sema, module_path: str) str {
    if (sema == nil || module_path == nil) {
        ret nil;
    }

    val mod_len: usize = str_len(module_path);
    if (mod_len == 0) {
        ret nil;
    }

    # 1) check project_id -> src_root mapping
    if (sema.project_id != nil && sema.src_root != nil) {
        val id_len: usize = str_len(sema.project_id);
        if (str_starts_with(module_path, sema.project_id)) {
            # check if it's followed by '.' or end of string
            if (mod_len == id_len || (mod_len > id_len && module_path[id_len] == '.')) {
                # get the rest after the prefix
                var rest: str = nil;
                if (mod_len > id_len) {
                    rest = (module_path::usize + id_len + 1)::str;  # skip prefix and dot
                }
                ret build_file_from_root(sema, sema.src_root, rest);
            }
        }
    }

    # 2) check include path mappings (-I flag)
    if (sema.includes != nil && sema.include_count > 0) {
        var ii: i32 = 0;
        for (ii < sema.include_count) {
            val inc_prefix: str = sema.includes[ii].prefix;
            if (inc_prefix == nil) {
                ii = ii + 1;
                cnt;
            }
            val prefix_len: usize = str_len(inc_prefix);
            if (str_starts_with(module_path, inc_prefix)) {
                if (mod_len == prefix_len || (mod_len > prefix_len && module_path[prefix_len] == '.')) {
                    var rest: str = nil;
                    if (mod_len > prefix_len) {
                        rest = (module_path::usize + prefix_len + 1)::str;
                    }
                    ret build_file_from_root(sema, sema.includes[ii].dir, rest);
                }
            }
            ii = ii + 1;
        }
    }

    # 3) check dependencies
    if (sema.deps != nil && sema.dep_count > 0 && sema.dep_root != nil) {
        var i: i32 = 0;
        for (i < sema.dep_count) {
            # deps is *Dep (array), so sema.deps[i] gives us Dep
            val dep_name: str = sema.deps[i].name;
            if (dep_name == nil) {
                i = i + 1;
                cnt;
            }

            # load the dependency's project id from its mach.toml
            val dep_project_id: str = load_dep_project_id(sema, dep_name);
            if (dep_project_id == nil) {
                i = i + 1;
                cnt;
            }

            val dep_id_len: usize = str_len(dep_project_id);
            if (str_starts_with(module_path, dep_project_id)) {
                if (mod_len == dep_id_len || (mod_len > dep_id_len && module_path[dep_id_len] == '.')) {
                    # get the rest after the prefix
                    var rest: str = nil;
                    if (mod_len > dep_id_len) {
                        rest = (module_path::usize + dep_id_len + 1)::str;
                    }

                    # build base dir: dep_root/dep_name/src (default to "src")
                    val dep_root_len: usize = str_len(sema.dep_root);
                    val dep_name_len: usize = str_len(dep_name);
                    val src_dir: str = "src";
                    val src_len: usize = 3;
                    val base_total: usize = dep_root_len + 1 + dep_name_len + 1 + src_len + 1;

                    val base_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, base_total);
                    if (result_is_err[*u8, allocator.AllocError](base_res)) {
                        i = i + 1;
                        cnt;
                    }

                    val base_buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](base_res);
                    var pos: usize = 0;

                    # copy dep_root
                    var j: usize = 0;
                    for (j < dep_root_len) {
                        base_buf[pos] = sema.dep_root[j];
                        pos = pos + 1;
                        j = j + 1;
                    }

                    base_buf[pos] = '/'; pos = pos + 1;

                    # copy dep_name
                    j = 0;
                    for (j < dep_name_len) {
                        base_buf[pos] = dep_name[j];
                        pos = pos + 1;
                        j = j + 1;
                    }

                    base_buf[pos] = '/'; pos = pos + 1;

                    # copy "src"
                    base_buf[pos] = 's'; pos = pos + 1;
                    base_buf[pos] = 'r'; pos = pos + 1;
                    base_buf[pos] = 'c'; pos = pos + 1;
                    base_buf[pos] = 0;

                    val base_dir: str = base_buf::&u8;
                    ret build_file_from_root(sema, base_dir, rest);
                }
            }

            i = i + 1;
        }
    }

    ret nil;
}

# load_module: load a module by path.
# ---
# sema: analyzer context
# path: module path (e.g., "mach.cli.main")
# ret:  loaded module or nil
pub fun load_module(sema: *Sema, mod_path: str) *SemaModule {
    if (sema == nil || mod_path == nil) {
        ret nil;
    }

    # check if already loaded
    var existing: *SemaModule = sema.modules;
    for (existing != nil) {
        if (existing.path != nil && str_equals(existing.path, mod_path)) {
            ret existing;
        }
        existing = existing.next;
    }

    # resolve module path to file path
    val file_path: str = resolve_module_path(sema, mod_path);
    if (file_path == nil) {
        ret nil;
    }

    # read the source file
    val source_res: Result[str, str] = utilfs.read_file(file_path, sema.alloc);
    if (result_is_err[str, str](source_res)) {
        ret nil;
    }

    val source: str = result_unwrap_ok[str, str](source_res);

    # parse the source
    var p: parser.Parser = parser.init(source, sema.alloc);

    val parse_res: Result[*ast.Node, str] = parser.parser_parse_program(?p);
    if (result_is_err[*ast.Node, str](parse_res)) {
        parser.parser_dnit(?p);
        ret nil;
    }

    val mod_ast: *ast.Node = result_unwrap_ok[*ast.Node, str](parse_res);

    if (p.had_error || mod_ast == nil) {
        parser.parser_dnit(?p);
        ret nil;
    }

    # create the module record
    val mod_res: Result[*SemaModule, allocator.AllocError] = allocator.allocator_alloc[SemaModule](sema.alloc, 1);
    if (result_is_err[*SemaModule, allocator.AllocError](mod_res)) {
        parser.parser_dnit(?p);
        ret nil;
    }

    val mod: *SemaModule = result_unwrap_ok[*SemaModule, allocator.AllocError](mod_res);
    mod.path = mod_path;
    mod.file_path = file_path;
    mod.source = source;
    mod.ast = mod_ast;
    mod.is_analyzed = false;
    mod.aliases = nil;
    mod.imports = nil;
    mod.table = nil;

    # add to module list (prepend)
    mod.next = sema.modules;
    sema.modules = mod;
    sema.module_count = sema.module_count + 1;

    # save current context
    val saved_module: *SemaModule = sema.current_module;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;
    val saved_symbols: *symbol.Table = sema.symbols;
    val saved_module_path: str = sema.module_path;

    # create a new symbol table for this module
    val table_res: Result[symbol.Table, str] = symbol.init(sema.alloc);
    if (result_is_err[symbol.Table, str](table_res)) {
        parser.parser_dnit(?p);
        ret nil;
    }

    # allocate space for the table and copy
    val table_ptr_res: Result[*symbol.Table, allocator.AllocError] = allocator.allocator_alloc[symbol.Table](sema.alloc, 1);
    if (result_is_err[*symbol.Table, allocator.AllocError](table_ptr_res)) {
        parser.parser_dnit(?p);
        ret nil;
    }
    val table_ptr: *symbol.Table = result_unwrap_ok[*symbol.Table, allocator.AllocError](table_ptr_res);
    @table_ptr = result_unwrap_ok[symbol.Table, str](table_res);

    # store table on module for cross-module lookups
    mod.table = table_ptr;

    # set module context
    sema.current_module = mod;
    sema.file_path = file_path;
    sema.source = source;
    sema.symbols = table_ptr;
    sema.module_path = mod_path;

    # analyze the module: pass 1 - collect declarations
    collect_declarations(sema, mod_ast);

    # analyze the module: pass 2 - resolve types
    resolve_types(sema, mod_ast);

    # process top-level comptime statements (e.g., $X.symbol = "Y")
    # these aren't processed in passes 1-2 but are needed for export_name
    val ct_decls: *ast.List = mod_ast.info.block_stmt.stmts;
    if (ct_decls != nil) {
        var ct_i: i32 = 0;
        for (ct_i < ct_decls.count) {
            val ct_node: *ast.Node = ct_decls.nodes[ct_i];
            if (ct_node != nil && ct_node.kind == ast.NODE_COMPTIME) {
                analyze_comptime_stmt(sema, ct_node);
            }
            ct_i = ct_i + 1;
        }
    }

    # pass 2b: resolve types in imported module function bodies
    resolve_functions(sema, mod_ast);

    # pass 3: validate imported module function bodies
    check_functions(sema, mod_ast);

    # mark as analyzed
    mod.is_analyzed = true;

    # restore context
    sema.current_module = saved_module;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
    sema.symbols = saved_symbols;
    sema.module_path = saved_module_path;

    parser.parser_dnit(?p);
    ret mod;
}
