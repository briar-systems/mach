    if (option_is_some[*symbol.Symbol](existing_opt)) {
        report_error_node(sema, node, "duplicate type definition");
        ret;
    }

    # create symbol
    val sym_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, name, symbol.SYM_REC);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        report_error_node(sema, node, "failed to create symbol");
        ret;
    }

    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    sym.module_path = sema.module_path;

    # check for generics
    if (node.info.type_decl.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.info.type_decl.generics;
    }
}

