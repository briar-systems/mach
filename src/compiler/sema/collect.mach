use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use tyctx:  mach.compiler.type_context;

use mach.compiler.sema;
use loader: mach.compiler.sema.loader;

# mach.compiler.sema.collect: pass 1 — declaration registration and type shells.

pub fun run(s: *sema.Sema, root: *ast.Node) {
    if (s == nil || root == nil) { ret; }
    val decls: *ast.List = root.info.block_stmt.stmts;
    if (decls == nil) { ret; }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            collect_decl(s, node);
        }
        i = i + 1;
    }
}

fun collect_decl(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }

    if (node.kind == ast.NODE_DECL_FUN)  { collect_fun(s, node); ret; }
    if (node.kind == ast.NODE_DECL_VAL)  { collect_var(s, node, symbol.SYM_VAL); ret; }
    if (node.kind == ast.NODE_DECL_VAR)  { collect_var(s, node, symbol.SYM_VAR); ret; }
    if (node.kind == ast.NODE_DECL_DEF)  { collect_def(s, node); ret; }
    if (node.kind == ast.NODE_DECL_EXT)  { collect_ext(s, node); ret; }
    if (node.kind == ast.NODE_DECL_REC)  { collect_rec(s, node); ret; }
    if (node.kind == ast.NODE_DECL_UNI)  { collect_uni(s, node); ret; }
    if (node.kind == ast.NODE_DECL_USE)  { collect_use(s, node); ret; }
    if (node.kind == ast.NODE_DECL_TEST) { collect_test(s, node); ret; }
    if (node.kind == ast.NODE_DECL_PUB)  { collect_pub(s, node); ret; }
    if (node.kind == ast.NODE_COMPTIME_IF) { collect_comptime_if(s, node); ret; }
}

# --- individual declaration collectors ---

fun collect_fun(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.fun_decl.name;
    if (name == nil) { sema.report_error(s, node, "function has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, symbol.SYM_FUN);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate function declaration");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }
    if (node.info.fun_decl.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.info.fun_decl.generics;
    }
}

fun collect_var(s: *sema.Sema, node: *ast.Node, kind: symbol.SymbolKind) {
    val name: str = node.info.var_decl.name;
    if (name == nil) { sema.report_error(s, node, "variable has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, kind);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate variable declaration");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }
}

fun collect_def(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.def_decl.name;
    if (name == nil) { sema.report_error(s, node, "type alias has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, symbol.SYM_TYPE);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate type declaration");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }
}

fun collect_ext(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.ext_decl.name;
    if (name == nil) { sema.report_error(s, node, "external has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, symbol.SYM_EXT);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate external declaration");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }
}

fun collect_rec(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.type_decl.name;
    if (name == nil) { sema.report_error(s, node, "record has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, symbol.SYM_REC);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate type definition");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }

    if (node.info.type_decl.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.info.type_decl.generics;

        # create generic type shell
        val gen_res: Result[*ty.Type, str] = tyctx.generic_type(s.types, name);
        if (result_is_ok[*ty.Type, str](gen_res)) {
            val gt: *ty.Type = result_unwrap_ok[*ty.Type, str](gen_res);
            sym.resolved_type = gt;
            node.ty = gt;
        }
    } or {
        # create record type shell (empty, fields filled in resolve)
        val rec_res: Result[*ty.Type, str] = tyctx.record_type(s.types, name, nil, 0);
        if (result_is_ok[*ty.Type, str](rec_res)) {
            val rt: *ty.Type = result_unwrap_ok[*ty.Type, str](rec_res);
            sym.resolved_type = rt;
            node.ty = rt;
        }
    }
}

fun collect_uni(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.type_decl.name;
    if (name == nil) { sema.report_error(s, node, "union has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, symbol.SYM_UNI);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate type definition");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }

    if (node.info.type_decl.generics != nil) {
        sym.is_generic = true;
        sym.generic_node = node.info.type_decl.generics;

        val gen_res: Result[*ty.Type, str] = tyctx.generic_type(s.types, name);
        if (result_is_ok[*ty.Type, str](gen_res)) {
            val gt: *ty.Type = result_unwrap_ok[*ty.Type, str](gen_res);
            sym.resolved_type = gt;
            node.ty = gt;
        }
    } or {
        val uni_res: Result[*ty.Type, str] = tyctx.union_type(s.types, name, nil, 0);
        if (result_is_ok[*ty.Type, str](uni_res)) {
            val ut: *ty.Type = result_unwrap_ok[*ty.Type, str](uni_res);
            sym.resolved_type = ut;
            node.ty = ut;
        }
    }
}

fun collect_use(s: *sema.Sema, node: *ast.Node) {
    val mod_path: str = node.info.use_decl.path;
    if (mod_path == nil) {
        sema.report_error(s, node, "use statement has null module path");
        ret;
    }

    val alias: str = node.info.use_decl.alias;
    val is_aliased: bool = alias != nil;

    loader.load(s, mod_path, is_aliased, alias);
}

fun collect_test(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.test_decl.name;
    if (name == nil) { sema.report_error(s, node, "test has no name"); ret; }

    val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, symbol.SYM_FUN);
    if (result_is_err[*symbol.Symbol, str](sym_res)) {
        sema.report_error(s, node, "duplicate test declaration");
        ret;
    }
    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
    sym.decl_node = node;
    if (s.current != nil) { sym.module_path = s.current.path; }
}

fun collect_pub(s: *sema.Sema, node: *ast.Node) {
    val inner: *ast.Node = node.info.wrapper.inner;
    if (inner == nil) { ret; }

    # collect the inner declaration first
    collect_decl(s, inner);

    # then mark it public
    var name: str = nil;
    if (inner.kind == ast.NODE_DECL_FUN)  { name = inner.info.fun_decl.name; }
    if (inner.kind == ast.NODE_DECL_VAL || inner.kind == ast.NODE_DECL_VAR) { name = inner.info.var_decl.name; }
    if (inner.kind == ast.NODE_DECL_DEF)  { name = inner.info.def_decl.name; }
    if (inner.kind == ast.NODE_DECL_EXT)  { name = inner.info.ext_decl.name; }
    if (inner.kind == ast.NODE_DECL_REC || inner.kind == ast.NODE_DECL_UNI) { name = inner.info.type_decl.name; }
    if (inner.kind == ast.NODE_DECL_TEST) { name = inner.info.test_decl.name; }

    if (name != nil) {
        val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
        if (option_is_some[*symbol.Symbol](sym_opt)) {
            option_unwrap[*symbol.Symbol](sym_opt).is_public = true;
        }
    }
}

fun collect_comptime_if(s: *sema.Sema, node: *ast.Node) {
    val eval_res: Result[bool, str] = sema.eval_comptime(s, node);
    if (result_is_err[bool, str](eval_res)) { ret; }

    val taken: bool = result_unwrap_ok[bool, str](eval_res);
    if (taken) {
        # process body declarations
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            collect_comptime_body(s, body);
        }
    } or {
        # try or-branches
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) {
            if (or_branch.kind == ast.NODE_COMPTIME_OR) {
                collect_comptime_if(s, or_branch);
            } or {
                collect_comptime_body(s, or_branch);
            }
        }
    }
}

fun collect_comptime_body(s: *sema.Sema, body: *ast.Node) {
    if (body == nil) { ret; }

    # body may be a block or a single declaration
    if (body.kind == ast.NODE_STMT_BLOCK || body.kind == ast.NODE_PROGRAM || body.kind == ast.NODE_STMT_LIST) {
        val stmts: *ast.List = body.info.block_stmt.stmts;
        if (stmts == nil) { ret; }
        var i: i32 = 0;
        for (i < stmts.count) {
            val node: *ast.Node = stmts.nodes[i];
            if (node != nil) { collect_decl(s, node); }
            i = i + 1;
        }
    } or {
        collect_decl(s, body);
    }
}
