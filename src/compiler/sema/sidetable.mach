# mach.compiler.sema.sidetable: per-node type and symbol side tables
#
# parallel arrays indexed by NodeId that store resolved types and symbols
# alongside the immutable AST. owned by Module records, populated during
# the check phase.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use mem:       std.memory;
use ast:       mach.compiler.parse.ast;
use scope:     mach.compiler.sema.scope;
use type:      mach.compiler.sema.type;

# per-node mapping from AST node to resolved type
# ---
# types: array of TypeId indexed by NodeId
# count: number of entries
pub rec ExprTypeMap {
    types: *type.TypeId;
    count: u32;
    cap:   u32;
    alloc: *allocator.Allocator;
}

# per-node mapping from AST node to resolved symbol
# ---
# syms:  array of SymbolId indexed by NodeId
# count: number of entries
pub rec NodeSymMap {
    syms:  *scope.SymbolId;
    count: u32;
    cap:   u32;
    alloc: *allocator.Allocator;
}

# init_expr_types: create an ExprTypeMap for a given number of AST nodes
# ---
# alloc:      allocator for the types array
# node_count: number of nodes to map
# ret:        initialized ExprTypeMap with all entries set to TYPE_NIL
pub fun init_expr_types(alloc: *allocator.Allocator, node_count: u32) ExprTypeMap {
    var etm: ExprTypeMap;
    etm.count = node_count;
    etm.cap   = node_count;
    etm.types = nil;
    etm.alloc = alloc;

    if (node_count > 0) {
        val res_alloc: Result[*type.TypeId, str] = allocator.allocate[type.TypeId](alloc, node_count::usize);
        if (is_ok[*type.TypeId, str](res_alloc)) {
            etm.types = unwrap_ok[*type.TypeId, str](res_alloc);
            var i: u32 = 0;
            for (i < node_count) {
                etm.types[i] = type.TYPE_NIL;
                i = i + 1;
            }
        }
    }

    ret etm;
}

# init_node_syms: create a NodeSymMap for a given number of AST nodes
# ---
# alloc:      allocator for the syms array
# node_count: number of nodes to map
# ret:        initialized NodeSymMap with all entries set to SYM_NIL
pub fun init_node_syms(alloc: *allocator.Allocator, node_count: u32) NodeSymMap {
    var nsm: NodeSymMap;
    nsm.count = node_count;
    nsm.cap   = node_count;
    nsm.syms  = nil;
    nsm.alloc = alloc;

    if (node_count > 0) {
        val res_alloc: Result[*scope.SymbolId, str] = allocator.allocate[scope.SymbolId](alloc, node_count::usize);
        if (is_ok[*scope.SymbolId, str](res_alloc)) {
            nsm.syms = unwrap_ok[*scope.SymbolId, str](res_alloc);
            var i: u32 = 0;
            for (i < node_count) {
                nsm.syms[i] = scope.SYM_NIL;
                i = i + 1;
            }
        }
    }

    ret nsm;
}

# set_type: record a resolved type for an AST node
# ---
# etm:     expression type map
# node_id: AST node
# type_id: resolved type
pub fun set_type(etm: *ExprTypeMap, node_id: ast.NodeId, type_id: type.TypeId) {
    if (etm.types == nil) { ret; }
    if (node_id::u32 >= etm.count) {
        grow_etm(etm, node_id::u32 + 1);
    }
    if (node_id::u32 < etm.count) {
        etm.types[node_id::u32] = type_id;
    }
}

# get_type: retrieve the resolved type for an AST node
# ---
# etm:     expression type map
# node_id: AST node
# ret:     resolved TypeId, or TYPE_NIL if not set
pub fun get_type(etm: *ExprTypeMap, node_id: ast.NodeId) type.TypeId {
    if (etm.types != nil && node_id::u32 < etm.count) {
        ret etm.types[node_id::u32];
    }
    ret type.TYPE_NIL;
}

# set_sym: record a resolved symbol for an AST node
# ---
# nsm:     node symbol map
# node_id: AST node
# sym_id:  resolved symbol
pub fun set_sym(nsm: *NodeSymMap, node_id: ast.NodeId, sym_id: scope.SymbolId) {
    if (nsm.syms == nil) { ret; }
    if (node_id::u32 >= nsm.count) {
        grow_nsm(nsm, node_id::u32 + 1);
    }
    if (node_id::u32 < nsm.count) {
        nsm.syms[node_id::u32] = sym_id;
    }
}

# get_sym: retrieve the resolved symbol for an AST node
# ---
# nsm:     node symbol map
# node_id: AST node
# ret:     resolved SymbolId, or SYM_NIL if not set
pub fun get_sym(nsm: *NodeSymMap, node_id: ast.NodeId) scope.SymbolId {
    if (nsm.syms != nil && node_id::u32 < nsm.count) {
        ret nsm.syms[node_id::u32];
    }
    ret scope.SYM_NIL;
}

fun grow_etm(etm: *ExprTypeMap, needed: u32) {
    if (etm.alloc == nil) { ret; }
    var new_cap: u32 = etm.cap;
    if (new_cap == 0) { new_cap = 64; }
    for (new_cap < needed) { new_cap = new_cap * 2; }
    val res: Result[*type.TypeId, str] = allocator.reallocate[type.TypeId](
        etm.alloc, etm.types, etm.cap::usize, new_cap::usize);
    if (is_err[*type.TypeId, str](res)) { ret; }
    etm.types = unwrap_ok[*type.TypeId, str](res);
    var i: u32 = etm.count;
    for (i < new_cap) {
        etm.types[i] = type.TYPE_NIL;
        i = i + 1;
    }
    etm.count = new_cap;
    etm.cap   = new_cap;
}

fun grow_nsm(nsm: *NodeSymMap, needed: u32) {
    if (nsm.alloc == nil) { ret; }
    var new_cap: u32 = nsm.cap;
    if (new_cap == 0) { new_cap = 64; }
    for (new_cap < needed) { new_cap = new_cap * 2; }
    val res: Result[*scope.SymbolId, str] = allocator.reallocate[scope.SymbolId](
        nsm.alloc, nsm.syms, nsm.cap::usize, new_cap::usize);
    if (is_err[*scope.SymbolId, str](res)) { ret; }
    nsm.syms = unwrap_ok[*scope.SymbolId, str](res);
    var i: u32 = nsm.count;
    for (i < new_cap) {
        nsm.syms[i] = scope.SYM_NIL;
        i = i + 1;
    }
    nsm.count = new_cap;
    nsm.cap   = new_cap;
}
