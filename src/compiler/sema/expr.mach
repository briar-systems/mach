use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use type:     mach.compiler.type;
use token:  mach.compiler.token;
use mach.compiler.sema;
use mach.compiler.sema.errors;

# mach.compiler.sema.expr: expression/type resolution, generics, and symbol lookup.

# maybe_resolve_symbol_type_in_module: resolve a type symbol in its module context if needed.
# ---
# sema: analyzer context
# mod:  module containing the symbol (may be nil for current)
# sym:  symbol to resolve
fun maybe_resolve_symbol_type_in_module(sema: *Sema, mod: *SemaModule, sym: *symbol.Symbol) {
    if (sema == nil || sym == nil) {
        ret;
    }
    if (sym.resolved_type != nil || sym.decl_node == nil) {
        ret;
    }
    if (sym.is_being_resolved) {
        ret;
    }

    sym.is_being_resolved = true;

    # save context
    val saved_module: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;

    if (mod != nil) {
        sema.current_module = mod;
        sema.symbols = mod.table;
        sema.file_path = mod.file_path;
        sema.source = mod.source;
    }

    resolve_node_type_for_symbol(sema, sym.decl_node);

    sym.is_being_resolved = false;

    # restore context
    sema.current_module = saved_module;
    sema.symbols = saved_symbols;
    sema.file_path = saved_file_path;
    sema.source = saved_source;
}

# resolve_node_type_for_symbol: minimal type resolution for a single declaration node.
# used by maybe_resolve_symbol_type_in_module to on-demand resolve type shells.
fun resolve_node_type_for_symbol(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # type declaration - resolve the underlying type
    if (node.kind == ast.NODE_DECL_DEF) {
        val type_node: *ast.Node = node.info.def_decl.type_node;
        if (type_node != nil) {
            val t: *type.Type = resolve_type_expr(sema, type_node);
            if (t != nil) {
                node.type = t;
                val name: str = node.info.def_decl.name;
                if (name != nil) {
                    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
                    if (option_is_some[*symbol.Symbol](sym_opt)) {
                        option_unwrap[*symbol.Symbol](sym_opt).resolved_type = t;
                    }
                }
            }
        }
        ret;
    }

    # function declaration - resolve signature
    if (node.kind == ast.NODE_DECL_FUN) {
        val fun_type: *type.Type = resolve_function_type(sema, node);
        if (fun_type != nil) {
            node.type = fun_type;
            val name2: str = node.info.fun_decl.name;
            if (name2 != nil) {
                val sym_opt2: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name2);
                if (option_is_some[*symbol.Symbol](sym_opt2)) {
                    option_unwrap[*symbol.Symbol](sym_opt2).resolved_type = fun_type;
                }
            }
        }
        ret;
    }

    # variable/constant declaration - resolve initializer type
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val init_node: *ast.Node = node.info.var_decl.init;
        if (init_node != nil) {
            val init_type: *type.Type = resolve_expr_type(sema, init_node);
            if (init_type != nil) {
                node.type = init_type;
                val name: str = node.info.var_decl.name;
                if (name != nil) {
                    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
                    if (option_is_some[*symbol.Symbol](sym_opt)) {
                        option_unwrap[*symbol.Symbol](sym_opt).resolved_type = init_type;
                    }
                }
            }
        }
        ret;
    }

    # record declaration - create type shell
    if (node.kind == ast.NODE_DECL_REC) {
        val name: str = node.info.type_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
            if (option_is_some[*symbol.Symbol](sym_opt)) {
                val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
                if (sym.resolved_type == nil) {
                    if (sym.is_generic) {
                        val gen_res: Result[*type.Type, str] = type.make_generic(sema.types, name);
                        if (result_is_ok[*type.Type, str](gen_res)) {
                            sym.resolved_type = result_unwrap_ok[*type.Type, str](gen_res);
                            node.type = sym.resolved_type;
                        }
                    } or {
                        val rec_res: Result[*type.Type, str] = type.make_record(sema.types, name, nil, 0);
                        if (result_is_ok[*type.Type, str](rec_res)) {
                            sym.resolved_type = result_unwrap_ok[*type.Type, str](rec_res);
                            node.type = sym.resolved_type;
                        }
                    }
                }
            }
        }
        ret;
    }

    # union declaration - create type shell
    if (node.kind == ast.NODE_DECL_UNI) {
        val name: str = node.info.type_decl.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
            if (option_is_some[*symbol.Symbol](sym_opt)) {
                val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
                if (sym.resolved_type == nil) {
                    if (sym.is_generic) {
                        val gen_res: Result[*type.Type, str] = type.make_generic(sema.types, name);
                        if (result_is_ok[*type.Type, str](gen_res)) {
                            sym.resolved_type = result_unwrap_ok[*type.Type, str](gen_res);
                            node.type = sym.resolved_type;
                        }
                    } or {
                        val uni_res: Result[*type.Type, str] = type.make_union(sema.types, name, nil, 0);
                        if (result_is_ok[*type.Type, str](uni_res)) {
                            sym.resolved_type = result_unwrap_ok[*type.Type, str](uni_res);
                            node.type = sym.resolved_type;
                        }
                    }
                }
            }
        }
        ret;
    }

    # pub wrapper - process inner declaration
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            resolve_node_type_for_symbol(sema, inner);
        }
        ret;
    }
}

# lookup_type_symbol: look up a type symbol by name, checking local scope and imports.
# ---
# sema: analyzer context
# name: type name (may be dotted like "alias.Type")
# ret:  symbol if found, nil otherwise
fun lookup_type_symbol(sema: *Sema, name: str) *symbol.Symbol {
    if (sema == nil || name == nil) {
        ret nil;
    }

    # check for dotted path (alias.Type)
    var pos: usize = 0;
    var found_dot: bool = false;
    val name_len: usize = str_len(name);
    var i: usize = 0;
    for (i < name_len) {
        if (name[i] == '.') {
            pos = i;
            found_dot = true;
            brk;
        }
        i = i + 1;
    }
    if (found_dot) {
        if (pos > 0 && sema.current_module != nil) {
            # extract alias and type name
            # alias is name[0..pos], type_name is name[pos+1..]
            # name_len already computed

            # find the alias in current module's aliases
            var alias_entry: *ModuleAlias = sema.current_module.aliases;
            for (alias_entry != nil) {
                if (alias_entry.alias != nil) {
                    val alias_len: usize = str_len(alias_entry.alias);
                    if (alias_len == pos) {
                        # compare alias prefix
                        var match: bool = true;
                        var i: usize = 0;
                        for (i < pos) {
                            if (name[i] != alias_entry.alias[i]) {
                                match = false;
                                brk;
                            }
                            i = i + 1;
                        }

                        if (match) {
                            # found matching alias - look up type in that module
                            val target_mod: *SemaModule = alias_entry.module;
                            if (target_mod != nil && target_mod.table != nil) {
                                # extract type name after the dot
                                val type_start: usize = pos + 1;
                                val type_len: usize = name_len - type_start;

                                # look up in that module's root scope
                                val root: *symbol.Scope = target_mod.table.root;
                                if (root != nil) {
                                    var si: i32 = 0;
                                    var fallback: *symbol.Symbol = nil;
                                    for (si < root.symbol_count) {
                                        val sym: *symbol.Symbol = ?root.symbols[si::usize];
                                        if (sym.name != nil) {
                                            val sym_len: usize = str_len(sym.name);
                                            if (sym_len == type_len) {
                                                # compare type name
                                                var tmatch: bool = true;
                                                var ti: usize = 0;
                                                for (ti < type_len) {
                                                    if (name[type_start + ti] != sym.name[ti]) {
                                                        tmatch = false;
                                                        brk;
                                                    }
                                                    ti = ti + 1;
                                                }
                                                if (tmatch && (sym.kind == symbol.SYM_TYPE ||
                                                               sym.kind == symbol.SYM_REC ||
                                                               sym.kind == symbol.SYM_UNI)) {
                                                    if (sym.is_public) {
                                                        maybe_resolve_symbol_type_in_module(sema, target_mod, sym);
                                                        ret sym;
                                                    }
                                                    if (fallback == nil) {
                                                        fallback = sym;
                                                    }
                                                }
                                            }
                                        }
                                        si = si + 1;
                                    }
                                    if (fallback != nil) {
                                        maybe_resolve_symbol_type_in_module(sema, target_mod, fallback);
                                        ret fallback;
                                    }
                                }
                            }
                            ret nil;  # alias found but type not found
                        }
                    }
                }
                alias_entry = alias_entry.next;
            }
        }
        # dotted name but alias not found - fall through to local lookup
    }

    # unqualified type: check local symbol table via direct scope walk
    # (avoids Option[*Symbol] return path which may have codegen issues)
    if (sema.symbols != nil && sema.symbols.current != nil) {
        var lk_scope: *symbol.Scope = sema.symbols.current;
        for (lk_scope != nil) {
            var lk_i: i32 = 0;
            for (lk_i < lk_scope.symbol_count) {
                val lk_sym: *symbol.Symbol = ?lk_scope.symbols[lk_i::usize];
                if (lk_sym.name != nil && str_equals(lk_sym.name, name)) {
                    if (lk_sym.kind == symbol.SYM_TYPE || lk_sym.kind == symbol.SYM_REC || lk_sym.kind == symbol.SYM_UNI) {
                        maybe_resolve_symbol_type_in_module(sema, sema.current_module, lk_sym);
                        ret lk_sym;
                    }
                }
                lk_i = lk_i + 1;
            }
            lk_scope = lk_scope.parent;
        }
    }

    # check unaliased imports (use foo.bar; brings public symbols into scope)
    if (sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                val root: *symbol.Scope = imp.module.table.root;
                if (root != nil) {
                    var i: i32 = 0;
                    for (i < root.symbol_count) {
                        val sym: *symbol.Symbol = ?root.symbols[i::usize];
                        if (sym.name != nil && sym.is_public && str_equals(sym.name, name)) {
                            if (sym.kind == symbol.SYM_TYPE ||
                                sym.kind == symbol.SYM_REC ||
                                sym.kind == symbol.SYM_UNI) {
                                maybe_resolve_symbol_type_in_module(sema, imp.module, sym);
                                ret sym;
                            }
                        }
                        i = i + 1;
                    }
                }
            }
            imp = imp.next;
        }
    }

    ret nil;
}

# lookup_module_function: look up a function symbol in an aliased module.
# ---
# sema:       analyzer context
# alias_name: module alias (e.g., "allocator" from `use allocator: ...`)
# func_name:  function name within that module
# ret:        symbol if found, nil otherwise
fun lookup_module_function(sema: *Sema, alias_name: str, func_name: str) *symbol.Symbol {
    if (sema == nil || alias_name == nil || func_name == nil || sema.current_module == nil) {
        ret nil;
    }
    var ma: *ModuleAlias = sema.current_module.aliases;
    for (ma != nil) {
        if (ma.alias != nil && str_equals(ma.alias, alias_name) && ma.module != nil && ma.module.table != nil) {
            val root: *symbol.Scope = symbol.table_root_scope(ma.module.table);
            if (root != nil) {
                val opt: Option[*symbol.Symbol] = symbol.scope_lookup_local(root, func_name);
                if (option_is_some[*symbol.Symbol](opt)) {
                    ret option_unwrap[*symbol.Symbol](opt);
                }
            }
        }
        ma = ma.next;
    }
    ret nil;
}

# lookup_function_symbol: look up a function symbol by name, checking local scope and imports.
# ---
# sema: analyzer context
# name: function name
# ret:  symbol if found, nil otherwise
fun lookup_function_symbol(sema: *Sema, name: str) *symbol.Symbol {
    if (sema == nil || name == nil) {
        ret nil;
    }

    # check local symbol table first
    val local_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
    if (option_is_some[*symbol.Symbol](local_opt)) {
        val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](local_opt);
        if (sym.kind == symbol.SYM_FUN || sym.kind == symbol.SYM_EXT) {
            ret sym;
        }
    }

    # check unaliased imports
    if (sema.current_module != nil) {
        var imp: *ModuleImport = sema.current_module.imports;
        for (imp != nil) {
            if (imp.module != nil && imp.module.table != nil) {
                val root: *symbol.Scope = imp.module.table.root;
                if (root != nil) {
                    var i: i32 = 0;
                    for (i < root.symbol_count) {
                        val sym: *symbol.Symbol = ?root.symbols[i::usize];
                        if (sym.name != nil && sym.is_public && str_equals(sym.name, name)) {
                            if (sym.kind == symbol.SYM_FUN || sym.kind == symbol.SYM_EXT) {
                                ret sym;
                            }
                        }
                        i = i + 1;
                    }
                }
            }
            imp = imp.next;
        }
    }

    ret nil;
}

# compute_record_layout: compute field offsets, size, and alignment for a record type.
# ---
# t:           record type to update (size and align are set)
# fields:      field array (offsets will be set in-place)
# field_count: number of fields
pub fun compute_record_layout(t: *type.Type, fields: *type.Field, field_count: i32) {
    var offset: usize = 0;
    var max_align: usize = 1;

    var i: i32 = 0;
    for (i < field_count) {
        val ft: *type.Type = fields[i].type;
        if (ft != nil) {
            val field_align: usize = ft.align;
            if (field_align > max_align) {
                max_align = field_align;
            }
            if (field_align > 0) {
                offset = (offset + field_align - 1) & ~(field_align - 1);
            }
            fields[i].offset = offset;
            offset = offset + ft.size;
        }
        i = i + 1;
    }

    if (max_align > 0) {
        offset = (offset + max_align - 1) & ~(max_align - 1);
    }

    t.size = offset;
    t.align = max_align;
}

# compute_union_layout: compute size and alignment for a union type.
# ---
# t:           union type to update (size and align are set)
# fields:      field array (all offsets will be set to 0)
# field_count: number of fields
pub fun compute_union_layout(t: *type.Type, fields: *type.Field, field_count: i32) {
    var max_size: usize = 0;
    var max_align: usize = 1;

    var i: i32 = 0;
    for (i < field_count) {
        val ft: *type.Type = fields[i].type;
        if (ft != nil) {
            if (ft.size > max_size) {
                max_size = ft.size;
            }
            if (ft.align > max_align) {
                max_align = ft.align;
            }
        }
        fields[i].offset = 0;
        i = i + 1;
    }

    if (max_align > 0) {
        max_size = (max_size + max_align - 1) & ~(max_align - 1);
    }

    t.size = max_size;
    t.align = max_align;
}

# --- shared generic instantiation helpers ---

# bind_generic_params_list: push scope and bind type params from an ast.List of param nodes.
# ---
# sema:          analyzer context
# params_list:   list of NODE_TYPE_NAME param nodes (e.g. [T, E])
# resolved_args: array of concrete types to bind
# count:         number of parameters to bind
# ret:           true on success, false on scope push failure
fun bind_generic_params_list(sema: *Sema, params_list: *ast.List,
                             resolved_args: **type.Type, count: i32) bool {
    val push_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
    if (result_is_err[bool, str](push_res)) {
        ret false;
    }

    var i: i32 = 0;
    for (i < count && i < params_list.count) {
        val param: *ast.Node = params_list.nodes[i];
        if (param != nil && resolved_args[i] != nil) {
            val param_name: str = param.info.type_name.path;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_name, symbol.SYM_TYPE);
                if (result_is_ok[*symbol.Symbol, str](bind_res)) {
                    result_unwrap_ok[*symbol.Symbol, str](bind_res).resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }
    ret true;
}

# bind_generic_params_names: push scope and bind type params from a names array.
# ---
# sema:          analyzer context
# param_names:   array of parameter name strings
# resolved_args: array of concrete types to bind
# count:         number of parameters to bind
# ret:           true on success, false on scope push failure
fun bind_generic_params_names(sema: *Sema, param_names: *str,
                              resolved_args: **type.Type, count: i32) bool {
    val push_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
    if (result_is_err[bool, str](push_res)) {
        ret false;
    }

    var i: i32 = 0;
    for (i < count) {
        if (param_names != nil && param_names[i] != nil && resolved_args[i] != nil) {
            val bind_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_names[i], symbol.SYM_TYPE);
            if (result_is_ok[*symbol.Symbol, str](bind_res)) {
                result_unwrap_ok[*symbol.Symbol, str](bind_res).resolved_type = resolved_args[i];
            }
        }
        i = i + 1;
    }
    ret true;
}

# lookup_type_cache: search the generic type cache for an existing instantiation.
# ---
# sema:          analyzer context
# base_generic:  the uninstantiated generic type
# resolved_args: array of concrete type arguments
# arg_count:     number of type arguments
# ret:           cached result type, or nil if not found
fun lookup_type_cache(sema: *Sema, base_generic: *type.Type,
                      resolved_args: **type.Type, arg_count: i32) *type.Type {
    var cached: *CachedInstantiation = sema.generic_cache;
    for (cached != nil) {
        if (cached.arg_count == arg_count && cached.result_type != nil &&
            cached.result_type.base_generic == base_generic) {
            var match: bool = true;
            var i: i32 = 0;
            for (i < cached.arg_count) {
                if (cached.generic_args[i] != resolved_args[i]) {
                    match = false;
                }
                i = i + 1;
            }
            if (match) {
                ret cached.result_type;
            }
        }
        cached = cached.next;
    }
    ret nil;
}

# store_type_cache: add a generic type instantiation to the cache.
# ---
# sema:          analyzer context
# result_type:   the instantiated concrete type
# resolved_args: array of concrete type arguments
# arg_count:     number of type arguments
fun store_type_cache(sema: *Sema, result_type: *type.Type,
                     resolved_args: **type.Type, arg_count: i32) {
    if (result_type == nil) { ret; }

    val ce_res: Result[*CachedInstantiation, allocator.AllocError] =
        allocator.allocator_zalloc[CachedInstantiation](sema.alloc, 1);
    if (result_is_err[*CachedInstantiation, allocator.AllocError](ce_res)) { ret; }

    val ce: *CachedInstantiation =
        result_unwrap_ok[*CachedInstantiation, allocator.AllocError](ce_res);
    val ga_res: Result[**type.Type, allocator.AllocError] =
        allocator.allocator_alloc[*type.Type](sema.alloc, arg_count::usize);
    if (result_is_err[**type.Type, allocator.AllocError](ga_res)) { ret; }

    ce.generic_args = result_unwrap_ok[**type.Type, allocator.AllocError](ga_res);
    var i: i32 = 0;
    for (i < arg_count) {
        ce.generic_args[i] = resolved_args[i];
        i = i + 1;
    }
    ce.arg_count = arg_count;
    ce.result_type = result_type;
    ce.next = sema.generic_cache;
    sema.generic_cache = ce;
}

# register_func_inst_symbol: register an instantiated function symbol in both
# the origin module's root scope and the caller's root scope.
# ---
# origin_table:  symbol table of the module where the generic is defined
# caller_table:  symbol table of the module calling the generic
# name:          mangled function name
# func_type:     instantiated function type
# func_ast:      cloned function AST node
# module_path:   origin module path
# is_public:     whether the original function is public
fun register_func_inst_symbol(origin_table: *symbol.Table, caller_table: *symbol.Table,
                              name: str, func_type: *type.Type, func_ast: *ast.Node,
                              module_path: str, is_public: bool) {
    # register in origin module's root scope
    val saved_origin: *symbol.Scope = origin_table.current;
    origin_table.current = origin_table.root;
    val origin_res: Result[*symbol.Symbol, str] = symbol.table_define(origin_table, name, symbol.SYM_FUN);
    if (result_is_ok[*symbol.Symbol, str](origin_res)) {
        val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](origin_res);
        sym.resolved_type = func_type;
        sym.decl_node = func_ast;
        sym.module_path = module_path;
        sym.is_public = is_public;
    }
    origin_table.current = saved_origin;

    # register in caller's root scope if different
    if (caller_table != origin_table) {
        val saved_caller: *symbol.Scope = caller_table.current;
        caller_table.current = caller_table.root;
        val caller_res: Result[*symbol.Symbol, str] = symbol.table_define(caller_table, name, symbol.SYM_FUN);
        if (result_is_ok[*symbol.Symbol, str](caller_res)) {
            val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](caller_res);
            sym.resolved_type = func_type;
            sym.decl_node = func_ast;
            sym.module_path = module_path;
            sym.is_public = is_public;
        }
        caller_table.current = saved_caller;
    }
}

# --- generic instantiation ---

# instantiate_generic_type: instantiate a generic type with concrete type arguments.
# ---
# sema:      analyzer context
# type_sym:  the generic type's symbol
# type_args: NODE_GENERIC node containing the type arguments list
# ret:       instantiated concrete type or nil
fun instantiate_generic_type(sema: *Sema, type_sym: *symbol.Symbol, type_args: *ast.Node) *type.Type {
    if (sema == nil || type_sym == nil || type_args == nil) {
        ret nil;
    }

    if (!type_sym.is_generic || type_sym.decl_node == nil) {
        ret nil;
    }

    val type_decl: *ast.Node = type_sym.decl_node;

    # get formal generic params from type declaration
    val generic_params: *ast.Node = type_decl.info.type_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    # type_args is NODE_GENERIC, its children is the list
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    # resolve type args in current scope BEFORE pushing bindings
    if (args_list.count > 8) {
        report_error_node(sema, type_args, "too many generic type arguments (maximum 8)");
        ret nil;
    }
    var resolved_args: [8]*type.Type;
    var all_concrete: bool = true;
    var j: i32 = 0;
    for (j < args_list.count && j < 8) {
        val arg: *ast.Node = args_list.nodes[j];
        if (arg != nil) {
            resolved_args[j] = resolve_type_expr(sema, arg);
            # check if this is an unresolvable type
            if (resolved_args[j] == nil ||
                resolved_args[j].kind == type.TYPE_GENERIC) {
                all_concrete = false;
            }
        } or {
            all_concrete = false;
        }
        j = j + 1;
    }

    # if not all args are concrete, don't instantiate
    if (!all_concrete) {
        ret nil;
    }

    # check cache for existing instantiation with same base + args
    var cached: *CachedInstantiation = sema.generic_cache;
    for (cached != nil) {
        if (cached.arg_count == args_list.count && cached.result_type != nil &&
            cached.result_type.base_generic == type_sym.resolved_type) {
            var cache_match: bool = true;
            var cm: i32 = 0;
            for (cm < cached.arg_count && cm < 8) {
                if (cached.generic_args[cm] != resolved_args[cm]) {
                    cache_match = false;
                }
                cm = cm + 1;
            }
            if (cache_match) {
                ret cached.result_type;
            }
        }
        cached = cached.next;
    }

    # push a new scope for the generic bindings
    val push_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
    if (result_is_err[bool, str](push_res)) {
        ret nil;
    }

    # bind each generic param to its resolved type arg
    var i: i32 = 0;
    for (i < params_list.count && i < 8) {
        val param: *ast.Node = params_list.nodes[i];
        if (param != nil && resolved_args[i] != nil) {
            val param_name: str = param.info.type_name.path;
            if (param_name != nil) {
                val bind_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_name, symbol.SYM_TYPE);
                if (result_is_ok[*symbol.Symbol, str](bind_res)) {
                    val bind_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](bind_res);
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # switch to origin module context for field resolution
    val saved_module: *SemaModule = sema.current_module;
    val saved_module_path: str = sema.module_path;
    val saved_file_path: str = sema.file_path;
    val saved_source: str = sema.source;
    val saved_symbols: *symbol.Table = sema.symbols;

    if (type_sym.module_path != nil) {
        var origin: *SemaModule = sema.modules;
        for (origin != nil) {
            if (origin.path != nil && str_equals(origin.path, type_sym.module_path)) {
                sema.current_module = origin;
                sema.module_path = origin.path;
                sema.file_path = origin.file_path;
                sema.source = origin.source;
                if (origin.table != nil) {
                    sema.symbols = origin.table;
                }
            }
            origin = origin.next;
        }
    }

    # re-push generic bindings on the origin module's symbol table
    val rebind_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
    if (result_is_err[bool, str](rebind_res)) {
        sema.symbols = saved_symbols;
        sema.current_module = saved_module;
        sema.module_path = saved_module_path;
        sema.file_path = saved_file_path;
        sema.source = saved_source;
        ret nil;
    }
    var rb_i: i32 = 0;
    for (rb_i < params_list.count && rb_i < 8) {
        val rb_param: *ast.Node = params_list.nodes[rb_i];
        if (rb_param != nil && resolved_args[rb_i] != nil) {
            val rb_name: str = rb_param.info.type_name.path;
            if (rb_name != nil) {
                val rb_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, rb_name, symbol.SYM_TYPE);
                if (result_is_ok[*symbol.Symbol, str](rb_res)) {
                    result_unwrap_ok[*symbol.Symbol, str](rb_res).resolved_type = resolved_args[rb_i];
                }
            }
        }
        rb_i = rb_i + 1;
    }

    # now resolve the type's fields with bindings in scope
    var result_type: *type.Type = nil;

    if (type_decl.kind == ast.NODE_DECL_REC) {
        # resolve record fields
        val ast_fields: *ast.List = type_decl.info.type_decl.fields;
        if (ast_fields != nil && ast_fields.count > 0) {
            # allocate fields array
            val fields_res: Result[*type.Field, allocator.AllocError] =
                allocator.allocator_alloc[type.Field](sema.alloc, ast_fields.count::usize);
            if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
                symbol.table_pop_scope(sema.symbols);
                sema.symbols = saved_symbols;
                symbol.table_pop_scope(sema.symbols);
                sema.current_module = saved_module;
                sema.module_path = saved_module_path;
                sema.file_path = saved_file_path;
                sema.source = saved_source;
                ret nil;
            }
            val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
            var field_count: i32 = 0;

            # resolve and populate fields
            var fi: i32 = 0;
            for (fi < ast_fields.count) {
                val field_node: *ast.Node = ast_fields.nodes[fi];
                if (field_node != nil) {
                    val field_name: str = field_node.info.field_decl.name;
                    val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
                    var field_type: *type.Type = nil;
                    if (field_type_node != nil) {
                        field_type = resolve_type_expr(sema, field_type_node);
                    }
                    if (field_name != nil && field_type != nil) {
                        fields[field_count].name = field_name;
                        fields[field_count].type = field_type;
                        fields[field_count].offset = 0;
                        field_count = field_count + 1;
                    }
                }
                fi = fi + 1;
            }

            # create the record type
            val rec_res: Result[*type.Type, str] = type.make_record(sema.types, type_sym.name, fields, field_count);
            if (result_is_ok[*type.Type, str](rec_res)) {
                result_type = result_unwrap_ok[*type.Type, str](rec_res);

                compute_record_layout(result_type, fields, field_count);

                # store generic args on the instantiated type
                type.set_generic_args(sema.types, result_type, ?resolved_args[0], args_list.count);
                type.set_base_generic(result_type, type_sym.resolved_type);
            }
        }
    } or {
        if (type_decl.kind == ast.NODE_DECL_UNI) {
            # resolve union variants
            val ast_variants: *ast.List = type_decl.info.type_decl.fields;
            if (ast_variants != nil && ast_variants.count > 0) {
                # allocate fields array
                val fields_res: Result[*type.Field, allocator.AllocError] =
                    allocator.allocator_alloc[type.Field](sema.alloc, ast_variants.count::usize);
                if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
                    symbol.table_pop_scope(sema.symbols);
                    sema.symbols = saved_symbols;
                    symbol.table_pop_scope(sema.symbols);
                    sema.current_module = saved_module;
                    sema.module_path = saved_module_path;
                    sema.file_path = saved_file_path;
                    sema.source = saved_source;
                    ret nil;
                }
                val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
                var field_count: i32 = 0;

                var vi: i32 = 0;
                for (vi < ast_variants.count) {
                    val variant_node: *ast.Node = ast_variants.nodes[vi];
                    if (variant_node != nil) {
                        val var_name: str = variant_node.info.field_decl.name;
                        val var_type_node: *ast.Node = variant_node.info.field_decl.type_node;
                        var var_type: *type.Type = nil;
                        if (var_type_node != nil) {
                            var_type = resolve_type_expr(sema, var_type_node);
                        }
                        if (var_name != nil && var_type != nil) {
                            fields[field_count].name = var_name;
                            fields[field_count].type = var_type;
                            fields[field_count].offset = 0;
                            field_count = field_count + 1;
                        }
                    }
                    vi = vi + 1;
                }

                # create the union type
                val uni_res: Result[*type.Type, str] = type.make_union(sema.types, type_sym.name, fields, field_count);
                if (result_is_ok[*type.Type, str](uni_res)) {
                    result_type = result_unwrap_ok[*type.Type, str](uni_res);

                    compute_union_layout(result_type, fields, field_count);

                    # store generic args on the instantiated type
                    type.set_generic_args(sema.types, result_type, ?resolved_args[0], args_list.count);
                    type.set_base_generic(result_type, type_sym.resolved_type);
                }
            }
        }
    }

    # pop the binding scope on origin table and restore caller's table
    symbol.table_pop_scope(sema.symbols);
    sema.symbols = saved_symbols;

    # pop the original binding scope on the caller's table
    symbol.table_pop_scope(sema.symbols);

    # restore module context
    sema.current_module = saved_module;
    sema.module_path = saved_module_path;
    sema.file_path = saved_file_path;
    sema.source = saved_source;

    # cache the instantiation for resolve_concrete_type lookups
    if (result_type != nil) {
        val ce_res: Result[*CachedInstantiation, allocator.AllocError] =
            allocator.allocator_zalloc[CachedInstantiation](sema.alloc, 1);
        if (result_is_ok[*CachedInstantiation, allocator.AllocError](ce_res)) {
            val ce: *CachedInstantiation =
                result_unwrap_ok[*CachedInstantiation, allocator.AllocError](ce_res);
            val ga_res: Result[**type.Type, allocator.AllocError] =
                allocator.allocator_alloc[*type.Type](sema.alloc, args_list.count::usize);
            if (result_is_ok[**type.Type, allocator.AllocError](ga_res)) {
                ce.generic_args = result_unwrap_ok[**type.Type, allocator.AllocError](ga_res);
                var ci: i32 = 0;
                for (ci < args_list.count && ci < 8) {
                    ce.generic_args[ci] = resolved_args[ci];
                    ci = ci + 1;
                }
                ce.arg_count = args_list.count;
                ce.result_type = result_type;
                ce.next = sema.generic_cache;
                sema.generic_cache = ce;
            }
        }
    }

    ret result_type;
}

# resolve_type_expr: resolve a type expression to a Type.
# ---
# sema: analyzer context
# node: type expression node
# ret:  resolved type or nil
pub fun resolve_type_expr(sema: *Sema, node: *ast.Node) *type.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # named type (primitive or typedef)
    if (node.kind == ast.NODE_TYPE_NAME) {
        val name: str = node.info.type_name.path;
        if (name != nil) {
            # lookup primitive type
            if (str_equals(name, "u8")) { ret type.get_primitive(sema.types, type.TYPE_U8); }
            if (str_equals(name, "u16")) { ret type.get_primitive(sema.types, type.TYPE_U16); }
            if (str_equals(name, "u32")) { ret type.get_primitive(sema.types, type.TYPE_U32); }
            if (str_equals(name, "u64")) { ret type.get_primitive(sema.types, type.TYPE_U64); }
            if (str_equals(name, "i8")) { ret type.get_primitive(sema.types, type.TYPE_I8); }
            if (str_equals(name, "i16")) { ret type.get_primitive(sema.types, type.TYPE_I16); }
            if (str_equals(name, "i32")) { ret type.get_primitive(sema.types, type.TYPE_I32); }
            if (str_equals(name, "i64")) { ret type.get_primitive(sema.types, type.TYPE_I64); }
            if (str_equals(name, "f32")) { ret type.get_primitive(sema.types, type.TYPE_F32); }
            if (str_equals(name, "f64")) { ret type.get_primitive(sema.types, type.TYPE_F64); }
            if (str_equals(name, "ptr")) { ret type.get_primitive(sema.types, type.TYPE_PTR); }
            if (str_equals(name, "va_list")) {
                val va_res: Result[*type.Type, str] = type.make_type(sema.types, type.TYPE_RECORD);
                if (result_is_ok[*type.Type, str](va_res)) {
                    val va_t: *type.Type = result_unwrap_ok[*type.Type, str](va_res);
                    va_t.size = sema.va_list_size;
                    va_t.align = sema.va_list_align;
                    va_t.name = "va_list";
                    ret va_t;
                }
                ret nil;
            }

            # lookup type symbol (local and imports)
            val sym: *symbol.Symbol = lookup_type_symbol(sema, name);
            if (sym != nil) {
                # check for generic instantiation: Type[arg1, arg2, ...]
                val type_args: *ast.Node = node.info.type_name.args;
                if (type_args != nil && type_args.kind == ast.NODE_GENERIC && sym.is_generic) {
                    # instantiate the generic type with concrete args
                    val inst_type: *type.Type = instantiate_generic_type(sema, sym, type_args);
                    if (inst_type != nil) {
                        ret inst_type;
                    }
                }

                # if type is already resolved, return it
                if (sym.resolved_type != nil) {
                    # on-demand field resolution: if a rec/uni has unresolved fields,
                    # resolve them now (handles cross-module ordering issues)
                    if (sym.resolved_type.field_count == 0 && sym.resolved_type.size == 0 &&
                        !sym.is_generic && !sym.is_being_resolved && sym.decl_node != nil) {
                        val dk: ast.NodeKind = sym.decl_node.kind;
                        if (dk == ast.NODE_DECL_REC || dk == ast.NODE_DECL_UNI) {
                            # switch to origin module context for field type resolution
                            val sv_mod: *SemaModule = sema.current_module;
                            val sv_sym: *symbol.Table = sema.symbols;
                            val sv_fp: str = sema.file_path;
                            val sv_src: str = sema.source;

                            if (sym.module_path != nil) {
                                var origin: *SemaModule = sema.modules;
                                for (origin != nil) {
                                    if (origin.path != nil && str_equals(origin.path, sym.module_path)) {
                                        sema.current_module = origin;
                                        sema.symbols = origin.table;
                                        sema.file_path = origin.file_path;
                                        sema.source = origin.source;
                                    }
                                    origin = origin.next;
                                }
                            }

                            sym.is_being_resolved = true;
                            if (dk == ast.NODE_DECL_REC) {
                                resolve_rec_fields_inline(sema, sym);
                            } or {
                                resolve_uni_fields_inline(sema, sym);
                            }
                            sym.is_being_resolved = false;

                            sema.current_module = sv_mod;
                            sema.symbols = sv_sym;
                            sema.file_path = sv_fp;
                            sema.source = sv_src;
                        }
                    }
                    ret sym.resolved_type;
                }
                # try to resolve on-demand from decl_node (for forward references)
                if (sym.decl_node != nil && sym.decl_node.kind == ast.NODE_DECL_DEF) {
                    val inner: *ast.Node = sym.decl_node.info.def_decl.type_node;
                    if (inner != nil) {
                        val t: *type.Type = resolve_type_expr(sema, inner);
                        if (t != nil) {
                            sym.resolved_type = t;
                            sym.decl_node.type = t;
                            ret t;
                        }
                    }
                }
                # for rec/uni, check if decl_node.type is set
                if (sym.decl_node != nil && sym.decl_node.type != nil) {
                    sym.resolved_type = sym.decl_node.type;
                    ret sym.decl_node.type;
                }
            }

            # fallback: manual scope walk to find generic type parameter bindings.
            # this bypasses lookup_type_symbol's Option-based return path which
            # may be affected by codegen issues with generic return values.
            # matches C sema's AST_TYPE_PARAM fallback (sema.c:4979).
            if (sema.symbols != nil && sema.symbols.current != nil) {
                var fb_scope: *symbol.Scope = sema.symbols.current;
                for (fb_scope != nil) {
                    var fb_i: i32 = 0;
                    for (fb_i < fb_scope.symbol_count) {
                        val fb_sym: *symbol.Symbol = ?fb_scope.symbols[fb_i::usize];
                        if (fb_sym.name != nil && str_equals(fb_sym.name, name)) {
                            if (fb_sym.resolved_type != nil) {
                                ret fb_sym.resolved_type;
                            }
                        }
                        fb_i = fb_i + 1;
                    }
                    fb_scope = fb_scope.parent;
                }
            }
            report_error_node(sema, node, "undefined type");
        }
        ret nil;
    }

    # pointer type
    if (node.kind == ast.NODE_TYPE_PTR || node.kind == ast.NODE_TYPE_REF) {
        val elem_type: *type.Type = resolve_type_expr(sema, node.info.type_ptr.inner);
        if (elem_type != nil) {
            val is_mutable: bool = node.kind == ast.NODE_TYPE_PTR;
            val ptr_res: Result[*type.Type, str] = type.make_pointer(sema.types, elem_type, is_mutable);
            if (result_is_ok[*type.Type, str](ptr_res)) {
                ret result_unwrap_ok[*type.Type, str](ptr_res);
            }
        }
        ret nil;
    }

    # array type
    if (node.kind == ast.NODE_TYPE_ARRAY) {
        # element type and size from type_array
        val elem_type: *type.Type = resolve_type_expr(sema, node.info.type_array.elem_type);
        val size_node: *ast.Node = node.info.type_array.size;

        var size: usize = 0;
        if (size_node != nil && size_node.kind == ast.NODE_EXPR_LIT_INT) {
            size = ast.node_get_int_value(size_node)::usize;
        }

        if (elem_type != nil && size > 0) {
            val arr_res: Result[*type.Type, str] = type.make_array(sema.types, elem_type, size);
            if (result_is_ok[*type.Type, str](arr_res)) {
                ret result_unwrap_ok[*type.Type, str](arr_res);
            }
        }
        ret nil;
    }

    # function type expression (NODE_TYPE_FUN uses type_fun variant, not fun_decl)
    if (node.kind == ast.NODE_TYPE_FUN) {
        var ret_type: *type.Type = type.get_primitive(sema.types, type.TYPE_VOID);
        if (node.info.type_fun.ret_type != nil) {
            val rt: *type.Type = resolve_type_expr(sema, node.info.type_fun.ret_type);
            if (rt != nil) {
                ret_type = rt;
            }
        }

        var param_types: **type.Type = nil;
        var param_count: i32 = 0;
        val params: *ast.List = node.info.type_fun.params;
        if (params != nil && params.count > 0) {
            val pt_res: Result[**type.Type, allocator.AllocError] = allocator.allocator_alloc[*type.Type](sema.alloc, params.count::usize);
            if (result_is_ok[**type.Type, allocator.AllocError](pt_res)) {
                param_types = result_unwrap_ok[**type.Type, allocator.AllocError](pt_res);
                param_count = params.count;
                var i: i32 = 0;
                for (i < params.count) {
                    val param: *ast.Node = params.nodes[i];
                    if (param != nil) {
                        val param_type_node: *ast.Node = param.info.field_decl.type_node;
                        val pt: *type.Type = resolve_type_expr(sema, param_type_node);
                        if (pt != nil) {
                            param_types[i] = pt;
                        } or {
                            param_types[i] = type.get_primitive(sema.types, type.TYPE_VOID);
                        }
                    }
                    i = i + 1;
                }
            }
        }

        val fun_res: Result[*type.Type, str] = type.make_function(sema.types, param_types, param_count, ret_type);
        if (param_types != nil) {
            allocator.allocator_free[*type.Type](sema.alloc, param_types, param_count::usize);
        }
        if (result_is_ok[*type.Type, str](fun_res)) {
            ret result_unwrap_ok[*type.Type, str](fun_res);
        }
        ret nil;
    }

    # inline anonymous record type: rec { a: T; b: U; }
    if (node.kind == ast.NODE_TYPE_REC) {
        val rec_fields: *ast.List = node.info.type_decl.fields;
        if (rec_fields != nil && rec_fields.count > 0) {
            val rfields_res: Result[*type.Field, allocator.AllocError] =
                allocator.allocator_alloc[type.Field](sema.alloc, rec_fields.count::usize);
            if (result_is_err[*type.Field, allocator.AllocError](rfields_res)) {
                ret nil;
            }
            val rfields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](rfields_res);
            var rfield_count: i32 = 0;

            var ri: i32 = 0;
            for (ri < rec_fields.count) {
                val rnode: *ast.Node = rec_fields.nodes[ri];
                if (rnode != nil) {
                    val rname: str = rnode.info.field_decl.name;
                    val rtype_node: *ast.Node = rnode.info.field_decl.type_node;
                    var rtype: *type.Type = nil;
                    if (rtype_node != nil) {
                        rtype = resolve_type_expr(sema, rtype_node);
                    }
                    if (rname != nil && rtype != nil) {
                        rfields[rfield_count].name = rname;
                        rfields[rfield_count].type = rtype;
                        rfield_count = rfield_count + 1;
                    }
                }
                ri = ri + 1;
            }

            if (rfield_count > 0) {
                val rec_res: Result[*type.Type, str] = type.make_record(sema.types, nil, rfields, rfield_count);
                if (result_is_ok[*type.Type, str](rec_res)) {
                    val anon_rec: *type.Type = result_unwrap_ok[*type.Type, str](rec_res);

                    compute_record_layout(anon_rec, rfields, rfield_count);

                    ret anon_rec;
                }
            }
        }
        ret nil;
    }

    # inline anonymous union type: uni { ok: T; err: E; }
    if (node.kind == ast.NODE_TYPE_UNI) {
        val variants: *ast.List = node.info.type_decl.fields;
        if (variants != nil && variants.count > 0) {
            val fields_res: Result[*type.Field, allocator.AllocError] =
                allocator.allocator_alloc[type.Field](sema.alloc, variants.count::usize);
            if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
                ret nil;
            }
            val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
            var field_count: i32 = 0;

            var vi: i32 = 0;
            for (vi < variants.count) {
                val vnode: *ast.Node = variants.nodes[vi];
                if (vnode != nil) {
                    val vname: str = vnode.info.field_decl.name;
                    val vtype_node: *ast.Node = vnode.info.field_decl.type_node;
                    var vtype: *type.Type = nil;
                    if (vtype_node != nil) {
                        vtype = resolve_type_expr(sema, vtype_node);
                    }
                    if (vname != nil && vtype != nil) {
                        fields[field_count].name = vname;
                        fields[field_count].type = vtype;
                        fields[field_count].offset = 0;
                        field_count = field_count + 1;
                    }
                }
                vi = vi + 1;
            }

            if (field_count > 0) {
                val uni_res: Result[*type.Type, str] = type.make_union(sema.types, nil, fields, field_count);
                if (result_is_ok[*type.Type, str](uni_res)) {
                    val anon_uni: *type.Type = result_unwrap_ok[*type.Type, str](uni_res);

                    compute_union_layout(anon_uni, fields, field_count);

                    ret anon_uni;
                }
            }
        }
        ret nil;
    }

    ret nil;
}

# resolve_rec_fields_inline: resolve record fields inline during type expression resolution.
# used for on-demand field resolution when a type is referenced before its fields are resolved.
fun resolve_rec_fields_inline(sema: *Sema, sym: *symbol.Symbol) {
    if (sema == nil || sym == nil || sym.decl_node == nil || sym.resolved_type == nil) {
        ret;
    }

    val node: *ast.Node = sym.decl_node;
    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) {
        ret;
    }

    val fields_res: Result[*type.Field, allocator.AllocError] =
        allocator.allocator_alloc[type.Field](sema.alloc, ast_fields.count::usize);
    if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
        ret;
    }
    val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
    var field_count: i32 = 0;

    var fi: i32 = 0;
    for (fi < ast_fields.count) {
        val field_node: *ast.Node = ast_fields.nodes[fi];
        if (field_node != nil) {
            val field_name: str = field_node.info.field_decl.name;
            val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
            var field_type: *type.Type = nil;
            if (field_type_node != nil) {
                field_type = resolve_type_expr(sema, field_type_node);
            }
            if (field_name != nil && field_type != nil) {
                fields[field_count].name = field_name;
                fields[field_count].type = field_type;
                fields[field_count].offset = 0;
                field_count = field_count + 1;
            }
        }
        fi = fi + 1;
    }

    if (field_count > 0) {
        val t: *type.Type = sym.resolved_type;
        t.fields = fields;
        t.field_count = field_count;

        compute_record_layout(t, fields, field_count);
    }
}

# resolve_uni_fields_inline: resolve union fields inline during type expression resolution.
fun resolve_uni_fields_inline(sema: *Sema, sym: *symbol.Symbol) {
    if (sema == nil || sym == nil || sym.decl_node == nil || sym.resolved_type == nil) {
        ret;
    }

    val node: *ast.Node = sym.decl_node;
    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) {
        ret;
    }

    val fields_res: Result[*type.Field, allocator.AllocError] =
        allocator.allocator_alloc[type.Field](sema.alloc, ast_fields.count::usize);
    if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
        ret;
    }
    val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
    var field_count: i32 = 0;

    var fi: i32 = 0;
    for (fi < ast_fields.count) {
        val field_node: *ast.Node = ast_fields.nodes[fi];
        if (field_node != nil) {
            val field_name: str = field_node.info.field_decl.name;
            val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
            var field_type: *type.Type = nil;
            if (field_type_node != nil) {
                field_type = resolve_type_expr(sema, field_type_node);
            }
            if (field_name != nil && field_type != nil) {
                fields[field_count].name = field_name;
                fields[field_count].type = field_type;
                fields[field_count].offset = 0;
                field_count = field_count + 1;
            }
        }
        fi = fi + 1;
    }

    if (field_count > 0) {
        val t: *type.Type = sym.resolved_type;
        t.fields = fields;
        t.field_count = field_count;

        compute_union_layout(t, fields, field_count);
    }
}

# resolve_function_type: resolve a function type.
# ---
# sema: analyzer context
# node: function type or declaration node
# ret:  function type or nil
pub fun resolve_function_type(sema: *Sema, node: *ast.Node) *type.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # bind function's own generic type parameters (e.g., fun ok[T, E](...))
    var pushed_func_scope: bool = false;
    if (node.info.fun_decl.generics != nil) {
        val func_generics: *ast.Node = node.info.fun_decl.generics;
        if (func_generics.kind == ast.NODE_GENERIC) {
            val params_list: *ast.List = func_generics.info.generic_node.args;
            if (params_list != nil && params_list.count > 0) {
                val push_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
                if (result_is_ok[bool, str](push_res)) {
                    pushed_func_scope = true;
                    # bind each type parameter as a type symbol with TYPE_GENERIC_PARAM
                    var i: i32 = 0;
                    for (i < params_list.count) {
                        val param: *ast.Node = params_list.nodes[i];
                        if (param != nil) {
                            val param_name: str = param.info.type_name.path;
                            if (param_name != nil) {
                                val sym_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_name, symbol.SYM_TYPE);
                                if (result_is_ok[*symbol.Symbol, str](sym_res)) {
                                    val tsym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
                                    # create a TYPE_GENERIC_PARAM type for this parameter
                                    val gp_res: Result[*type.Type, str] = type.make_generic_param(sema.types, param_name);
                                    if (result_is_ok[*type.Type, str](gp_res)) {
                                        tsym.resolved_type = result_unwrap_ok[*type.Type, str](gp_res);
                                    }
                                }
                            }
                        }
                        i = i + 1;
                    }
                }
            }
        }
    }

    # get return type
    var ret_type: *type.Type = type.get_primitive(sema.types, type.TYPE_VOID);
    if (node.info.fun_decl.ret_type != nil) {
        val rt: *type.Type = resolve_type_expr(sema, node.info.fun_decl.ret_type);
        if (rt != nil) {
            ret_type = rt;
        }
    }

    # get parameter types
    var param_types: **type.Type = nil;
    var param_count: i32 = 0;

    val params: *ast.List = node.info.fun_decl.params;
    if (params != nil && params.count > 0) {
        val pt_res: Result[**type.Type, allocator.AllocError] = allocator.allocator_alloc[*type.Type](sema.alloc, params.count::usize);
        if (result_is_ok[**type.Type, allocator.AllocError](pt_res)) {
            param_types = result_unwrap_ok[**type.Type, allocator.AllocError](pt_res);
            param_count = params.count;

            var i: i32 = 0;
            for (i < params.count) {
                val param: *ast.Node = params.nodes[i];
                if (param != nil) {
                    # param is NODE_PARAM: type annotation is in field_decl.type_node
                    val param_type_node: *ast.Node = param.info.field_decl.type_node;
                    val pt: *type.Type = resolve_type_expr(sema, param_type_node);
                    if (pt != nil) {
                        param_types[i] = pt;
                        param.type = pt;  # set type on param node for lowering
                    } or {
                        param_types[i] = type.get_primitive(sema.types, type.TYPE_VOID);
                    }
                }
                i = i + 1;
            }
        }
    }

    # pop the function type parameter scope if we pushed one
    if (pushed_func_scope) {
        symbol.table_pop_scope(sema.symbols);
    }

    # create function type
    val fun_res: Result[*type.Type, str] = type.make_function(sema.types, param_types, param_count, ret_type);
    if (param_types != nil) {
        allocator.allocator_free[*type.Type](sema.alloc, param_types, param_count::usize);
    }

    if (result_is_ok[*type.Type, str](fun_res)) {
        ret result_unwrap_ok[*type.Type, str](fun_res);
    }
    ret nil;
}

# resolve_generic_call_return_type: resolve the return type of a generic function call.
# ---
# sema:      analyzer context
# func_sym:  the generic function's symbol
# type_args: the call's type arguments node
# ret:       resolved concrete return type or nil
fun resolve_generic_call_return_type(sema: *Sema, func_sym: *symbol.Symbol, type_args: *ast.Node) *type.Type {
    if (sema == nil || func_sym == nil || type_args == nil) {
        ret nil;
    }

    val func_decl: *ast.Node = func_sym.decl_node;
    if (func_decl == nil) {
        ret nil;
    }

    # get formal generic params from function declaration
    val generic_params: *ast.Node = func_decl.info.fun_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    # generic params should have a list of param nodes in children
    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    # type args should be a NODE_GENERIC or similar with args list
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    # first resolve the type args in the current scope BEFORE pushing
    if (args_list.count > 8) {
        report_error_node(sema, type_args, "too many generic type arguments (maximum 8)");
        ret nil;
    }
    var resolved_args: [8]*type.Type;  # max 8 type args
    var valid_count: i32 = 0;
    var j: i32 = 0;
    for (j < params_list.count && j < 8) {
        val arg: *ast.Node = args_list.nodes[j];
        if (arg != nil) {
            resolved_args[j] = resolve_type_expr(sema, arg);
            if (resolved_args[j] != nil) {
                valid_count = valid_count + 1;
            }
        }
        j = j + 1;
    }

    # switch to the origin module so that type names in the return type annotation
    # resolve in the correct module context (e.g. AllocError in std.allocator)
    val saved_mod: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    if (func_sym.module_path != nil) {
        var origin_mod: *SemaModule = sema.modules;
        for (origin_mod != nil) {
            if (origin_mod.path != nil && str_equals(origin_mod.path, func_sym.module_path)) {
                sema.current_module = origin_mod;
                if (origin_mod.table != nil) {
                    sema.symbols = origin_mod.table;
                }
            }
            origin_mod = origin_mod.next;
        }
    }

    # push a new scope for the generic bindings
    val push_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
    if (result_is_err[bool, str](push_res)) {
        sema.symbols = saved_symbols;
        sema.current_module = saved_mod;
        ret nil;
    }

    # bind each generic param to its resolved type arg
    var i: i32 = 0;
    for (i < params_list.count && i < 8) {
        val param: *ast.Node = params_list.nodes[i];

        if (param != nil && resolved_args[i] != nil) {
            val param_name: str = param.info.type_name.path;
            if (param_name != nil) {
                # create a symbol for this binding in the new scope
                val bind_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_name, symbol.SYM_TYPE);
                if (result_is_ok[*symbol.Symbol, str](bind_res)) {
                    val bind_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](bind_res);
                    bind_sym.resolved_type = resolved_args[i];
                }
            }
        }
        i = i + 1;
    }

    # resolve the return type node with the bindings in scope
    val ret_type: *type.Type = resolve_type_expr(sema, func_decl.info.fun_decl.ret_type);

    # pop the binding scope
    symbol.table_pop_scope(sema.symbols);

    # restore caller module context
    sema.symbols = saved_symbols;
    sema.current_module = saved_mod;

    ret ret_type;
}

# instantiate_generic_function: create a specialized version of a generic free function
# for a concrete set of type arguments from the call site.
# ---
# sema:      analyzer context
# func_sym:  the generic function's symbol (e.g., ok, err)
# type_args: the call's type arguments node
# ret:       mangled name of the instantiation, or nil on failure
# Module context swap: this function temporarily switches sema.current_module
# and sema.symbols to the origin module (where the generic was defined) so that
# type annotations resolve in the correct scope. Both fields are saved before
# the swap and restored on ALL exit paths (normal return, early error return).
pub fun instantiate_generic_function(sema: *Sema, func_sym: *symbol.Symbol, type_args: *ast.Node) str {
    if (sema == nil || func_sym == nil || type_args == nil) {
        ret nil;
    }

    val func_decl: *ast.Node = func_sym.decl_node;
    if (func_decl == nil) {
        ret nil;
    }

    # get formal generic params from function declaration
    val generic_params: *ast.Node = func_decl.info.fun_decl.generics;
    if (generic_params == nil) {
        ret nil;
    }

    val params_list: *ast.List = generic_params.info.generic_node.args;
    if (params_list == nil || params_list.count == 0) {
        ret nil;
    }

    # resolve type args
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count != params_list.count) {
        ret nil;
    }

    if (args_list.count > 8) {
        report_error_node(sema, type_args, "too many generic type arguments (maximum 8)");
        ret nil;
    }
    var resolved_args: [8]*type.Type;
    var ri: i32 = 0;
    for (ri < args_list.count && ri < 8) {
        val arg: *ast.Node = args_list.nodes[ri];
        if (arg != nil) {
            resolved_args[ri] = resolve_type_expr(sema, arg);
        }
        ri = ri + 1;
    }

    # bail out when any type arg is still a generic parameter — the instantiation
    # will be created later by instantiate_nested_generic_calls when the parent
    # generic function is instantiated with concrete types.
    var gi: i32 = 0;
    for (gi < args_list.count && gi < 8) {
        if (resolved_args[gi] != nil && resolved_args[gi].kind == type.TYPE_GENERIC_PARAM) {
            ret nil;
        }
        gi = gi + 1;
    }

    # generate mangled name: "funcName" + "I" + mangle(type_args) + "E"
    var mangled_buf: [512]u8;
    var pos: i32 = 0;

    val base_name: str = func_sym.name;
    if (base_name == nil) {
        ret nil;
    }
    val base_len: usize = str_len(base_name);
    var ci: usize = 0;
    # need room for this char + I + E + null (4 bytes); stop before overflow
    for (ci < base_len && pos + 4 <= 512) {
        mangled_buf[pos::usize] = base_name[ci];
        pos = pos + 1;
        ci = ci + 1;
    }
    if (ci < base_len) { ret nil; }  # base name too long — overflow

    # write "I" — need room for I + E + null (3 bytes)
    if (pos + 3 > 512) { ret nil; }
    mangled_buf[pos::usize] = 'I';
    pos = pos + 1;

    # write each type arg's mangled form
    # reserve 2 bytes at all times for the trailing E and null
    var ai: i32 = 0;
    for (ai < args_list.count) {
        val arg_ty: *type.Type = resolved_args[ai];
        if (arg_ty != nil) {
            if (pos + 2 >= 512) { ret nil; }
            val remaining: i32 = 510 - pos;  # cap leaving 2 bytes for E + null
            val mangle_written: i32 = type_mangle(arg_ty, ?mangled_buf[pos::usize], remaining::usize);
            pos = pos + mangle_written;
            if (pos + 2 > 512) { ret nil; }
        }
        ai = ai + 1;
    }

    # write "E" and null terminator — need 2 bytes
    if (pos + 2 > 512) { ret nil; }
    mangled_buf[pos::usize] = 'E';
    pos = pos + 1;
    mangled_buf[pos::usize] = 0;

    val mangled_name: str = (?mangled_buf[0])::str;

    # check if this instantiation already exists (O(1) hash lookup)
    val existing_name: str = inst_map_get(?sema.func_inst_map, mangled_name);
    if (existing_name != nil) {
        # ensure the symbol is also visible in the caller's root scope
        # so resolve_call can attach node.symbol
        val cur_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, existing_name);
        if (!option_is_some[*symbol.Symbol](cur_opt)) {
            # find the original symbol's resolved_type from the origin module
            var existing_rt: *type.Type = nil;
            if (func_sym.module_path != nil) {
                var omod: *SemaModule = sema.modules;
                for (omod != nil) {
                    if (omod.path != nil && str_equals(omod.path, func_sym.module_path) && omod.table != nil) {
                        val oopt: Option[*symbol.Symbol] = symbol.table_lookup(omod.table, existing_name);
                        if (option_is_some[*symbol.Symbol](oopt)) {
                            existing_rt = option_unwrap[*symbol.Symbol](oopt).resolved_type;
                        }
                    }
                    omod = omod.next;
                }
            }
            val sc: *symbol.Scope = sema.symbols.current;
            sema.symbols.current = sema.symbols.root;
            val alias_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, existing_name, symbol.SYM_FUN);
            if (result_is_ok[*symbol.Symbol, str](alias_res)) {
                val alias_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](alias_res);
                alias_sym.module_path = func_sym.module_path;
                alias_sym.is_public = func_sym.is_public;
                alias_sym.decl_node = func_sym.decl_node;
                alias_sym.resolved_type = existing_rt;
            }
            sema.symbols.current = sc;
        }
        ret existing_name;
    }

    # get generic param names
    var param_names: *str = nil;
    val param_count: i32 = params_list.count;
    val names_res: Result[*str, allocator.AllocError] = allocator.allocator_alloc[str](sema.alloc, param_count::usize);
    if (result_is_ok[*str, allocator.AllocError](names_res)) {
        param_names = result_unwrap_ok[*str, allocator.AllocError](names_res);
        var ni: i32 = 0;
        for (ni < param_count) {
            val pnode: *ast.Node = params_list.nodes[ni];
            if (pnode != nil) {
                param_names[ni] = pnode.info.type_name.path;
            }
            ni = ni + 1;
        }
    }

    # switch to origin module so that names in the function's type annotations
    # resolve in the correct module context
    val saved_mod: *SemaModule = sema.current_module;
    val saved_symbols: *symbol.Table = sema.symbols;
    var origin_table: *symbol.Table = sema.symbols;
    if (func_sym.module_path != nil) {
        var origin_mod: *SemaModule = sema.modules;
        for (origin_mod != nil) {
            if (origin_mod.path != nil && str_equals(origin_mod.path, func_sym.module_path)) {
                sema.current_module = origin_mod;
                if (origin_mod.table != nil) {
                    sema.symbols = origin_mod.table;
                    origin_table = origin_mod.table;
                }
            }
            origin_mod = origin_mod.next;
        }
    }

    # resolve the concrete function type with type bindings
    val push_res: Result[bool, str] = symbol.table_push_scope(sema.symbols);
    if (result_is_err[bool, str](push_res)) {
        sema.symbols = saved_symbols;
        sema.current_module = saved_mod;
        ret nil;
    }

    var bi: i32 = 0;
    for (bi < param_count && bi < 8) {
        if (param_names != nil && param_names[bi] != nil && resolved_args[bi] != nil) {
            val bind_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_names[bi], symbol.SYM_TYPE);
            if (result_is_ok[*symbol.Symbol, str](bind_res)) {
                val bind_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](bind_res);
                bind_sym.resolved_type = resolved_args[bi];
            }
        }
        bi = bi + 1;
    }

    # resolve return type
    var concrete_ret_type: *type.Type = nil;
    if (func_decl.info.fun_decl.ret_type != nil) {
        concrete_ret_type = resolve_type_expr(sema, func_decl.info.fun_decl.ret_type);
    }

    # resolve parameter types
    val func_params: *ast.List = func_decl.info.fun_decl.params;
    var concrete_param_count: i32 = 0;
    var concrete_param_types: [16]*type.Type;
    if (func_params != nil) {
        var pi: i32 = 0;
        for (pi < func_params.count && pi < 16) {
            val param: *ast.Node = func_params.nodes[pi];
            if (param != nil) {
                val param_type_node: *ast.Node = param.info.field_decl.type_node;
                if (param_type_node != nil) {
                    concrete_param_types[concrete_param_count] = resolve_type_expr(sema, param_type_node);
                } or {
                    concrete_param_types[concrete_param_count] = nil;
                }
                concrete_param_count = concrete_param_count + 1;
            }
            pi = pi + 1;
        }
    }

    # clone the function AST for this instantiation so each instantiation
    # gets its own nodes with concrete types (not shared TYPE_GENERIC_PARAM)
    val clone_res: Result[*ast.Node, str] = ast.clone_node(sema.alloc, func_decl);
    if (result_is_err[*ast.Node, str](clone_res)) {
        symbol.table_pop_scope(sema.symbols);
        sema.symbols = saved_symbols;
        sema.current_module = saved_mod;
        ret nil;
    }
    val cloned_func: *ast.Node = result_unwrap_ok[*ast.Node, str](clone_res);

    # walk CLONED body for nested generic calls (sets symbols on clone, not shared AST)
    if (cloned_func.info.fun_decl.body != nil) {
        instantiate_nested_generic_calls(sema, cloned_func.info.fun_decl.body);
    }

    # walk CLONED body to set concrete types on all nodes
    substitute_types_in_body(sema, cloned_func);

    symbol.table_pop_scope(sema.symbols);

    # restore caller module context
    sema.symbols = saved_symbols;
    sema.current_module = saved_mod;

    # create the instantiated function type
    val ftype_res: Result[*type.Type, str] = type.make_function(sema.types,
        ?concrete_param_types[0], concrete_param_count, concrete_ret_type);

    var inst_func_type: *type.Type = nil;
    if (result_is_ok[*type.Type, str](ftype_res)) {
        inst_func_type = result_unwrap_ok[*type.Type, str](ftype_res);
    }

    # allocate persistent copy of mangled name
    val name_len: usize = str_len(mangled_name);
    val name_alloc_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, name_len + 1);
    if (result_is_err[*u8, allocator.AllocError](name_alloc_res)) {
        ret nil;
    }
    val persistent_name: *u8 = result_unwrap_ok[*u8, allocator.AllocError](name_alloc_res);
    var pni: usize = 0;
    for (pni < name_len) {
        persistent_name[pni] = mangled_name[pni];
        pni = pni + 1;
    }
    persistent_name[name_len] = 0;
    val pname: str = persistent_name::str;

    # allocate persistent copy of param_types array
    var persistent_param_types: **type.Type = nil;
    if (param_count > 0) {
        val pt_res: Result[**type.Type, allocator.AllocError] = allocator.allocator_alloc[*type.Type](sema.alloc, param_count::usize);
        if (result_is_ok[**type.Type, allocator.AllocError](pt_res)) {
            persistent_param_types = result_unwrap_ok[**type.Type, allocator.AllocError](pt_res);
            var pti: i32 = 0;
            for (pti < param_count && pti < 8) {
                persistent_param_types[pti] = resolved_args[pti];
                pti = pti + 1;
            }
        }
    }

    # create FunctionInstantiation record
    val inst_res: Result[*FunctionInstantiation, allocator.AllocError] = allocator.allocator_zalloc[FunctionInstantiation](sema.alloc, 1);
    if (result_is_err[*FunctionInstantiation, allocator.AllocError](inst_res)) {
        ret nil;
    }

    val finst: *FunctionInstantiation = result_unwrap_ok[*FunctionInstantiation, allocator.AllocError](inst_res);
    finst.func_ast = cloned_func;
    finst.mangled_name = pname;
    finst.func_type = inst_func_type;
    finst.param_names = param_names;
    finst.param_types = persistent_param_types;
    finst.param_count = param_count;
    finst.origin_module = sema.current_module;
    finst.next = sema.func_insts;
    sema.func_insts = finst;
    sema.func_inst_count = sema.func_inst_count + 1;
    inst_map_put(?sema.func_inst_map, sema.alloc, pname, pname);

    # create a symbol for the instantiated function in the ORIGIN module's ROOT scope
    # (not the current scope, which may be a temporary scope that gets popped)
    val saved_current: *symbol.Scope = origin_table.current;
    origin_table.current = origin_table.root;
    val inst_sym_res: Result[*symbol.Symbol, str] = symbol.table_define(origin_table, pname, symbol.SYM_FUN);
    if (result_is_ok[*symbol.Symbol, str](inst_sym_res)) {
        val inst_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](inst_sym_res);
        inst_sym.resolved_type = inst_func_type;
        inst_sym.decl_node = finst.func_ast;
        inst_sym.module_path = func_sym.module_path;
        inst_sym.is_public = func_sym.is_public;
    }
    origin_table.current = saved_current;

    # also register in the caller's root scope so resolve_call can attach node.symbol
    if (saved_symbols != origin_table) {
        val saved_caller_current: *symbol.Scope = saved_symbols.current;
        saved_symbols.current = saved_symbols.root;
        val caller_sym_res: Result[*symbol.Symbol, str] = symbol.table_define(saved_symbols, pname, symbol.SYM_FUN);
        if (result_is_ok[*symbol.Symbol, str](caller_sym_res)) {
            val caller_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](caller_sym_res);
            caller_sym.resolved_type = inst_func_type;
            caller_sym.decl_node = finst.func_ast;
            caller_sym.module_path = func_sym.module_path;
            caller_sym.is_public = func_sym.is_public;
        }
        saved_symbols.current = saved_caller_current;
    }

    ret pname;
}

# instantiate_nested_generic_calls: walk a function body AST to find generic
# free function calls (e.g., ok[*T, E](...)) and create FunctionInstantiation
# records for them. Called during generic function instantiation while type
# bindings are active so that type params resolve to concrete types.
fun instantiate_nested_generic_calls(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind == ast.NODE_EXPR_CALL) {
        val call_ta: *ast.Node = node.info.call_expr.type_args;
        if (call_ta != nil) {
            val callee: *ast.Node = node.info.call_expr.callee;
            if (callee != nil && callee.kind == ast.NODE_EXPR_IDENT) {
                val fname: str = callee.info.ident_expr.name;
                if (fname != nil) {
                    var fsym: *symbol.Symbol = nil;
                    val fopt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, fname);
                    if (option_is_some[*symbol.Symbol](fopt)) {
                        fsym = option_unwrap[*symbol.Symbol](fopt);
                    } or {
                        fsym = lookup_function_symbol(sema, fname);
                    }
                    if (fsym != nil && fsym.decl_node != nil &&
                        fsym.decl_node.info.fun_decl.generics != nil) {
                        val nested_inst_name: str = instantiate_generic_function(sema, fsym, call_ta);
                        if (nested_inst_name != nil) {
                            val nested_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, nested_inst_name);
                            if (option_is_some[*symbol.Symbol](nested_opt)) {
                                node.symbol = option_unwrap[*symbol.Symbol](nested_opt)::ptr;
                            }
                        }
                    }
                }
            }

            # module-qualified generic calls inside generic function bodies
            if (callee != nil && callee.kind == ast.NODE_EXPR_FIELD) {
                val mq_base: *ast.Node = callee.info.field_expr.object;
                if (mq_base != nil && mq_base.kind == ast.NODE_EXPR_IDENT) {
                    val mq_sym: *symbol.Symbol = lookup_module_function(sema, mq_base.info.ident_expr.name, callee.info.field_expr.field);
                    if (mq_sym != nil && mq_sym.decl_node != nil &&
                        mq_sym.decl_node.info.fun_decl.generics != nil) {
                        val nested_inst_name: str = instantiate_generic_function(sema, mq_sym, call_ta);
                        if (nested_inst_name != nil) {
                            val nested_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, nested_inst_name);
                            if (option_is_some[*symbol.Symbol](nested_opt)) {
                                node.symbol = option_unwrap[*symbol.Symbol](nested_opt)::ptr;
                            }
                        }
                    }
                }
            }
        }
        val ca: *ast.List = node.info.call_expr.args;
        if (ca != nil) {
            var i: i32 = 0;
            for (i < ca.count) {
                instantiate_nested_generic_calls(sema, ca.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_BLOCK) {
        val sl: *ast.List = node.info.block_stmt.stmts;
        if (sl != nil) {
            var i: i32 = 0;
            for (i < sl.count) {
                instantiate_nested_generic_calls(sema, sl.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_EXPR || node.kind == ast.NODE_STMT_RET ||
        node.kind == ast.NODE_DECL_PUB || node.kind == ast.NODE_EXPR_PAREN) {
        instantiate_nested_generic_calls(sema, node.info.wrapper.inner);
        ret;
    }

    if (node.kind == ast.NODE_STMT_IF || node.kind == ast.NODE_STMT_OR) {
        instantiate_nested_generic_calls(sema, node.info.cond_stmt.cond);
        instantiate_nested_generic_calls(sema, node.info.cond_stmt.body);
        instantiate_nested_generic_calls(sema, node.info.cond_stmt.or_branch);
        ret;
    }

    if (node.kind == ast.NODE_DECL_VAL || node.kind == ast.NODE_DECL_VAR) {
        instantiate_nested_generic_calls(sema, node.info.var_decl.init);
        ret;
    }

    if (node.kind == ast.NODE_STMT_FOR) {
        instantiate_nested_generic_calls(sema, node.info.for_stmt.cond);
        instantiate_nested_generic_calls(sema, node.info.for_stmt.body);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_BINARY) {
        instantiate_nested_generic_calls(sema, node.info.binary_expr.left);
        instantiate_nested_generic_calls(sema, node.info.binary_expr.right);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_UNARY || node.kind == ast.NODE_EXPR_ADDR ||
        node.kind == ast.NODE_EXPR_DEREF) {
        instantiate_nested_generic_calls(sema, node.info.unary_expr.expr);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_FIELD) {
        instantiate_nested_generic_calls(sema, node.info.field_expr.object);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_INDEX) {
        instantiate_nested_generic_calls(sema, node.info.index_expr.base);
        instantiate_nested_generic_calls(sema, node.info.index_expr.index);
        ret;
    }

    if (node.kind == ast.NODE_EXPR_CAST) {
        instantiate_nested_generic_calls(sema, node.info.cast_expr.expr);
        ret;
    }
}

# resolve_concrete_type: resolve a type that may contain TYPE_GENERIC_PARAM references
# using the active scope bindings.
# ---
# sema: analyzer context (must have type bindings in scope)
# t:    type to resolve
# ret:  concrete type with generic params substituted, or t unchanged
fun resolve_concrete_type(sema: *Sema, t: *type.Type) *type.Type {
    if (sema == nil || t == nil) {
        ret nil;
    }

    # direct generic param: look up binding in scope
    if (t.kind == type.TYPE_GENERIC_PARAM) {
        if (t.name != nil) {
            val opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, t.name);
            if (option_is_some[*symbol.Symbol](opt)) {
                val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](opt);
                if (sym.resolved_type != nil) {
                    ret sym.resolved_type;
                }
            }
        }
        ret t;
    }

    # pointer to possibly-generic inner type
    if (t.kind == type.TYPE_POINTER) {
        val resolved_inner: *type.Type = resolve_concrete_type(sema, t.inner);
        if (resolved_inner != t.inner && resolved_inner != nil) {
            val ptr_res: Result[*type.Type, str] = type.make_pointer(sema.types, resolved_inner, t.is_mutable);
            if (result_is_ok[*type.Type, str](ptr_res)) {
                ret result_unwrap_ok[*type.Type, str](ptr_res);
            }
        }
        ret t;
    }

    # array of possibly-generic element type
    if (t.kind == type.TYPE_ARRAY) {
        val resolved_inner: *type.Type = resolve_concrete_type(sema, t.inner);
        if (resolved_inner != t.inner && resolved_inner != nil) {
            val arr_res: Result[*type.Type, str] = type.make_array(sema.types, resolved_inner, t.array_len);
            if (result_is_ok[*type.Type, str](arr_res)) {
                ret result_unwrap_ok[*type.Type, str](arr_res);
            }
        }
        ret t;
    }

    # function type with possibly-generic param/return types
    if (t.kind == type.TYPE_FUN) {
        var any_changed: bool = false;
        var resolved_params: [16]*type.Type;
        var pi: i32 = 0;
        for (pi < t.param_count && pi < 16) {
            resolved_params[pi] = resolve_concrete_type(sema, t.params[pi]);
            if (resolved_params[pi] != t.params[pi]) {
                any_changed = true;
            }
            pi = pi + 1;
        }
        val resolved_ret: *type.Type = resolve_concrete_type(sema, t.ret_type);
        if (resolved_ret != t.ret_type) {
            any_changed = true;
        }
        if (any_changed) {
            # allocate persistent param array
            var new_params: **type.Type = nil;
            if (t.param_count > 0) {
                val pp_res: Result[**type.Type, allocator.AllocError] = allocator.allocator_alloc[*type.Type](sema.alloc, t.param_count::usize);
                if (result_is_ok[**type.Type, allocator.AllocError](pp_res)) {
                    new_params = result_unwrap_ok[**type.Type, allocator.AllocError](pp_res);
                    var ci: i32 = 0;
                    for (ci < t.param_count && ci < 16) {
                        new_params[ci] = resolved_params[ci];
                        ci = ci + 1;
                    }
                }
            }
            val fun_res: Result[*type.Type, str] = type.make_function(sema.types, new_params, t.param_count, resolved_ret);
            if (result_is_ok[*type.Type, str](fun_res)) {
                ret result_unwrap_ok[*type.Type, str](fun_res);
            }
        }
        ret t;
    }

    # generic record/union instantiation with possibly-generic args
    if ((t.kind == type.TYPE_RECORD || t.kind == type.TYPE_UNION) &&
        t.base_generic != nil && t.generic_arg_count > 0) {
        if (t.generic_arg_count > 8) {
            sema.had_error = true;
            ret t;
        }
        var any_changed: bool = false;
        var resolved_args: [8]*type.Type;
        var ai: i32 = 0;
        for (ai < t.generic_arg_count && ai < 8) {
            resolved_args[ai] = resolve_concrete_type(sema, t.generic_args[ai]);
            if (resolved_args[ai] != t.generic_args[ai]) {
                any_changed = true;
            }
            ai = ai + 1;
        }
        if (any_changed) {
            # search cached instantiations for a match
            var cached: *CachedInstantiation = sema.generic_cache;
            for (cached != nil) {
                if (cached.arg_count == t.generic_arg_count && cached.result_type != nil &&
                    cached.result_type.base_generic == t.base_generic) {
                    var match: bool = true;
                    var ci: i32 = 0;
                    for (ci < cached.arg_count && ci < 8) {
                        if (cached.generic_args[ci] != resolved_args[ci]) {
                            match = false;
                        }
                        ci = ci + 1;
                    }
                    if (match) {
                        ret cached.result_type;
                    }
                }
                cached = cached.next;
            }
        }
        ret t;
    }

    ret t;
}

# substitute_types_in_body: walk a cloned AST and set concrete types on all nodes.
# ---
# sema: analyzer context (must have type bindings in scope)
# node: cloned AST node to substitute types in
#
# for nodes with type_node children, re-resolves the full type expression.
# for all other nodes, performs direct TYPE_GENERIC_PARAM substitution.
fun substitute_types_in_body(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # resolve this node's type (substitutes TYPE_GENERIC_PARAM → concrete)
    node.type = resolve_concrete_type(sema, node.type);

    val k: ast.NodeKind = node.kind;

    # recurse into children by kind

    if (k == ast.NODE_DECL_VAL || k == ast.NODE_DECL_VAR) {
        substitute_types_in_body(sema, node.info.var_decl.type_node);
        substitute_types_in_body(sema, node.info.var_decl.init);
        ret;
    }

    if (k == ast.NODE_PARAM || k == ast.NODE_FIELD) {
        substitute_types_in_body(sema, node.info.field_decl.type_node);
        ret;
    }

    if (k == ast.NODE_EXPR_CAST) {
        substitute_types_in_body(sema, node.info.cast_expr.expr);
        substitute_types_in_body(sema, node.info.cast_expr.type_node);
        ret;
    }

    if (k == ast.NODE_EXPR_ARRAY_LIT) {
        substitute_types_in_body(sema, node.info.array_lit.size);
        substitute_types_in_body(sema, node.info.array_lit.type_node);
        val elems: *ast.List = node.info.array_lit.elements;
        if (elems != nil) {
            var i: i32 = 0;
            for (i < elems.count) {
                substitute_types_in_body(sema, elems.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (k == ast.NODE_EXPR_STRUCT_LIT) {
        substitute_types_in_body(sema, node.info.struct_lit.type_node);
        val fields: *ast.List = node.info.struct_lit.fields;
        if (fields != nil) {
            var i: i32 = 0;
            for (i < fields.count) {
                substitute_types_in_body(sema, fields.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (k == ast.NODE_PROGRAM || k == ast.NODE_STMT_LIST || k == ast.NODE_STMT_BLOCK) {
        val sl: *ast.List = node.info.block_stmt.stmts;
        if (sl != nil) {
            var i: i32 = 0;
            for (i < sl.count) {
                substitute_types_in_body(sema, sl.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    if (k == ast.NODE_DECL_PUB || k == ast.NODE_STMT_EXPR || k == ast.NODE_STMT_RET ||
        k == ast.NODE_EXPR_PAREN || k == ast.NODE_COMPTIME || k == ast.NODE_STMT_FIN) {
        substitute_types_in_body(sema, node.info.wrapper.inner);
        ret;
    }

    if (k == ast.NODE_DECL_EXT) {
        substitute_types_in_body(sema, node.info.ext_decl.inner);
        ret;
    }

    if (k == ast.NODE_DECL_DEF) {
        substitute_types_in_body(sema, node.info.def_decl.type_node);
        substitute_types_in_body(sema, node.info.def_decl.generics);
        ret;
    }

    if (k == ast.NODE_DECL_FUN) {
        val params: *ast.List = node.info.fun_decl.params;
        if (params != nil) {
            var i: i32 = 0;
            for (i < params.count) {
                substitute_types_in_body(sema, params.nodes[i]);
                i = i + 1;
            }
        }
        substitute_types_in_body(sema, node.info.fun_decl.body);
        substitute_types_in_body(sema, node.info.fun_decl.generics);
        substitute_types_in_body(sema, node.info.fun_decl.ret_type);
        ret;
    }

    if (k == ast.NODE_DECL_TEST) {
        substitute_types_in_body(sema, node.info.test_decl.body);
        ret;
    }

    if (k == ast.NODE_DECL_REC || k == ast.NODE_DECL_UNI ||
        k == ast.NODE_TYPE_REC || k == ast.NODE_TYPE_UNI) {
        val fields: *ast.List = node.info.type_decl.fields;
        if (fields != nil) {
            var i: i32 = 0;
            for (i < fields.count) {
                substitute_types_in_body(sema, fields.nodes[i]);
                i = i + 1;
            }
        }
        substitute_types_in_body(sema, node.info.type_decl.generics);
        ret;
    }

    if (k == ast.NODE_STMT_IF || k == ast.NODE_STMT_OR || k == ast.NODE_COMPTIME_IF ||
        k == ast.NODE_COMPTIME_OR || k == ast.NODE_OR_BRANCH) {
        substitute_types_in_body(sema, node.info.cond_stmt.cond);
        substitute_types_in_body(sema, node.info.cond_stmt.body);
        substitute_types_in_body(sema, node.info.cond_stmt.or_branch);
        ret;
    }

    if (k == ast.NODE_STMT_FOR) {
        substitute_types_in_body(sema, node.info.for_stmt.cond);
        substitute_types_in_body(sema, node.info.for_stmt.body);
        ret;
    }

    if (k == ast.NODE_EXPR_BINARY) {
        substitute_types_in_body(sema, node.info.binary_expr.left);
        substitute_types_in_body(sema, node.info.binary_expr.right);
        ret;
    }

    if (k == ast.NODE_EXPR_UNARY || k == ast.NODE_EXPR_ADDR || k == ast.NODE_EXPR_DEREF) {
        substitute_types_in_body(sema, node.info.unary_expr.expr);
        ret;
    }

    if (k == ast.NODE_EXPR_CALL) {
        # evaluate deferred comptime intrinsics ($size_of/$align_of) now that
        # generic type parameters are bound to concrete types
        val ct_callee: *ast.Node = node.info.call_expr.callee;
        if (ct_callee != nil && ct_callee.kind == ast.NODE_COMPTIME) {
            val ct_inner: *ast.Node = ct_callee.info.wrapper.inner;
            if (ct_inner != nil && ct_inner.kind == ast.NODE_EXPR_IDENT) {
                val ct_name: str = ct_inner.info.ident_expr.name;
                if (ct_name != nil) {
                    if (str_equals(ct_name, "size_of") || str_equals(ct_name, "align_of")) {
                        # recurse into args first so type substitution happens
                        val ct_args: *ast.List = node.info.call_expr.args;
                        if (ct_args != nil) {
                            var ci: i32 = 0;
                            for (ci < ct_args.count) {
                                substitute_types_in_body(sema, ct_args.nodes[ci]);
                                ci = ci + 1;
                            }
                        }
                        resolve_comptime_size_align(sema, node, ct_name);
                        ret;
                    }
                }
            }
        }
        substitute_types_in_body(sema, node.info.call_expr.callee);
        val args: *ast.List = node.info.call_expr.args;
        if (args != nil) {
            var i: i32 = 0;
            for (i < args.count) {
                substitute_types_in_body(sema, args.nodes[i]);
                i = i + 1;
            }
        }
        substitute_types_in_body(sema, node.info.call_expr.type_args);
        ret;
    }

    if (k == ast.NODE_EXPR_INDEX) {
        substitute_types_in_body(sema, node.info.index_expr.base);
        substitute_types_in_body(sema, node.info.index_expr.index);
        ret;
    }

    if (k == ast.NODE_EXPR_FIELD) {
        substitute_types_in_body(sema, node.info.field_expr.object);
        ret;
    }

    if (k == ast.NODE_TYPE_NAME) {
        substitute_types_in_body(sema, node.info.type_name.args);
        ret;
    }

    if (k == ast.NODE_TYPE_PTR || k == ast.NODE_TYPE_REF) {
        substitute_types_in_body(sema, node.info.type_ptr.inner);
        ret;
    }

    if (k == ast.NODE_TYPE_ARRAY) {
        substitute_types_in_body(sema, node.info.type_array.elem_type);
        substitute_types_in_body(sema, node.info.type_array.size);
        ret;
    }

    if (k == ast.NODE_TYPE_FUN) {
        val params: *ast.List = node.info.type_fun.params;
        if (params != nil) {
            var i: i32 = 0;
            for (i < params.count) {
                substitute_types_in_body(sema, params.nodes[i]);
                i = i + 1;
            }
        }
        substitute_types_in_body(sema, node.info.type_fun.ret_type);
        ret;
    }

    if (k == ast.NODE_GENERIC) {
        val args: *ast.List = node.info.generic_node.args;
        if (args != nil) {
            var i: i32 = 0;
            for (i < args.count) {
                substitute_types_in_body(sema, args.nodes[i]);
                i = i + 1;
            }
        }
        ret;
    }

    # leaf nodes: NODE_DECL_USE, NODE_STMT_BRK, NODE_STMT_CNT, NODE_STMT_MASM,
    # NODE_VARIADIC, NODE_EXPR_IDENT, NODE_EXPR_LIT_*: no children to recurse
}

# resolve_int_suffix: extract type from integer literal suffix (e.g., "42u8" -> TYPE_U8).
# returns nil if no suffix is present.
fun resolve_int_suffix(sema: *Sema, text: str) *type.Type {
    if (text == nil) { ret nil; }
    val len: usize = str_len(text);
    if (len < 3) { ret nil; }

    # find suffix start: scan backwards for 'u' or 'i' (not hex-ambiguous)
    var si: usize = len - 1;
    for (si > 0 && text[si] >= '0' && text[si] <= '9') { si = si - 1; }
    if (si == 0 || (text[si] != 'u' && text[si] != 'i')) { ret nil; }

    # match known suffixes from si to end
    val suf_len: usize = len - si;
    if (text[si] == 'u') {
        if (suf_len == 2 && text[si + 1] == '8') {
            ret type.get_primitive(sema.types, type.TYPE_U8);
        }
        if (suf_len == 3 && text[si + 1] == '1' && text[si + 2] == '6') {
            ret type.get_primitive(sema.types, type.TYPE_U16);
        }
        if (suf_len == 3 && text[si + 1] == '3' && text[si + 2] == '2') {
            ret type.get_primitive(sema.types, type.TYPE_U32);
        }
        if (suf_len == 3 && text[si + 1] == '6' && text[si + 2] == '4') {
            ret type.get_primitive(sema.types, type.TYPE_U64);
        }
    }
    if (text[si] == 'i') {
        if (suf_len == 2 && text[si + 1] == '8') {
            ret type.get_primitive(sema.types, type.TYPE_I8);
        }
        if (suf_len == 3 && text[si + 1] == '1' && text[si + 2] == '6') {
            ret type.get_primitive(sema.types, type.TYPE_I16);
        }
        if (suf_len == 3 && text[si + 1] == '3' && text[si + 2] == '2') {
            ret type.get_primitive(sema.types, type.TYPE_I32);
        }
        if (suf_len == 3 && text[si + 1] == '6' && text[si + 2] == '4') {
            ret type.get_primitive(sema.types, type.TYPE_I64);
        }
    }
    ret nil;
}

# resolve_float_suffix: extract type from float literal suffix (e.g., "3.14f32" -> TYPE_F32).
# returns nil if no suffix is present.
fun resolve_float_suffix(sema: *Sema, text: str) *type.Type {
    if (text == nil) { ret nil; }
    val len: usize = str_len(text);
    if (len < 4) { ret nil; }

    # float suffixes are always "f32" or "f64" at the end
    if (text[len - 3] == 'f' && text[len - 2] == '3' && text[len - 1] == '2') {
        ret type.get_primitive(sema.types, type.TYPE_F32);
    }
    if (text[len - 3] == 'f' && text[len - 2] == '6' && text[len - 1] == '4') {
        ret type.get_primitive(sema.types, type.TYPE_F64);
    }
    ret nil;
}

# coerce_lit_type: coerce an unsuffixed numeric literal to an expected type.
# only overrides the default (i64 for int, f64 for float); suffixed literals are preserved.
# handles bare literals and negated literals (-42).
pub fun coerce_lit_type(sema: *Sema, node: *ast.Node, target: *type.Type) {
    if (node == nil || target == nil) { ret; }

    val default_int: *type.Type = type.get_primitive(sema.types, type.TYPE_I64);
    val default_float: *type.Type = type.get_primitive(sema.types, type.TYPE_F64);

    # bare integer literal -> integer target
    if (node.kind == ast.NODE_EXPR_LIT_INT
        && node.type == default_int
        && type.type_is_integer(target)) {
        node.type = target;
        ret;
    }

    # bare float literal -> float target
    if (node.kind == ast.NODE_EXPR_LIT_FLOAT
        && node.type == default_float
        && type.type_is_float(target)) {
        node.type = target;
        ret;
    }

    # negated literal: -42, -3.14
    if (node.kind == ast.NODE_EXPR_UNARY
        && node.info.unary_expr.op == token.TAG_MINUS
        && node.info.unary_expr.expr != nil) {
        val inner: *ast.Node = node.info.unary_expr.expr;
        if (inner.kind == ast.NODE_EXPR_LIT_INT
            && inner.type == default_int
            && type.type_is_integer(target)) {
            inner.type = target;
            node.type = target;
        } or (inner.kind == ast.NODE_EXPR_LIT_FLOAT
              && inner.type == default_float
              && type.type_is_float(target)) {
            inner.type = target;
            node.type = target;
        }
    }
}

# resolve_expr_type: infer the type of an expression.
# ---
# sema: analyzer context
# node: expression node
# ret:  inferred type or nil
pub fun resolve_expr_type(sema: *Sema, node: *ast.Node) *type.Type {
    if (sema == nil || node == nil) {
        ret nil;
    }

    # if node already has a type, return it
    if (node.type != nil) {
        ret node.type;
    }

    # integer literal - check suffix, default to i64
    if (node.kind == ast.NODE_EXPR_LIT_INT) {
        val int_text: str = node.info.lit_expr.text;
        val int_suffix_type: *type.Type = resolve_int_suffix(sema, int_text);
        if (int_suffix_type != nil) {
            node.type = int_suffix_type;
        } or {
            node.type = type.get_primitive(sema.types, type.TYPE_I64);
        }
        ret node.type;
    }

    # string literal
    if (node.kind == ast.NODE_EXPR_LIT_STR) {
        node.type = type.get_primitive(sema.types, type.TYPE_PTR);
        ret node.type;
    }

    # bool literal - bool is u8 under the hood
    if (node.kind == ast.NODE_EXPR_LIT_BOOL) {
        node.type = type.get_primitive(sema.types, type.TYPE_U8);
        ret node.type;
    }

    # char literal - single byte
    if (node.kind == ast.NODE_EXPR_LIT_CHAR) {
        node.type = type.get_primitive(sema.types, type.TYPE_U8);
        ret node.type;
    }

    # float literal - check suffix, default to f64
    if (node.kind == ast.NODE_EXPR_LIT_FLOAT) {
        val float_text: str = node.info.lit_expr.text;
        val float_suffix_type: *type.Type = resolve_float_suffix(sema, float_text);
        if (float_suffix_type != nil) {
            node.type = float_suffix_type;
        } or {
            node.type = type.get_primitive(sema.types, type.TYPE_F64);
        }
        ret node.type;
    }

    # identifier - lookup symbol type
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.info.ident_expr.name;
        if (name != nil) {
            var sym: *symbol.Symbol = nil;

            # first check local scopes
            val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
            if (option_is_some[*symbol.Symbol](sym_opt)) {
                sym = option_unwrap[*symbol.Symbol](sym_opt);
            } or {
                # if not found locally, check unaliased imports
                if (sema.current_module != nil) {
                    var imp: *ModuleImport = sema.current_module.imports;
                    for (imp != nil && sym == nil) {
                        if (imp.module != nil && imp.module.table != nil) {
                            val root: *symbol.Scope = symbol.table_root_scope(imp.module.table);
                            if (root != nil) {
                                val cand_opt: Option[*symbol.Symbol] = symbol.scope_lookup_local(root, name);
                                if (option_is_some[*symbol.Symbol](cand_opt)) {
                                    val cand: *symbol.Symbol = option_unwrap[*symbol.Symbol](cand_opt);
                                    if (cand.is_public) {
                                        sym = cand;
                                    }
                                }
                            }
                        }
                        imp = imp.next;
                    }
                }
            }

            if (sym != nil && sym.resolved_type != nil) {
                node.type = sym.resolved_type;
                node.symbol = sym::ptr;
                ret node.type;
            }
            report_error_node(sema, node, "undefined identifier");
        }
        ret nil;
    }

    # field access expression (e.g., node.type, type.kind)
    if (node.kind == ast.NODE_EXPR_FIELD) {
        val fa_base: *ast.Node = node.info.field_expr.object;
        val fa_field_name: str = node.info.field_expr.field;
        if (fa_base == nil || fa_field_name == nil) {
            ret nil;
        }

        # check if base is a module alias
        if (fa_base.kind == ast.NODE_EXPR_IDENT && sema.current_module != nil) {
            val fa_base_name: str = fa_base.info.ident_expr.name;
            if (fa_base_name != nil) {
                var fa_ma: *ModuleAlias = sema.current_module.aliases;
                for (fa_ma != nil) {
                    if (fa_ma.alias != nil && str_equals(fa_ma.alias, fa_base_name)) {
                        # module alias - look up field_name in that module's symbol table
                        if (fa_ma.module != nil && fa_ma.module.table != nil) {
                            val fa_root: *symbol.Scope = symbol.table_root_scope(fa_ma.module.table);
                            if (fa_root != nil) {
                                val fa_sym_opt: Option[*symbol.Symbol] = symbol.scope_lookup_local(fa_root, fa_field_name);
                                if (option_is_some[*symbol.Symbol](fa_sym_opt)) {
                                    val fa_sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](fa_sym_opt);
                                    if (fa_sym.resolved_type != nil) {
                                        node.type = fa_sym.resolved_type;
                                        node.symbol = fa_sym::ptr;
                                        ret node.type;
                                    }
                                }
                            }
                        }
                        ret nil;
                    }
                    fa_ma = fa_ma.next;
                }
            }
        }

        # not a module alias - resolve base expression type
        val fa_base_ty: *type.Type = resolve_expr_type(sema, fa_base);
        if (fa_base_ty == nil) {
            ret nil;
        }

        # auto-dereference pointer to record/union
        var fa_struct_ty: *type.Type = fa_base_ty;
        if (fa_base_ty.kind == type.TYPE_POINTER && fa_base_ty.inner != nil) {
            fa_struct_ty = fa_base_ty.inner;
        }

        # look up field in record/union
        if (fa_struct_ty.kind == type.TYPE_RECORD || fa_struct_ty.kind == type.TYPE_UNION) {
            val fa_field_opt: Option[*type.Field] = type.get_field(fa_struct_ty, fa_field_name);
            if (option_is_some[*type.Field](fa_field_opt)) {
                val fa_field: *type.Field = option_unwrap[*type.Field](fa_field_opt);
                node.type = fa_field.type;
                ret node.type;
            }
        }

        ret nil;
    }

    # cast expression
    if (node.kind == ast.NODE_EXPR_CAST) {
        # resolve inner expression first (for side effects like generic instantiation)
        val cast_inner: *ast.Node = node.info.cast_expr.expr;
        if (cast_inner != nil) {
            resolve_expr_type(sema, cast_inner);
        }
        val cast_type_node: *ast.Node = node.info.cast_expr.type_node;
        if (cast_type_node != nil) {
            val cast_target: *type.Type = resolve_type_expr(sema, cast_type_node);
            if (cast_target != nil) {
                node.type = cast_target;
                ret node.type;
            }
        }
        ret nil;
    }

    # parenthesized expression
    if (node.kind == ast.NODE_EXPR_PAREN) {
        val paren_inner: *ast.Node = node.info.wrapper.inner;
        if (paren_inner != nil) {
            val paren_ty: *type.Type = resolve_expr_type(sema, paren_inner);
            if (paren_ty != nil) {
                node.type = paren_ty;
                ret node.type;
            }
        }
        ret nil;
    }

    # struct literal (e.g., MyStruct { field: value })
    if (node.kind == ast.NODE_EXPR_STRUCT_LIT) {
        val slit_type_node: *ast.Node = node.info.struct_lit.type_node;
        if (slit_type_node != nil) {
            val slit_type: *type.Type = resolve_type_expr(sema, slit_type_node);
            if (slit_type != nil) {
                node.type = slit_type;

                # resolve field value expressions so calls inside struct literals
                # are properly analyzed (triggers generic instantiation, sets node.type)
                val slit_fields: *ast.List = node.info.struct_lit.fields;
                if (slit_fields != nil) {
                    var sfi: i32 = 0;
                    for (sfi < slit_fields.count) {
                        val sfield: *ast.Node = slit_fields.nodes[sfi];
                        if (sfield != nil) {
                            val sfval: *ast.Node = sfield.info.field_decl.type_node;
                            if (sfval != nil) {
                                resolve_expr_type(sema, sfval);

                                # coerce literal to field type
                                val sfname: str = sfield.info.field_decl.name;
                                if (sfname != nil) {
                                    val field_opt: Option[*type.Field] = type.get_field(slit_type, sfname);
                                    if (option_is_some[*type.Field](field_opt)) {
                                        val field: *type.Field = option_unwrap[*type.Field](field_opt);
                                        coerce_lit_type(sema, sfval, field.type);
                                    }
                                }
                            }
                        }
                        sfi = sfi + 1;
                    }
                }

                ret node.type;
            }
        }
        ret nil;
    }

    # binary expression
    if (node.kind == ast.NODE_EXPR_BINARY) {
        val lhs_type: *type.Type = resolve_expr_type(sema, node.info.binary_expr.left);
        val rhs_type: *type.Type = resolve_expr_type(sema, node.info.binary_expr.right);

        # comparison and logical operators always produce bool
        val op: u8 = node.info.binary_expr.op;
        if (op == token.TAG_EQ_EQ || op == token.TAG_BANG_EQ ||
            op == token.TAG_LT || op == token.TAG_LT_EQ ||
            op == token.TAG_GT || op == token.TAG_GT_EQ ||
            op == token.TAG_AMP_AMP || op == token.TAG_PIPE_PIPE) {
            node.type = type.get_primitive(sema.types, type.TYPE_U8);
            ret node.type;
        }

        # coerce unsuffixed integer literals to the non-literal operand's type
        if (lhs_type != nil && rhs_type != nil) {
            val lhs_is_lit: bool = node.info.binary_expr.left.kind == ast.NODE_EXPR_LIT_INT;
            val rhs_is_lit: bool = node.info.binary_expr.right.kind == ast.NODE_EXPR_LIT_INT;
            val default_int: *type.Type = type.get_primitive(sema.types, type.TYPE_I64);

            if (lhs_is_lit && !rhs_is_lit && type.type_is_integer(rhs_type)
                && node.info.binary_expr.left.type == default_int) {
                node.info.binary_expr.left.type = rhs_type;
                node.type = rhs_type;
                ret node.type;
            }
            if (rhs_is_lit && !lhs_is_lit && type.type_is_integer(lhs_type)
                && node.info.binary_expr.right.type == default_int) {
                node.info.binary_expr.right.type = lhs_type;
                node.type = lhs_type;
                ret node.type;
            }

            # if either operand is unsigned, prefer the unsigned type so that
            # arithmetic operations (especially div/mod) use unsigned instructions
            if (type.type_is_unsigned(rhs_type) && !type.type_is_unsigned(lhs_type)) {
                node.type = rhs_type;
                ret node.type;
            }
            node.type = lhs_type;
            ret node.type;
        }

        if (lhs_type != nil) {
            node.type = lhs_type;
            ret node.type;
        }
        if (rhs_type != nil) {
            node.type = rhs_type;
            ret node.type;
        }
        ret nil;
    }

    # unary expression
    if (node.kind == ast.NODE_EXPR_UNARY) {
        val operand_type: *type.Type = resolve_expr_type(sema, node.info.unary_expr.expr);
        if (operand_type != nil) {
            node.type = operand_type;
            ret node.type;
        }
        ret nil;
    }

    # function call
    if (node.kind == ast.NODE_EXPR_CALL) {
        # variadic builtins: va_start, va_arg, va_end
        val va_callee: *ast.Node = node.info.call_expr.callee;
        if (va_callee != nil && va_callee.kind == ast.NODE_EXPR_IDENT) {
            val va_name: str = va_callee.info.ident_expr.name;
            if (va_name != nil) {
                if (str_equals(va_name, "va_start") || str_equals(va_name, "va_end")) {
                    node.type = type.get_primitive(sema.types, type.TYPE_VOID);
                    ret node.type;
                }
                if (str_equals(va_name, "va_arg")) {
                    val va_ta: *ast.Node = node.info.call_expr.type_args;
                    if (va_ta != nil && va_ta.kind == ast.NODE_GENERIC) {
                        val va_ta_list: *ast.List = va_ta.info.generic_node.args;
                        if (va_ta_list != nil && va_ta_list.count > 0) {
                            val va_arg_type: *type.Type = resolve_type_expr(sema, va_ta_list.nodes[0]);
                            if (va_arg_type != nil) {
                                node.type = va_arg_type;
                                ret node.type;
                            }
                        }
                    }
                    node.type = type.get_primitive(sema.types, type.TYPE_VOID);
                    ret node.type;
                }
            }
        }

        # comptime intrinsic calls: $size_of(T), $align_of(T)
        if (va_callee != nil && va_callee.kind == ast.NODE_COMPTIME) {
            val ct_inner: *ast.Node = va_callee.info.wrapper.inner;
            if (ct_inner != nil && ct_inner.kind == ast.NODE_EXPR_IDENT) {
                val ct_name: str = ct_inner.info.ident_expr.name;
                if (ct_name != nil) {
                    if (str_equals(ct_name, "size_of") || str_equals(ct_name, "align_of")) {
                        ret resolve_comptime_size_align(sema, node, ct_name);
                    }
                }
            }
        }

        # resolve argument types
        val call_args: *ast.List = node.info.call_expr.args;
        if (call_args != nil) {
            var ai: i32 = 0;
            for (ai < call_args.count) {
                if (call_args.nodes[ai] != nil) {
                    resolve_expr_type(sema, call_args.nodes[ai]);
                }
                ai = ai + 1;
            }
        }

        val callee: *ast.Node = node.info.call_expr.callee;
        if (callee != nil) {
            val callee_type: *type.Type = resolve_expr_type(sema, callee);
            if (callee_type != nil && callee_type.kind == type.TYPE_FUN) {
                # coerce argument literals to parameter types
                if (call_args != nil && callee_type.params != nil) {
                    var pi: i32 = 0;
                    for (pi < call_args.count && pi < callee_type.param_count) {
                        if (call_args.nodes[pi] != nil && callee_type.params[pi] != nil) {
                            coerce_lit_type(sema, call_args.nodes[pi], callee_type.params[pi]);
                        }
                        pi = pi + 1;
                    }
                }

                # check for generic function call with type args
                val type_args: *ast.Node = node.info.call_expr.type_args;
                if (type_args != nil && callee.kind == ast.NODE_EXPR_IDENT) {
                    # look up the function symbol (including imports)
                    val func_name: str = callee.info.ident_expr.name;
                    if (func_name != nil) {
                        val sym: *symbol.Symbol = lookup_function_symbol(sema, func_name);
                        if (sym != nil && sym.is_generic && sym.decl_node != nil) {
                            # resolve return type with generic bindings
                            var ret_ty: *type.Type = nil;
                            if (sym.decl_node.info.fun_decl.ret_type != nil) {
                                ret_ty = resolve_generic_call_return_type(sema, sym, type_args);
                            }
                            # create an instantiation record for lowering
                            val inst_name: str = instantiate_generic_function(sema, sym, type_args);
                            # attach the instantiated symbol to the call node
                            if (inst_name != nil) {
                                val inst_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, inst_name);
                                if (option_is_some[*symbol.Symbol](inst_opt)) {
                                    node.symbol = option_unwrap[*symbol.Symbol](inst_opt)::ptr;
                                }
                            }
                            if (ret_ty != nil) {
                                node.type = ret_ty;
                                ret ret_ty;
                            }
                            # void-returning generic: set type to void and return
                            node.type = callee_type.ret_type;
                            ret node.type;
                        }
                    }
                }
                # module-qualified generic calls (e.g., allocator.allocator_alloc[u8](...))
                if (type_args != nil && callee.kind == ast.NODE_EXPR_FIELD) {
                    val mq_base: *ast.Node = callee.info.field_expr.object;
                    if (mq_base != nil && mq_base.kind == ast.NODE_EXPR_IDENT) {
                        val mq_sym: *symbol.Symbol = lookup_module_function(sema, mq_base.info.ident_expr.name, callee.info.field_expr.field);
                        if (mq_sym != nil && mq_sym.is_generic && mq_sym.decl_node != nil) {
                            val mq_ret_ty: *type.Type = resolve_generic_call_return_type(sema, mq_sym, type_args);
                            val mq_inst_name: str = instantiate_generic_function(sema, mq_sym, type_args);
                            if (mq_inst_name != nil) {
                                val mq_inst_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, mq_inst_name);
                                if (option_is_some[*symbol.Symbol](mq_inst_opt)) {
                                    node.symbol = option_unwrap[*symbol.Symbol](mq_inst_opt)::ptr;
                                }
                            }
                            if (mq_ret_ty != nil) {
                                node.type = mq_ret_ty;
                                ret mq_ret_ty;
                            }
                            # void-returning generic: set type to void and return
                            node.type = callee_type.ret_type;
                            ret node.type;
                        }
                    }
                }
                # non-generic module-qualified calls (e.g., impl.write(...))
                if (callee.kind == ast.NODE_EXPR_FIELD) {
                    val mq_base: *ast.Node = callee.info.field_expr.object;
                    if (mq_base != nil && mq_base.kind == ast.NODE_EXPR_IDENT) {
                        val mq_sym: *symbol.Symbol = lookup_module_function(sema, mq_base.info.ident_expr.name, callee.info.field_expr.field);
                        if (mq_sym != nil) {
                            node.symbol = mq_sym::ptr;
                        }
                    }
                }
                # bare ident non-generic calls (e.g., str_equals(...))
                if (node.symbol == nil && callee.kind == ast.NODE_EXPR_IDENT) {
                    val bare_name: str = callee.info.ident_expr.name;
                    if (bare_name != nil) {
                        val bare_sym: *symbol.Symbol = lookup_function_symbol(sema, bare_name);
                        if (bare_sym != nil) {
                            node.symbol = bare_sym::ptr;
                        }
                    }
                }
                node.type = callee_type.ret_type;
                ret node.type;
            }
        }
        ret nil;
    }

    # address-of
    if (node.kind == ast.NODE_EXPR_ADDR) {
        val operand_type: *type.Type = resolve_expr_type(sema, node.info.unary_expr.expr);
        if (operand_type != nil) {
            val ptr_res: Result[*type.Type, str] = type.make_pointer(sema.types, operand_type, true);
            if (result_is_ok[*type.Type, str](ptr_res)) {
                node.type = result_unwrap_ok[*type.Type, str](ptr_res);
                ret node.type;
            }
        }
        ret nil;
    }

    # index expression (e.g., arr[i]) - element type of pointer/array
    if (node.kind == ast.NODE_EXPR_INDEX) {
        val idx_base: *ast.Node = node.info.index_expr.base;
        # resolve index expression so sub-expressions get their types set
        val idx_index: *ast.Node = node.info.index_expr.index;
        if (idx_index != nil) {
            resolve_expr_type(sema, idx_index);
        }
        if (idx_base != nil) {
            val idx_base_ty: *type.Type = resolve_expr_type(sema, idx_base);
            if (idx_base_ty != nil) {
                if (idx_base_ty.kind == type.TYPE_POINTER && idx_base_ty.inner != nil) {
                    node.type = idx_base_ty.inner;
                    ret node.type;
                }
                if (idx_base_ty.kind == type.TYPE_ARRAY && idx_base_ty.inner != nil) {
                    node.type = idx_base_ty.inner;
                    ret node.type;
                }
            }
        }
        ret nil;
    }

    # dereference
    if (node.kind == ast.NODE_EXPR_DEREF) {
        val operand_type: *type.Type = resolve_expr_type(sema, node.info.unary_expr.expr);
        if (operand_type != nil && operand_type.kind == type.TYPE_POINTER) {
            node.type = operand_type.inner;
            ret node.type;
        }
        ret nil;
    }

    # nil
    if (node.kind == ast.NODE_EXPR_LIT_NIL) {
        node.type = type.get_primitive(sema.types, type.TYPE_NIL);
        ret node.type;
    }

    # array literal
    if (node.kind == ast.NODE_EXPR_ARRAY_LIT) {
        val arr_elem_type_node: *ast.Node = node.info.array_lit.type_node;
        val arr_size_node: *ast.Node = node.info.array_lit.size;
        if (arr_elem_type_node != nil) {
            val elem_type: *type.Type = resolve_type_expr(sema, arr_elem_type_node);
            if (elem_type != nil && arr_size_node != nil) {
                val count: usize = ast.node_get_int_value(arr_size_node)::usize;
                if (count > 0) {
                    val arr_res: Result[*type.Type, str] = type.make_array(sema.types, elem_type, count);
                    if (result_is_ok[*type.Type, str](arr_res)) {
                        node.type = result_unwrap_ok[*type.Type, str](arr_res);
                        ret node.type;
                    }
                }
            }
        }
        ret nil;
    }

    ret nil;
}

# --- type mangling for generic instantiation dedup ---

# type_mangle: write a compact type encoding into a buffer.
# used for generating unique mangled names for generic instantiations.
# returns the number of bytes written.
fun type_mangle(t: *type.Type, buf: *u8, cap: usize) i32 {
    if (t == nil || buf == nil || cap == 0) { ret 0; }

    # primitive type codes (Itanium-inspired)
    if (t.kind == type.TYPE_VOID)    { buf[0] = 'v'; ret 1; }
    if (t.kind == type.TYPE_U8)      { buf[0] = 'h'; ret 1; }
    if (t.kind == type.TYPE_U16)     { buf[0] = 't'; ret 1; }
    if (t.kind == type.TYPE_U32)     { buf[0] = 'j'; ret 1; }
    if (t.kind == type.TYPE_U64)     { buf[0] = 'm'; ret 1; }
    if (t.kind == type.TYPE_I8)      { buf[0] = 'a'; ret 1; }
    if (t.kind == type.TYPE_I16)     { buf[0] = 's'; ret 1; }
    if (t.kind == type.TYPE_I32)     { buf[0] = 'i'; ret 1; }
    if (t.kind == type.TYPE_I64)     { buf[0] = 'x'; ret 1; }
    if (t.kind == type.TYPE_F32)     { buf[0] = 'f'; ret 1; }
    if (t.kind == type.TYPE_F64)     { buf[0] = 'd'; ret 1; }
    if (t.kind == type.TYPE_NIL)     { buf[0] = 'n'; ret 1; }

    # raw pointer
    if (t.kind == type.TYPE_PTR) {
        buf[0] = 'p';
        ret 1;
    }

    # typed pointer *T
    if (t.kind == type.TYPE_POINTER) {
        if (cap < 2) { ret 0; }
        buf[0] = 'P';
        val inner_written: i32 = type_mangle(t.inner, ?buf[1], cap - 1);
        ret 1 + inner_written;
    }

    # array [N]T
    if (t.kind == type.TYPE_ARRAY) {
        if (cap < 3) { ret 0; }
        buf[0] = 'A';
        var pos: i32 = 1;
        # write array size as decimal digits
        val arr_sz: usize = type.type_size(t);
        val elem_sz: usize = type.type_size(t.inner);
        var arr_count: usize = 0;
        if (elem_sz > 0) { arr_count = arr_sz / elem_sz; }
        pos = pos + write_mangle_digits(buf, pos::usize, arr_count, cap);
        if (pos::usize < cap) {
            buf[pos::usize] = '_';
            pos = pos + 1;
        }
        val elem_written: i32 = type_mangle(t.inner, ?buf[pos::usize], cap - pos::usize);
        ret pos + elem_written;
    }

    # named types (record, union, generic) — use name if available
    if (t.name != nil) {
        val nlen: usize = str_len(t.name);
        var pos: i32 = 0;
        pos = pos + write_mangle_digits(buf, pos::usize, nlen, cap);
        var ni: usize = 0;
        for (ni < nlen && pos::usize < cap) {
            buf[pos::usize] = t.name[ni];
            pos = pos + 1;
            ni = ni + 1;
        }
        ret pos;
    }

    # fallback: unknown type marker
    buf[0] = '?';
    ret 1;
}

# write_mangle_digits: write a number as decimal digits into a buffer.
# returns the number of bytes written.
fun write_mangle_digits(buf: *u8, pos: usize, n: usize, cap: usize) i32 {
    if (n == 0) {
        if (pos < cap) { buf[pos] = '0'; ret 1; }
        ret 0;
    }
    # count digits
    var dlen: i32 = 0;
    var v: usize = n;
    for (v > 0) { dlen = dlen + 1; v = v / 10; }
    if (pos + dlen::usize > cap) { ret 0; }
    # write digits in reverse
    var i: i32 = dlen - 1;
    v = n;
    for (v > 0) {
        buf[pos + i::usize] = (v % 10)::u8 + 48;
        v = v / 10;
        i = i - 1;
    }
    ret dlen;
}

# resolve_type_from_expr: interpret an expression node as a type for comptime intrinsics.
# Handles bare identifiers (primitives, named types) and address-of expressions (&T, &&T, ...).
# Returns nil if the node cannot be interpreted as a type.
fun resolve_type_from_expr(sema: *Sema, node: *ast.Node) *type.Type {
    if (node == nil) { ret nil; }

    # bare identifier — look up as primitive or named type
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val type_name: str = node.info.ident_expr.name;
        if (type_name == nil) { ret nil; }

        val pk: Option[type.TypeKind] = type.primitive_kind_from_name(type_name);
        if (option_is_some[type.TypeKind](pk)) {
            ret type.get_primitive(sema.types, option_unwrap[type.TypeKind](pk));
        }

        val tsym: *symbol.Symbol = lookup_type_symbol(sema, type_name);
        if (tsym != nil && tsym.resolved_type != nil) {
            ret tsym.resolved_type;
        }

        ret nil;
    }

    # unary & expression — &T means pointer to T (readonly, is_mutable=false)
    if (node.kind == ast.NODE_EXPR_UNARY && node.info.unary_expr.op == token.TAG_AMP) {
        val inner_type: *type.Type = resolve_type_from_expr(sema, node.info.unary_expr.expr);
        if (inner_type == nil) { ret nil; }
        val ptr_res: Result[*type.Type, str] = type.make_pointer(sema.types, inner_type, false);
        if (result_is_ok[*type.Type, str](ptr_res)) {
            ret result_unwrap_ok[*type.Type, str](ptr_res);
        }
        ret nil;
    }

    ret nil;
}

# resolve_comptime_size_align: evaluate $size_of(T) or $align_of(T) and fold to integer literal.
fun resolve_comptime_size_align(sema: *Sema, node: *ast.Node, name: str) *type.Type {
    val args: *ast.List = node.info.call_expr.args;
    if (args == nil || args.count != 1) { ret nil; }

    val arg: *ast.Node = args.nodes[0];
    if (arg == nil) { ret nil; }

    # resolve the argument to a type
    var arg_type: *type.Type = nil;

    # try interpreting as a type first (avoids false "undefined identifier" errors)
    arg_type = resolve_type_from_expr(sema, arg);

    # fall back to expression resolution (handles generic type params)
    if (arg_type == nil) {
        arg_type = resolve_expr_type(sema, arg);
    }

    # fall back to type already on the node (set by substitute_types_in_body
    # during generic instantiation)
    if (arg_type == nil) {
        arg_type = arg.type;
    }

    if (arg_type == nil) { ret nil; }

    # don't fold when arg is a generic parameter — will be folded during instantiation.
    # store type on the arg node so substitute_types_in_body can resolve it later.
    if (arg_type.kind == type.TYPE_GENERIC_PARAM) {
        arg.type = arg_type;
        ret nil;
    }

    # compute the value
    var value: usize = 0;
    if (str_equals(name, "size_of")) {
        value = type.type_size(arg_type);
    } or {
        value = type.type_align(arg_type);
    }

    # convert to integer literal text
    val text: str = usize_to_decimal(sema, value);

    # transform the call node into an integer literal
    node.kind = ast.NODE_EXPR_LIT_INT;
    node.info.lit_expr.text = text;
    node.type = type.get_primitive(sema.types, type.TYPE_I64);
    ret node.type;
}

# usize_to_decimal: convert a usize to a decimal string.
fun usize_to_decimal(sema: *Sema, value: usize) str {
    if (value == 0) { ret "0"; }

    # count digits
    var tmp: usize = value;
    var len: usize = 0;
    for (tmp > 0) { len = len + 1; tmp = tmp / 10; }

    # allocate buffer
    val res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, len + 1);
    if (result_is_err[*u8, allocator.AllocError](res)) { ret "0"; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](res);

    buf[len] = 0;
    tmp = value;
    var i: usize = len;
    for (tmp > 0) {
        i = i - 1;
        buf[i] = (tmp % 10)::u8 + 48;
        tmp = tmp / 10;
    }
    ret buf::&u8;
}
