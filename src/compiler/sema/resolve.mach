use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use type:     mach.compiler.type;
use token:  mach.compiler.token;

use mach.compiler.sema;
use mach.compiler.sema.errors;
use mach.compiler.sema.expr;

# mach.compiler.sema.resolve: pass 2 (type resolution) and pass 2b (function body resolution).

# resolve_types: pass 2 - resolve all types.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
pub fun resolve_types(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    # first pass: create type shells for all declarations
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # resolve type for this declaration
        resolve_node_type(sema, node);

        i = i + 1;
    }

    # second pass: resolve record/union fields (now that all type shells exist)
    var j: i32 = 0;
    for (j < decls.count) {
        val node2: *ast.Node = decls.nodes[j];
        if (node2 != nil) {
            resolve_node_fields(sema, node2);
        }
        j = j + 1;
    }
}

# resolve_node_type: resolve the type for a declaration node.
# ---
# sema: analyzer context
# node: declaration node
# ret:  none
fun resolve_node_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # type declaration - resolve the underlying type
    if (node.kind == ast.NODE_DECL_DEF) {
        val type_node: *ast.Node = node.info.def_decl.type_node;
        if (type_node != nil) {
            val t: *type.Type = resolve_type_expr(sema, type_node);
            if (t != nil) {
                node.type = t;
                # update symbol's resolved type
                val name: str = node.info.def_decl.name;
                if (name != nil) {
                    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
                    if (option_is_some[*symbol.Symbol](sym_opt)) {
                        option_unwrap[*symbol.Symbol](sym_opt).resolved_type = t;
                    }
                }
            }
        }
        ret;
    }

    # function declaration - resolve signature
    if (node.kind == ast.NODE_DECL_FUN) {
        val fun_type: *type.Type = resolve_function_type(sema, node);
        if (fun_type != nil) {
            node.type = fun_type;

            # update symbol's type
            val name2: str = node.info.fun_decl.name;
            if (name2 != nil) {
                val sym_opt2: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name2);
                if (option_is_some[*symbol.Symbol](sym_opt2)) {
                    val sym2: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt2);
                    sym2.resolved_type = fun_type;
                }
            }
        }
        ret;
    }

    # variable/constant declaration - resolve type annotation and/or initializer
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val type_annot: *ast.Node = node.info.var_decl.type_node;
        val init_node: *ast.Node = node.info.var_decl.init;

        # first try to resolve from type annotation
        if (type_annot != nil) {
            val annot_type: *type.Type = resolve_type_expr(sema, type_annot);
            if (annot_type != nil) {
                node.type = annot_type;
            }
        }

        # also resolve initializer (for type inference when no annotation)
        if (init_node != nil) {
            val init_type: *type.Type = resolve_expr_type(sema, init_node);
            if (node.type == nil && init_type != nil) {
                node.type = init_type;
            }
        }

        # update symbol's resolved type
        if (node.type != nil) {
            val name: str = node.info.var_decl.name;
            if (name != nil) {
                val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
                if (option_is_some[*symbol.Symbol](sym_opt)) {
                    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
                    sym.resolved_type = node.type;
                }
            }
        }
        ret;
    }

    # comptime if - process taken branch for type resolution
    if (node.kind == ast.NODE_COMPTIME_IF) {
        # the taken branch body
        val taken: *ast.Node = node.info.cond_stmt.body;
        if (taken != nil) {
            resolve_comptime_if_types(sema, taken);
        }
        ret;
    }

    # record declaration - create type and update symbol
    if (node.kind == ast.NODE_DECL_REC) {
        resolve_rec_type(sema, node);
        ret;
    }

    # union declaration - create type and update symbol
    if (node.kind == ast.NODE_DECL_UNI) {
        resolve_uni_type(sema, node);
        ret;
    }

    # pub wrapper - process inner declaration
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            resolve_node_type(sema, inner);
        }
        ret;
    }
}

# resolve_node_fields: resolve fields for record/union declarations (second pass).
# ---
# sema: analyzer context
# node: declaration node
# ret:  none
fun resolve_node_fields(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind == ast.NODE_DECL_REC) {
        resolve_rec_fields(sema, node);
        ret;
    }

    if (node.kind == ast.NODE_DECL_UNI) {
        resolve_uni_fields(sema, node);
        ret;
    }

    # comptime if - resolve fields in taken branch
    if (node.kind == ast.NODE_COMPTIME_IF) {
        val taken: *ast.Node = node.info.cond_stmt.body;
        if (taken != nil) {
            resolve_comptime_if_fields(sema, taken);
        }
        ret;
    }

    # pub wrapper - process inner declaration
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            resolve_node_fields(sema, inner);
        }
        ret;
    }
}

# resolve_comptime_if_fields: resolve record/union fields in a $if taken branch.
fun resolve_comptime_if_fields(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    if (body.kind != ast.NODE_STMT_BLOCK) {
        resolve_node_fields(sema, body);
        ret;
    }

    val decls: *ast.List = body.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            resolve_node_fields(sema, node);
        }
        i = i + 1;
    }
}

# resolve_rec_type: resolve types for a record declaration.
# ---
# sema: analyzer context
# node: record declaration node
# ret:  none
fun resolve_rec_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    # get symbol
    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) {
        ret;
    }

    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);

    # if already resolved, skip
    if (sym.resolved_type != nil) {
        ret;
    }

    # if generic, don't resolve fields yet - wait for instantiation
    if (sym.is_generic) {
        # create placeholder generic type
        val gen_res: Result[*type.Type, str] = type.make_generic(sema.types, name);
        if (result_is_ok[*type.Type, str](gen_res)) {
            sym.resolved_type = result_unwrap_ok[*type.Type, str](gen_res);
            node.type = sym.resolved_type;
        }
        ret;
    }

    # create record type shell first (fields resolved in second pass)
    val rec_res: Result[*type.Type, str] = type.make_record(sema.types, name, nil, 0);
    if (result_is_ok[*type.Type, str](rec_res)) {
        sym.resolved_type = result_unwrap_ok[*type.Type, str](rec_res);
        node.type = sym.resolved_type;
    }
}

# resolve_rec_fields: resolve fields for a record declaration (second pass).
# ---
# This is called after all type shells exist, so self-referential types work.
# sema: analyzer context
# node: record declaration node
# ret:  none
pub fun resolve_rec_fields(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) {
        ret;
    }

    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.resolved_type == nil || sym.is_generic) {
        ret;
    }

    # skip if fields already resolved
    if (sym.resolved_type.field_count != 0) {
        ret;
    }

    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) {
        ret;
    }

    val fields_res: Result[*type.Field, allocator.AllocError] =
        allocator.allocator_alloc[type.Field](sema.alloc, ast_fields.count::usize);
    if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
        ret;
    }
    val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
    var field_count: i32 = 0;

    var fi: i32 = 0;
    for (fi < ast_fields.count) {
        val field_node: *ast.Node = ast_fields.nodes[fi];
        if (field_node != nil) {
            val field_name: str = field_node.info.field_decl.name;
            val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
            var field_type: *type.Type = nil;
            if (field_type_node != nil) {
                field_type = resolve_type_expr(sema, field_type_node);
            }
            if (field_name != nil && field_type != nil) {
                fields[field_count].name = field_name;
                fields[field_count].type = field_type;
                fields[field_count].offset = 0;
                field_count = field_count + 1;
            }
        }
        fi = fi + 1;
    }

    if (field_count > 0) {
        # update type with resolved fields
        val t: *type.Type = sym.resolved_type;
        t.fields = fields;
        t.field_count = field_count;

        compute_record_layout(t, fields, field_count);
    }
}

# resolve_uni_type: resolve types for a union declaration.
# ---
# sema: analyzer context
# node: union declaration node
# ret:  none
fun resolve_uni_type(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    # get symbol
    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) {
        ret;
    }

    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);

    # if already resolved, skip
    if (sym.resolved_type != nil) {
        ret;
    }

    # if generic, don't resolve fields yet - wait for instantiation
    if (sym.is_generic) {
        # create placeholder generic type
        val gen_res: Result[*type.Type, str] = type.make_generic(sema.types, name);
        if (result_is_ok[*type.Type, str](gen_res)) {
            sym.resolved_type = result_unwrap_ok[*type.Type, str](gen_res);
            node.type = sym.resolved_type;
        }
        ret;
    }

    # non-generic union: create empty shell (fields resolved in second pass)
    val uni_res: Result[*type.Type, str] = type.make_union(sema.types, name, nil, 0);
    if (result_is_ok[*type.Type, str](uni_res)) {
        sym.resolved_type = result_unwrap_ok[*type.Type, str](uni_res);
        node.type = sym.resolved_type;
    }
}

# resolve_uni_fields: resolve fields for a union declaration (second pass).
# ---
# This is called after all type shells exist, so self-referential types work.
# sema: analyzer context
# node: union declaration node
# ret:  none
pub fun resolve_uni_fields(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val name: str = node.info.type_decl.name;
    if (name == nil) {
        ret;
    }

    val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) {
        ret;
    }

    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.resolved_type == nil || sym.is_generic) {
        ret;
    }

    # skip if fields already resolved
    if (sym.resolved_type.field_count != 0) {
        ret;
    }

    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) {
        ret;
    }

    val fields_res: Result[*type.Field, allocator.AllocError] =
        allocator.allocator_alloc[type.Field](sema.alloc, ast_fields.count::usize);
    if (result_is_err[*type.Field, allocator.AllocError](fields_res)) {
        ret;
    }
    val fields: *type.Field = result_unwrap_ok[*type.Field, allocator.AllocError](fields_res);
    var field_count: i32 = 0;

    var fi: i32 = 0;
    for (fi < ast_fields.count) {
        val field_node: *ast.Node = ast_fields.nodes[fi];
        if (field_node != nil) {
            val field_name: str = field_node.info.field_decl.name;
            val field_type_node: *ast.Node = field_node.info.field_decl.type_node;
            var field_type: *type.Type = nil;
            if (field_type_node != nil) {
                field_type = resolve_type_expr(sema, field_type_node);
            }
            if (field_name != nil && field_type != nil) {
                fields[field_count].name = field_name;
                fields[field_count].type = field_type;
                fields[field_count].offset = 0;
                field_count = field_count + 1;
            }
        }
        fi = fi + 1;
    }

    if (field_count > 0) {
        val t: *type.Type = sym.resolved_type;
        t.fields = fields;
        t.field_count = field_count;

        compute_union_layout(t, fields, field_count);
    }
}

# resolve_comptime_if_types: resolve types in a $if taken branch.
# ---
# sema: analyzer context
# body: taken branch body node
# ret:  none
fun resolve_comptime_if_types(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    # body should be a block node
    if (body.kind != ast.NODE_STMT_BLOCK) {
        # single declaration
        resolve_node_type(sema, body);
        ret;
    }

    # get declarations from block
    val decls: *ast.List = body.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            resolve_node_type(sema, node);
        }
        i = i + 1;
    }
}

# resolve_functions: pass 2b - resolve types in function bodies.
# ---
# sema:   analyzer context
# module: module root node
# ret:    none
pub fun resolve_functions(sema: *Sema, module: *ast.Node) {
    if (sema == nil || module == nil) {
        ret;
    }

    # get declarations from module
    val decls: *ast.List = module.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node == nil) {
            i = i + 1;
            cnt;
        }

        # resolve function body
        if (node.kind == ast.NODE_DECL_FUN) {
            resolve_function(sema, node);
        }

        # pub wrapper - process inner declaration
        if (node.kind == ast.NODE_DECL_PUB) {
            val inner: *ast.Node = node.info.wrapper.inner;
            if (inner != nil && inner.kind == ast.NODE_DECL_FUN) {
                resolve_function(sema, inner);
            }
        }

        # comptime statement
        if (node.kind == ast.NODE_COMPTIME) {
            analyze_comptime_stmt(sema, node);
        }

        # comptime if - resolve functions in taken branch
        if (node.kind == ast.NODE_COMPTIME_IF) {
            val taken: *ast.Node = node.info.cond_stmt.body;
            if (taken != nil) {
                resolve_comptime_if_functions(sema, taken);
            }
        }

        i = i + 1;
    }
}

# resolve_comptime_if_functions: resolve functions in a $if taken branch.
# ---
# sema: analyzer context
# body: taken branch body node
# ret:  none
fun resolve_comptime_if_functions(sema: *Sema, body: *ast.Node) {
    if (sema == nil || body == nil) {
        ret;
    }

    # body should be a block node
    if (body.kind != ast.NODE_STMT_BLOCK) {
        # single declaration
        if (body.kind == ast.NODE_DECL_FUN) {
            resolve_function(sema, body);
        }
        if (body.kind == ast.NODE_DECL_PUB) {
            val inner: *ast.Node = body.info.wrapper.inner;
            if (inner != nil && inner.kind == ast.NODE_DECL_FUN) {
                resolve_function(sema, inner);
            }
        }
        if (body.kind == ast.NODE_COMPTIME_IF) {
            val taken: *ast.Node = body.info.cond_stmt.body;
            if (taken != nil) {
                resolve_comptime_if_functions(sema, taken);
            }
        }
        ret;
    }

    # get declarations from block
    val decls: *ast.List = body.info.block_stmt.stmts;
    if (decls == nil) {
        ret;
    }

    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            if (node.kind == ast.NODE_DECL_FUN) {
                resolve_function(sema, node);
            }
            if (node.kind == ast.NODE_DECL_PUB) {
                val inner: *ast.Node = node.info.wrapper.inner;
                if (inner != nil && inner.kind == ast.NODE_DECL_FUN) {
                    resolve_function(sema, inner);
                }
            }
            if (node.kind == ast.NODE_COMPTIME_IF) {
                val taken: *ast.Node = node.info.cond_stmt.body;
                if (taken != nil) {
                    resolve_comptime_if_functions(sema, taken);
                }
            }
        }
        i = i + 1;
    }
}

# resolve_function: resolve types in a function body.
# ---
# sema: analyzer context
# node: function declaration node
# ret:  none
fun resolve_function(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # set current function
    sema.current_fn = node;

    # get function return type
    if (node.type != nil && node.type.kind == type.TYPE_FUN) {
        sema.current_fn_ret = node.type.ret_type;
    } or {
        sema.current_fn_ret = type.get_primitive(sema.types, type.TYPE_VOID);
    }

    # create new scope for function
    val push_res: Result[bool, str] = push_scope(sema);
    if (result_is_err[bool, str](push_res)) {
        report_error_node(sema, node, "failed to create function scope");
        ret;
    }

    # push symbol table scope so local variables don't leak into root scope
    symbol.table_push_scope(sema.symbols);

    # bind generic type parameters (function generics)
    if (node.info.fun_decl.generics != nil) {
        val func_generics: *ast.Node = node.info.fun_decl.generics;
        if (func_generics.kind == ast.NODE_GENERIC) {
            val gp_list: *ast.List = func_generics.info.generic_node.args;
            if (gp_list != nil) {
                var gi: i32 = 0;
                for (gi < gp_list.count) {
                    val gp: *ast.Node = gp_list.nodes[gi];
                    if (gp != nil) {
                        val gp_name: str = gp.info.type_name.path;
                        if (gp_name != nil) {
                            val gp_sym_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, gp_name, symbol.SYM_TYPE);
                            if (result_is_ok[*symbol.Symbol, str](gp_sym_res)) {
                                val gp_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](gp_sym_res);
                                val gp_type_res: Result[*type.Type, str] = type.make_generic_param(sema.types, gp_name);
                                if (result_is_ok[*type.Type, str](gp_type_res)) {
                                    gp_sym.resolved_type = result_unwrap_ok[*type.Type, str](gp_type_res);
                                }
                            }
                        }
                    }
                    gi = gi + 1;
                }
            }
        }
    }

    # add parameters to scope
    val params: *ast.List = node.info.fun_decl.params;
    if (params != nil) {
        var i: i32 = 0;
        for (i < params.count) {
            val param: *ast.Node = params.nodes[i];
            if (param != nil) {
                val param_name: str = param.info.field_decl.name;
                if (param_name != nil) {
                    var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
                    if (param.kind == ast.NODE_DECL_VAR) {
                        sym_kind = symbol.SYM_VAR;
                    }
                    val sym_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, param_name, sym_kind);
                    if (result_is_ok[*symbol.Symbol, str](sym_res)) {
                        val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
                        sym.resolved_type = param.type;
                        sym.decl_node = param;
                    }
                }
            }
            i = i + 1;
        }
    }

    # resolve function body
    val body: *ast.Node = node.info.fun_decl.body;
    if (body != nil) {
        resolve_stmt(sema, body);
    }

    # pop symbol table scope (matches push in resolve_function above)
    symbol.table_pop_scope(sema.symbols);

    # pop function scope
    pop_scope(sema);

    # clear current function
    sema.current_fn = nil;
    sema.current_fn_ret = nil;
}

# resolve_stmt: resolve types in a statement.
# ---
# sema: analyzer context
# node: statement node
# ret:  none
fun resolve_stmt(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    # comptime statement
    if (node.kind == ast.NODE_COMPTIME) {
        analyze_comptime_stmt(sema, node);
        ret;
    }

    # block statement
    if (node.kind == ast.NODE_STMT_BLOCK) {
        # create new scope for block
        val push_res: Result[bool, str] = push_scope(sema);
        if (result_is_ok[bool, str](push_res)) {
            symbol.table_push_scope(sema.symbols);
            val stmts: *ast.List = node.info.block_stmt.stmts;
            if (stmts != nil) {
                var i: i32 = 0;
                for (i < stmts.count) {
                    resolve_stmt(sema, stmts.nodes[i]);
                    i = i + 1;
                }
            }
            symbol.table_pop_scope(sema.symbols);
            pop_scope(sema);
        }
        ret;
    }

    # expression statement
    if (node.kind == ast.NODE_STMT_EXPR) {
        val expr: *ast.Node = node.info.wrapper.inner;
        if (expr != nil) {
            resolve_expr_type(sema, expr);
        }
        ret;
    }

    # variable declaration
    if (node.kind == ast.NODE_DECL_VAR || node.kind == ast.NODE_DECL_VAL) {
        val name: str = node.info.var_decl.name;
        val init: *ast.Node = node.info.var_decl.init;
        val type_annot: *ast.Node = node.info.var_decl.type_node;

        # first try to resolve from type annotation
        if (type_annot != nil) {
            val annot_type: *type.Type = resolve_type_expr(sema, type_annot);
            if (annot_type != nil) {
                node.type = annot_type;
            }
        }

        # always resolve initializer for type inference
        if (init != nil) {
            val init_type: *type.Type = resolve_expr_type(sema, init);
            if (node.type == nil && init_type != nil) {
                node.type = init_type;
            }
        }

        if (name != nil) {
            var sym_kind: symbol.SymbolKind = symbol.SYM_VAL;
            if (node.kind == ast.NODE_DECL_VAR) {
                sym_kind = symbol.SYM_VAR;
            }
            val sym_res: Result[*symbol.Symbol, str] = symbol.table_define(sema.symbols, name, sym_kind);
            if (result_is_ok[*symbol.Symbol, str](sym_res)) {
                val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
                sym.resolved_type = node.type;
                sym.decl_node = node;
            }
        }
        ret;
    }

    # return statement
    if (node.kind == ast.NODE_STMT_RET) {
        val ret_expr: *ast.Node = node.info.wrapper.inner;
        if (ret_expr != nil) {
            resolve_expr_type(sema, ret_expr);

            # coerce integer literals to the expected return type
            if (sema.current_fn_ret != nil && type.type_is_integer(sema.current_fn_ret)) {
                # bare literal: ret 42
                if (ret_expr.kind == ast.NODE_EXPR_LIT_INT) {
                    ret_expr.type = sema.current_fn_ret;
                }
                # negated literal: ret -1
                or (ret_expr.kind == ast.NODE_EXPR_UNARY
                    && ret_expr.info.unary_expr.op == token.TAG_MINUS
                    && ret_expr.info.unary_expr.expr != nil
                    && ret_expr.info.unary_expr.expr.kind == ast.NODE_EXPR_LIT_INT) {
                    ret_expr.info.unary_expr.expr.type = sema.current_fn_ret;
                    ret_expr.type = sema.current_fn_ret;
                }
            }
        }
        ret;
    }

    # if statement
    if (node.kind == ast.NODE_STMT_IF) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) {
            resolve_expr_type(sema, cond);
        }

        val then_stmt: *ast.Node = node.info.cond_stmt.body;
        if (then_stmt != nil) {
            resolve_stmt(sema, then_stmt);
        }

        val else_stmt: *ast.Node = node.info.cond_stmt.or_branch;
        if (else_stmt != nil) {
            resolve_stmt(sema, else_stmt);
        }
        ret;
    }

    # or block (else clause of if/or chain)
    if (node.kind == ast.NODE_STMT_OR) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) {
            resolve_expr_type(sema, cond);
        }

        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            resolve_stmt(sema, body);
        }

        val next: *ast.Node = node.info.cond_stmt.or_branch;
        if (next != nil) {
            resolve_stmt(sema, next);
        }
        ret;
    }

    # while/for loop
    if (node.kind == ast.NODE_STMT_FOR) {
        val cond: *ast.Node = node.info.for_stmt.cond;
        if (cond != nil) {
            resolve_expr_type(sema, cond);
        }

        val body: *ast.Node = node.info.for_stmt.body;
        if (body != nil) {
            resolve_stmt(sema, body);
        }
        ret;
    }

    # comptime if ($if) - statement context
    if (node.kind == ast.NODE_COMPTIME_IF) {
        process_comptime_if_stmt(sema, node);
        ret;
    }
}

# process_comptime_if_stmt: process a $if compile-time conditional in statement context.
# ---
# sema: analyzer context
# node: comptime_if node
# ret:  none
fun process_comptime_if_stmt(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    if (node.kind != ast.NODE_COMPTIME_IF && node.kind != ast.NODE_COMPTIME_OR) {
        ret;
    }

    val eval_res: Result[bool, str] = eval_comptime_cond(sema, node);
    if (result_is_err[bool, str](eval_res)) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) {
            report_error_node(sema, cond, "failed to evaluate compile-time condition");
        }
        ret;
    }

    val cond_result: bool = result_unwrap_ok[bool, str](eval_res);

    if (cond_result) {
        val body: *ast.Node = node.info.cond_stmt.body;
        node.info.cond_stmt.or_branch = nil;
        if (body != nil) {
            resolve_stmt(sema, body);
        }
    } or {
        node.info.cond_stmt.body = nil;
        val or_node: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_node != nil) {
            process_comptime_if_stmt(sema, or_node);
            node.info.cond_stmt.body = or_node.info.cond_stmt.body;
            node.info.cond_stmt.or_branch = nil;
        }
    }
}

# analyze_comptime_stmt: handle $attribute assignments and $error.
pub fun analyze_comptime_stmt(sema: *Sema, node: *ast.Node) {
    if (sema == nil || node == nil) {
        ret;
    }

    val inner: *ast.Node = node.info.wrapper.inner;
    if (inner == nil) {
        ret;
    }

    # handle assignment: $symbol.attr = "value"
    if (inner.kind == ast.NODE_EXPR_BINARY) {
        val op: u8 = inner.info.binary_expr.op;
        if (op == token.TAG_EQ) {
            val lhs: *ast.Node = inner.info.binary_expr.left;
            val rhs: *ast.Node = inner.info.binary_expr.right;

            if (rhs == nil || rhs.kind != ast.NODE_EXPR_LIT_STR) {
                report_error_node(sema, inner, "expected string literal for attribute value");
                ret;
            }

            if (lhs == nil || lhs.kind != ast.NODE_EXPR_FIELD) {
                report_error_node(sema, inner, "expected attribute access (e.g. $foo.name)");
                ret;
            }

            val obj: *ast.Node = lhs.info.field_expr.object;
            if (obj == nil || obj.kind != ast.NODE_EXPR_IDENT) {
                report_error_node(sema, inner, "expected symbol identifier");
                ret;
            }

            val sym_opt: Option[*symbol.Symbol] = symbol.table_lookup(sema.symbols, obj.info.ident_expr.name);
            if (option_is_none[*symbol.Symbol](sym_opt)) {
                report_error_node(sema, inner, "undefined symbol");
                ret;
            }

            val field_name: str = lhs.info.field_expr.field;
            if (field_name == nil) {
                report_error_node(sema, inner, "attribute has no name");
                ret;
            }

            # strip quotes from string literal
            val raw: str = rhs.info.lit_expr.text;
            var value: str = raw;
            if (raw != nil && str_len(raw) >= 2 && raw[0] == '"' && raw[str_len(raw) - 1] == '"') {
                val inner_len: usize = str_len(raw) - 2;
                val res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, inner_len + 1);
                if (result_is_err[*u8, allocator.AllocError](res)) {
                    report_error_node(sema, inner, "out of memory");
                    ret;
                }
                val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](res);
                var i: usize = 0;
                for (i < inner_len) {
                    buf[i] = raw[i + 1];
                    i = i + 1;
                }
                buf[inner_len] = 0;
                value = buf::&u8;
            }

            val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
            if (str_equals(field_name, "name") || str_equals(field_name, "symbol")) {
                sym.export_name = value;
            } or {
                report_error_node(sema, inner, "unknown compiletime attribute");
            }

            ret;
        }
    }

    # handle $error("message")
    if (inner.kind == ast.NODE_EXPR_CALL) {
        val func: *ast.Node = inner.info.call_expr.callee;
        if (func != nil && func.kind == ast.NODE_EXPR_IDENT) {
            val name: str = func.info.ident_expr.name;
            if (name != nil && str_equals(name, "error")) {
                val args: *ast.List = inner.info.call_expr.args;
                if (args == nil || args.count != 1) {
                    report_error_node(sema, inner, "expected 1 argument for $error");
                    ret;
                }
                val arg: *ast.Node = args.nodes[0];
                if (arg == nil || arg.kind != ast.NODE_EXPR_LIT_STR) {
                    report_error_node(sema, inner, "expected string literal for error message");
                    ret;
                }
                val raw_msg: str = arg.info.lit_expr.text;
                var msg: str = raw_msg;
                if (raw_msg != nil && str_len(raw_msg) >= 2 && raw_msg[0] == '"' && raw_msg[str_len(raw_msg) - 1] == '"') {
                    val inner_len2: usize = str_len(raw_msg) - 2;
                    val res2: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](sema.alloc, inner_len2 + 1);
                    if (result_is_err[*u8, allocator.AllocError](res2)) {
                        report_error_node(sema, inner, "out of memory");
                        ret;
                    }
                    val buf2: *u8 = result_unwrap_ok[*u8, allocator.AllocError](res2);
                    var j: usize = 0;
                    for (j < inner_len2) {
                        buf2[j] = raw_msg[j + 1];
                        j = j + 1;
                    }
                    buf2[inner_len2] = 0;
                    msg = buf2::&u8;
                }

                report_error_node(sema, inner, msg);
                ret;
            }
        }
    }

    # validate other comptime expressions
    resolve_expr_type(sema, inner);
}
