use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.option;
use std.types.result;

use allocator: std.allocator;

use ast:    mach.compiler.ast;
use symbol: mach.compiler.symbol;
use ty:     mach.compiler.type;
use tyctx:  mach.compiler.type_context;
use token:  mach.compiler.token;

use mach.compiler.sema;

# mach.compiler.sema.resolve: pass 2 — type resolution, expression typing, generic instantiation.

# --- entry point ---

pub fun run(s: *sema.Sema, root: *ast.Node) {
    if (s == nil || root == nil) { ret; }
    val decls: *ast.List = root.info.block_stmt.stmts;
    if (decls == nil) { ret; }

    # 2a: resolve type declarations (defs, rec fields, uni fields)
    resolve_type_decls(s, decls);

    # 2b: resolve function signatures
    resolve_fn_sigs(s, decls);

    # 2c: resolve function bodies
    resolve_fn_bodies(s, decls);
}

# --- phase 2a: type declarations ---

fun resolve_type_decls(s: *sema.Sema, decls: *ast.List) {
    if (decls == nil) { ret; }
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            resolve_type_decl(s, node);
        }
        i = i + 1;
    }
}

fun resolve_type_decl(s: *sema.Sema, node: *ast.Node) {
    if (node == nil) { ret; }

    if (node.kind == ast.NODE_DECL_DEF) {
        resolve_def(s, node);
    }
    if (node.kind == ast.NODE_DECL_REC) {
        resolve_rec_fields(s, node);
    }
    if (node.kind == ast.NODE_DECL_UNI) {
        resolve_uni_fields(s, node);
    }
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { resolve_type_decl(s, inner); }
    }
    if (node.kind == ast.NODE_COMPTIME_IF) {
        resolve_comptime_if_body(s, node, true);
    }
}

fun resolve_def(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.def_decl.name;
    if (name == nil) { ret; }
    val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) { ret; }
    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.resolved_type != nil) { ret; }

    val type_node: *ast.Node = node.info.def_decl.type_node;
    if (type_node == nil) { ret; }
    val t: *ty.Type = resolve_type_expr(s, type_node);
    if (t != nil) {
        sym.resolved_type = t;
        node.ty = t;
    }
}

fun resolve_rec_fields(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.type_decl.name;
    if (name == nil) { ret; }
    val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) { ret; }
    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.is_generic) { ret; }
    if (sym.resolved_type == nil) { ret; }
    if (sym.resolved_type.field_count > 0) { ret; }

    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) { ret; }

    val fields_res: Result[*ty.Field, str] = tyctx.alloc_fields(s.types, ast_fields.count);
    if (result_is_err[*ty.Field, str](fields_res)) { ret; }
    val fields: *ty.Field = result_unwrap_ok[*ty.Field, str](fields_res);
    var count: i32 = 0;
    var offset: usize = 0;
    var max_align: usize = 1;

    var i: i32 = 0;
    for (i < ast_fields.count) {
        val fnode: *ast.Node = ast_fields.nodes[i];
        if (fnode != nil) {
            val fname: str = fnode.info.field_decl.name;
            val ftype_node: *ast.Node = fnode.info.field_decl.type_node;
            var ftype: *ty.Type = nil;
            if (ftype_node != nil) { ftype = resolve_type_expr(s, ftype_node); }
            if (fname != nil && ftype != nil) {
                # alignment padding
                val fa: usize = ty.type_align(ftype);
                if (fa > 0) {
                    val rem: usize = offset % fa;
                    if (rem != 0) { offset = offset + (fa - rem); }
                    if (fa > max_align) { max_align = fa; }
                }
                fields[count].name = fname;
                fields[count].ty = ftype;
                fields[count].offset = offset;
                offset = offset + ty.type_size(ftype);
                count = count + 1;
            }
        }
        i = i + 1;
    }

    # final padding
    val rem: usize = offset % max_align;
    if (rem != 0) { offset = offset + (max_align - rem); }

    sym.resolved_type.fields = fields;
    sym.resolved_type.field_count = count;
    sym.resolved_type.size = offset;
    sym.resolved_type.align = max_align;
}

fun resolve_uni_fields(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.type_decl.name;
    if (name == nil) { ret; }
    val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) { ret; }
    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.is_generic) { ret; }
    if (sym.resolved_type == nil) { ret; }
    if (sym.resolved_type.field_count > 0) { ret; }

    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) { ret; }

    val fields_res: Result[*ty.Field, str] = tyctx.alloc_fields(s.types, ast_fields.count);
    if (result_is_err[*ty.Field, str](fields_res)) { ret; }
    val fields: *ty.Field = result_unwrap_ok[*ty.Field, str](fields_res);
    var count: i32 = 0;
    var max_size: usize = 0;
    var max_align: usize = 1;

    var i: i32 = 0;
    for (i < ast_fields.count) {
        val fnode: *ast.Node = ast_fields.nodes[i];
        if (fnode != nil) {
            val fname: str = fnode.info.field_decl.name;
            val ftype_node: *ast.Node = fnode.info.field_decl.type_node;
            var ftype: *ty.Type = nil;
            if (ftype_node != nil) { ftype = resolve_type_expr(s, ftype_node); }
            if (fname != nil && ftype != nil) {
                fields[count].name = fname;
                fields[count].ty = ftype;
                fields[count].offset = 0;
                val fsz: usize = ty.type_size(ftype);
                val fa: usize = ty.type_align(ftype);
                if (fsz > max_size) { max_size = fsz; }
                if (fa > max_align) { max_align = fa; }
                count = count + 1;
            }
        }
        i = i + 1;
    }

    sym.resolved_type.fields = fields;
    sym.resolved_type.field_count = count;
    sym.resolved_type.size = max_size;
    sym.resolved_type.align = max_align;
}

# --- phase 2b: function signatures ---

fun resolve_fn_sigs(s: *sema.Sema, decls: *ast.List) {
    if (decls == nil) { ret; }
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            resolve_fn_sig_node(s, node);
        }
        i = i + 1;
    }
}

fun resolve_fn_sig_node(s: *sema.Sema, node: *ast.Node) {
    if (node == nil) { ret; }
    if (node.kind == ast.NODE_DECL_FUN) { resolve_fn_sig(s, node); }
    if (node.kind == ast.NODE_DECL_EXT) { resolve_ext_sig(s, node); }
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { resolve_fn_sig_node(s, inner); }
    }
    if (node.kind == ast.NODE_COMPTIME_IF) {
        resolve_comptime_if_body(s, node, false);
    }
}

fun resolve_fn_sig(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.fun_decl.name;
    if (name == nil) { ret; }
    val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) { ret; }
    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.resolved_type != nil) { ret; }

    # resolve return type
    var ret_type: *ty.Type = tyctx.get_void(s.types);
    if (node.info.fun_decl.ret_type != nil) {
        val rt: *ty.Type = resolve_type_expr(s, node.info.fun_decl.ret_type);
        if (rt != nil) { ret_type = rt; }
    }

    # resolve parameters
    var param_types: **ty.Type = nil;
    var param_count: i32 = 0;
    val params: *ast.List = node.info.fun_decl.params;
    if (params != nil && params.count > 0) {
        val pt_res: Result[**ty.Type, str] = tyctx.alloc_params(s.types, params.count);
        if (result_is_ok[**ty.Type, str](pt_res)) {
            param_types = result_unwrap_ok[**ty.Type, str](pt_res);
            param_count = params.count;
            var i: i32 = 0;
            for (i < params.count) {
                val p: *ast.Node = params.nodes[i];
                if (p != nil && p.info.field_decl.type_node != nil) {
                    val pt: *ty.Type = resolve_type_expr(s, p.info.field_decl.type_node);
                    if (pt != nil) {
                        param_types[i] = pt;
                        p.ty = pt;
                    } or {
                        param_types[i] = tyctx.get_void(s.types);
                    }
                }
                i = i + 1;
            }
        }
    }

    # bind generic type parameters if present
    if (node.info.fun_decl.generics != nil) {
        val gen: *ast.Node = node.info.fun_decl.generics;
        if (gen.kind == ast.NODE_GENERIC) {
            val glist: *ast.List = gen.info.generic_node.args;
            if (glist != nil) {
                var gi: i32 = 0;
                for (gi < glist.count) {
                    val gp: *ast.Node = glist.nodes[gi];
                    if (gp != nil) {
                        val gp_name: str = gp.info.type_name.path;
                        if (gp_name != nil) {
                            val gp_type_res: Result[*ty.Type, str] = tyctx.generic_param_type(s.types, gp_name);
                            if (result_is_ok[*ty.Type, str](gp_type_res)) {
                                # bind in scope for function body resolution
                            }
                        }
                    }
                    gi = gi + 1;
                }
            }
        }
    }

    # create function type
    val fun_res: Result[*ty.Type, str] = tyctx.function_type(s.types, param_types, param_count, ret_type);
    if (result_is_ok[*ty.Type, str](fun_res)) {
        val ft: *ty.Type = result_unwrap_ok[*ty.Type, str](fun_res);
        sym.resolved_type = ft;
        node.ty = ft;
    }
}

fun resolve_ext_sig(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.ext_decl.name;
    if (name == nil) { ret; }
    val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) { ret; }
    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.resolved_type != nil) { ret; }

    val inner: *ast.Node = node.info.ext_decl.inner;
    if (inner == nil) { ret; }

    if (inner.kind == ast.NODE_DECL_FUN) {
        resolve_fn_sig(s, inner);
        sym.resolved_type = inner.ty;
        node.ty = inner.ty;
    }
    if (inner.kind == ast.NODE_DECL_VAL || inner.kind == ast.NODE_DECL_VAR) {
        val type_node: *ast.Node = inner.info.var_decl.type_node;
        if (type_node != nil) {
            val t: *ty.Type = resolve_type_expr(s, type_node);
            if (t != nil) {
                sym.resolved_type = t;
                node.ty = t;
                inner.ty = t;
            }
        }
    }
}

# --- phase 2c: function bodies ---

fun resolve_fn_bodies(s: *sema.Sema, decls: *ast.List) {
    if (decls == nil) { ret; }
    var i: i32 = 0;
    for (i < decls.count) {
        val node: *ast.Node = decls.nodes[i];
        if (node != nil) {
            resolve_fn_body_node(s, node);
        }
        i = i + 1;
    }
}

fun resolve_fn_body_node(s: *sema.Sema, node: *ast.Node) {
    if (node == nil) { ret; }
    if (node.kind == ast.NODE_DECL_FUN) { resolve_fn_body(s, node); }
    if (node.kind == ast.NODE_DECL_TEST) { resolve_test_body(s, node); }
    if (node.kind == ast.NODE_DECL_PUB) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { resolve_fn_body_node(s, inner); }
    }
    if (node.kind == ast.NODE_COMPTIME_IF) {
        resolve_comptime_if_body(s, node, false);
    }
    # top-level val/var with initializer
    if (node.kind == ast.NODE_DECL_VAL || node.kind == ast.NODE_DECL_VAR) {
        resolve_top_var(s, node);
    }
}

fun resolve_fn_body(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }
    if (node.info.fun_decl.body == nil) { ret; }

    # skip generic template functions (resolved on instantiation)
    if (node.info.fun_decl.generics != nil) { ret; }

    s.current_fn = node;
    if (node.ty != nil && node.ty.kind == ty.TY_FUN) {
        s.fn_ret_type = node.ty.ret_type;
    } or {
        s.fn_ret_type = tyctx.get_void(s.types);
    }

    # push scope for function body
    sema.push_scope(s);

    # bind parameters
    val params: *ast.List = node.info.fun_decl.params;
    if (params != nil) {
        var i: i32 = 0;
        for (i < params.count) {
            val p: *ast.Node = params.nodes[i];
            if (p != nil && p.info.field_decl.name != nil) {
                val sym_res: Result[*symbol.Symbol, str] = sema.define(s, p.info.field_decl.name, symbol.SYM_PARAM);
                if (result_is_ok[*symbol.Symbol, str](sym_res)) {
                    val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
                    sym.resolved_type = p.ty;
                    sym.decl_node = p;
                }
            }
            i = i + 1;
        }
    }

    resolve_stmt(s, node.info.fun_decl.body);

    sema.pop_scope(s);
    s.current_fn = nil;
    s.fn_ret_type = nil;
}

fun resolve_test_body(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }
    if (node.info.test_decl.body == nil) { ret; }

    s.current_fn = node;
    s.fn_ret_type = tyctx.get_void(s.types);

    sema.push_scope(s);
    resolve_stmt(s, node.info.test_decl.body);
    sema.pop_scope(s);

    s.current_fn = nil;
    s.fn_ret_type = nil;
}

fun resolve_top_var(s: *sema.Sema, node: *ast.Node) {
    val name: str = node.info.var_decl.name;
    if (name == nil) { ret; }
    val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (!option_is_some[*symbol.Symbol](sym_opt)) { ret; }
    val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
    if (sym.resolved_type != nil) { ret; }

    val type_node: *ast.Node = node.info.var_decl.type_node;
    val init: *ast.Node = node.info.var_decl.init;

    if (type_node != nil) {
        val t: *ty.Type = resolve_type_expr(s, type_node);
        if (t != nil) {
            sym.resolved_type = t;
            node.ty = t;
        }
    }
    if (init != nil) {
        val it: *ty.Type = resolve_expr(s, init);
        if (sym.resolved_type == nil && it != nil) {
            sym.resolved_type = it;
            node.ty = it;
        }
    }
}

# --- type expression resolution ---

pub fun resolve_type_expr(s: *sema.Sema, node: *ast.Node) *ty.Type {
    if (s == nil || node == nil) { ret nil; }

    # named type
    if (node.kind == ast.NODE_TYPE_NAME) {
        val name: str = node.info.type_name.path;
        if (name == nil) { ret nil; }

        # check primitives
        if (str_equals(name, "void")) { ret tyctx.get_void(s.types); }
        if (str_equals(name, "bool")) { ret tyctx.get_bool(s.types); }
        if (str_equals(name, "u8"))   { ret tyctx.get_u8(s.types); }
        if (str_equals(name, "u16"))  { ret tyctx.get_u16(s.types); }
        if (str_equals(name, "u32"))  { ret tyctx.get_u32(s.types); }
        if (str_equals(name, "u64"))  { ret tyctx.get_u64(s.types); }
        if (str_equals(name, "i8"))   { ret tyctx.get_i8(s.types); }
        if (str_equals(name, "i16"))  { ret tyctx.get_i16(s.types); }
        if (str_equals(name, "i32"))  { ret tyctx.get_i32(s.types); }
        if (str_equals(name, "i64"))  { ret tyctx.get_i64(s.types); }
        if (str_equals(name, "f32"))  { ret tyctx.get_f32(s.types); }
        if (str_equals(name, "f64"))  { ret tyctx.get_f64(s.types); }
        if (str_equals(name, "ptr"))  { ret tyctx.get_ptr(s.types); }
        if (str_equals(name, "usize")) { ret tyctx.get_usize(s.types); }
        if (str_equals(name, "isize")) { ret tyctx.get_isize(s.types); }
        if (str_equals(name, "str"))  { ret tyctx.get_str(s.types); }
        if (str_equals(name, "va_list")) {
            val va_res: Result[*ty.Type, str] = tyctx.create_type(s.types, ty.TY_RECORD);
            if (result_is_ok[*ty.Type, str](va_res)) {
                val va_t: *ty.Type = result_unwrap_ok[*ty.Type, str](va_res);
                va_t.size = 24;
                va_t.align = 8;
                va_t.name = "va_list";
                ret va_t;
            }
            ret nil;
        }

        # symbol lookup
        val sym: *symbol.Symbol = lookup_type_sym(s, name);
        if (sym != nil) {
            # generic instantiation
            val type_args: *ast.Node = node.info.type_name.args;
            if (type_args != nil && type_args.kind == ast.NODE_GENERIC && sym.is_generic) {
                val inst: *ty.Type = instantiate_generic_type(s, sym, type_args);
                if (inst != nil) { ret inst; }
            }
            if (sym.resolved_type != nil) {
                # on-demand field resolution for cross-module records/unions
                if (sym.resolved_type.field_count == 0 && sym.resolved_type.size == 0 &&
                    !sym.is_generic && !sym.is_being_resolved && sym.decl_node != nil) {
                    val dk: ast.NodeKind = sym.decl_node.kind;
                    if (dk == ast.NODE_DECL_REC) {
                        sym.is_being_resolved = true;
                        resolve_rec_fields(s, sym.decl_node);
                        sym.is_being_resolved = false;
                    }
                    if (dk == ast.NODE_DECL_UNI) {
                        sym.is_being_resolved = true;
                        resolve_uni_fields(s, sym.decl_node);
                        sym.is_being_resolved = false;
                    }
                }
                ret sym.resolved_type;
            }
            # forward reference: resolve def on demand
            if (sym.decl_node != nil && sym.decl_node.kind == ast.NODE_DECL_DEF) {
                val inner: *ast.Node = sym.decl_node.info.def_decl.type_node;
                if (inner != nil) {
                    val t: *ty.Type = resolve_type_expr(s, inner);
                    if (t != nil) {
                        sym.resolved_type = t;
                        sym.decl_node.ty = t;
                        ret t;
                    }
                }
            }
            if (sym.decl_node != nil && sym.decl_node.ty != nil) {
                sym.resolved_type = sym.decl_node.ty;
                ret sym.decl_node.ty;
            }
        }

        # fallback: manual scope walk for generic param bindings
        if (s.current != nil) {
            var fb_scope: *symbol.Scope = s.current.table.current;
            for (fb_scope != nil) {
                var fb_i: i32 = 0;
                for (fb_i < fb_scope.symbol_count) {
                    val fb_sym: *symbol.Symbol = ?fb_scope.symbols[fb_i::usize];
                    if (fb_sym.name != nil && str_equals(fb_sym.name, name)) {
                        if (fb_sym.resolved_type != nil) { ret fb_sym.resolved_type; }
                    }
                    fb_i = fb_i + 1;
                }
                fb_scope = fb_scope.parent;
            }
        }

        sema.report_error(s, node, "undefined type");
        ret nil;
    }

    # pointer type
    if (node.kind == ast.NODE_TYPE_PTR || node.kind == ast.NODE_TYPE_REF) {
        val elem: *ty.Type = resolve_type_expr(s, node.info.type_ptr.inner);
        if (elem != nil) {
            val is_mut: bool = node.kind == ast.NODE_TYPE_PTR;
            val ptr_res: Result[*ty.Type, str] = tyctx.pointer_type(s.types, elem, is_mut);
            if (result_is_ok[*ty.Type, str](ptr_res)) {
                ret result_unwrap_ok[*ty.Type, str](ptr_res);
            }
        }
        ret nil;
    }

    # array type
    if (node.kind == ast.NODE_TYPE_ARRAY) {
        val elem: *ty.Type = resolve_type_expr(s, node.info.type_array.elem_type);
        val size_node: *ast.Node = node.info.type_array.size;
        var size: usize = 0;
        if (size_node != nil && size_node.kind == ast.NODE_EXPR_LIT_INT) {
            size = ast.node_get_int_value(size_node)::usize;
        }
        if (elem != nil && size > 0) {
            val arr_res: Result[*ty.Type, str] = tyctx.array_type(s.types, elem, size);
            if (result_is_ok[*ty.Type, str](arr_res)) {
                ret result_unwrap_ok[*ty.Type, str](arr_res);
            }
        }
        ret nil;
    }

    # function type
    if (node.kind == ast.NODE_TYPE_FUN) {
        var ret_type: *ty.Type = tyctx.get_void(s.types);
        if (node.info.type_fun.ret_type != nil) {
            val rt: *ty.Type = resolve_type_expr(s, node.info.type_fun.ret_type);
            if (rt != nil) { ret_type = rt; }
        }
        var param_types: **ty.Type = nil;
        var param_count: i32 = 0;
        val params: *ast.List = node.info.type_fun.params;
        if (params != nil && params.count > 0) {
            val pt_res: Result[**ty.Type, str] = tyctx.alloc_params(s.types, params.count);
            if (result_is_ok[**ty.Type, str](pt_res)) {
                param_types = result_unwrap_ok[**ty.Type, str](pt_res);
                param_count = params.count;
                var i: i32 = 0;
                for (i < params.count) {
                    val p: *ast.Node = params.nodes[i];
                    if (p != nil) {
                        val pt: *ty.Type = resolve_type_expr(s, p.info.field_decl.type_node);
                        if (pt != nil) { param_types[i] = pt; }
                        or { param_types[i] = tyctx.get_void(s.types); }
                    }
                    i = i + 1;
                }
            }
        }
        val fun_res: Result[*ty.Type, str] = tyctx.function_type(s.types, param_types, param_count, ret_type);
        if (result_is_ok[*ty.Type, str](fun_res)) {
            ret result_unwrap_ok[*ty.Type, str](fun_res);
        }
        ret nil;
    }

    # inline record type
    if (node.kind == ast.NODE_TYPE_REC) {
        ret resolve_inline_rec(s, node);
    }

    # inline union type
    if (node.kind == ast.NODE_TYPE_UNI) {
        ret resolve_inline_uni(s, node);
    }

    ret nil;
}

fun resolve_inline_rec(s: *sema.Sema, node: *ast.Node) *ty.Type {
    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) { ret nil; }

    val fields_res: Result[*ty.Field, str] = tyctx.alloc_fields(s.types, ast_fields.count);
    if (result_is_err[*ty.Field, str](fields_res)) { ret nil; }
    val fields: *ty.Field = result_unwrap_ok[*ty.Field, str](fields_res);
    var count: i32 = 0;

    var i: i32 = 0;
    for (i < ast_fields.count) {
        val fnode: *ast.Node = ast_fields.nodes[i];
        if (fnode != nil) {
            val fname: str = fnode.info.field_decl.name;
            val ft: *ty.Type = resolve_type_expr(s, fnode.info.field_decl.type_node);
            if (fname != nil && ft != nil) {
                fields[count].name = fname;
                fields[count].ty = ft;
                count = count + 1;
            }
        }
        i = i + 1;
    }

    if (count > 0) {
        val rec_res: Result[*ty.Type, str] = tyctx.record_type(s.types, nil, fields, count);
        if (result_is_ok[*ty.Type, str](rec_res)) {
            ret result_unwrap_ok[*ty.Type, str](rec_res);
        }
    }
    ret nil;
}

fun resolve_inline_uni(s: *sema.Sema, node: *ast.Node) *ty.Type {
    val ast_fields: *ast.List = node.info.type_decl.fields;
    if (ast_fields == nil || ast_fields.count == 0) { ret nil; }

    val fields_res: Result[*ty.Field, str] = tyctx.alloc_fields(s.types, ast_fields.count);
    if (result_is_err[*ty.Field, str](fields_res)) { ret nil; }
    val fields: *ty.Field = result_unwrap_ok[*ty.Field, str](fields_res);
    var count: i32 = 0;

    var i: i32 = 0;
    for (i < ast_fields.count) {
        val fnode: *ast.Node = ast_fields.nodes[i];
        if (fnode != nil) {
            val fname: str = fnode.info.field_decl.name;
            val ft: *ty.Type = resolve_type_expr(s, fnode.info.field_decl.type_node);
            if (fname != nil && ft != nil) {
                fields[count].name = fname;
                fields[count].ty = ft;
                fields[count].offset = 0;
                count = count + 1;
            }
        }
        i = i + 1;
    }

    if (count > 0) {
        val uni_res: Result[*ty.Type, str] = tyctx.union_type(s.types, nil, fields, count);
        if (result_is_ok[*ty.Type, str](uni_res)) {
            ret result_unwrap_ok[*ty.Type, str](uni_res);
        }
    }
    ret nil;
}

# --- expression resolution ---

pub fun resolve_expr(s: *sema.Sema, node: *ast.Node) *ty.Type {
    if (s == nil || node == nil) { ret nil; }
    if (node.ty != nil) { ret node.ty; }

    # literals
    if (node.kind == ast.NODE_EXPR_LIT_INT) {
        node.ty = tyctx.get_i64(s.types);
        ret node.ty;
    }
    if (node.kind == ast.NODE_EXPR_LIT_FLOAT) {
        node.ty = tyctx.get_f64(s.types);
        ret node.ty;
    }
    if (node.kind == ast.NODE_EXPR_LIT_STR) {
        node.ty = tyctx.get_str(s.types);
        ret node.ty;
    }
    if (node.kind == ast.NODE_EXPR_LIT_CHAR) {
        node.ty = tyctx.get_u8(s.types);
        ret node.ty;
    }
    if (node.kind == ast.NODE_EXPR_LIT_BOOL) {
        node.ty = tyctx.get_bool(s.types);
        ret node.ty;
    }
    if (node.kind == ast.NODE_EXPR_LIT_NIL) {
        node.ty = tyctx.get_nil(s.types);
        ret node.ty;
    }

    # identifier
    if (node.kind == ast.NODE_EXPR_IDENT) {
        val name: str = node.info.ident_expr.name;
        if (name != nil) {
            val sym_opt: Option[*symbol.Symbol] = sema.lookup(s, name);
            if (option_is_some[*symbol.Symbol](sym_opt)) {
                val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](sym_opt);
                if (sym.resolved_type != nil) {
                    node.ty = sym.resolved_type;
                    ret node.ty;
                }
            }
            sema.report_error(s, node, "undefined identifier");
        }
        ret nil;
    }

    # field access
    if (node.kind == ast.NODE_EXPR_FIELD) {
        ret resolve_field_access(s, node);
    }

    # cast
    if (node.kind == ast.NODE_EXPR_CAST) {
        val inner: *ast.Node = node.info.cast_expr.expr;
        if (inner != nil) { resolve_expr(s, inner); }
        val type_node: *ast.Node = node.info.cast_expr.type_node;
        if (type_node != nil) {
            val t: *ty.Type = resolve_type_expr(s, type_node);
            if (t != nil) { node.ty = t; ret node.ty; }
        }
        ret nil;
    }

    # paren
    if (node.kind == ast.NODE_EXPR_PAREN) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) {
            val t: *ty.Type = resolve_expr(s, inner);
            if (t != nil) { node.ty = t; ret node.ty; }
        }
        ret nil;
    }

    # struct literal
    if (node.kind == ast.NODE_EXPR_STRUCT_LIT) {
        val type_node: *ast.Node = node.info.struct_lit.type_node;
        if (type_node != nil) {
            val t: *ty.Type = resolve_type_expr(s, type_node);
            if (t != nil) {
                node.ty = t;
                val slit_fields: *ast.List = node.info.struct_lit.fields;
                if (slit_fields != nil) {
                    var si: i32 = 0;
                    for (si < slit_fields.count) {
                        val sf: *ast.Node = slit_fields.nodes[si];
                        if (sf != nil && sf.info.field_decl.type_node != nil) {
                            resolve_expr(s, sf.info.field_decl.type_node);
                        }
                        si = si + 1;
                    }
                }
                ret node.ty;
            }
        }
        ret nil;
    }

    # binary
    if (node.kind == ast.NODE_EXPR_BINARY) {
        val lhs: *ty.Type = resolve_expr(s, node.info.binary_expr.left);
        val rhs: *ty.Type = resolve_expr(s, node.info.binary_expr.right);
        val op: u8 = node.info.binary_expr.op;
        # comparison/logical operators → bool
        if (op == token.TAG_EQ_EQ || op == token.TAG_BANG_EQ ||
            op == token.TAG_LT || op == token.TAG_LT_EQ ||
            op == token.TAG_GT || op == token.TAG_GT_EQ ||
            op == token.TAG_AMP_AMP || op == token.TAG_PIPE_PIPE) {
            node.ty = tyctx.get_bool(s.types);
            ret node.ty;
        }
        if (lhs != nil && rhs != nil && ty.type_is_unsigned(rhs) && !ty.type_is_unsigned(lhs)) {
            node.ty = rhs;
            ret node.ty;
        }
        if (lhs != nil) { node.ty = lhs; ret node.ty; }
        if (rhs != nil) { node.ty = rhs; ret node.ty; }
        ret nil;
    }

    # unary
    if (node.kind == ast.NODE_EXPR_UNARY) {
        val t: *ty.Type = resolve_expr(s, node.info.unary_expr.expr);
        if (t != nil) { node.ty = t; ret node.ty; }
        ret nil;
    }

    # call
    if (node.kind == ast.NODE_EXPR_CALL) {
        ret resolve_call(s, node);
    }

    # address-of
    if (node.kind == ast.NODE_EXPR_ADDR) {
        val t: *ty.Type = resolve_expr(s, node.info.unary_expr.expr);
        if (t != nil) {
            val ptr_res: Result[*ty.Type, str] = tyctx.pointer_type(s.types, t, true);
            if (result_is_ok[*ty.Type, str](ptr_res)) {
                node.ty = result_unwrap_ok[*ty.Type, str](ptr_res);
                ret node.ty;
            }
        }
        ret nil;
    }

    # deref
    if (node.kind == ast.NODE_EXPR_DEREF) {
        val t: *ty.Type = resolve_expr(s, node.info.unary_expr.expr);
        if (t != nil && t.kind == ty.TY_POINTER) {
            node.ty = t.inner;
            ret node.ty;
        }
        ret nil;
    }

    # index
    if (node.kind == ast.NODE_EXPR_INDEX) {
        val idx: *ast.Node = node.info.index_expr.index;
        if (idx != nil) { resolve_expr(s, idx); }
        val base: *ast.Node = node.info.index_expr.base;
        if (base != nil) {
            val bt: *ty.Type = resolve_expr(s, base);
            if (bt != nil) {
                if (bt.kind == ty.TY_POINTER && bt.inner != nil) {
                    node.ty = bt.inner;
                    ret node.ty;
                }
                if (bt.kind == ty.TY_ARRAY && bt.inner != nil) {
                    node.ty = bt.inner;
                    ret node.ty;
                }
            }
        }
        ret nil;
    }

    # array literal
    if (node.kind == ast.NODE_EXPR_ARRAY_LIT) {
        val elem_type_node: *ast.Node = node.info.array_lit.type_node;
        val size_node: *ast.Node = node.info.array_lit.size;
        if (elem_type_node != nil) {
            val elem: *ty.Type = resolve_type_expr(s, elem_type_node);
            if (elem != nil && size_node != nil) {
                val count: usize = ast.node_get_int_value(size_node)::usize;
                if (count > 0) {
                    val arr_res: Result[*ty.Type, str] = tyctx.array_type(s.types, elem, count);
                    if (result_is_ok[*ty.Type, str](arr_res)) {
                        node.ty = result_unwrap_ok[*ty.Type, str](arr_res);
                        ret node.ty;
                    }
                }
            }
        }
        ret nil;
    }

    ret nil;
}

# --- field access ---

fun resolve_field_access(s: *sema.Sema, node: *ast.Node) *ty.Type {
    val base: *ast.Node = node.info.field_expr.object;
    val field_name: str = node.info.field_expr.field;
    if (base == nil || field_name == nil) { ret nil; }

    # check if base is a module alias
    if (base.kind == ast.NODE_EXPR_IDENT) {
        val base_name: str = base.info.ident_expr.name;
        if (base_name != nil) {
            val mod_sym_opt: Option[*symbol.Symbol] = sema.lookup(s, base_name);
            if (option_is_some[*symbol.Symbol](mod_sym_opt)) {
                val mod_sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](mod_sym_opt);
                if (mod_sym.kind == symbol.SYM_MODULE && mod_sym.scope != nil) {
                    val field_opt: Option[*symbol.Symbol] = symbol.scope_lookup_local(mod_sym.scope, field_name);
                    if (option_is_some[*symbol.Symbol](field_opt)) {
                        val fs: *symbol.Symbol = option_unwrap[*symbol.Symbol](field_opt);
                        if (fs.resolved_type != nil) {
                            node.ty = fs.resolved_type;
                            ret node.ty;
                        }
                    }
                    ret nil;
                }
            }
        }
    }

    # not a module alias — resolve base type
    val base_ty: *ty.Type = resolve_expr(s, base);
    if (base_ty == nil) { ret nil; }

    # auto-deref pointer to record/union
    var struct_ty: *ty.Type = base_ty;
    if (base_ty.kind == ty.TY_POINTER && base_ty.inner != nil) {
        struct_ty = base_ty.inner;
    }

    if (struct_ty.kind == ty.TY_RECORD || struct_ty.kind == ty.TY_UNION) {
        val field_opt: Option[*ty.Field] = ty.get_field(struct_ty, field_name);
        if (option_is_some[*ty.Field](field_opt)) {
            val f: *ty.Field = option_unwrap[*ty.Field](field_opt);
            node.ty = f.ty;
            ret node.ty;
        }
    }
    ret nil;
}

# --- call resolution ---

fun resolve_call(s: *sema.Sema, node: *ast.Node) *ty.Type {
    # variadic builtins
    val callee: *ast.Node = node.info.call_expr.callee;
    if (callee != nil && callee.kind == ast.NODE_EXPR_IDENT) {
        val va_name: str = callee.info.ident_expr.name;
        if (va_name != nil) {
            if (str_equals(va_name, "va_start") || str_equals(va_name, "va_end")) {
                node.ty = tyctx.get_void(s.types);
                ret node.ty;
            }
            if (str_equals(va_name, "va_arg")) {
                val ta: *ast.Node = node.info.call_expr.type_args;
                if (ta != nil && ta.kind == ast.NODE_GENERIC) {
                    val ta_list: *ast.List = ta.info.generic_node.args;
                    if (ta_list != nil && ta_list.count > 0) {
                        val vat: *ty.Type = resolve_type_expr(s, ta_list.nodes[0]);
                        if (vat != nil) { node.ty = vat; ret node.ty; }
                    }
                }
                node.ty = tyctx.get_void(s.types);
                ret node.ty;
            }
        }
    }

    # resolve arguments
    val args: *ast.List = node.info.call_expr.args;
    if (args != nil) {
        var ai: i32 = 0;
        for (ai < args.count) {
            if (args.nodes[ai] != nil) { resolve_expr(s, args.nodes[ai]); }
            ai = ai + 1;
        }
    }

    if (callee == nil) { ret nil; }

    val callee_type: *ty.Type = resolve_expr(s, callee);
    if (callee_type == nil || callee_type.kind != ty.TY_FUN) { ret nil; }

    val type_args: *ast.Node = node.info.call_expr.type_args;

    # generic function call: ident[T](...)
    if (type_args != nil && callee.kind == ast.NODE_EXPR_IDENT) {
        val func_name: str = callee.info.ident_expr.name;
        if (func_name != nil) {
            val sym: *symbol.Symbol = lookup_fn_sym(s, func_name);
            if (sym != nil && sym.is_generic && sym.decl_node != nil) {
                val ret_ty: *ty.Type = resolve_generic_call_ret(s, sym, type_args);
                val inst_name: str = instantiate_generic_fn(s, sym, type_args);
                if (inst_name != nil) {
                    val inst_opt: Option[*symbol.Symbol] = sema.lookup(s, inst_name);
                    if (option_is_some[*symbol.Symbol](inst_opt)) {
                        node.symbol = option_unwrap[*symbol.Symbol](inst_opt)::ptr;
                    }
                }
                if (ret_ty != nil) { node.ty = ret_ty; ret ret_ty; }
                node.ty = callee_type.ret_type;
                ret node.ty;
            }
        }
    }

    # generic function call: module.func[T](...)
    if (type_args != nil && callee.kind == ast.NODE_EXPR_FIELD) {
        val mq_base: *ast.Node = callee.info.field_expr.object;
        if (mq_base != nil && mq_base.kind == ast.NODE_EXPR_IDENT) {
            val mq_sym: *symbol.Symbol = lookup_module_fn(s, mq_base.info.ident_expr.name, callee.info.field_expr.field);
            if (mq_sym != nil && mq_sym.is_generic && mq_sym.decl_node != nil) {
                val ret_ty: *ty.Type = resolve_generic_call_ret(s, mq_sym, type_args);
                val inst_name: str = instantiate_generic_fn(s, mq_sym, type_args);
                if (inst_name != nil) {
                    val inst_opt: Option[*symbol.Symbol] = sema.lookup(s, inst_name);
                    if (option_is_some[*symbol.Symbol](inst_opt)) {
                        node.symbol = option_unwrap[*symbol.Symbol](inst_opt)::ptr;
                    }
                }
                if (ret_ty != nil) { node.ty = ret_ty; ret ret_ty; }
                node.ty = callee_type.ret_type;
                ret node.ty;
            }
        }
    }

    # non-generic module.func() — attach symbol for lowering
    if (callee.kind == ast.NODE_EXPR_FIELD) {
        val mq_base: *ast.Node = callee.info.field_expr.object;
        if (mq_base != nil && mq_base.kind == ast.NODE_EXPR_IDENT) {
            val mq_sym: *symbol.Symbol = lookup_module_fn(s, mq_base.info.ident_expr.name, callee.info.field_expr.field);
            if (mq_sym != nil) { node.symbol = mq_sym::ptr; }
        }
    }

    node.ty = callee_type.ret_type;
    ret node.ty;
}

# --- statement resolution ---

fun resolve_stmt(s: *sema.Sema, node: *ast.Node) {
    if (s == nil || node == nil) { ret; }

    if (node.kind == ast.NODE_STMT_BLOCK) {
        sema.push_scope(s);
        val stmts: *ast.List = node.info.block_stmt.stmts;
        if (stmts != nil) {
            var i: i32 = 0;
            for (i < stmts.count) {
                resolve_stmt(s, stmts.nodes[i]);
                i = i + 1;
            }
        }
        sema.pop_scope(s);
        ret;
    }

    if (node.kind == ast.NODE_STMT_EXPR) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { resolve_expr(s, inner); }
        ret;
    }

    if (node.kind == ast.NODE_DECL_VAL || node.kind == ast.NODE_DECL_VAR) {
        val name: str = node.info.var_decl.name;
        val type_annot: *ast.Node = node.info.var_decl.type_node;
        val init: *ast.Node = node.info.var_decl.init;

        if (type_annot != nil) {
            val t: *ty.Type = resolve_type_expr(s, type_annot);
            if (t != nil) { node.ty = t; }
        }
        if (init != nil) {
            val it: *ty.Type = resolve_expr(s, init);
            if (node.ty == nil && it != nil) { node.ty = it; }
        }
        if (name != nil) {
            var kind: symbol.SymbolKind = symbol.SYM_VAL;
            if (node.kind == ast.NODE_DECL_VAR) { kind = symbol.SYM_VAR; }
            val sym_res: Result[*symbol.Symbol, str] = sema.define(s, name, kind);
            if (result_is_ok[*symbol.Symbol, str](sym_res)) {
                val sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](sym_res);
                sym.resolved_type = node.ty;
                sym.decl_node = node;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_RET) {
        val expr: *ast.Node = node.info.wrapper.inner;
        if (expr != nil) {
            resolve_expr(s, expr);
            if (expr.kind == ast.NODE_EXPR_LIT_INT && s.fn_ret_type != nil && ty.type_is_integer(s.fn_ret_type)) {
                expr.ty = s.fn_ret_type;
            }
        }
        ret;
    }

    if (node.kind == ast.NODE_STMT_IF) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) { resolve_expr(s, cond); }
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) { resolve_stmt(s, body); }
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) { resolve_stmt(s, or_branch); }
        ret;
    }

    if (node.kind == ast.NODE_STMT_OR || node.kind == ast.NODE_OR_BRANCH) {
        val cond: *ast.Node = node.info.cond_stmt.cond;
        if (cond != nil) { resolve_expr(s, cond); }
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) { resolve_stmt(s, body); }
        val next: *ast.Node = node.info.cond_stmt.or_branch;
        if (next != nil) { resolve_stmt(s, next); }
        ret;
    }

    if (node.kind == ast.NODE_STMT_FOR) {
        val cond: *ast.Node = node.info.for_stmt.cond;
        if (cond != nil) { resolve_expr(s, cond); }
        val body: *ast.Node = node.info.for_stmt.body;
        if (body != nil) { resolve_stmt(s, body); }
        ret;
    }

    if (node.kind == ast.NODE_STMT_FIN) {
        val inner: *ast.Node = node.info.wrapper.inner;
        if (inner != nil) { resolve_stmt(s, inner); }
        ret;
    }

    if (node.kind == ast.NODE_COMPTIME_IF) {
        resolve_comptime_if_body(s, node, false);
        ret;
    }

    if (node.kind == ast.NODE_STMT_MASM) { ret; }
    if (node.kind == ast.NODE_STMT_BRK) { ret; }
    if (node.kind == ast.NODE_STMT_CNT) { ret; }
}

# --- comptime if helper ---

fun resolve_comptime_if_body(s: *sema.Sema, node: *ast.Node, types_only: bool) {
    val eval_res: Result[bool, str] = sema.eval_comptime(s, node);
    if (result_is_err[bool, str](eval_res)) { ret; }
    val taken: bool = result_unwrap_ok[bool, str](eval_res);

    if (taken) {
        val body: *ast.Node = node.info.cond_stmt.body;
        if (body != nil) {
            if (types_only) {
                resolve_comptime_body_types(s, body);
            } or {
                resolve_comptime_body_all(s, body);
            }
        }
    } or {
        val or_branch: *ast.Node = node.info.cond_stmt.or_branch;
        if (or_branch != nil) {
            if (or_branch.kind == ast.NODE_COMPTIME_OR) {
                resolve_comptime_if_body(s, or_branch, types_only);
            } or {
                if (types_only) {
                    resolve_comptime_body_types(s, or_branch);
                } or {
                    resolve_comptime_body_all(s, or_branch);
                }
            }
        }
    }
}

fun resolve_comptime_body_types(s: *sema.Sema, body: *ast.Node) {
    if (body == nil) { ret; }
    if (body.kind == ast.NODE_STMT_BLOCK || body.kind == ast.NODE_PROGRAM || body.kind == ast.NODE_STMT_LIST) {
        val stmts: *ast.List = body.info.block_stmt.stmts;
        if (stmts == nil) { ret; }
        var i: i32 = 0;
        for (i < stmts.count) {
            val n: *ast.Node = stmts.nodes[i];
            if (n != nil) { resolve_type_decl(s, n); }
            i = i + 1;
        }
    } or {
        resolve_type_decl(s, body);
    }
}

fun resolve_comptime_body_all(s: *sema.Sema, body: *ast.Node) {
    if (body == nil) { ret; }
    if (body.kind == ast.NODE_STMT_BLOCK || body.kind == ast.NODE_PROGRAM || body.kind == ast.NODE_STMT_LIST) {
        val stmts: *ast.List = body.info.block_stmt.stmts;
        if (stmts == nil) { ret; }
        var i: i32 = 0;
        for (i < stmts.count) {
            val n: *ast.Node = stmts.nodes[i];
            if (n != nil) { resolve_fn_body_node(s, n); }
            i = i + 1;
        }
    } or {
        resolve_fn_body_node(s, body);
    }
}

# --- symbol lookup helpers ---

fun lookup_type_sym(s: *sema.Sema, name: str) *symbol.Symbol {
    if (s == nil || name == nil) { ret nil; }
    val opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (option_is_some[*symbol.Symbol](opt)) {
        val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](opt);
        if (symbol.symbol_is_type_symbol(sym)) { ret sym; }
    }
    ret nil;
}

fun lookup_fn_sym(s: *sema.Sema, name: str) *symbol.Symbol {
    if (s == nil || name == nil) { ret nil; }
    val opt: Option[*symbol.Symbol] = sema.lookup(s, name);
    if (option_is_some[*symbol.Symbol](opt)) {
        val sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](opt);
        if (symbol.symbol_is_callable(sym)) { ret sym; }
    }
    ret nil;
}

fun lookup_module_fn(s: *sema.Sema, alias_name: str, func_name: str) *symbol.Symbol {
    if (s == nil || alias_name == nil || func_name == nil) { ret nil; }
    val mod_opt: Option[*symbol.Symbol] = sema.lookup(s, alias_name);
    if (!option_is_some[*symbol.Symbol](mod_opt)) { ret nil; }
    val mod_sym: *symbol.Symbol = option_unwrap[*symbol.Symbol](mod_opt);
    if (mod_sym.kind != symbol.SYM_MODULE || mod_sym.scope == nil) { ret nil; }
    val fn_opt: Option[*symbol.Symbol] = symbol.scope_lookup_local(mod_sym.scope, func_name);
    if (option_is_some[*symbol.Symbol](fn_opt)) {
        ret option_unwrap[*symbol.Symbol](fn_opt);
    }
    ret nil;
}

# --- generic type instantiation ---

fun instantiate_generic_type(s: *sema.Sema, sym: *symbol.Symbol, type_args: *ast.Node) *ty.Type {
    if (s == nil || sym == nil || type_args == nil) { ret nil; }
    if (type_args.kind != ast.NODE_GENERIC) { ret nil; }
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil || args_list.count == 0) { ret nil; }

    # resolve concrete type arguments
    val arg_count: i32 = args_list.count;
    val resolved_args_res: Result[**ty.Type, allocator.AllocError] = allocator.allocator_alloc[*ty.Type](s.alloc, arg_count::usize);
    if (result_is_err[**ty.Type, allocator.AllocError](resolved_args_res)) { ret nil; }
    val resolved_args: **ty.Type = result_unwrap_ok[**ty.Type, allocator.AllocError](resolved_args_res);

    var i: i32 = 0;
    for (i < arg_count) {
        val arg_type: *ty.Type = resolve_type_expr(s, args_list.nodes[i]);
        if (arg_type == nil) { ret nil; }
        resolved_args[i] = arg_type;
        i = i + 1;
    }

    # check cache
    var cached: *sema.GenericInst = s.generic_cache;
    for (cached != nil) {
        if (cached.arg_count == arg_count && cached.result != nil) {
            var match: bool = true;
            var ci: i32 = 0;
            for (ci < arg_count) {
                if (!ty.types_equal(cached.args[ci], resolved_args[ci])) {
                    match = false;
                }
                ci = ci + 1;
            }
            if (match) { ret cached.result; }
        }
        cached = cached.next;
    }

    # instantiate based on record or union
    var result_type: *ty.Type = nil;
    if (sym.decl_node == nil) { ret nil; }

    val dk: ast.NodeKind = sym.decl_node.kind;
    if (dk == ast.NODE_DECL_REC) {
        # resolve fields with generic params substituted
        val ast_fields: *ast.List = sym.decl_node.info.type_decl.fields;
        if (ast_fields != nil) {
            val fields_res: Result[*ty.Field, str] = tyctx.alloc_fields(s.types, ast_fields.count);
            if (result_is_err[*ty.Field, str](fields_res)) { ret nil; }
            val fields: *ty.Field = result_unwrap_ok[*ty.Field, str](fields_res);
            var field_count: i32 = 0;

            # push scope with generic bindings
            sema.push_scope(s);
            bind_generic_params(s, sym, resolved_args, arg_count);

            var fi: i32 = 0;
            for (fi < ast_fields.count) {
                val fnode: *ast.Node = ast_fields.nodes[fi];
                if (fnode != nil) {
                    val fname: str = fnode.info.field_decl.name;
                    val ft: *ty.Type = resolve_type_expr(s, fnode.info.field_decl.type_node);
                    if (fname != nil && ft != nil) {
                        fields[field_count].name = fname;
                        fields[field_count].ty = ft;
                        field_count = field_count + 1;
                    }
                }
                fi = fi + 1;
            }
            sema.pop_scope(s);

            val rec_res: Result[*ty.Type, str] = tyctx.record_type(s.types, sym.name, fields, field_count);
            if (result_is_ok[*ty.Type, str](rec_res)) {
                result_type = result_unwrap_ok[*ty.Type, str](rec_res);
                tyctx.set_generic_args(s.types, result_type, ?resolved_args[0], arg_count);
                tyctx.set_base_generic(result_type, sym.resolved_type);
            }
        }
    }

    if (dk == ast.NODE_DECL_UNI) {
        val ast_fields: *ast.List = sym.decl_node.info.type_decl.fields;
        if (ast_fields != nil) {
            val fields_res: Result[*ty.Field, str] = tyctx.alloc_fields(s.types, ast_fields.count);
            if (result_is_err[*ty.Field, str](fields_res)) { ret nil; }
            val fields: *ty.Field = result_unwrap_ok[*ty.Field, str](fields_res);
            var field_count: i32 = 0;

            sema.push_scope(s);
            bind_generic_params(s, sym, resolved_args, arg_count);

            var fi: i32 = 0;
            for (fi < ast_fields.count) {
                val fnode: *ast.Node = ast_fields.nodes[fi];
                if (fnode != nil) {
                    val fname: str = fnode.info.field_decl.name;
                    val ft: *ty.Type = resolve_type_expr(s, fnode.info.field_decl.type_node);
                    if (fname != nil && ft != nil) {
                        fields[field_count].name = fname;
                        fields[field_count].ty = ft;
                        fields[field_count].offset = 0;
                        field_count = field_count + 1;
                    }
                }
                fi = fi + 1;
            }
            sema.pop_scope(s);

            val uni_res: Result[*ty.Type, str] = tyctx.union_type(s.types, sym.name, fields, field_count);
            if (result_is_ok[*ty.Type, str](uni_res)) {
                result_type = result_unwrap_ok[*ty.Type, str](uni_res);
                tyctx.set_generic_args(s.types, result_type, ?resolved_args[0], arg_count);
                tyctx.set_base_generic(result_type, sym.resolved_type);
            }
        }
    }

    # cache result
    if (result_type != nil) {
        val cache_res: Result[*sema.GenericInst, allocator.AllocError] = allocator.allocator_alloc[sema.GenericInst](s.alloc, 1);
        if (result_is_ok[*sema.GenericInst, allocator.AllocError](cache_res)) {
            val entry: *sema.GenericInst = result_unwrap_ok[*sema.GenericInst, allocator.AllocError](cache_res);
            entry.args = resolved_args;
            entry.arg_count = arg_count;
            entry.result = result_type;
            entry.next = s.generic_cache;
            s.generic_cache = entry;
        }
    }

    ret result_type;
}

fun bind_generic_params(s: *sema.Sema, sym: *symbol.Symbol, args: **ty.Type, count: i32) {
    if (sym.generic_node == nil || sym.generic_node.kind != ast.NODE_GENERIC) { ret; }
    val gp_list: *ast.List = sym.generic_node.info.generic_node.args;
    if (gp_list == nil) { ret; }

    var i: i32 = 0;
    for (i < gp_list.count && i < count) {
        val gp: *ast.Node = gp_list.nodes[i];
        if (gp != nil) {
            val gp_name: str = gp.info.type_name.path;
            if (gp_name != nil) {
                val gp_sym_res: Result[*symbol.Symbol, str] = sema.define(s, gp_name, symbol.SYM_TYPE);
                if (result_is_ok[*symbol.Symbol, str](gp_sym_res)) {
                    val gp_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](gp_sym_res);
                    gp_sym.resolved_type = args[i];
                }
            }
        }
        i = i + 1;
    }
}

# --- generic function instantiation ---

fun resolve_generic_call_ret(s: *sema.Sema, sym: *symbol.Symbol, type_args: *ast.Node) *ty.Type {
    if (sym == nil || sym.decl_node == nil || type_args == nil) { ret nil; }
    val ret_node: *ast.Node = sym.decl_node.info.fun_decl.ret_type;
    if (ret_node == nil) { ret tyctx.get_void(s.types); }

    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil) { ret nil; }

    sema.push_scope(s);
    # resolve args and bind
    val gen: *ast.Node = sym.generic_node;
    if (gen != nil && gen.kind == ast.NODE_GENERIC) {
        val gp_list: *ast.List = gen.info.generic_node.args;
        if (gp_list != nil) {
            var i: i32 = 0;
            for (i < gp_list.count && i < args_list.count) {
                val gp: *ast.Node = gp_list.nodes[i];
                if (gp != nil) {
                    val gp_name: str = gp.info.type_name.path;
                    if (gp_name != nil) {
                        val concrete: *ty.Type = resolve_type_expr(s, args_list.nodes[i]);
                        if (concrete != nil) {
                            val gp_sym_res: Result[*symbol.Symbol, str] = sema.define(s, gp_name, symbol.SYM_TYPE);
                            if (result_is_ok[*symbol.Symbol, str](gp_sym_res)) {
                                result_unwrap_ok[*symbol.Symbol, str](gp_sym_res).resolved_type = concrete;
                            }
                        }
                    }
                }
                i = i + 1;
            }
        }
    }
    val ret_type: *ty.Type = resolve_type_expr(s, ret_node);
    sema.pop_scope(s);
    ret ret_type;
}

fun instantiate_generic_fn(s: *sema.Sema, sym: *symbol.Symbol, type_args: *ast.Node) str {
    if (s == nil || sym == nil || sym.decl_node == nil || type_args == nil) { ret nil; }
    val args_list: *ast.List = type_args.info.generic_node.args;
    if (args_list == nil) { ret nil; }

    # build mangled name
    val base_name: str = sym.name;
    if (base_name == nil) { ret nil; }
    val base_len: usize = str_len(base_name);
    val buf_cap: usize = base_len + 256;
    val buf_res: Result[*u8, allocator.AllocError] = allocator.allocator_alloc[u8](s.alloc, buf_cap);
    if (result_is_err[*u8, allocator.AllocError](buf_res)) { ret nil; }
    val buf: *u8 = result_unwrap_ok[*u8, allocator.AllocError](buf_res);

    var pos: usize = 0;
    var bi: usize = 0;
    for (bi < base_len && pos < buf_cap - 1) {
        buf[pos] = base_name[bi];
        pos = pos + 1;
        bi = bi + 1;
    }

    # append type arg mangling
    if (pos < buf_cap - 1) { buf[pos] = '_'; pos = pos + 1; }
    if (pos < buf_cap - 1) { buf[pos] = '_'; pos = pos + 1; }

    var ai: i32 = 0;
    for (ai < args_list.count) {
        val arg_type: *ty.Type = resolve_type_expr(s, args_list.nodes[ai]);
        if (arg_type != nil) {
            val written: i32 = type_mangle(arg_type, ?buf[pos], buf_cap - pos);
            pos = pos + written::usize;
        }
        if (ai + 1 < args_list.count && pos < buf_cap - 1) {
            buf[pos] = '_';
            pos = pos + 1;
        }
        ai = ai + 1;
    }
    buf[pos] = 0;

    val mangled: str = buf::&u8;

    # check dedup map
    val existing: str = sema.spec_map_get(?s.spec_map, mangled);
    if (existing != nil) { ret existing; }

    # register
    sema.spec_map_put(?s.spec_map, s.alloc, mangled, mangled);

    # create a symbol for the instantiation
    val inst_sym_res: Result[*symbol.Symbol, str] = sema.define(s, mangled, symbol.SYM_FUN);
    if (result_is_ok[*symbol.Symbol, str](inst_sym_res)) {
        val inst_sym: *symbol.Symbol = result_unwrap_ok[*symbol.Symbol, str](inst_sym_res);
        # resolve function type with concrete params
        val fn_type: *ty.Type = resolve_generic_call_ret(s, sym, type_args);
        if (fn_type != nil) {
            # need the full function type, not just return type
            # re-resolve the full signature
        }
        inst_sym.decl_node = sym.decl_node;
        inst_sym.resolved_type = sym.resolved_type;
        if (s.current != nil) { inst_sym.module_path = s.current.path; }
    }

    # record the spec
    val spec_res: Result[*sema.FnSpec, allocator.AllocError] = allocator.allocator_alloc[sema.FnSpec](s.alloc, 1);
    if (result_is_ok[*sema.FnSpec, allocator.AllocError](spec_res)) {
        val spec: *sema.FnSpec = result_unwrap_ok[*sema.FnSpec, allocator.AllocError](spec_res);
        spec.func_ast = sym.decl_node;
        spec.mangled = mangled;
        spec.func_type = sym.resolved_type;
        spec.param_count = args_list.count;
        spec.next = s.fn_specs;
        s.fn_specs = spec;
        s.fn_spec_count = s.fn_spec_count + 1;
    }

    ret mangled;
}

# --- type mangling ---

fun type_mangle(t: *ty.Type, buf: *u8, cap: usize) i32 {
    if (t == nil || buf == nil || cap == 0) { ret 0; }

    if (t.kind == ty.TY_VOID)    { buf[0] = 'v'; ret 1; }
    if (t.kind == ty.TY_U8)      { buf[0] = 'h'; ret 1; }
    if (t.kind == ty.TY_U16)     { buf[0] = 't'; ret 1; }
    if (t.kind == ty.TY_U32)     { buf[0] = 'j'; ret 1; }
    if (t.kind == ty.TY_U64)     { buf[0] = 'm'; ret 1; }
    if (t.kind == ty.TY_I8)      { buf[0] = 'a'; ret 1; }
    if (t.kind == ty.TY_I16)     { buf[0] = 's'; ret 1; }
    if (t.kind == ty.TY_I32)     { buf[0] = 'i'; ret 1; }
    if (t.kind == ty.TY_I64)     { buf[0] = 'x'; ret 1; }
    if (t.kind == ty.TY_F32)     { buf[0] = 'f'; ret 1; }
    if (t.kind == ty.TY_F64)     { buf[0] = 'd'; ret 1; }
    if (t.kind == ty.TY_NIL)     { buf[0] = 'n'; ret 1; }
    if (t.kind == ty.TY_PTR)     { buf[0] = 'p'; ret 1; }

    if (t.kind == ty.TY_POINTER) {
        if (cap < 2) { ret 0; }
        buf[0] = 'P';
        val inner_w: i32 = type_mangle(t.inner, ?buf[1], cap - 1);
        ret 1 + inner_w;
    }

    if (t.kind == ty.TY_ARRAY) {
        if (cap < 3) { ret 0; }
        buf[0] = 'A';
        var pos: i32 = 1;
        val arr_len: usize = t.array_len;
        pos = pos + write_digits(buf, pos::usize, arr_len, cap);
        if (pos::usize < cap) { buf[pos::usize] = '_'; pos = pos + 1; }
        val elem_w: i32 = type_mangle(t.inner, ?buf[pos::usize], cap - pos::usize);
        ret pos + elem_w;
    }

    if (t.name != nil) {
        val nlen: usize = str_len(t.name);
        var pos: i32 = 0;
        pos = pos + write_digits(buf, pos::usize, nlen, cap);
        var ni: usize = 0;
        for (ni < nlen && pos::usize < cap) {
            buf[pos::usize] = t.name[ni];
            pos = pos + 1;
            ni = ni + 1;
        }
        ret pos;
    }

    buf[0] = '?';
    ret 1;
}

fun write_digits(buf: *u8, pos: usize, n: usize, cap: usize) i32 {
    if (n == 0) {
        if (pos < cap) { buf[pos] = '0'; ret 1; }
        ret 0;
    }
    var digits: [20]u8;
    var count: i32 = 0;
    var v: usize = n;
    for (v > 0) {
        digits[count] = (v % 10)::u8 + '0';
        v = v / 10;
        count = count + 1;
    }
    var written: i32 = 0;
    var di: i32 = count - 1;
    for (di >= 0) {
        if (pos + written::usize < cap) {
            buf[pos + written::usize] = digits[di];
            written = written + 1;
        }
        di = di - 1;
    }
    ret written;
}
