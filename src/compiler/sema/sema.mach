# mach.compiler.sema.sema: semantic analysis context and phase driver
#
# coordinates the four sema phases across all modules in topological order:
# collect (forward declarations), resolve (names and types), check (body
# type-checking), and validate (final consistency checks).

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;

use module: mach.compiler.sema.module;
use scope:  mach.compiler.sema.scope;
use type:   mach.compiler.sema.type;
use mono:   mach.compiler.sema.mono;
use diag:   mach.compiler.diag;

# top-level semantic analysis context
# ---
# alloc:   backing allocator
# modules: module table (owned externally)
# symbols: symbol table for all modules
# types:   type table for all modules
# mono:    monomorphization cache
# diag:    diagnostic list (owned externally)
# strings: shared string pool (owned externally)
pub rec Sema {
    alloc:   &allocator.Allocator;
    modules: *module.ModuleTable;
    symbols: *scope.SymbolTable;
    types:   *type.TypeTable;
    mono:    *mono.MonoCache;
    diag:    *diag.DiagList;
    strings: ptr;
}

# init: create a semantic analysis context
# ---
# alloc:    allocator for sema-owned tables
# modules:  module table to analyze
# diag:     diagnostic list for error reporting
# strings:  shared string pool for interning
# ptr_size: pointer size in bytes for the target
# ret:      initialized Sema
pub fun init(alloc: &allocator.Allocator, modules: *module.ModuleTable,
             diag: *diag.DiagList, strings: ptr,
             ptr_size: u32) Sema {
    var sema: Sema;
    sema.alloc   = alloc;
    sema.modules = modules;
    sema.diag    = diag;
    sema.strings = strings;

    val res_symbols: Result[*scope.SymbolTable, str] = allocator.allocate[scope.SymbolTable](alloc, 1);
    if (is_ok[*scope.SymbolTable, str](res_symbols)) {
        sema.symbols = unwrap_ok[*scope.SymbolTable, str](res_symbols);
        @sema.symbols = scope.init(alloc);
    } or {
        sema.symbols = nil;
    }

    val res_types: Result[*type.TypeTable, str] = allocator.allocate[type.TypeTable](alloc, 1);
    if (is_ok[*type.TypeTable, str](res_types)) {
        sema.types = unwrap_ok[*type.TypeTable, str](res_types);
        @sema.types = type.init(alloc, ptr_size, ptr_size);
    } or {
        sema.types = nil;
    }

    val res_mono: Result[*mono.MonoCache, str] = allocator.allocate[mono.MonoCache](alloc, 1);
    if (is_ok[*mono.MonoCache, str](res_mono)) {
        sema.mono = unwrap_ok[*mono.MonoCache, str](res_mono);
        @sema.mono = mono.init(alloc);
    } or {
        sema.mono = nil;
    }

    ret sema;
}

# dnit: destroy the sema context, freeing all owned tables
# ---
# sema: sema context to destroy
pub fun dnit(sema: *Sema) {
    if (sema == nil) { ret; }

    if (sema.symbols != nil) {
        scope.dnit(sema.symbols);
        allocator.deallocate[scope.SymbolTable](sema.alloc, sema.symbols, 1);
        sema.symbols = nil;
    }

    if (sema.types != nil) {
        type.dnit(sema.types);
        allocator.deallocate[type.TypeTable](sema.alloc, sema.types, 1);
        sema.types = nil;
    }

    if (sema.mono != nil) {
        mono.dnit(sema.mono);
        allocator.deallocate[mono.MonoCache](sema.alloc, sema.mono, 1);
        sema.mono = nil;
    }
}

