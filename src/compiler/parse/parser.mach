# mach.compiler.parse.parser: recursive descent parser with Pratt expression parsing

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use allocator: std.allocator;
use page:      std.allocator.page;


use token: mach.compiler.lex.token;
use lexer: mach.compiler.lex.lexer;
use ast:   mach.compiler.parse.ast;

pub rec ParseError {
    tok_idx: u32;
    message: str;
}

pub rec ParseResult {
    store:   ast.NodeStore;
    root:    ast.NodeId;
    errors:  *ParseError;
    err_len: u32;
    ok:      bool;
}

rec Parser {
    stream:    *lexer.TokenStream;
    store:     *ast.NodeStore;
    alloc:     &allocator.Allocator;
    pos:       u32;
    errors:    *ParseError;
    err_len:   u32;
    err_cap:   u32;
    panicking: bool;
}

val MAX_CHILDREN: u32 = 1024;
val PREC_ASSIGN: u8 = 0;
val PREC_CALL:   u8 = 12;
val PREC_CAST:   u8 = 13;

# parse: parse a token stream into an AST.
# ---
# stream: token stream from the lexer
# alloc:  backing allocator
# ret:    parse result containing the AST and any errors
pub fun parse(stream: *lexer.TokenStream, alloc: &allocator.Allocator) ParseResult {
    var store: ast.NodeStore = ast.init(alloc);

    var p: Parser;
    p.stream    = stream;
    p.store     = ?store;
    p.alloc     = alloc;
    p.pos       = 0;
    p.errors    = nil;
    p.err_len   = 0;
    p.err_cap   = 0;
    p.panicking = false;

    val root: ast.NodeId = parse_program(?p);

    var result: ParseResult;
    result.store   = store;
    result.root    = root;
    result.errors  = p.errors;
    result.err_len = p.err_len;
    result.ok      = p.err_len == 0;
    ret result;
}

fun advance(p: *Parser) {
    if (p.stream.tokens[p.pos].tag != token.TAG_EOF) {
        p.pos = p.pos + 1;
    }
}

fun current(p: *Parser) token.Token {
    ret p.stream.tokens[p.pos];
}

fun current_tag(p: *Parser) token.Tag {
    ret p.stream.tokens[p.pos].tag;
}

fun current_text(p: *Parser) str {
    ret lexer.text(p.stream, p.stream.tokens[p.pos]);
}

fun current_text_len(p: *Parser) u16 {
    ret p.stream.tokens[p.pos].span.len;
}

fun check(p: *Parser, tag: token.Tag) bool {
    ret current_tag(p) == tag;
}

fun match_tag(p: *Parser, tag: token.Tag) bool {
    if (check(p, tag)) {
        advance(p);
        ret true;
    }
    ret false;
}

fun expect(p: *Parser, tag: token.Tag, msg: str) bool {
    if (check(p, tag)) {
        advance(p);
        ret true;
    }
    error(p, msg);
    ret false;
}

fun is_keyword(p: *Parser, kw: str) bool {
    if (current_tag(p) != token.TAG_IDENT) { ret false; }
    val tok: token.Token = current(p);
    ret str_region_equals(p.stream.source, tok.span.offset::usize, tok.span.len::usize, kw);
}

fun at_end(p: *Parser) bool {
    ret current_tag(p) == token.TAG_EOF;
}

fun error(p: *Parser, message: str) {
    if (p.panicking) { ret; }
    p.panicking = true;

    if (p.err_len >= p.err_cap) {
        var new_cap: u32 = 16;
        if (p.err_cap > 0) {
            new_cap = p.err_cap * 2;
        }
        val res_reallocate: Result[*ParseError, str] = allocator.reallocate[ParseError](
            p.alloc, p.errors, p.err_cap::usize, new_cap::usize);
        if (is_err[*ParseError, str](res_reallocate)) { ret; }
        p.errors  = unwrap_ok[*ParseError, str](res_reallocate);
        p.err_cap = new_cap;
    }

    p.errors[p.err_len].tok_idx = p.pos;
    p.errors[p.err_len].message = message;
    p.err_len = p.err_len + 1;
}

fun synchronize(p: *Parser) {
    p.panicking = false;
    for (!at_end(p)) {
        if (current_tag(p) == token.TAG_SEMI) {
            advance(p);
            ret;
        }
        if (current_tag(p) == token.TAG_RBRACE) {
            advance(p);
            ret;
        }
        if (current_tag(p) == token.TAG_IDENT) {
            if (is_keyword(p, "fun")) { ret; }
            if (is_keyword(p, "rec")) { ret; }
            if (is_keyword(p, "uni")) { ret; }
            if (is_keyword(p, "val")) { ret; }
            if (is_keyword(p, "var")) { ret; }
            if (is_keyword(p, "pub")) { ret; }
            if (is_keyword(p, "use")) { ret; }
            if (is_keyword(p, "def")) { ret; }
            if (is_keyword(p, "ext")) { ret; }
            if (is_keyword(p, "fwd")) { ret; }
            if (is_keyword(p, "test")) { ret; }
        }
        if (current_tag(p) == token.TAG_DOLLAR) {
            ret;
        }
        advance(p);
    }
}

fun intern_token_text(p: *Parser) ast.StrId {
    val tok: token.Token = current(p);
    val txt: str = lexer.text(p.stream, tok);
    ret ast.intern(p.store, txt, tok.span.len::u32);
}

fun parse_program(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    var children: [1024]u32;
    var count: u32 = 0;

    for (!at_end(p)) {
        val child: ast.NodeId = parse_top_level_decl(p);
        if (child != ast.NODE_NIL && count < MAX_CHILDREN) {
            children[count] = child::u32;
            count = count + 1;
        }
    }

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    ret ast.add_node(p.store, ast.NK_PROGRAM, start_tok, p.pos, payload);
}

fun parse_top_level_decl(p: *Parser) ast.NodeId {
    if (is_keyword(p, "pub"))  { ret parse_pub_decl(p); }
    if (is_keyword(p, "use"))  { ret parse_use_decl(p); }
    if (is_keyword(p, "fun"))  { ret parse_fun_decl(p); }
    if (is_keyword(p, "rec"))  { ret parse_rec_decl(p); }
    if (is_keyword(p, "uni"))  { ret parse_uni_decl(p); }
    if (is_keyword(p, "val"))  { ret parse_val_decl(p); }
    if (is_keyword(p, "var"))  { ret parse_var_decl(p); }
    if (is_keyword(p, "def"))  { ret parse_def_decl(p); }
    if (is_keyword(p, "ext"))  { ret parse_ext_decl(p); }
    if (is_keyword(p, "fwd"))  { ret parse_fwd_decl(p); }
    if (is_keyword(p, "test")) { ret parse_test_decl(p); }
    if (current_tag(p) == token.TAG_DOLLAR) { ret parse_comptime(p); }

    error(p, "expected top-level declaration");
    synchronize(p);
    ret ast.NODE_NIL;
}

fun parse_pub_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var inner: ast.NodeId = ast.NODE_NIL;
    if (is_keyword(p, "fun"))  { inner = parse_fun_decl(p); }
    or (is_keyword(p, "rec")) { inner = parse_rec_decl(p); }
    or (is_keyword(p, "uni")) { inner = parse_uni_decl(p); }
    or (is_keyword(p, "val")) { inner = parse_val_decl(p); }
    or (is_keyword(p, "var")) { inner = parse_var_decl(p); }
    or (is_keyword(p, "def")) { inner = parse_def_decl(p); }
    or (is_keyword(p, "ext")) { inner = parse_ext_decl(p); }
    or (is_keyword(p, "fwd")) { inner = parse_fwd_decl(p); }
    or {
        error(p, "expected declaration after 'pub'");
        synchronize(p);
        ret ast.NODE_NIL;
    }

    val payload: u32 = ast.add_extra(p.store, inner::u32);
    ret ast.add_node(p.store, ast.NK_DECL_PUB, start_tok, p.pos, payload);
}

fun parse_use_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var alias: ast.StrId = ast.STR_NIL;

    if (current_tag(p) == token.TAG_IDENT) {
        val save_pos: u32 = p.pos;
        val maybe_alias: ast.StrId = intern_token_text(p);
        advance(p);

        if (current_tag(p) == token.TAG_COLON) {
            alias = maybe_alias;
            advance(p);
        } or {
            p.pos = save_pos;
        }
    }

    var path_buf: [256]u8;
    var path_len: u32 = 0;

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected module path in use declaration");
        synchronize(p);
        ret ast.NODE_NIL;
    }

    var tok: token.Token = current(p);
    var seg: str = lexer.text(p.stream, tok);
    var seg_len: u16 = tok.span.len;
    var i: u32 = 0;
    for (i < seg_len::u32 && path_len < 255) {
        path_buf[path_len] = seg[i];
        path_len = path_len + 1;
        i = i + 1;
    }
    advance(p);

    for (current_tag(p) == token.TAG_DOT) {
        advance(p);
        if (path_len < 255) {
            path_buf[path_len] = '.';
            path_len = path_len + 1;
        }
        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected identifier after '.' in use path");
            synchronize(p);
            ret ast.NODE_NIL;
        }
        tok = current(p);
        seg = lexer.text(p.stream, tok);
        seg_len = tok.span.len;
        i = 0;
        for (i < seg_len::u32 && path_len < 255) {
            path_buf[path_len] = seg[i];
            path_len = path_len + 1;
            i = i + 1;
        }
        advance(p);
    }

    path_buf[path_len] = 0;
    val path_str: ast.StrId = ast.intern(p.store, (?path_buf[0])::str, path_len);

    expect(p, token.TAG_SEMI, "expected ';' after use declaration");

    val payload: u32 = ast.add_extra(p.store, path_str::u32);
    ast.add_extra(p.store, alias::u32);

    ret ast.add_node(p.store, ast.NK_DECL_USE, start_tok, p.pos, payload);
}

fun parse_fun_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected function name");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    var generics: ast.NodeId = ast.NODE_NIL;
    if (current_tag(p) == token.TAG_LBRACKET) {
        generics = parse_generic_params(p);
    }

    val params: ast.NodeSpan = parse_param_list(p);

    var ret_type: ast.NodeId = ast.NODE_NIL;
    if (!check(p, token.TAG_LBRACE) && !check(p, token.TAG_SEMI)) {
        ret_type = parse_type(p);
    }

    var body: ast.NodeId = ast.NODE_NIL;
    if (check(p, token.TAG_LBRACE)) {
        body = parse_block(p);
    } or {
        expect(p, token.TAG_SEMI, "expected '{' or ';' after function signature");
    }

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, params.start);
    ast.add_extra(p.store, params.len);
    ast.add_extra(p.store, ret_type::u32);
    ast.add_extra(p.store, body::u32);
    ast.add_extra(p.store, generics::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_FUN, start_tok, p.pos, payload);
}

fun parse_rec_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected record name");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    var generics: ast.NodeId = ast.NODE_NIL;
    if (current_tag(p) == token.TAG_LBRACKET) {
        generics = parse_generic_params(p);
    }

    val fields: ast.NodeSpan = parse_field_list(p);

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, fields.start);
    ast.add_extra(p.store, fields.len);
    ast.add_extra(p.store, generics::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_REC, start_tok, p.pos, payload);
}

fun parse_uni_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected union name");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    var generics: ast.NodeId = ast.NODE_NIL;
    if (current_tag(p) == token.TAG_LBRACKET) {
        generics = parse_generic_params(p);
    }

    val fields: ast.NodeSpan = parse_field_list(p);

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, fields.start);
    ast.add_extra(p.store, fields.len);
    ast.add_extra(p.store, generics::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_UNI, start_tok, p.pos, payload);
}

fun parse_val_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected variable name");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    var type_node: ast.NodeId = ast.NODE_NIL;
    if (match_tag(p, token.TAG_COLON)) {
        type_node = parse_type(p);
    }

    var init_expr: ast.NodeId = ast.NODE_NIL;
    if (match_tag(p, token.TAG_EQ)) {
        init_expr = parse_expression(p, 0);
    }

    expect(p, token.TAG_SEMI, "expected ';' after val declaration");

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, type_node::u32);
    ast.add_extra(p.store, init_expr::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_VAL, start_tok, p.pos, payload);
}

fun parse_var_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected variable name");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    var type_node: ast.NodeId = ast.NODE_NIL;
    if (match_tag(p, token.TAG_COLON)) {
        type_node = parse_type(p);
    }

    var init_expr: ast.NodeId = ast.NODE_NIL;
    if (match_tag(p, token.TAG_EQ)) {
        init_expr = parse_expression(p, 0);
    }

    expect(p, token.TAG_SEMI, "expected ';' after var declaration");

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, type_node::u32);
    ast.add_extra(p.store, init_expr::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_VAR, start_tok, p.pos, payload);
}

fun parse_def_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected type alias name");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    expect(p, token.TAG_COLON, "expected ':' after def name");
    val type_node: ast.NodeId = parse_type(p);
    expect(p, token.TAG_SEMI, "expected ';' after def declaration");

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, type_node::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_DEF, start_tok, p.pos, payload);
}

fun parse_ext_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var abi_str: ast.StrId = ast.STR_NIL;
    if (current_tag(p) == token.TAG_LIT_STRING) {
        abi_str = intern_token_text(p);
        advance(p);
    }

    if (!is_keyword(p, "fun")) {
        error(p, "expected 'fun' in ext declaration");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected function name in ext declaration");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val name: ast.StrId = intern_token_text(p);
    advance(p);

    val params: ast.NodeSpan = parse_param_list(p);

    var ret_type: ast.NodeId = ast.NODE_NIL;
    if (!check(p, token.TAG_SEMI)) {
        ret_type = parse_type(p);
    }

    expect(p, token.TAG_SEMI, "expected ';' after ext declaration");

    val payload: u32 = ast.add_extra(p.store, abi_str::u32);
    ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, params.start);
    ast.add_extra(p.store, params.len);
    ast.add_extra(p.store, ret_type::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_EXT, start_tok, p.pos, payload);
}

fun parse_fwd_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected identifier after 'fwd'");
        synchronize(p);
        ret ast.NODE_NIL;
    }
    val first: ast.StrId = intern_token_text(p);
    advance(p);

    var name: ast.StrId = ast.STR_NIL;
    var module_alias: ast.StrId = ast.STR_NIL;
    var symbol_name: ast.StrId = ast.STR_NIL;

    if (current_tag(p) == token.TAG_COLON) {
        advance(p);
        name = first;
        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected module alias after ':'");
            synchronize(p);
            ret ast.NODE_NIL;
        }
        module_alias = intern_token_text(p);
        advance(p);
        expect(p, token.TAG_DOT, "expected '.' after module alias");
        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected symbol name after '.'");
            synchronize(p);
            ret ast.NODE_NIL;
        }
        symbol_name = intern_token_text(p);
        advance(p);
    } or (current_tag(p) == token.TAG_DOT) {
        advance(p);
        module_alias = first;
        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected symbol name after '.'");
            synchronize(p);
            ret ast.NODE_NIL;
        }
        symbol_name = intern_token_text(p);
        name = symbol_name;
        advance(p);
    } or {
        error(p, "expected '.' or ':' after identifier in fwd declaration");
        synchronize(p);
        ret ast.NODE_NIL;
    }

    expect(p, token.TAG_SEMI, "expected ';' after fwd declaration");

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, module_alias::u32);
    ast.add_extra(p.store, symbol_name::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_FWD, start_tok, p.pos, payload);
}

fun parse_test_decl(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var name: ast.StrId = ast.STR_NIL;
    if (current_tag(p) == token.TAG_LIT_STRING) {
        name = intern_token_text(p);
        advance(p);
    }

    val body: ast.NodeId = parse_block(p);

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, body::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_DECL_TEST, start_tok, p.pos, payload);
}

fun parse_type_fun_params(p: *Parser) ast.NodeSpan {
    var span: ast.NodeSpan;
    span.start = 0;
    span.len   = 0;

    if (!expect(p, token.TAG_LPAREN, "expected '(' for function type parameters")) {
        ret span;
    }

    var children: [256]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RPAREN) && !at_end(p)) {
        if (count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between parameters")) {
                brk;
            }
        }

        val param_tok: u32 = p.pos;

        if (current_tag(p) == token.TAG_DOT_DOT_DOT) {
            val va_name: ast.StrId = ast.intern(p.store, "...", 3);
            advance(p);
            val va_payload: u32 = ast.add_extra(p.store, va_name::u32);
            ast.add_extra(p.store, ast.NODE_NIL::u32);
            val va_node: ast.NodeId = ast.add_node(p.store, ast.NK_PARAM, param_tok, p.pos, va_payload);
            if (count < 256) {
                children[count] = va_node::u32;
                count = count + 1;
            }
            brk;
        }

        val ptype: ast.NodeId = parse_type(p);
        val pname: ast.StrId = ast.intern(p.store, "_", 1);

        val ppayload: u32 = ast.add_extra(p.store, pname::u32);
        ast.add_extra(p.store, ptype::u32);

        val pnode: ast.NodeId = ast.add_node(p.store, ast.NK_PARAM, param_tok, p.pos, ppayload);
        if (count < 256) {
            children[count] = pnode::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RPAREN, "expected ')' after function type parameters");

    span.start = ast.add_extra_slice(p.store, ?children[0], count);
    span.len   = count;
    ret span;
}

fun parse_param_list(p: *Parser) ast.NodeSpan {
    var span: ast.NodeSpan;
    span.start = 0;
    span.len   = 0;

    if (!expect(p, token.TAG_LPAREN, "expected '(' for parameter list")) {
        ret span;
    }

    var children: [256]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RPAREN) && !at_end(p)) {
        if (count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between parameters")) {
                brk;
            }
        }

        val param_tok: u32 = p.pos;

        if (current_tag(p) == token.TAG_DOT_DOT_DOT) {
            val va_name: ast.StrId = ast.intern(p.store, "...", 3);
            advance(p);
            val va_payload: u32 = ast.add_extra(p.store, va_name::u32);
            ast.add_extra(p.store, ast.NODE_NIL::u32);
            val va_node: ast.NodeId = ast.add_node(p.store, ast.NK_PARAM, param_tok, p.pos, va_payload);
            if (count < 256) {
                children[count] = va_node::u32;
                count = count + 1;
            }
            brk;
        }

        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected parameter name");
            synchronize(p);
            brk;
        }
        val pname: ast.StrId = intern_token_text(p);
        advance(p);

        expect(p, token.TAG_COLON, "expected ':' after parameter name");
        val ptype: ast.NodeId = parse_type(p);

        val ppayload: u32 = ast.add_extra(p.store, pname::u32);
        ast.add_extra(p.store, ptype::u32);

        val pnode: ast.NodeId = ast.add_node(p.store, ast.NK_PARAM, param_tok, p.pos, ppayload);
        if (count < 256) {
            children[count] = pnode::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RPAREN, "expected ')' after parameter list");

    span.start = ast.add_extra_slice(p.store, ?children[0], count);
    span.len   = count;
    ret span;
}

fun parse_field_list(p: *Parser) ast.NodeSpan {
    var span: ast.NodeSpan;
    span.start = 0;
    span.len   = 0;

    if (!expect(p, token.TAG_LBRACE, "expected '{' for field list")) {
        ret span;
    }

    var children: [256]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACE) && !at_end(p)) {
        val field_tok: u32 = p.pos;

        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected field name");
            synchronize(p);
            cnt;
        }
        val fname: ast.StrId = intern_token_text(p);
        advance(p);

        expect(p, token.TAG_COLON, "expected ':' after field name");
        val ftype: ast.NodeId = parse_type(p);
        expect(p, token.TAG_SEMI, "expected ';' after field declaration");

        val fpayload: u32 = ast.add_extra(p.store, fname::u32);
        ast.add_extra(p.store, ftype::u32);

        val fnode: ast.NodeId = ast.add_node(p.store, ast.NK_FIELD, field_tok, p.pos, fpayload);
        if (count < 256) {
            children[count] = fnode::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACE, "expected '}' after field list");

    span.start = ast.add_extra_slice(p.store, ?children[0], count);
    span.len   = count;
    ret span;
}

fun parse_generic_params(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var children: [64]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACKET) && !at_end(p)) {
        if (count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between generic parameters")) {
                brk;
            }
        }

        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected generic parameter name");
            synchronize(p);
            brk;
        }

        val gname: ast.StrId = intern_token_text(p);
        advance(p);

        val gpayload: u32 = ast.add_extra(p.store, gname::u32);
        val gnode: ast.NodeId = ast.add_node(p.store, ast.NK_EXPR_IDENT, start_tok, p.pos, gpayload);
        if (count < 64) {
            children[count] = gnode::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACKET, "expected ']' after generic parameters");

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    ret ast.add_node(p.store, ast.NK_GENERIC_PARAMS, start_tok, p.pos, payload);
}

fun parse_stmt(p: *Parser) ast.NodeId {
    if (is_keyword(p, "if"))  { ret parse_if_stmt(p); }
    if (is_keyword(p, "for")) { ret parse_for_stmt(p); }
    if (is_keyword(p, "ret")) { ret parse_ret_stmt(p); }
    if (is_keyword(p, "brk")) {
        val brk_tok: u32 = p.pos;
        advance(p);
        expect(p, token.TAG_SEMI, "expected ';' after 'brk'");
        p.panicking = false;
        ret ast.add_node(p.store, ast.NK_STMT_BRK, brk_tok, p.pos, 0);
    }
    if (is_keyword(p, "cnt")) {
        val cnt_tok: u32 = p.pos;
        advance(p);
        expect(p, token.TAG_SEMI, "expected ';' after 'cnt'");
        p.panicking = false;
        ret ast.add_node(p.store, ast.NK_STMT_CNT, cnt_tok, p.pos, 0);
    }
    if (is_keyword(p, "fin")) { ret parse_fin_stmt(p); }
    if (is_keyword(p, "val")) { ret parse_val_decl(p); }
    if (is_keyword(p, "var")) { ret parse_var_decl(p); }
    if (is_keyword(p, "asm")) { ret parse_asm_stmt(p); }
    if (current_tag(p) == token.TAG_DOLLAR) { ret parse_comptime(p); }
    if (current_tag(p) == token.TAG_LBRACE) { ret parse_block(p); }

    val expr_tok: u32 = p.pos;
    val expr: ast.NodeId = parse_expression(p, 0);
    if (expr == ast.NODE_NIL) {
        synchronize(p);
        ret ast.NODE_NIL;
    }

    expect(p, token.TAG_SEMI, "expected ';' after expression statement");

    val payload: u32 = ast.add_extra(p.store, expr::u32);
    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_EXPR, expr_tok, p.pos, payload);
}

fun parse_block(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    if (!expect(p, token.TAG_LBRACE, "expected '{'")) {
        ret ast.NODE_NIL;
    }

    var children: [1024]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACE) && !at_end(p)) {
        val child: ast.NodeId = parse_stmt(p);
        if (child != ast.NODE_NIL && count < MAX_CHILDREN) {
            children[count] = child::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACE, "expected '}'");

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_BLOCK, start_tok, p.pos, payload);
}

fun parse_comptime_block(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    if (!expect(p, token.TAG_LBRACE, "expected '{'")) {
        ret ast.NODE_NIL;
    }

    var children: [1024]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACE) && !at_end(p)) {
        val child: ast.NodeId = parse_block_item(p);
        if (child != ast.NODE_NIL && count < MAX_CHILDREN) {
            children[count] = child::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACE, "expected '}'");

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_BLOCK, start_tok, p.pos, payload);
}

fun parse_block_item(p: *Parser) ast.NodeId {
    if (is_keyword(p, "pub"))  { ret parse_pub_decl(p); }
    if (is_keyword(p, "use"))  { ret parse_use_decl(p); }
    if (is_keyword(p, "fun"))  { ret parse_fun_decl(p); }
    if (is_keyword(p, "rec"))  { ret parse_rec_decl(p); }
    if (is_keyword(p, "uni"))  { ret parse_uni_decl(p); }
    if (is_keyword(p, "def"))  { ret parse_def_decl(p); }
    if (is_keyword(p, "ext"))  { ret parse_ext_decl(p); }
    if (is_keyword(p, "fwd"))  { ret parse_fwd_decl(p); }
    if (is_keyword(p, "test")) { ret parse_test_decl(p); }
    ret parse_stmt(p);
}

fun parse_if_stmt(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    expect(p, token.TAG_LPAREN, "expected '(' after 'if'");
    val cond: ast.NodeId = parse_expression(p, 0);
    expect(p, token.TAG_RPAREN, "expected ')' after if condition");

    val body: ast.NodeId = parse_block(p);

    var or_chain: ast.NodeId = ast.NODE_NIL;
    if (is_keyword(p, "or")) {
        or_chain = parse_or_chain(p);
    }

    val payload: u32 = ast.add_extra(p.store, cond::u32);
    ast.add_extra(p.store, body::u32);
    ast.add_extra(p.store, or_chain::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_IF, start_tok, p.pos, payload);
}

fun parse_or_chain(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (check(p, token.TAG_LPAREN)) {
        advance(p);
        val cond: ast.NodeId = parse_expression(p, 0);
        expect(p, token.TAG_RPAREN, "expected ')' after or condition");

        val body: ast.NodeId = parse_block(p);

        var next_or: ast.NodeId = ast.NODE_NIL;
        if (is_keyword(p, "or")) {
            next_or = parse_or_chain(p);
        }

        val payload: u32 = ast.add_extra(p.store, cond::u32);
        ast.add_extra(p.store, body::u32);
        ast.add_extra(p.store, next_or::u32);

        ret ast.add_node(p.store, ast.NK_STMT_OR, start_tok, p.pos, payload);
    }

    val body: ast.NodeId = parse_block(p);

    val payload: u32 = ast.add_extra(p.store, ast.NODE_NIL::u32);
    ast.add_extra(p.store, body::u32);
    ast.add_extra(p.store, ast.NODE_NIL::u32);

    ret ast.add_node(p.store, ast.NK_STMT_OR, start_tok, p.pos, payload);
}

fun parse_for_stmt(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var cond: ast.NodeId = ast.NODE_NIL;
    if (check(p, token.TAG_LPAREN)) {
        advance(p);
        cond = parse_expression(p, 0);
        expect(p, token.TAG_RPAREN, "expected ')' after for condition");
    }

    val body: ast.NodeId = parse_block(p);

    val payload: u32 = ast.add_extra(p.store, cond::u32);
    ast.add_extra(p.store, body::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_FOR, start_tok, p.pos, payload);
}

fun parse_ret_stmt(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var value: ast.NodeId = ast.NODE_NIL;
    if (!check(p, token.TAG_SEMI)) {
        value = parse_expression(p, 0);
    }

    expect(p, token.TAG_SEMI, "expected ';' after ret statement");

    val payload: u32 = ast.add_extra(p.store, value::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_RET, start_tok, p.pos, payload);
}

fun parse_fin_stmt(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var body: ast.NodeId = ast.NODE_NIL;
    if (check(p, token.TAG_LBRACE)) {
        body = parse_block(p);
    } or {
        body = parse_stmt(p);
    }

    val payload: u32 = ast.add_extra(p.store, body::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_FIN, start_tok, p.pos, payload);
}

fun parse_asm_stmt(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (!expect(p, token.TAG_LBRACE, "expected '{' after 'asm'")) {
        ret ast.NODE_NIL;
    }

    val text_start: u32 = p.stream.tokens[p.pos].span.offset;
    var depth: u32 = 1;

    for (depth > 0 && !at_end(p)) {
        if (current_tag(p) == token.TAG_LBRACE) {
            depth = depth + 1;
        }
        or (current_tag(p) == token.TAG_RBRACE) {
            depth = depth - 1;
            if (depth == 0) { brk; }
        }
        advance(p);
    }

    val text_end: u32 = p.stream.tokens[p.pos].span.offset;
    val asm_text: str = (p.stream.source::usize + text_start::usize)::str;
    val asm_len: u32 = text_end - text_start;
    val asm_str: ast.StrId = ast.intern(p.store, asm_text, asm_len);

    expect(p, token.TAG_RBRACE, "expected '}' after asm block");

    val payload: u32 = ast.add_extra(p.store, asm_str::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_STMT_ASM, start_tok, p.pos, payload);
}

fun parse_comptime(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (is_keyword(p, "if")) {
        ret parse_comptime_if(p);
    }

    val inner: ast.NodeId = parse_expression(p, 0);
    expect(p, token.TAG_SEMI, "expected ';' after comptime expression");

    val payload: u32 = ast.add_extra(p.store, inner::u32);
    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_COMPTIME, start_tok, p.pos, payload);
}

fun parse_comptime_if(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    expect(p, token.TAG_LPAREN, "expected '(' after '$if'");
    val cond: ast.NodeId = parse_expression(p, 0);
    expect(p, token.TAG_RPAREN, "expected ')' after comptime if condition");

    val body: ast.NodeId = parse_comptime_block(p);

    var or_chain: ast.NodeId = ast.NODE_NIL;
    if (current_tag(p) == token.TAG_DOLLAR) {
        val save: u32 = p.pos;
        advance(p);
        if (is_keyword(p, "or")) {
            or_chain = parse_comptime_or(p);
        } or {
            p.pos = save;
        }
    }

    val payload: u32 = ast.add_extra(p.store, cond::u32);
    ast.add_extra(p.store, body::u32);
    ast.add_extra(p.store, or_chain::u32);

    p.panicking = false;
    ret ast.add_node(p.store, ast.NK_COMPTIME_IF, start_tok, p.pos, payload);
}

fun parse_comptime_or(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (check(p, token.TAG_LPAREN)) {
        advance(p);
        val cond: ast.NodeId = parse_expression(p, 0);
        expect(p, token.TAG_RPAREN, "expected ')' after comptime or condition");

        val body: ast.NodeId = parse_comptime_block(p);

        var next_or: ast.NodeId = ast.NODE_NIL;
        if (current_tag(p) == token.TAG_DOLLAR) {
            val save: u32 = p.pos;
            advance(p);
            if (is_keyword(p, "or")) {
                next_or = parse_comptime_or(p);
            } or {
                p.pos = save;
            }
        }

        val payload: u32 = ast.add_extra(p.store, cond::u32);
        ast.add_extra(p.store, body::u32);
        ast.add_extra(p.store, next_or::u32);

        ret ast.add_node(p.store, ast.NK_COMPTIME_OR, start_tok, p.pos, payload);
    }

    val body: ast.NodeId = parse_comptime_block(p);

    val payload: u32 = ast.add_extra(p.store, ast.NODE_NIL::u32);
    ast.add_extra(p.store, body::u32);
    ast.add_extra(p.store, ast.NODE_NIL::u32);

    ret ast.add_node(p.store, ast.NK_COMPTIME_OR, start_tok, p.pos, payload);
}

fun parse_expression(p: *Parser, min_prec: u8) ast.NodeId {
    var left: ast.NodeId = parse_prefix(p);
    if (left == ast.NODE_NIL) { ret ast.NODE_NIL; }

    for (!at_end(p)) {
        val tag: token.Tag = current_tag(p);

        if (tag == token.TAG_LPAREN) {
            if (min_prec > PREC_CALL) { brk; }
            left = parse_call_expr(p, left);
            cnt;
        }
        if (tag == token.TAG_LBRACKET) {
            if (min_prec > PREC_CALL) { brk; }
            if (is_type_arg_bracket(p)) {
                left = parse_generic_call(p, left);
            } or {
                left = parse_index_expr(p, left);
            }
            cnt;
        }
        if (tag == token.TAG_DOT) {
            if (min_prec > PREC_CALL) { brk; }
            left = parse_field_expr(p, left);
            cnt;
        }
        if (tag == token.TAG_COLON_COLON) {
            if (min_prec > PREC_CAST) { brk; }
            left = parse_cast_expr(p, left);
            cnt;
        }
        if (tag == token.TAG_LBRACE) {
            if (min_prec > PREC_CALL) { brk; }
            left = parse_typed_literal(p, left);
            cnt;
        }

        if (tag == token.TAG_EQ) {
            if (min_prec > PREC_ASSIGN) { brk; }
            val op_tok: u32 = p.pos;
            advance(p);
            val rhs: ast.NodeId = parse_expression(p, 0);
            val payload: u32 = ast.add_extra(p.store, left::u32);
            ast.add_extra(p.store, rhs::u32);
            ast.add_extra(p.store, token.TAG_EQ::u32);
            left = ast.add_node(p.store, ast.NK_EXPR_BINARY, op_tok, p.pos, payload);
            cnt;
        }

        val prec: u8 = token.infix_precedence(tag);
        if (prec == 0 || prec < min_prec) { brk; }

        val op_tok: u32 = p.pos;
        advance(p);

        var next_prec: u8 = prec + 1;
        if (token.is_right_assoc(tag)) {
            next_prec = prec;
        }

        val rhs: ast.NodeId = parse_expression(p, next_prec);

        val payload: u32 = ast.add_extra(p.store, left::u32);
        ast.add_extra(p.store, rhs::u32);
        ast.add_extra(p.store, tag::u32);

        left = ast.add_node(p.store, ast.NK_EXPR_BINARY, op_tok, p.pos, payload);
    }

    ret left;
}

fun parse_prefix(p: *Parser) ast.NodeId {
    val tag: token.Tag = current_tag(p);
    val start_tok: u32 = p.pos;

    if (tag == token.TAG_IDENT) {
        if (is_keyword(p, "true")) {
            advance(p);
            val payload: u32 = ast.add_extra(p.store, 1);
            ret ast.add_node(p.store, ast.NK_EXPR_LIT_BOOL, start_tok, p.pos, payload);
        }
        if (is_keyword(p, "false")) {
            advance(p);
            val payload: u32 = ast.add_extra(p.store, 0);
            ret ast.add_node(p.store, ast.NK_EXPR_LIT_BOOL, start_tok, p.pos, payload);
        }
        if (is_keyword(p, "nil")) {
            advance(p);
            ret ast.add_node(p.store, ast.NK_EXPR_LIT_NIL, start_tok, p.pos, 0);
        }

        val name: ast.StrId = intern_token_text(p);
        advance(p);

        if (current_tag(p) == token.TAG_LBRACE) {
            val ident_payload: u32 = ast.add_extra(p.store, name::u32);
            val ident_node: ast.NodeId = ast.add_node(p.store, ast.NK_EXPR_IDENT, start_tok, p.pos, ident_payload);
            ret parse_typed_literal(p, ident_node);
        }

        val payload: u32 = ast.add_extra(p.store, name::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_IDENT, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_LIT_INT) {
        val text: ast.StrId = intern_token_text(p);
        advance(p);
        val payload: u32 = ast.add_extra(p.store, text::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_LIT_INT, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_LIT_FLOAT) {
        val text: ast.StrId = intern_token_text(p);
        advance(p);
        val payload: u32 = ast.add_extra(p.store, text::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_LIT_FLOAT, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_LIT_STRING) {
        val text: ast.StrId = intern_token_text(p);
        advance(p);
        val payload: u32 = ast.add_extra(p.store, text::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_LIT_STR, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_LIT_CHAR) {
        val text: ast.StrId = intern_token_text(p);
        advance(p);
        val payload: u32 = ast.add_extra(p.store, text::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_LIT_CHAR, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_LPAREN) {
        advance(p);
        val inner: ast.NodeId = parse_expression(p, 0);
        expect(p, token.TAG_RPAREN, "expected ')' after parenthesized expression");
        val payload: u32 = ast.add_extra(p.store, inner::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_PAREN, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_LBRACKET) {
        ret parse_array_lit(p);
    }

    if (tag == token.TAG_QUESTION) {
        advance(p);
        val operand: ast.NodeId = parse_expression(p, PREC_CALL);
        val payload: u32 = ast.add_extra(p.store, operand::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_ADDR, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_AT) {
        advance(p);
        val operand: ast.NodeId = parse_expression(p, PREC_CALL);
        val payload: u32 = ast.add_extra(p.store, operand::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_DEREF, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_MINUS) {
        advance(p);
        val operand: ast.NodeId = parse_expression(p, PREC_CALL);
        val payload: u32 = ast.add_extra(p.store, operand::u32);
        ast.add_extra(p.store, token.TAG_MINUS::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_UNARY, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_BANG) {
        advance(p);
        val operand: ast.NodeId = parse_expression(p, PREC_CALL);
        val payload: u32 = ast.add_extra(p.store, operand::u32);
        ast.add_extra(p.store, token.TAG_BANG::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_UNARY, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_TILDE) {
        advance(p);
        val operand: ast.NodeId = parse_expression(p, PREC_CALL);
        val payload: u32 = ast.add_extra(p.store, operand::u32);
        ast.add_extra(p.store, token.TAG_TILDE::u32);
        ret ast.add_node(p.store, ast.NK_EXPR_UNARY, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_DOLLAR) {
        advance(p);
        val inner: ast.NodeId = parse_expression(p, PREC_CALL);
        val payload: u32 = ast.add_extra(p.store, inner::u32);
        ret ast.add_node(p.store, ast.NK_COMPTIME, start_tok, p.pos, payload);
    }

    error(p, "expected expression");
    ret ast.NODE_NIL;
}

fun parse_typed_literal(p: *Parser, type_expr: ast.NodeId) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var children: [256]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACE) && !at_end(p)) {
        if (count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between struct fields")) {
                brk;
            }
            if (check(p, token.TAG_RBRACE)) { brk; }
        }

        val fi_tok: u32 = p.pos;

        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected field name in struct literal");
            synchronize(p);
            brk;
        }
        val fi_name: ast.StrId = intern_token_text(p);
        advance(p);

        expect(p, token.TAG_COLON, "expected ':' after field name in struct literal");
        val fi_value: ast.NodeId = parse_expression(p, 0);

        val fi_payload: u32 = ast.add_extra(p.store, fi_name::u32);
        ast.add_extra(p.store, fi_value::u32);

        val fi_node: ast.NodeId = ast.add_node(p.store, ast.NK_FIELD_INIT, fi_tok, p.pos, fi_payload);
        if (count < 256) {
            children[count] = fi_node::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACE, "expected '}' after struct literal");

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, type_expr::u32);
    ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    ret ast.add_node(p.store, ast.NK_EXPR_STRUCT_LIT, start_tok, p.pos, payload);
}

fun parse_array_lit(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var children: [256]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACKET) && !at_end(p)) {
        if (count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between array elements")) {
                brk;
            }
            if (check(p, token.TAG_RBRACKET)) { brk; }
        }

        val elem: ast.NodeId = parse_expression(p, 0);
        if (count < 256) {
            children[count] = elem::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACKET, "expected ']' after array literal");

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    ret ast.add_node(p.store, ast.NK_EXPR_ARRAY_LIT, start_tok, p.pos, payload);
}

fun parse_call_expr(p: *Parser, callee: ast.NodeId) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var args: [256]u32;
    var arg_count: u32 = 0;

    for (!check(p, token.TAG_RPAREN) && !at_end(p)) {
        if (arg_count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between arguments")) {
                brk;
            }
        }
        val arg: ast.NodeId = parse_expression(p, 0);
        if (arg_count < 256) {
            args[arg_count] = arg::u32;
            arg_count = arg_count + 1;
        }
    }

    expect(p, token.TAG_RPAREN, "expected ')' after arguments");

    val span_start: u32 = ast.add_extra_slice(p.store, ?args[0], arg_count);
    val payload: u32 = ast.add_extra(p.store, callee::u32);
    ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, arg_count);
    ast.add_extra(p.store, ast.NODE_NIL::u32);

    ret ast.add_node(p.store, ast.NK_EXPR_CALL, start_tok, p.pos, payload);
}

fun is_type_arg_bracket(p: *Parser) bool {
    val save: u32 = p.pos;
    advance(p);
    val tag: token.Tag = current_tag(p);
    p.pos = save;
    if (tag == token.TAG_STAR) { ret true; }
    if (tag == token.TAG_AMP) { ret true; }
    if (tag == token.TAG_LBRACKET) { ret true; }
    if (tag == token.TAG_IDENT) {
        val save2: u32 = p.pos;
        advance(p);
        advance(p);
        var depth: i32 = 1;
        for (depth > 0 && !at_end(p)) {
            val t: token.Tag = current_tag(p);
            if (t == token.TAG_LBRACKET) { depth = depth + 1; }
            or (t == token.TAG_RBRACKET) { depth = depth - 1; }
            or (t == token.TAG_SEMI || t == token.TAG_LBRACE) { brk; }
            advance(p);
        }
        val after: token.Tag = current_tag(p);
        p.pos = save2;
        if (after == token.TAG_LPAREN) { ret true; }
    }
    ret false;
}

fun parse_generic_call(p: *Parser, callee: ast.NodeId) ast.NodeId {
    val start_tok: u32 = p.pos;
    val type_args: ast.NodeId = parse_type_args(p);

    if (current_tag(p) == token.TAG_LPAREN) {
        advance(p);
        var args: [256]u32;
        var count: u32 = 0;

        for (!check(p, token.TAG_RPAREN) && !at_end(p)) {
            if (count > 0) {
                if (!expect(p, token.TAG_COMMA, "expected ',' between arguments")) {
                    brk;
                }
            }

            val arg: ast.NodeId = parse_expression(p, 0);
            if (count < 256) {
                args[count] = arg::u32;
                count = count + 1;
            }
        }

        expect(p, token.TAG_RPAREN, "expected ')' after arguments");

        val span_start: u32 = ast.add_extra_slice(p.store, ?args[0], count);
        val payload: u32 = ast.add_extra(p.store, callee::u32);
        ast.add_extra(p.store, span_start);
        ast.add_extra(p.store, count);
        ast.add_extra(p.store, type_args::u32);

        ret ast.add_node(p.store, ast.NK_EXPR_CALL, start_tok, p.pos, payload);
    }

    val payload: u32 = ast.add_extra(p.store, callee::u32);
    ast.add_extra(p.store, type_args::u32);
    ret ast.add_node(p.store, ast.NK_EXPR_INDEX, start_tok, p.pos, payload);
}

fun parse_index_expr(p: *Parser, base: ast.NodeId) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    val index: ast.NodeId = parse_expression(p, 0);
    expect(p, token.TAG_RBRACKET, "expected ']' after index expression");

    val payload: u32 = ast.add_extra(p.store, base::u32);
    ast.add_extra(p.store, index::u32);

    ret ast.add_node(p.store, ast.NK_EXPR_INDEX, start_tok, p.pos, payload);
}

fun parse_field_expr(p: *Parser, base: ast.NodeId) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    if (current_tag(p) != token.TAG_IDENT) {
        error(p, "expected field name after '.'");
        ret ast.NODE_NIL;
    }
    val field_name: ast.StrId = intern_token_text(p);
    advance(p);

    val payload: u32 = ast.add_extra(p.store, base::u32);
    ast.add_extra(p.store, field_name::u32);

    ret ast.add_node(p.store, ast.NK_EXPR_FIELD, start_tok, p.pos, payload);
}

fun parse_cast_expr(p: *Parser, operand: ast.NodeId) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    val target: ast.NodeId = parse_type(p);

    val payload: u32 = ast.add_extra(p.store, operand::u32);
    ast.add_extra(p.store, target::u32);

    ret ast.add_node(p.store, ast.NK_EXPR_CAST, start_tok, p.pos, payload);
}

fun parse_type(p: *Parser) ast.NodeId {
    val tag: token.Tag = current_tag(p);
    val start_tok: u32 = p.pos;

    if (tag == token.TAG_STAR) {
        advance(p);
        val inner: ast.NodeId = parse_type(p);
        val payload: u32 = ast.add_extra(p.store, inner::u32);
        ret ast.add_node(p.store, ast.NK_TYPE_PTR, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_AMP) {
        advance(p);
        val inner: ast.NodeId = parse_type(p);
        val payload: u32 = ast.add_extra(p.store, inner::u32);
        ret ast.add_node(p.store, ast.NK_TYPE_REF, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_AMP_AMP) {
        advance(p);
        val inner: ast.NodeId = parse_type(p);
        val inner_ref_payload: u32 = ast.add_extra(p.store, inner::u32);
        val inner_ref: ast.NodeId = ast.add_node(p.store, ast.NK_TYPE_REF, start_tok, p.pos, inner_ref_payload);
        val outer_payload: u32 = ast.add_extra(p.store, inner_ref::u32);
        ret ast.add_node(p.store, ast.NK_TYPE_REF, start_tok, p.pos, outer_payload);
    }

    if (tag == token.TAG_LBRACKET) {
        advance(p);
        val count_expr: ast.NodeId = parse_expression(p, 0);
        expect(p, token.TAG_RBRACKET, "expected ']' in array type");
        val elem_type: ast.NodeId = parse_type(p);
        val payload: u32 = ast.add_extra(p.store, count_expr::u32);
        ast.add_extra(p.store, elem_type::u32);
        ret ast.add_node(p.store, ast.NK_TYPE_ARRAY, start_tok, p.pos, payload);
    }

    if (is_keyword(p, "fun")) {
        advance(p);
        val params: ast.NodeSpan = parse_type_fun_params(p);
        var ret_type: ast.NodeId = ast.NODE_NIL;
        if (current_tag(p) != token.TAG_SEMI && current_tag(p) != token.TAG_COMMA
            && current_tag(p) != token.TAG_RPAREN && current_tag(p) != token.TAG_RBRACE
            && current_tag(p) != token.TAG_RBRACKET) {
            ret_type = parse_type(p);
        }
        val payload: u32 = ast.add_extra(p.store, params.start);
        ast.add_extra(p.store, params.len);
        ast.add_extra(p.store, ret_type::u32);
        ret ast.add_node(p.store, ast.NK_TYPE_FUN, start_tok, p.pos, payload);
    }

    if (is_keyword(p, "rec")) {
        advance(p);
        val fields: ast.NodeSpan = parse_field_list(p);
        val payload: u32 = ast.add_extra(p.store, fields.start);
        ast.add_extra(p.store, fields.len);
        ret ast.add_node(p.store, ast.NK_TYPE_REC, start_tok, p.pos, payload);
    }

    if (is_keyword(p, "uni")) {
        advance(p);
        val fields: ast.NodeSpan = parse_field_list(p);
        val payload: u32 = ast.add_extra(p.store, fields.start);
        ast.add_extra(p.store, fields.len);
        ret ast.add_node(p.store, ast.NK_TYPE_UNI, start_tok, p.pos, payload);
    }

    if (tag == token.TAG_IDENT) {
        ret parse_type_name(p);
    }

    error(p, "expected type");
    ret ast.NODE_NIL;
}

fun parse_type_name(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;

    var path_buf: [256]u8;
    var path_len: u32 = 0;

    var tok: token.Token = current(p);
    var seg: str = lexer.text(p.stream, tok);
    var seg_len: u16 = tok.span.len;
    var i: u32 = 0;
    for (i < seg_len::u32 && path_len < 255) {
        path_buf[path_len] = seg[i];
        path_len = path_len + 1;
        i = i + 1;
    }
    advance(p);

    for (current_tag(p) == token.TAG_DOT) {
        if (path_len < 255) {
            path_buf[path_len] = '.';
            path_len = path_len + 1;
        }
        advance(p);
        if (current_tag(p) != token.TAG_IDENT) {
            error(p, "expected identifier after '.' in type path");
            brk;
        }
        tok = current(p);
        seg = lexer.text(p.stream, tok);
        seg_len = tok.span.len;
        i = 0;
        for (i < seg_len::u32 && path_len < 255) {
            path_buf[path_len] = seg[i];
            path_len = path_len + 1;
            i = i + 1;
        }
        advance(p);
    }

    path_buf[path_len] = 0;
    val name: ast.StrId = ast.intern(p.store, (?path_buf[0])::str, path_len);

    var type_args: ast.NodeId = ast.NODE_NIL;
    if (current_tag(p) == token.TAG_LBRACKET) {
        type_args = parse_type_args(p);
    }

    val payload: u32 = ast.add_extra(p.store, name::u32);
    ast.add_extra(p.store, type_args::u32);

    ret ast.add_node(p.store, ast.NK_TYPE_NAME, start_tok, p.pos, payload);
}

fun parse_type_args(p: *Parser) ast.NodeId {
    val start_tok: u32 = p.pos;
    advance(p);

    var children: [64]u32;
    var count: u32 = 0;

    for (!check(p, token.TAG_RBRACKET) && !at_end(p)) {
        if (count > 0) {
            if (!expect(p, token.TAG_COMMA, "expected ',' between type arguments")) {
                brk;
            }
        }

        val ty: ast.NodeId = parse_type(p);
        if (count < 64) {
            children[count] = ty::u32;
            count = count + 1;
        }
    }

    expect(p, token.TAG_RBRACKET, "expected ']' after type arguments");

    val span_start: u32 = ast.add_extra_slice(p.store, ?children[0], count);
    val payload: u32 = ast.add_extra(p.store, span_start);
    ast.add_extra(p.store, count);

    ret ast.add_node(p.store, ast.NK_GENERIC_PARAMS, start_tok, p.pos, payload);
}

test "parser: parse simple function" {
    var a: allocator.Allocator;
    page.make(?a);

    var stream: lexer.TokenStream = lexer.tokenize("fun main() i64 { ret 0; }", ?a);
    if (stream.tokens == nil) { ret 0; }

    val result: ParseResult = parse(?stream, ?a);
    if (!result.ok) { ret 0; }

    val root: &ast.Node = ast.get(?result.store, result.root);
    if (root.kind != ast.NK_PROGRAM) { ret 0; }

    val stmts: ast.NodeSpan = ast.block_stmts(?result.store, result.root);
    if (stmts.len != 1) { ret 0; }

    val child_id: ast.NodeId = result.store.extra[stmts.start]::ast.NodeId;
    val child: &ast.Node = ast.get(?result.store, child_id);
    if (child.kind != ast.NK_DECL_FUN) { ret 0; }

    val fname: ast.StrId = ast.fun_name(?result.store, child_id);
    val fname_str: str = ast.get_str(?result.store, fname);
    if (!str_region_equals(fname_str, 0, 4, "main")) { ret 0; }

    ret 1;
}
