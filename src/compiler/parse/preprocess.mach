# mach.compiler.parse.preprocess: comptime conditional flattening
#
# runs after parsing, before module graph loading. evaluates $if/$or
# conditions that depend only on $mach.* builtins (build target, platform
# constants) and replaces comptime conditional nodes with the statements
# from the taken branch. after this pass, no NK_COMPTIME_IF/NK_COMPTIME_OR
# nodes remain in the AST — downstream passes see a flat declaration list.
#
# fully standalone: no dependency on sema or comptime modules. platform
# constants are self-detected using the same $if mechanism as everywhere else.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use ast:   mach.compiler.parse.ast;
use token: mach.compiler.lex.token;

val OS_LINUX:   i64 = 1;
val OS_MACOS:   i64 = 2;
val OS_WINDOWS: i64 = 3;

val ARCH_X86_64: i64 = 1;
val ARCH_ARM64:  i64 = 2;

$if ($mach.build.target.os.id == $mach.os.linux.id) {
    val HOST_OS_ID:   i64 = 1;
    val HOST_OS_NAME: str = "linux";
}
$or ($mach.build.target.os.id == $mach.os.macos.id) {
    val HOST_OS_ID:   i64 = 2;
    val HOST_OS_NAME: str = "macos";
}
$or ($mach.build.target.os.id == $mach.os.windows.id) {
    val HOST_OS_ID:   i64 = 3;
    val HOST_OS_NAME: str = "windows";
}
$or {
    val HOST_OS_ID:   i64 = 1;
    val HOST_OS_NAME: str = "linux";
}

$if ($mach.build.target.arch.id == $mach.arch.x86_64.id) {
    val HOST_ARCH_ID:   i64 = 1;
    val HOST_ARCH_NAME: str = "x86_64";
}
$or ($mach.build.target.arch.id == $mach.arch.arm64.id) {
    val HOST_ARCH_ID:   i64 = 2;
    val HOST_ARCH_NAME: str = "arm64";
}
$or {
    val HOST_ARCH_ID:   i64 = 1;
    val HOST_ARCH_NAME: str = "x86_64";
}

val HOST_PTR_WIDTH: i64 = 8;

pub def CKind: u8;
pub val CK_INT:    CKind = 1;
pub val CK_BOOL:   CKind = 2;
pub val CK_STRING: CKind = 3;
pub val CK_NIL:    CKind = 4;

pub rec CValue {
    kind:     CKind;
    int_val:  i64;
    bool_val: bool;
    str_val:  str;
}

fun make_int(v: i64) CValue {
    var cv: CValue;
    cv.kind = CK_INT; cv.int_val = v; cv.bool_val = false; cv.str_val = nil;
    ret cv;
}

fun make_bool(v: bool) CValue {
    var cv: CValue;
    cv.kind = CK_BOOL; cv.int_val = 0; cv.bool_val = v; cv.str_val = nil;
    ret cv;
}

fun make_string(v: str) CValue {
    var cv: CValue;
    cv.kind = CK_STRING; cv.int_val = 0; cv.bool_val = false; cv.str_val = v;
    ret cv;
}

fun make_nil() CValue {
    var cv: CValue;
    cv.kind = CK_NIL; cv.int_val = 0; cv.bool_val = false; cv.str_val = nil;
    ret cv;
}

pub fun flatten(store: *ast.NodeStore, root: ast.NodeId) {
    if (root::u32 == ast.NODE_NIL::u32) { ret; }
    val node: &ast.Node = ast.get(store, root);
    if (node.kind != ast.NK_PROGRAM) { ret; }
    flatten_block(store, root);
}

fun flatten_block(store: *ast.NodeStore, block_id: ast.NodeId) {
    var changed: bool = true;
    for (changed) {
        changed = false;
        val stmts: ast.NodeSpan = ast.block_stmts(store, block_id);
        if (stmts.len == 0) { ret; }

        var has_comptime: bool = false;
        var i: u32 = 0;
        for (i < stmts.len) {
            val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
            if (child_id::u32 != ast.NODE_NIL::u32) {
                val child: &ast.Node = ast.get(store, child_id);
                if (child.kind == ast.NK_COMPTIME_IF) {
                    has_comptime = true;
                }
                if (child.kind == ast.NK_DECL_PUB) {
                    val inner_id: ast.NodeId = ast.get_extra(store, child.payload)::ast.NodeId;
                    if (inner_id::u32 != ast.NODE_NIL::u32) {
                        val inner: &ast.Node = ast.get(store, inner_id);
                        if (inner.kind == ast.NK_COMPTIME_IF) {
                            has_comptime = true;
                        }
                    }
                }
            }
            i = i + 1;
        }

        if (!has_comptime) {
            flatten_children(store, stmts);
            ret;
        }

        changed = true;

        var buf: [1024]u32;
        var count: u32 = 0;

        i = 0;
        for (i < stmts.len) {
            val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
            if (child_id::u32 == ast.NODE_NIL::u32) {
                i = i + 1;
                cnt;
            }

            val child: &ast.Node = ast.get(store, child_id);

            if (child.kind == ast.NK_COMPTIME_IF) {
                collect_taken(store, child_id, ?buf[0], ?count);
            } or (child.kind == ast.NK_DECL_PUB) {
                val inner_id: ast.NodeId = ast.get_extra(store, child.payload)::ast.NodeId;
                if (inner_id::u32 != ast.NODE_NIL::u32) {
                    val inner: &ast.Node = ast.get(store, inner_id);
                    if (inner.kind == ast.NK_COMPTIME_IF) {
                        collect_taken_pub(store, child_id, inner_id, ?buf[0], ?count);
                    } or {
                        if (count < 1024) {
                            buf[count] = child_id::u32;
                            count = count + 1;
                        }
                    }
                } or {
                    if (count < 1024) {
                        buf[count] = child_id::u32;
                        count = count + 1;
                    }
                }
            } or {
                if (count < 1024) {
                    buf[count] = child_id::u32;
                    count = count + 1;
                }
            }

            i = i + 1;
        }

        val new_start: u32 = ast.add_extra_slice(store, ?buf[0], count);
        val p: u32 = store.nodes[block_id::u32].payload;
        store.extra[p]     = new_start;
        store.extra[p + 1] = count;
    }

    val final_stmts: ast.NodeSpan = ast.block_stmts(store, block_id);
    flatten_children(store, final_stmts);
}

fun flatten_children(store: *ast.NodeStore, stmts: ast.NodeSpan) {
    var i: u32 = 0;
    for (i < stmts.len) {
        val child_id: ast.NodeId = ast.get_extra(store, stmts.start + i)::ast.NodeId;
        if (child_id::u32 != ast.NODE_NIL::u32) {
            val child: &ast.Node = ast.get(store, child_id);
            if (child.kind == ast.NK_DECL_FUN) {
                flatten_fun_body(store, child_id);
            }
            if (child.kind == ast.NK_DECL_PUB) {
                val inner_id: ast.NodeId = ast.get_extra(store, child.payload)::ast.NodeId;
                if (inner_id::u32 != ast.NODE_NIL::u32) {
                    val inner: &ast.Node = ast.get(store, inner_id);
                    if (inner.kind == ast.NK_DECL_FUN) {
                        flatten_fun_body(store, inner_id);
                    }
                }
            }
            if (child.kind == ast.NK_STMT_BLOCK) {
                flatten_block(store, child_id);
            }
        }
        i = i + 1;
    }
}

fun flatten_fun_body(store: *ast.NodeStore, fun_id: ast.NodeId) {
    val body_id: ast.NodeId = ast.fun_body(store, fun_id);
    if (body_id::u32 == ast.NODE_NIL::u32) { ret; }
    val body: &ast.Node = ast.get(store, body_id);
    if (body.kind == ast.NK_STMT_BLOCK) {
        flatten_block(store, body_id);
    }
}

fun collect_taken(store: *ast.NodeStore, node_id: ast.NodeId,
                  buf: *u32, count: *u32) {
    val cond_id: ast.NodeId = ast.cond_expr(store, node_id);
    val cv: CValue = eval_cond(store, cond_id);
    var taken: bool = false;
    if (cv.kind == CK_BOOL) {
        taken = cv.bool_val;
    } or (cv.kind == CK_INT) {
        taken = cv.int_val != 0;
    }

    if (taken) {
        append_body_stmts(store, node_id, buf, count);
        ret;
    }

    val or_chain: ast.NodeId = ast.cond_or_chain(store, node_id);
    if (or_chain::u32 != ast.NODE_NIL::u32) {
        collect_taken_or(store, or_chain, buf, count);
    }
}

fun collect_taken_or(store: *ast.NodeStore, node_id: ast.NodeId,
                     buf: *u32, count: *u32) {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret; }
    val node: &ast.Node = ast.get(store, node_id);
    if (node.kind != ast.NK_COMPTIME_OR) { ret; }

    val cond_id: ast.NodeId = ast.cond_expr(store, node_id);
    if (cond_id::u32 == ast.NODE_NIL::u32) {
        append_body_stmts(store, node_id, buf, count);
        ret;
    }

    val cv: CValue = eval_cond(store, cond_id);
    var taken: bool = false;
    if (cv.kind == CK_BOOL) {
        taken = cv.bool_val;
    } or (cv.kind == CK_INT) {
        taken = cv.int_val != 0;
    }

    if (taken) {
        append_body_stmts(store, node_id, buf, count);
        ret;
    }

    val or_chain: ast.NodeId = ast.cond_or_chain(store, node_id);
    if (or_chain::u32 != ast.NODE_NIL::u32) {
        collect_taken_or(store, or_chain, buf, count);
    }
}

fun append_body_stmts(store: *ast.NodeStore, node_id: ast.NodeId,
                      buf: *u32, count: *u32) {
    val body_id: ast.NodeId = ast.cond_body(store, node_id);
    if (body_id::u32 == ast.NODE_NIL::u32) { ret; }
    val body: &ast.Node = ast.get(store, body_id);
    if (body.kind != ast.NK_STMT_BLOCK) { ret; }

    val body_stmts: ast.NodeSpan = ast.block_stmts(store, body_id);
    var j: u32 = 0;
    for (j < body_stmts.len) {
        if (@count < 1024) {
            buf[@count] = ast.get_extra(store, body_stmts.start + j);
            @count = @count + 1;
        }
        j = j + 1;
    }
}

fun collect_taken_pub(store: *ast.NodeStore, pub_id: ast.NodeId,
                      comptime_id: ast.NodeId, buf: *u32, count: *u32) {
    var inner_buf: [1024]u32;
    var inner_count: u32 = 0;
    collect_taken(store, comptime_id, ?inner_buf[0], ?inner_count);

    var k: u32 = 0;
    for (k < inner_count) {
        val inner_id: ast.NodeId = inner_buf[k]::ast.NodeId;
        val pub_node: &ast.Node = ast.get(store, pub_id);
        val payload: u32 = ast.add_extra(store, inner_id::u32);
        val wrap_id: ast.NodeId = ast.add_node(store, ast.NK_DECL_PUB,
            pub_node.tok_idx, pub_node.end_tok, payload);
        if (@count < 1024) {
            buf[@count] = wrap_id::u32;
            @count = @count + 1;
        }
        k = k + 1;
    }
}

pub fun eval_cond(store: *ast.NodeStore, node_id: ast.NodeId) CValue {
    if (node_id::u32 == ast.NODE_NIL::u32) { ret make_nil(); }

    val node: &ast.Node = ast.get(store, node_id);

    if (node.kind == ast.NK_EXPR_LIT_INT) {
        val sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
        ret make_int(parse_int(ast.get_str(store, sid)));
    }

    if (node.kind == ast.NK_EXPR_LIT_BOOL) {
        ret make_bool(ast.get_extra(store, node.payload) != 0);
    }

    if (node.kind == ast.NK_EXPR_LIT_STR) {
        val sid: ast.StrId = ast.get_extra(store, node.payload)::ast.StrId;
        ret make_string(ast.get_str(store, sid));
    }

    if (node.kind == ast.NK_COMPTIME) {
        val res: Result[CValue, str] = resolve_builtin(store, node_id);
        if (is_ok[CValue, str](res)) {
            ret unwrap_ok[CValue, str](res);
        }
        val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        ret eval_cond(store, inner_id);
    }

    if (node.kind == ast.NK_EXPR_PAREN) {
        val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
        ret eval_cond(store, inner_id);
    }

    if (node.kind == ast.NK_EXPR_BINARY) {
        ret eval_binary(store, node_id);
    }

    if (node.kind == ast.NK_EXPR_UNARY) {
        ret eval_unary(store, node_id);
    }

    ret make_nil();
}

fun eval_binary(store: *ast.NodeStore, node_id: ast.NodeId) CValue {
    val lhs_id: ast.NodeId = ast.binary_lhs(store, node_id);
    val rhs_id: ast.NodeId = ast.binary_rhs(store, node_id);
    val op: u8 = ast.binary_op(store, node_id);

    val lhs: CValue = eval_cond(store, lhs_id);
    val rhs: CValue = eval_cond(store, rhs_id);

    if (lhs.kind == CK_INT && rhs.kind == CK_INT) {
        if (op == token.TAG_EQ_EQ::u8)  { ret make_bool(lhs.int_val == rhs.int_val); }
        if (op == token.TAG_BANG_EQ::u8) { ret make_bool(lhs.int_val != rhs.int_val); }
        if (op == token.TAG_LT::u8)     { ret make_bool(lhs.int_val < rhs.int_val); }
        if (op == token.TAG_GT::u8)     { ret make_bool(lhs.int_val > rhs.int_val); }
        if (op == token.TAG_LT_EQ::u8)  { ret make_bool(lhs.int_val <= rhs.int_val); }
        if (op == token.TAG_GT_EQ::u8)  { ret make_bool(lhs.int_val >= rhs.int_val); }
    }

    if (lhs.kind == CK_BOOL && rhs.kind == CK_BOOL) {
        if (op == token.TAG_AMP_AMP::u8)  { ret make_bool(lhs.bool_val && rhs.bool_val); }
        if (op == token.TAG_PIPE_PIPE::u8) { ret make_bool(lhs.bool_val || rhs.bool_val); }
        if (op == token.TAG_EQ_EQ::u8)    { ret make_bool(lhs.bool_val == rhs.bool_val); }
        if (op == token.TAG_BANG_EQ::u8)   { ret make_bool(lhs.bool_val != rhs.bool_val); }
    }

    if (lhs.kind == CK_STRING && rhs.kind == CK_STRING) {
        if (op == token.TAG_EQ_EQ::u8)  { ret make_bool(str_equals(lhs.str_val, rhs.str_val)); }
        if (op == token.TAG_BANG_EQ::u8) { ret make_bool(!str_equals(lhs.str_val, rhs.str_val)); }
    }

    ret make_nil();
}

fun eval_unary(store: *ast.NodeStore, node_id: ast.NodeId) CValue {
    val node: &ast.Node = ast.get(store, node_id);
    val operand_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    val op: u32 = ast.get_extra(store, node.payload + 1);
    val operand: CValue = eval_cond(store, operand_id);

    if (op == token.TAG_BANG::u32 && operand.kind == CK_BOOL) {
        ret make_bool(!operand.bool_val);
    }
    if (op == token.TAG_MINUS::u32 && operand.kind == CK_INT) {
        ret make_int(0 - operand.int_val);
    }

    ret make_nil();
}

fun resolve_builtin(store: *ast.NodeStore, node_id: ast.NodeId) Result[CValue, str] {
    val node: &ast.Node = ast.get(store, node_id);
    if (node.kind != ast.NK_COMPTIME) {
        ret err[CValue, str]("not a comptime node");
    }

    val inner_id: ast.NodeId = ast.get_extra(store, node.payload)::ast.NodeId;
    if (inner_id::u32 == ast.NODE_NIL::u32) {
        ret err[CValue, str]("empty comptime expression");
    }

    var segs: [8]str;
    var seg_count: i32 = 0;
    var cur: ast.NodeId = inner_id;

    for (seg_count < 8) {
        val n: &ast.Node = ast.get(store, cur);
        if (n.kind == ast.NK_EXPR_FIELD) {
            val field_sid: ast.StrId = ast.get_extra(store, n.payload + 1)::ast.StrId;
            segs[seg_count] = ast.get_str(store, field_sid);
            seg_count = seg_count + 1;
            cur = ast.get_extra(store, n.payload)::ast.NodeId;
        } or (n.kind == ast.NK_EXPR_IDENT) {
            val ident_sid: ast.StrId = ast.get_extra(store, n.payload)::ast.StrId;
            segs[seg_count] = ast.get_str(store, ident_sid);
            seg_count = seg_count + 1;
            brk;
        } or {
            brk;
        }
    }

    var ri: i32 = 0;
    var rj: i32 = seg_count - 1;
    for (ri < rj) {
        val tmp: str = segs[ri];
        segs[ri] = segs[rj];
        segs[rj] = tmp;
        ri = ri + 1;
        rj = rj - 1;
    }

    if (seg_count < 2 || !str_equals(segs[0], "mach")) {
        ret err[CValue, str]("not a $mach builtin");
    }

    if (seg_count == 3 && str_equals(segs[1], "compiler")) {
        if (str_equals(segs[2], "version")) { ret ok[CValue, str](make_string("0.9.0")); }
        if (str_equals(segs[2], "name"))    { ret ok[CValue, str](make_string("mach")); }
    }

    if (seg_count >= 4 && str_equals(segs[1], "build") && str_equals(segs[2], "target")) {
        if (seg_count == 4) {
            if (str_equals(segs[3], "os"))            { ret ok[CValue, str](make_string(HOST_OS_NAME)); }
            if (str_equals(segs[3], "arch"))          { ret ok[CValue, str](make_string(HOST_ARCH_NAME)); }
            if (str_equals(segs[3], "pointer_width")) { ret ok[CValue, str](make_int(HOST_PTR_WIDTH)); }
        }
        if (seg_count == 5 && str_equals(segs[4], "id")) {
            if (str_equals(segs[3], "os"))   { ret ok[CValue, str](make_int(HOST_OS_ID)); }
            if (str_equals(segs[3], "arch")) { ret ok[CValue, str](make_int(HOST_ARCH_ID)); }
        }
    }

    if (seg_count == 4 && str_equals(segs[1], "os") && str_equals(segs[3], "id")) {
        if (str_equals(segs[2], "linux"))   { ret ok[CValue, str](make_int(OS_LINUX)); }
        if (str_equals(segs[2], "macos"))   { ret ok[CValue, str](make_int(OS_MACOS)); }
        if (str_equals(segs[2], "windows")) { ret ok[CValue, str](make_int(OS_WINDOWS)); }
    }

    if (seg_count == 4 && str_equals(segs[1], "arch") && str_equals(segs[3], "id")) {
        if (str_equals(segs[2], "x86_64")) { ret ok[CValue, str](make_int(ARCH_X86_64)); }
        if (str_equals(segs[2], "arm64"))  { ret ok[CValue, str](make_int(ARCH_ARM64)); }
    }

    ret err[CValue, str]("unknown $mach builtin");
}

fun parse_int(text: str) i64 {
    if (text == nil) { ret 0; }
    var acc: i64 = 0;
    var i: usize = 0;
    for (text[i] != 0) {
        if (text[i] < '0' || text[i] > '9') { brk; }
        acc = acc * 10 + (text[i] - '0')::i64;
        i = i + 1;
    }
    ret acc;
}
