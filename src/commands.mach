use          std.types.string;
use console: std.io.console;

use cmd_build:  mach.cmd_build;
use cmd_dep:    mach.cmd_dep;
use cmd_format: mach.cmd_format;
use cmd_help:   mach.cmd_help;
use cmd_init:   mach.cmd_init;
use cmd_run:    mach.cmd_run;

pub fun dispatch(args: []str) i64 {
    if (args.len < 2) {
        console.print("error: no arguments provided\n");
        cmd_help.show_general_help();
        ret 1;
    }

    val command: str = args[1];

    if (command.equals("help"))   { ret cmd_help.handle(args); }
    or (command.equals("build"))  { ret cmd_build.handle(args); }
    or (command.equals("dep"))    { ret cmd_dep.handle(args); }
    or (command.equals("init"))   { ret cmd_init.handle(args); }
    or (command.equals("run"))    { ret cmd_run.handle(args); }
    or (command.equals("format")) { ret cmd_format.handle(args); }
    or (command.equals("version")) {
        val version: str = $build.version;
        console.print("v%s\n", version);
        ret 0;
    }

    console.print("error: unknown command '%s'\n", command);
    cmd_help.show_general_help();
    ret 1;
}
