use std.lang.driver.session;
use std.lang.target;

pub fun dispatch(args: []str) i64 {
    if (args.len < 2) {
        console.print("error: no arguments provided\n");
        ret 1;
    }

    val command: str = args[1];

    if (command.equals("help")) {
        ret handle_help(args);
    }
    or (command.equals("build")) {
        ret handle_build(args);
    }
    or (command.equals("init")) {
        ret handle_init(args);
    }
    or (command.equals("run")) {
        ret handle_run(args);
    }

    console.print("error: unknown command '%s'\n", command);
    console.print("use 'mach help' for usage information\n");
    ret 1;
}

fun show_general_help() {
    console.print("usage: mach <command> [options]\n");
    console.print("\n");
    console.print("available commands:\n");
    console.print("  help        show this help message or help for a specific command\n");
    console.print("  build       build the project or a named path\n");
    console.print("  init        initialize a new mach project in the specified directory\n");
    console.print("  run         run the output of a mach build\n");
    console.print("\n");
    console.print("use 'mach help <command>' for more information on a specific command\n");
}

fun show_build_help() {
    console.print("usage: mach build <path> [options]\n");
    console.print("\n");
    console.print("builds a mach project or single source file\n");
    console.print("\n");
    console.print("arguments:\n");
    console.print("  <path>      path to mach.toml, source file, or directory containing mach.toml\n");
    console.print("\n");
    console.print("options:\n");
    console.print("  --target <name>       select build target (for projects with multiple targets)\n");
    console.print("  --debug               build with debug information (default: on)\n");
    console.print("  --release             build in release mode (disables debug, enables optimizations)\n");
    console.print("  --optimize            enable optimizations (disabled by default)\n");
    console.print("  --output <path>       specify output file path\n");
    console.print("  --link <lib>          link against library (can be specified multiple times)\n");
    console.print("  --dep <module>=<path> add module root mapping (can be specified multiple times)\n");
    console.print("  --emit-obj <path>     emit object file to specified path\n");
    console.print("  --emit-asm <path>     emit assembly file to specified path\n");
    console.print("  --emit-ir <path>      emit LLVM IR to specified path\n");
    console.print("  --emit-ast <path>     emit abstract syntax tree to specified path\n");
}

fun show_init_help() {
    console.print("usage: mach init <name>\n");
    console.print("\n");
    console.print("initializes a new mach project with the specified name\n");
}

fun show_run_help() {
    console.print("usage: mach run <path>\n");
    console.print("\n");
    console.print("note: 'mach run' is not implemented yet.\n");
}

rec BuildOptions {
    target_override: Option[str];
    dep_overrides:   List[ConfigDependency];
}

fun build_options_init(opts: *BuildOptions) Option[str] {
    mem.zero[BuildOptions](opts, 1);
    opts.target_override = none[str]();

    ret opts.dep_overrides.init(4);
}

fun build_options_dnit(opts: *BuildOptions) {
    if (opts.dep_overrides.data != nil) {
        var i: usize = 0;
        for (i < opts.dep_overrides.len) {
            val dep_ptr: *ConfigDependency = opts.dep_overrides.data + i;
            dep_ptr.dnit();
            i = i + 1;
        }
    }

    opts.dep_overrides.dnit();
    opts.target_override = none[str]();
}

fun parse_dep_argument(arg: str) Result[ConfigDependency, str] {
    val eq_opt: Option[usize] = arg.index_of_char('=');
    if (eq_opt.is_none()) {
        ret err[ConfigDependency, str]("--dep expects '<module>=<path>'");
    }

    val eq_pos: usize = eq_opt.unwrap();
    if (eq_pos == 0 || eq_pos >= arg.len - 1) {
        ret err[ConfigDependency, str]("--dep expects non-empty <module> and <path>");
    }

    val module_opt: Option[str] = arg.substring(0, eq_pos);
    val path_opt:   Option[str] = arg.substring(eq_pos + 1, arg.len);

    if (module_opt.is_none() || path_opt.is_none()) {
        ret err[ConfigDependency, str]("invalid --dep mapping");
    }

    var dep: ConfigDependency;
    dep.init();
    dep.id   = module_opt.unwrap();
    dep.path = path_opt.unwrap();

    ret ok[ConfigDependency, str](dep);
}

fun handle_help(args: []str) i64 {
    # check if help for a specific command was requested
    if (args.len >= 3) {
        val subcommand: str = args[2];
        
        if (subcommand.equals("build")) {
            show_build_help();
            ret 0;
        }
        or (subcommand.equals("help")) {
            console.print("usage: mach help [command]\n");
            ret 0;
        }
        or (subcommand.equals("init")) {
            show_init_help();
            ret 0;
        }
        or (subcommand.equals("run")) {
            show_run_help();
            ret 0;
        }
        or {
            console.print("error: unknown command '%s'\n", subcommand);
            console.print("use 'mach help' to see available commands\n");
            ret 1;
        }
    }
    
    # show general help
    show_general_help();
    ret 0;
}

fun handle_build(args: []str) i64 {
    if (args.len < 3) {
        console.print("error: no path specified for build command\n");
        ret 1;
    }

    val res_input: Result[Path, str] = path_from_string(args[2]);
    if (res_input.is_err()) {
        console.print("error: invalid path '%s': %s\n", args[2], res_input.unwrap_err());
        ret 1;
    }

    var input_path: Path = res_input.unwrap_ok();

    if (fs.exists(input_path) == false) {
        console.print("error: specified path '%s' does not exist\n", args[2]);
        input_path.dnit();
        ret 1;
    }

    val res_config_path: Result[Path, str] = resolve_config_path(input_path);
    if (res_config_path.is_err()) {
        console.print("error: %s\n", res_config_path.unwrap_err());
        input_path.dnit();
        ret 1;
    }

    var config_path: Path = res_config_path.unwrap_ok();

    console.print("info: loading config from '%s'\n", config_path.as_str());

    var build_opts: BuildOptions;
    val build_opts_err: Option[str] = build_options_init(?build_opts);
    if (build_opts_err.is_some()) {
        console.print("error: failed to initialize build options: %s\n", build_opts_err.unwrap());
        config_path.dnit();
        input_path.dnit();
        ret 1;
    }

    var i: usize = 3;
    val target_inline_prefix: str = "--target=";
    for (i < args.len) {
        val option: str = args[i];

        if (option.equals("--target")) {
            if (i + 1 >= args.len) {
                console.print("error: --target expects a value\n");
                build_options_dnit(?build_opts);
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            i = i + 1;
            build_opts.target_override = some[str](args[i]);
        }
        or (option.starts_with(target_inline_prefix)) {
            val inline_opt: Option[str] = option.substring(target_inline_prefix.len, option.len);
            if (inline_opt.is_none()) {
                console.print("error: --target expects a value\n");
                build_options_dnit(?build_opts);
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            val inline_value: str = inline_opt.unwrap();
            if (inline_value.len == 0) {
                console.print("error: --target expects a value\n");
                build_options_dnit(?build_opts);
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            build_opts.target_override = some[str](inline_value);
        }
        or (option.equals("--dep")) {
            if (i + 1 >= args.len) {
                console.print("error: --dep expects '<module>=<path>'\n");
                build_options_dnit(?build_opts);
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            i = i + 1;
            val dep_res: Result[ConfigDependency, str] = parse_dep_argument(args[i]);
            if (dep_res.is_err()) {
                console.print("error: %s\n", dep_res.unwrap_err());
                build_options_dnit(?build_opts);
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }

            val push_err: Option[str] = build_opts.dep_overrides.push(dep_res.unwrap_ok());
            if (push_err.is_some()) {
                console.print("error: failed to record dependency override: %s\n", push_err.unwrap());
                build_options_dnit(?build_opts);
                config_path.dnit();
                input_path.dnit();
                ret 1;
            }
        }
        or {
            console.print("error: unknown build option '%s'\n", option);
            build_options_dnit(?build_opts);
            config_path.dnit();
            input_path.dnit();
            ret 1;
        }

        i = i + 1;
    }

    val exit_code: i64 = run_configured_build(config_path, ?build_opts);
    build_options_dnit(?build_opts);

    config_path.dnit();
    input_path.dnit();

    ret exit_code;
}

fun resolve_config_path(path: Path) Result[Path, str] {
    if (fs.is_dir(path)) {
        val res_join: Result[Path, str] = path_join(path, "mach.toml"::Path);
        if (res_join.is_err()) {
            ret err[Path, str](res_join.unwrap_err());
        }

        val config_path: Path = res_join.unwrap_ok();
        if (fs.exists(config_path) == false) {
            config_path.dnit();
            ret err[Path, str]("directory does not contain mach.toml");
        }

        ret ok[Path, str](config_path);
    }
    
    val path_str: str = path.as_str();

    if (path_str.ends_with("mach.toml")) {
        val clone_result: Result[Path, str] = path.clone();
        if (clone_result.is_err()) {
            ret err[Path, str](clone_result.unwrap_err());
        }
        ret ok[Path, str](clone_result.unwrap_ok());
    }

    if (path_str.ends_with(".mach")) {
        ret err[Path, str]("single-source builds are not implemented yet");
    }

    ret err[Path, str]("specified path is not a mach project or config file");
}

fun target_plan_push(plan: *List[String], name: str) Option[str] {
    val clone_res: Result[String, str] = name.clone();
    if (clone_res.is_err()) {
        ret some[str](clone_res.unwrap_err());
    }

    var owned: String = clone_res.unwrap_ok();
    val push_err: Option[str] = plan.push(owned);
    if (push_err.is_some()) {
        owned.dnit();
        ret push_err;
    }

    ret none[str]();
}

fun target_plan_add_named(plan: *List[String], config: *Config, name: str) Option[str] {
    if (config.targets.len == 0) {
        ret some[str]("project defines no build targets");
    }

    var i: usize = 0;
    for (i < config.targets.len) {
        val target_ptr: *ConfigTarget = config.targets.data + i;
        if (target_ptr.name.equals(name)) {
            ret target_plan_push(plan, target_ptr.name);
        }
        i = i + 1;
    }

    ret some[str]("requested target was not found");
}

fun target_plan_add_native(plan: *List[String], config: *Config) Option[str] {
    if (config.targets.len == 0) {
        ret some[str]("project defines no build targets");
    }

    var i: usize = 0;
    for (i < config.targets.len) {
        val target_ptr: *ConfigTarget = config.targets.data + i;
        if (target_ptr.triple.data == nil || target_ptr.triple.len == 0) {
            i = i + 1;
            cnt;
        }

        if (target_triple_is_native(target_ptr.triple)) {
            val push_err: Option[str] = target_plan_push(plan, target_ptr.name);
            if (push_err.is_some()) {
                ret push_err;
            }
            ret none[str]();
        }

        i = i + 1;
    }

    val native: str = target_native_triple();
    console.print("info: native triple detected as '%s'\n", native);

    var i_print: usize = 0;
    for (i_print < config.targets.len) {
        val t_ptr: *ConfigTarget = config.targets.data + i_print;
        console.print("info: available target '%s' triple '%s'\n", t_ptr.name, t_ptr.triple);
        i_print = i_print + 1;
    }

    ret some[str]("no targets match the native triple");
}

fun build_target_plan_from_selection(plan: *List[String], config: *Config, selection: str) Option[str] {
    if (selection.data == nil || selection.len == 0) {
        if (config.targets.len == 0) {
            ret some[str]("project defines no build targets");
        }

        val first_target: *ConfigTarget = config.targets.data;
        ret target_plan_push(plan, first_target.name);
    }

    if (selection.equals("native")) {
        ret target_plan_add_native(plan, config);
    }

    ret target_plan_add_named(plan, config, selection);
}

fun destroy_target_plan(plan: *List[String]) {
    if (plan.data != nil) {
        var i: usize = 0;
        for (i < plan.len) {
            val entry: *String = plan.data + i;
            entry.dnit();
            i = i + 1;
        }
    }

    plan.dnit();
}

fun determine_target_plan(path_config: Path, opts: *BuildOptions) Result[List[String], str] {
    val config_result: Result[Config, str] = config_read(path_config.as_str());
    if (config_result.is_err()) {
        ret err[List[String], str](config_result.unwrap_err());
    }

    var config: Config = config_result.unwrap_ok();

    var initial_cap: usize = config.targets.len;
    if (initial_cap == 0) {
        initial_cap = 1;
    }

    var plan: List[String];
    val plan_err: Option[str] = plan.init(initial_cap);
    if (plan_err.is_some()) {
        config.dnit();
        ret err[List[String], str](plan_err.unwrap());
    }

    var selection: str = config.target;
    if (opts != nil && opts.target_override.is_some()) {
        selection = opts.target_override.unwrap();
    }

    val build_err: Option[str] = build_target_plan_from_selection(?plan, ?config, selection);
    if (build_err.is_some()) {
        destroy_target_plan(?plan);
        config.dnit();
        ret err[List[String], str](build_err.unwrap());
    }

    if (plan.len == 0) {
        destroy_target_plan(?plan);
        config.dnit();
        ret err[List[String], str]("no targets selected for build");
    }

    config.dnit();

    ret ok[List[String], str](plan);
}

fun build_single_target(path_config: Path, opts: *BuildOptions, target_name: str) i64 {
    val config_result: Result[Config, str] = config_read(path_config.as_str());
    if (config_result.is_err()) {
        console.print("error: failed to read config '%s' for target '%s': %s\n", path_config.as_str(), target_name, config_result.unwrap_err());
        ret 1;
    }

    var config: Config = config_result.unwrap_ok();
    config.target = target_name;

    if (opts != nil && opts.dep_overrides.data != nil) {
        var dep_index: usize = 0;
        for (dep_index < opts.dep_overrides.len) {
            val dep_opt: Option[ConfigDependency] = opts.dep_overrides.get(dep_index);
            if (dep_opt.is_some()) {
                val push_err: Option[str] = config.dependency_add(dep_opt.unwrap());
                if (push_err.is_some()) {
                    console.print("error: failed to register dependency override for target '%s': %s\n", target_name, push_err.unwrap());
                    config.dnit();
                    ret 1;
                }
            }
            dep_index = dep_index + 1;
        }
    }

    val root_res: Result[Path, str] = determine_project_root(path_config);
    if (root_res.is_err()) {
        console.print("error: failed to determine project root for target '%s': %s\n", target_name, root_res.unwrap_err());
        config.dnit();
        ret 1;
    }

    var project_root: Path = root_res.unwrap_ok();

    var session: Session;
    val session_err: Option[str] = session.init_from_config(?config, ?project_root);
    if (session_err.is_some()) {
        console.print("error: failed to initialize build session for target '%s': %s\n", target_name, session_err.unwrap());
        project_root.dnit();
        ret 1;
    }

    var driver: Driver;
    val driver_err: Option[str] = driver.init(?session);
    if (driver_err.is_some()) {
        console.print("error: failed to initialize driver for target '%s': %s\n", target_name, driver_err.unwrap());
        session.dnit();
        ret 1;
    }

    var options: PipelineOptions = pipeline_options_default();
    val pipeline_err: Option[str] = driver.run_pipeline(options);
    if (pipeline_err.is_some()) {
        console.print("error: build pipeline failed for target '%s': %s\n", target_name, pipeline_err.unwrap());
    }

    driver.print_diagnostics();

    val has_errors: bool = driver.has_errors();

    driver.dnit();
    session.dnit();

    if (pipeline_err.is_some() || has_errors) {
        ret 1;
    }

    ret 0;
}

fun run_configured_build(path_config: Path, opts: *BuildOptions) i64 {
    val plan_res: Result[List[String], str] = determine_target_plan(path_config, opts);
    if (plan_res.is_err()) {
        val plan_err: str = plan_res.unwrap_err();
        console.print("error: %s (while preparing targets from '%s')\n", plan_err, path_config.as_str());
        ret 1;
    }

    var plan: List[String] = plan_res.unwrap_ok();

    var overall_status: i64 = 0;
    var i: usize = 0;
    for (i < plan.len) {
        val target_entry: *String = plan.data + i;
        val target_name: str = target_entry.as_str();

        console.print("info: building target '%s'\n", target_name);

        val result: i64 = build_single_target(path_config, opts, target_name);
        if (result != 0) {
            overall_status = result;
        }

        i = i + 1;
    }

    destroy_target_plan(?plan);

    ret overall_status;
}

fun determine_project_root(path_config: Path) Result[Path, str] {
    val dir_opt: Option[str] = path_config.dirname();
    if (dir_opt.is_some()) {
        ret path_from_string(dir_opt.unwrap());
    }

    ret path_from_string(".");
}

