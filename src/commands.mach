use          std.types.string;
use          std.types.bool;
use          std.types.list;
use          std.types.size;
use          std.types.option;
use          std.types.result;
use mem:     std.system.memory;
use console: std.io.console;
use fs:      std.io.filesystem;
use path:    std.io.path;
use tokens:  std.lang.tokens;

use cu:       mach.compiler.compilation_unit;
use pipeline: mach.compiler.pipeline;
use stages:   mach.compiler.stages;
use config:   mach.config;

val PROJECT_FILE_NAME: string = "mach.toml";

pub rec BuildOptions {
    path:     string;       # path argument (project directory, project file, or source file)

    # project config overrides
    target:   string;       # target selection override (for use with project config)
    # single-file options (can also override current target options)
    debug:    bool;         # build with debug info
    optimize: bool;         # enable optimizations
    output:   Option[string]; # manual output filename override
    link_to:  List[string];   # libraries to link against
    include:  List[string];   # manual include paths for the compiler
    modules:  List[string];   # manual module mapping, e.g `n=dir` where `n` is the module prefix at `dir`
    emit_obj: Option[string]; # emit object file to this path
    emit_asm: Option[string]; # emit assembly file to this path
    emit_ir:  Option[string]; # emit intermediate representation file to this path
    emit_ast: Option[string]; # emit abstract syntax tree file to this path

    is_project: bool; # true if building a full project, false if single module
}

fun is_project_file(path: string) bool {
    ret path.equals(PROJECT_FILE_NAME);
}

fun get_module_name(path: string) Option[string] {
    val dot_index: Option[usize] = path.last_index_of(".");
    if (dot_index.is_none()) {
        ret none[string]();
    }
    ret path.substring(0, dot_index.unwrap());
}

fun show_general_help() {
    console.print("usage: mach <command> [options]\n");
    console.print("\n");
    console.print("available commands:\n");
    console.print("  help        show this help message or help for a specific command\n");
    console.print("  build       build the project or a named path\n");
    console.print("\n");
    console.print("use 'mach help <command>' for more information on a specific command\n");
}

fun show_build_help() {
    console.print("usage: mach build <path> [options]\n");
    console.print("\n");
    console.print("builds a mach project or single source file\n");
    console.print("\n");
    console.print("arguments:\n");
    console.print("  <path>      path to mach.toml, source file, or directory containing mach.toml\n");
    console.print("\n");
    console.print("options:\n");
    console.print("  --target <name>       select build target (for projects with multiple targets)\n");
    console.print("  --debug               build with debug information (default: on)\n");
    console.print("  --release             build in release mode (disables debug, enables optimizations)\n");
    console.print("  --optimize            enable optimizations\n");
    console.print("  --no-optimize         disable optimizations\n");
    console.print("  --output <path>       specify output file path\n");
    console.print("  --link-to <lib>       link against library (can be specified multiple times)\n");
    console.print("  --include <path>      add include path (can be specified multiple times)\n");
    console.print("  --module <mapping>    add module mapping as 'name=path' (can be specified multiple times)\n");
    console.print("  --emit-obj <path>     emit object file to specified path\n");
    console.print("  --emit-asm <path>     emit assembly file to specified path\n");
    console.print("  --emit-ir <path>      emit LLVM IR to specified path\n");
    console.print("  --emit-ast <path>     emit abstract syntax tree to specified path\n");
}

fun handle_help(args: []string) i64 {
    # check if help for a specific command was requested
    if (args.len >= 3) {
        val subcommand: string = args[2];
        
        if (subcommand.equals("build")) {
            show_build_help();
            ret 0;
        }
        or (subcommand.equals("help")) {
            console.print("usage: mach help [command]\n");
            ret 0;
        }
        or {
            console.print("error: unknown command '%s'\n", subcommand);
            console.print("use 'mach help' to see available commands\n");
            ret 1;
        }
    }
    
    # show general help
    show_general_help();
    ret 0;
}

fun handle_build(args: []string) i64 {
    if (args.len < 3) {
        console.print("error: no path specified for build command\n");
        ret 1;
    }

    var options: BuildOptions;
    options.path     = args[2];
    options.target   = "";
    options.debug    = true;
    options.optimize = true;
    options.output   = none[string]();

    val link_to_res: Result[List[string], string] = list_new[string](4);
    if (link_to_res.is_err()) {
        console.print("error: failed to initialize link_to list\n");
        ret 1;
    }
    options.link_to = link_to_res.unwrap_ok();

    val include_res: Result[List[string], string] = list_new[string](4);
    if (include_res.is_err()) {
        console.print("error: failed to initialize include list\n");
        ret 1;
    }
    options.include = include_res.unwrap_ok();

    val modules_res: Result[List[string], string] = list_new[string](4);
    if (modules_res.is_err()) {
        console.print("error: failed to initialize modules list\n");
        ret 1;
    }
    options.modules = modules_res.unwrap_ok();

    options.emit_obj = none[string]();
    options.emit_asm = none[string]();
    options.emit_ir  = none[string]();
    options.emit_ast = none[string]();

    # validate path
    if (options.path.is_empty()) {
        console.print("error: empty path specified for build command\n");
        ret 1;
    }

    # determine if building a project or single module
    options.is_project = is_project_file(options.path);

    # set default output name
    options.output = get_module_name(options.path);

    var arg: u64 = 3;
    for (arg < args.len) {
        if (args[arg].equals("--debug")) {
            options.debug = true;
        }
        or (args[arg].equals("--release")) {
            options.debug    = false;
            options.optimize = true;
        }
        or (args[arg].equals("--optimize")) {
            options.optimize = true;
        }
        or (args[arg].equals("--no-optimize")) {
            options.optimize = false;
        }
        or (args[arg].equals("--target")) {
            if (arg + 1 >= args.len) {
                console.print("error: --target requires a target name argument\n");
                ret 1;
            }
            options.target = args[arg + 1];
            arg = arg + 1;
        }
        or (args[arg].equals("--output")) {
            if (arg + 1 >= args.len) {
                console.print("error: --output requires a filename argument\n");
                ret 1;
            }
            options.output = some[string](args[arg + 1]);
            arg = arg + 1;
        }
        or (args[arg].equals("--link-to")) {
            if (arg + 1 >= args.len) {
                console.print("error: --link-to requires a library name argument\n");
                ret 1;
            }
            val push_err: Option[string] = options.link_to.push(args[arg + 1]);
            if (push_err.is_some()) {
                console.print("error: failed to store --link-to argument: %s\n", push_err.unwrap());
                ret 1;
            }
            arg = arg + 1;
        }
        or (args[arg].equals("--include")) {
            if (arg + 1 >= args.len) {
                console.print("error: --include requires a path argument\n");
                ret 1;
            }
            val push_err: Option[string] = options.include.push(args[arg + 1]);
            if (push_err.is_some()) {
                console.print("error: failed to store --include argument: %s\n", push_err.unwrap());
                ret 1;
            }
            arg = arg + 1;
        }
        or (args[arg].equals("--module")) {
            if (arg + 1 >= args.len) {
                console.print("error: --module requires a mapping argument\n");
                ret 1;
            }
            val push_err: Option[string] = options.modules.push(args[arg + 1]);
            if (push_err.is_some()) {
                console.print("error: failed to store --module argument: %s\n", push_err.unwrap());
                ret 1;
            }
            arg = arg + 1;
        }
        or (args[arg].equals("--emit-obj")) {
            if (arg + 1 >= args.len) {
                console.print("error: --emit-obj requires a filename argument\n");
                ret 1;
            }
            options.emit_obj = some[string](args[arg + 1]);
            arg = arg + 1;
        }
        or (args[arg].equals("--emit-asm")) {
            if (arg + 1 >= args.len) {
                console.print("error: --emit-asm requires a filename argument\n");
                ret 1;
            }
            options.emit_asm = some[string](args[arg + 1]);
            arg = arg + 1;
        }
        or (args[arg].equals("--emit-ir")) {
            if (arg + 1 >= args.len) {
                console.print("error: --emit-ir requires a filename argument\n");
                ret 1;
            }
            options.emit_ir = some[string](args[arg + 1]);
            arg = arg + 1;
        }
        or (args[arg].equals("--emit-ast")) {
            if (arg + 1 >= args.len) {
                console.print("error: --emit-ast requires a filename argument\n");
                ret 1;
            }
            options.emit_ast = some[string](args[arg + 1]);
            arg = arg + 1;
        }
        or {
            console.print("error: unknown option '%s' for build command\n", args[arg]);
            ret 1;
        }
        arg = arg + 1;
    }

    # locate or create config
    val cfg_result: Result[config.Config, string] = locate_config(?options);
    if (cfg_result.is_err()) {
        console.print("error: failed to load configuration: %s\n", cfg_result.unwrap_err());
        ret 1;
    }
    
    var cfg: config.Config = cfg_result.unwrap_ok();
    
    # execute the build
    val result: i64 = build_with_config(?cfg);
    cfg.dnit();
    ret result;
}

fun create_default_config(options: *BuildOptions) Result[config.Config, string] {
    var cfg: config.Config;
    cfg.init();

    val module_name_opt: Option[string] = get_module_name(options.path);
    if (module_name_opt.is_none()) {
        cfg.dnit();
        ret err[config.Config, string]("failed to determine module name from path");
    }
    val module_name: string = module_name_opt.unwrap();
    
    # set project metadata
    cfg.project_id   = module_name;
    cfg.project_name = module_name;
    cfg.version      = "0.0.0";
    cfg.dir_source   = ".";
    cfg.target       = "default";
    
    # create a single target from options
    var target: config.Target;
    target.init();
    target.name       = "default";
    target.triple     = $target.triple; # use host triple by default
    target.entrypoint = options.path;
    target.artifacts  = ".";
    
    # set output path
    if (options.output.is_some()) {
        target.out = options.output.unwrap();
    } or {
        target.out = cfg.project_name;
    }
    
    # set optimization level
    if (options.optimize) {
        target.opt_level = 2;
    } or {
        target.opt_level = 0;
    }
    
    # set emit flags
    target.emit_ast = options.emit_ast.is_some();
    target.emit_ir  = options.emit_ir.is_some();
    target.emit_asm = options.emit_asm.is_some();
    target.emit_obj = options.emit_obj.is_some();
    target.build_library = false;
    target.no_pie = false;
    
    val push_err: Option[string] = cfg.target_add(target);
    if (push_err.is_some()) {
        cfg.dnit();
        ret err[config.Config, string]("failed to add target to config");
    }
    
    ret ok[config.Config, string](cfg);
}

fun locate_config(options: *BuildOptions) Result[config.Config, string] {
    # if path is a project file, read it directly
    if (options.is_project) {
        val cfg_result: Result[config.Config, string] = config.config_read(options.path);
        if (cfg_result.is_err()) {
            ret cfg_result;
        }
        
        var cfg: config.Config = cfg_result.unwrap_ok();
        
        # apply command-line overrides
        if (options.target.is_empty() == false) {
            cfg.target = options.target;
        }
        
        ret ok[config.Config, string](cfg);
    }
    
    # for single files, create a default config
    ret create_default_config(options);
}

fun run_target(cfg: *config.Config, target: config.Target) i64 {
    # display build info
    console.print("project: %s v%s\n", cfg.project_name, cfg.version);
    console.print("target: %s", target.name);
    if (target.triple.is_empty() == false) {
        console.print(" (%s)", target.triple);
    }
    console.print("\n");
    
    # determine entrypoint path
    var entrypoint_path: string = target.entrypoint;
    if (cfg.dir_source.is_empty() == false && cfg.dir_source.equals(".") == false) {
        entrypoint_path = path.join(cfg.dir_source, target.entrypoint);
    }
    
    val module_name_opt: Option[string] = get_module_name(target.entrypoint);
    if (module_name_opt.is_none()) {
        console.print("error: failed to determine module name from entrypoint '%s'\n", target.entrypoint);
        ret 1;
    }
    val module_name: string = module_name_opt.unwrap();
    console.print("compiling: %s\n", entrypoint_path);
    
    # create compilation unit
    val unit_result: Result[cu.CompilationUnit, string] = cu.cu_from_file(entrypoint_path, module_name);
    if (unit_result.is_err()) {
        console.print("error: failed to read source file: %s\n", unit_result.unwrap_err());
        ret 1;
    }
    
    var unit: cu.CompilationUnit = unit_result.unwrap_ok();
    
    # run compilation pipeline through lexer stage
    val compile_result: Result[bool, string] = pipeline.compile(?unit, stages.STAGE_LEXER);
    if (compile_result.is_err()) {
        console.print("error: compilation failed: %s\n", compile_result.unwrap_err());
        unit.print_all_diagnostics();
        unit.dnit();
        ret 1;
    }
    
    if (unit.is_ok() == false) {
        unit.print_all_diagnostics();
        unit.dnit();
        ret 1;
    }
    
    # display token count and debug print all tokens
    val tokens_opt: Option[List[tokens.Token]] = unit.get_tokens();
    if (tokens_opt.is_some()) {
        val tok_list: List[tokens.Token] = tokens_opt.unwrap();
        console.print("lexer: tokenized %d tokens\n", tok_list.len);
    }
    
    console.print("compilation pipeline: lexer stage complete\n");
    console.print("note: parser, semantic analysis, and codegen stages not yet implemented\n");
    unit.dnit();
    
    ret 0;
}

fun build_with_config(cfg: *config.Config) i64 {
    val build_all: bool = cfg.target.equals("all");

    if (build_all) {
        var i: usize = 0;
        for (i < cfg.targets.len) {
            val tgt_opt: Option[config.Target] = cfg.targets.get(i);
            if (tgt_opt.is_some()) {
                val result: i64 = run_target(cfg, tgt_opt.unwrap());
                if (result != 0) {
                    ret result;
                }
            }
            i = i + 1;
        }
        ret 0;
    }

    var selected_target: Option[config.Target] = none[config.Target]();
    var i: usize = 0;
    for (i < cfg.targets.len) {
        val tgt_opt: Option[config.Target] = cfg.targets.get(i);
        if (tgt_opt.is_some()) {
            val tgt: config.Target = tgt_opt.unwrap();
            if (tgt.name.equals(cfg.target)) {
                selected_target = some[config.Target](tgt);
                brk;
            }
        }
        i = i + 1;
    }

    if (selected_target.is_none()) {
        console.print("error: target '%s' not found in config\n", cfg.target);
        ret 1;
    }

    ret run_target(cfg, selected_target.unwrap());
}

pub fun dispatch(args: []string) i64 {
    if (args.len < 2) {
        console.print("error: no arguments provided\n");
        ret 1;
    }

    val command: string = args[1];

    if (command.equals("help")) {
        ret handle_help(args);
    }
    or (command.equals("build")) {
        ret handle_build(args);
    }

    console.print("error: unknown command '%s'\n", command);
    console.print("use 'mach help' for usage information\n");
    ret 1;
}
