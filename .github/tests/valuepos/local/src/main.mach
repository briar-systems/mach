rec Point { x: i64; y: i64; }
uni Box { a: i64; b: f64; }
def MyInt: i64;

fun pick[T](v: T) T {
    val t: T = T;
    ret v;
}

fun nothing() { ret; }

fun main() i64 {
    val p: Point = Point;
    val u: Box = Box;
    val x: i64 = MyInt;
    val nv: i64 = nothing();
    ret nothing().x + pick[i64](p.x) + u.a + x + nv;
}
