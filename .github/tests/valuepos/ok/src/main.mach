use std.runtime;
use plib.lib;

rec Point { x: i64; y: i64; }

fun sz[T]() i64 { ret $size_of(T)::i64; }
fun seven() i64 { ret 7; }

# every construct adjacent to the new never-value diagnostics must keep
# building: a record literal, a function reference, a generic parameter in a
# comptime intrinsic, and qualified value access through a module alias.
# 8 + 7 + 8 + 7 + 7 = 37.
`symbol("main")`
fun main(argc: i64, argv: **u8) i64 {
    val p: Point = Point{ x: 8, y: 1 };
    val f: fun() i64 = seven;
    ret p.x + f() + sz[i64]() + lib.answer + lib.get();
}
