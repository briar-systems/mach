# win64runner integration app: a windows-target project whose tests and main
# only run on a linux host through a declared launcher (`--runner wine`,
# #1345). the logic is trivial on purpose — the suite exercises the spawn
# path, not codegen.

use std.runtime;

$main.symbol = "main";
fun main(argc: i64, argv: **u8) i64 {
    if (add(20, 22) == 42) { ret 0; }
    ret 1;
}

# add: the trivial computation both main and the tests assert on.
fun add(a: i64, b: i64) i64 {
    ret a + b;
}

test "win64runner: addition holds under the launcher" {
    if (add(20, 22) != 42) { ret 1; }
    ret 0;
}

test "win64runner: a second test gets its own process" {
    if (add(1, 2) != 3) { ret 1; }
    ret 0;
}
