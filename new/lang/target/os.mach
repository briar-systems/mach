# operating system interface and id registry.
#
# every os implementation in os/ exposes a uniform interface (entry
# convention, syscall layer, default library layout) plus a stable numeric
# id used for compile-time conditional compilation via `$mach.os.<name>.id`.
# the interface itself is defined alongside the implementations as they land.

use std.types.size;

# canonical numeric ids for known operating systems. stable across compiler
# versions; user code dispatches on them through `$mach.os.<name>.id` and
# `$mach.build.target.os.id`.
pub val OS_UNKNOWN: u32 = 0;
pub val OS_LINUX:   u32 = 1;
pub val OS_DARWIN:  u32 = 2;
pub val OS_WINDOWS: u32 = 3;
