use std.types.size;

use token: mach.lang.fe.token;
use id:    mach.lang.fe.ast.id;

# discriminator for Stmt.data
pub def StmtKind: u8;

pub val STMT_KIND_EXPR:        StmtKind = 0;
pub val STMT_KIND_BLOCK:       StmtKind = 1;
pub val STMT_KIND_IF:          StmtKind = 2;
pub val STMT_KIND_FOR:         StmtKind = 3;
pub val STMT_KIND_RET:         StmtKind = 4;
pub val STMT_KIND_BRK:         StmtKind = 5;
pub val STMT_KIND_CNT:         StmtKind = 6;
pub val STMT_KIND_FIN:         StmtKind = 7;
pub val STMT_KIND_DECL:        StmtKind = 8;
pub val STMT_KIND_ASM:         StmtKind = 9;
pub val STMT_KIND_COMPTIME_IF: StmtKind = 10;
pub val STMT_KIND_ERROR:       StmtKind = 255;

# a bare expression used as a statement
# ---
# expr: the expression
pub rec StmtExpr {
    expr: id.ExprId;
}

# a brace-delimited sequence of statements
# ---
# stmts_start: start index into ast.extras; each slot holds a StmtId
# stmts_len:   number of statements in the block
pub rec StmtBlock {
    stmts_start: u32;
    stmts_len:   u32;
}

# an if/or-chain statement; else_block is STMT_NIL when there is no trailing `or` branch
# ---
# cond:       condition expression
# then_block: body executed when cond is true
# else_block: body executed when cond is false, or STMT_NIL
pub rec StmtIf {
    cond:       id.ExprId;
    then_block: id.StmtId;
    else_block: id.StmtId;
}

# a for loop; an absent condition runs forever until a brk or ret
# ---
# cond: loop condition, or EXPR_NIL for infinite loop
# body: loop body statement (typically STMT_KIND_BLOCK)
pub rec StmtFor {
    cond: id.ExprId;
    body: id.StmtId;
}

# a return statement
# ---
# value: returned expression, or EXPR_NIL for a bare `ret`
pub rec StmtRet {
    value: id.ExprId;
}

# a `fin expr` deferred-execution statement
# ---
# expr: expression to evaluate at scope exit
pub rec StmtFin {
    expr: id.ExprId;
}

# a local declaration used as a statement (val or var)
# ---
# decl: the wrapped declaration
pub rec StmtDecl {
    decl: id.DeclId;
}

# role of an asm operand, encoded in AsmOperand.role
pub def AsmOperandRole: u8;

pub val ASM_OP_IN:      AsmOperandRole = 0;
pub val ASM_OP_OUT:     AsmOperandRole = 1;
pub val ASM_OP_CLOBBER: AsmOperandRole = 2;

# one entry in an asm operand list
# ---
# role:   which ASM_OP_* role the operand plays
# name:   body-scope identifier for IN and OUT, or the clobbered register name for CLOBBER
# source: mach-level identifier bound to name for IN and OUT when renamed (e.g. `m: in = msg`); empty span when the body-name is the mach-var name, and always empty for CLOBBER
pub rec AsmOperand {
    role:   AsmOperandRole;
    name:   token.Span;
    source: token.Span;
}

# an `asm ISA? (operands?) { body }` inline-assembly statement
# ---
# isa:            span of the optional ISA identifier (e.g. `x86_64`); empty span when unspecified (portable MASM)
# operands_start: start index into ast.asm_operands
# operands_len:   number of operands; 0 when the operand list is absent or empty
# body:           span covering the raw text between the outer `{` and its matching `}`; the body may contain portable MASM directives and nested ISA blocks, resolved at code generation
pub rec StmtAsm {
    isa:            token.Span;
    operands_start: u32;
    operands_len:   u32;
    body:           token.Span;
}

# a `$if (cond) { stmts } $or (cond) { stmts } $or { stmts }` chain at statement scope
# ---
# branches_start: start index into ast.comptime_branches
# branches_len:   number of arms (at least 1)
pub rec StmtComptimeIf {
    branches_start: u32;
    branches_len:   u32;
}

# a syntactic statement node
# ---
# span: byte range of the statement in source
# kind: which STMT_KIND_* variant is active
# data: kind-specific payload; unused for BRK, CNT, ERROR (discriminated by kind alone); the asm body span contains raw assembly text rather than mach tokens
pub rec Stmt {
    span: token.Span;
    kind: StmtKind;
    data: uni {
        expr:        StmtExpr;
        block:       StmtBlock;
        if_:         StmtIf;
        for_:        StmtFor;
        ret_:        StmtRet;
        fin:         StmtFin;
        decl:        StmtDecl;
        asm_:        StmtAsm;
        comptime_if: StmtComptimeIf;
    };
}
