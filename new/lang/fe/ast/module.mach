use std.types.size;

use token: mach.lang.fe.token;

# the top-level AST node for one parsed source file
# ---
# span:        byte range covering the whole module
# decls_start: start index into ast.extras; each slot holds a DeclId
# decls_len:   number of declarations at module scope
pub rec Module {
    span:        token.Span;
    decls_start: u32;
    decls_len:   u32;
}
