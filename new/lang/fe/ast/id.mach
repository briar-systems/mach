use std.types.size;

# identifier for an Expr node
pub def ExprId: u32;

# identifier for a Stmt node
pub def StmtId: u32;

# identifier for a Decl node
pub def DeclId: u32;

# identifier for a Type node
pub def TypeId: u32;

# identifier for a Module node
pub def ModuleId: u32;

pub val EXPR_NIL:   ExprId   = 0xFFFFFFFF;
pub val STMT_NIL:   StmtId   = 0xFFFFFFFF;
pub val DECL_NIL:   DeclId   = 0xFFFFFFFF;
pub val TYPE_NIL:   TypeId   = 0xFFFFFFFF;
pub val MODULE_NIL: ModuleId = 0xFFFFFFFF;
