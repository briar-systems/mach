# bounded const-eval engine used by the module-graph driver and the resolve
# phase to evaluate `$if` predicates and other compile-time-constant
# expressions.
#
# scope: literals, references to comptime-known constants (`$mach.*` and
# user-registered vals), and arithmetic / comparison / logical / bitwise /
# shift operators over them.
#
# explicitly out of scope: function calls, loops, type-introspection
# intrinsics (`$size_of` and friends are sema's job once types are known),
# and any expression that cannot be reduced to a single comptime value.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.zstr;
use std.types.result;

use std.allocator;

use intern: mach.lang.intern;
use ast:    mach.lang.fe.ast;
use id:     mach.lang.fe.ast.id;
use expr:   mach.lang.fe.ast.expr;
use token:  mach.lang.fe.token;
use os:     mach.lang.target.os;
use isa:    mach.lang.target.isa;

# discriminator for CTValue.data
pub def CTKind: u8;

pub val CT_KIND_INT:   CTKind = 0;
pub val CT_KIND_FLOAT: CTKind = 1;
pub val CT_KIND_BOOL:  CTKind = 2;
pub val CT_KIND_STR:   CTKind = 3;

# a tagged comptime-evaluated value
# ---
# kind: which CT_KIND_* variant is active
# data: kind-specific payload
pub rec CTValue {
    kind: CTKind;
    data: uni {
        i: i64;
        f: f64;
        b: bool;
        s: intern.StrId;
    };
}

# named comptime constant; produced when a comptime-evaluable val decl is
# registered with a context for later reference by its bare identifier
# ---
# name:  interned identifier
# value: pre-evaluated constant
pub rec NamedConst {
    name:  intern.StrId;
    value: CTValue;
}

# build/target context plus user-defined comptime constants visible to one
# evaluation. populated by the driver from mach.toml plus prior comptime val
# decls evaluated in dependency order.
# ---
# alloc:          allocator used for the user_consts buffer
# target_os_id:   numeric os id (one of os.OS_*)
# target_arch_id: numeric arch id (one of isa.ARCH_*)
# pointer_width:  target pointer width in bytes
# compiler_name:  interned "mach"
# compiler_ver:   interned compiler version string
# user_consts:    array of NamedConst entries; linear lookup is fine at this size
# user_const_len: number of entries currently stored
# user_const_cap: allocated slots in user_consts
pub rec ComptimeCtx {
    alloc:          *Allocator;
    target_os_id:   u32;
    target_arch_id: u32;
    pointer_width:  u32;
    compiler_name:  intern.StrId;
    compiler_ver:   intern.StrId;
    user_consts:    *NamedConst;
    user_const_len: u32;
    user_const_cap: u32;
}

val INITIAL_CONST_CAP: u32 = 16;

# constructs a ComptimeCtx with the given target parameters and no user consts
# ---
# alloc:          allocator used for owned storage
# target_os_id:   numeric os id (one of os.OS_*)
# target_arch_id: numeric arch id (one of isa.ARCH_*)
# pointer_width:  pointer width in bytes for the target
# compiler_name:  interned compiler name
# compiler_ver:   interned compiler version
# ret:            a fresh ComptimeCtx
pub fun init(
    alloc:          *Allocator,
    target_os_id:   u32,
    target_arch_id: u32,
    pointer_width:  u32,
    compiler_name:  intern.StrId,
    compiler_ver:   intern.StrId,
) ComptimeCtx {
    var c: ComptimeCtx;
    c.alloc          = alloc;
    c.target_os_id   = target_os_id;
    c.target_arch_id = target_arch_id;
    c.pointer_width  = pointer_width;
    c.compiler_name  = compiler_name;
    c.compiler_ver   = compiler_ver;
    c.user_consts    = nil;
    c.user_const_len = 0;
    c.user_const_cap = 0;
    ret c;
}

# releases the user_consts buffer
# ---
# c: context to tear down; all fields are zeroed
pub fun dnit(c: *ComptimeCtx) {
    if (c == nil) { ret; }
    if (c.user_consts != nil && c.user_const_cap > 0) {
        deallocate[NamedConst](c.alloc, c.user_consts, c.user_const_cap::usize);
    }
    c.user_consts    = nil;
    c.user_const_len = 0;
    c.user_const_cap = 0;
}

# registers a comptime constant under `name`, growing user_consts as needed
# ---
# c:     context to extend
# name:  interned identifier
# value: pre-evaluated constant
# ret:   true on success, or an allocation error
pub fun register(c: *ComptimeCtx, name: intern.StrId, value: CTValue) Result[bool, str] {
    if (c.user_consts == nil) {
        val r: Result[*NamedConst, str] = allocate[NamedConst](c.alloc, INITIAL_CONST_CAP::usize);
        if (is_err[*NamedConst, str](r)) {
            ret err[bool, str](unwrap_err[*NamedConst, str](r));
        }
        c.user_consts    = unwrap_ok[*NamedConst, str](r);
        c.user_const_cap = INITIAL_CONST_CAP;
    }
    or (c.user_const_len == c.user_const_cap) {
        val new_cap: u32 = c.user_const_cap * 2;
        val r: Result[*NamedConst, str] = reallocate[NamedConst](c.alloc, c.user_consts, c.user_const_cap::usize, new_cap::usize);
        if (is_err[*NamedConst, str](r)) {
            ret err[bool, str](unwrap_err[*NamedConst, str](r));
        }
        c.user_consts    = unwrap_ok[*NamedConst, str](r);
        c.user_const_cap = new_cap;
    }

    var nc: NamedConst;
    nc.name  = name;
    nc.value = value;
    c.user_consts[c.user_const_len] = nc;
    c.user_const_len = c.user_const_len + 1;
    ret ok[bool, str](true);
}

# looks up a comptime constant by interned name
# ---
# c:    context to search
# name: interned identifier to find
# ret:  pointer to the entry in c.user_consts, or nil if not registered
pub fun lookup(c: *ComptimeCtx, name: intern.StrId) *NamedConst {
    var i: u32 = 0;
    for (i < c.user_const_len) {
        if (c.user_consts[i].name == name) {
            ret ?c.user_consts[i];
        }
        i = i + 1;
    }
    ret nil;
}

# truthiness check for $if/$or predicates: only CT_KIND_BOOL values are
# considered truthy; non-bool values are an error at the call site (this
# helper is called only after eval has succeeded with a bool result)
# ---
# v:   value to test
# ret: true when v.kind is CT_KIND_BOOL and v.data.b is true
pub fun is_truthy(v: CTValue) bool {
    ret v.kind == CT_KIND_BOOL && v.data.b;
}

# evaluates a comptime expression in the given context
# ---
# c:        the comptime context (target params + user constants)
# a:        the ast that owns `e`
# source:   source text covering `e` (for span lookup)
# e:        expression id to evaluate
# interner: shared string interner; used to compare identifier text via StrId
# ret:      a CTValue, or an error message describing why evaluation failed
pub fun eval(
    c:        *ComptimeCtx,
    a:        *ast.Ast,
    source:   str,
    e:        id.ExprId,
    interner: *intern.Interner,
) Result[CTValue, str] {
    if (e == id.EXPR_NIL) { ret err[CTValue, str]("missing expression"); }

    val node: *expr.Expr = ast.get_expr(a, e);
    val k: expr.ExprKind = node.kind;

    if (k == expr.EXPR_KIND_LIT_INT)   { ret eval_lit_int(source, node.span); }
    if (k == expr.EXPR_KIND_LIT_FLOAT) { ret eval_lit_float(source, node.span); }
    if (k == expr.EXPR_KIND_LIT_CHAR)  { ret eval_lit_char(source, node.span); }
    if (k == expr.EXPR_KIND_LIT_STR)   { ret eval_lit_str(source, node.span, interner); }
    if (k == expr.EXPR_KIND_LIT_ZSTR)  { ret eval_lit_str(source, node.span, interner); }
    if (k == expr.EXPR_KIND_LIT_NIL)   { ret err[CTValue, str]("nil is not comptime-evaluable"); }

    if (k == expr.EXPR_KIND_BINARY) { ret eval_binary(c, a, source, ?node.data.binary, interner); }
    if (k == expr.EXPR_KIND_UNARY)  { ret eval_unary(c, a, source, ?node.data.unary, interner); }

    if (k == expr.EXPR_KIND_IDENT) { ret eval_ident(c, source, node.span, interner); }

    if (k == expr.EXPR_KIND_COMPTIME_IDENT || k == expr.EXPR_KIND_MEMBER) {
        ret eval_path(c, a, source, e, interner);
    }

    if (k == expr.EXPR_KIND_CALL)       { ret err[CTValue, str]("function calls are not comptime-evaluable"); }
    if (k == expr.EXPR_KIND_INDEX)      { ret err[CTValue, str]("index expressions are not comptime-evaluable"); }
    if (k == expr.EXPR_KIND_CAST)       { ret err[CTValue, str]("type casts are not comptime-evaluable"); }
    if (k == expr.EXPR_KIND_ARRAY_LIT)  { ret err[CTValue, str]("array literals are not comptime-evaluable"); }
    if (k == expr.EXPR_KIND_STRUCT_LIT) { ret err[CTValue, str]("struct literals are not comptime-evaluable"); }
    if (k == expr.EXPR_KIND_ERROR)      { ret err[CTValue, str]("expression has a parse error"); }

    ret err[CTValue, str]("expression is not comptime-evaluable");
}

# returns a fat-string view into source covering `span`. the returned str
# shares source's storage; do not free it independently.
fun span_text(source: str, span: token.Span) str {
    var s: str;
    s.len  = span.len::u32;
    s.data = ?source.data[span.offset];
    ret s;
}

# parses an integer literal from its source text, accepting hex (`0x`),
# binary (`0b`), and octal (`0o`) prefixes, digit separators (`_`), and
# trailing type suffixes (`u8`, `i64`, etc., which are consumed but ignored
# at the comptime-value layer)
fun eval_lit_int(source: str, span: token.Span) Result[CTValue, str] {
    val text: str = span_text(source, span);
    if (text.len == 0) { ret err[CTValue, str]("empty integer literal"); }

    var i:     u32 = 0;
    var base:  i64 = 10;

    if (text.len >= 2 && text.data[0] == '0') {
        if      (text.data[1] == 'x') { base = 16; i = 2; }
        or      (text.data[1] == 'b') { base = 2;  i = 2; }
        or      (text.data[1] == 'o') { base = 8;  i = 2; }
    }

    var value:  i64 = 0;
    var saw_digit: bool = false;
    for (i < text.len) {
        val c: u8 = text.data[i];
        if (c == '_') { i = i + 1; cnt; }
        if (c == 'u' || c == 'i' || c == 'f') { brk; }

        var digit: i64 = 0 - 1;
        if      (c >= '0' && c <= '9') { digit = (c - '0')::i64; }
        or      (c >= 'a' && c <= 'f') { digit = (c - 'a')::i64 + 10; }
        or      (c >= 'A' && c <= 'F') { digit = (c - 'A')::i64 + 10; }
        or {
            ret err[CTValue, str]("invalid digit in integer literal");
        }

        if (digit >= base) { ret err[CTValue, str]("digit out of range for base"); }

        value = value * base + digit;
        saw_digit = true;
        i = i + 1;
    }

    if (!saw_digit) { ret err[CTValue, str]("integer literal has no digits"); }

    var v: CTValue;
    v.kind   = CT_KIND_INT;
    v.data.i = value;
    ret ok[CTValue, str](v);
}

# parses a float literal from its source text. supports decimal `digit.digit`
# form with optional exponent and `f<n>` width suffix; rejects malformed input
fun eval_lit_float(source: str, span: token.Span) Result[CTValue, str] {
    val text: str = span_text(source, span);
    if (text.len == 0) { ret err[CTValue, str]("empty float literal"); }

    var i: u32 = 0;
    var integer_part: f64 = 0.0;
    var saw_digit: bool = false;
    for (i < text.len) {
        val c: u8 = text.data[i];
        if (c == '_') { i = i + 1; cnt; }
        if (c == '.') { brk; }
        if (c == 'e' || c == 'E') { brk; }
        if (c == 'f') { brk; }
        if (c < '0' || c > '9') { ret err[CTValue, str]("invalid character in float literal"); }
        integer_part = integer_part * 10.0 + (c - '0')::f64;
        saw_digit = true;
        i = i + 1;
    }

    var fraction: f64 = 0.0;
    var fdiv:     f64 = 1.0;
    if (i < text.len && text.data[i] == '.') {
        i = i + 1;
        for (i < text.len) {
            val c: u8 = text.data[i];
            if (c == '_') { i = i + 1; cnt; }
            if (c == 'e' || c == 'E') { brk; }
            if (c == 'f') { brk; }
            if (c < '0' || c > '9') { ret err[CTValue, str]("invalid character in float literal"); }
            fraction = fraction * 10.0 + (c - '0')::f64;
            fdiv = fdiv * 10.0;
            saw_digit = true;
            i = i + 1;
        }
    }

    var value: f64 = integer_part + fraction / fdiv;

    if (i < text.len && (text.data[i] == 'e' || text.data[i] == 'E')) {
        i = i + 1;
        var neg: bool = false;
        if (i < text.len && text.data[i] == '-') { neg = true; i = i + 1; }
        or (i < text.len && text.data[i] == '+') { i = i + 1; }

        var exp: i64 = 0;
        var saw_exp_digit: bool = false;
        for (i < text.len) {
            val c: u8 = text.data[i];
            if (c == 'f') { brk; }
            if (c < '0' || c > '9') { ret err[CTValue, str]("invalid character in float exponent"); }
            exp = exp * 10 + (c - '0')::i64;
            saw_exp_digit = true;
            i = i + 1;
        }
        if (!saw_exp_digit) { ret err[CTValue, str]("missing digits in float exponent"); }

        var scale: f64 = 1.0;
        var k: i64 = 0;
        for (k < exp) {
            scale = scale * 10.0;
            k = k + 1;
        }
        if (neg) { value = value / scale; } or { value = value * scale; }
    }

    if (!saw_digit) { ret err[CTValue, str]("float literal has no digits"); }

    var v: CTValue;
    v.kind   = CT_KIND_FLOAT;
    v.data.f = value;
    ret ok[CTValue, str](v);
}

# parses a character literal `'X'` including escape sequences
fun eval_lit_char(source: str, span: token.Span) Result[CTValue, str] {
    val text: str = span_text(source, span);
    if (text.len < 3) { ret err[CTValue, str]("malformed character literal"); }
    if (text.data[0] != '\'' || text.data[text.len - 1] != '\'') {
        ret err[CTValue, str]("character literal not delimited by single quotes");
    }

    var inner: str;
    inner.len  = text.len - 2;
    inner.data = ?text.data[1];

    val r: Result[u8, str] = decode_char(inner);
    if (is_err[u8, str](r)) {
        ret err[CTValue, str](unwrap_err[u8, str](r));
    }

    var v: CTValue;
    v.kind   = CT_KIND_INT;
    v.data.i = unwrap_ok[u8, str](r)::i64;
    ret ok[CTValue, str](v);
}

# parses a string-shaped literal (either `"..."` or `` `...` ``); decodes
# escape sequences and interns the resulting bytes. the returned StrId is
# a handle into `interner`.
fun eval_lit_str(source: str, span: token.Span, interner: *intern.Interner) Result[CTValue, str] {
    val text: str = span_text(source, span);
    if (text.len < 2) { ret err[CTValue, str]("malformed string literal"); }

    val open: u8 = text.data[0];
    if (open != '"' && open != '`') {
        ret err[CTValue, str]("string literal not delimited");
    }
    if (text.data[text.len - 1] != open) {
        ret err[CTValue, str]("string literal missing closing delimiter");
    }

    var inner: str;
    inner.len  = text.len - 2;
    inner.data = ?text.data[1];

    val s_r: Result[intern.StrId, str] = intern_decoded(interner, inner);
    if (is_err[intern.StrId, str](s_r)) {
        ret err[CTValue, str](unwrap_err[intern.StrId, str](s_r));
    }

    var v: CTValue;
    v.kind   = CT_KIND_STR;
    v.data.s = unwrap_ok[intern.StrId, str](s_r);
    ret ok[CTValue, str](v);
}

# decodes escape sequences in `inner` and interns the result via `interner`
fun intern_decoded(interner: *intern.Interner, inner: str) Result[intern.StrId, str] {
    val has_escape: bool = contains_byte(inner, '\\');
    if (!has_escape) {
        ret intern.intern(interner, inner);
    }

    val r_buf: Result[*u8, str] = allocate[u8](interner.alloc, inner.len::usize);
    if (is_err[*u8, str](r_buf)) {
        ret err[intern.StrId, str](unwrap_err[*u8, str](r_buf));
    }
    val buf: *u8 = unwrap_ok[*u8, str](r_buf);

    var read:    u32 = 0;
    var write:   u32 = 0;
    for (read < inner.len) {
        val c: u8 = inner.data[read];
        if (c != '\\') {
            buf[write] = c;
            read  = read + 1;
            write = write + 1;
            cnt;
        }
        if (read + 1 >= inner.len) {
            deallocate[u8](interner.alloc, buf, inner.len::usize);
            ret err[intern.StrId, str]("stray backslash at end of string literal");
        }
        var sub: str;
        sub.len = 0;
        var consumed: u32 = 0;
        val esc_r: Result[u8, str] = decode_escape(?inner.data[read], inner.len - read, ?consumed);
        if (is_err[u8, str](esc_r)) {
            deallocate[u8](interner.alloc, buf, inner.len::usize);
            ret err[intern.StrId, str](unwrap_err[u8, str](esc_r));
        }
        buf[write] = unwrap_ok[u8, str](esc_r);
        read  = read + consumed;
        write = write + 1;
    }

    var decoded: str;
    decoded.len  = write;
    decoded.data = buf;

    val id_r: Result[intern.StrId, str] = intern.intern(interner, decoded);
    deallocate[u8](interner.alloc, buf, inner.len::usize);
    ret id_r;
}

# decodes a single character (or escape sequence) from a string view
fun decode_char(inner: str) Result[u8, str] {
    if (inner.len == 0) { ret err[u8, str]("empty character literal"); }
    if (inner.data[0] != '\\') {
        if (inner.len != 1) { ret err[u8, str]("character literal must contain exactly one character"); }
        ret ok[u8, str](inner.data[0]);
    }
    var consumed: u32 = 0;
    val r: Result[u8, str] = decode_escape(inner.data, inner.len, ?consumed);
    if (is_err[u8, str](r)) { ret r; }
    if (consumed::u32 != inner.len) {
        ret err[u8, str]("character literal must contain exactly one escape sequence");
    }
    ret r;
}

# decodes an escape sequence starting at `p` (which points at the leading
# backslash); writes the number of input bytes consumed into `out_consumed`
fun decode_escape(p: *u8, len: u32, out_consumed: *u32) Result[u8, str] {
    if (len < 2) { ret err[u8, str]("incomplete escape sequence"); }
    val c: u8 = p[1];

    if (c == 'n')  { @out_consumed = 2; ret ok[u8, str](10); }
    if (c == 't')  { @out_consumed = 2; ret ok[u8, str](9); }
    if (c == 'r')  { @out_consumed = 2; ret ok[u8, str](13); }
    if (c == '\\') { @out_consumed = 2; ret ok[u8, str](92); }
    if (c == '\'') { @out_consumed = 2; ret ok[u8, str](39); }
    if (c == '"')  { @out_consumed = 2; ret ok[u8, str](34); }
    if (c == '0')  { @out_consumed = 2; ret ok[u8, str](0); }
    if (c == 'x') {
        if (len < 4) { ret err[u8, str]("incomplete \\x escape"); }
        val hi: i64 = hex_digit(p[2]);
        val lo: i64 = hex_digit(p[3]);
        if (hi < 0 || lo < 0) { ret err[u8, str]("invalid \\x escape"); }
        @out_consumed = 4;
        ret ok[u8, str]((hi * 16 + lo)::u8);
    }
    ret err[u8, str]("unknown escape sequence");
}

fun hex_digit(c: u8) i64 {
    if (c >= '0' && c <= '9') { ret (c - '0')::i64; }
    if (c >= 'a' && c <= 'f') { ret (c - 'a')::i64 + 10; }
    if (c >= 'A' && c <= 'F') { ret (c - 'A')::i64 + 10; }
    ret 0 - 1;
}

fun contains_byte(s: str, b: u8) bool {
    var i: u32 = 0;
    for (i < s.len) {
        if (s.data[i] == b) { ret true; }
        i = i + 1;
    }
    ret false;
}

# binary-operator dispatch
fun eval_binary(
    c:        *ComptimeCtx,
    a:        *ast.Ast,
    source:   str,
    bin:      *expr.ExprBinary,
    interner: *intern.Interner,
) Result[CTValue, str] {
    if (bin.op == expr.BIN_ASSIGN) { ret err[CTValue, str]("assignment is not comptime-evaluable"); }

    if (bin.op == expr.BIN_AND || bin.op == expr.BIN_OR) {
        ret eval_logical(c, a, source, bin, interner);
    }

    val lhs_r: Result[CTValue, str] = eval(c, a, source, bin.lhs, interner);
    if (is_err[CTValue, str](lhs_r)) { ret lhs_r; }
    val rhs_r: Result[CTValue, str] = eval(c, a, source, bin.rhs, interner);
    if (is_err[CTValue, str](rhs_r)) { ret rhs_r; }

    val lhs: CTValue = unwrap_ok[CTValue, str](lhs_r);
    val rhs: CTValue = unwrap_ok[CTValue, str](rhs_r);

    if (bin.op == expr.BIN_EQ || bin.op == expr.BIN_NEQ) {
        ret apply_equality(bin.op, lhs, rhs);
    }
    if (bin.op == expr.BIN_LT || bin.op == expr.BIN_LEQ
     || bin.op == expr.BIN_GT || bin.op == expr.BIN_GEQ) {
        ret apply_compare(bin.op, lhs, rhs);
    }
    ret apply_arith(bin.op, lhs, rhs);
}

# unary-operator dispatch
fun eval_unary(
    c:        *ComptimeCtx,
    a:        *ast.Ast,
    source:   str,
    un:       *expr.ExprUnary,
    interner: *intern.Interner,
) Result[CTValue, str] {
    if (un.op == expr.UN_ADDR || un.op == expr.UN_DEREF) {
        ret err[CTValue, str]("address-of and dereference are not comptime-evaluable");
    }

    val r: Result[CTValue, str] = eval(c, a, source, un.operand, interner);
    if (is_err[CTValue, str](r)) { ret r; }
    val v: CTValue = unwrap_ok[CTValue, str](r);

    if (un.op == expr.UN_NEG) {
        if (v.kind == CT_KIND_INT)   { ret int_value(0 - v.data.i); }
        if (v.kind == CT_KIND_FLOAT) { ret float_value(0.0 - v.data.f); }
        ret err[CTValue, str]("unary - requires a numeric operand");
    }
    if (un.op == expr.UN_NOT) {
        if (v.kind != CT_KIND_BOOL) { ret err[CTValue, str]("unary ! requires a bool operand"); }
        ret bool_value(!v.data.b);
    }
    if (un.op == expr.UN_BIT_NOT) {
        if (v.kind != CT_KIND_INT) { ret err[CTValue, str]("unary ~ requires an integer operand"); }
        ret int_value(~v.data.i);
    }
    ret err[CTValue, str]("unsupported unary operator");
}

# short-circuit && / ||
fun eval_logical(
    c:        *ComptimeCtx,
    a:        *ast.Ast,
    source:   str,
    bin:      *expr.ExprBinary,
    interner: *intern.Interner,
) Result[CTValue, str] {
    val lhs_r: Result[CTValue, str] = eval(c, a, source, bin.lhs, interner);
    if (is_err[CTValue, str](lhs_r)) { ret lhs_r; }
    val lhs: CTValue = unwrap_ok[CTValue, str](lhs_r);
    if (lhs.kind != CT_KIND_BOOL) { ret err[CTValue, str]("logical operator requires bool operands"); }

    if (bin.op == expr.BIN_AND && !lhs.data.b) { ret bool_value(false); }
    if (bin.op == expr.BIN_OR  &&  lhs.data.b) { ret bool_value(true); }

    val rhs_r: Result[CTValue, str] = eval(c, a, source, bin.rhs, interner);
    if (is_err[CTValue, str](rhs_r)) { ret rhs_r; }
    val rhs: CTValue = unwrap_ok[CTValue, str](rhs_r);
    if (rhs.kind != CT_KIND_BOOL) { ret err[CTValue, str]("logical operator requires bool operands"); }

    ret bool_value(rhs.data.b);
}

fun apply_equality(op: expr.BinOp, lhs: CTValue, rhs: CTValue) Result[CTValue, str] {
    if (lhs.kind != rhs.kind) {
        ret err[CTValue, str]("equality requires operands of the same kind");
    }
    var eq: bool = false;
    if (lhs.kind == CT_KIND_INT)   { eq = lhs.data.i == rhs.data.i; }
    or (lhs.kind == CT_KIND_FLOAT) { eq = lhs.data.f == rhs.data.f; }
    or (lhs.kind == CT_KIND_BOOL)  { eq = lhs.data.b == rhs.data.b; }
    or (lhs.kind == CT_KIND_STR)   { eq = lhs.data.s == rhs.data.s; }

    if (op == expr.BIN_EQ)  { ret bool_value(eq); }
    ret bool_value(!eq);
}

fun apply_compare(op: expr.BinOp, lhs: CTValue, rhs: CTValue) Result[CTValue, str] {
    if (lhs.kind != rhs.kind) {
        ret err[CTValue, str]("comparison requires operands of the same kind");
    }
    if (lhs.kind == CT_KIND_INT) {
        if (op == expr.BIN_LT)  { ret bool_value(lhs.data.i <  rhs.data.i); }
        if (op == expr.BIN_LEQ) { ret bool_value(lhs.data.i <= rhs.data.i); }
        if (op == expr.BIN_GT)  { ret bool_value(lhs.data.i >  rhs.data.i); }
        ret bool_value(lhs.data.i >= rhs.data.i);
    }
    if (lhs.kind == CT_KIND_FLOAT) {
        if (op == expr.BIN_LT)  { ret bool_value(lhs.data.f <  rhs.data.f); }
        if (op == expr.BIN_LEQ) { ret bool_value(lhs.data.f <= rhs.data.f); }
        if (op == expr.BIN_GT)  { ret bool_value(lhs.data.f >  rhs.data.f); }
        ret bool_value(lhs.data.f >= rhs.data.f);
    }
    ret err[CTValue, str]("ordered comparison requires numeric operands");
}

fun apply_arith(op: expr.BinOp, lhs: CTValue, rhs: CTValue) Result[CTValue, str] {
    if (lhs.kind != rhs.kind) {
        ret err[CTValue, str]("arithmetic requires operands of the same kind");
    }
    if (lhs.kind == CT_KIND_INT) {
        if (op == expr.BIN_ADD) { ret int_value(lhs.data.i + rhs.data.i); }
        if (op == expr.BIN_SUB) { ret int_value(lhs.data.i - rhs.data.i); }
        if (op == expr.BIN_MUL) { ret int_value(lhs.data.i * rhs.data.i); }
        if (op == expr.BIN_DIV) {
            if (rhs.data.i == 0) { ret err[CTValue, str]("integer division by zero"); }
            ret int_value(lhs.data.i / rhs.data.i);
        }
        if (op == expr.BIN_MOD) {
            if (rhs.data.i == 0) { ret err[CTValue, str]("integer modulo by zero"); }
            ret int_value(lhs.data.i % rhs.data.i);
        }
        if (op == expr.BIN_BIT_AND) { ret int_value(lhs.data.i & rhs.data.i); }
        if (op == expr.BIN_BIT_OR)  { ret int_value(lhs.data.i | rhs.data.i); }
        if (op == expr.BIN_BIT_XOR) { ret int_value(lhs.data.i ^ rhs.data.i); }
        if (op == expr.BIN_SHL)     { ret int_value(lhs.data.i << rhs.data.i); }
        if (op == expr.BIN_SHR)     { ret int_value(lhs.data.i >> rhs.data.i); }
        ret err[CTValue, str]("unsupported integer operator");
    }
    if (lhs.kind == CT_KIND_FLOAT) {
        if (op == expr.BIN_ADD) { ret float_value(lhs.data.f + rhs.data.f); }
        if (op == expr.BIN_SUB) { ret float_value(lhs.data.f - rhs.data.f); }
        if (op == expr.BIN_MUL) { ret float_value(lhs.data.f * rhs.data.f); }
        if (op == expr.BIN_DIV) {
            if (rhs.data.f == 0.0) { ret err[CTValue, str]("float division by zero"); }
            ret float_value(lhs.data.f / rhs.data.f);
        }
        ret err[CTValue, str]("unsupported float operator");
    }
    ret err[CTValue, str]("arithmetic requires numeric operands");
}

# resolves a bare identifier expression (no `$` prefix). language-level
# boolean literals `true` and `false` are short-circuited; everything else
# must have been registered as a comptime constant by the driver.
fun eval_ident(
    c:        *ComptimeCtx,
    source:   str,
    span:     token.Span,
    interner: *intern.Interner,
) Result[CTValue, str] {
    val text: str = span_text(source, span);
    if (str_equals(text, "true"))  { ret bool_value(true); }
    if (str_equals(text, "false")) { ret bool_value(false); }

    val id_r: Result[intern.StrId, str] = intern.intern_span(interner, source, span);
    if (is_err[intern.StrId, str](id_r)) {
        ret err[CTValue, str](unwrap_err[intern.StrId, str](id_r));
    }
    val name: intern.StrId = unwrap_ok[intern.StrId, str](id_r);
    val nc: *NamedConst = lookup(c, name);
    if (nc == nil) {
        ret err[CTValue, str]("identifier is not a comptime constant in scope");
    }
    ret ok[CTValue, str](nc.value);
}

# resolves a `$mach.<...>` path expression. the path may bottom out at a
# COMPTIME_IDENT (single-segment, e.g. `$foo`) or be a chain of MEMBER
# expressions whose leftmost root is a COMPTIME_IDENT.
fun eval_path(
    c:        *ComptimeCtx,
    a:        *ast.Ast,
    source:   str,
    e:        id.ExprId,
    interner: *intern.Interner,
) Result[CTValue, str] {
    var stack: [16]token.Span;
    var depth: u32 = 0;

    var cur: id.ExprId = e;
    for (true) {
        if (depth >= 16) { ret err[CTValue, str]("comptime path is too deeply nested"); }
        val node: *expr.Expr = ast.get_expr(a, cur);
        if (node.kind == expr.EXPR_KIND_MEMBER) {
            stack[depth] = node.data.member.name;
            depth = depth + 1;
            cur = node.data.member.object;
            cnt;
        }
        if (node.kind == expr.EXPR_KIND_COMPTIME_IDENT) {
            stack[depth] = comptime_ident_name(node.span);
            depth = depth + 1;
            brk;
        }
        ret err[CTValue, str]("comptime path must start with a `$` identifier");
    }

    ret resolve_mach_path(c, source, ?stack[0], depth);
}

# returns the span of the identifier portion of a `$ident` token (skips the
# leading `$`)
fun comptime_ident_name(full: token.Span) token.Span {
    var s: token.Span;
    s.offset = full.offset + 1;
    if (full.len > 0) { s.len = full.len - 1; } or { s.len = 0; }
    ret s;
}

# matches the path text built from the segment stack against the recognized
# `$mach.*` namespace and returns the corresponding compile-time value.
# `stack` is leaf-first: stack[0] is the rightmost segment and
# stack[depth - 1] is the root (`mach`).
fun resolve_mach_path(c: *ComptimeCtx, source: str, stack: *token.Span, depth: u32) Result[CTValue, str] {
    if (depth == 0) { ret err[CTValue, str]("empty comptime path"); }

    val root: str = span_text(source, stack[depth - 1]);
    if (!str_equals(root, "mach")) {
        ret err[CTValue, str]("comptime path root must be `$mach`");
    }

    # $mach.compiler.version
    if (depth == 3 && seg_is(source, stack, 1, "compiler") && seg_is(source, stack, 0, "version")) {
        ret str_value(c.compiler_ver);
    }
    # $mach.compiler.name
    if (depth == 3 && seg_is(source, stack, 1, "compiler") && seg_is(source, stack, 0, "name")) {
        ret str_value(c.compiler_name);
    }

    # $mach.build.target.pointer_width
    if (depth == 4
     && seg_is(source, stack, 2, "build")
     && seg_is(source, stack, 1, "target")
     && seg_is(source, stack, 0, "pointer_width")) {
        ret int_value(c.pointer_width::i64);
    }

    # $mach.build.target.os.id
    if (depth == 5
     && seg_is(source, stack, 3, "build")
     && seg_is(source, stack, 2, "target")
     && seg_is(source, stack, 1, "os")
     && seg_is(source, stack, 0, "id")) {
        ret int_value(c.target_os_id::i64);
    }

    # $mach.build.target.arch.id
    if (depth == 5
     && seg_is(source, stack, 3, "build")
     && seg_is(source, stack, 2, "target")
     && seg_is(source, stack, 1, "arch")
     && seg_is(source, stack, 0, "id")) {
        ret int_value(c.target_arch_id::i64);
    }

    # $mach.os.<name>.id
    if (depth == 4 && seg_is(source, stack, 2, "os") && seg_is(source, stack, 0, "id")) {
        val name: str = span_text(source, stack[1]);
        ret int_value(os_id_for(name)::i64);
    }

    # $mach.arch.<name>.id
    if (depth == 4 && seg_is(source, stack, 2, "arch") && seg_is(source, stack, 0, "id")) {
        val name: str = span_text(source, stack[1]);
        ret int_value(arch_id_for(name)::i64);
    }

    ret err[CTValue, str]("unknown `$mach.*` path");
}

# compares the segment at `idx` (0 = leaf, depth - 1 = root) against `expected`
fun seg_is(source: str, stack: *token.Span, idx: u32, expected: str) bool {
    val span: token.Span = stack[idx];
    val text: str = span_text(source, span);
    ret str_equals(text, expected);
}

fun os_id_for(name: str) u32 {
    if (str_equals(name, "linux"))   { ret os.OS_LINUX; }
    if (str_equals(name, "darwin"))  { ret os.OS_DARWIN; }
    if (str_equals(name, "windows")) { ret os.OS_WINDOWS; }
    ret os.OS_UNKNOWN;
}

fun arch_id_for(name: str) u32 {
    if (str_equals(name, "x86_64"))  { ret isa.ARCH_X86_64; }
    if (str_equals(name, "aarch64")) { ret isa.ARCH_AARCH64; }
    ret isa.ARCH_UNKNOWN;
}

fun int_value(i: i64) Result[CTValue, str] {
    var v: CTValue;
    v.kind   = CT_KIND_INT;
    v.data.i = i;
    ret ok[CTValue, str](v);
}

fun float_value(f: f64) Result[CTValue, str] {
    var v: CTValue;
    v.kind   = CT_KIND_FLOAT;
    v.data.f = f;
    ret ok[CTValue, str](v);
}

fun bool_value(b: bool) Result[CTValue, str] {
    var v: CTValue;
    v.kind   = CT_KIND_BOOL;
    v.data.b = b;
    ret ok[CTValue, str](v);
}

fun str_value(s: intern.StrId) Result[CTValue, str] {
    var v: CTValue;
    v.kind   = CT_KIND_STR;
    v.data.s = s;
    ret ok[CTValue, str](v);
}
