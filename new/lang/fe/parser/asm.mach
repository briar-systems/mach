# Inline assembly. Parses the optional ISA tag, the operand list
# (`name: in`, `name: out`, `name: clobber`, with optional `= source`
# rename), and collects the raw body text by tracking brace depth
# through the already-lexed token stream.

use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use token:  mach.lang.fe.token;
use ast:    mach.lang.fe.ast;
use id:     mach.lang.fe.ast.id;
use stmt:   mach.lang.fe.ast.stmt;
use parser: mach.lang.fe.parser.state;

# parses an `asm [ISA]? (operand_list)? { body }` statement starting at the `asm` keyword
# ---
# p:   parser state; current token must be the IDENT `asm`
# ret: StmtId of the resulting STMT_KIND_ASM node
pub fun parse_asm(p: *parser.Parser) id.StmtId {
    val start: token.Token = parser.advance(p);

    var isa: token.Span;
    isa.offset = 0;
    isa.len    = 0;

    if (parser.at(p, token.KIND_IDENT)) {
        isa = parser.advance(p).span;
    }

    val operands_start: u32 = p.ast.asm_operand_len::u32;
    var operands_len:   u32 = 0;

    if (parser.at(p, token.KIND_LPAREN)) {
        operands_len = parse_operand_list(p);
    }

    var body: token.Span;
    body.offset = 0;
    body.len    = 0;
    var end_span: token.Span = start.span;

    if (!parser.at(p, token.KIND_LBRACE)) {
        parser.error_at_current(p, "expected '{' to open inline assembly body");
    } or {
        val lbrace: token.Token = parser.advance(p);
        val body_start: usize = lbrace.span.offset + lbrace.span.len;
        collect_body(p, body_start, ?body, ?end_span);
    }

    var asm_stmt: stmt.StmtAsm;
    asm_stmt.isa            = isa;
    asm_stmt.operands_start = operands_start;
    asm_stmt.operands_len   = operands_len;
    asm_stmt.body           = body;

    var node: stmt.Stmt;
    node.span = parser.span_of(start.span, end_span);
    node.kind = stmt.STMT_KIND_ASM;
    node.data.asm_ = asm_stmt;
    ret parser.push_stmt(p, node);
}

# parses the operand list `(name: role [= source], ...)`
# ---
# p:   parser state; current token must be LPAREN
# ret: number of operands appended to ast.asm_operands
fun parse_operand_list(p: *parser.Parser) u32 {
    parser.advance(p);

    var count: u32 = 0;

    if (parser.at(p, token.KIND_RPAREN)) {
        parser.advance(p);
        ret 0;
    }

    if (!parse_operand(p)) {
        parser.sync_to(p, token.KIND_RPAREN, token.KIND_LBRACE, token.KIND_EOF);
        if (parser.at(p, token.KIND_RPAREN)) { parser.advance(p); }
        ret count;
    }
    count = count + 1;

    for (parser.eat(p, token.KIND_COMMA)) {
        if (!parse_operand(p)) {
            parser.sync_to(p, token.KIND_RPAREN, token.KIND_LBRACE, token.KIND_EOF);
            brk;
        }
        count = count + 1;
    }

    parser.expect(p, token.KIND_RPAREN, "expected ')' to close asm operand list");
    ret count;
}

# parses a single operand `name: role [= source]` and appends it to ast.asm_operands
# ---
# p:   parser state
# ret: true on success; false if the syntax was invalid (caller handles recovery)
fun parse_operand(p: *parser.Parser) bool {
    if (!parser.at(p, token.KIND_IDENT)) {
        parser.error_at_current(p, "expected an operand name");
        ret false;
    }
    val name: token.Span = parser.advance(p).span;

    if (!parser.expect(p, token.KIND_COLON, "expected ':' after operand name")) { ret false; }

    if (!parser.at(p, token.KIND_IDENT)) {
        parser.error_at_current(p, "expected 'in', 'out', or 'clobber'");
        ret false;
    }

    var role: stmt.AsmOperandRole;
    if      (parser.at_kw(p, "in"))      { role = stmt.ASM_OP_IN; }
    or      (parser.at_kw(p, "out"))     { role = stmt.ASM_OP_OUT; }
    or      (parser.at_kw(p, "clobber")) { role = stmt.ASM_OP_CLOBBER; }
    or                                   {
        parser.error_at_current(p, "expected 'in', 'out', or 'clobber'");
        ret false;
    }
    parser.advance(p);

    var source: token.Span;
    source.offset = 0;
    source.len    = 0;

    if (role != stmt.ASM_OP_CLOBBER && parser.at(p, token.KIND_EQ)) {
        parser.advance(p);
        if (!parser.at(p, token.KIND_IDENT)) {
            parser.error_at_current(p, "expected mach-level identifier after '='");
            ret false;
        }
        source = parser.advance(p).span;
    }

    var op: stmt.AsmOperand;
    op.role   = role;
    op.name   = name;
    op.source = source;

    val r: Result[u32, str] = ast.add_asm_operand(p.ast, op);
    if (is_err[u32, str](r)) {
        parser.error_at(p, name, "out of memory while parsing asm operand");
        ret false;
    }
    ret true;
}

# collects the raw body text between the already-consumed `{` and its matching `}` by tracking brace depth through the token stream
# ---
# p:            parser state; current token is the first token inside the body, after `{`
# start_offset: byte offset immediately after the opening `{`
# body:         out-parameter receiving the span covering the raw body text
# end_span:     out-parameter receiving the span of the closing `}`
fun collect_body(p: *parser.Parser, start_offset: usize, body: *token.Span, end_span: *token.Span) {
    var depth:       usize = 1;
    var last_offset: usize = start_offset;

    for (!parser.at_eof(p)) {
        val t: token.Token = parser.current(p);
        if (t.kind == token.KIND_LBRACE) {
            depth = depth + 1;
            last_offset = t.span.offset + t.span.len;
            parser.advance(p);
            cnt;
        }
        if (t.kind == token.KIND_RBRACE) {
            depth = depth - 1;
            if (depth == 0) {
                body.offset = start_offset;
                body.len    = t.span.offset - start_offset;
                end_span.offset = t.span.offset;
                end_span.len    = t.span.len;
                parser.advance(p);
                ret;
            }
            last_offset = t.span.offset + t.span.len;
            parser.advance(p);
            cnt;
        }
        last_offset = t.span.offset + t.span.len;
        parser.advance(p);
    }

    parser.error_at_current(p, "unterminated asm body");
    body.offset     = start_offset;
    body.len        = last_offset - start_offset;
    end_span.offset = last_offset;
    end_span.len    = 0;
}
