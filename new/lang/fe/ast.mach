    or (a.decl_len == a.decl_cap) {
        val new_cap: usize = a.decl_cap * 2;
        val r: Result[*decl.Decl, str] = reallocate[decl.Decl](a.alloc, a.decls, a.decl_cap, new_cap);
        if (is_err[*decl.Decl, str](r)) {
