# Identifier interner. Maps text to stable `StrId` handles. The same
# byte sequence presented twice resolves to the same `StrId`; the
# resolved bytes remain valid for the interner's lifetime.

use std.types.bool;
use std.types.option;
use std.types.size;
use std.types.string;
use std.types.result;

use std.allocator;

use map: std.collections.map;

use token: mach.lang.fe.token;

# stable handle into an Interner's universe.
pub def StrId: u32;

pub val STR_NIL: StrId = 0xFFFFFFFF;

# string interner: dedupes inserts and assigns each unique string a stable u32 id
# ---
# alloc:   allocator used for owned copies, the index, and the dedup map
# strings: array of owned strings indexed by StrId
# len:     number of strings stored
# cap:     allocated slots in strings
# dedup:   text -> StrId map keyed by content for O(1) interning
pub rec Interner {
    alloc:   *Allocator;
    strings: *str;
    len:     usize;
    cap:     usize;
    dedup:   map.Map[str, StrId];
}

val INITIAL_CAP: usize = 32;

# constructs an empty Interner backed by the given allocator
# ---
# alloc: allocator used for owned strings, the index, and the dedup map
# ret:   a new empty Interner
pub fun init(alloc: *Allocator) Interner {
    var i: Interner;
    i.alloc   = alloc;
    i.strings = nil;
    i.len     = 0;
    i.cap     = 0;
    i.dedup   = map.init[str, StrId](alloc, map.hash_str, map.eq_str);
    ret i;
}

# frees every owned string, the index, and the dedup map
# ---
# i: the interner to tear down; all fields are zeroed
pub fun dnit(i: *Interner) {
    if (i == nil) { ret; }

    var k: usize = 0;
    for (k < i.len) {
        str_free(i.alloc, i.strings[k]);
        k = k + 1;
    }

    if (i.strings != nil && i.cap > 0) {
        deallocate[str](i.alloc, i.strings, i.cap);
    }

    map.dnit[str, StrId](?i.dedup);

    i.strings = nil;
    i.len     = 0;
    i.cap     = 0;
}

# returns the StrId for text, allocating an owned copy and a fresh id only on first occurrence
# ---
# i:    the interner
# text: text to intern
# ret:  the StrId for text (existing or new), or an allocation error
pub fun intern(i: *Interner, text: str) Result[StrId, str] {
    val existing: Result[*StrId, str] = map.get[str, StrId](?i.dedup, ?text);
    if (is_ok[*StrId, str](existing)) {
        ret ok[StrId, str](@unwrap_ok[*StrId, str](existing));
    }

    val cp_r: Result[str, str] = str_dup(i.alloc, text);
    if (is_err[str, str](cp_r)) {
        ret err[StrId, str](unwrap_err[str, str](cp_r));
    }
    val owned: str = unwrap_ok[str, str](cp_r);

    ret store_and_index(i, owned);
}

# returns the StrId for a substring of source, allocating only on first occurrence
# ---
# i:      the interner
# source: source string the slice is taken from
# span:   byte range within source to intern
# ret:    the StrId for the substring (existing or new), or an allocation error
pub fun intern_span(i: *Interner, source: str, span: token.Span) Result[StrId, str] {
    val cp_r: Result[str, str] = str_dup_range(i.alloc, source, span.offset, span.len);
    if (is_err[str, str](cp_r)) {
        ret err[StrId, str](unwrap_err[str, str](cp_r));
    }
    val owned: str = unwrap_ok[str, str](cp_r);

    val existing: Result[*StrId, str] = map.get[str, StrId](?i.dedup, ?owned);
    if (is_ok[*StrId, str](existing)) {
        str_free(i.alloc, owned);
        ret ok[StrId, str](@unwrap_ok[*StrId, str](existing));
    }

    ret store_and_index(i, owned);
}

# returns the text for a previously interned id, or none when id is out
# of range; the returned str is stable for the interner's lifetime
# ---
# i:   the interner
# id:  StrId returned by a previous intern() or intern_span() call
# ret: some(text) when id is in range, none otherwise
pub fun lookup(i: *Interner, id: StrId) Option[str] {
    if (id::usize >= i.len) { ret none[str](); }
    ret some[str](i.strings[id]);
}

# stores `owned` in the strings array, indexes it in the dedup map, and returns its new StrId
fun store_and_index(i: *Interner, owned: str) Result[StrId, str] {
    if (i.strings == nil) {
        val r: Result[*str, str] = allocate[str](i.alloc, INITIAL_CAP);
        if (is_err[*str, str](r)) {
            str_free(i.alloc, owned);
            ret err[StrId, str](unwrap_err[*str, str](r));
        }
        i.strings = unwrap_ok[*str, str](r);
        i.cap     = INITIAL_CAP;
    }
    or (i.len == i.cap) {
        val new_cap: usize = i.cap * 2;
        val r: Result[*str, str] = reallocate[str](i.alloc, i.strings, i.cap, new_cap);
        if (is_err[*str, str](r)) {
            str_free(i.alloc, owned);
            ret err[StrId, str](unwrap_err[*str, str](r));
        }
        i.strings = unwrap_ok[*str, str](r);
        i.cap     = new_cap;
    }

    val new_id: StrId = i.len::u32;
    i.strings[i.len] = owned;
    i.len = i.len + 1;

    val ins_r: Result[bool, str] = map.insert[str, StrId](?i.dedup, owned, new_id);
    if (is_err[bool, str](ins_r)) {
        str_free(i.alloc, owned);
        var empty: str;
        empty.len  = 0;
        empty.data = nil;
        i.strings[i.len - 1] = empty;
        i.len = i.len - 1;
        ret err[StrId, str](unwrap_err[bool, str](ins_r));
    }

    ret ok[StrId, str](new_id);
}
