use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use std.allocator;

use token: mach.lang.fe.token;
use src:   mach.lang.source;

# severity level of a Diagnostic
pub def Severity: u8;

pub val SEVERITY_ERROR:   Severity = 0;
pub val SEVERITY_WARNING: Severity = 1;
pub val SEVERITY_INFO:    Severity = 2;
pub val SEVERITY_HELP:    Severity = 3;

# a single reported diagnostic tied to a span in a source file
# ---
# severity: severity level of the diagnostic
# file_id:  identifier of the file the span points into
# span:     byte range being reported on
# message:  owned human-readable message
pub rec Diagnostic {
    severity: Severity;
    file_id:  src.FileId;
    span:     token.Span;
    message:  str;
}

# owning list of diagnostics collected during one or more phases
# ---
# alloc: allocator used for the items array and every owned message
# items: contiguous array of Diagnostic records
# len:   number of diagnostics currently stored
# cap:   allocated slots in items
pub rec DiagList {
    alloc: *Allocator;
    items: *Diagnostic;
    len:   usize;
    cap:   usize;
}

val INITIAL_CAP: usize = 16;

# constructs an empty diagnostic list backed by the given allocator
# ---
# alloc: allocator used for the items array and owned messages
# ret:   a new empty DiagList
pub fun init(alloc: *Allocator) DiagList {
    var d: DiagList;
    d.alloc = alloc;
    d.items = nil;
    d.len   = 0;
    d.cap   = 0;
    ret d;
}

# frees every diagnostic's message and the list's backing array
# ---
# list: the list to tear down; all fields are zeroed
pub fun dnit(list: *DiagList) {
    if (list == nil) { ret; }

    var i: usize = 0;
    for (i < list.len) {
        val d: *Diagnostic = ?list.items[i];
        str_free(list.alloc, d.message);
        i = i + 1;
    }

    if (list.items != nil && list.cap > 0) {
        deallocate[Diagnostic](list.alloc, list.items, list.cap);
    }
    list.items = nil;
    list.len   = 0;
    list.cap   = 0;
}

# records an error-severity diagnostic, duplicating the message into the list's allocator
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun error(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_ERROR, file_id, span, message);
}

# records a warning-severity diagnostic, duplicating the message into the list's allocator
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun warning(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_WARNING, file_id, span, message);
}

# records an info-severity diagnostic, duplicating the message into the list's allocator
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun info(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_INFO, file_id, span, message);
}

# records a help-severity diagnostic, duplicating the message into the list's allocator
# ---
# list:    diagnostic list to append to
# file_id: identifier of the file the span points into
# span:    byte range being reported on
# message: human-readable message (copied)
# ret:     true on success, or an allocation error
pub fun help(list: *DiagList, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    ret emit(list, SEVERITY_HELP, file_id, span, message);
}

# reports whether the list contains at least one error-severity diagnostic
# ---
# list: the list to scan
# ret:  true if any entry has SEVERITY_ERROR
pub fun has_errors(list: *DiagList) bool {
    var i: usize = 0;
    for (i < list.len) {
        if (list.items[i].severity == SEVERITY_ERROR) {
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

fun emit(list: *DiagList, severity: Severity, file_id: src.FileId, span: token.Span, message: str) Result[bool, str] {
    val r_msg: Result[str, str] = str_dup(list.alloc, message);
    if (is_err[str, str](r_msg)) {
        ret err[bool, str](unwrap_err[str, str](r_msg));
    }
    val owned: str = unwrap_ok[str, str](r_msg);

    if (list.items == nil) {
        val r: Result[*Diagnostic, str] = allocate[Diagnostic](list.alloc, INITIAL_CAP);
        if (is_err[*Diagnostic, str](r)) {
            str_free(list.alloc, owned);
            ret err[bool, str](unwrap_err[*Diagnostic, str](r));
        }
        list.items = unwrap_ok[*Diagnostic, str](r);
        list.cap   = INITIAL_CAP;
    }
    or (list.len == list.cap) {
        val new_cap: usize = list.cap * 2;
        val r: Result[*Diagnostic, str] = reallocate[Diagnostic](list.alloc, list.items, list.cap, new_cap);
        if (is_err[*Diagnostic, str](r)) {
            str_free(list.alloc, owned);
            ret err[bool, str](unwrap_err[*Diagnostic, str](r));
        }
        list.items = unwrap_ok[*Diagnostic, str](r);
        list.cap   = new_cap;
    }

    var d: Diagnostic;
    d.severity = severity;
    d.file_id  = file_id;
    d.span     = span;
    d.message  = owned;
    list.items[list.len] = d;
    list.len = list.len + 1;

    ret ok[bool, str](true);
}
