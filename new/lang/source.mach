use std.types.bool;
use std.types.size;
use std.types.string;
use std.types.result;

use std.allocator;

# identifier for a loaded source file, stable for the lifetime of its SourceMap
pub def FileId: u32;

# 1-based line and column within a source file
# ---
# line: line number, 1-based
# col:  column number, 1-based
pub rec Position {
    line: usize;
    col:  usize;
}

# a loaded source file with a precomputed newline index
# ---
# path:        owned file path as known to the loader
# text:        owned source text; text.data[text.len] is 0 for FFI-friendliness
# line_starts: byte offset of the start of each line
# line_len:    number of entries in line_starts
pub rec SourceFile {
    path:        str;
    text:        str;
    line_starts: *usize;
    line_len:    usize;
}

# registry of loaded source files indexed by FileId
# ---
# alloc: allocator used for all owned storage in this map
# files: contiguous array of SourceFile records
# len:   number of files currently stored
# cap:   allocated slots in files
pub rec SourceMap {
    alloc: *Allocator;
    files: *SourceFile;
    len:   usize;
    cap:   usize;
}

val INITIAL_MAP_CAP: usize = 8;

# constructs an empty source map backed by the given allocator
# ---
# alloc: allocator used for path, text, line index, and file array storage
# ret:   a new empty SourceMap
pub fun init(alloc: *Allocator) SourceMap {
    var m: SourceMap;
    m.alloc = alloc;
    m.files = nil;
    m.len   = 0;
    m.cap   = 0;
    ret m;
}

# releases every loaded file and clears the map
# ---
# m: the map to tear down; all fields are zeroed
pub fun dnit(m: *SourceMap) {
    if (m == nil) { ret; }

    var i: usize = 0;
    for (i < m.len) {
        val file: *SourceFile = ?m.files[i];
        str_free(m.alloc, file.path);
        str_free(m.alloc, file.text);
        if (file.line_starts != nil && file.line_len > 0) {
            deallocate[usize](m.alloc, file.line_starts, file.line_len);
        }
        i = i + 1;
    }

    if (m.files != nil && m.cap > 0) {
        deallocate[SourceFile](m.alloc, m.files, m.cap);
    }
    m.files = nil;
    m.len   = 0;
    m.cap   = 0;
}

# registers a source file, copying its path and text into the map's allocator
# ---
# m:    the source map
# path: file path to associate with this file
# text: source text to index and store; the stored copy is null-terminated
# ret:  FileId of the newly added file, or an allocation error
pub fun add(m: *SourceMap, path: str, text: str) Result[FileId, str] {
    val text_len: usize = text.len::usize;

    var line_len: usize = 1;
    var i: usize = 0;
    for (i < text_len) {
        if (text.data[i] == '\n') { line_len = line_len + 1; }
        i = i + 1;
    }

    val r_starts: Result[*usize, str] = allocate[usize](m.alloc, line_len);
    if (is_err[*usize, str](r_starts)) {
        ret err[FileId, str](unwrap_err[*usize, str](r_starts));
    }
    val starts: *usize = unwrap_ok[*usize, str](r_starts);

    starts[0] = 0;
    var idx: usize = 1;
    i = 0;
    for (i < text_len) {
        if (text.data[i] == '\n') {
            starts[idx] = i + 1;
            idx = idx + 1;
        }
        i = i + 1;
    }

    val r_path: Result[str, str] = str_dup(m.alloc, path);
    if (is_err[str, str](r_path)) {
        deallocate[usize](m.alloc, starts, line_len);
        ret err[FileId, str](unwrap_err[str, str](r_path));
    }
    val path_copy: str = unwrap_ok[str, str](r_path);

    val r_text: Result[str, str] = str_dup(m.alloc, text);
    if (is_err[str, str](r_text)) {
        str_free(m.alloc, path_copy);
        deallocate[usize](m.alloc, starts, line_len);
        ret err[FileId, str](unwrap_err[str, str](r_text));
    }
    val text_copy: str = unwrap_ok[str, str](r_text);

    if (m.files == nil) {
        val r: Result[*SourceFile, str] = allocate[SourceFile](m.alloc, INITIAL_MAP_CAP);
        if (is_err[*SourceFile, str](r)) {
            str_free(m.alloc, text_copy);
            str_free(m.alloc, path_copy);
            deallocate[usize](m.alloc, starts, line_len);
            ret err[FileId, str](unwrap_err[*SourceFile, str](r));
        }
        m.files = unwrap_ok[*SourceFile, str](r);
        m.cap   = INITIAL_MAP_CAP;
    }
    or (m.len == m.cap) {
        val new_cap: usize = m.cap * 2;
        val r: Result[*SourceFile, str] = reallocate[SourceFile](m.alloc, m.files, m.cap, new_cap);
        if (is_err[*SourceFile, str](r)) {
            str_free(m.alloc, text_copy);
            str_free(m.alloc, path_copy);
            deallocate[usize](m.alloc, starts, line_len);
            ret err[FileId, str](unwrap_err[*SourceFile, str](r));
        }
        m.files = unwrap_ok[*SourceFile, str](r);
        m.cap   = new_cap;
    }

    var file: SourceFile;
    file.path        = path_copy;
    file.text        = text_copy;
    file.line_starts = starts;
    file.line_len    = line_len;

    val id: FileId = m.len::u32;
    m.files[m.len] = file;
    m.len = m.len + 1;

    ret ok[FileId, str](id);
}

# returns a pointer to the SourceFile for a given FileId
# ---
# m:   the source map
# id:  identifier of the file to look up
# ret: pointer into the map's files array; invalidated by a later add() that grows the array
pub fun get(m: *SourceMap, id: FileId) *SourceFile {
    ret ?m.files[id];
}

# converts a byte offset in a file to a 1-based Position
# ---
# file:   the source file being queried
# offset: byte offset into file.text
# ret:    a 1-based (line, col) Position
pub fun position(file: *SourceFile, offset: usize) Position {
    var lo: usize = 0;
    var hi: usize = file.line_len;
    for (lo < hi) {
        val mid: usize = lo + (hi - lo) / 2;
        if (file.line_starts[mid] <= offset) {
            lo = mid + 1;
        } or {
            hi = mid;
        }
    }

    var p: Position;
    p.line = lo;
    p.col  = offset - file.line_starts[lo - 1] + 1;
    ret p;
}

# returns the byte offset where a 1-based line begins
# ---
# file: the source file being queried
# line: 1-based line number
# ret:  byte offset of the line start, or file.text.len if line is out of range
pub fun line_start(file: *SourceFile, line: usize) usize {
    if (line == 0 || line > file.line_len) {
        ret file.text.len::usize;
    }
    ret file.line_starts[line - 1];
}
