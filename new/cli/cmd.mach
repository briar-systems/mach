use std.types.size;
use std.types.zstr;

use print: std.print;

use cmd_help: mach.cli.cmd_help;

# dispatch: dispatch subcommands based on CLI args
# ---
# argc: argument count
# argv: argument vector
# ret:  exit code
pub fun dispatch(argc: usize, argv: *zstr) i64 {
    if (argc < 2) {
        cmd_help.run(argc, argv);
        ret 1;
    }

    val command: zstr = argv[1];

    if (zstr_equals(command, `build`)) { ret cmd_build.run(argc, argv); }
    if (zstr_equals(command, `run`))   { ret cmd_run.run(argc, argv); }
    if (zstr_equals(command, `test`))  { ret cmd_test.run(argc, argv); }
    if (zstr_equals(command, `dep`))   { ret cmd_dep.run(argc, argv); }
    if (zstr_equals(command, `init`))  { ret cmd_init.run(argc, argv); }
    if (zstr_equals(command, `help`))  { ret cmd_help.run(argc, argv); }

    print.eprintlnf("error: unknown command '%s'", command);
    cmd_help.run(argc, argv);
    ret 1;
}
