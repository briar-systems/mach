# invel/1718-scope experiment: control. identical raw-svc exit(42) program, but no
# dylib dependency, so the linker takes the static (emit_exec) path: LC_UNIXTHREAD,
# no LC_LOAD_DYLINKER, no dyld. expected to be Killed:9 on Apple Silicon, confirming
# the established static-image rejection on the same runner the dynamic variants run.

#[symbol("start")]
pub fun start() {
    asm aarch64 {
        mov x0, 42        # exit status 42
        mov x16, 1        # SYS_exit
        svc 0x80
    }
}
