# invel/1718-scope experiment: minimal arm64-darwin program that exits 42 through a
# libSystem call instead of a raw trap. `_exit` is the Mach-O symbol for C `exit`;
# the call is bound by dyld to /usr/lib/libSystem.B.dylib via a stub + GOT slot.
# probes whether routing the syscall through libSystem (vs raw svc) is what Apple
# Silicon requires once the image is dyld-linked.

#[library("/usr/lib/libSystem.B.dylib")]
#[symbol("_exit")]
ext fun libc_exit(code: i32);

#[symbol("start")]
pub fun start() {
    libc_exit(42);
}
