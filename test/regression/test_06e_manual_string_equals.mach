use std.runtime;
use std.types.string;
use std.types.size;
use std.types.bool;

fun manual_eq(a: str, b: str) bool {
    var i: usize = 0;
    for (a[i] != 0 && b[i] != 0) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret a[i] == b[i];
}

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val a: str = "abc";
    val b: str = "abc";
    val c: str = "abd";

    if (!manual_eq(a, b)) { ret 1; }
    if (manual_eq(a, c)) { ret 2; }
    ret 0;
}
