use std.runtime;
use std.types.string;
use std.types.size;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val s: str = "abc";
    var i: usize = 0;
    var count: usize = 0;
    
    for (s[i] != 0) {
        count = count + 1;
        i = i + 1;
    }
    
    if (count != 3) { ret 1; }
    ret 0;
}
