use std.runtime;
use std.types.size;

rec Holder {
    data: [4]i32;
}

fun (this:*Holder) get(i:usize) i32 {
    ret this.data[i];
}

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    var h:Holder;
    var idx:usize = 0;
    h.data[idx] = 10i32;
    idx = idx + 1;
    h.data[idx] = 20i32;
    idx = idx + 1;
    h.data[idx] = 30i32;
    idx = idx + 1;
    h.data[idx] = 40i32;

    var i:usize = 2;
    val v:i32 = h.get(i);
    if (v != 30i32) { ret 1; }
    ret 0;
}
