use std.runtime;
use std.types.size;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val arr: [4]u8 = [4]u8{ 1, 2, 3, 0 };
    var i: usize = 0;
    
    # can we index with a constant?
    if (arr[0] != 1) { ret 1; }
    if (arr[1] != 2) { ret 2; }
    if (arr[2] != 3) { ret 3; }
    if (arr[3] != 0) { ret 4; }
    
    # can we index with a variable?
    i = 0;
    if (arr[i] != 1) { ret 5; }
    i = 1;
    if (arr[i] != 2) { ret 6; }
    
    ret 0;
}
