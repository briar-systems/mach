use std.runtime;
use std.types.string;
use lib: regression.lib_04_abi_return;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val p: lib.Pair = lib.make_pair();
    if (p.a != 11i32) { ret 1; }
    if (p.b != 22i32) { ret 2; }
    val s: str = lib.make_str();
    if (s[0] != 'o') { ret 3; }
    if (s[1] != 'k') { ret 4; }
    if (s[2] != 0) { ret 5; }
    ret 0;
}
