use std.runtime;
use std.types.string;
use std.types.bool;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val a: str = "abc";
    val b: str = "abc";
    val c: str = "abd";
    if (!a.equals(b)) { ret 1; }
    if (a.equals(c)) { ret 2; }
    if (!"".equals("")) { ret 3; }
    ret 0;
}
