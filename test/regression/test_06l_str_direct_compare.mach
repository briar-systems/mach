use std.runtime;
use std.types.string;
use std.types.size;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val a: str = "abc";
    val b: str = "abc";
    
    # direct compare bytes at indices 0, 1, 2
    if (a[0] != b[0]) { ret 1; }
    if (a[1] != b[1]) { ret 2; }
    if (a[2] != b[2]) { ret 3; }
    
    ret 0;
}
