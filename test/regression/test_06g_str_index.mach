use std.runtime;
use std.types.string;
use std.types.size;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val a: str = "abc";
    var i: usize = 0;
    
    # test: can we index a str and compare?
    if (a[0] != 97) { ret 1; }  # 'a' = 97
    if (a[1] != 98) { ret 2; }  # 'b' = 98
    if (a[2] != 99) { ret 3; }  # 'c' = 99
    if (a[3] != 0)  { ret 4; }  # null terminator
    
    # test: indexing with variable
    i = 0;
    if (a[i] != 97) { ret 5; }
    i = 1;
    if (a[i] != 98) { ret 6; }
    
    ret 0;
}
