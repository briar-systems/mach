use std.runtime;

rec Pair {
    a: i32;
    b: i32;
}

fun make_pair() Pair {
    ret Pair { a: 11i32, b: 22i32 };
}

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val p: Pair = make_pair();
    val pp: &Pair = ?p;
    if (pp.a != 11i32) { ret 1; }
    if (pp.b != 22i32) { ret 2; }
    ret 0;
}
