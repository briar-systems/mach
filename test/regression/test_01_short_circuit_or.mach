use std.runtime;
use std.types.bool;

$main.symbol = "main";
fun touch(x:*i32) bool {
    x[0] = x[0] + 1;
    ret true;
}

fun main(argc: i64, argv: &&u8) i64 {
    var hits:i32 = 0;
    if (true || touch(?hits)) {
        if (hits != 0) { ret 1; }
    } or {
        ret 2;
    }

    if (false || touch(?hits)) {
        if (hits != 1) { ret 3; }
    } or {
        ret 4;
    }

    ret 0;
}
