use std.runtime;
use std.types.bool;

$main.symbol = "main";
fun touch(x: *i32) bool {
    x[0] = x[0] + 1;
    ret true;
}

fun main(argc: i64, argv: &&u8) i64 {
    var hits: i32 = 0;

    if (false && touch(?hits)) {
        ret 1;
    }
    if (hits != 0) { ret 2; }

    if (true && touch(?hits)) {
        if (hits != 1) { ret 3; }
    } or {
        ret 4;
    }

    ret 0;
}
