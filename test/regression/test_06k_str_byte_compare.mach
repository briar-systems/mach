use std.runtime;
use std.types.string;
use std.types.size;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val a: str = "abc";
    val b: str = "abc";
    
    # single byte compare at index 0
    val a0: u8 = a[0];
    val b0: u8 = b[0];
    
    if (a0 != 97) { ret 1; }  # 'a' = 97
    if (b0 != 97) { ret 2; }
    if (a0 != b0) { ret 3; }
    
    ret 0;
}
