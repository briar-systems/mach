use std.runtime;
use std.types.size;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val arr: [4]u8 = [4]u8{ 1, 2, 3, 0 };
    var i: usize = 0;
    var count: usize = 0;
    for (arr[i] != 0) {
        count = count + 1;
        i = i + 1;
    }
    if (count != 3) { ret 1; }
    ret 0;
}
