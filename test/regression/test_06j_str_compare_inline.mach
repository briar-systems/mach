use std.runtime;
use std.types.string;
use std.types.size;
use std.types.bool;

$main.symbol = "main";
fun main(argc: i64, argv: &&u8) i64 {
    val a: str = "abc";
    val b: str = "abc";
    
    # test: str len calculation (for loop with str indexing)
    var len: usize = 0;
    for (a[len] != 0) {
        len = len + 1;
    }
    if (len != 3) { ret 1; }
    
    # test: byte-by-byte compare in loop
    var i: usize = 0;
    for (i < 3) {
        if (a[i] != b[i]) { ret 2; }
        i = i + 1;
    }
    
    # test: final null check
    if (a[3] != 0) { ret 3; }
    if (b[3] != 0) { ret 4; }
    
    ret 0;
}
