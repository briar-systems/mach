# constant-time surface case (#1646)
#
# an `#[oblivious]` function computes a branchless masked select over secret operands
# using only bitwise / additive ops - never a secret branch, memory index, or
# variable-latency op - and a secret buffer is zeroized; the results are declassified
# with `:^` (the OP_DECLASSIFY barrier, which selects to a coalescable move) so they can
# be printed. proves the secret taint and the declassify barrier flow end-to-end without
# perturbing execution: the program compiles, runs, and produces the correct value on
# every target.

use std.runtime;
use std.types.size.usize;
use p: std.print;

# branchless constant-time select: returns `a` when `cond` is 1, `b` when it is 0. the
# mask (all-ones or all-zero) is built with a public-zero subtraction, and every
# operation is bitwise or additive, so no leakage-observable op touches a secret.
#[oblivious]
fun ct_select(cond: ^u32, a: ^u32, b: ^u32) ^u32 {
    val mask: ^u32 = 0 - cond;
    ret (a & mask) | (b & ~mask);
}

# declassify a secret to a public value at the API boundary (the only secret->public
# crossing the type system permits, besides inline asm).
fun declassify(x: ^u32) u32 { ret x:^; }

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    # public literals up-coerce to the secret parameters; the secret results are
    # declassified for the public print path.
    p.printlnf("sel1={}", declassify(ct_select(1, 111, 222))::i64);   # 111
    p.printlnf("sel0={}", declassify(ct_select(0, 111, 222))::i64);   # 222

    # hold a secret, then WIPE it with a zeroizing assignment into secret storage (a
    # public zero into `^` storage - the destination-secrecy seed path), read back 0.
    var z: ^u32 = ct_select(1, 9, 9);   # a secret value
    z = 0;                              # zeroize the secret storage
    p.printlnf("zero={}", declassify(z)::i64);                        # 0
    ret 0;
}
