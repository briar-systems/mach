# a second translation unit, so the -g build carries more than one compile unit
#
# the debuginfo case verifies llvm-dwarfdump --verify over a MULTI-TU image: this
# module plus main plus the std modules the program pulls give several compile units
# in one .debug_info, exercising the cross-module .debug_abbrev / .debug_str dedup
# (the #1708 / #2009 coverage) that a single-TU shape cannot reach.

# add two integers
pub fun add(a: i64, b: i64) i64 {
    ret a + b;
}

# multiply two integers
pub fun mul(a: i64, b: i64) i64 {
    ret a * b;
}
