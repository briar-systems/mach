# pie-rodata-fault surface case: the pure-constant read-only guard.
#
# a string literal's bytes are pure `.rodata` - initialized read-only data that carries
# no base relocation. under `mach build --pie` #1844 keeps pure `.rodata` out of the
# writable `.data.rel.ro`/PT_GNU_RELRO region, so the kernel maps it read-only from
# process start rather than writable-then-re-protected. this program reads through the
# string (proving it is mapped readable) and then writes to its first byte; that store
# faults (SIGSEGV) because the page was never writable. the rodata-fault producer
# observes the fault as the golden. this is the pure-constant sibling of pie-relro-fault,
# a permanent guard that constants land in read-only-from-load `.rodata`.
use std.runtime;
use std.types.size.usize;
use std.types.string.str;
use p: std.print;

# a string literal: its bytes live in pure `.rodata`, carrying no relocation.
val msg: str = "immutable";

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    # read the first byte: proves the literal is mapped and readable.
    p.printlnf("read={}", msg[0]::i64);
    # write to the literal's own `.rodata` bytes; the page is read-only from load, so
    # this store raises SIGSEGV.
    msg[0] = 'X';
    p.printlnf("rodata_write=ok");
    ret 0;
}
