# sign-extension surface case (the #1750 area)
#
# a 32-bit value must be held sign-extended to its register width on lp64
# (riscv64); a negative i32 that crosses a call boundary, a return, or a signed
# compare must stay negative. the observable is the printed result of each, so a
# backend that reads a negative i32 as a large positive diverges the output.

use std.runtime;
use std.types.size.usize;
use p: std.print;

# pass + return a 32-bit value across the C-ABI boundary
fun ident(x: i32) i32 { ret x; }

# negate a 32-bit value (produces a negative from a positive and back)
fun neg(x: i32) i32 { ret 0 - x; }

# sign-extend a 32-bit value to 64 bits
fun widen(x: i32) i64 { ret x::i64; }

# count how many of two 32-bit arguments are negative under a signed compare
fun count_neg(a: i32, b: i32) i64 {
    var n: i64 = 0;
    if (a < 0) { n = n + 1; }
    if (b < 0) { n = n + 1; }
    ret n;
}

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    p.printlnf("ident={}", widen(ident(-5)));        # -5
    p.printlnf("neg={}", widen(neg(7)));             # -7
    p.printlnf("double-neg={}", widen(neg(neg(-3)))); # -3
    p.printlnf("min={}", widen(ident(-2147483648)));  # i32 min, -2147483648
    p.printlnf("count={}", count_neg(ident(-1), 1));  # 1 (was 2 when -1 read positive)
    p.printlnf("cmp-lt={}", count_neg(-5, -3));        # 2
    p.printlnf("cmp-none={}", count_neg(4, 9));        # 0
    ret 0;
}
