# control-flow surface case
#
# branches, counted loops, an or-chain classifier reached by a direct call, and a
# computed fold over a stack buffer. the printed results depend on every branch and
# loop edge resolving correctly, so a mis-encoded branch or loop diverges the output.

use std.runtime;
use std.types.size.usize;
use p: std.print;

# counted loop: sum 0..n-1
fun sum_to(n: i64) i64 {
    var acc: i64 = 0;
    var i: i64 = 0;
    for (i < n) {
        acc = acc + i;
        i = i + 1;
    }
    ret acc;
}

# an or-chain classifier reached by a direct call
fun classify(v: i64) i64 {
    if (v == 0) { ret 0; } or (v == 1) { ret 7; } or (v == 2) { ret 13; }
    or (v == 3) { ret 21; } or (v == 4) { ret 34; } ret 1;
}

# nested branches and a loop folding the classifier over a small buffer. the
# quadratic fill over a non-power-of-two length makes the fold genuinely depend on
# the seed (a linear fill over a multiple of the period would not)
fun fold(seed: i64) i64 {
    var buf: [30]u8;
    var i: i64 = 0;
    for (i < 30) { buf[i] = ((i * i + seed) & 7)::u8; i = i + 1; }

    var sum: i64 = 0;
    var hi: i64 = 0;
    i = 0;
    for (i < 30) {
        val c: i64 = classify(buf[i]::i64);
        if (c > 20) { hi = hi + c; } or (c > 5) { sum = sum + c; } or { sum = sum + 1; }
        i = i + 1;
    }
    ret (sum & 255) + (hi & 255);
}

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    p.printlnf("sum10={}", sum_to(10));     # 45
    p.printlnf("sum100={}", sum_to(100));   # 4950
    p.printlnf("class3={}", classify(3));   # 21
    p.printlnf("class9={}", classify(9));   # 1 (default arm)
    p.printlnf("fold0={}", fold(0));
    p.printlnf("fold3={}", fold(3));

    # an early-exit guard: the loop stops the first time the running sum exceeds 50.
    var n: i64 = 0;
    var k: i64 = 0;
    for (k < 1000) {
        n = n + k;
        if (n > 50) { k = 1000; } or { k = k + 1; }
    }
    p.printlnf("guard={}", n);
    ret 0;
}
