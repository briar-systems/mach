# elf-relro structural guard: a --pie image whose read-only data carries relocated
# constant pointers - a `val` pointer table and a `val` function-pointer table (the
# vtable case). the linker routes these into a PT_GNU_RELRO region for the runtime to
# re-protect read-only after self-relocation. the relro producer walks the program
# headers host-side and never executes the binary, so the body only has to link and
# keep the tables live; the golden asserts PT_GNU_RELRO present (relro=1). the runtime
# re-protection itself is exercised by the pie-reloc exec guard.
use std.runtime;
use std.types.size.usize;

var v0: i64 = 1;
var v1: i64 = 2;
var v2: i64 = 3;

# a constant pointer table: three relocated constants in read-only data.
val c_table: [3]*i64 = [3]*i64{?v0, ?v1, ?v2};

fun f0(x: i64) i64 { ret x; }
fun f1(x: i64) i64 { ret x; }
fun f2(x: i64) i64 { ret x; }

def UnaryFn: fun(i64) i64;

# a constant function-pointer table (the vtable case): three relocated code pointers.
val c_fns: [3]UnaryFn = [3]UnaryFn{f0, f1, f2};

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 { ret c_table[0][0] + c_fns[0](0); }
