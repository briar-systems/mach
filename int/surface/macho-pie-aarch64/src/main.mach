# a minimal linked program for the field producer to inspect. the producer reads
# the binary's header (here the PE DllCharacteristics ASLR bit) host-side and never
# executes it, so the body only has to link.
use std.runtime;
use std.types.size.usize;

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 { ret 0; }
