# float surface case (the #1733 / #1637 area)
#
# f32 and f64 arithmetic, and float pass/return across call boundaries, must agree
# on every target. floats are folded to exact integers (scaled, truncated) before
# printing so the golden is target-independent and the output path never carries a
# float through a variadic call.

use std.runtime;
use std.types.size.usize;
use p: std.print;

fun addf(x: f64, y: f64) f64 { ret x + y; }
fun mulf(x: f64, y: f64) f64 { ret x * y; }
fun subf(x: f64, y: f64) f64 { ret x - y; }
fun addf32(x: f32, y: f32) f32 { ret x + y; }

# scale an f64 by 1000 and truncate to an exact integer observable
fun obs(v: f64) i64 { ret (v * 1000.0)::i64; }

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    var x: f64 = 2.5;
    var y: f64 = 1.25;
    p.printlnf("add={}", obs(addf(x, y)));   # 3750
    p.printlnf("sub={}", obs(subf(x, y)));   # 1250
    p.printlnf("mul={}", obs(mulf(x, y)));   # 3125

    # f32 arithmetic then widened to f64 for the fold.
    var a: f32 = 1.5::f32;
    var b: f32 = 0.25::f32;
    val s: f32 = addf32(a, b);
    p.printlnf("f32-add={}", obs(s::f64));   # 1750

    # a small accumulating loop over f64 to exercise repeated FP ops.
    var acc: f64 = 0.0;
    var i: i64 = 0;
    for (i < 8) { acc = acc + 0.5; i = i + 1; }
    p.printlnf("loop={}", obs(acc));         # 4000
    ret 0;
}
