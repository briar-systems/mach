# `$each x in ARR` over a comptime-constant array `val`: the body is spliced once
# per element with `x` bound to that element's constant. exercised over a scalar
# array (value use + per-element `$if`) and a record array whose function-pointer
# field is driven as a static dispatch table.

use std.runtime;
use p: std.print;

val PRIMES: [4]i64 = [4]i64{2, 3, 5, 7};

rec Rule {
    tag: i64;
    fn:  fun(i64) i64;
}

fun inc(x: i64) i64 { ret x + 1; }
fun dbl(x: i64) i64 { ret x + x; }
fun neg(x: i64) i64 { ret 0 - x; }

val RULES: [3]Rule = [3]Rule{
    Rule{tag: 1, fn: inc},
    Rule{tag: 2, fn: dbl},
    Rule{tag: 3, fn: neg},
};

#[symbol("main")]
pub fun main(argc: i64, argv: **u8) i64 {
    var total: i64 = 0;
    $each x in PRIMES {
        total = total + x;
    }
    p.printf("sum={}\n", total);

    var fives: i64 = 0;
    $each x in PRIMES {
        $if (x == 5) { fives = fives + 1; }
        $or { }
    }
    p.printf("fives={}\n", fives);

    $each r in RULES {
        $if (r.tag == 2) {
            p.printf("double: {}\n", r.fn(10));
        }
        $or {
            p.printf("tag={} -> {}\n", r.tag, r.fn(10));
        }
    }
    ret 0;
}
