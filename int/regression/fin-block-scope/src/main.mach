# pin for block-scoped fin: a fin belongs to its enclosing block. a normal
# block exit replays the block's fins in reverse declaration order; a loop
# body replays per iteration with that iteration's values; `brk` / `cnt`
# replay the fins of every scope being exited (the loop body's included,
# innermost first); `ret` evaluates its expression, then unwinds every open
# scope innermost first; the classic function-top-level pattern is unchanged.
#
# the flat model this replaces registered every fin for the whole function:
# loop-interior fins replayed once at ret with final values, and brk / cnt
# skipped fins entirely.

use std.runtime;
use p: std.print;

var trail: i64 = 0;
var acc:   i64 = 0;
var g:     i64 = 5;

# append digit k to the global trail and return it
fun mark(k: i64) i64 {
    trail = trail * 10 + k;
    ret trail;
}

fun read_g() i64 { ret g; }

# a bare block's fins replay at its exit (reverse order), before code after it
fun block_exit() i64 {
    trail = 0;
    mark(1);
    {
        fin { mark(3); }
        fin { mark(2); }
    }
    mark(4);
    ret trail;
}

# a loop-body fin replays at the end of every iteration, seeing that
# iteration's values (here: i already incremented)
fun per_iter() i64 {
    acc = 0;
    var i: i64 = 1;
    for (i <= 3) {
        fin { acc = acc * 10 + i; }
        i = i + 1;
    }
    ret acc;
}

# brk replays the loop body's pending fins before branching to the exit
fun brk_replay() i64 {
    trail = 0;
    var i: i64 = 0;
    for (i < 10) {
        fin { mark(7); }
        if (i == 1) { mark(5); brk; }
        i = i + 1;
    }
    mark(9);
    ret trail;
}

# cnt replays the loop body's pending fins: the iteration is ending
fun cnt_replay() i64 {
    trail = 0;
    var i: i64 = 0;
    for (i < 3) {
        fin { mark(2); }
        i = i + 1;
        if (i == 2) { cnt; }
        mark(1);
    }
    ret trail;
}

# nested blocks tear down innermost first on their normal exits; the
# function-scope fin runs at ret, after the return value is bound
fun nested_blocks() i64 {
    trail = 0;
    fin { mark(4); }
    {
        fin { mark(3); }
        {
            fin { mark(2); }
            mark(1);
        }
    }
    ret trail;
}

# ret from inside nested blocks unwinds every open scope innermost first,
# after the return expression is evaluated
fun ret_unwind() i64 {
    trail = 0;
    fin { mark(3); }
    {
        fin { mark(2); }
        {
            fin { mark(1); }
            ret mark(9);
        }
    }
    ret 0;
}

# a conditional ret replays only on the returning path; the fall-through path
# replays once at its own exit
fun cond_ret(c: i64) i64 {
    trail = 0;
    fin { mark(1); }
    if (c == 1) { ret mark(9); }
    mark(5);
    ret trail;
}

# a fin nested in a fin body belongs to that body's block and replays when
# the body finishes
fun fin_in_fin() i64 {
    trail = 0;
    {
        fin { mark(1); fin { mark(2); } mark(3); }
        mark(9);
    }
    ret trail;
}

# the classic top-level cleanup pattern: value evaluated, then teardown
fun classic() i64 {
    g = 5;
    fin { g = 0; }
    ret read_g();
}

#[symbol("main")]
fun main(argc: i64, argv: **u8) i64 {
    p.printlnf("block={}", block_exit());
    p.printlnf("iter={}", per_iter());
    p.printlnf("brk={}", brk_replay());
    p.printlnf("cnt={}", cnt_replay());
    p.printlnf("nested={}", nested_blocks());
    p.printlnf("nested_trail={}", trail);
    p.printlnf("unwind={}", ret_unwind());
    p.printlnf("unwind_trail={}", trail);
    p.printlnf("cond_taken={}", cond_ret(1));
    p.printlnf("cond_taken_trail={}", trail);
    p.printlnf("cond_fall={}", cond_ret(0));
    p.printlnf("cond_fall_trail={}", trail);
    p.printlnf("finfin={}", fin_in_fin());
    p.printlnf("classic={}", classic());
    p.printlnf("classic_g={}", g);
    ret 0;
}
