# regression pin for loop rotation / bottom-test loops (#1937)
#
# a counted `for (cond)` is rotated into bottom-test form: the header test is
# duplicated into the preheader as an entry guard, and the reverse-postorder
# layout then lays the loop out body-first so the body falls through into the
# test and the single conditional back edge is the only per-iteration branch. the
# transform must preserve loop semantics EXACTLY - the body runs the same number
# of times with the same values, and crucially a zero-trip while-loop must still
# run zero times (the guard must not turn a while into a do-while).
#
# every bound rides `argc` (1 at runtime, opaque to the compiler), so no profile
# can constant-fold a loop away and every guard / back edge executes for real. the
# probes cover each case the rotation must respect: a zero-trip loop (the guard
# skips it), a one-trip and a many-trip loop, a nested loop (both levels rotate),
# a loop with `brk` (early exit past the test), and a loop with `cnt` (a second
# back edge into the header the rotation must not disturb). a broken guard, a
# dropped zero-trip skip, or a mishandled brk/cnt edge diverges the output.

use std.runtime;
use std.types.size.usize;
use p: std.print;

# sum 0..n-1; n==0 is the zero-trip case the guard must skip.
fun count_sum(n: i64) i64 {
    var acc: i64 = 0;
    var i: i64 = 0;
    for (i < n) {
        acc = acc + i;
        i = i + 1;
    }
    ret acc;
}

# nested counted loops: n*n increments of 1.
fun nested(n: i64) i64 {
    var acc: i64 = 0;
    var i: i64 = 0;
    for (i < n) {
        var j: i64 = 0;
        for (j < n) {
            acc = acc + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    ret acc;
}

# `brk` exits the loop the first time i reaches the limit, summing 0..limit-1.
fun brk_sum(n: i64, limit: i64) i64 {
    var acc: i64 = 0;
    var i: i64 = 0;
    for (i < n) {
        if (i == limit) { brk; }
        acc = acc + i;
        i = i + 1;
    }
    ret acc;
}

# `cnt` skips even values, summing only the odd i in 0..n-1. cnt branches back to
# the header (a second back edge) which the rotation must leave intact.
fun cnt_sum(n: i64) i64 {
    var acc: i64 = 0;
    var i: i64 = 0;
    for (i < n) {
        val cur: i64 = i;
        i = i + 1;
        if ((cur & 1) == 0) { cnt; }
        acc = acc + cur;
    }
    ret acc;
}

# a multi-instruction body (xorshift step) reduced to a checksum, so a rotated
# body that miscomputes or reorders diverges the sum.
fun xorshift_sum(n: i64) i64 {
    var x: i64 = 1;
    var sum: i64 = 0;
    var i: i64 = 0;
    for (i < n) {
        x = x ^ (x << 13);
        x = x ^ (x >> 7);
        x = x ^ (x << 17);
        sum = sum + x;
        i = i + 1;
    }
    ret sum;
}

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    # 1 at runtime; opaque to the compiler, so every bound is a real runtime read.
    val one: i64 = argc::i64;

    p.printf("count:");
    p.printf(" {}", count_sum(0 * one));    # 0  (zero-trip: guard skips)
    p.printf(" {}", count_sum(1 * one));    # 0  (one-trip)
    p.printf(" {}", count_sum(2 * one));    # 1
    p.printf(" {}", count_sum(100 * one));  # 4950
    p.println("");

    p.printf("nested:");
    p.printf(" {}", nested(0 * one));        # 0
    p.printf(" {}", nested(1 * one));        # 1
    p.printf(" {}", nested(12 * one));       # 144
    p.println("");

    p.printf("brk:");
    p.printf(" {}", brk_sum(100 * one, 0 * one));   # 0  (brk on first iteration)
    p.printf(" {}", brk_sum(100 * one, 5 * one));   # 10 (sum 0..4)
    p.printf(" {}", brk_sum(3 * one, 100 * one));   # 3  (brk never reached: 0+1+2)
    p.println("");

    p.printf("cnt:");
    p.printf(" {}", cnt_sum(0 * one));       # 0
    p.printf(" {}", cnt_sum(10 * one));      # 25 (1+3+5+7+9)
    p.println("");

    p.printf("xorshift:");
    p.printf(" {}", xorshift_sum(1000 * one));
    p.println("");

    ret 0;
}
