# regression pin for the fin/ret evaluation order: a `ret` expression is fully
# evaluated before the pending `fin` bodies run, then the fins replay
# (innermost first), then the function returns the bound value.
#
# the broken order replayed the fins before lowering the ret expression, so a
# ret-position call observed fin teardown effects: `direct` returned 0 instead
# of 5, `shortcircuit` folded to 0, and `nested` returned the post-fin trail.
# the void-ret and fall-through exits are pinned unchanged (fins still run).

use std.runtime;
use p: std.print;

var g:     i64 = 5;
var trail: i64 = 0;
var voids: i64 = 0;

fun read_g() i64 { ret g; }

# core: the ret-position call runs before the fin mutation
fun direct() i64 {
    g = 5;
    fin { g = 0; }
    ret read_g();
}

# a short-circuit expression in ret position evaluates whole before any fin
fun shortcircuit() u8 {
    g = 5;
    fin { g = 0; }
    ret (g > 3) && (read_g() > 3);
}

# append a digit to the global trail and return it
fun mark(k: i64) i64 {
    trail = trail * 10 + k;
    ret trail;
}

# the value evaluates first, then the fins unwind in reverse registration order
fun nested() i64 {
    fin { mark(2); }
    fin { mark(1); }
    ret mark(9);
}

# a bare ret still replays the fins
fun void_ret() {
    fin { voids = voids + 1; }
    ret;
}

# fall-through exit still replays the fins
fun fall_through() {
    fin { voids = voids + 10; }
}

#[symbol("main")]
fun main(argc: i64, argv: **u8) i64 {
    p.printlnf("direct={}", direct());
    p.printlnf("sc={}", shortcircuit()::i64);
    p.printlnf("nested={}", nested());
    p.printlnf("trail={}", trail);
    void_ret();
    fall_through();
    p.printlnf("voids={}", voids);
    ret 0;
}
