# regression pin for #1750: a negative i32 at the call boundary.
#
# on lp64 (riscv64) a 32-bit value must be held sign-extended to the register
# width. before #1750 the backend did not maintain that for a directly materialized
# i32 constant or a 32-bit load, so a negative i32 passed/returned/compared read as
# a large positive -- e.g. make_slot(reg = -1) counted two live slots instead of
# one. this minimal repro passes -1 through a call and a return, then counts it
# under a signed compare; the count is the observable.

use std.runtime;
use std.types.size.usize;
use p: std.print;

# pass + return a 32-bit value across the C-ABI boundary (the make_slot reg path).
fun ident(x: i32) i32 { ret x; }

# count how many of two slots hold a negative reg id under a signed compare.
fun count_neg(a: i32, b: i32) i64 {
    var n: i64 = 0;
    if (a < 0) { n = n + 1; }
    if (b < 0) { n = n + 1; }
    ret n;
}

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    var reg: i32 = ident(-1);
    p.printlnf("count={}", count_neg(reg, 1));   # 1 (was 2 when -1 read positive)
    p.printlnf("widen={}", reg::i64);            # -1
    p.printlnf("min={}", ident(-2147483648)::i64); # -2147483648
    ret 0;
}
