fun c_i64(a: i64) i64 {
    var r: i64 = 0;
    if (a == -5000000000) { r = r + 1; }
    if (a != -5000000000) { r = r + 2; }
    if (a < -5000000000)  { r = r + 4; }
    if (a <= -5000000000) { r = r + 8; }
    if (a > -5000000000)  { r = r + 16; }
    if (a >= -5000000000) { r = r + 32; }
    ret r;
}

fun c_u8(a: u8) i64 {
    var r: i64 = 0;
    if (a == 200) { r = r + 1; }
    if (a != 200) { r = r + 2; }
    if (a < 200)  { r = r + 4; }
    if (a <= 200) { r = r + 8; }
    if (a > 200)  { r = r + 16; }
    if (a >= 200) { r = r + 32; }
    ret r;
}

fun c_u16(a: u16) i64 {
    var r: i64 = 0;
    if (a == 40000) { r = r + 1; }
    if (a != 40000) { r = r + 2; }
    if (a < 40000)  { r = r + 4; }
    if (a <= 40000) { r = r + 8; }
    if (a > 40000)  { r = r + 16; }
    if (a >= 40000) { r = r + 32; }
    ret r;
}

fun c_u32(a: u32) i64 {
    var r: i64 = 0;
    if (a == 3000000000) { r = r + 1; }
    if (a != 3000000000) { r = r + 2; }
    if (a < 3000000000)  { r = r + 4; }
    if (a <= 3000000000) { r = r + 8; }
    if (a > 3000000000)  { r = r + 16; }
    if (a >= 3000000000) { r = r + 32; }
    ret r;
}

fun c_u64(a: u64) i64 {
    var r: i64 = 0;
    if (a == 9000000000000000000) { r = r + 1; }
    if (a != 9000000000000000000) { r = r + 2; }
    if (a < 9000000000000000000)  { r = r + 4; }
    if (a <= 9000000000000000000) { r = r + 8; }
    if (a > 9000000000000000000)  { r = r + 16; }
    if (a >= 9000000000000000000) { r = r + 32; }
    ret r;
}

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    # 0 at runtime; opaque to the compiler, so every operand load is a real
    # runtime read and every compare a real branch in every profile.
    val off: usize = argc - 1;

    # signed boundary sets: min, -1, 0, 1, max per width.
    var a8: [5]i8;
    a8[0] = -128; a8[1] = -1; a8[2] = 0; a8[3] = 1; a8[4] = 127;
    var a16: [5]i16;
    a16[0] = -32768; a16[1] = -1; a16[2] = 0; a16[3] = 1; a16[4] = 32767;
    var a32: [5]i32;
    a32[0] = -2147483648; a32[1] = -1; a32[2] = 0; a32[3] = 1; a32[4] = 2147483647;
    var a64: [5]i64;
    a64[0] = -9223372036854775807; a64[0] = a64[0] - 1;
    a64[1] = -1; a64[2] = 0; a64[3] = 1; a64[4] = 9223372036854775807;

    # unsigned boundary sets: 0, 1, signed-boundary crossers, max (the wrapped
    # all-ones value, so a signed misread flips the relation).
    var b8: [5]u8;
    b8[0] = 0; b8[1] = 1; b8[2] = 127; b8[3] = 128; b8[4] = 255;
    var b16: [5]u16;
    b16[0] = 0; b16[1] = 1; b16[2] = 32767; b16[3] = 32768; b16[4] = 65535;
    var b32: [5]u32;
    b32[0] = 0; b32[1] = 1; b32[2] = 2147483647; b32[3] = 2147483648; b32[4] = 4294967295;
    var b64: [5]u64;
    b64[0] = 0; b64[1] = 1;
    b64[2] = 9223372036854775807;
    b64[3] = b64[2] + 1;
    b64[4] = 0; b64[4] = b64[4] - 1;

    var i: usize = 0;
    var j: usize = 0;

    p.printf("i8:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i8(a8[i + off], a8[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("i16:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i16(a16[i + off], a16[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("i32:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i32(a32[i + off], a32[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("i64:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i64(a64[i + off], a64[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u8:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u8(b8[i + off], b8[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u16:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u16(b16[i + off], b16[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u32:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u32(b32[i + off], b32[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u64:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u64(b64[i + off], b64[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    var cv0: [3]i8;
    cv0[0] = -100; cv0[1] = -56; cv0[2] = 0;
    p.printlnf("c_i8n: {} {} {}", c_i8n(cv0[off]), c_i8n(cv0[off + 1]), c_i8n(cv0[off + 2]));
    var cv1: [3]i8;
    cv1[0] = 50; cv1[1] = 100; cv1[2] = 127;
    p.printlnf("c_i8p: {} {} {}", c_i8p(cv1[off]), c_i8p(cv1[off + 1]), c_i8p(cv1[off + 2]));
    var cv2: [3]i16;
    cv2[0] = -30000; cv2[1] = -3000; cv2[2] = 5;
    p.printlnf("c_i16: {} {} {}", c_i16(cv2[off]), c_i16(cv2[off + 1]), c_i16(cv2[off + 2]));
    var cv3: [3]i32;
    cv3[0] = -2000000000; cv3[1] = -70000; cv3[2] = 3;
    p.printlnf("c_i32: {} {} {}", c_i32(cv3[off]), c_i32(cv3[off + 1]), c_i32(cv3[off + 2]));
    var cv4: [3]i64;
    cv4[0] = -9000000000000000000; cv4[1] = -5000000000; cv4[2] = 77;
    p.printlnf("c_i64: {} {} {}", c_i64(cv4[off]), c_i64(cv4[off + 1]), c_i64(cv4[off + 2]));
    var cv5: [3]u8;
    cv5[0] = 100; cv5[1] = 200; cv5[2] = 255;
    p.printlnf("c_u8: {} {} {}", c_u8(cv5[off]), c_u8(cv5[off + 1]), c_u8(cv5[off + 2]));
    var cv6: [3]u16;
    cv6[0] = 0; cv6[1] = 40000; cv6[2] = 65535;
    p.printlnf("c_u16: {} {} {}", c_u16(cv6[off]), c_u16(cv6[off + 1]), c_u16(cv6[off + 2]));
    var cv7: [3]u32;
    cv7[0] = 5; cv7[1] = 3000000000; cv7[2] = 4294967295;
    p.printlnf("c_u32: {} {} {}", c_u32(cv7[off]), c_u32(cv7[off + 1]), c_u32(cv7[off + 2]));
    var cv8: [3]u64;
    cv8[0] = 3; cv8[1] = 9000000000000000000;
    cv8[2] = 0; cv8[2] = cv8[2] - 1;
    p.printlnf("c_u64: {} {} {}", c_u64(cv8[off]), c_u64(cv8[off + 1]), c_u64(cv8[off + 2]));

    ret 0;
}
