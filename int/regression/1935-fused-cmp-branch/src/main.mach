# regression pin for the fused compare-and-branch terminators (#1935)
#
# instruction selection fuses a single-consumer comparison with the conditional
# branch that reads it into one MIR_SEL_CBR_* terminator; each backend then
# materializes a native compare-and-branch (x86-64 CMP;Jcc, arm64 SUBS;B.cc,
# riscv64 beq/bne/blt/bltu/bge/bgeu). every relation here sits on exactly that
# shape - a comparison consumed once, by a branch - so this program pins the
# fused paths across all six condition codes, both signednesses, every operand
# width (1/2/4/8), the signed/unsigned boundary values, and both branch
# outcomes.
#
# each t_* probe answers with a relation bitmask (1 ==, 2 !=, 4 <, 8 <=, 16 >,
# 32 >=), so exactly three relations hold for any ordered pair: 41 for a == b,
# 14 for a < b, 50 for a > b. any other printed value is a miscompiled branch.
# the operand indices ride `argc`, so no profile can constant-fold the compares
# away and the golden pins real branch execution at every optimization level.
#
# the c_* probes repeat the mask against a LITERAL operand, pinning the
# immediate compare paths: a sub-word constant reaches the backend WIDTH-MASKED
# (i8 -56 rides as raw bits 200), so a backend that folds or materializes the
# raw immediate without interpreting it at the compare width misreads the
# relation (the aarch64 SUBS imm12 fold did). the GT/GE relations swap the
# literal onto the compare lhs, covering the immediate-lhs materialization too.
# each row probes below / equal / above the constant: 14 41 50.

use std.runtime;
use std.types.size.usize;
use p: std.print;

fun t_i8(a: i8, b: i8) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_i16(a: i16, b: i16) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_i32(a: i32, b: i32) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_i64(a: i64, b: i64) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u8(a: u8, b: u8) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u16(a: u16, b: u16) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u32(a: u32, b: u32) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u64(a: u64, b: u64) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
