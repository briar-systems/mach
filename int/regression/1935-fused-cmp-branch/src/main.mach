# regression pin for the fused compare-and-branch terminators (#1935)
#
# instruction selection fuses a single-consumer comparison with the conditional
# branch that reads it into one MIR_SEL_CBR_* terminator; each backend then
# materializes a native compare-and-branch (x86-64 CMP;Jcc, arm64 SUBS;B.cc,
# riscv64 beq/bne/blt/bltu/bge/bgeu). every relation here sits on exactly that
# shape - a comparison consumed once, by a branch - so this program pins the
# fused paths across all six condition codes, both signednesses, every operand
# width (1/2/4/8), the signed/unsigned boundary values, and both branch
# outcomes.
#
# each t_* probe answers with a relation bitmask (1 ==, 2 !=, 4 <, 8 <=, 16 >,
# 32 >=), so exactly three relations hold for any ordered pair: 41 for a == b,
# 14 for a < b, 50 for a > b. any other printed value is a miscompiled branch.
# the operand indices ride `argc`, so no profile can constant-fold the compares
# away and the golden pins real branch execution at every optimization level.

use std.runtime;
use std.types.size.usize;
use p: std.print;

fun t_i8(a: i8, b: i8) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_i16(a: i16, b: i16) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_i32(a: i32, b: i32) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_i64(a: i64, b: i64) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u8(a: u8, b: u8) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u16(a: u16, b: u16) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u32(a: u32, b: u32) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

fun t_u64(a: u64, b: u64) i64 {
    var r: i64 = 0;
    if (a == b) { r = r + 1; }
    if (a != b) { r = r + 2; }
    if (a < b)  { r = r + 4; }
    if (a <= b) { r = r + 8; }
    if (a > b)  { r = r + 16; }
    if (a >= b) { r = r + 32; }
    ret r;
}

#[symbol("main")]
fun main(argc: usize, argv: **u8) i64 {
    # 0 at runtime; opaque to the compiler, so every operand load is a real
    # runtime read and every compare a real branch in every profile.
    val off: usize = argc - 1;

    # signed boundary sets: min, -1, 0, 1, max per width.
    var a8: [5]i8;
    a8[0] = -128; a8[1] = -1; a8[2] = 0; a8[3] = 1; a8[4] = 127;
    var a16: [5]i16;
    a16[0] = -32768; a16[1] = -1; a16[2] = 0; a16[3] = 1; a16[4] = 32767;
    var a32: [5]i32;
    a32[0] = -2147483648; a32[1] = -1; a32[2] = 0; a32[3] = 1; a32[4] = 2147483647;
    var a64: [5]i64;
    a64[0] = -9223372036854775807; a64[0] = a64[0] - 1;
    a64[1] = -1; a64[2] = 0; a64[3] = 1; a64[4] = 9223372036854775807;

    # unsigned boundary sets: 0, 1, signed-boundary crossers, max (the wrapped
    # all-ones value, so a signed misread flips the relation).
    var b8: [5]u8;
    b8[0] = 0; b8[1] = 1; b8[2] = 127; b8[3] = 128; b8[4] = 255;
    var b16: [5]u16;
    b16[0] = 0; b16[1] = 1; b16[2] = 32767; b16[3] = 32768; b16[4] = 65535;
    var b32: [5]u32;
    b32[0] = 0; b32[1] = 1; b32[2] = 2147483647; b32[3] = 2147483648; b32[4] = 4294967295;
    var b64: [5]u64;
    b64[0] = 0; b64[1] = 1;
    b64[2] = 9223372036854775807;
    b64[3] = b64[2] + 1;
    b64[4] = 0; b64[4] = b64[4] - 1;

    var i: usize = 0;
    var j: usize = 0;

    p.printf("i8:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i8(a8[i + off], a8[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("i16:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i16(a16[i + off], a16[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("i32:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i32(a32[i + off], a32[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("i64:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_i64(a64[i + off], a64[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u8:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u8(b8[i + off], b8[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u16:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u16(b16[i + off], b16[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u32:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u32(b32[i + off], b32[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    p.printf("u64:");
    i = 0;
    for (i < 5) {
        j = 0;
        for (j < 5) {
            p.printf(" {}", t_u64(b64[i + off], b64[j]));
            j = j + 1;
        }
        i = i + 1;
    }
    p.println("");

    ret 0;
}
