fun c_i8n(a: i8) i64 {
    var r: i64 = 0;
    if (a == -56) { r = r + 1; }
    if (a != -56) { r = r + 2; }
    if (a < -56)  { r = r + 4; }
    if (a <= -56) { r = r + 8; }
    if (a > -56)  { r = r + 16; }
    if (a >= -56) { r = r + 32; }
    ret r;
}

fun c_i8p(a: i8) i64 {
    var r: i64 = 0;
    if (a == 100) { r = r + 1; }
    if (a != 100) { r = r + 2; }
    if (a < 100)  { r = r + 4; }
    if (a <= 100) { r = r + 8; }
    if (a > 100)  { r = r + 16; }
    if (a >= 100) { r = r + 32; }
    ret r;
}

fun c_i16(a: i16) i64 {
    var r: i64 = 0;
    if (a == -3000) { r = r + 1; }
    if (a != -3000) { r = r + 2; }
    if (a < -3000)  { r = r + 4; }
    if (a <= -3000) { r = r + 8; }
    if (a > -3000)  { r = r + 16; }
    if (a >= -3000) { r = r + 32; }
