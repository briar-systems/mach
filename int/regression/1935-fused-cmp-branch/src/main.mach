}

fun c_i32(a: i32) i64 {
    var r: i64 = 0;
    if (a == -70000) { r = r + 1; }
    if (a != -70000) { r = r + 2; }
    if (a < -70000)  { r = r + 4; }
    if (a <= -70000) { r = r + 8; }
    if (a > -70000)  { r = r + 16; }
    if (a >= -70000) { r = r + 32; }
