{
    "version": "0.0.0",
    "paths": {
        "src": "{path_project}/src",
        "dep": "{path_project}/dep",
        "out": "{path_project}/out",
        "entry": "{path_src}/main.mach"
    },
    "type": "executable",
    "name": "mach",
    "targets": [
        "current"
    ],
    "options": {
        "verbose_lex": true,
        "verbose_parse": true,
        "verbose_analysis": true,
        "verbose_codegen": true,
        "verbose_link": true,
        "dump_irl": true,
        "dump_tac": true,
        "dump_asm": true
    },
    "dependancies": []
}
