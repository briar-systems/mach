val a_start: u8 = 0;
val b_start: u8 = a_start + 1;
val c_start: u8 = 0;

fun fib(n: u64): u64 {
    var a: u64 = a_start;
    var b: u64 = b_start;
    var c: u64 = c_start;
    
    var i: u64 = 0;
    for i < n - 1 {
        c = a + b;
        a = b;
        b = c;
        i = i + 1;
    }

    ret b;
}

fun main(): u32 {
    fib(10);
}
