fun fib(n: u64): u64 {
    var a: u64 = 0;
    var b: u64 = 1;
    var c: u64 = 0;
    
    var i: u64 = 0;
    for i < n - 1 {
        c = a + b;
        a = b;
        b = c;
        i = i + 1;
    }

    ret b;
}

fun main(): u32 {
    fib(10);
}

str foo {
    foo: u32;
    foo: u32;
}

uni bar {
    bar: u32;
    foo: foo;
}

fun test(): void {
    vol foo: *u32 = 0xDEADBEEF::*u32;
    var bar: u32  = @foo;
}
