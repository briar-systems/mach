use lists:   std.lists
use console: std.io.console

fun find<T>(m: *[]T, key: T): u32 ! string {
    var i: u32 = 0
    for i < len(m.keys) {
        if m.keys[i] == key[i] {
            pass i
        }
        i = i + 1
    }

    fail "key not found"
}

fun main() {
    val list:  []u32 = [ 1, 2, 3, 4 ]

    var idx: u32
    try find<u32>(list, 3) {
        pass res { idx = res }
        fail err { ret err }
    }
}
