use      std.types.bool;
use      std.types.option;
use      std.types.result;
use      std.types.size;
use mem: std.system.memory;

pub def char: u8;
pub def str:  []char;

pub rec String {
    data: *char;
    len:  usize;
    cap:  usize;
}

pub fun (this: str) is_empty() bool {
    ret this.len == 0;
}

pub fun (this: str) is_valid() bool {
    ret this.data != nil || this.len == 0;
}

pub fun (this: str) equals(other: str) bool {
    if (this.len != other.len) {
        ret false;
    }

    var i: usize = 0;
    for (i < this.len) {
        if (@(this.data + i) != @(other.data + i)) {
            ret false;
        }
        i = i + 1;
    }

    ret true;
}

pub fun (this: str) compare(other: str) isize {
    var min_len: usize = this.len;
    if (other.len < min_len) {
        min_len = other.len;
    }

    var i: usize = 0;
    for (i < min_len) {
        val a: u8 = @(this.data + i);
        val b: u8 = @(other.data + i);

        if (a < b) {
            ret -1;
        }
        or (a > b) {
            ret 1;
        }

        i = i + 1;
    }

    if (this.len < other.len) {
        ret -1;
    }
    or (this.len > other.len) {
        ret 1;
    }

    ret 0;
}

pub fun (this: str) starts_with(prefix: str) bool {
    if (this.len < prefix.len) {
        ret false;
    }

    var i: usize = 0;
    for (i < prefix.len) {
        if (@(this.data + i) != @(prefix.data + i)) {
            ret false;
        }
        i = i + 1;
    }

    ret true;
}

pub fun (this: str) ends_with(suffix: str) bool {
    if (this.len < suffix.len) {
        ret false;
    }

    val offset: usize = this.len - suffix.len;
    var i: usize = 0;
    for (i < suffix.len) {
        if (@(this.data + offset + i) != @(suffix.data + i)) {
            ret false;
        }
        i = i + 1;
    }

    ret true;
}

pub fun (this: str) contains(segment: str) bool {
    if (this.data == nil || segment.data == nil || segment.len == 0 || segment.len > this.len) {
        ret false;
    }

    var i: usize = 0;
    for (i <= this.len - segment.len) {
        var found: bool = true;

        var j: usize = 0;
        for (j < segment.len) {
            if (@(this.data + i + j) != @(segment.data + j)) {
                found = false;
                brk;
            }
            j = j + 1;
        }

        if (found) {
            ret true;
        }

        i = i + 1;
    }

    ret false;
}

pub fun (this: str) index_of(segment: str) Option[usize] {
    if (this.data == nil || segment.data == nil || segment.len == 0 || segment.len > this.len) {
        ret none[usize]();
    }

    var i: usize = 0;
    for (i <= this.len - segment.len) {
        var found: bool = true;

        var j: usize = 0;
        for (j < segment.len) {
            if (@(this.data + i + j) != @(segment.data + j)) {
                found = false;
                brk;
            }
            j = j + 1;
        }

        if (found) {
            ret some[usize](i);
        }

        i = i + 1;
    }

    ret none[usize]();
}

pub fun (this: str) last_index_of(segment: str) Option[usize] {
    if (this.data == nil || segment.data == nil || segment.len == 0 || segment.len > this.len) {
        ret none[usize]();
    }

    var i: usize = this.len - segment.len;
    for (i >= 0) {
        var found: bool = true;

        var j: usize = 0;
        for (j < segment.len) {
            if (@(this.data + i + j) != @(segment.data + j)) {
                found = false;
                brk;
            }
            j = j + 1;
        }

        if (found) {
            ret some[usize](i);
        }

        if (i == 0) {
            brk;
        }
        i = i - 1;
    }

    ret none[usize]();
}

pub fun (this: str) substring(start: usize, end: usize) Option[String] {
    if (this.data == nil || start >= end || end > this.len) {
        ret none[String]();
    }

    val sub_len:   usize = end - start;
    val alloc_res: Option[*char] = mem.allocate[char](sub_len);
    if (alloc_res.is_none()) {
        ret none[String]();
    }

    val sub_data: *char = alloc_res.unwrap();

    mem.copy[char](sub_data, this.data + start, sub_len);

    var result: String;
    result.data = sub_data;
    result.len  = sub_len;
    result.cap  = sub_len;

    ret some[String](result);
}

pub fun (this: str) clone() Option[String] {
    if (this.len == 0) {
        var empty: String;
        empty.data = nil;
        empty.len = 0;
        empty.cap = 0;
        ret some[String](empty);
    }

    val alloc_res: Option[*char] = mem.allocate[char](this.len);
    if (alloc_res.is_none()) {
        ret none[String]();
    }

    val new_data: *char = alloc_res.unwrap();

    mem.copy[char](new_data, this.data, this.len);

    var result: String;
    result.data = new_data;
    result.len  = this.len;
    result.cap  = this.len;

    ret some[String](result);
}

pub fun (this: *String) new() {
    this.data = nil;
    this.len = 0;
    this.cap = 0;
}

pub fun (this: *String) with_capacity(capacity: usize) bool {
    this.len = 0;
    this.cap = 0;

    if (capacity == 0) {
        this.data = nil;
        ret true;
    }

    val alloc_res: Option[*char] = mem.allocate[char](capacity);
    if (alloc_res.is_none()) {
        this.data = nil;
        ret false;
    }

    this.data = alloc_res.unwrap();
    this.cap = capacity;
    ret true;
}

pub fun (this: *String) from(s: str) bool {
    this.len = 0;
    this.cap = 0;

    if (s.len == 0) {
        this.data = nil;
        ret true;
    }

    val alloc_res: Option[*char] = mem.allocate[char](s.len);
    if (alloc_res.is_none()) {
        this.data = nil;
        ret false;
    }

    this.data = alloc_res.unwrap();
    mem.copy[char](this.data, s.data, s.len);
    this.len = s.len;
    this.cap = s.len;
    ret true;
}

pub fun (this: *String) as_str() str {
    var view: str;
    view.data = this.data;
    view.len = this.len;
    ret view;
}

fun (this: *String) ensure_capacity(needed: usize) bool {
    if (this.len + needed <= this.cap) {
        ret true;
    }

    var new_cap: usize = this.cap;
    if (new_cap == 0) {
        new_cap = 64;
    }

    for (new_cap < this.len + needed) {
        if (new_cap >= 0xFFFFFFFFFFFFFFFF / 2) {
            new_cap = this.len + needed;
            brk;
        }
        new_cap = new_cap * 2;
    }

    val realloc_res: Option[*char] = mem.reallocate[char](this.data, this.cap, new_cap);
    if (realloc_res.is_none()) {
        ret false;
    }

    this.data = realloc_res.unwrap();
    this.cap = new_cap;
    ret true;
}

pub fun (this: *String) push(ch: char) bool {
    if (this.ensure_capacity(1) == false) {
        ret false;
    }

    @(this.data + this.len) = ch;
    this.len = this.len + 1;
    ret true;
}

pub fun (this: *String) append(s: str) bool {
    if (s.len == 0) {
        ret true;
    }

    if (this.ensure_capacity(s.len) == false) {
        ret false;
    }

    mem.copy[char](this.data + this.len, s.data, s.len);
    this.len = this.len + s.len;
    ret true;
}

pub fun (this: *String) clear() {
    this.len = 0;
}

pub fun (this: *String) dnit() {
    if (this.data != nil && this.cap > 0) {
        mem.deallocate[char](this.data, this.cap);
        this.data = nil;
        this.len = 0;
        this.cap = 0;
    }
}

fun append_escape_sequence(sb: *String, ch: u8) bool {
    var mapped: u8 = ch;
    if (ch == 'n')  { mapped = 10; }
    or (ch == 't')  { mapped = 9; }
    or (ch == 'r')  { mapped = 13; }
    or (ch == '0')  { mapped = 0; }
    or (ch == '\\') { mapped = '\\'; }
    or (ch == '"')  { mapped = '"'; }
    or (ch == '\'') { mapped = '\''; }

    ret sb.push(mapped);
}

fun append_unsigned_decimal(sb: *String, value: usize) bool {
    if (value == 0) {
        ret sb.push('0');
    }

    var digits: [20]u8;
    var count: usize = 0;

    var n: usize = value;
    for (n > 0) {
        digits[count] = ('0' + (n % 10)::u8);
        count = count + 1;
        n = n / 10;
    }

    # append in reverse order
    for (count > 0) {
        count = count - 1;
        if (sb.push(digits[count]) == false) {
            ret false;
        }
    }

    ret true;
}

fun append_signed_decimal(sb: *String, value: isize) bool {
    if (value < 0) {
        if (sb.push('-') == false) {
            ret false;
        }
        val abs_value: usize = (0 - value)::usize;
        ret append_unsigned_decimal(sb, abs_value);
    }

    ret append_unsigned_decimal(sb, value::usize);
}

fun append_hex(sb: *String, value: usize, uppercase: bool) bool {
    if (value == 0) {
        ret sb.append_byte('0');
    }

    var digits: [16]u8;
    var count: usize = 0;

    var n: usize = value;
    for (n > 0) {
        val digit: u8 = (n % 16)::u8;
        if (digit < 10) {
            digits[count] = '0' + digit;
        } or {
            if (uppercase) {
                digits[count] = 'A' + (digit - 10);
            } or {
                digits[count] = 'a' + (digit - 10);
            }
        }
        count = count + 1;
        n = n / 16;
    }

    # append in reverse order
    for (count > 0) {
        count = count - 1;
        if (sb.push(digits[count]) == false) {
            ret false;
        }
    }

    ret true;
}

fun append_bool(sb: *String, value: bool) bool {
    if (value) {
        ret sb.append("true");
    }
    ret sb.append("false");
}

fun append_pointer(sb: *String, value: ptr) bool {
    if (sb.append("0x") == false) {
        ret false;
    }

    val addr: usize = value::usize;
    ret append_hex(sb, addr, false);
}

pub fun (pattern: str) format(...) Option[String] {
    if (pattern.data == nil && pattern.len > 0) {
        ret none[String]();
    }

    # if no format specifiers needed, just clone the pattern
    val arg_count: usize = va_count();
    if (arg_count == 0) {
        # no arguments - check if pattern needs escaping
        var needs_processing: bool = false;
        var i: usize = 0;
        for (i < pattern.len) {
            val ch: u8 = @(pattern.data + i);
            if (ch == '\\' || ch == '%') {
                needs_processing = true;
                brk;
            }
            i = i + 1;
        }

        if (needs_processing == false) {
            # no processing needed, just clone
            ret pattern.clone();
        }
    }

    var result: String;
    if (result.with_capacity(pattern.len + 64) == false) {
        ret none[String]();
    }

    var arg_index: usize = 0;
    var pos: usize = 0;

    for (pos < pattern.len) {
        val ch: u8 = @(pattern.data + pos);

        if (ch == '\\' && (pos + 1) < pattern.len) {
            val next: u8 = @(pattern.data + pos + 1);
            if (append_escape_sequence(?result, next) == false) {
                result.dnit();
                ret none[String]();
            }
            pos = pos + 2;
        }
        or (ch == '%' && (pos + 1) < pattern.len) {
            val spec: u8 = @(pattern.data + pos + 1);

            if (spec == '%') {
                # literal '%'
                if (result.push('%') == false) {
                    result.dnit();
                    ret none[String]();
                }
                pos = pos + 2;
            }
            or (arg_index >= arg_count) {
                # not enough arguments - keep literal
                if (result.push('%') == false || result.push(spec) == false) {
                    result.dnit();
                    ret none[String]();
                }
                pos = pos + 2;
            }
            or (spec == 's') {
                val arg_str: *str = va_arg(arg_index)::*str;
                if (result.append(@arg_str) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or (spec == 'd') {
                val arg_int: *isize = va_arg(arg_index)::*isize;
                if (append_signed_decimal(?result, @arg_int) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or (spec == 'u') {
                val arg_uint: *usize = va_arg(arg_index)::*usize;
                if (append_unsigned_decimal(?result, @arg_uint) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or (spec == 'x') {
                val arg_hex: *usize = va_arg(arg_index)::*usize;
                if (append_hex(?result, @arg_hex, false) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or (spec == 'X') {
                val arg_hex: *usize = va_arg(arg_index)::*usize;
                if (append_hex(?result, @arg_hex, true) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or (spec == 'b') {
                val arg_bool: *bool = va_arg(arg_index)::*bool;
                if (append_bool(?result, @arg_bool) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or (spec == 'p') {
                val arg_ptr: *ptr = va_arg(arg_index)::*ptr;
                if (append_pointer(?result, @arg_ptr) == false) {
                    result.dnit();
                    ret none[String]();
                }
                arg_index = arg_index + 1;
                pos = pos + 2;
            }
            or {
                # unknown specifier - keep literal
                if (result.push('%') == false || result.push(spec) == false) {
                    result.dnit();
                    ret none[String]();
                }
                pos = pos + 2;
            }
        }
        or {
            if (result.push(ch) == false) {
                result.dnit();
                ret none[String]();
            }
            pos = pos + 1;
        }
    }

    ret some[String](result);
}
