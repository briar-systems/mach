use std.types.size;
use std.types.string;
use std.types.list;
use std.types.result;
use std.types.option;
use std.io.path;

use mem: std.system.memory;

pub def FileID: usize;
pub val FILE_ID_INVALID: FileID = $max(usize);

# stores information about a mach source file
pub rec FileInfo {
    id:       FileID;
    path:     Path;
    source:   String;
}

# arena that owns all source files during compilation
pub rec FileArena {
    files: List[FileInfo];
}

# initialize a file arena with initial capacity
pub fun (this: *FileArena) init(cap: usize) Option[str] {
    mem.zero[FileArena](this, 1);

    val res_init: Result[List[FileInfo], str] = list_new[FileInfo](cap);
    if (res_init.is_err()) {
        ret some[str](res_init.unwrap_err());
    }

    this.files = res_init.unwrap_ok();

    ret none[str]();
}

pub fun (this: *FileInfo) dnit() {
    this.path.dnit();
    this.source.dnit();
    mem.zero[FileInfo](this, 1);
}

# clean up file arena and all owned files
pub fun (this: *FileArena) dnit() {
    var i: usize = 0;
    for (i < this.files.len) {
        val file_opt: Option[FileInfo] = this.files.get(i);
        if (file_opt.is_some()) {
            file_opt.unwrap().dnit();
        }
        i = i + 1;
    }

    this.files.dnit();

    mem.zero[FileArena](this, 1);
}

# add a file to the arena and get its FileID
pub fun (this: *FileArena) add(path: Path, source: str) Result[FileID, str] {
    val res_path_clone: Result[Path, str] = path.clone();
    if (res_path_clone.is_err()) {
        ret err[FileID, str]("failed to clone file path");
    }
    val res_source_clone: Result[String, str] = source.clone();
    if (res_source_clone.is_err()) {
        res_path_clone.unwrap_ok().dnit();
        ret err[FileID, str]("failed to clone file source");
    }

    var info: FileInfo;
    info.id     = this.files.len;
    info.path   = res_path_clone.unwrap_ok();
    info.source = res_source_clone.unwrap_ok();
    
    val res: Option[str] = this.files.push(info);
    if (res.is_some()) {
        ret err[FileID, str](res.unwrap());
    }
    
    ret ok[FileID, str](info.id);
}

pub fun (this: FileArena) get(id: FileID) Option[FileInfo] {
    if (id >= this.files.len) {
        ret none[FileInfo]();
    }

    ret this.files.get(id);
}
