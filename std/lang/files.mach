use std.types.size;
use std.types.string;
use std.types.list;
use std.types.result;
use std.types.option;

pub def FileID: usize;
pub val FILE_ID_INVALID: FileID = $max(usize);

pub rec FileInfo {
    id:       FileID;
    path:     string;
    source:   string;
}

pub rec FileArena {
    files: List[FileInfo];
}

pub fun file_arena_make() Result[FileArena, string] {
    var arena: FileArena;

    val res: Result[List[FileInfo], string] = list_new[FileInfo](16);
    if (res.is_err()) {
        ret err[FileArena, string](res.unwrap_err());
    }

    arena.files = res.unwrap_ok();

    ret ok[FileArena, string](arena);
}

pub fun (this: *FileArena) add_file(path: string, source: string) Result[FileID, string] {
    var info: FileInfo;
    info.id       = this.files.len;
    info.path     = path;
    info.source   = source;
    
    val res: Option[string] = this.files.push(info);
    if (res.is_some()) {
        ret err[FileID, string](res.unwrap());
    }
    
    ret ok[FileID, string](info.id);
}

pub fun (this: FileArena) get_file(id: FileID) Option[FileInfo] {
    if (id >= this.files.len) {
        ret none[FileInfo]();
    }

    ret this.files.get(id);
}
