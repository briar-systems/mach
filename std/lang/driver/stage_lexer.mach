use std.lang.files;
use std.lang.lexer;
use std.lang.tokens;
use std.types.bool;
use std.types.list;
use std.types.option;
use std.types.result;
use std.types.size;
use std.types.string;

use mach.compiler.build_context;
use mach.compiler.compilation_unit;
use mach.compiler.diagnostics;
use mach.compiler.stages;

# run the lexer stage on a compilation unit
pub fun run(ctx: *BuildContext, cu: *CompilationUnit) Result[bool, str] {
    if (cu.reached_stage(STAGE_LEXER)) {
        ret ok[bool, str](true);
    }
    
    # get source from file arena
    val file_opt: Option[FileInfo] = ctx.get_file(cu.get_file_id());
    if (file_opt.is_none()) {
        ret err[bool, str]("file not found in arena");
    }
    
    val file_info: FileInfo = file_opt.unwrap();
    
    # initialize lexer
    var lex: Lexer = lexer_make(file_info.source, cu.get_file_id());
    
    # tokenize the entire source
    val token_list_result: Result[List[Token], str] = list_new[Token](256);
    if (token_list_result.is_err()) {
        ret err[bool, str]("failed to allocate token list");
    }
    var token_list: List[Token] = token_list_result.unwrap_ok();
    
    for {
        val tok: Token = lex.next_token();
        
        # check for errors
        if (tok.kind == TOKEN_ERROR) {
            ctx.add_diagnostic(
                DIAG_ERROR,
                STAGE_LEXER,
                tok.span,
                "invalid token"
            );
        }
        
        # add token to list
        val push_err: Option[str] = token_list.push(tok);
        if (push_err.is_some()) {
            val err_msg: str = push_err.unwrap();
            ctx.add_diagnostic(
                DIAG_ERROR,
                STAGE_LEXER,
                tok.span,
                err_msg
            );
            ret err[bool, str](err_msg);
        }
        
        # stop at EOF
        if (tok.kind == TOKEN_EOF) {
            brk;
        }
    }
    
    cu.tokens = some[List[Token]](token_list);
    cu.mark_stage(STAGE_LEXER);
    
    if (ctx.is_ok() == false) {
        ret ok[bool, str](false);
    }
    
    ret ok[bool, str](true);
}
