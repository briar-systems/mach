use std.types.bool;

pub rec PipelineOptions {
    run_setup:    bool;
    run_parse:    bool;
    run_semantic: bool;
    run_lower:    bool;
    run_codegen:  bool;
}

pub fun pipeline_options_default() PipelineOptions {
    var options: PipelineOptions;
    options.run_setup    = true;
    options.run_parse    = true;
    options.run_semantic = true;
    options.run_lower    = true;
    options.run_codegen  = true;
    ret options;
}
