use          std.types.bool;
use          std.types.size;
use          std.types.result;
use          std.types.string;
use          std.types.option;
use          std.io.path;
use fs:      std.io.filesystem;
use console: std.io.console;

use std.lang.files;

use               mach.compiler.stages;
use               mach.compiler.build_context;
use               mach.compiler.compilation_unit;
use               mach.config;
use stage_lexer:  mach.compiler.stage_lexer;
use stage_parser: mach.compiler.stage_parser;
use cu:           mach.compiler.compilation_unit;
use ctx:          mach.compiler.build_context;

fun ensure_stage(ctx: *BuildContext, cu: *CompilationUnit, stage: PipelineStage) Result[bool, str] {
    if (cu.reached_stage(stage)) {
        ret ok[bool, str](true);
    }

    if (stage == STAGE_LEXER) {
        ret stage_lexer.run(ctx, cu);
    }
    or (stage == STAGE_PARSER) {
        ret stage_parser.run(ctx, cu);
    }
    or (stage == STAGE_SEMANTIC) {
        ret err[bool, str]("semantic stage not implemented");
    }
    or (stage == STAGE_CODEGEN) {
        ret err[bool, str]("codegen stage not implemented");
    }

    ret err[bool, str]("unsupported pipeline stage");
}

pub fun compile(ctx: *BuildContext, cu: *CompilationUnit, target_stage: PipelineStage) Result[bool, str] {
    if (target_stage <= STAGE_NONE) {
        ret ok[bool, str](true);
    }

    var stage_result: Result[bool, str];

    if (target_stage >= STAGE_LEXER) {
        stage_result = ensure_stage(ctx, cu, STAGE_LEXER);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, str](false);
        }
    }

    if (target_stage >= STAGE_PARSER) {
        stage_result = ensure_stage(ctx, cu, STAGE_PARSER);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, str](false);
        }
    }

    if (target_stage >= STAGE_SEMANTIC) {
        stage_result = ensure_stage(ctx, cu, STAGE_SEMANTIC);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, str](false);
        }
    }

    if (target_stage >= STAGE_CODEGEN) {
        stage_result = ensure_stage(ctx, cu, STAGE_CODEGEN);
        if (stage_result.is_err()) {
            ret stage_result;
        }
        if (stage_result.unwrap_ok() == false) {
            ret ok[bool, str](false);
        }
    }

    if (target_stage >= STAGE_COMPLETE && cu.reached_stage(STAGE_CODEGEN) && ctx.is_ok()) {
        cu.mark_stage(STAGE_COMPLETE);
    }

    ret ok[bool, str](ctx.is_ok());
}

pub fun run_target(cfg: *Config, target_index: usize) Option[str] {
    val tgt_opt: Option[Target] = cfg.targets.get(target_index);
    if (tgt_opt.is_none()) {
        ret some[str]("target index out of range");
    }

    val target: Target = tgt_opt.unwrap();

    # determine entrypoint path
    var entrypoint_path: Path;
    var needs_cleanup:   bool = false;

    if (cfg.dir_source.is_empty() == false && cfg.dir_source.equals(".") == false) {
        val dir_path_res: Result[Path, str] = path_from_string(cfg.dir_source);
        if (dir_path_res.is_err()) {
            console.print("error: failed to create path: %s\n", dir_path_res.unwrap_err());
            ret some[str]("failed to create directory path");
        }
        var dir_path: Path = dir_path_res.unwrap_ok();

        val entry_path_res: Result[Path, str] = path_from_string(target.entrypoint);
        if (entry_path_res.is_err()) {
            console.print("error: failed to create path: %s\n", entry_path_res.unwrap_err());
            dir_path.dnit();
            ret some[str]("failed to create entrypoint path");
        }
        var entry_path: Path = entry_path_res.unwrap_ok();

        val joined_res: Result[Path, str] = path_join(dir_path, entry_path);
        if (joined_res.is_err()) {
            console.print("error: failed to join paths: %s\n", joined_res.unwrap_err());
            dir_path.dnit();
            entry_path.dnit();
            ret some[str]("failed to join entrypoint path");
        }

        entrypoint_path = joined_res.unwrap_ok();
        needs_cleanup = true;

        # cleanup temporary paths
        dir_path.dnit();
        entry_path.dnit();
    }
    or {
        val entry_path_res: Result[Path, str] = path_from_string(target.entrypoint);
        if (entry_path_res.is_err()) {
            console.print("error: failed to create path: %s\n", entry_path_res.unwrap_err());
            ret some[str]("failed to create entrypoint path");
        }
        entrypoint_path = entry_path_res.unwrap_ok();
        needs_cleanup = true;
    }

    val entrypoint_str: str = entrypoint_path.as_str();

    # use the project id as the root module name when building from a config
    val module_name: str = cfg.project_id;
    console.print("compiling: %s\n", entrypoint_str);

    # create build context
    var build_ctx: ctx.BuildContext;
    val ctx_init_err: Option[str] = build_ctx.init();
    if (ctx_init_err.is_some()) {
        console.print("error: failed to initialize build context: %s\n", ctx_init_err.unwrap());
        if (needs_cleanup) {
            entrypoint_path.dnit();
        }
        ret some[str]("failed to initialize build context");
    }

    # read source file
    val file_result: Result[[]u8, str] = fs.read_all(entrypoint_str);
    if (file_result.is_err()) {
        val err_msg: str = file_result.unwrap_err();
        console.print("error: failed to read source file: %s\n", err_msg);
        build_ctx.dnit();
        if (needs_cleanup) {
            entrypoint_path.dnit();
        }
        ret some[str]("failed to read source file");
    }

    val bytes: []u8 = file_result.unwrap_ok();
    val source_code: str = str{ bytes.data, bytes.len };

    # add file to arena
    val file_id_res: Result[FileID, str] = build_ctx.add_file(entrypoint_str, source_code);
    if (file_id_res.is_err()) {
        console.print("error: failed to add file to arena: %s\n", file_id_res.unwrap_err());
        build_ctx.dnit();
        if (needs_cleanup) {
            entrypoint_path.dnit();
        }
        ret some[str]("failed to add file to arena");
    }

    val file_id: FileID = file_id_res.unwrap_ok();

    # can cleanup entrypoint_path now that it's been added to the arena
    if (needs_cleanup) {
        entrypoint_path.dnit();
    }

    # create compilation unit
    val unit_idx_res: Result[UnitID, str] = build_ctx.create_unit(file_id, module_name);
    if (unit_idx_res.is_err()) {
        console.print("error: failed to create compilation unit: %s\n", unit_idx_res.unwrap_err());
        build_ctx.dnit();
        ret some[str]("failed to create compilation unit");
    }

    val unit_idx: UnitID = unit_idx_res.unwrap_ok();
    val unit_opt: Option[*cu.CompilationUnit] = build_ctx.get_unit(unit_idx);
    if (unit_opt.is_none()) {
        console.print("error: failed to retrieve compilation unit\n");
        build_ctx.dnit();
        ret some[str]("failed to retrieve compilation unit");
    }

    var unit: *cu.CompilationUnit = unit_opt.unwrap();

    # run compilation pipeline through parser stage
    val compile_result: Result[bool, str] = compile(?build_ctx, unit, STAGE_PARSER);
    if (compile_result.is_err()) {
        console.print("error: compilation failed: %s\n", compile_result.unwrap_err());
        build_ctx.print_diagnostics();
        build_ctx.dnit();
        ret some[str]("compilation failed");
    }

    if (build_ctx.is_ok() == false) {
        build_ctx.print_diagnostics();
        build_ctx.dnit();
        ret some[str]("compilation had errors");
    }

    build_ctx.dnit();

    ret none[str]();
}

pub fun build_with_config(cfg: *Config) i64 {
    val build_all: bool = cfg.target.equals("all");

    if (build_all) {
        var i: usize = 0;
        for (i < cfg.targets.len) {
            val tgt_opt: Option[Target] = cfg.targets.get(i);
            if (tgt_opt.is_some()) {
                val opt_run: Option[str] = run_target(cfg, i);
                if (opt_run.is_some()) {
                    console.print("error: %s\n", opt_run.unwrap());
                    ret 1;
                }
            }
            i = i + 1;
        }
        ret 0;
    }

    var selected_index: Option[usize] = none[usize]();
    var i: usize = 0;
    for (i < cfg.targets.len) {
        val tgt_opt: Option[Target] = cfg.targets.get(i);
        if (tgt_opt.is_some()) {
            val tgt: Target = tgt_opt.unwrap();
            if (tgt.name.equals(cfg.target)) {
                selected_index = some[usize](i);
                brk;
            }
        }
        i = i + 1;
    }

    if (selected_index.is_none()) {
        console.print("error: target '%s' not found in config\n", cfg.target);
        ret 1;
    }

    val opt_run: Option[str] = run_target(cfg, selected_index.unwrap());
    if (opt_run.is_some()) {
        console.print("error: %s\n", opt_run.unwrap());
        ret 1;
    }

    ret 0;
}
