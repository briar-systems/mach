use std.lang.ast;
use std.lang.files;
use std.lang.tokens;
use std.types.bool;
use std.types.size;
use std.types.list;
use std.types.option;
use std.types.result;
use std.types.string;

use mach.compiler.stages;

use mem: std.system.memory;

pub def UnitID: usize;
pub val UNIT_ID_INVALID: UnitID = $max(usize);

# compilation unit - holds state for compiling a single module
pub rec CompilationUnit {
    # source reference
    unit_id:     UnitID;
    file_id:     FileID;
    module_name: String;
    
    # compilation artifacts
    tokens: Option[List[Token]];
    ast:    Option[AST];
    
    # pipeline progress
    current_stage: PipelineStage;
}

pub fun (this: *CompilationUnit) init(file_id: FileID, module_name: str) Option[str] {
    mem.zero[CompilationUnit](this, 1);

    val res_module_name: Result[String, str] = module_name.clone();
    if (res_module_name.is_err()) {
        ret some[str]("failed to clone module name");
    }
    this.module_name = res_module_name.unwrap_ok();

    this.unit_id     = UNIT_ID_INVALID;
    this.file_id     = file_id;

    this.tokens = none[List[Token]]();
    this.ast    = none[AST]();
    
    this.current_stage = STAGE_NONE;
}

pub fun (this: *CompilationUnit) dnit() {
    this.module_name.dnit();

    if (this.tokens.is_some()) {
        this.tokens.unwrap().dnit();
        this.tokens = none[List[Token]]();
    }

    if (this.ast.is_some()) {
        this.ast.unwrap().dnit();
        this.ast = none[AST]();
    }

    mem.zero[CompilationUnit](this, 1);
    this.unit_id = UNIT_ID_INVALID;
    this.file_id = FILE_ID_INVALID;
}

# get file id
pub fun (this: *CompilationUnit) get_file_id() FileID {
    ret this.file_id;
}

# get the token list
pub fun (this: *CompilationUnit) get_tokens() Option[List[Token]] {
    ret this.tokens;
}

# get the ast
pub fun (this: *CompilationUnit) get_ast() Option[AST] {
    ret this.ast;
}

# get current pipeline stage
pub fun (this: *CompilationUnit) get_stage() PipelineStage {
    ret this.current_stage;
}

# check if the given stage has already been executed
pub fun (this: *CompilationUnit) reached_stage(stage: PipelineStage) bool {
    ret this.current_stage >= stage;
}

# update the current stage marker without regressing
pub fun (this: *CompilationUnit) mark_stage(stage: PipelineStage) {
    if (stage > this.current_stage) {
        this.current_stage = stage;
    }
}
