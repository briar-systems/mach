use std.types.bool;
use std.types.option;
use std.types.size;
use std.types.string;
use std.lang.files;

pub def TokenKind: i16;

pub val TOKEN_ERROR:   TokenKind = -1;
pub val TOKEN_EOF:     TokenKind = 0;
pub val TOKEN_COMMENT: TokenKind = TOKEN_EOF + 1;

pub val TOKEN_LIT_INT:    TokenKind = TOKEN_COMMENT + 1;
pub val TOKEN_LIT_FLOAT:  TokenKind = TOKEN_LIT_INT + 1;
pub val TOKEN_LIT_CHAR:   TokenKind = TOKEN_LIT_FLOAT + 1;
pub val TOKEN_LIT_STRING: TokenKind = TOKEN_LIT_CHAR + 1;

pub val TOKEN_IDENTIFIER: TokenKind = TOKEN_LIT_STRING + 1;

pub val TOKEN_KW_USE: TokenKind = TOKEN_IDENTIFIER + 1;
pub val TOKEN_KW_EXT: TokenKind = TOKEN_KW_USE + 1;
pub val TOKEN_KW_DEF: TokenKind = TOKEN_KW_EXT + 1;
pub val TOKEN_KW_PUB: TokenKind = TOKEN_KW_DEF + 1;
pub val TOKEN_KW_REC: TokenKind = TOKEN_KW_PUB + 1;
pub val TOKEN_KW_UNI: TokenKind = TOKEN_KW_REC + 1;
pub val TOKEN_KW_VAL: TokenKind = TOKEN_KW_UNI + 1;
pub val TOKEN_KW_VAR: TokenKind = TOKEN_KW_VAL + 1;
pub val TOKEN_KW_FUN: TokenKind = TOKEN_KW_VAR + 1;
pub val TOKEN_KW_RET: TokenKind = TOKEN_KW_FUN + 1;
pub val TOKEN_KW_IF:  TokenKind = TOKEN_KW_RET + 1;
pub val TOKEN_KW_OR:  TokenKind = TOKEN_KW_IF + 1;
pub val TOKEN_KW_FOR: TokenKind = TOKEN_KW_OR + 1;
pub val TOKEN_KW_CNT: TokenKind = TOKEN_KW_FOR + 1;
pub val TOKEN_KW_BRK: TokenKind = TOKEN_KW_CNT + 1;
pub val TOKEN_KW_ASM: TokenKind = TOKEN_KW_BRK + 1;
pub val TOKEN_KW_NIL: TokenKind = TOKEN_KW_ASM + 1;

pub val TOKEN_L_PAREN:    TokenKind = TOKEN_KW_NIL + 1;
pub val TOKEN_R_PAREN:    TokenKind = TOKEN_L_PAREN + 1;
pub val TOKEN_L_BRACKET:  TokenKind = TOKEN_R_PAREN + 1;
pub val TOKEN_R_BRACKET:  TokenKind = TOKEN_L_BRACKET + 1;
pub val TOKEN_L_BRACE:    TokenKind = TOKEN_R_BRACKET + 1;
pub val TOKEN_R_BRACE:    TokenKind = TOKEN_L_BRACE + 1;
pub val TOKEN_COLON:      TokenKind = TOKEN_R_BRACE + 1;
pub val TOKEN_SEMICOLON:  TokenKind = TOKEN_COLON + 1;
pub val TOKEN_QUESTION:   TokenKind = TOKEN_SEMICOLON + 1;
pub val TOKEN_AT:         TokenKind = TOKEN_QUESTION + 1;
pub val TOKEN_DOLLAR:     TokenKind = TOKEN_AT + 1;
pub val TOKEN_DOT:        TokenKind = TOKEN_DOLLAR + 1;
pub val TOKEN_COMMA:      TokenKind = TOKEN_DOT + 1;
pub val TOKEN_UNDERSCORE: TokenKind = TOKEN_COMMA + 1;
pub val TOKEN_ELLIPSIS:   TokenKind = TOKEN_UNDERSCORE + 1;

pub val TOKEN_PLUS:      TokenKind = TOKEN_ELLIPSIS + 1;
pub val TOKEN_MINUS:     TokenKind = TOKEN_PLUS + 1;
pub val TOKEN_STAR:      TokenKind = TOKEN_MINUS + 1;
pub val TOKEN_PERCENT:   TokenKind = TOKEN_STAR + 1;
pub val TOKEN_CARET:     TokenKind = TOKEN_PERCENT + 1;
pub val TOKEN_AMPERSAND: TokenKind = TOKEN_CARET + 1;
pub val TOKEN_PIPE:      TokenKind = TOKEN_AMPERSAND + 1;
pub val TOKEN_TILDE:     TokenKind = TOKEN_PIPE + 1;
pub val TOKEN_LESS:      TokenKind = TOKEN_TILDE + 1;
pub val TOKEN_GREATER:   TokenKind = TOKEN_LESS + 1;
pub val TOKEN_EQUAL:     TokenKind = TOKEN_GREATER + 1;
pub val TOKEN_BANG:      TokenKind = TOKEN_EQUAL + 1;
pub val TOKEN_SLASH:     TokenKind = TOKEN_BANG + 1;

pub val TOKEN_EQUAL_EQUAL:         TokenKind = TOKEN_SLASH + 1;
pub val TOKEN_BANG_EQUAL:          TokenKind = TOKEN_EQUAL_EQUAL + 1;
pub val TOKEN_LESS_EQUAL:          TokenKind = TOKEN_BANG_EQUAL + 1;
pub val TOKEN_GREATER_EQUAL:       TokenKind = TOKEN_LESS_EQUAL + 1;
pub val TOKEN_LESS_LESS:           TokenKind = TOKEN_GREATER_EQUAL + 1;
pub val TOKEN_GREATER_GREATER:     TokenKind = TOKEN_LESS_LESS + 1;
pub val TOKEN_AMPERSAND_AMPERSAND: TokenKind = TOKEN_GREATER_GREATER + 1;
pub val TOKEN_PIPE_PIPE:           TokenKind = TOKEN_AMPERSAND_AMPERSAND + 1;
pub val TOKEN_COLON_COLON:         TokenKind = TOKEN_PIPE_PIPE + 1;

pub rec Span {
    offset:  usize;
    length:  usize;
    line:    usize;
    column:  usize;
    file_id: FileID;
}

pub fun span_end(span: Span) usize {
    ret span.offset + span.length;
}

pub fun span_is_empty(span: Span) bool {
    ret span.length == 0;
}

pub fun span_overlaps(a: Span, b: Span) bool {
    if (span_is_empty(a) || span_is_empty(b)) {
        ret false;
    }

    ret (a.offset < span_end(b)) && (b.offset < span_end(a));
}

pub rec Token {
    kind: TokenKind;
    span: Span;
}

pub fun token_make(kind: TokenKind, offset: usize, length: usize, line: usize, column: usize, file_id: FileID) Token {
    var span: Span;
    span.offset  = offset;
    span.length  = length;
    span.line    = line;
    span.column  = column;
    span.file_id = file_id;

    var token: Token;
    token.kind = kind;
    token.span = span;
    ret token;
}

pub fun (this: Token) is(kind: TokenKind) bool {
    ret this.kind == kind;
}

pub fun (this: Token) is_any(kind_a: TokenKind, kind_b: TokenKind) bool {
    ret (this.kind == kind_a) || (this.kind == kind_b);
}

pub fun (this: Token) is_literal() bool {
    ret this.kind >= TOKEN_LIT_INT && this.kind <= TOKEN_LIT_STRING;
}

pub fun (this: Token) is_keyword() bool {
    ret this.kind >= TOKEN_KW_USE && this.kind <= TOKEN_KW_NIL;
}

pub fun token_kind_to_string(kind: TokenKind) str {
    if (kind == TOKEN_ERROR)   { ret "error"; }
    if (kind == TOKEN_EOF)     { ret "eof"; }
    if (kind == TOKEN_COMMENT) { ret "comment"; }

    if (kind == TOKEN_LIT_INT)    { ret "lit_int"; }
    if (kind == TOKEN_LIT_FLOAT)  { ret "lit_float"; }
    if (kind == TOKEN_LIT_CHAR)   { ret "lit_char"; }
    if (kind == TOKEN_LIT_STRING) { ret "lit_string"; }

    if (kind == TOKEN_IDENTIFIER) { ret "identifier"; }

    if (kind == TOKEN_KW_USE) { ret "use"; }
    if (kind == TOKEN_KW_EXT) { ret "ext"; }
    if (kind == TOKEN_KW_DEF) { ret "def"; }
    if (kind == TOKEN_KW_PUB) { ret "pub"; }
    if (kind == TOKEN_KW_REC) { ret "rec"; }
    if (kind == TOKEN_KW_UNI) { ret "uni"; }
    if (kind == TOKEN_KW_VAL) { ret "val"; }
    if (kind == TOKEN_KW_VAR) { ret "var"; }
    if (kind == TOKEN_KW_FUN) { ret "fun"; }
    if (kind == TOKEN_KW_RET) { ret "ret"; }
    if (kind == TOKEN_KW_IF)  { ret "if"; }
    if (kind == TOKEN_KW_OR)  { ret "or"; }
    if (kind == TOKEN_KW_FOR) { ret "for"; }
    if (kind == TOKEN_KW_CNT) { ret "cnt"; }
    if (kind == TOKEN_KW_BRK) { ret "brk"; }
    if (kind == TOKEN_KW_ASM) { ret "asm"; }
    if (kind == TOKEN_KW_NIL) { ret "nil"; }

    if (kind == TOKEN_L_PAREN)    { ret "("; }
    if (kind == TOKEN_R_PAREN)    { ret ")"; }
    if (kind == TOKEN_L_BRACKET)  { ret "["; }
    if (kind == TOKEN_R_BRACKET)  { ret "]"; }
    if (kind == TOKEN_L_BRACE)    { ret "{"; }
    if (kind == TOKEN_R_BRACE)    { ret "}"; }
    if (kind == TOKEN_COLON)      { ret ":"; }
    if (kind == TOKEN_SEMICOLON)  { ret ";"; }
    if (kind == TOKEN_QUESTION)   { ret "?"; }
    if (kind == TOKEN_AT)         { ret "@"; }
    if (kind == TOKEN_DOLLAR)     { ret "$"; }
    if (kind == TOKEN_DOT)        { ret "."; }
    if (kind == TOKEN_COMMA)      { ret ","; }
    if (kind == TOKEN_UNDERSCORE) { ret "_"; }
    if (kind == TOKEN_ELLIPSIS)   { ret "..."; }

    if (kind == TOKEN_PLUS)      { ret "+"; }
    if (kind == TOKEN_MINUS)     { ret "-"; }
    if (kind == TOKEN_STAR)      { ret "*"; }
    if (kind == TOKEN_PERCENT)   { ret "%"; }
    if (kind == TOKEN_CARET)     { ret "^"; }
    if (kind == TOKEN_AMPERSAND) { ret "&"; }
    if (kind == TOKEN_PIPE)      { ret "|"; }
    if (kind == TOKEN_TILDE)     { ret "~"; }
    if (kind == TOKEN_LESS)      { ret "<"; }
    if (kind == TOKEN_GREATER)   { ret ">"; }
    if (kind == TOKEN_EQUAL)     { ret "="; }
    if (kind == TOKEN_BANG)      { ret "!"; }
    if (kind == TOKEN_SLASH)     { ret "/"; }

    if (kind == TOKEN_EQUAL_EQUAL)         { ret "=="; }
    if (kind == TOKEN_BANG_EQUAL)          { ret "!="; }
    if (kind == TOKEN_LESS_EQUAL)          { ret "<="; }
    if (kind == TOKEN_GREATER_EQUAL)       { ret ">="; }
    if (kind == TOKEN_LESS_LESS)           { ret "<<"; }
    if (kind == TOKEN_GREATER_GREATER)     { ret ">>"; }
    if (kind == TOKEN_AMPERSAND_AMPERSAND) { ret "&&"; }
    if (kind == TOKEN_PIPE_PIPE)           { ret "||"; }
    if (kind == TOKEN_COLON_COLON)         { ret "::"; }

    ret "unknown";
}

fun keyword_equals(text: str, keyword: str) bool {
    if (text.len != keyword.len) {
        ret false;
    }

    if (text.len == 0) {
        ret true;
    }

    if (text.data == nil || keyword.data == nil) {
        ret false;
    }

    var i: usize = 0;
    for (i < text.len) {
        if (@(text.data + i) != @(keyword.data + i)) {
            ret false;
        }
        i = i + 1;
    }

    ret true;
}

pub fun token_kind_from_identifier(text: str) TokenKind {
    if (text.len == 0) {
        ret TOKEN_IDENTIFIER;
    }

    if (text.len == 2) {
        if (keyword_equals(text, "if")) { ret TOKEN_KW_IF; }
        if (keyword_equals(text, "or")) { ret TOKEN_KW_OR; }
    }
    or (text.len == 3) {
        if (keyword_equals(text, "nil")) { ret TOKEN_KW_NIL; }
        if (keyword_equals(text, "asm")) { ret TOKEN_KW_ASM; }
        if (keyword_equals(text, "use")) { ret TOKEN_KW_USE; }
        if (keyword_equals(text, "ext")) { ret TOKEN_KW_EXT; }
        if (keyword_equals(text, "def")) { ret TOKEN_KW_DEF; }
        if (keyword_equals(text, "pub")) { ret TOKEN_KW_PUB; }
        if (keyword_equals(text, "rec")) { ret TOKEN_KW_REC; }
        if (keyword_equals(text, "uni")) { ret TOKEN_KW_UNI; }
        if (keyword_equals(text, "val")) { ret TOKEN_KW_VAL; }
        if (keyword_equals(text, "var")) { ret TOKEN_KW_VAR; }
        if (keyword_equals(text, "fun")) { ret TOKEN_KW_FUN; }
        if (keyword_equals(text, "ret")) { ret TOKEN_KW_RET; }
        if (keyword_equals(text, "for")) { ret TOKEN_KW_FOR; }
        if (keyword_equals(text, "cnt")) { ret TOKEN_KW_CNT; }
        if (keyword_equals(text, "brk")) { ret TOKEN_KW_BRK; }
    }

    ret TOKEN_IDENTIFIER;
}

pub fun token_lexeme(source: str, token: Token) Option[str] {
    if (source.data == nil || token.span.length == 0) {
        ret none[str]();
    }

    if (token.span.offset >= source.len) {
        ret none[str]();
    }

    val end: usize = token.span.offset + token.span.length;
    if (end > source.len) {
        ret none[str]();
    }

    ret some[str](str{ (source.data + token.span.offset), token.span.length });
}
