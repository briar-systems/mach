pub rec AstTypeParamNode {
    name: AstIdentifier;
}

pub rec AstTypeFunctionNode {
    params: List[AstId];
    return_type: Option[AstId];
    is_variadic: bool;
}

pub rec AstTypeRecordNode {
    name: Option[AstIdentifier];
    fields: List[AstId];
}

pub rec AstTypeUnionNode {
    name: Option[AstIdentifier];
    fields: List[AstId];
}

pub uni AstNodeData {
    program:        AstProgramNode;
    module:         AstModuleNode;
    use_decl:       AstUseNode;
    extern_decl:    AstExternNode;
    def_decl:       AstTypeAliasNode;
    binding:        AstBindingNode;
    function:       AstFunctionNode;
    record_decl:    AstRecordNode;
    union_decl:     AstUnionNode;
    field_decl:     AstFieldNode;
    param_decl:     AstParamNode;
    block:          AstBlockNode;
    expr_stmt:      AstExprStmtNode;
    asm_stmt:       AstAsmStmtNode;
    comptime:       AstComptimeNode;
    return_stmt:    AstReturnNode;
    if_stmt:        AstIfNode;
    loop_stmt:      AstLoopNode;
    break_stmt:     AstBreakNode;
    continue_stmt:  AstContinueNode;
    call_expr:      AstCallNode;
    binary_expr:    AstBinaryNode;
    unary_expr:     AstUnaryNode;
    index_expr:     AstIndexNode;
    field_expr:     AstFieldAccessNode;
    cast_expr:      AstCastNode;
    ident_expr:     AstIdentifierNode;
    literal_expr:   AstLiteralNode;
    null_expr:      AstNullNode;
    array_expr:     AstArrayNode;
    struct_expr:    AstStructNode;
    varargs_expr:   AstVarargsNode;
    type_name:      AstTypeNameNode;
    type_ptr:       AstTypePointerNode;
    type_array:     AstTypeArrayNode;
    type_param:     AstTypeParamNode;
    type_fun:       AstTypeFunctionNode;
    type_rec:       AstTypeRecordNode;
    type_uni:       AstTypeUnionNode;
}

pub rec AstNode {
    id:   AstId;
    kind: AstKind;
    span: Span;
    data: AstNodeData;
}

pub fun ast_node_make(kind: AstKind, span: Span) AstNode {
    var node: AstNode;
    node.id   = AST_ID_UNASSIGNED;
    node.kind = kind;
    node.span = span;
    ret node;
}

pub fun (this: AstNode) has_valid_id() bool {
    ret ast_id_is_valid(this.id);
}

pub rec AstArena {
    nodes: List[AstNode];
}

pub fun ast_arena_new(initial_capacity: usize) Result[AstArena, string] {
    var cap: usize = initial_capacity;
    if (cap == 0) {
        cap = 64;
    }

    val list_result: Result[List[AstNode], string] = list_new[AstNode](cap);
    if (list_result.is_err()) {
        ret err[AstArena, string](list_result.unwrap_err());
    }

    var arena: AstArena;
    arena.nodes = list_result.unwrap_ok();
    ret ok[AstArena, string](arena);
}

pub fun (this: *AstArena) free() {
    this.nodes.free();
}

pub fun (this: *AstArena) clear() {
    this.nodes.clear();
}

pub fun (this: *AstArena) len() usize {
    ret this.nodes.len;
}

pub fun (this: *AstArena) push(node: AstNode) Result[AstId, string] {
    val push_err: Option[string] = this.nodes.push(node);
    if (push_err.is_some()) {
        ret err[AstId, string](push_err.unwrap());
    }

    val index: usize = this.nodes.len - 1;
    val id_result: Result[AstId, string] = ast_id_from_index(index);
    if (id_result.is_err()) {
        this.nodes.pop();
        ret err[AstId, string](id_result.unwrap_err());
    }

    val id: AstId = id_result.unwrap_ok();
    val ptr: *AstNode = this.nodes.data + index;
    ptr.id = id;

    ret ok[AstId, string](id);
}

pub fun (this: *AstArena) get_mut(id: AstId) Option[*AstNode] {
    if (ast_id_is_valid(id) == false) {
        ret none[*AstNode]();
    }

    val index: usize = ast_id_to_index(id);
    if (index >= this.nodes.len) {
        ret none[*AstNode]();
    }

    ret some[*AstNode](this.nodes.data + index);
}

pub fun (this: AstArena) get(id: AstId) Option[AstNode] {
    if (ast_id_is_valid(id) == false) {
        ret none[AstNode]();
    }

    val index: usize = ast_id_to_index(id);
    if (index >= this.nodes.len) {
        ret none[AstNode]();
    }

    ret some[AstNode](@(this.nodes.data + index));
}

pub fun (this: *AstArena) emplace(kind: AstKind, span: Span) Result[*AstNode, string] {
    val node: AstNode = ast_node_make(kind, span);
    val id_result: Result[AstId, string] = this.push(node);
    if (id_result.is_err()) {
        ret err[*AstNode, string](id_result.unwrap_err());
    }

    val node_id: AstId = id_result.unwrap_ok();
    val ptr_opt: Option[*AstNode] = this.get_mut(node_id);
    if (ptr_opt.is_none()) {
        ret err[*AstNode, string]("failed to get ast node reference");
    }

    ret ok[*AstNode, string](ptr_opt.unwrap());
}

pub rec Ast {
    arena: AstArena;
    root_id: AstId;
}

pub fun ast_create(initial_capacity: usize) Result[Ast, string] {
    val arena_result: Result[AstArena, string] = ast_arena_new(initial_capacity);
    if (arena_result.is_err()) {
        ret err[Ast, string](arena_result.unwrap_err());
    }

    var ast: Ast;
    ast.arena   = arena_result.unwrap_ok();
    ast.root_id = AST_ID_UNASSIGNED;
    ret ok[Ast, string](ast);
}

pub fun ast_from_parts(arena: AstArena, root: AstId) Ast {
    var ast: Ast;
    ast.arena   = arena;
    ast.root_id = root;
    ret ast;
}

pub fun (this: *Ast) set_root(root: AstId) {
    this.root_id = root;
}

pub fun (this: Ast) root() AstId {
    ret this.root_id;
}

pub fun (this: Ast) is_ready() bool {
    ret ast_id_is_valid(this.root_id);
}

pub fun (this: *Ast) borrow_arena() *AstArena {
    ret ?this.arena;
}

pub fun (this: Ast) arena_len() usize {
    ret this.arena.len();
}
