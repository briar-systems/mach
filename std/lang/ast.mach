use          std.lang.tokens;
use          std.types.bool;
use          std.types.list;
use          std.types.option;
use          std.types.result;
use          std.types.size;
use          std.types.string;

pub def AstId: u32;
pub val AST_ID_UNASSIGNED: AstId = 0xffff_ffff;
pub val AST_ID_MAX_INDEX: usize  = 0xffff_ffff;

pub fun ast_id_from_index(index: usize) Result[AstId, string] {
    if (index > AST_ID_MAX_INDEX) {
        ret err[AstId, string]("ast arena exhausted (node index overflow)");
    }

    ret ok[AstId, string]((index :: AstId));
}

pub fun ast_id_to_index(id: AstId) usize {
    ret (id :: usize);
}

pub fun ast_id_is_valid(id: AstId) bool {
    ret id != AST_ID_UNASSIGNED;
}

pub def AstKind: u16;

pub val AST_NODE_PROGRAM:      AstKind = 0;
pub val AST_NODE_MODULE:       AstKind = AST_NODE_PROGRAM + 1;
pub val AST_NODE_USE:          AstKind = AST_NODE_MODULE + 1;
pub val AST_NODE_EXT:          AstKind = AST_NODE_USE + 1;
pub val AST_NODE_DEF:          AstKind = AST_NODE_EXT + 1;
pub val AST_NODE_BINDING:      AstKind = AST_NODE_DEF + 1;
pub val AST_NODE_FUN:          AstKind = AST_NODE_BINDING + 1;
pub val AST_NODE_REC:          AstKind = AST_NODE_FUN + 1;
pub val AST_NODE_UNI:          AstKind = AST_NODE_REC + 1;
pub val AST_NODE_FIELD:        AstKind = AST_NODE_UNI + 1;
pub val AST_NODE_PARAM:        AstKind = AST_NODE_FIELD + 1;
pub val AST_NODE_BLOCK:        AstKind = AST_NODE_PARAM + 1;
pub val AST_NODE_EXPR_STMT:    AstKind = AST_NODE_BLOCK + 1;
pub val AST_NODE_ASM:          AstKind = AST_NODE_EXPR_STMT + 1;
pub val AST_NODE_COMPTIME:     AstKind = AST_NODE_ASM + 1;
pub val AST_NODE_RETURN:       AstKind = AST_NODE_COMPTIME + 1;
pub val AST_NODE_IF:           AstKind = AST_NODE_RETURN + 1;
pub val AST_NODE_LOOP:         AstKind = AST_NODE_IF + 1;
pub val AST_NODE_BREAK:        AstKind = AST_NODE_LOOP + 1;
pub val AST_NODE_CONTINUE:     AstKind = AST_NODE_BREAK + 1;
pub val AST_NODE_CALL:         AstKind = AST_NODE_CONTINUE + 1;
pub val AST_NODE_BINARY:       AstKind = AST_NODE_CALL + 1;
pub val AST_NODE_UNARY:        AstKind = AST_NODE_BINARY + 1;
pub val AST_NODE_INDEX:        AstKind = AST_NODE_UNARY + 1;
pub val AST_NODE_FIELD_ACCESS: AstKind = AST_NODE_INDEX + 1;
pub val AST_NODE_CAST:         AstKind = AST_NODE_FIELD_ACCESS + 1;
pub val AST_NODE_IDENT:        AstKind = AST_NODE_CAST + 1;
pub val AST_NODE_LITERAL:      AstKind = AST_NODE_IDENT + 1;
pub val AST_NODE_NULL:         AstKind = AST_NODE_LITERAL + 1;
pub val AST_NODE_ARRAY:        AstKind = AST_NODE_NULL + 1;
pub val AST_NODE_STRUCT:       AstKind = AST_NODE_ARRAY + 1;
pub val AST_NODE_VARARGS:      AstKind = AST_NODE_STRUCT + 1;
pub val AST_NODE_TYPE_NAME:    AstKind = AST_NODE_VARARGS + 1;
pub val AST_NODE_TYPE_PTR:     AstKind = AST_NODE_TYPE_NAME + 1;
pub val AST_NODE_TYPE_ARRAY:   AstKind = AST_NODE_TYPE_PTR + 1;
pub val AST_NODE_TYPE_PARAM:   AstKind = AST_NODE_TYPE_ARRAY + 1;
pub val AST_NODE_TYPE_FUN:     AstKind = AST_NODE_TYPE_PARAM + 1;
pub val AST_NODE_TYPE_REC:     AstKind = AST_NODE_TYPE_FUN + 1;
pub val AST_NODE_TYPE_UNI:     AstKind = AST_NODE_TYPE_REC + 1;

pub fun ast_kind_to_string(kind: AstKind) string {
    if (kind == AST_NODE_PROGRAM) { ret "program"; }
    if (kind == AST_NODE_MODULE) { ret "module"; }
    if (kind == AST_NODE_USE) { ret "use"; }
    if (kind == AST_NODE_EXT) { ret "extern"; }
    if (kind == AST_NODE_DEF) { ret "def"; }
    if (kind == AST_NODE_BINDING) { ret "binding"; }
    if (kind == AST_NODE_FUN) { ret "function"; }
    if (kind == AST_NODE_REC) { ret "record"; }
    if (kind == AST_NODE_UNI) { ret "union"; }
    if (kind == AST_NODE_FIELD) { ret "field"; }
    if (kind == AST_NODE_PARAM) { ret "param"; }
    if (kind == AST_NODE_BLOCK) { ret "block"; }
    if (kind == AST_NODE_EXPR_STMT) { ret "expr_stmt"; }
    if (kind == AST_NODE_ASM) { ret "asm"; }
    if (kind == AST_NODE_COMPTIME) { ret "comptime"; }
    if (kind == AST_NODE_RETURN) { ret "return"; }
    if (kind == AST_NODE_IF) { ret "if"; }
    if (kind == AST_NODE_LOOP) { ret "loop"; }
    if (kind == AST_NODE_BREAK) { ret "break"; }
    if (kind == AST_NODE_CONTINUE) { ret "continue"; }
    if (kind == AST_NODE_CALL) { ret "call"; }
    if (kind == AST_NODE_BINARY) { ret "binary"; }
    if (kind == AST_NODE_UNARY) { ret "unary"; }
    if (kind == AST_NODE_INDEX) { ret "index"; }
    if (kind == AST_NODE_FIELD_ACCESS) { ret "field_access"; }
    if (kind == AST_NODE_CAST) { ret "cast"; }
    if (kind == AST_NODE_IDENT) { ret "ident"; }
    if (kind == AST_NODE_LITERAL) { ret "literal"; }
    if (kind == AST_NODE_NULL) { ret "null"; }
    if (kind == AST_NODE_ARRAY) { ret "array"; }
    if (kind == AST_NODE_STRUCT) { ret "struct"; }
    if (kind == AST_NODE_VARARGS) { ret "varargs"; }
    if (kind == AST_NODE_TYPE_NAME) { ret "type_name"; }
    if (kind == AST_NODE_TYPE_PTR) { ret "type_ptr"; }
    if (kind == AST_NODE_TYPE_ARRAY) { ret "type_array"; }
    if (kind == AST_NODE_TYPE_PARAM) { ret "type_param"; }
    if (kind == AST_NODE_TYPE_FUN) { ret "type_fun"; }
    if (kind == AST_NODE_TYPE_REC) { ret "type_rec"; }
    if (kind == AST_NODE_TYPE_UNI) { ret "type_uni"; }
    ret "unknown";
}

pub def AstVisibility: u8;
pub val AST_VIS_PRIVATE: AstVisibility = 0;
pub val AST_VIS_PUBLIC:  AstVisibility = 1;

pub fun (this: AstVisibility) is_public() bool {
    ret this == AST_VIS_PUBLIC;
}

pub def AstLoopKind: u8;
pub val AST_LOOP_WHILE:    AstLoopKind = 0;
pub val AST_LOOP_INFINITE: AstLoopKind = 1;

pub rec AstIdentifier {
    name: string;
    span: Span;
}

pub fun ast_identifier(name: string, span: Span) AstIdentifier {
    var ident: AstIdentifier;
    ident.name = name;
    ident.span = span;
    ret ident;
}

pub fun ast_identifier_empty() AstIdentifier {
    var ident: AstIdentifier;
    ret ident;
}

pub rec AstProgramNode {
    items: List[AstId];
}

pub rec AstModuleNode {
    name: AstIdentifier;
    items: List[AstId];
}

pub rec AstUseNode {
    path: List[AstIdentifier];
    alias: Option[AstIdentifier];
    visibility: AstVisibility;
}

pub rec AstExternNode {
    name: AstIdentifier;
    type_id: Option[AstId];
    convention: Option[string];
    symbol_name: Option[string];
    visibility: AstVisibility;
}

pub rec AstTypeAliasNode {
    name: AstIdentifier;
    type_id: AstId;
    visibility: AstVisibility;
}

pub rec AstBindingNode {
    name: AstIdentifier;
    type_id: Option[AstId];
    init_expr: Option[AstId];
    is_mutable: bool;
    visibility: AstVisibility;
}

pub rec AstFunctionReceiver {
    name: Option[AstIdentifier];
    type_id: AstId;
}

pub rec AstFunctionNode {
    name: AstIdentifier;
    params: List[AstId];
    generics: List[AstId];
    return_type: Option[AstId];
    body: Option[AstId];
    receiver: Option[AstFunctionReceiver];
    is_variadic: bool;
    is_method: bool;
    visibility: AstVisibility;
}

pub rec AstRecordNode {
    name: AstIdentifier;
    generics: List[AstId];
    fields: List[AstId];
    visibility: AstVisibility;
}

pub rec AstUnionNode {
    name: AstIdentifier;
    generics: List[AstId];
    fields: List[AstId];
    visibility: AstVisibility;
}

pub rec AstFieldNode {
    name: AstIdentifier;
    type_id: AstId;
}

pub rec AstParamNode {
    name: AstIdentifier;
    type_id: AstId;
    default_value: Option[AstId];
    is_variadic: bool;
}

pub rec AstBlockNode {
    statements: List[AstId];
    trailing: Option[AstId];
}

pub rec AstExprStmtNode {
    expr: AstId;
}

pub rec AstAsmStmtNode {
    template: string;
    constraints: Option[string];
}

pub rec AstComptimeNode {
    inner: AstId;
}

pub rec AstReturnNode {
    value: Option[AstId];
}

pub rec AstIfBranch {
    condition: Option[AstId];
    body: AstId;
}

pub rec AstIfNode {
    condition: AstId;
    then_branch: AstId;
    or_branches: List[AstIfBranch];
}

pub rec AstLoopNode {
    kind: AstLoopKind;
    condition: Option[AstId];
    body: AstId;
}

pub rec AstBreakNode {
    label: Option[AstIdentifier];
}

pub rec AstContinueNode {
    label: Option[AstIdentifier];
}

pub rec AstCallNode {
    callee: AstId;
    arguments: List[AstId];
    type_arguments: List[AstId];
    is_method_call: bool;
}

pub rec AstBinaryNode {
    left: AstId;
    right: AstId;
    op: TokenKind;
}

pub rec AstUnaryNode {
    operand: AstId;
    op: TokenKind;
    is_prefix: bool;
}

pub rec AstIndexNode {
    target: AstId;
    index: AstId;
}

pub rec AstFieldAccessNode {
    object: AstId;
    field: AstIdentifier;
    is_method: bool;
}

pub rec AstCastNode {
    value: AstId;
    type_id: AstId;
}

pub rec AstIdentifierNode {
    name: AstIdentifier;
    generic_args: List[AstId];
}

pub uni AstLiteralValue {
    int_value:  u64;
    float_value: f64;
    char_value:  u32;
    string_value: string;
}

pub rec AstLiteralNode {
    kind: TokenKind;
    lexeme: string;
    value: AstLiteralValue;
}

pub rec AstNullNode {
    unused: bool;
}

pub rec AstArrayNode {
    element_type: Option[AstId];
