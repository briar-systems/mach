use          std.types.bool;
use          std.types.list;
use          std.types.option;
use          std.types.result;
use          std.types.size;
use          std.types.string;
use console: std.io.console;
use mem:     std.system.memory;

use std.lang.module;
use std.lang.config;
use std.lang.diagnostics;

pub rec Driver {
    config:      *Config;
    modules:     List[Module];
    diagnostics: List[Diagnostic];
}

pub fun (this: *Driver) init(config: *Config) Option[str] {
    mem.zero[Driver](this, 1);

    if (config == nil) {
        ret some[str]("invalid project config");
    }

    this.config = config;

    val opt_modules_init: Option[str] = this.modules.init(4);
    if (opt_modules_init.is_some()) {
        ret opt_modules_init;
    }

    val opt_diagnostics_init: Option[str] = this.diagnostics.init(8);
    if (opt_diagnostics_init.is_some()) {
        ret opt_diagnostics_init;
    }

    ret none[str]();
}

pub fun (this: *Driver) dnit() {
    var i: usize = 0;
    for (i < this.modules.len) {
        val module: *Module = this.modules.data + i;
        module.dnit();
        i = i + 1;
    }

    this.modules.dnit();

    i = 0;
    for (i < this.diagnostics.len) {
        val diag: *Diagnostic = this.diagnostics.data + i;
        diag.dnit();
        i = i + 1;
    }

    this.diagnostics.dnit();

    mem.zero[Driver](this, 1);
}

