use std.types.string;
use std.types.result;
use std.types.bool;

$if (OS == OS_LINUX) {
    use platform: std.system.platform.linux.filesystem;
}

$if (OS == OS_DARWIN) {
    use platform: std.system.platform.darwin.filesystem;
}

$if (OS == OS_WINDOWS) {
    use platform: std.system.platform.windows.filesystem;
}

# error codes
pub val ERR_NONE:          i32 = 0;
pub val ERR_NOT_FOUND:     i32 = -2;   # ENOENT
pub val ERR_PERMISSION:    i32 = -13;  # EACCES
pub val ERR_EXISTS:        i32 = -17;  # EEXIST
pub val ERR_NOT_DIR:       i32 = -20;  # ENOTDIR
pub val ERR_IS_DIR:        i32 = -21;  # EISDIR
pub val ERR_INVALID:       i32 = -22;  # EINVAL
pub val ERR_NO_SPACE:      i32 = -28;  # ENOSPC
pub val ERR_READ_ONLY:     i32 = -30;  # EROFS
pub val ERR_NAME_TOO_LONG: i32 = -36;  # ENAMETOOLONG
pub val ERR_NOT_EMPTY:     i32 = -39;  # ENOTEMPTY
pub val ERR_IO:            i32 = -5;   # EIO
pub val ERR_NO_MEM:        i32 = -12;  # ENOMEM
pub val ERR_UNKNOWN:       i32 = -1;

# file open flags
pub val O_RDONLY:  i32 = 0x0000;
pub val O_WRONLY:  i32 = 0x0001;
pub val O_RDWR:    i32 = 0x0002;
pub val O_CREAT:   i32 = 0o100;
pub val O_EXCL:    i32 = 0o200;
pub val O_TRUNC:   i32 = 0o1000;
pub val O_APPEND:  i32 = 0o2000;

# unix style permissions
pub val MODE_644: i32 = 0o644;  # rw-r--r--
pub val MODE_600: i32 = 0o600;  # rw-------
pub val MODE_755: i32 = 0o755;  # rwxr-xr-x
pub val MODE_700: i32 = 0o700;  # rwx------

# read entire file into memory
pub fun read_all(path: string) Result[[]u8, i32] {
    ret platform.read_file(path);
}

# write data to file, truncating if exists
pub fun write_all(path: string, data: []u8) Result[u64, i32] {
    ret platform.write_file(path, data, O_WRONLY | O_CREAT | O_TRUNC, MODE_644);
}

# append data to file
pub fun append_all(path: string, data: []u8) Result[u64, i32] {
    ret platform.write_file(path, data, O_WRONLY | O_CREAT | O_APPEND, MODE_644);
}

# check if file or directory exists
pub fun exists(path: string) bool {
    ret platform.check_access(path);
}

# remove a file
pub fun remove(path: string) Result[u64, i32] {
    ret platform.unlink_file(path);
}

# remove an empty directory
pub fun remove_dir(path: string) Result[u64, i32] {
    ret platform.unlink_dir(path);
}

# rename or move a file/directory
pub fun rename(oldpath: string, newpath: string) Result[u64, i32] {
    ret platform.rename_path(oldpath, newpath);
}

# create a new directory
pub fun create_dir(path: string, mode: i32) Result[u64, i32] {
    ret platform.make_dir(path, mode);
}

# get file metadata, following symbolic links
pub fun stat(path: string) Result[platform.FileInfo, i32] {
    ret platform.get_stat(path, true);
}

# get file metadata, not following symbolic links
pub fun lstat(path: string) Result[platform.FileInfo, i32] {
    ret platform.get_stat(path, false);
}

# check if path is a directory
pub fun is_dir(path: string) bool {
    val res: Result[platform.FileInfo, i32] = stat(path);
    if (res.is_err()) {
        ret false;
    }
    ret res.unwrap_ok().is_dir;
}

# check if path is a regular file
pub fun is_file(path: string) bool {
    val res: Result[platform.FileInfo, i32] = stat(path);
    if (res.is_err()) {
        ret false;
    }
    ret res.unwrap_ok().is_file;
}

# get file size in bytes
pub fun file_size(path: string) Result[u64, i32] {
    val res: Result[platform.FileInfo, i32] = stat(path);
    if (res.is_err()) {
        ret err[u64, i32](res.unwrap_err());
    }
    ret ok[u64, i32](res.unwrap_ok().size);
}

# convert error code to human-readable message
pub fun error_string(code: i32) string {
    if (code == ERR_NONE) { ret "no error"; }
    if (code == ERR_NOT_FOUND) { ret "file not found"; }
    if (code == ERR_PERMISSION) { ret "permission denied"; }
    if (code == ERR_EXISTS) { ret "file already exists"; }
    if (code == ERR_NOT_DIR) { ret "not a directory"; }
    if (code == ERR_IS_DIR) { ret "is a directory"; }
    if (code == ERR_INVALID) { ret "invalid argument"; }
    if (code == ERR_NO_SPACE) { ret "no space left on device"; }
    if (code == ERR_READ_ONLY) { ret "read-only file system"; }
    if (code == ERR_NAME_TOO_LONG) { ret "file name too long"; }
    if (code == ERR_NOT_EMPTY) { ret "directory not empty"; }
    if (code == ERR_IO) { ret "input/output error"; }
    if (code == ERR_NO_MEM) { ret "out of memory"; }
    ret "unknown error";
}
