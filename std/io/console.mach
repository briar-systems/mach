use std.types.string;
use std.types.result;
use std.types.size;

use mem: std.system.memory;

$if (OS == OS_LINUX) {
    use sys: std.system.platform.linux.sys;
}

$if (OS == OS_DARWIN) {
    use sys: std.system.platform.darwin.sys;
}

$if (OS == OS_WINDOWS) {
    use sys: std.system.platform.windows.sys;
}

pub val STDIN:  i32 = 0;
pub val STDOUT: i32 = 1;
pub val STDERR: i32 = 2;

$if (OS == OS_LINUX || OS == OS_DARWIN) {

    fun platform_write(fd: i32, data: *u8, size: usize) i64 {
        ret sys.write(fd, data, size);
    }

    fun platform_read(fd: i32, dest: *u8, max: usize) i64 {
        ret sys.read(fd, dest, max);
    }
}

$if (OS == OS_WINDOWS) {

    fun windows_handle(fd: i32) *u8 {
        if (fd == STDIN) {
            ret sys.get_std_handle(sys.STD_INPUT_HANDLE);
        }
        or (fd == STDOUT) {
            ret sys.get_std_handle(sys.STD_OUTPUT_HANDLE);
        }
        or (fd == STDERR) {
            ret sys.get_std_handle(sys.STD_ERROR_HANDLE);
        }

        ret nil;
    }

    fun windows_chunked_io(handle: *u8, buffer: *u8, size: usize, is_write: u8) i64 {
        var remaining: usize = size;
        var offset: usize = 0;
        var total: usize = 0;

        for (remaining > 0) {
            var chunk: usize = remaining;
            if (chunk > 0xffff_ffff) {
                chunk = 0xffff_ffff;
            }

            var count32: u32 = 0;
            var ok: u32 = 0;
            if (is_write != 0) {
                ok = sys.write_file(handle, (buffer + offset), chunk :: u32, (?count32) :: *u32);
            } or {
                ok = sys.read_file(handle, (buffer + offset), chunk :: u32, (?count32) :: *u32);
            }

            if (ok == 0) {
                ret -1;
            }

            val processed: usize = count32 :: usize;
            if (processed == 0) {
                brk;
            }

            offset = offset + processed;
            total = total + processed;
            remaining = remaining - processed;
        }

        ret total :: i64;
    }

    fun platform_write(fd: i32, data: *u8, size: usize) i64 {
        val handle: *u8 = windows_handle(fd);
        if (handle == nil || (handle :: i64) == -1) {
            ret -1;
        }

        ret windows_chunked_io(handle, data, size, 1);
    }

    fun platform_read(fd: i32, dest: *u8, max: usize) i64 {
        val handle: *u8 = windows_handle(fd);
        if (handle == nil || (handle :: i64) == -1) {
            ret -1;
        }

        ret windows_chunked_io(handle, dest, max, 0);
    }
}

fun write_segment(fd: i32, part: string) i64 {
    if (part.len == 0) { ret 0; }
    ret platform_write(fd, part.data, part.len);
}

pub fun write_to(fd: i32, pattern: string, ...) i64 {
    val extra: usize = va_count();
    if (extra == 0) {
        ret write_segment(fd, pattern);
    }

    val res: Result[string, string] = pattern.format(...);
    if (res.is_err()) {
        # TODO: cascade result
        ret -1;
    }

    val rendered: string = res.unwrap_ok();
    if (rendered.len == 0) {
        ret 0;
    }

    val wrote: i64 = write_segment(fd, rendered);

    if (rendered.data != nil) {
        mem.dealloc[u8](rendered.data, rendered.len);
    }

    ret wrote;
}

pub fun write(pattern: string, ...) i64 {
    ret write_to(STDOUT, pattern, ...);
}

pub fun print(pattern: string, ...) i64 {
    ret write_to(STDOUT, pattern, ...);
}

pub fun error(pattern: string, ...) i64 {
    ret write_to(STDERR, pattern, ...);
}

pub fun read_from(fd: i32, dest: *u8, max: usize) i64 {
    if (dest == nil || max == 0) {
        ret 0;
    }
    ret platform_read(fd, dest, max);
}

pub fun read(dest: *u8, max: usize) i64 {
    ret read_from(STDIN, dest, max);
}
