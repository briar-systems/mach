$if (OS == OS_LINUX) {
    use memory: std.system.platform.linux.memory;
}

$if (OS == OS_DARWIN) {
    use memory: std.system.platform.darwin.memory;
}

$if (OS == OS_WINDOWS) {
    use memory: std.system.platform.windows.memory;
}

use std.types.size;
use std.types.option;

