pub fun raw_fill(p: ptr, value: u8, size: usize) {
    if (p == nil || size == 0) {
        ret;
    }

    var i: usize = 0;
    val bytes: *u8 = (p::*u8);
    for (i < size) {
        @(bytes + i) = value;
        i = i + 1;
    }
}

pub fun raw_copy(dst: ptr, src: ptr, size: usize) {
    if (dst == nil || src == nil || size == 0) {
        ret;
    }

    var i: usize = 0;
    val dst_bytes: *u8 = (dst::*u8);
    val src_bytes: *u8 = (src::*u8);
    for (i < size) {
        val b: u8 = @(src_bytes + i);
        @(dst_bytes + i) = b;
        i = i + 1;
    }
}

pub fun raw_zero(p: ptr, size: usize) {
    raw_fill(p, 0, size);
}

pub fun allocate[T](count: usize) Result[*T, string] {
    if (count == 0) {
        ret err[*T, string]("cannot allocate zero elements");
    }

    val size:  usize = $size_of(T);
    val total: usize = size * count;
    if (size != 0 && total / size != count) {
        ret err[*T, string]("allocation size overflow");
    }

    val mem: *T = memory.allocate(total)::*T;
    if (mem == nil) {
        ret err[*T, string]("system allocation failed");
    }

    ret ok[*T, string](mem);
}

pub fun zallocate[T](count: usize) Result[*T, string] {
    val alloc_result: Result[*T, string] = allocate[T](count);
    if (alloc_result.is_err()) {
        ret err[*T, string]("failed to allocate zeroed memory: " + alloc_result.unwrap_err());
    }

    val mem: *T = alloc_result.unwrap_ok();
    zero[T](mem, count);

    ret ok[*T, string](mem);
}

pub fun deallocate[T](p: *T, count: usize) Option[string] {
    if (p == nil || count == 0) {
        # NOTE: do not explicitly fail. Deallocating nil or zero size is a no-op.
        ret none[string]();
    }

    val res: bool = memory.deallocate(p::ptr, $size_of(T) * count);
    if (!res) {
        ret some[string]("system deallocation failed");
    }

    ret none[string]();
}

pub fun reallocate[T](p: *T, old_count: usize, new_count: usize) Result[*T, string] {
    if (new_count == 0) {
        ret err[*T, string]("cannot reallocate to zero elements");
    }

    val elem_size: usize = $size_of(T);
    val old_size:  usize = elem_size * old_count;
    val new_size:  usize = elem_size * new_count;

    # check for size overflow
    if (elem_size != 0 && new_size / elem_size != new_count) {
        ret err[*T, string]("reallocation size overflow");
    }

    # use platform-specific reallocate
    val new_mem: *T = memory.reallocate(p::ptr, old_size, new_size)::*T;
    if (new_mem == nil) {
        ret err[*T, string]("system reallocation failed");
    }

    ret ok[*T, string](new_mem);
}

pub fun fill[T](p: *T, value: T, count: usize) {
    if (p == nil || count == 0) {
        ret;
    }

    var i: usize = 0;
    for (i < count) {
        @(p + i) = value;
        i = i + 1;
    }
}

pub fun copy[T](dst: *T, src: *T, count: usize) {
    if (dst == nil || src == nil || count == 0) {
        ret;
    }

    var i: usize = 0;
    for (i < count) {
        @(dst + i) = @(src + i);
        i = i + 1;
    }
}

pub fun zero[T](p: *T, count: usize) {
    if (p == nil || count == 0) {
        ret;
    }

    var size: usize = $size_of(T) * count;
    raw_zero(p::ptr, size);
}
