use std.system.platform.linux.syscall;
use std.types.size;

pub val SYS_READ:          u64 = 0;
pub val SYS_WRITE:         u64 = 1;
pub val SYS_CLOSE:         u64 = 3;
pub val SYS_FSTAT:         u64 = 5;
pub val SYS_LSEEK:         u64 = 8;
pub val SYS_MMAP:          u64 = 9;
pub val SYS_MUNMAP:        u64 = 11;
pub val SYS_UNLINKAT:      u64 = 263;
pub val SYS_RENAMEAT:      u64 = 264;
pub val SYS_MKDIRAT:       u64 = 258;
pub val SYS_NEWFSTATAT:    u64 = 262;
pub val SYS_GETDENTS64:    u64 = 217;
pub val SYS_FACCESSAT:     u64 = 269;
pub val SYS_CLOCK_GETTIME: u64 = 228;
pub val SYS_OPENAT:        u64 = 257;

pub val AT_FDCWD: i32 = -100;

fun sext_i32(value: i32) u64 {
	ret (value::i64)::u64;
}

pub fun read(fd: i32, buf: *u8, count: usize) i64 {
	ret syscall3(SYS_READ, sext_i32(fd), (buf::u64), count::u64);
}

pub fun write(fd: i32, buf: *u8, count: usize) i64 {
	ret syscall3(SYS_WRITE, sext_i32(fd), (buf::u64), count::u64);
}

pub fun openat(dirfd: i32, path: *u8, flags: i32, mode: i32) i64 {
	ret syscall4(SYS_OPENAT, sext_i32(dirfd), (path::u64), (flags::u64), (mode::u64));
}

pub fun close(fd: i32) i64 {
	ret syscall1(SYS_CLOSE, sext_i32(fd));
}

pub fun mmap(addr: *u8, length: usize, prot: i32, flags: i32, fd: i32, offset: i64) *u8 {
	val res: i64 = syscall6(
		SYS_MMAP,
		(addr::u64),
		length::u64,
		(prot::u64),
		(flags::u64),
		sext_i32(fd),
		(offset::u64)
	);

	if (res < 0) {
		ret nil;
	}

	ret (res::u64)::*u8;
}

pub fun munmap(addr: *u8, length: usize) i32 {
	val res: i64 = syscall2(SYS_MUNMAP, (addr::u64), length::u64);

	if (res < 0) {
		ret -1;
	}

	ret 0;
}

pub fun clock_gettime(clock_id: i32, ts: *u8) i32 {
	val res: i64 = syscall2(SYS_CLOCK_GETTIME, (clock_id::u64), (ts::u64));

	if (res < 0) {
		ret -1;
	}

	ret (res::i32);
}

pub fun fstat(fd: i32, statbuf: *u8) i64 {
	ret syscall2(SYS_FSTAT, sext_i32(fd), (statbuf::u64));
}

pub fun newfstatat(dirfd: i32, path: *u8, statbuf: *u8, flags: i32) i64 {
	ret syscall4(SYS_NEWFSTATAT, sext_i32(dirfd), (path::u64), (statbuf::u64), (flags::u64));
}

pub fun unlinkat(dirfd: i32, path: *u8, flags: i32) i64 {
	ret syscall3(SYS_UNLINKAT, sext_i32(dirfd), (path::u64), (flags::u64));
}

pub fun renameat(olddirfd: i32, oldpath: *u8, newdirfd: i32, newpath: *u8) i64 {
	ret syscall4(SYS_RENAMEAT, sext_i32(olddirfd), (oldpath::u64), sext_i32(newdirfd), (newpath::u64));
}

pub fun mkdirat(dirfd: i32, path: *u8, mode: i32) i64 {
	ret syscall3(SYS_MKDIRAT, sext_i32(dirfd), (path::u64), (mode::u64));
}

pub fun getdents64(fd: i32, dirp: *u8, count: usize) i64 {
	ret syscall3(SYS_GETDENTS64, sext_i32(fd), (dirp::u64), count::u64);
}

pub fun faccessat(dirfd: i32, path: *u8, mode: i32, flags: i32) i64 {
	ret syscall4(SYS_FACCESSAT, sext_i32(dirfd), (path::u64), (mode::u64), (flags::u64));
}

pub fun lseek(fd: i32, offset: i64, whence: i32) i64 {
	ret syscall3(SYS_LSEEK, sext_i32(fd), (offset::u64), (whence::u64));
}
