use      std.types.bool;
use      std.types.list;
use      std.types.option;
use      std.types.result;
use      std.types.size;
use      std.types.string;
use      std.text.ascii;
use mem: std.system.memory;

# json value types
pub val JSON_NULL:   u32 = 0;
pub val JSON_BOOL:   u32 = 1;
pub val JSON_NUMBER: u32 = 2;
pub val JSON_STRING: u32 = 3;
pub val JSON_ARRAY:  u32 = 4;
pub val JSON_OBJECT: u32 = 5;

pub rec JsonValue {
    tag:  u32;
    data: uni {
        bool_val:   bool;
        number_val: f64;
        string_val: string;
        array_val:  *List[JsonValue];
        object_val: *List[JsonProperty];
    };
}

pub rec JsonProperty {
    key:   string;
    value: JsonValue;
}

rec JsonParser {
    input: string;
    pos:   usize;
}

# constructors
pub fun json_null() JsonValue {
    var v: JsonValue;
    v.tag = JSON_NULL;
    ret v;
}

pub fun json_bool(value: bool) JsonValue {
    var v: JsonValue;
    v.tag = JSON_BOOL;
    v.data.bool_val = value;
    ret v;
}

pub fun json_number(value: f64) JsonValue {
    var v: JsonValue;
    v.tag = JSON_NUMBER;
    v.data.number_val = value;
    ret v;
}

pub fun json_string(value: string) JsonValue {
    var v: JsonValue;
    v.tag = JSON_STRING;
    v.data.string_val = value;
    ret v;
}

pub fun json_array(value: *List[JsonValue]) JsonValue {
    var v: JsonValue;
    v.tag = JSON_ARRAY;
    v.data.array_val = value;
    ret v;
}

pub fun json_object(value: *List[JsonProperty]) JsonValue {
    var v: JsonValue;
    v.tag = JSON_OBJECT;
    v.data.object_val = value;
    ret v;
}

# lifecycle
pub fun (this: *JsonValue) init() {
    this.tag = JSON_NULL;
    this.data.string_val.data = nil;
    this.data.string_val.len  = 0;
    this.data.array_val = nil;
    this.data.object_val = nil;
}

pub fun (this: *JsonValue) dnit() {
    # TODO: freeing union string field causes compiler bug with LLVM IR generation
    if (this.tag == JSON_STRING) {
        this.data.string_val.dnit();
    }
    or (this.tag == JSON_ARRAY) {
        if (this.data.array_val != nil) {
            var i: usize = 0;
            for (i < this.data.array_val.len) {
                val item: *JsonValue = this.data.array_val.data + i;
                item.dnit();
                i = i + 1;
            }

            this.data.array_val.dnit();
            mem.dealloc[List[JsonValue]](this.data.array_val, 1);
            this.data.array_val = nil;
        }
    }
    or (this.tag == JSON_OBJECT) {
        if (this.data.object_val != nil) {
            var i: usize = 0;
            for (i < this.data.object_val.len) {
                val prop: *JsonProperty = this.data.object_val.data + i;
                # TODO: freeing fields through pointer causes compiler bug
                val key_ptr: *string = ?prop.key;
                key_ptr.dnit();
                val value_ptr: *JsonValue = ?prop.value;
                value_ptr.dnit();
                i = i + 1;
            }
            this.data.object_val.dnit();
            mem.dealloc[List[JsonProperty]](this.data.object_val, 1);
            this.data.object_val = nil;
        }
    }

    this.tag = JSON_NULL;
    this.data.string_val.data = nil;
    this.data.string_val.len  = 0;
    this.data.array_val = nil;
    this.data.object_val = nil;
}

# type checks
pub fun (this: JsonValue) is_null() bool {
    ret this.tag == JSON_NULL;
}

pub fun (this: JsonValue) is_bool() bool {
    ret this.tag == JSON_BOOL;
}

pub fun (this: JsonValue) is_number() bool {
    ret this.tag == JSON_NUMBER;
}

pub fun (this: JsonValue) is_string() bool {
    ret this.tag == JSON_STRING;
}

pub fun (this: JsonValue) is_array() bool {
    ret this.tag == JSON_ARRAY;
}

pub fun (this: JsonValue) is_object() bool {
    ret this.tag == JSON_OBJECT;
}

# value getters
pub fun (this: JsonValue) as_bool() Option[bool] {
    if (this.tag == JSON_BOOL) {
        ret some[bool](this.data.bool_val);
    }
    ret none[bool]();
}

pub fun (this: JsonValue) as_number() Option[f64] {
    if (this.tag == JSON_NUMBER) {
        ret some[f64](this.data.number_val);
    }
    ret none[f64]();
}

pub fun (this: JsonValue) as_string() Option[string] {
    if (this.tag == JSON_STRING) {
        ret some[string](this.data.string_val);
    }
    ret none[string]();
}

pub fun (this: JsonValue) as_array() Option[*List[JsonValue]] {
    if (this.tag == JSON_ARRAY) {
        ret some[*List[JsonValue]](this.data.array_val);
    }
    ret none[*List[JsonValue]]();
}

pub fun (this: JsonValue) as_object() Option[*List[JsonProperty]] {
    if (this.tag == JSON_OBJECT) {
        ret some[*List[JsonProperty]](this.data.object_val);
    }
    ret none[*List[JsonProperty]]();
}

# parser helpers
fun (this: *JsonParser) current() u8 {
    if (this.pos >= this.input.len) {
        ret 0;
    }
    ret @(this.input.data + this.pos);
}

fun (this: *JsonParser) peek(offset: usize) u8 {
    val idx: usize = this.pos + offset;
    if (idx >= this.input.len) {
        ret 0;
    }
    ret @(this.input.data + idx);
}

fun (this: *JsonParser) advance() {
    if (this.pos < this.input.len) {
        this.pos = this.pos + 1;
    }
}

fun (this: *JsonParser) skip_whitespace() {
    for (this.pos < this.input.len) {
        val ch: u8 = this.current();
        if (ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r') {
            this.advance();
        } or {
            brk;
        }
    }
}

fun (this: *JsonParser) match_keyword(keyword: string) bool {
    var i: usize = 0;
    for (i < keyword.len) {
        if (this.peek(i) != @(keyword.data + i)) {
            ret false;
        }
        i = i + 1;
    }
    this.pos = this.pos + keyword.len;
    ret true;
}

fun (this: *JsonParser) parse_string_content() Result[string, string] {
    val start: usize = this.pos;
    var len: usize = 0;
    var has_escapes: bool = false;

    for (this.pos < this.input.len) {
        val ch: u8 = this.current();

        if (ch == '"') {
            brk;
        }
        or (ch == '\\') {
            has_escapes = true;
            this.advance();
            if (this.pos >= this.input.len) {
                ret err[string, string]("unexpected end in escape sequence");
            }
            this.advance();
            len = len + 1;
        }
        or (ch < 32) {
            ret err[string, string]("invalid control character in string");
        }
        or {
            this.advance();
            len = len + 1;
        }
    }

    # allocate string buffer
    val buffer: *u8 = mem.alloc[u8](len);
    if (buffer == nil) {
        ret err[string, string]("failed to allocate string buffer");
    }

    # copy and process escapes
    var write_pos: usize = 0;
    var read_pos: usize = start;

    for (read_pos < this.pos) {
        val ch: u8 = @(this.input.data + read_pos);

        if (ch == '\\') {
            read_pos = read_pos + 1;
            if (read_pos >= this.pos) {
                brk;
            }

            val esc: u8 = @(this.input.data + read_pos);
            if (esc == 'n') {
                @(buffer + write_pos) = 10;
            }
            or (esc == 't') {
                @(buffer + write_pos) = 9;
            }
            or (esc == 'r') {
                @(buffer + write_pos) = 13;
            }
            or (esc == '\\') {
                @(buffer + write_pos) = '\\';
            }
            or (esc == '"') {
                @(buffer + write_pos) = '"';
            }
            or (esc == '/') {
                @(buffer + write_pos) = '/';
            }
            or (esc == 'b') {
                @(buffer + write_pos) = 8;
            }
            or (esc == 'f') {
                @(buffer + write_pos) = 12;
            }
            or {
                @(buffer + write_pos) = esc;
            }

            write_pos = write_pos + 1;
            read_pos = read_pos + 1;
        }
        or {
            @(buffer + write_pos) = ch;
            write_pos = write_pos + 1;
            read_pos = read_pos + 1;
        }
    }

    var result: string;
    result.data = buffer;
    result.len = len;
    ret ok[string, string](result);
}

fun (this: *JsonParser) parse_string() Result[JsonValue, string] {
    if (this.current() != '"') {
        ret err[JsonValue, string]("expected '\"'");
    }

    this.advance();
    val str_result: Result[string, string] = this.parse_string_content();

    if (str_result.is_err()) {
        ret err[JsonValue, string](str_result.unwrap_err());
    }

    if (this.current() != '"') {
        val s: string = str_result.unwrap_ok();
    val s_ptr: *string = ?s;
    s_ptr.dnit();
        ret err[JsonValue, string]("unterminated string");
    }

    this.advance();
    ret ok[JsonValue, string](json_string(str_result.unwrap_ok()));
}

fun (this: *JsonParser) parse_number() Result[JsonValue, string] {
    val start: usize = this.pos;
    var is_negative: bool = false;

    # optional minus
    if (this.current() == '-') {
        is_negative = true;
        this.advance();
    }

    if (is_digit(this.current()) == 0) {
        ret err[JsonValue, string]("expected digit");
    }

    # integer part
    for (this.pos < this.input.len && is_digit(this.current())) {
        this.advance();
    }

    var is_float: bool = false;

    # optional fractional part
    if (this.current() == '.') {
        is_float = true;
        this.advance();

        if (is_digit(this.current()) == 0) {
            ret err[JsonValue, string]("expected digit after decimal point");
        }

        for (this.pos < this.input.len && is_digit(this.current())) {
            this.advance();
        }
    }

    # optional exponent
    val ch: u8 = this.current();
    if (ch == 'e' || ch == 'E') {
        is_float = true;
        this.advance();

        val exp_ch: u8 = this.current();
        if (exp_ch == '+' || exp_ch == '-') {
            this.advance();
        }

        if (is_digit(this.current()) == 0) {
            ret err[JsonValue, string]("expected digit in exponent");
        }

        for (this.pos < this.input.len && is_digit(this.current())) {
            this.advance();
        }
    }

    # parse number from string slice
    val num_len: usize = this.pos - start;
    val num_data: *u8 = this.input.data + start;

    # simple integer parsing
    var value: f64 = 0.0;
    var i: usize = start;

    if (is_negative) {
        i = i + 1;
    }

    # parse integer part
    for (i < this.pos) {
        val digit_ch: u8 = @(this.input.data + i);
        if (digit_ch == '.' || digit_ch == 'e' || digit_ch == 'E') {
            brk;
        }
        val d: i32 = digit_val(digit_ch);
        if (d < 0 || d > 9) {
            brk;
        }
        value = value * 10.0 + (d::f64);
        i = i + 1;
    }

    # parse fractional part if present
    if (i < this.pos && @(this.input.data + i) == '.') {
        i = i + 1;
        var divisor: f64 = 10.0;
        for (i < this.pos) {
            val digit_ch: u8 = @(this.input.data + i);
            if (digit_ch == 'e' || digit_ch == 'E') {
                brk;
            }
            val d: i32 = digit_val(digit_ch);
            if (d < 0 || d > 9) {
                brk;
            }
            value = value + ((d::f64) / divisor);
            divisor = divisor * 10.0;
            i = i + 1;
        }
    }

    if (is_negative) {
        value = 0.0 - value;
    }

    ret ok[JsonValue, string](json_number(value));
}

fun (this: *JsonParser) parse_array() Result[JsonValue, string] {
    if (this.current() != '[') {
        ret err[JsonValue, string]("expected '['");
    }

    this.advance();
    this.skip_whitespace();

    val list_ptr: *List[JsonValue] = mem.alloc[List[JsonValue]](1);
    if (list_ptr == nil) {
        ret err[JsonValue, string]("failed to allocate array list");
    }

    val list_result: Result[List[JsonValue], string] = list_new[JsonValue](4);
    if (list_result.is_err()) {
        mem.dealloc[List[JsonValue]](list_ptr, 1);
        ret err[JsonValue, string](list_result.unwrap_err());
    }

    @list_ptr = list_result.unwrap_ok();

    # empty array
    if (this.current() == ']') {
        this.advance();
        ret ok[JsonValue, string](json_array(list_ptr));
    }

    for {
        val elem_result: Result[JsonValue, string] = this.parse_value();
        if (elem_result.is_err()) {
            list_ptr.dnit();
            mem.dealloc[List[JsonValue]](list_ptr, 1);
            ret err[JsonValue, string](elem_result.unwrap_err());
        }

        val push_err: Option[string] = list_ptr.push(elem_result.unwrap_ok());
        if (push_err.is_some()) {
            list_ptr.dnit();
            mem.dealloc[List[JsonValue]](list_ptr, 1);
            ret err[JsonValue, string](push_err.unwrap());
        }

        this.skip_whitespace();

        if (this.current() == ']') {
            this.advance();
            brk;
        }
        or (this.current() == ',') {
            this.advance();
            this.skip_whitespace();
        }
        or {
            list_ptr.dnit();
            mem.dealloc[List[JsonValue]](list_ptr, 1);
            ret err[JsonValue, string]("expected ',' or ']' in array");
        }
    }

    ret ok[JsonValue, string](json_array(list_ptr));
}

fun (this: *JsonParser) parse_object() Result[JsonValue, string] {
    if (this.current() != '{') {
        ret err[JsonValue, string]("expected '{'");
    }

    this.advance();
    this.skip_whitespace();

    val list_ptr: *List[JsonProperty] = mem.alloc[List[JsonProperty]](1);
    if (list_ptr == nil) {
        ret err[JsonValue, string]("failed to allocate object list");
    }

    val list_result: Result[List[JsonProperty], string] = list_new[JsonProperty](4);
    if (list_result.is_err()) {
        mem.dealloc[List[JsonProperty]](list_ptr, 1);
        ret err[JsonValue, string](list_result.unwrap_err());
    }

    @list_ptr = list_result.unwrap_ok();

    # empty object
    if (this.current() == '}') {
        this.advance();
        ret ok[JsonValue, string](json_object(list_ptr));
    }

    for {
        # parse key
        if (this.current() != '"') {
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string]("expected string key");
        }

        this.advance();
        val key_result: Result[string, string] = this.parse_string_content();
        if (key_result.is_err()) {
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string](key_result.unwrap_err());
        }

        if (this.current() != '"') {
            val k: string = key_result.unwrap_ok();
            val k_ptr: *string = ?k;
            k_ptr.dnit();
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string]("unterminated key string");
        }

        this.advance();
        this.skip_whitespace();

        # expect colon
        if (this.current() != ':') {
            val k: string = key_result.unwrap_ok();
            val k_ptr: *string = ?k;
            k_ptr.dnit();
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string]("expected ':' after key");
        }

        this.advance();
        this.skip_whitespace();

        # parse value
        val val_result: Result[JsonValue, string] = this.parse_value();
        if (val_result.is_err()) {
            val k: string = key_result.unwrap_ok();
            val k_ptr: *string = ?k;
            k_ptr.dnit();
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string](val_result.unwrap_err());
        }

        var prop: JsonProperty;
        prop.key = key_result.unwrap_ok();
        prop.value = val_result.unwrap_ok();

        val push_err: Option[string] = list_ptr.push(prop);
        if (push_err.is_some()) {
            # TODO: freeing fields through pointer causes compiler bug
            # val key_ptr: *string = ?prop.key;
            # key_ptr.dnit();
            # val value_ptr: *JsonValue = ?prop.value;
            # value_ptr.dnit();
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string](push_err.unwrap());
        }

        this.skip_whitespace();

        if (this.current() == '}') {
            this.advance();
            brk;
        }
        or (this.current() == ',') {
            this.advance();
            this.skip_whitespace();
        }
        or {
            list_ptr.dnit();
            mem.dealloc[List[JsonProperty]](list_ptr, 1);
            ret err[JsonValue, string]("expected ',' or '}' in object");
        }
    }

    ret ok[JsonValue, string](json_object(list_ptr));
}

fun (this: *JsonParser) parse_value() Result[JsonValue, string] {
    this.skip_whitespace();

    val ch: u8 = this.current();

    if (ch == 'n') {
        if (this.match_keyword("null")) {
            ret ok[JsonValue, string](json_null());
        }
        ret err[JsonValue, string]("invalid keyword");
    }
    or (ch == 't') {
        if (this.match_keyword("true")) {
            ret ok[JsonValue, string](json_bool(true));
        }
        ret err[JsonValue, string]("invalid keyword");
    }
    or (ch == 'f') {
        if (this.match_keyword("false")) {
            ret ok[JsonValue, string](json_bool(false));
        }
        ret err[JsonValue, string]("invalid keyword");
    }
    or (ch == '"') {
        ret this.parse_string();
    }
    or (ch == '[') {
        ret this.parse_array();
    }
    or (ch == '{') {
        ret this.parse_object();
    }
    or (ch == '-' || is_digit(ch)) {
        ret this.parse_number();
    }
    or {
        ret err[JsonValue, string]("unexpected character");
    }
}

# main parse function
pub fun parse_json(input: string) Result[JsonValue, string] {
    if (input.data == nil) {
        ret err[JsonValue, string]("input is null");
    }

    var parser: JsonParser;
    parser.input = input;
    parser.pos = 0;

    val result: Result[JsonValue, string] = parser.parse_value();

    if (result.is_err()) {
        ret result;
    }

    parser.skip_whitespace();

    if (parser.pos < input.len) {
        var value: JsonValue = result.unwrap_ok();
        val value_ptr: *JsonValue = ?value;
    value_ptr.dnit();
        ret err[JsonValue, string]("unexpected data after json value");
    }

    ret result;
}

# object lookup helper
pub fun (this: JsonValue) get_property(key: string) Option[JsonValue] {
    if (this.tag != JSON_OBJECT || this.data.object_val == nil) {
        ret none[JsonValue]();
    }

    var i: usize = 0;
    for (i < this.data.object_val.len) {
        val prop: *JsonProperty = this.data.object_val.data + i;
        if (prop.key.equals(key)) {
            ret some[JsonValue](prop.value);
        }
        i = i + 1;
    }

    ret none[JsonValue]();
}

# array index helper
pub fun (this: JsonValue) get_index(index: usize) Option[JsonValue] {
    if (this.tag != JSON_ARRAY || this.data.array_val == nil) {
        ret none[JsonValue]();
    }

    if (index >= this.data.array_val.len) {
        ret none[JsonValue]();
    }

    ret some[JsonValue](@(this.data.array_val.data + index));
}
